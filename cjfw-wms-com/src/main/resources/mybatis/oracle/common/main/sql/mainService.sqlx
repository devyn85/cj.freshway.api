<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="oldMainService">
	<select id="getMenuMainViewList" resultType="HMap">
        SELECT /* [menuService.sqlx][getMenuMainViewList][20180306][CJ Developer.] */
        		MENU_ID,
				MENU_NM,
				MENU_URL,
				UPPER_MENU_ID,
				SORT_ORDER,
				MENU_YN,
				USE_YN
        FROM	TB_CF_MENU   
        WHERE   MENU_YN = '1'    
        ORDER BY SORT_ORDER
    </select>
    
    <select id="getMenuRoleMainViewList" resultType="MainMenuGetResDto">
        SELECT /* [menuService.sqlx][getMenuRoleMainViewList][20180306][CJ Developer.] */
	        	B.MENU_ID,
				C.MENU_NM,
				B.MENU_URL,
				B.UPPER_MENU_ID,
				B.SORT_ORDER,
				MAX(NVL(A.MENU_YN,'0')) AS MENU_YN,
				MAX(NVL(A.USE_YN,'0')) AS USE_YN,
				MAX(NVL(A.SEARCH_YN,'0')) AS SEARCH_YN,
	            MAX(NVL(A.NEW_YN,'0')) AS NEW_YN,
	            MAX(NVL(A.DELETE_YN,'0')) AS DELETE_YN,
	            MAX(NVL(A.SAVE_YN,'0')) AS SAVE_YN,
	            MAX(NVL(A.PRINT_YN,'0')) AS PRINT_YN,
	            MAX(NVL(A.EXCEL_YN,'0')) AS EXCEL_YN,
	            MAX(NVL(A.BTN1_YN,'0')) AS BTN1_YN,
	            MAX(NVL(A.BTN2_YN,'0')) AS BTN2_YN,
	            MAX(NVL(A.BTN3_YN,'0')) AS BTN3_YN,
	            MAX(NVL(A.BTN4_YN,'0')) AS BTN4_YN,
	            MAX(NVL(A.BTN5_YN,'0')) AS BTN5_YN,
	            MAX(NVL(A.BTN6_YN,'0')) AS BTN6_YN,
	            MAX(NVL(A.BTN7_YN,'0')) AS BTN7_YN,
	            MAX(NVL(A.BTN8_YN,'0')) AS BTN8_YN,
	            MAX(NVL(A.BTN9_YN,'0')) AS BTN9_YN,
	            MAX(NVL(A.BTN10_YN,'0')) AS BTN10_YN
        FROM	TB_CF_MENU_ROLE A JOIN TB_CF_MENU B ON A.MENU_ID = B.MENU_ID
        JOIN    TB_CF_MENU_I18N C ON B.MENU_ID = C.MENU_ID
        WHERE   B.MENU_YN = '1'   
          AND   A.MENU_YN = '1'   
          AND   A.USE_YN      = '1' 
          AND   A.AUTHORITY IN
		<foreach collection="gRoles" item="item" index="index" open="(" close=")" separator=",">
			#{item}
		</foreach>
		  AND C.LANGUAGE_CD = #{locale}
		GROUP BY B.MENU_ID, C.MENU_NM, B.MENU_URL, B.UPPER_MENU_ID, B.SORT_ORDER
        ORDER BY B.SORT_ORDER
    </select>

    <select id="getSiteMapMenuList" resultType="SiteMapMenuGetResDto">
        SELECT /* [menuService.sqlx][getSiteMapMenuList][20230719][CJ Developer.] */
            B.MENU_ID,
            C.MENU_NM,
            case when MAX(NVL(A.USE_YN,'0')) = '1' then B.menu_url else '' end as menu_URL,
            B.UPPER_MENU_ID,
            case when d.user_id is not null then '1' else '0' end as favorite_YN ,
            MAX(NVL(A.USE_YN,'0')) AS USE_YN
        FROM	TB_CF_MENU B
        LEFT JOIN TB_CF_MENU_ROLE A
             ON ( A.MENU_ID = B.MENU_ID
                  AND A.AUTHORITY IN
                  <foreach collection="gRoles" item="item" index="index" open="(" close=")" separator=",">
                      #{item}
                  </foreach>
                )
        JOIN  TB_CF_MENU_I18N C ON B.MENU_ID = C.MENU_ID
        LEFT JOIN TB_CF_USERS_MYMENU D on B.MENU_ID = D.MENU_ID and d.user_id =#{userId}
        WHERE   B.MENU_YN = '1'
          and   B.use_yn = '1'
          AND C.LANGUAGE_CD = #{locale}
        GROUP BY B.MENU_ID, C.MENU_NM, B.MENU_URL, B.UPPER_MENU_ID, B.SORT_ORDER, d.user_id
        ORDER BY B.SORT_ORDER
    </select>

    <select id="getUsersMyMenuList" resultType="UserMyMenuGetResDto">
        SELECT /* [menuService.sqlx][getUsersMyMenuList][즐겨찾기 메뉴 목록 조회][20220708][ssj] */
        		MENU_ID,
				MENU_NM,
				MENU_URL
        FROM	TB_CF_USERS_MYMENU   
        WHERE   USER_ID = #{userId}
    </select>
    
    <select id="getUsersMyMenu" resultType="int">
        SELECT /* [menuService.sqlx][getUsersMyMenu][즐겨찾기 메뉴 추가 시 이미 등록된 메뉴인지 확인 여부][20220708][ssj] */
				COUNT(*)
        FROM	TB_CF_USERS_MYMENU   
        WHERE   USER_ID = #{userId}
        AND		MENU_ID = #{menuId}
    </select>
    
    <insert id="insertUsersMyMenu">
        INSERT /* [menuService.sqlx][insertUsersMyMenu][즐겨찾기 메뉴 추가][20220708][ssj] */
        INTO TB_CF_USERS_MYMENU (
        	USER_ID,
        	MENU_ID,
			MENU_NM,
			MENU_URL
		)
        VALUES (
        	#{userId},
        	#{menuId},
			#{menuNm},
			#{menuUrl}
        )
    </insert>
    
	<delete id="deleteUsersMyMenu">
        DELETE /* [menuService.sqlx][deleteUsersMyMenu][즐겨찾기 메뉴 삭제][20220708][ssj] */
        FROM	TB_CF_USERS_MYMENU
        WHERE	USER_ID	= #{userId}
        AND		MENU_ID	= #{menuId}
    </delete>
    
	<select id="getCurrentUser" resultType="MainUserGetResDto">
        SELECT /* [mainService.sqlx][user][20220315][정민성] */
	           A.USER_ID
	         , A.USER_NM
	         , A.MAIL_ADDR
	         , A.EMP_NO
	         , A.COM_CD
	      FROM TB_CF_USERS A
	     WHERE A.USER_ID = #{userId}
    </select>
    
	<select id="groupCd" resultType="HMap">
        SELECT /* [mainService.sqlx][groupCd][20220315][정민성] */
	           COM_GRP_CD
		     , GRP_CD_NM
		     , GRP_CD_DESC
	      FROM TB_CM_CD_GRP
	     WHERE USE_YN = '1'
	     ORDER BY COM_GRP_CD
    </select>
    
	<select id="commonCd" resultType="HMap">
        SELECT /* [mainService.sqlx][commonCd][20220315][정민성] */
		       COM_GRP_CD
	         , COM_CD
		     , CD_NM
		     , SORT_NO
		     , CD_DESC
		     , RSV_STR1_VAL
		     , RSV_STR2_VAL
		     , RSV_STR3_VAL
		     , RSV_STR4_VAL
		     , RSV_STR5_VAL
		     , RSV_STR6_VAL
		     , RSV_STR7_VAL
		     , RSV_STR8_VAL
	      FROM TB_CM_CD_DTL A
	     WHERE USE_YN = '1'
	     ORDER BY COM_GRP_CD, SORT_NO
    </select>

    <select id="getLoginLogOutList" resultType="LoginHistoryGetResDto">
        <![CDATA[
        SELECT /* [mainService.sqlx][getLoinoutList][로그인 이력 조회][20220712][ssj] */
            IP_ADDR AS ipAddr
			, LOG_DTM AS logDtm
            , LOG_TYPE AS logType
        FROM (SELECT 	IP_ADDR,
                        LOG_DTM,
                        CASE LOG_TYPE WHEN '1' THEN 'Login' WHEN '0' THEN 'Logout' END AS LOG_TYPE,
                        ROW_NUMBER() OVER(ORDER BY LOG_DTM DESC) AS ROWCNT
              FROM	TB_CF_LOGIN_LOG
              WHERE	USER_ID = #{userId}
             ) A
        WHERE ROWCNT <= 30
        ]]>
    </select>

    <select id="getLatestLoginHist" resultType="LoginHistoryGetResDto">
		<![CDATA[
        SELECT /* [mainService.sqlx][getLatestLoginHist][최근 로그인 이력 조회][20220712][ssj] */
            A.IP_ADDR AS ipAddr
            , A.LOG_DTM AS logDtm
            , CASE A.LOG_TYPE WHEN '1' THEN 'Login' WHEN '0' THEN 'Logout' END AS logType
        FROM(
                SELECT IP_ADDR,
                       LOG_DTM,
                       LOG_TYPE,
                       USER_ID,
                       ROW_NUMBER() OVER (ORDER BY LOG_DTM DESC) ROW_NUM
                FROM TB_CF_LOGIN_LOG
                WHERE USER_ID = #{userId}
				AND LOG_TYPE = 1
            ) A
        WHERE ROW_NUM = 2
		]]>
    </select>

    <select id="getGrpCommCodeList" resultType="cjfw.wms.portal.common.main.dto.GrpCommCodeListGetResDto$CommCode">
	    SELECT /* [mainService.sqlx][getGrpCommCodeList][2023.05.23][wisujang] */    
		    STORERKEY           ,
		    CODELIST AS COM_GRP_CD,
		    SEQNO AS SPRT_NO    ,
		    BASECODE AS COM_CD  ,
		    BASEDESCR AS CD_NM  ,
		    DATA1 AS RSV_STR1_VAL,
		    DATA2 AS RSV_STR2_VAL,
		    DATA3 AS RSV_STR3_VAL,
		    DATA4 AS RSV_STR4_VAL,
		    '' AS RSV_STR5_VAL,
		    '' AS RSV_STR6_VAL,
		    '' AS RSV_STR7_VAL,
		    '' AS RSV_STR8_VAL,
		    '' AS RSV_NUM1_VAL,
		    '' AS RSV_NUM2_VAL,
		    '' AS RSV_NUM3_VAL,
		    '' AS RSV_NUM4_VAL,
		    '' AS RSV_NUM5_VAL,
		    '' AS RSV_NUM6_VAL,
		    '' AS RSV_NUM7_VAL,
		    '' AS RSV_NUM8_VAL
		FROM
		    (SELECT
		        CM_CODE.STORERKEY             ,
		        CM_CODE.CODELIST              ,
		        CM_CODE.SEQNO                 ,
		        CM_CODE.BASECODE              ,
		        CM_CODE.BASEDESCR             ,
		        CM_CODE.CONVCODE              ,
		        CM_CODE.CONVDESCR             ,
		        CM_CODE.DATA1                 ,
		        CM_CODE.DATA2                 ,
		        CM_CODE.DATA3                 ,
		        CM_CODE.DATA4           
		    FROM
		        CM_CODE     
		    WHERE
		        STORERKEY ='STD'     
		        AND    DEL_YN='N'     
		    UNION
		    ALL     SELECT
		        CM_CODE.STORERKEY             ,
		        CM_CODE.CODELIST              ,
		        CM_CODE.SEQNO                 ,
		        CM_CODE.BASECODE              ,
		        CM_CODE.BASEDESCR             ,
		        CM_CODE.CONVCODE              ,
		        CM_CODE.CONVDESCR                 ,
		        CM_CODE.DATA1                     ,
		        CM_CODE.DATA2                     ,
		        CM_CODE.DATA3                     ,
		        CM_CODE.DATA4               
		    FROM
		        CM_CODE
		    WHERE 1=1
		      AND CM_CODE.DEL_YN='N'   
		      AND CM_CODE.STORERKEY='FW00'
		) T_RESULT        
    </select>

</mapper>