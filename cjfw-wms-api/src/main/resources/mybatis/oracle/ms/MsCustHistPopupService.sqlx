<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="msCustHist">
	<!-- 이력정보 상세정보 팝업 -->
	<select id="getCustHistList" parameterType="cjfw.wms.ms.dto.MsCustHistPopupReqDto" resultType="cjfw.wms.ms.dto.MsCustHistPopupResDto">
		SELECT	/* [MsCustHistPopupService.sqlx][getCustHistList][이력정보 상세정보 조회][YeoSeungCheol][2025.07.29] */
			B.HIST_DT						      		AS HIST_DATE   /* 일자 		*/
			,B.SKU                                  	AS SKU         /* 상품코드 	*/
      		,A.DESCRIPTION                          	AS DESCRIPTION /* 상품명 		*/
      		,A.STORAGETYPE                              AS STORAGETYPE /* 저장조건		*/
      		,DECODE(A.BASEUOM, A.BASEUOM, 'BOX')    	AS BASE_UOM    /* 기본단위 	*/
      		,B.LENGTH                               	AS LENGTH      /* 길이 		*/
      		,B.WIDTH                                	AS WIDTH       /* 너비 		*/
      		,B.HEIGHT                               	AS HEIGHT      /* 높이		*/
      	FROM
      		MS_SKU_HIST B
      	JOIN
      		MS_SKU A
      			ON 		B.SKU = A.SKU
      		WHERE 1=1
      			<if test="sku != null and sku != ''">
      				AND B.SKU = #{sku}
      			</if>
	</select>
</mapper>
