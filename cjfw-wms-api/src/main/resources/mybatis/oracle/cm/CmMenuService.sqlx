<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cmMenuService">

	<select id="getFavoriteMenuList" resultType="CmMenuResDto">
        SELECT  /* [CmMenuService.sqlx][getFavoriteMenuList][즐겨찾기 메뉴 목록 조회][JangGwangSeok][2025.08.18] */
		     A.PROG_CD														/* 프로그램코드 */
		    ,DECODE(C.PROG_NM, NULL, A.PROG_NM, C.PROG_NM) AS PROG_NM		/* 프로그램명 */
		    ,B.MENU_SEQ														/* 메뉴순번 */
		    ,A.PROG_NO														/* 프로그램내부순번 */
		    ,A.PROG_URL														/* 프로그램URL */
		FROM FRAMEONE_PROGRAM A
		LEFT JOIN FRAMEONE_MYMENU B ON A.PROG_CD = B.PROG_CD
		LEFT OUTER JOIN FRAMEONE_PROGRAM_LANGUAGE C ON B.PROG_CD = C.PROG_CD
		    AND C.LANG_CL = #{gLang}
		WHERE B.USER_ID = #{gUserId}
		    AND A.MENU_YN = 1 AND A.USE_YN = 1
		ORDER BY B.MENU_SEQ, A.PROG_NO
    </select>
    
    <insert id="insertFavoriteMenu">
		INSERT /* [CmMenuService.sqlx][getFavoriteMenuList][즐겨찾기 메뉴 저장][JangGwangSeok][2025.08.18] */ INTO FRAMEONE_MYMENU
		( 
			 USER_ID
			,PROG_CD
			,MENU_SEQ
			,REG_ID
			,REG_DTM
		)
		VALUES
		( 
			 #{regId}
			,#{progCd}
			,(SELECT NVL(MAX(MENU_SEQ),0)+1 AS MENUSEQ FROM FRAMEONE_MYMENU WHERE USER_ID = #{regId})
			,#{regId}
			,SYSDATE
		)
	</insert>
	
	<delete id="deleteFavoriteMenu">
		DELETE /* [CmMenuService.sqlx][deleteFavoriteMenu][즐겨찾기 메뉴 삭제][JangGwangSeok][2025.08.18] */ FROM FRAMEONE_MYMENU
    	WHERE USER_ID = #{regId}
    		AND PROG_CD = #{progCd}
    </delete>
    
</mapper>