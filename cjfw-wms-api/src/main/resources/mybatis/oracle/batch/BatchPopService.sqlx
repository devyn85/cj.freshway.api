<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="batchPopService">
	<!-- 배치 정보 조회(목록) -->
	<select id="getBatchParamSetList" resultType="BatchMngResDto">
        SELECT A.JOB_NAME
             , A.PARAM_NAME
             , A.PARAM_DESC
             , A.PARAM_VALUE
             , A.PARAM_TYPE
             , A.USE_YN
          FROM BATCH_D A
         WHERE A.JOB_NAME = #{jobName}
         ORDER BY CASE WHEN A.PARAM_NAME = 'AVC_LOG_PARAMS' <!-- (*20250825) 배치로그 파라미터의 경우 항상 마지막에 표시함 -->
                       THEN 9
                       ELSE 1
                  END 
    </select>

    <!-- 배치 파라미터 정보 INSERT -->
    <insert id="insertBatchD">
        INSERT	/* [BatchPopService.sqlx][BatchPopService.insertBatchParamSetList][배치 파라미터 정보 INSERT][yewon.kim][20250709] */
        INTO BATCH_D
              ( JOB_NAME
              , PARAM_NAME
              , PARAM_DESC
              , PARAM_VALUE
              , PARAM_TYPE
              , ADDWHO
              , ADDDATE
              , EDITWHO
              , EDITDATE
              )
        VALUES
            ( #{jobName}
              , #{paramName}
              , #{paramDesc}
              , #{paramValue}
              , #{paramType}
              , #{gUserId}
              , SYSDATE
              , #{gUserId}
              , SYSDATE
            )
    </insert>



    <!-- 배치 파라미터 UPDATE -->
    <update id="updateBatchD">
        UPDATE	/* [BatchPopService.sqlx][BatchPopService.udateBatchD][배치 파라미터 정보 UPDATE][yewon.kim][20250709] */
                BATCH_D
           SET  PARAM_NAME = #{paramName}
             ,  PARAM_VALUE  = #{paramValue}
             ,  PARAM_TYPE = #{paramType}
             ,  PARAM_DESC = #{paramDesc}
             ,  EDITDATE = SYSDATE
             ,  EDITWHO = #{gUserId}
         WHERE  JOB_NAME = #{jobName}
           AND  PARAM_NAME = #{paramName}
    </update>

    <!-- 배치 파라미터 DELETE -->
    <delete id="deleteBatchD">
        DELETE BATCH_D
         WHERE JOB_NAME = #{jobName}
           AND PARAM_NAME = #{paramName}
    </delete>

</mapper>