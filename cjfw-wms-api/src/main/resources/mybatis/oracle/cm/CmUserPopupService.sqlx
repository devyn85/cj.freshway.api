<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cmUserPopupService">
	<!-- 사용자 정보 조회 -->	
	<select id="getPopList" resultType="CmUserPopupResDto">
		SELECT	FU.USER_ID, 
				FU.USER_ID 									AS USER_ID_DISP, 			/*사용자ID(마스킹)*/
				FU.USER_NM,
				FU.USER_NM 									AS USER_NM_NO_MASKING,		/*사용자명(평문)*/
				FU.EMPTYPE, 															/*사원구분*/
				NVL(FE.DEPTHR_NM, MS_CUST.DESCRIPTION)  	AS DEPARTMENT, 				/*부서코드*/
				DAMO.DEC(FE.HANDPHONE_NO) 					AS HANDPHONE_NO,
				FE.MAIL_ID
		FROM FRAMEONE_USER FU 
		LEFT JOIN FRAMEONE_EMP FE ON FU.EMP_NO = FE.EMP_NO AND FU.COM_CD = FE.COM_CD
		LEFT JOIN MS_CUST ON MS_CUST.CUSTKEY = FU.CUSTKEY
		WHERE 1=1
			AND FU.DEL_YN = 'N'
			AND FU.STATUS = '90'
			<if test="userId != null and userId != ''">
				AND  UPPER(FU.USER_ID) LIKE UPPER('%' || #{userId} || '%')
			</if>
	     	<if test="userNm != null and userNm != ''">
				AND (
				FU.USER_NM LIKE '%' || #{userNm} || '%'
				OR UPPER(FU.USER_ID) LIKE UPPER('%' || #{userNm} || '%')
				)
			</if>
			<if test="name != null and name != ''">
				AND (
				FU.USER_NM LIKE '%' || #{name} || '%'
				OR UPPER(FU.USER_ID) LIKE UPPER('%' || #{name} || '%')
				)
			</if>
			<if test="empType != null and empType != ''">
				AND FU.EMPTYPE = #{empType}
			</if>
			<if test="depthrNm != null and depthrNm != ''">
				AND UPPER(FE.DEPTHR_NM) LIKE UPPER('%' || #{depthrNm} || '%')
			</if>
	</select>
</mapper>