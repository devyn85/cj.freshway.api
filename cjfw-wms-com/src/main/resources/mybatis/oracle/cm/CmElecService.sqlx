	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 26">
	              ,SUM(NVL(COSTCD26, 0))  AS COSTCD26
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 27">
	              ,SUM(NVL(COSTCD27, 0))  AS COSTCD27
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 28">
	              ,SUM(NVL(COSTCD28, 0))  AS COSTCD28
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 29">
	              ,SUM(NVL(COSTCD29, 0))  AS COSTCD29
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 30">
	              ,SUM(NVL(COSTCD30, 0))  AS COSTCD30
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 31">
	              ,SUM(NVL(COSTCD31, 0))  AS COSTCD31
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 32">
	              ,SUM(NVL(COSTCD32, 0))  AS COSTCD32
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 33">
	              ,SUM(NVL(COSTCD33, 0))  AS COSTCD33
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 34">
	              ,SUM(NVL(COSTCD34, 0))  AS COSTCD34
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 35">
	              ,SUM(NVL(COSTCD35, 0))  AS COSTCD35
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 36">
	              ,SUM(NVL(COSTCD36, 0))  AS COSTCD36
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 37">
	              ,SUM(NVL(COSTCD37, 0))  AS COSTCD37
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 38">
	              ,SUM(NVL(COSTCD38, 0))  AS COSTCD38
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 39">
	              ,SUM(NVL(COSTCD39, 0))  AS COSTCD39
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 40">
	              ,SUM(NVL(COSTCD40, 0))  AS COSTCD40
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 41">
	              ,SUM(NVL(COSTCD41, 0))  AS COSTCD41
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 42">
	              ,SUM(NVL(COSTCD42, 0))  AS COSTCD42
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 43">
	              ,SUM(NVL(COSTCD43, 0))  AS COSTCD43
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 44">
	              ,SUM(NVL(COSTCD44, 0))  AS COSTCD44
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 45">
	              ,SUM(NVL(COSTCD45, 0))  AS COSTCD45
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 46">
	              ,SUM(NVL(COSTCD46, 0))  AS COSTCD46
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 47">
	              ,SUM(NVL(COSTCD47, 0))  AS COSTCD47
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 48">
	              ,SUM(NVL(COSTCD48, 0))  AS COSTCD48
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 49">
	              ,SUM(NVL(COSTCD49, 0))  AS COSTCD49
	              </if>
	              <if test="CUSTCD_CNT != null and CUSTCD_CNT > 50">
	              ,SUM(NVL(COSTCD50, 0))  AS COSTCD50
	              </if>
			  FROM T_FORM
			GROUP BY CHANNEL ,CHANNELNAME
			)
			ORDER BY CHANNEL, DISUSETYPE, REASONCODE, GUBUN
	</select>

	<select id="selectElecForm2Cont1" resultType="map">
		WITH T_FORM AS (
			/* [cmElecService.sqlx][selectElecForm2Cont1][재고 폐기 승인요청서(KX센터) 전자결재로 올려야 하는 문서조회][JangGwangSeok][2025.09.22] */
		    SELECT GUBUN
		           ,DISUSETYPE
		           ,DISUSETYPENAME
		           ,DETAILCODE
		           ,DETAILNAME
		           ,${COSTCD2}
		     FROM (
		    SELECT
		              '30'                             AS GUBUN
		              ,SY_PROCESSTEMP_AJ.OTHER04       AS OTHER01
		              ,SY_PROCESSTEMP_AJ.OTHER02       AS DISUSETYPE
		              ,FN_CODEDESCR(SY_PROCESSTEMP_AJ.STORERKEY, 'DISUSETYPE', SY_PROCESSTEMP_AJ.OTHER02)      AS DISUSETYPENAME
		              ,'100'                            AS DETAILCODE
		              ,'SKU'                            AS DETAILNAME
		              ,count(distinct SY_PROCESSTEMP_AJ.SKU)           AS DETAIL
		        FROM AJ_APPRREQUEST
		        JOIN SY_PROCESSTEMP_AJ
		        ON   AJ_APPRREQUEST.APPROVALREQDT = SY_PROCESSTEMP_AJ.LIST_NO
		        AND  AJ_APPRREQUEST.APPROVALREQNO = SY_PROCESSTEMP_AJ.BATCH_NO
		        AND  AJ_APPRREQUEST.DCCODE        = SY_PROCESSTEMP_AJ.DCCODE
		        AND  AJ_APPRREQUEST.ORGANIZE      = SY_PROCESSTEMP_AJ.ORGANIZE
		        AND  AJ_APPRREQUEST.DOCDT         = SY_PROCESSTEMP_AJ.DOCDT
		        AND  AJ_APPRREQUEST.DOCNO         = SY_PROCESSTEMP_AJ.DOCNO
		        AND  SY_PROCESSTEMP_AJ.PROCESSFLAG = 'Y'
		        JOIN MS_COST
		        ON   MS_COST.STORERKEY = SY_PROCESSTEMP_AJ.STORERKEY
		        AND  MS_COST.COSTCODE  = SY_PROCESSTEMP_AJ.OTHER04
				AND  MS_COST.FROMDATE  <![CDATA[<=]]> SY_PROCESSTEMP_AJ.DOCDT
				AND  MS_COST.TODATE    <![CDATA[>=]]> SY_PROCESSTEMP_AJ.DOCDT
		        WHERE 1=1
		        AND   AJ_APPRREQUEST.DEL_YN        = 'N'
		        AND   AJ_APPRREQUEST.APPROVALREQDT = #{approvalReauestDt}
				AND   AJ_APPRREQUEST.APPROVALREQNO = #{approvalReauestNo}
		        group by SY_PROCESSTEMP_AJ.OTHER04  ,SY_PROCESSTEMP_AJ.OTHER02  ,SY_PROCESSTEMP_AJ.STORERKEY
		    UNION ALL
		    SELECT
		              '30'                             AS GUBUN
		              ,SY_PROCESSTEMP_AJ.OTHER04       AS OTHER01
		              ,SY_PROCESSTEMP_AJ.OTHER02       AS DISUSETYPE
		              ,FN_CODEDESCR(SY_PROCESSTEMP_AJ.STORERKEY, 'DISUSETYPE', SY_PROCESSTEMP_AJ.OTHER02)      AS DISUSETYPENAME
		              ,'200'                         AS DETAILCODE
		              ,'물량'                        AS DETAILNAME
		              ,sum(SY_PROCESSTEMP_AJ.INVOICEQTY)           AS DETAIL
		        FROM AJ_APPRREQUEST
		        JOIN SY_PROCESSTEMP_AJ
		        ON   AJ_APPRREQUEST.APPROVALREQDT = SY_PROCESSTEMP_AJ.LIST_NO
		        AND  AJ_APPRREQUEST.APPROVALREQNO = SY_PROCESSTEMP_AJ.BATCH_NO
		        AND  AJ_APPRREQUEST.DCCODE        = SY_PROCESSTEMP_AJ.DCCODE
		        AND  AJ_APPRREQUEST.ORGANIZE      = SY_PROCESSTEMP_AJ.ORGANIZE
		        AND  AJ_APPRREQUEST.DOCDT         = SY_PROCESSTEMP_AJ.DOCDT
		        AND  AJ_APPRREQUEST.DOCNO         = SY_PROCESSTEMP_AJ.DOCNO
		        AND  SY_PROCESSTEMP_AJ.PROCESSFLAG = 'Y'
		        JOIN MS_COST
		        ON   MS_COST.STORERKEY = SY_PROCESSTEMP_AJ.STORERKEY
		        AND  MS_COST.COSTCODE  = SY_PROCESSTEMP_AJ.OTHER04
				AND  MS_COST.FROMDATE  <![CDATA[<=]]> SY_PROCESSTEMP_AJ.DOCDT
				AND  MS_COST.TODATE    <![CDATA[>=]]> SY_PROCESSTEMP_AJ.DOCDT
		        WHERE 1=1
		        AND   AJ_APPRREQUEST.DEL_YN        = 'N'
		        AND   AJ_APPRREQUEST.APPROVALREQDT = #{approvalReauestDt}
				AND   AJ_APPRREQUEST.APPROVALREQNO = #{approvalReauestNo}
		        group by SY_PROCESSTEMP_AJ.OTHER04  ,SY_PROCESSTEMP_AJ.OTHER02  ,SY_PROCESSTEMP_AJ.STORERKEY
		    UNION ALL
		    SELECT
		              '30'                             AS GUBUN
		              ,SY_PROCESSTEMP_AJ.OTHER04       AS OTHER01
		              ,SY_PROCESSTEMP_AJ.OTHER02       AS DISUSETYPE
		              ,FN_CODEDESCR(SY_PROCESSTEMP_AJ.STORERKEY, 'DISUSETYPE', SY_PROCESSTEMP_AJ.OTHER02)      AS DISUSETYPENAME
		              ,'300'                         AS DETAILCODE
		              ,'폐기금액'                    AS DETAILNAME
		              ,sum(SY_PROCESSTEMP_AJ.ETCQTY1) + (sum(SY_PROCESSTEMP_AJ.INVOICEQTY) * 220)           AS DETAIL
		        FROM AJ_APPRREQUEST
		        JOIN SY_PROCESSTEMP_AJ
		        ON   AJ_APPRREQUEST.APPROVALREQDT = SY_PROCESSTEMP_AJ.LIST_NO
		        AND  AJ_APPRREQUEST.APPROVALREQNO = SY_PROCESSTEMP_AJ.BATCH_NO
		        AND  AJ_APPRREQUEST.DCCODE        = SY_PROCESSTEMP_AJ.DCCODE
		        AND  AJ_APPRREQUEST.ORGANIZE      = SY_PROCESSTEMP_AJ.ORGANIZE
		        AND  AJ_APPRREQUEST.DOCDT         = SY_PROCESSTEMP_AJ.DOCDT
		        AND  AJ_APPRREQUEST.DOCNO         = SY_PROCESSTEMP_AJ.DOCNO
		        AND  SY_PROCESSTEMP_AJ.PROCESSFLAG = 'Y'
		        JOIN MS_COST
		        ON   MS_COST.STORERKEY = SY_PROCESSTEMP_AJ.STORERKEY
		        AND  MS_COST.COSTCODE  = SY_PROCESSTEMP_AJ.OTHER04
				AND  MS_COST.FROMDATE  <![CDATA[<=]]> SY_PROCESSTEMP_AJ.DOCDT
				AND  MS_COST.TODATE    <![CDATA[>=]]> SY_PROCESSTEMP_AJ.DOCDT
		        WHERE 1=1
		        AND   AJ_APPRREQUEST.DEL_YN        = 'N'
		        AND   AJ_APPRREQUEST.APPROVALREQDT = #{approvalReauestDt}
				AND   AJ_APPRREQUEST.APPROVALREQNO = #{approvalReauestNo}
		        group by SY_PROCESSTEMP_AJ.OTHER04  ,SY_PROCESSTEMP_AJ.OTHER02  ,SY_PROCESSTEMP_AJ.STORERKEY
		    UNION ALL
		    SELECT
		              '30'                             AS GUBUN
		              ,SY_PROCESSTEMP_AJ.OTHER04       AS OTHER01
		              ,SY_PROCESSTEMP_AJ.OTHER02       AS DISUSETYPE
		              ,FN_CODEDESCR(SY_PROCESSTEMP_AJ.STORERKEY, 'DISUSETYPE', SY_PROCESSTEMP_AJ.OTHER02)      AS DISUSETYPENAME
		              ,'400'                         AS DETAILCODE
		              ,'재고금액'                    AS DETAILNAME
		              ,sum(SY_PROCESSTEMP_AJ.ETCQTY1)           AS DETAIL
		        FROM AJ_APPRREQUEST
		        JOIN SY_PROCESSTEMP_AJ
		        ON   AJ_APPRREQUEST.APPROVALREQDT = SY_PROCESSTEMP_AJ.LIST_NO
		        AND  AJ_APPRREQUEST.APPROVALREQNO = SY_PROCESSTEMP_AJ.BATCH_NO
		        AND  AJ_APPRREQUEST.DCCODE        = SY_PROCESSTEMP_AJ.DCCODE
		        AND  AJ_APPRREQUEST.ORGANIZE      = SY_PROCESSTEMP_AJ.ORGANIZE
		        AND  AJ_APPRREQUEST.DOCDT         = SY_PROCESSTEMP_AJ.DOCDT
		        AND  AJ_APPRREQUEST.DOCNO         = SY_PROCESSTEMP_AJ.DOCNO
		        AND  SY_PROCESSTEMP_AJ.PROCESSFLAG = 'Y'
		        JOIN MS_COST
		        ON   MS_COST.STORERKEY = SY_PROCESSTEMP_AJ.STORERKEY
		        AND  MS_COST.COSTCODE  = SY_PROCESSTEMP_AJ.OTHER04
				AND  MS_COST.FROMDATE  <![CDATA[<=]]> SY_PROCESSTEMP_AJ.DOCDT
				AND  MS_COST.TODATE    <![CDATA[>=]]> SY_PROCESSTEMP_AJ.DOCDT
		        WHERE 1=1
		        AND   AJ_APPRREQUEST.DEL_YN        = 'N'
		        AND   AJ_APPRREQUEST.APPROVALREQDT = #{approvalReauestDt}
				AND   AJ_APPRREQUEST.APPROVALREQNO = #{approvalReauestNo}
		        group by SY_PROCESSTEMP_AJ.OTHER04  ,SY_PROCESSTEMP_AJ.OTHER02  ,SY_PROCESSTEMP_AJ.STORERKEY
		    UNION ALL
		    SELECT
		              '30'                             AS GUBUN
		              ,SY_PROCESSTEMP_AJ.OTHER04       AS OTHER01
		              ,SY_PROCESSTEMP_AJ.OTHER02       AS DISUSETYPE
		              ,FN_CODEDESCR(SY_PROCESSTEMP_AJ.STORERKEY, 'DISUSETYPE', SY_PROCESSTEMP_AJ.OTHER02)      AS DISUSETYPENAME
		              ,'500'                         AS DETAILCODE
		              ,'폐기비용'                    AS DETAILNAME
		              ,sum(SY_PROCESSTEMP_AJ.OTHER04) * 220           AS DETAIL
		        FROM AJ_APPRREQUEST
		        JOIN SY_PROCESSTEMP_AJ
		        ON   AJ_APPRREQUEST.APPROVALREQDT = SY_PROCESSTEMP_AJ.LIST_NO
		        AND  AJ_APPRREQUEST.APPROVALREQNO = SY_PROCESSTEMP_AJ.BATCH_NO
		        AND  AJ_APPRREQUEST.DCCODE        = SY_PROCESSTEMP_AJ.DCCODE
		        AND  AJ_APPRREQUEST.ORGANIZE      = SY_PROCESSTEMP_AJ.ORGANIZE
		        AND  AJ_APPRREQUEST.DOCDT         = SY_PROCESSTEMP_AJ.DOCDT
		        AND  AJ_APPRREQUEST.DOCNO         = SY_PROCESSTEMP_AJ.DOCNO
		        AND  SY_PROCESSTEMP_AJ.PROCESSFLAG = 'Y'
		        JOIN MS_COST
		        ON   MS_COST.STORERKEY = SY_PROCESSTEMP_AJ.STORERKEY
		        AND  MS_COST.COSTCODE  = SY_PROCESSTEMP_AJ.OTHER04
				AND  MS_COST.FROMDATE  <![CDATA[<=]]> SY_PROCESSTEMP_AJ.DOCDT
				AND  MS_COST.TODATE    <![CDATA[>=]]> SY_PROCESSTEMP_AJ.DOCDT
		        WHERE 1=1
		        AND   AJ_APPRREQUEST.DEL_YN        = 'N'
		        AND   AJ_APPRREQUEST.APPROVALREQDT = #{approvalReauestDt}
				AND   AJ_APPRREQUEST.APPROVALREQNO = #{approvalReauestNo}
		        group by SY_PROCESSTEMP_AJ.OTHER04  ,SY_PROCESSTEMP_AJ.OTHER02  ,SY_PROCESSTEMP_AJ.STORERKEY
		    )
		        PIVOT (
		                  SUM(DETAIL)
		                  FOR OTHER01 IN ( ${COSTCD1} )
		     )
		    ORDER BY DISUSETYPE, DETAILCODE, DETAILNAME
		)

		SELECT  GUBUN
		       ,DISUSETYPE
		       ,DISUSETYPENAME
		       ,DETAILCODE
		       ,DETAILNAME
		       ,${COSTCD4}
		FROM   (
		    SELECT  GUBUN
		           ,DISUSETYPE
		           ,DISUSETYPENAME
		           ,DETAILCODE
		           ,DETAILNAME
		           ,${COSTCD2}
		    FROM   T_FORM
		    UNION ALL
		    SELECT  '50' AS GUBUN
		           ,UNISTR('') AS DISUSETYPE
		           ,UNISTR('') AS DISUSETYPENAME
		           ,DETAILCODE
		           ,DETAILNAME
		           ,${COSTCD3}
		    FROM   T_FORM
		    GROUP BY DETAILCODE, DETAILNAME
		)
		ORDER BY GUBUN,DISUSETYPE, DETAILCODE
	</select>

	<select id="selectElecForm5Cont1" resultType="map">
		SELECT  /* [CmElecService.sqlx][selectElecForm5Cont1][키트처리 전자결재 목록 조회][20260120] */
			'Y' AS KIT_YN
			,AJ_APPRREQUEST.DCCODE AS DCCODE
			,AJ_APPRREQUEST.DOCNO AS SKU
			,MS_SKU.DESCRIPTION AS SKU_NAME
			,MS_SKU.BASEUOM AS UOM
			,nvl(ST_KIT_PLAN.CONFIRMQTY, 0) AS QTY
		FROM AJ_APPRREQUEST
		JOIN ST_KIT_PLAN
			ON AJ_APPRREQUEST.DOCNO = ST_KIT_PLAN.SKU
			AND AJ_APPRREQUEST.DCCODE = ST_KIT_PLAN.DCCODE
			AND AJ_APPRREQUEST.STORERKEY = ST_KIT_PLAN.STORERKEY
			AND AJ_APPRREQUEST.SLIPDT = ST_KIT_PLAN.PLAN_DT
		JOIN MS_SKU
			ON MS_SKU.STORERKEY          = AJ_APPRREQUEST.STORERKEY
		   AND MS_SKU.SKU                = AJ_APPRREQUEST.DOCNO
		   AND MS_SKU.DEL_YN             = 'N'
		WHERE
			AJ_APPRREQUEST.APPROVALREQDT = #{approvalReauestDt}
			AND AJ_APPRREQUEST.APPROVALREQNO = #{approvalReauestNo}
		UNION ALL
		SELECT
			'N' AS KIT_YN
			,ST_KIT_PLANDETAIL.DCCODE AS DCCODE
			,ST_KIT_PLANDETAIL.BOM_SKU AS SKU
			,MS_SKU.DESCRIPTION AS SKU_NAME
			,MS_SKU.BASEUOM AS UOM
			,nvl(ST_KIT_PLANDETAIL.CONFIRMQTY * MS_KITSKU.QTY, 0) AS QTY
		FROM AJ_APPRREQUEST
		JOIN ST_KIT_PLANDETAIL
			ON AJ_APPRREQUEST.DOCNO = ST_KIT_PLANDETAIL.SKU
			AND AJ_APPRREQUEST.DCCODE = ST_KIT_PLANDETAIL.DCCODE
			AND AJ_APPRREQUEST.STORERKEY = ST_KIT_PLANDETAIL.STORERKEY
			AND AJ_APPRREQUEST.SLIPDT = ST_KIT_PLANDETAIL.PLAN_DT
		JOIN MS_KITSKU
			ON MS_KITSKU.KIT_SKU = AJ_APPRREQUEST.DOCNO
			AND MS_KITSKU.DCCODE = ST_KIT_PLANDETAIL.DCCODE
			AND MS_KITSKU.STORERKEY = ST_KIT_PLANDETAIL.STORERKEY
			AND MS_KITSKU.SKU = ST_KIT_PLANDETAIL.BOM_SKU
		    AND MS_KITSKU.DEL_YN = 'N'
            AND MS_KITSKU.FROMDATE <![CDATA[<=]]> TO_CHAR(SYSDATE, 'YYYYMMDD')
		    AND MS_KITSKU.TODATE <![CDATA[>=]]> TO_CHAR(SYSDATE, 'YYYYMMDD')
		JOIN MS_SKU
			ON MS_SKU.STORERKEY          = ST_KIT_PLANDETAIL.STORERKEY
		   AND MS_SKU.SKU                = ST_KIT_PLANDETAIL.BOM_SKU
		   AND MS_SKU.DEL_YN             = 'N'
		WHERE
			AJ_APPRREQUEST.APPROVALREQDT = #{approvalReauestDt}
			AND AJ_APPRREQUEST.APPROVALREQNO = #{approvalReauestNo}
	</select>

	<select id="selectElecForm6Cont1" resultType="map">
        SELECT    /* [cmElecService.sqlx][selectElecForm6Cont1][비용기표 조회][sunho.kim][2025.10.28] */
                TO_CHAR(ISSUE_DATE, 'YYYY-MM-DD')                                        AS ISSUE_DATE                                              /* 전기일 */
              , EX.ADJUSTMENT_SUPPLIER_NAME                                              AS ADJUSTMENT_SUPPLIER_NAME                                /* 협력사명 */
              , TO_CHAR(NVL(EX.SUPPLY_PRICE, 0), '999,999,999')                          AS SUPPLY_PRICE                                            /* 공급가액 */
              , TO_CHAR(NVL(EX.TAX_AMOUNT, 0), '999,999,999')                            AS TAX_AMOUNT                                              /* 부가세 */
              , TO_CHAR(NVL(EX.AMOUNT, 0), '999,999,999')                                AS AMOUNT                                                  /* 총액 */
              , X.ACCOUNT_DETAIL_NAME                                                    AS ACCOUNT_DETAIL                                          /* 비용구분 */
              , CD1.BASEDESCR                                                            AS TAX_TAG                                                 /* 증빙구분 */
              , TO_CHAR(EX.TAX_YMD, 'YYYY-MM-DD')                                        AS TAX_YMD                                                 /* 증빙일 */
        FROM    IB_EXPENSE EX

        LEFT JOIN   (  
             SELECT 
                  X.EXPENSE_SN
                 ,CASE WHEN MAX(ACCOUNT_DETAIL_CODE) IN ('K10', 'K11', 'W01', 'W02', 'W03')
                       THEN '보관료'
                       WHEN MAX(ACCOUNT_DETAIL_CODE) IN ('K09')
                       THEN '보관료(PLT)'
                       ELSE MAX(ACCOUNT_DETAIL_NAME)
                  END                                AS ACCOUNT_DETAIL_NAME
             FROM   IB_EXPENSE_DISTRIBUTION X
             LEFT OUTER JOIN CM_CODE CD
               ON CD.CODELIST  = 'JOURNALCODE'
              AND CD.BASECODE  = X.ACCOUNT_DETAIL_CODE  
             GROUP BY X.EXPENSE_SN        
            ) X 
            ON X.EXPENSE_SN = EX.SERIALKEY

        LEFT OUTER JOIN CM_CODE_STORER CD1
                    ON CD1.STORERKEY = EX.STORERKEY
                   AND CD1.CODELIST  = 'TAX_TAG'
                   AND CD1.BASECODE  = EX.TAX_TAG

        WHERE  EX.SERIALKEY IN (
                   SELECT SLIPNO
                     FROM AJ_APPRREQUEST
                    WHERE AJ_APPRREQUEST.DOCTYPE       = 'IBEXPENSE'
                      AND AJ_APPRREQUEST.DEL_YN        = 'N'
                      AND AJ_APPRREQUEST.APPROVALREQDT = #{approvalReauestDt}
                      AND AJ_APPRREQUEST.APPROVALREQNO = #{approvalReauestNo} )

       ORDER BY EX.KEY_NO
    </select>

	<select id="selectElecApprDoctype" resultType="map">
        SELECT
              AJ_APPRREQUEST.DOCTYPE
             ,AJ_APPRREQUEST.APPROVALSTATUS
             ,AJ_APPRREQUEST.DCCODE
        FROM AJ_APPRREQUEST
        WHERE 1 = 1
            AND AJ_APPRREQUEST.DEL_YN = 'N'
            AND AJ_APPRREQUEST.APPROVALREQDT = #{approvalReauestDt}
            AND AJ_APPRREQUEST.APPROVALREQNO = #{approvalReauestNo}
    </select>

</mapper>