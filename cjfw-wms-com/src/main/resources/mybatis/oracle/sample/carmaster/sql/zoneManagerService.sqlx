<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="zoneManagerService">

	<!-- 존 정보 리스트 조회 -->
	<select id="getZoneManagerList" resultType="ZoneManagerGetResDto">
		SELECT    /* [zoneManagerService.sqlx][getZoneManagerList][존 정보 리스트 조회][20250421][KimSunHo] */
			 MS_ZONE.SERIALKEY						                           AS SERIALKEY     /* 데이터번호 */ 
			,MS_ZONE.DCCODE                                                    AS DCCODE  		/* 센터코드 */
			,MS_ZONE.ZONE                                                      AS ZONE  		/* 존코드 */
			,MS_ZONE.DESCRIPTION                                               AS DESCRIPTION  	/* 존 설명 */
			--,fn_CODEDESCR ( 'STD','INSTRATEGY_ZONE' ,MS_ZONE.INSTRATEGY  )     AS INSTRATEGY    /* 입고 전략 */
			--,fn_CODEDESCR ( 'STD','OUTSTRATEGY_ZONE',MS_ZONE.OUTSTRATEGY )     AS OUTSTRATEGY   /* 출고 전략 */
			--,fn_CODEDESCR ( 'STD','STATUS_ZONE'     ,MS_ZONE.STATUS      )     AS STATUS
			--,fn_CODEDESCR ( 'STD','DEL_YN'          ,MS_ZONE.DEL_YN )          AS DEL_YN 
			--,fn_CODEDESCR ( 'STD','STORAGETYPE_ZONE',MS_ZONE.STORAGETYPE )     AS STORAGETYPE 
			--,fn_CODEDESCR ( 'STD','ZONE_GUGAN'      ,MS_ZONE.ZONE_GUGAN )      AS ZONE_GUGAN 

			,MS_ZONE.INSTRATEGY                                                AS INSTRATEGY    /* 입고 전략 */
			,MS_ZONE.OUTSTRATEGY                                               AS OUTSTRATEGY   /* 출고 전략 */
			,MS_ZONE.STATUS                                                    AS STATUS        /* 진행상태 */
			,MS_ZONE.DEL_YN                                                    AS DEL_YN        /* 삭제여부 */
			,MS_ZONE.STORAGETYPE                                               AS STORAGETYPE   /* 저장유형 */
			,MS_ZONE.ZONE_GUGAN                                                AS ZONE_GUGAN    /* 존구간 */
			,MS_ZONE.SERIALKEY	                                               AS SERIALKEY     /* 데이터번호 */		
			,TO_CHAR(MS_ZONE.ADDDATE, 'yyyymmddhh24miss')                      AS ADDDATE	    /* 최초등록시간 */
			,TO_CHAR(MS_ZONE.EDITDATE, 'yyyymmddhh24miss')                     AS EDITDATE      /* 최종변경시간 */			      
			,MS_ZONE.ADDWHO                                                    AS ADDWHO        /* 최초등록자 */
			,MS_ZONE.EDITWHO                                                   AS EDITWHO       /* 최종변경자 */
		
		FROM   MS_ZONE	  MS_ZONE  
	        WHERE  1=1
	        <if test="schDccode != null and schDccode != ''">
	        AND    MS_ZONE.DCCODE                   LIKE '%' || #{schDccode} || '%'           
	        </if>
	        <if test="schZone != null and schZone != ''">
	        AND    MS_ZONE.ZONE                     LIKE '%' || #{schZone} || '%'           
	        </if>
	        <if test="schDescription != null and schDescription != ''">
	        AND    MS_ZONE.DESCRIPTION              LIKE '%' || #{schDescription} || '%'           
	        </if>
	</select>
	
	<!-- 존 정보 INSERT -->
    <insert id="insert">
		INSERT	/* [zoneManagerService.sqlx][insert][존 정보 INSERT][20250421][KimSunHo] */ 
			INTO MS_ZONE
		  (DCCODE
		  ,ZONE
		  ,DESCRIPTION
		  ,INSTRATEGY
		  ,OUTSTRATEGY
		  ,STORAGETYPE
		  ,ZONE_GUGAN
		  ,ADDWHO
		  ,EDITWHO)
		VALUES
		  (#{dccode}
		  ,UPPER(#{zone})
		  ,#{description}
		  ,NVL(#{instrategy},'STD')
		  ,NVL(#{outstrategy},'STD')
		  ,#{storagetype}
		  ,#{zoneGugan}
		  ,#{regId}
		  ,#{regId})
    </insert>
    
    
    <!-- 존 정보 UPDATE -->
    <update id="update">
		UPDATE	/* [zoneManagerService.sqlx][update][존 정보 UPDATE][20250421][KimSunHo] */
			MS_ZONE
		   SET DESCRIPTION = #{description},
		       INSTRATEGY  = NVL(#{instrategy},'STD'),
		       OUTSTRATEGY = NVL(#{outstrategy},'STD'),
		       STORAGETYPE = #{storagetype},
		       ZONE_GUGAN  = #{zoneGugan},
		       DEL_YN      = #{delYn},
		       STATUS      = #{status},
		       EDITDATE    = SYSDATE,
		       EDITWHO     = #{regId}
		 WHERE SERIALKEY = #{serialkey}	
	</update> 
</mapper>