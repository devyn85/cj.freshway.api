                 #{fileName},
                 #{fileExtension},
                 #{fileLocation},
                 #{fileSizeBytes},
                 #{transFileName},
                 '',
                 #{uploadResDocId},
                 #{uploadFileName},
                 #{uploadWorkplaceId},
                 '',
                 '0',
                 '',
                 'HTTP',
                 'Y',
                 #{gUserId},
                 SYSDATE,
                 #{gUserId},
                 SYSDATE
               )
    </insert>

    <update id="updateCmCarHttpDocAttachDate">
        UPDATE CM_CAR /* [msCarDriverService.sqlx][msCarDriverService.updateCmCarHttpDocAttachDate] */
        <set>
            EDITWHO = #{gUserId},
            EDITDATE = SYSDATE
            <if test='gubun == "1"'>
                ,FROMDATE = #{carDt}
            </if>
            <if test='gubun == "2"'>
                ,TODATE = #{carDt}
            </if>
            <if test='gubun == "3"'>
                ,TODATE2 = #{carDt}
            </if>
        </set>
        WHERE CARNO = #{carNo}
    </update>
    
    <select id="getDriverDupCount" resultType="int">
        SELECT COUNT(*) 
        FROM  CM_CAR 
        WHERE CARNO = #{carNo}     
  	</select> 
  	
    <select id="getDriverList" resultType="MsCarDriverResDto">
        SELECT
             CM_DRIVER.DRIVERID 		AS CODE
            ,CM_DRIVER.DRIVERNAME   	AS NAME
			,DAMO.DEC(CM_DRIVER.PHONE1) AS PHONE1
        FROM CM_DRIVER
        WHERE 1 = 1
        <if test="driverId != null and driverId != ''"> 
           AND CM_DRIVER.DRIVERID = #{driverId} 
        </if>           
    </select>
        <insert id="insertTemp" >
        INSERT /* [msCarDriverService.sqlx][insertTemp][임시 Tabele 등록] */
        INTO SY_PROCESSTEMP_DM_D ( SERIALKEY, PROCESSTYPE,PROCESSCREATOR,SPID,ADDWHO,EDITWHO
        /**/
          ,DCCODE
        , SOKEY
        , INVOICETYPE
        , POKEY
        , LOT
        , LOTTABLE01
        , LOTTABLE02
        , LOTTABLE03
        , LOTTABLE04
        , LOTTABLE05
        , POTYPE
        , SOTYPE
        , PLANDOCTYPE
        , COURIER
        , SITE
        , PLANDOCDT
        , MERGEDOCDT
        , DELIVERYDATE
        , OTHER06
        , OTHER07
        , ORDERQTY
        , OPENQTY
        , PROCESSQTY
        , DOCLINE
        , IOTYPE
        , WORKQTY
        , INSPECTQTY
        , RETURNTYPE
        , RETURNWHO
        , REFERENCE07
        , REFERENCE01
        , REFERENCE02
        , REFERENCE03
        , REFERENCE04
        , REFERENCE05
        , REFERENCE06
        , OTHER01
        , OTHER02
        , OTHER08
        /**/
        )
        SELECT 
          SEQ_SY_PROCESSTEMP_DM_D.NEXTVAL   /* [2] 안전한 바깥쪽 위치에 시퀀스 배치 */
        , A.*
    FROM (
        <foreach collection="list" item="item" index="index" separator="UNION ALL">
            SELECT 
          #{item.processtype}, #{item.gUserId},#{item.gSpid},#{item.gUserId},#{item.gUserId}
         
        , #{item.dccode}
        , #{item.sokey}
        , #{item.invoicetype}
        , #{item.pokey}
        , #{item.lot}
        , #{item.lottable01}
        , #{item.lottable02}
        , #{item.lottable03}
        , #{item.lottable04}
        , #{item.lottable05}
        , #{item.potype}
        , #{item.sotype}
        , #{item.plandoctype}
        , #{item.courier}
        , #{item.site}
        , #{item.plandocdt}
        , #{item.mergedocdt}
        , #{item.deliverydate}
        , #{item.other06}
        , #{item.other07}
        , #{item.orderqty}
        , #{item.openqty}
        , #{item.processqty}
        , #{item.docline}
        , #{item.iotype}
        , #{item.workqty}
        , #{item.inspectqty}
        , #{item.returntype}
        , #{item.returnwho}
        , #{item.reference07}
        , #{item.reference01}
        , #{item.reference02}
        , #{item.reference03}
        , #{item.reference04}
        , #{item.reference05}
        , #{item.reference06}
        , #{item.other01}
        , #{item.other02}
        , #{item.other08}
            FROM DUAL
        </foreach>
        ) A
    </insert>
    <!-- POP 일괄등록 결과 조회(목록) -->
    <select id="getExcelUploadResult" resultType="MsCarDriverExcelResDto">
    	SELECT /* [msPopMngService.sqlx][msCarDriverService.getExcelUploadResult][][][] */
    	       SY_PROCESSTEMP_DM_D.PROCESSFLAG   AS PROCESS_YN
              ,SY_PROCESSTEMP_DM_D.PROCPOSS_MSG        AS PROCESS_MSG
        FROM  SY_PROCESSTEMP_DM_D
        WHERE SY_PROCESSTEMP_DM_D.PROCESSCREATOR = #{gUserId}
        AND   SY_PROCESSTEMP_DM_D.PROCESSTYPE    = #{processtype}
        AND   SY_PROCESSTEMP_DM_D.SPID           = #{gSpid}
        ORDER BY SY_PROCESSTEMP_DM_D.SERIALKEY
    </select>
    
</mapper>