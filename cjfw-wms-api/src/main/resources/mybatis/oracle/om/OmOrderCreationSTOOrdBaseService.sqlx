			SLIPLINE,
			ROUTE,
			IF_TIMESTAMP,
			SERIALNO,
			CONVSERIALNO,
			REAL_YN,
			MAP_DIV,
			MAPKEY_NO,
			MAPKEY_LINE,
			ISSUE_NO,
			MOVE_YN,
			TEMP_YN,
			ADD_YN,
			REF_DOC_NO,
			REF_DOC_LINE,
			QUICK_YN,
			CANCEL_END_YN,
			REF_DOCID,
			REF_CUST_DOCID,
			OPEN_TIME,
			ADDDATE,
			EDITDATE,
			ADDWHO,
			EDITWHO
		FROM
			LOGISONE.IF_DM_DOCUMENT_D
		WHERE DOCNO = #{docno}
			AND DELIVERYDATE = #{deliverydate}
	</select>
</mapper>