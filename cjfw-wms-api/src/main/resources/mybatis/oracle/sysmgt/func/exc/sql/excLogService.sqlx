<?xml version="1.0" encoding="UTF-8"?><!--Converted at: Mon Feb 17 11:21:55 KST 2014-->
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="excLogService">
    
    <!-- 시스템 예외 이력 조회 -->
    <select id="getExcLogList" resultType="ExcLogGetResDto">
		SELECT  /* [excLogService.sqlx][excLog.getExcLogList][2020.02.21][CWS] */
    			EXN_NO AS EXN_NO				/* 일련번호 */
    			, EXCPT_CNTS AS EXCPT_CNTS		/* 예외내용 */
    			, OCCR_DY AS OCCR_DY			/* 발생일자 */
    			, CLNT_ADDR AS CLNT_ADDR		/* 클라이언트 IP */
    			, SVR_ADDR AS SVR_ADDR			/* 서버 IP */
    			, CALL_URI AS CALL_URI			/* 호출 URL */
		FROM    TB_CF_EXN_LOG
		WHERE 	1=1
		AND		TO_CHAR(TO_DATE(OCCR_DY, 'YYYY-MM-DD HH24:MI:SS'), 'YYYYMMDD') <![CDATA[<=]]> REPLACE(#{thruDt}, '-', '')	/* 게시기간 */
		AND		TO_CHAR(TO_DATE(OCCR_DY, 'YYYY-MM-DD HH24:MI:SS'), 'YYYYMMDD') <![CDATA[>=]]> REPLACE(#{fromDt}, '-', '')	/* 게시기간 */
		ORDER BY EXN_NO DESC, OCCR_DY DESC
    </select>
    
</mapper>