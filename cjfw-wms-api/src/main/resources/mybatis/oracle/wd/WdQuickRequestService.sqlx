<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="wdQuickRequestService">
    <!-- 
    	*******************************************************************************************************
    	* Tab1(1/3)
    	*******************************************************************************************************
    -->
	<!-- Tab1 VOC접수내역 리스트 -->
    <select id="getTab1MasterList" resultType="cjfw.wms.wd.dto.WdQuickRequestResDto">
		SELECT /* [WdQuickRequestService.sqlx][WdQuickRequestService.getTab1MasterList][VOC접수내역 조회][sss][20250717] */                
               NVL(MAX(WD_VOC_QUICK_ORDER.STATUS),'01')                         AS STATUS           /*진행상태(01:VOC퀵요청,02:센터접수,03:퀵주문등록,04:퀵주문취소등록,05:퀵주문처리완료,06:퀵주문취소완료)*/
              ,NVL(MAX(NVL(CD2.BASEDESCR,WD_VOC_QUICK_ORDER.STATUS)),'VOC퀵요청') AS STATUSNM         /*진행상태명*/
              ,MAX(RT_CLAIMINFO.WRITEDATE)                                      AS WRITEDATE        /*의뢰일-클레임작성일자*/
              ,RT_CLAIMINFO_VSR.VOCNO                                           AS VOCNO            /*VOC번호*/
              ,RT_CLAIMINFO_VSR.VSRNO                                           AS VSRNO            /*VSR번호*/
              ,MAX(RT_CLAIMINFO_VSR.VSRTYPE)                                    AS VSRTYPE          /*VSR유형*/
              ,MAX(NVL(CD1.BASEDESCR,RT_CLAIMINFO_VSR.VSRTYPE))                 AS VSRTYPENM        /*VSR유형명*/
              ,MAX(RT_CLAIMINFO.SKU)                                            AS SKU              /*상품코드*/
              ,MAX(MS_SKU.DESCRIPTION)                                          AS SKUNAME          /*상품명*/   
              ,MAX(RT_CLAIMINFO.ORDERQTY)                                       AS ORDERQTY         /*주문수량*/
              ,MAX(RT_CLAIMINFO.ORDERUOM)                                       AS ORDERUOM         /*주문UOM*/
              ,MAX(RT_CLAIMINFO.CLAIMQTY)                                       AS VOC_QTY          /*VOC량*/  
              ,MAX(RT_CLAIMINFO_VSR.CUSTKEY)                                    AS CUSTKEY          /*협력사코드*/
              ,MAX(MS_CUST.CUSTKEYNM)                                           AS CUSTKEYNM        /*협력사명*/              
              ,MAX(RT_CLAIMINFO_VSR.REQ_DEPT_NAME)                              AS REQ_DEPARTMENT   /*요청부서코드*/
              ,MAX(RT_CLAIMINFO_VSR.REQ_DEPT_NAME)                              AS REQ_DEPARTMENTNM /*요청부서명*/
              --   
              ,MAX(MS_CUST.BILLTOCUSTKEY)                                        AS CUSTKEYMNG       /*관리처코드*/
              ,MAX(FN_DESCR_CUST(RT_CLAIMINFO.STORERKEY,MS_CUST.BILLTOCUSTKEY))  AS CUSTKEYNMMNG     /*관리처명*/
              --
              ,MAX(RT_CLAIMINFO_VSR.REQ_ID)                        AS REQ_ID             /*요청자*/    
              ,MAX(NVL(CM_USER.USERNAME,RT_CLAIMINFO_VSR.ADDWHO))  AS REQ_NM             /*요청자명*/
              ,MAX(TO_CHAR(RT_CLAIMINFO_VSR.ADDDATE,'YYYY-MM-DD HH24:MI:SS')) AS ADDDATE /*의뢰일시*/
              ,MAX(RT_CLAIMINFO.TITLE)                             AS TITLE              /*제목-클레임제목*/
              ,MAX(RT_CLAIMINFO.MEMO)                              AS MEMO               /*전달사항-클레임세부내역*/
              ,MAX(RT_CLAIMINFO_VSR.RMK)                           AS RMK                /*비고-전달사항*/       
              ,MAX(WD_VOC_QUICK_ORDER.RCPT_NO)                     AS RCPT_NO            /*센터접수번호*/
              ,MAX(WD_VOC_QUICK_ORDER.QUICK_DOCNO)                 AS QUICK_DOCNO        /*퀵주문번호*/
              /**/
              ,MAX(RT_CLAIMINFO.DCCODE)                            AS DCCODE             /*물류센터*/
              ,MAX(MS_SKUDCSET.LOC)                                AS LOC                /*로케이션 */
              ,MAX(TO_CHAR(TO_DATE(WD_VOC_QUICK_ORDER.RCPT_DATE||WD_VOC_QUICK_ORDER.RCPT_HOUR,'YYYY-MM-DD HH24:MI'),'YYYY-MM-DD HH24:MI'))  AS RCPTDATE        /*센터접수일시*/
              ,MAX(TO_CHAR(TO_DATE(WD_VOC_QUICK_ORDER.QUICK_ORDER_RCPT_DATE||WD_VOC_QUICK_ORDER.QUICK_ORDER_RCPT_HOUR,'YYYY-MM-DD HH24:MI'),'YYYY-MM-DD HH24:MI')) AS QUICK_DATE      /*퀵주문접수일시*/
              ,MAX(WD_VOC_QUICK_ORDER.RCPT_HOUR)                  AS RCPT_HOUR         /*센터접수시간*/
              ,MAX(RT_CLAIMINFO.DCCODE)                           AS DCCODE            /*물류센터*/
              --
              ,MAX(WD_VOC_QUICK_ORDER.RESP_DEPT)                   AS RESP_DEPT    /*귀책부서*/
              ,MAX(WD_VOC_QUICK_ORDER.RESP_REASON)                 AS RESP_REASON  /*귀책사유*/
              ,MAX(WD_VOC_QUICK_ORDER.RESP_EMP)                    AS RESP_EMP     /*귀책담당자*/
              --,MAX(MS_CUST.ADDRESS1 ||' '||MS_CUST.ADDRESS2)     AS ADDRESS      /*사업자 등록 주소*/
              --,MAX(DAMO.DEC(NVL(MS_CUST.PHONE1,MS_CUST.PHONE2))) AS PHONE        /*사업자 전화번호*/
              ,MAX(DAMO.DEC(RT_CLAIMINFO.ADDRESS))                 AS ADDRESS      /*주소*/    
			  ,MAX(DAMO.DEC(RT_CLAIMINFO.PHONE  ))                 AS PHONE        /*전화번호*/     
              ,MAX(WD_VOC_QUICK_ORDER.QUICK_DOCNO)                 AS QUICK_DOCNO  /*퀵주문번호*/
              ,MAX(WD_VOC_QUICK_ORDER.DELIVERYMEMO)                AS DELIVERYMEMO /*배송메시지*/
              --
        FROM RT_CLAIMINFO_VSR /*클레임정보VSR*/
        JOIN RT_CLAIMINFO     /*반품클레임정보*/
          ON RT_CLAIMINFO_VSR.STORERKEY  = RT_CLAIMINFO.STORERKEY
         AND RT_CLAIMINFO_VSR.VOCNO      = RT_CLAIMINFO.SAPCLAIMNO 
         AND RT_CLAIMINFO_VSR.VOC_DTL_NO = RT_CLAIMINFO.SAPCLAIMLINE
        LEFT JOIN MS_SKU
          ON MS_SKU.STORERKEY = #{gStorerkey}
         AND MS_SKU.SKU       = RT_CLAIMINFO.SKU       
        LEFT JOIN MS_SKUDCSET 
          ON MS_SKUDCSET.STORERKEY = RT_CLAIMINFO.STORERKEY
         AND MS_SKUDCSET.DCCODE    = RT_CLAIMINFO.DCCODE
         AND MS_SKUDCSET.SKU       = RT_CLAIMINFO.SKU       
   LEFT JOIN WD_VOC_QUICK_ORDER
          ON RT_CLAIMINFO.STORERKEY     = WD_VOC_QUICK_ORDER.STORERKEY 
         AND RT_CLAIMINFO.DCCODE        = WD_VOC_QUICK_ORDER.DCCODE 
         AND RT_CLAIMINFO_VSR.VOCNO     = WD_VOC_QUICK_ORDER.VOCNO 
         AND RT_CLAIMINFO_VSR.SERIALKEY = WD_VOC_QUICK_ORDER.IF_SERIALKEY
   LEFT JOIN    (
                 SELECT MS_CUST.STORERKEY AS STORERKEY
                      , MS_CUST.CUSTKEY   AS CUSTKEY                            
                      , DESCRIPTION       AS CUSTKEYNM 
                      , ADDRESS1          AS ADDRESS1 
                      , ADDRESS2          AS ADDRESS2 
                      , PHONE1            AS PHONE1
                      , PHONE2            AS PHONE2
                      --
                      , MS_CUST.BILLTOCUSTKEY AS BILLTOCUSTKEY
                      ,ROW_NUMBER() OVER(PARTITION BY STORERKEY, CUSTKEY ORDER BY EDITDATE DESC) AS RN
                   FROM MS_CUST 
                  WHERE MS_CUST.STORERKEY = #{gStorerkey}
                    AND MS_CUST.CUSTKEY IN (SELECT DISTINCT CUSTKEY 
                                              FROM RT_CLAIMINFO_VSR RT
                                             WHERE RT.STORERKEY = #{gStorerkey}     
                                               AND RT.VSRTYPE IN ('11','12') /*VSR유형(11:VOC직송의뢰,12:긴급주문직송의뢰)*/  
                                            )
                  ) MS_CUST /*판매처-실착지*/     
           ON  (RT_CLAIMINFO.STORERKEY  = MS_CUST.STORERKEY AND RT_CLAIMINFO_VSR.CUSTKEY = MS_CUST.CUSTKEY AND MS_CUST.RN = 1)
    LEFT JOIN CM_USER            ON (CM_USER.SERIALKEY = RT_CLAIMINFO_VSR.SERIALKEY AND CM_USER.USERID = RT_CLAIMINFO_VSR.ADDWHO)                
    LEFT JOIN CM_CODE_STORER CD1 ON (CD1.STORERKEY = #{gStorerkey} AND CD1.CODELIST = 'VSR_TYPE'     AND CD1.BASECODE = RT_CLAIMINFO_VSR.VSRTYPE)       /*VSR유형*/
    LEFT JOIN CM_CODE_STORER CD2 ON (CD2.STORERKEY = #{gStorerkey} AND CD2.CODELIST = 'STATUS_QUICK' AND CD2.BASECODE = WD_VOC_QUICK_ORDER.STATUS) /*.VOC퀵진행사항*/                
        WHERE RT_CLAIMINFO_VSR.STORERKEY = #{gStorerkey} /*고객사*/
          AND RT_CLAIMINFO.DCCODE IN ('9999', #{fixdccode})  /*센터*/
          AND RT_CLAIMINFO_VSR.VSRTYPE IN ('11','12') /*VSR유형(11:VOC직송의뢰,12:긴급주문직송의뢰)*/          
	      <!-- START.권한센터 -->
	      AND (
	          EXISTS (SELECT 1
                        FROM CM_USER_AUTHORITY 
                       WHERE CM_USER_AUTHORITY.DCCODE    = RT_CLAIMINFO.DCCODE       
                         AND CM_USER_AUTHORITY.STORERKEY = RT_CLAIMINFO.STORERKEY    
                         --AND CM_USER_AUTHORITY.ORGANIZE  = RT_CLAIMINFO.ORGANIZE     
                         --AND CM_USER_AUTHORITY.AREA      = RT_CLAIMINFO.AREA         
                         AND CM_USER_AUTHORITY.STORERKEY = #{gStorerkey}
                         AND CM_USER_AUTHORITY.USERID    = #{gUserId}
                         AND CM_USER_AUTHORITY.DCCODE    = NVL(#{fixdccode},'9999')
                         --AND CM_USER_AUTHORITY.AREA    = '{gArea}'  
	     	           <!-- 창고.다중검색 -->
	     	           <if test='gOrganizeMulti != null and gOrganizeMulti.length > 0'>
	     		           AND CM_USER_AUTHORITY.ORGANIZE IN
	     		           <foreach collection="gOrganizeMulti" item="code" open="(" close=")" separator=",">
	     		             #{code}
	     		           </foreach>
	     	           </if>                       
                     ) OR NVL(RT_CLAIMINFO.DCCODE,'9999') = '9999') /*센터코드 미존재->9999*/
	      <!-- END.권한센터	-->   
	      AND RT_CLAIMINFO.WRITEDATE <![CDATA[>=]]> #{dt1} AND RT_CLAIMINFO.WRITEDATE <![CDATA[<=]]> #{dt2}
	      <!-- 긴급여부 -->
	      <if test="urgentYn != null and urgentYn != ''"> AND RT_CLAIMINFO_VSR.URGENT_YN  =  #{urgentYn}   </if>   
	      <!-- 진행상태 -->
	      <if test="status != null and status != ''">     AND WD_VOC_QUICK_ORDER.STATUS  =  #{status}   </if> 	             
	      <!-- VSR유형 -->
	      <if test="vsrtype != null and vsrtype != ''">   AND RT_CLAIMINFO_VSR.VSRTYPE  =  #{vsrtype}   </if>	      
	      <!-- VOC번호 -->
	      <if test="vocno != null and vocno != ''">   AND RT_CLAIMINFO_VSR.VOCNO  =  #{vocno}   </if>
          <if test="contractcustkeyMulti != null and contractcustkeyMulti != ''">
              AND RT_CLAIMINFO_VSR.CUSTKEY IN
              <foreach collection="contractcustkeyMulti" item="item" open="(" separator="," close=")">
                  #{item}
              </foreach> 
          </if>	      
          <!-- 센터접수번호 -->	     
          <if test="quickDocnoMulti != null and quickDocnoMulti != ''">
              AND WD_VOC_QUICK_ORDER.RCPT_NO IN
              <foreach collection="quickDocnoMulti" item="item" open="(" separator="," close=")">
                  #{item}
              </foreach> 
          </if>	
        GROUP BY RT_CLAIMINFO.DCCODE
                ,RT_CLAIMINFO.STORERKEY
                ,RT_CLAIMINFO_VSR.VOCNO
                ,RT_CLAIMINFO_VSR.VSRNO 
        ORDER BY RT_CLAIMINFO.DCCODE
                ,RT_CLAIMINFO.STORERKEY
                ,MAX(RT_CLAIMINFO.WRITEDATE) DESC                
                ,RT_CLAIMINFO_VSR.VOCNO
                ,RT_CLAIMINFO_VSR.VSRNO     
    </select>
    
    <!-- 센터접수번호 조회	-->       
    <select id="getRcptNo" resultType="cjfw.wms.wd.dto.WdQuickRequestResDto">
        SELECT /* [WdQuickRequestService.sqlx][WdQuickRequestService.getRcptNo][센터접수번호 조회][sss][20250717] */
               TO_CHAR(SYSDATE, 'YYYYMMDD')||LPAD(NVL((MAX(SUBSTR(RCPT_NO,9,3))),0) + 1,3,'0') AS RCPT_NO  
          FROM WD_VOC_QUICK_ORDER
         WHERE 1=1
           AND STORERKEY = #{gStorerkey}
           AND RCPT_DATE = TO_CHAR(SYSDATE, 'YYYYMMDD')  
    </select>   
    
    
    
    <!-- serialkey 조회	-->       
    <select id="getSerialkey" resultType="cjfw.wms.wd.dto.WdQuickRequestResDto">
        SELECT /* [WdQuickRequestService.sqlx][WdQuickRequestService.getRcptNo][serialkey 조회][sss][20250717] */
               SEQ_WD_VOC_QUICK_ORDER_01.NEXTVAL AS SERIALKEY
          FROM DUAL  
    </select> 
    
    <!-- 퀵주문접수 체크 정보 을(를) 조회 -->
    <select id="selectChkIntMaster"  parameterType="hashMap" resultType="hashMap">
        <![CDATA[
        SELECT /* [WdQuickRequestService.selectChkIntMaster][퀵주문접수 체크][sss][20250717] */
               (
                SELECT CASE WHEN COUNT(*) > 0 THEN 'Y' ELSE 'N' END AS CHK1
                  FROM WD_VOC_QUICK_ORDER
                 WHERE VOCNO     = #{vocno}    
                   AND STORERKEY = #{storerkey} 
               ) AS CHK1 /*체크.접수여부*/
             , (
                SELECT MAX(QUICK_DOCNO) AS QUICK_DOCNO
                  FROM WD_VOC_QUICK_ORDER
                 WHERE VOCNO     = #{vocno}           
                   AND STORERKEY = #{storerkey}       
               ) AS QUICK_DOCNO /*센터접수번호*/                     
          FROM DUAL
        ]]>
    </select>       
    
    
    <!-- 센터 접수 처리 -->
    <insert id="insertMasterList">
		INSERT /* [WdQuickRequestService.insertMasterList][센터 접수 처리][sss][20250717] */
		  INTO WD_VOC_QUICK_ORDER (
                   STORERKEY              /* 고객사코드 */
                 , RCPT_NO                /* 센터접수번호 */                  
                 , SERIALKEY              /* 시리얼키 (NEXTVAL) */         
                 , IF_SERIALKEY           /* IF데이터번호 */                
                 , QUICK_DOCNO            /* 퀵주문번호 */                  
                 , STATUS                 /* 진행상태 */                   
                 , VOCNO                  /* VOC번호 */                  
                 , VOCSEQ                 /* VOC순번 */                  
                 , VSRTYPE                /* VSR유형 */                  
                 , VSRNO                  /* VSR번호 */                  
                 , VSR_SEQ                /* VSR순번 */                  
                 , DCCODE                 /* 물류센터 */                   
                 --, DELIVERYDATE           /* 납품일 */                    
                 , DOCNO                  /* 주문번호 */                   
                 , DOCLINE                /* 주문순번 */                   
                 , DEPARTMENT             /* 담당부서코드 */                 
                 , SLST_ID                /* 판매처코드 */                  
                 , SLST_NM                /* 판매처명 */                   
                 , MGMT_CUSTKEY           /* 관리처코드 */                  
                 , MGMT_CUSTNAME          /* 관리처명 */                   
                 , SKU                    /* 상품코드 */                   
                 , SKU_INFO               /* 상품내역 */                   
                 , UOM                    /* 상품단위 */                   
                 , ORDERQTY               /* 주문량 */                    
                 , ORDERUOM               /* 주문단위 */                   
                 , VOC_UOM                /* voc단위 */                  
                 , VOC_QTY                /* voc량 */                   
                 , GTH_SEQ                /* 집하지방문순서 */                
                 , GTH_CD                 /* 집하지코드 */                  
                 , GTH_NM                 /* 집하지명 */                   
                 , GTH_ADDR               /* 집하지주소 */                  
                 , GTH_ADDRDTL            /* 집하지상세주소 */                  
                 , GTH_EMP_NM             /* 집하지담당자명 */                
                 , GTH_TEL                /* 집하지연락처 */                 
             , PO_CUSTKEY             /* 협력사코드 */                  
             , PO_CUST_TEL            /* 협력사연락처 */                 
                 , WRITER                 /* 작성자 */                    
                 , WRITEDATE              /* 작성일자 */                   
                 , WRITETIME              /* 작성시간 */                   
                 , REQ_DEPARTMENT         /* 요청부서 */                   
                 , REQ_ID                 /* 요청자 */                    
                 , TO_SEQ                 /* 도착지 방문순서 */               
                 , ADDRESS                /* 고객주소 */                   
                 , ADDRESS2               /* 고객상세주소 */                   
                 , PHONE                  /* 고객전화번호 */                 
                 , RMK                    /* 비고 */                     
                 , DELIVERYTYPE           /* 배송방법 */                   
                 , DELIVERY_METHOD        /* 배송수단 */                   
                 , DELIVERY_OPTION        /* 배송선택 */                   
                 , ARTICLE_TYPE           /* 물품종류 */                   
                 , PAY_TYPE               /* 지급구분 */                   
                 , RESERVEDATE            /* 예약일시 */                   
                 , RESP_DEPT              /* 귀책부서 */                   
                 , RESP_REASON            /* 귀책사유 */                   
                 , RESP_EMP               /* 귀책담당자 */                  
                 , MEMO                   /* 전달사항 */    
                 , RCPT_DATE              /*센터접수일자*/ 
                 , RCPT_HOUR              /*센터접수시간*/ 
                 , ADDDATE                /* 최초등록시간 */                 
                 , EDITDATE               /* 최종변경시간 */                 
                 , ADDWHO                 /* 최초등록자 */        
                 , URGENT_YN			  /* 긴급여부 */          
            )  
            SELECT RT_CLAIMINFO_VSR.STORERKEY	                            AS STORERKEY       /* 고객사코드 */
                 , #{rcptNo}                                                AS RCPT_NO         /* 센터접수번호 */
                 , SEQ_WD_VOC_QUICK_ORDER_01.NEXTVAL                        AS SERIALKEY       /* 시리얼키 (NEXTVAL) */
                 , RT_CLAIMINFO_VSR.SERIALKEY                               AS IF_SERIALKEY    /* IF데이터번호 */
                 , NULL                                                     AS QUICK_DOCNO     /* 퀵주문번호 */
                 , '02'                                                     AS STATUS          /*진행상태(01:VOC퀵요청,02:센터접수,03:퀵주문등록,04:퀵주문취소등록,05:퀵주문처리완료,06:퀵주문취소완료)*/
                 , RT_CLAIMINFO_VSR.VOCNO                                   AS VOCNO           /* VOC번호 */
                 , 1                                                        AS VOCSEQ          /* VOC순번 */
                 , CASE WHEN RT_CLAIMINFO_VSR.VSRTYPE = '11' THEN '01' 
                        WHEN RT_CLAIMINFO_VSR.VSRTYPE = '12' THEN '02'
                   ELSE 
                       RT_CLAIMINFO_VSR.VSRTYPE END                       AS VSRTYPE         /*VSR유형(01:VOC직송의뢰,02:긴급주문직송의뢰)*/
                 , RT_CLAIMINFO_VSR.VSRNO                                 AS VSRNO           /* VSR번호 */
                 , RT_CLAIMINFO_VSR.SEQ                                   AS VSR_SEQ         /* VSR순번 */
                 , #{dccode}                                              AS DCCODE          /* 물류센터 */
                 --, RT_CLAIMINFO.DELIVERYDATE                               AS DELIVERYDATE    /* 납품일 */
                 , RT_CLAIMINFO.DOCNO                                        AS DOCNO           /* 주문번호 */
                 , RT_CLAIMINFO.DOCLINE                                      AS DOCLINE         /* 주문순번 */
                 , ''                                                        AS DEPARTMENT      /* 담당부서코드 */
                 --                                                      
                 , RT_CLAIMINFO.MNGPLC_ID                                    AS MNGPLC_ID       /* 판매처코드 */
                 ,(SELECT DESCRIPTION  
                     FROM MS_CUST
                    WHERE CUSTKEY = RT_CLAIMINFO.MNGPLC_ID
                      AND ROWNUM = 1)                                        AS SLST_NM         /* 판매처명 */     
                 , RT_CLAIMINFO.SHPTO_ID                                     AS MGMT_CUSTKEY    /* 관리처코드 */
                 ,(SELECT DESCRIPTION  
                     FROM MS_CUST
                    WHERE CUSTKEY = RT_CLAIMINFO.SHPTO_ID
                      AND ROWNUM = 1)                                        AS MGMT_CUSTNAME   /* 관리처명 */        
                 --
                 , RT_CLAIMINFO.SKU                                       AS SKU             /* 상품코드 */
                 , MS_SKU.DESCRIPTION                                     AS SKU_INFO        /* 상품내역  */
                 , RT_CLAIMINFO.UOM                                       AS UOM             /* 상품단위 */
                 , RT_CLAIMINFO.ORDERQTY                                  AS ORDERQTY        /* 주문량 */
                 , RT_CLAIMINFO.ORDERUOM                                  AS ORDERUOM        /* 주문단위 */
                 , RT_CLAIMINFO.UOM                                       AS VOC_UOM         /* voc단위 */
                 , RT_CLAIMINFO.CLAIMQTY                                  AS VOC_QTY         /* voc량 */
                 , NULL                                                   AS GTH_SEQ         /* 집하지방문순서 */
                 , NULL                                                   AS GTH_CD          /* 집하지코드 */
                 , NULL                                                   AS GTH_NM          /* 집하지명 */
                 , LOGISONESVC.FN_ADDRESS_INFO('ADDR1',DAMO.DEC(CD41.DATA3),'','')  AS GTH_ADDR        /* 집하지주소 */
                 , LOGISONESVC.FN_ADDRESS_INFO('ADDR1',DAMO.DEC(CD41.DATA3),'','')  AS GTH_ADDRDTL     /* 집하지상세주소 */
                 , CD41.DATA4                                             AS GTH_EMP_NM      /* 집하지담당자명 */
                 , CD41.DATA2                                             AS GTH_TEL         /* 집하지연락처 */ 
                 , RT_CLAIMINFO_VSR.CUSTKEY                               AS PO_CUSTKEY      /* 협력사코드 */
                 , NVL(MS_CUST.PHONE1,MS_CUST.PHONE2)                      AS PO_CUST_TEL    /* 협력사연락처 */
                 , RT_CLAIMINFO.WRITER                                    AS WRITER          /* 작성자 - 클레임 */
                 , RT_CLAIMINFO.WRITEDATE                                 AS WRITEDATE       /* 작성일자 - 클레임 */
                 , RT_CLAIMINFO.WRITETIME                                 AS WRITETIME       /* 작성시간 - 클레임 */
                 , NVL(CM_USER.DEPARTMENT,CD41.DATA1)                     AS REQ_DEPARTMENT  /* 요청부서 */
                 , #{gUserId}                                             AS REQ_ID          /* 요청자 */
                 , NULL                                                   AS TO_SEQ          /* 도착지 방문순서 */
                 --, MS_CUST.ADDRESS1                                       AS ADDRESS         /* 고객주소 */
                 --, MS_CUST.ADDRESS2                                       AS ADDRESS2        /* 고객상세주소 */
                 ,LOGISONESVC.FN_ADDRESS_INFO('ADDR1',DAMO.DEC(RT_CLAIMINFO.ADDRESS),'','') AS ADDRESS       /* 고객주소*/
                 ,LOGISONESVC.FN_ADDRESS_INFO('ADDR2',DAMO.DEC(RT_CLAIMINFO.ADDRESS),'','') AS ADDRESS2      /* 고객주소2*/
                 , NVL(MS_CUST.PHONE1,MS_CUST.PHONE2)                     AS PHONE           /* 고객전화번호 */
                 , RT_CLAIMINFO_VSR.RMK                                   AS RMK             /* 비고 */
                 , '1'                                                    AS DELIVERYTYPE    /* 배송방법(1:편도,2:왕복,3:경유) */
                 , NULL                                                   AS DELIVERY_METHOD /* 배송수단 */
                 , '1'                                                    AS DELIVERY_OPTION /* 배송선택(1:일반,2:급송) - 1:고정 */
                 , NULL                                                   AS ARTICLE_TYPE    /* 물품종류 */
                 , '3'                                                    AS PAY_TYPE        /* 지급구분(1:선불,2:착불,3:신용) */
                 , NULL                                                   AS RESERVEDATE     /* 예약일시 */
                 , NULL                                                   AS RESP_DEPT       /* 귀책부서 */
                 , NULL                                                   AS RESP_REASON     /* 귀책사유 */
                 , NULL                                                   AS RESP_EMP        /* 귀책담당자 */
                 <!--, RT_CLAIMINFO.MEMO                                      AS MEMO            /* 전달사항 */-->
                 , NULL                                                   AS MEMO            /* 전달사항 */
                 , TO_CHAR(SYSDATE, 'YYYYMMDD')                           AS RCPT_DATE       /* 센터접수일자*/ 
                 , TO_CHAR(SYSDATE,'HH24MI')                              AS RCPT_HOUR       /* 센터접수시간*/                  
                 , SYSDATE                                                AS ADDDATE         /* 최초등록시간 */
                 , SYSDATE                                                AS EDITDATE        /* 최종변경시간 */
                 , #{gUserId}                                             AS ADDWHO          /* 최초등록자 */
                 , RT_CLAIMINFO_VSR.URGENT_YN							  AS URGENT_YN		 /* 긴급여부 */					
           FROM RT_CLAIMINFO_VSR /*클레임정보VSR*/
           JOIN RT_CLAIMINFO
             ON (RT_CLAIMINFO_VSR.STORERKEY  = RT_CLAIMINFO.STORERKEY
             AND RT_CLAIMINFO_VSR.VOCNO      = RT_CLAIMINFO.SAPCLAIMNO 
             AND RT_CLAIMINFO_VSR.VOC_DTL_NO = RT_CLAIMINFO.SAPCLAIMLINE)
       LEFT JOIN MS_SKU
              ON MS_SKU.STORERKEY = RT_CLAIMINFO.STORERKEY
             AND MS_SKU.SKU       = RT_CLAIMINFO.SKU
       LEFT JOIN (
                  SELECT MS_CUST.STORERKEY AS STORERKEY
                       , MS_CUST.CUSTKEY   AS CUSTKEY                            
                       , DESCRIPTION       AS CUSTNAME 
                       , ADDRESS1          AS ADDRESS1 
                       , ADDRESS2          AS ADDRESS2 
                       , PHONE1            AS PHONE1
                       , PHONE2            AS PHONE2
                       -- 
                       , MS_CUST.BILLTOCUSTKEY AS BILLTOCUSTKEY
                       ,ROW_NUMBER() OVER(PARTITION BY STORERKEY, CUSTKEY ORDER BY EDITDATE DESC) AS RN
                    FROM MS_CUST 
                   WHERE MS_CUST.STORERKEY = #{gStorerkey}
                     AND MS_CUST.CUSTKEY IN (SELECT CUSTKEY 
                                               FROM RT_CLAIMINFO_VSR
                                              WHERE RT_CLAIMINFO_VSR.STORERKEY = #{gStorerkey}     
                                                AND RT_CLAIMINFO_VSR.VOCNO     = #{vocno}    
                                            )                 
                 ) MS_CUST /*판매처-실착지*/     
              ON  (RT_CLAIMINFO.STORERKEY= MS_CUST.STORERKEY AND RT_CLAIMINFO_VSR.CUSTKEY = MS_CUST.CUSTKEY AND MS_CUST.RN = 1)
	  LEFT JOIN CM_USER             ON (CM_USER.USERID = #{gUserId})               /*사용자명*/
      LEFT JOIN CM_CODE_STORER CD41 ON (CD41.STORERKEY = 'FW00' AND CD41.CODELIST = 'QUICK_ORDERER'    AND CD41.BASECODE = #{dccode})     /*퀵주문 - 센터기준기준*/	  
          WHERE RT_CLAIMINFO_VSR.STORERKEY = #{gStorerkey}               
            AND RT_CLAIMINFO_VSR.VOCNO     = #{vocno}
            --    
            AND #{dccode} IS NOT NULL      
    </insert>    
    
    <!-- 
        여러개의 VSR 전달사항 합치기 처리 update 
          -> 전달사항은 VSR별로 존재할 수 있으나, 센터접수는 VSR과 무관하게 1건이므로, 전달사항을 합쳐서 update 처리  
           - VSR번호는 줄바꿈으로 구분하여 합치기 처리
    -->
    <insert id="updateMasterList01">
	    UPDATE /* [WdQuickRequestService.sqlx][WdQuickRequestService.updateMasterList01][여러개의 VSR 전달사항 합치기 처리][sss][20250717] */
	           WD_VOC_QUICK_ORDER A
	 	   SET RMK = (SELECT LISTAGG(
	 	                     DISTINCT RMK,
	 	                     CHR(10)||CHR(13)
	 	                 ) WITHIN GROUP  (ORDER BY VSRNO)
	 	                FROM WD_VOC_QUICK_ORDER
	 	               WHERE RCPT_NO = #{rcptNo} 
	 	                 AND RCPT_NO = A.RCPT_NO	
	 	             )
	 	 WHERE RCPT_NO = #{rcptNo} /*센터접수번호는 1개의 RMK를 가짐 - 여러개의 VSR의 RMK*/     
           AND STATUS  = '02' /*상태(01:VOC퀵요청,02:센터접수,03:퀵주문등록,04:퀵주문취소등록,05:퀵주문처리완료,06:퀵주문취소완료)*/
    </insert>    
    
    <!-- 
        퀵 API 연동 배송정보 UPDATE
        ->DELIVERYMEMO를 memo에 연동  
         - 전달사항과 배송정보는 줄바꿈으로 구분하여 합치기 처리
    -->
    <insert id="updateMasterList02">
        UPDATE /* [WdQuickRequestService.sqlx][WdQuickRequestService.updateMasterList01][여러개의 VSR 전달사항 합치기 처리][sss][20250717] */
               WD_VOC_QUICK_ORDER A
           SET DELIVERYMEMO = #{testPrefix} ||
                         (
                         SELECT  LISTAGG(MEMO, '\r\n'||CHR(13) || '  ' || '\r\n'||CHR(13)) WITHIN GROUP (ORDER BY GTH_SEQ)     || '  ' ||CHR(13) ||CHR(13)||
                                            LISTAGG(MEMO_DEST, '\r\n'||CHR(13) || '  ' || '\r\n'||CHR(13)) WITHIN GROUP (ORDER BY TO_SEQ) ||
                                            '\r\n'||CHR(13)||CHR(13) ||'▶▶전달사항 :'||CHR(13)||  MAX(RMK) AS memo   --전달내용   
                                    FROM (              
                                          SELECT   /* ===== 출하지 헤더 ===== */
                                                 GTH_SEQ || ' / ' ||
                                                 GTH_NM || ' / ' ||
                                                 GTH_ADDR||' '||DAMO.DEC(GTH_ADDRDTL)|| ' / ' ||
                                                 DAMO.DEC(GTH_TEL) || ' '
                                                 || '\r\n'||CHR(13) ||
                                                 /* ===== 상품 라인 ===== */
                                                 RTRIM(
                                                     LISTAGG(
                                                         SKU || ' / ' ||
                                                         SKU_INFO || ' / ' ||
                                                         VOC_UOM || ' / ' ||
                                                         VOC_QTY || '  ',
                                                         '\r\n'||CHR(13)
                                                     ) WITHIN GROUP (ORDER BY SKU),
                                                     '  '
                                                 ) AS MEMO   --집하지  
                                              , /* ===== 도착지 헤더 ===== */
                                                  MAX(A.TO_SEQ) || ' / ' ||
                                                  MAX(MGMT_CUSTNAME) || ' / ' ||
                                                  MAX(REPLACE(ADDRESS||' '||DAMO.DEC(ADDRESS2),'__','')) || ' / ' ||
                                                  MAX(DAMO.DEC(PHONE)) || '  '
                                                 || '\r\n'||CHR(13) ||
                                                 /* ===== 상품 라인 ===== */
                                                 RTRIM(
                                                     LISTAGG(
                                                         SKU || ' / ' ||
                                                         SKU_INFO || ' / ' ||
                                                         VOC_UOM || ' / ' ||
                                                         VOC_QTY || '  ',
                                                         '\r\n'||CHR(13)
                                                     ) WITHIN GROUP (ORDER BY SKU),
                                                     '  '
                                                 ) AS MEMO_DEST   --도착지   
                                              ,MAX(RMK) AS RMK
                                              ,MAX(A.TO_SEQ) AS TO_SEQ     /*도착지 방문순서*/
                                              --
                                              ,GTH_SEQ
                                              ,GTH_NM
                                              ,GTH_ADDR
                                              ,GTH_TEL
                                           FROM WD_VOC_QUICK_ORDER A
                                          WHERE RCPT_NO = #{rcptNo} /*센터접수번호*/
                                          GROUP BY GTH_SEQ
                                                 , GTH_NM
                                                 , GTH_ADDR
                                                 , GTH_ADDRDTL
                                                 , ADDRESS
                                                 , ADDRESS2
                                                 , GTH_TEL
                                             
                                     ) A    
                         WHERE RCPT_NO = #{rcptNo}
                          AND RCPT_NO  = A.RCPT_NO    
           )
         WHERE RCPT_NO = #{rcptNo} /*센터접수번호는 1개의 RMK를 가짐 - 여러개의 VSR의 RMK*/     
           AND STATUS  = '02' /*상태(01:VOC퀵요청,02:센터접수,03:퀵주문등록,04:퀵주문취소등록,05:퀵주문처리완료,06:퀵주문취소완료)*/
    </insert>          
    
    <!-- 
    퀵접수내역 삭제 delete
      =>마스터 항목이므로 rcptNo 기준으로 update  
    -->
    <insert id="deleteMasterCenterRecept">
        DELETE /* [WdQuickRequestService.deleteMasterCenterRecept][퀵접수내역 삭제][sss][20250717] */
               WD_VOC_QUICK_ORDER
         WHERE RCPT_NO   = #{rcptNo}    /*센터접수번호*/  
           AND STATUS    = '02' /*상태(01:VOC퀵요청,02:센터접수,03:퀵주문등록,04:퀵주문취소등록,05:퀵주문처리완료,06:퀵주문취소완료)*/
    </insert>        
    
    
    <!-- 
    	*******************************************************************************************************
    	* Tab2(2/3) - tab3 마스터 조회도 공용사용
    	*******************************************************************************************************
    --> 
    <!-- Tab2 퀵주문접수 -->
    <select id="getTab2MasterList" resultType="cjfw.wms.wd.dto.WdQuickRequestResVOCDto">
		/* wdQuickRequestService.getTab2MasterList */
		SELECT /* [WdQuickRequestService.sqlx][WdQuickRequestService.getTab2MasterList][퀵주문접수 조회][sss][20250717] */
               NVL(MAX(NVL(CD2.BASEDESCR,WD_VOC_QUICK_ORDER.STATUS)),'VOC퀵요청')   AS STATUSNM    /*진행상태명*/   
              ,WD_VOC_QUICK_ORDER.RCPT_NO                                          AS RCPT_NO      /*센터접수번호*/
              ,WD_VOC_QUICK_ORDER.QUICK_DOCNO                                      AS QUICK_DOCNO  /*퀵주문번호*/ 
              ,WD_VOC_QUICK_ORDER.VOCNO                                            AS VOCNO        /*VOC번호 */
              ,WD_VOC_QUICK_ORDER.VOCSEQ                                           AS VOCSEQ       /*VOC순번 */
              ,WD_VOC_QUICK_ORDER.VSRNO                                            AS VSRNO        /*VSR번호 */           
              ,MAX(NVL(CD1.BASEDESCR,WD_VOC_QUICK_ORDER.VSRTYPE))                  AS VSRTYPENM    /*VSR명*/
              ,MAX(WD_VOC_QUICK_ORDER.DOCNO  )                                          AS DOCNO        /*주문번호*/
              ,MAX(WD_VOC_QUICK_ORDER.DOCLINE)                                          AS DOCLINE      /*주문순번*/  
              ,MAX(WD_VOC_QUICK_ORDER.SKU    )                                          AS SKU          /*상품코드*/  
              ,MAX(MS_SKU.DESCRIPTION)                                             AS SKUNAME      /*상품명*/        
              ,MAX(WD_VOC_QUICK_ORDER.SKU_INFO)                                    AS SKU_INFO     /*상품내역*/          
              ,SUM(WD_VOC_QUICK_ORDER.ORDERQTY)                                         AS ORDERQTY     /*주문량*/
              ,MAX(WD_VOC_QUICK_ORDER.ORDERUOM)                                         AS ORDERUOM     /*주문단위*/
              ,MAX(WD_VOC_QUICK_ORDER.VOC_UOM )                                         AS VOC_UOM      /*voc단위 */
              ,MAX(NVL(CD3.BASEDESCR,WD_VOC_QUICK_ORDER.VOC_UOM))                   AS VOC_UOMNM    /*voc단위명*/
              ,MAX(WD_VOC_QUICK_ORDER.UOM)                                          AS UOM          /*상품단위*/
              ,MAX(WD_VOC_QUICK_ORDER.VOC_QTY)                                      AS VOC_QTY      /*voc량*/  
              ,SUM(CASE WHEN ST_STOCK.DCCODE = '2600' THEN ST_STOCK.QTY ELSE 0 END) AS QTY2600      /*재고1*/
              ,SUM(CASE WHEN ST_STOCK.DCCODE = '2620' THEN ST_STOCK.QTY ELSE 0 END) AS QTY2620      /*재고2*/
              ,SUM(CASE WHEN ST_STOCK.DCCODE = '2630' THEN ST_STOCK.QTY ELSE 0 END) AS QTY2630      /*재고3*/
              ,SUM(CASE WHEN ST_STOCK.DCCODE = '2650' THEN ST_STOCK.QTY ELSE 0 END) AS QTY2650      /*재고4*/
              ,SUM(CASE WHEN ST_STOCK.DCCODE = '2660' THEN ST_STOCK.QTY ELSE 0 END) AS QTY2660      /*재고5*/
              ,SUM(CASE WHEN ST_STOCK.DCCODE = '2230' THEN ST_STOCK.QTY ELSE 0 END) AS QTY2230      /*재고6*/
              ,SUM(CASE WHEN ST_STOCK.DCCODE = '2260' THEN ST_STOCK.QTY ELSE 0 END) AS QTY2260      /*재고7*/
              ,MAX(MS_SKUDCSET.LOC)                                                 AS LOC          /*로케이션 */
              ,MAX(WD_VOC_QUICK_ORDER.DELIVERYMEMO)                                 AS DELIVERYMEMO /*배송메시지*/
              --
              ,MAX(DELIVERYTYPE)                                                    AS DELIVERYTYPE    /*배송방법*/
              ,MAX(DELIVERY_METHOD)                                                 AS DELIVERY_METHOD /*배송수단*/
              ,MAX(DELIVERY_OPTION)                                                 AS DELIVERY_OPTION /*배송선택*/
              ,MAX(ARTICLE_TYPE)                                                    AS ARTICLE_TYPE    /*물품종류*/
              ,MAX(PAY_TYPE)                                                        AS PAY_TYPE        /*지급구분*/
              ,MAX(SUBSTR(WD_VOC_QUICK_ORDER.RESERVEDATE,1,8))                      AS RESERVEDATE1    --예약일(오늘 기준 최대 한달까지 선택가능)
              ,MAX(SUBSTR(WD_VOC_QUICK_ORDER.RESERVEDATE,9,2))                      AS RESERVEDATE2    --예약시분
              --
              ,MAX(TO_CHAR(TO_DATE(WD_VOC_QUICK_ORDER.RCPT_DATE||WD_VOC_QUICK_ORDER.RCPT_HOUR,'YYYY-MM-DD HH24:MI'),'YYYY-MM-DD HH24:MI')) AS RCPTDATE        /*센터접수일시*/
              ,MAX(TO_CHAR(TO_DATE(WD_VOC_QUICK_ORDER.QUICK_ORDER_RCPT_DATE||WD_VOC_QUICK_ORDER.QUICK_ORDER_RCPT_HOUR,'YYYY-MM-DD HH24:MI'),'YYYY-MM-DD HH24:MI')) AS QUICK_DATE      /*퀵주문접수일시*/
              ,MAX(WD_VOC_QUICK_ORDER.RCPT_HOUR)                 AS RCPT_HOUR /*센터접수시간*/            
              ,NVL(MAX(WD_VOC_QUICK_ORDER.STATUS),'01')          AS STATUS    /*진행상태(01:VOC퀵요청,02:센터접수,03:퀵주문등록,04:퀵주문취소등록,05:퀵주문처리완료,06:퀵주문취소완료)*/
              ,MAX(WD_VOC_QUICK_ORDER.SERIALKEY)                     AS SERIALKEY /*데이터번호*/
              ,MAX(WD_VOC_QUICK_ORDER.DCCODE)                    AS DCCODE    /*물류센터*/
              --
              ,MAX(WD_VOC_QUICK_ORDER.RESP_DEPT)                 AS RESP_DEPT   /*귀책부서*/
              ,MAX(WD_VOC_QUICK_ORDER.RESP_REASON)               AS RESP_REASON /*귀책사유*/
              ,MAX(WD_VOC_QUICK_ORDER.RESP_EMP)                  AS RESP_EMP    /*귀책담당자*/
              ,MAX(WD_VOC_QUICK_ORDER.MEMO)                      AS MEMO        /*전달사항*/      
              ,MAX(WD_VOC_QUICK_ORDER.RMK)                       AS RMK         /*비고*/      
              --
              ,MAX(GTH_SEQ               )                  AS GTH_SEQ         /*집하지방문순서*/
              ,MAX(GTH_CD                )                  AS GTH_CD          /*집하지코드*/ 
              ,MAX(GTH_NM                )                  AS GTH_NM          /*집하지명*/
              ,MAX(GTH_ADDR              )                  AS GTH_ADDR        /*집하지주소*/ 
              ,MAX(DAMO.DEC(GTH_ADDRDTL) )                  AS GTH_ADDRDTL     /*집하지상세주소*/          
              ,MAX(GTH_EMP_NM            )                  AS GTH_EMP_NM      /*집하지담당자명*/
              ,MAX(DAMO.DEC(GTH_TEL)     )                  AS GTH_TEL         /*집하지연락처*/   
              ,MAX(WD_VOC_QUICK_ORDER.DCCODE)          AS DCCODE          /*물류센터*/
              --요청자정보
              ,MAX(WD_VOC_QUICK_ORDER.REQ_DEPARTMENT)               AS REQ_DEPARTMENT   /*요청부서*/
              ,MAX(MS_COST.DESCRIPTION)                             AS REQ_DEPARTMENTNM /*요청부서명*/
            ,MAX(WD_VOC_QUICK_ORDER.REQ_ID)                       AS REQ_ID           /*요청자-접수자*/    
            ,MAX(NVL(CM_USER.USERNAME,WD_VOC_QUICK_ORDER.REQ_ID)) AS REQ_NM           /*요청자명-접수자*/
              /**/
             ,COUNT(*)                                             AS ITEMCNT        /*아이템수*/ 
               --,IF_SERIALKEY    AS IF_SERIALKEY    /*IF데이터번호*/
               --,STATUS          AS STATUS          /*진행상태*/
               --,VSR_SEQ         AS VSR_SEQ         /*VSR순번 */
               --,DELIVERYDATE    AS DELIVERYDATE    /*납품일*/
               --,DEPARTMENT      AS DEPARTMENT      /*담당부서코드*/
               --,SLST_ID         AS SLST_ID         /*판매처코드*/
               --,SLST_NM         AS SLST_NM         /*판매처명*/
               --,MGMT_CUSTKEY    AS MGMT_CUSTKEY    /*관리처코드*/
               --,MGMT_CUSTNAME   AS MGMT_CUSTNAME   /*관리처명*/
               --,PO_CUSTKEY      AS PO_CUSTKEY      /*협력사코드*/
               --,PO_CUST_TEL     AS PO_CUST_TEL     /*협력사연락처*/
               --,WRITER          AS WRITER          /*작성자*/
               --,WRITEDATE       AS WRITEDATE       /*작성일자*/
               --,WRITETIME       AS WRITETIME       /*작성시간*/
               --,TO_SEQ          AS TO_SEQ          /*도착지 방문순서*/
               --,ADDRESS         AS ADDRESS         /*고객주소*/
               --,PHONE           AS PHONE           /*고객전화번호*/
               --,ADDDATE         AS ADDDATE         /*최초등록시간*/
               --,EDITDATE        AS EDITDATE        /*최종변경시간*/
               --,ADDWHO          AS ADDWHO          /*최초등록자*/
               --,EDITWHO         AS EDITWHO         /*최종변경자*/            
            FROM WD_VOC_QUICK_ORDER
       LEFT JOIN MS_SKU
              ON MS_SKU.STORERKEY = #{gStorerkey} 
             AND MS_SKU.SKU       = WD_VOC_QUICK_ORDER.SKU    
       LEFT JOIN MS_SKUDCSET 
              ON MS_SKUDCSET.STORERKEY = #{gStorerkey} 
             AND MS_SKUDCSET.DCCODE    = WD_VOC_QUICK_ORDER.DCCODE
             AND MS_SKUDCSET.SKU       = WD_VOC_QUICK_ORDER.SKU  
       LEFT JOIN (SELECT T.STORERKEY
                        ,T.COSTCODE
                        ,T.DESCRIPTION
                        ,ROW_NUMBER() OVER(PARTITION BY STORERKEY, COSTCODE ORDER BY EDITDATE DESC) AS RN                                                                   
                    FROM MS_COST T                                                                            
                   WHERE T.STORERKEY = #{gStorerkey}
                     AND #{dt1} BETWEEN NVL(T.FROMDATE,'19991231') AND NVL(T.TODATE,'99991231')         
                     AND NVL(T.DEL_YN,'N') = 'N'                                                              
                   ) MS_COST    /*귀속부서*/
               ON  (WD_VOC_QUICK_ORDER.STORERKEY = MS_COST.STORERKEY 
	                AND WD_VOC_QUICK_ORDER.REQ_DEPARTMENT = MS_COST.COSTCODE 
	                AND MS_COST.RN = 1
                   )                                 
	   LEFT JOIN (
	            SELECT MAX(ST_STOCK.STORERKEY) AS STORERKEY
	                  ,ST_STOCK.DCCODE         AS DCCODE
	                  ,ST_STOCK.SKU            AS SKU
	                  ,ST_STOCK.UOM            AS UOM
	                  ,SUM(ST_STOCK.QTY)   AS QTY        	
	              FROM ST_STOCK                              	
	             WHERE STORERKEY = #{gStorerkey} 
	               AND EXISTS (SELECT 1
	                             FROM WD_VOC_QUICK_ORDER
	                            WHERE STORERKEY = ST_STOCK.STORERKEY
	                              AND DCCODE    = ST_STOCK.DCCODE
	                              AND UOM       = ST_STOCK.UOM
	                              AND SKU       = ST_STOCK.SKU
	                          )   
	            GROUP BY ST_STOCK.DCCODE
	                    ,ST_STOCK.SKU
	                    ,ST_STOCK.UOM       
	            ) ST_STOCK
	            ON (	
	                  WD_VOC_QUICK_ORDER.DCCODE    = ST_STOCK.DCCODE
	              AND WD_VOC_QUICK_ORDER.UOM       = ST_STOCK.UOM
	              AND WD_VOC_QUICK_ORDER.SKU       = ST_STOCK.SKU             
	               )   
    LEFT JOIN CM_USER            ON (CM_USER.USERID = WD_VOC_QUICK_ORDER.REQ_ID)               /*사용자명*/ 
    LEFT JOIN CM_CODE_STORER CD1 ON (CD1.STORERKEY = #{gStorerkey} AND CD1.CODELIST = 'VSR_TYPE'     AND CD1.BASECODE = WD_VOC_QUICK_ORDER.VSRTYPE) /*VSR유형*/
    LEFT JOIN CM_CODE_STORER CD2 ON (CD2.STORERKEY = #{gStorerkey} AND CD2.CODELIST = 'STATUS_QUICK' AND CD2.BASECODE = WD_VOC_QUICK_ORDER.STATUS)  /*VOC퀵진행사항*/                
    LEFT JOIN CM_CODE_STORER CD3 ON (CD3.STORERKEY = #{gStorerkey} AND CD3.CODELIST = 'VOC_UOM'      AND CD3.BASECODE = WD_VOC_QUICK_ORDER.VOC_UOM) /*VOC단위*/
	    WHERE WD_VOC_QUICK_ORDER.STORERKEY = #{gStorerkey}  
          AND WD_VOC_QUICK_ORDER.DCCODE IN ('9999', #{fixdccode})  /*센터*/
	      AND WD_VOC_QUICK_ORDER.WRITEDATE <![CDATA[>=]]> #{dt1}
	      AND WD_VOC_QUICK_ORDER.WRITEDATE <![CDATA[<=]]> #{dt2}
	      
	      <!-- VSR유형구분(1:VOC,2:수기퀵주문접수) -->
		  <choose>
		      <when test="vsrtypeFlag == '2'.toString()">
		         AND WD_VOC_QUICK_ORDER.VSRTYPE = '90' /*VSR유형(01:VOC직송의뢰),90:수기접수*/
		      </when>
		  <otherwise>
		      AND WD_VOC_QUICK_ORDER.VSRTYPE IN ('01','02') /*VSR유형(01:VOC직송의뢰)*/
		  </otherwise>
		  </choose>	      
	      
	      <!-- 긴급여부 -->
	      <if test="urgentYn != null and urgentYn != ''"> 
	          AND WD_VOC_QUICK_ORDER.URGENT_YN = #{urgentYn}
	      </if>   
	      <!-- 진행상태 -->
	      <if test="status != null and status != ''">     AND WD_VOC_QUICK_ORDER.STATUS  =  #{status}   </if> 	             
	      <!-- VSR유형 -->
	      <if test="vsrtype != null and vsrtype != ''">   AND WD_VOC_QUICK_ORDER.VSRTYPE  =  #{vsrtype}   </if>	      
	      <!-- VOC번호 -->
	      <if test="vocno != null and vocno != ''">   AND WD_VOC_QUICK_ORDER.VOCNO  =  #{vocno}   </if>
          <if test="contractcustkeyMulti != null and contractcustkeyMulti != ''">
              AND WD_VOC_QUICK_ORDER.PO_CUSTKEY IN
              <foreach collection="contractcustkeyMulti" item="item" open="(" separator="," close=")">
                  #{item}
              </foreach> 
          </if>	
          <!-- 센터접수번호 -->	     
          <if test="quickDocnoMulti != null and quickDocnoMulti != ''">
              AND WD_VOC_QUICK_ORDER.RCPT_NO IN
              <foreach collection="quickDocnoMulti" item="item" open="(" separator="," close=")">
                  #{item}
              </foreach> 
          </if>	           	      
        GROUP BY  WD_VOC_QUICK_ORDER.DCCODE
                 ,WD_VOC_QUICK_ORDER.RCPT_NO   --PK
                 ,WD_VOC_QUICK_ORDER.QUICK_DOCNO
                 ,WD_VOC_QUICK_ORDER.VOCNO   
                 ,WD_VOC_QUICK_ORDER.VOCSEQ  
                 ,WD_VOC_QUICK_ORDER.VSRNO   
                 ,WD_VOC_QUICK_ORDER.VSRTYPE 
                 ,WD_VOC_QUICK_ORDER.DOCNO   
                 ,WD_VOC_QUICK_ORDER.DOCLINE  
        ORDER BY  MAX(WD_VOC_QUICK_ORDER.RCPT_DATE || WD_VOC_QUICK_ORDER.RCPT_HOUR) DESC         /*센터접수일시*/  
                 ,WD_VOC_QUICK_ORDER.DCCODE
                 ,WD_VOC_QUICK_ORDER.RCPT_NO DESC    --PK
                 ,MAX(WD_VOC_QUICK_ORDER.SERIALKEY) --PK
                 ,WD_VOC_QUICK_ORDER.VOCNO   
                 ,WD_VOC_QUICK_ORDER.VOCSEQ  
                 ,WD_VOC_QUICK_ORDER.VSRNO   
                 ,WD_VOC_QUICK_ORDER.VSRTYPE 
                 ,MAX(WD_VOC_QUICK_ORDER.DOCNO   )
                 ,MAX(WD_VOC_QUICK_ORDER.DOCLINE )
                 ,MAX(WD_VOC_QUICK_ORDER.SKU     )
                 ,MAX(WD_VOC_QUICK_ORDER.SKU_INFO)
                 ,MAX(WD_VOC_QUICK_ORDER.ORDERQTY)
                 ,MAX(WD_VOC_QUICK_ORDER.ORDERUOM)
                 ,MAX(WD_VOC_QUICK_ORDER.VOC_UOM )
                 ,MAX(WD_VOC_QUICK_ORDER.VOC_QTY )	             
    </select>
    
    
    <!-- Tab2 퀵주문접수 상세 - 집하지 -->
    <select id="getTab2DetailList01" resultType="cjfw.wms.wd.dto.WdQuickRequestResVOCDto">
		SELECT /* [WdQuickRequestService.sqlx][WdQuickRequestService.getTab2DetailList01][퀵주문접수 상세 조회][sss][20250717] */
		       WD_VOC_QUICK_ORDER.GTH_SEQ                        AS GTH_SEQ    /*집하지방문순서  - 집하지*/
              ,NVL(CD2.BASEDESCR,WD_VOC_QUICK_ORDER.STATUS)      AS STATUSNM   /*진행상태명*/	
		      ,WD_VOC_QUICK_ORDER.RCPT_NO                        AS RCPT_NO    /*센터접수번호*/
              ,WD_VOC_QUICK_ORDER.VOCNO                          AS VOCNO      /*VOC번호 */
              ,WD_VOC_QUICK_ORDER.VOCSEQ                         AS VOCSEQ     /*VOC순번 */
              ,WD_VOC_QUICK_ORDER.VSRNO                          AS VSRNO      /*VSR번호 */           
              ,NVL(CD1.BASEDESCR,WD_VOC_QUICK_ORDER.VSRTYPE)     AS VSRTYPENM  /*VSR명*/
              ,WD_VOC_QUICK_ORDER.DOCNO                          AS DOCNO      /*주문번호*/
              ,WD_VOC_QUICK_ORDER.DOCLINE                        AS DOCLINE    /*주문순번*/  
              ,WD_VOC_QUICK_ORDER.SKU                            AS SKU        /*상품코드*/  
              ,MS_SKU.DESCRIPTION                                AS SKUNAME    /*상품명*/        
              ,WD_VOC_QUICK_ORDER.SKU_INFO                       AS SKU_INFO   /*상품내역*/          
              ,WD_VOC_QUICK_ORDER.ORDERQTY                       AS ORDERQTY   /*주문량*/
              ,WD_VOC_QUICK_ORDER.ORDERUOM                       AS ORDERUOM   /*주문단위*/
              ,WD_VOC_QUICK_ORDER.VOC_UOM                        AS VOC_UOM    /*voc단위 */
              ,NVL(CD3.BASEDESCR,WD_VOC_QUICK_ORDER.VOC_UOM)     AS VOC_UOMNM  /*voc단위명*/
              ,WD_VOC_QUICK_ORDER.UOM                            AS UOM        /*상품단위*/
              ,WD_VOC_QUICK_ORDER.VOC_QTY                        AS VOC_QTY    /*voc량*/  
              --                                                               
              ,WD_VOC_QUICK_ORDER.RCPT_DATE                      AS RCPT_DATE  /*센터접수일자*/
              ,WD_VOC_QUICK_ORDER.RCPT_HOUR                      AS RCPT_HOUR  /*센터접수시간*/            
         	  ,NVL(WD_VOC_QUICK_ORDER.STATUS,'01')               AS STATUS     /*진행상태(01:VOC퀵요청,02:센터접수,03:퀵주문등록,04:퀵주문취소등록,05:퀵주문처리완료,06:퀵주문취소완료)*/
         	  ,WD_VOC_QUICK_ORDER.SERIALKEY	                     AS SERIALKEY  /*데이터번호*/
              --
              ,WD_VOC_QUICK_ORDER.GTH_CD                         AS GTH_CD          /*집하지코드*/ 
              ,WD_VOC_QUICK_ORDER.GTH_NM                         AS GTH_NM          /*집하지명*/
              ,WD_VOC_QUICK_ORDER.GTH_ADDR                       AS GTH_ADDR        /*집하지주소*/ 
              ,DAMO.DEC(WD_VOC_QUICK_ORDER.GTH_ADDRDTL)          AS GTH_ADDRDTL     /*집하지상세주소*/                
              ,WD_VOC_QUICK_ORDER.GTH_EMP_NM                     AS GTH_EMP_NM      /*집하지담당자명*/
              ,DAMO.DEC(WD_VOC_QUICK_ORDER.GTH_TEL)              AS GTH_TEL         /*집하지연락처*/   
              ,NVL(MS_SKUDCSET.LOC,'STD')                        AS LOC             /*로케이션 */         
            /**/
            ,WD_VOC_QUICK_ORDER.SERIALKEY                        AS SERIALKEY       /*데이터번호*/   
        	,WD_VOC_QUICK_ORDER.DCCODE                           AS DCCODE          /*물류센터*/  
            ,WD_VOC_QUICK_ORDER.IF_SERIALKEY                     AS IF_SERIALKEY    /*IF데이터번호*/
            ,WD_VOC_QUICK_ORDER.QUICK_DOCNO                      AS QUICK_DOCNO     /*퀵주문번호*/
            ,WD_VOC_QUICK_ORDER.STATUS                           AS STATUS          /*진행상태*/
            ,WD_VOC_QUICK_ORDER.VSR_SEQ                          AS VSR_SEQ         /*VSR순번 */
            ,WD_VOC_QUICK_ORDER.DCCODE                           AS DCCODE          /*물류센터*/
            ,WD_VOC_QUICK_ORDER.DELIVERYDATE                     AS DELIVERYDATE    /*납품일*/
            ,WD_VOC_QUICK_ORDER.DEPARTMENT                       AS DEPARTMENT      /*담당부서코드*/
            ,WD_VOC_QUICK_ORDER.SLST_ID                          AS SLST_ID         /*판매처코드*/
            ,WD_VOC_QUICK_ORDER.SLST_NM                          AS SLST_NM         /*판매처명*/
            ,WD_VOC_QUICK_ORDER.MGMT_CUSTKEY                     AS MGMT_CUSTKEY    /*관리처코드*/
            ,WD_VOC_QUICK_ORDER.MGMT_CUSTNAME                    AS MGMT_CUSTNAME   /*관리처명*/
            ,WD_VOC_QUICK_ORDER.UOM                              AS UOM             /*상품단위*/
            ,WD_VOC_QUICK_ORDER.PO_CUSTKEY                       AS PO_CUSTKEY      /*협력사코드*/
            ,WD_VOC_QUICK_ORDER.PO_CUST_TEL                      AS PO_CUST_TEL     /*협력사연락처*/
            ,WD_VOC_QUICK_ORDER.WRITER                           AS WRITER          /*작성자*/
            ,WD_VOC_QUICK_ORDER.WRITEDATE                        AS WRITEDATE       /*작성일자*/
            ,WD_VOC_QUICK_ORDER.WRITETIME                        AS WRITETIME       /*작성시간*/
            ,WD_VOC_QUICK_ORDER.REQ_DEPARTMENT                   AS REQ_DEPARTMENT  /*요청부서*/
            ,WD_VOC_QUICK_ORDER.REQ_ID                           AS REQ_ID          /*요청자*/
            ,WD_VOC_QUICK_ORDER.TO_SEQ                           AS TO_SEQ          /*도착지 방문순서*/
            ,WD_VOC_QUICK_ORDER.ADDRESS                          AS ADDRESS         /*고객주소*/ 
            ,DAMO.DEC(WD_VOC_QUICK_ORDER.ADDRESS2)               AS ADDRESS2        /*고객주소상세*/             
            ,DAMO.DEC(WD_VOC_QUICK_ORDER.PHONE)                  AS PHONE           /*고객전화번호*/
            ,WD_VOC_QUICK_ORDER.RMK                              AS RMK             /*비고*/
            ,WD_VOC_QUICK_ORDER.DELIVERYTYPE                     AS DELIVERYTYPE    /*배송방법*/
            ,WD_VOC_QUICK_ORDER.DELIVERY_METHOD                  AS DELIVERY_METHOD /*배송수단*/
            ,WD_VOC_QUICK_ORDER.DELIVERY_OPTION                  AS DELIVERY_OPTION /*배송선택*/
            ,WD_VOC_QUICK_ORDER.ARTICLE_TYPE                     AS ARTICLE_TYPE    /*물품종류*/
            ,WD_VOC_QUICK_ORDER.PAY_TYPE                         AS PAY_TYPE        /*지급구분*/
            ,WD_VOC_QUICK_ORDER.RESERVEDATE                      AS RESERVEDATE     /*예약일시*/
            ,WD_VOC_QUICK_ORDER.RESP_DEPT                        AS RESP_DEPT       /*귀책부서*/
            ,WD_VOC_QUICK_ORDER.RESP_REASON                      AS RESP_REASON     /*귀책사유*/
            ,WD_VOC_QUICK_ORDER.RESP_EMP                         AS RESP_EMP        /*귀책담당자*/
            ,WD_VOC_QUICK_ORDER.MEMO                             AS MEMO            /*전달사항*/
            ,WD_VOC_QUICK_ORDER.ADDDATE                          AS ADDDATE         /*최초등록시간*/
            ,WD_VOC_QUICK_ORDER.EDITDATE                         AS EDITDATE        /*최종변경시간*/
            ,WD_VOC_QUICK_ORDER.ADDWHO                           AS ADDWHO          /*최초등록자*/
            ,WD_VOC_QUICK_ORDER.EDITWHO                          AS EDITWHO         /*최종변경자*/              	                  
        FROM WD_VOC_QUICK_ORDER
   LEFT JOIN MS_SKU
          ON MS_SKU.STORERKEY = #{gStorerkey} 
         AND MS_SKU.SKU       = WD_VOC_QUICK_ORDER.SKU    
   LEFT JOIN MS_SKUDCSET 
          ON MS_SKUDCSET.STORERKEY = #{gStorerkey} 
         AND MS_SKUDCSET.DCCODE    = WD_VOC_QUICK_ORDER.DCCODE
         AND MS_SKUDCSET.SKU       = WD_VOC_QUICK_ORDER.SKU    
   LEFT JOIN CM_USER            ON (CM_USER.USERID = WD_VOC_QUICK_ORDER.REQ_ID)               /*사용자명*/ 
   LEFT JOIN CM_CODE_STORER CD1 ON (CD1.STORERKEY = #{gStorerkey} AND CD1.CODELIST = 'VSR_TYPE'     AND CD1.BASECODE = WD_VOC_QUICK_ORDER.VSRTYPE) /*VSR유형*/
   LEFT JOIN CM_CODE_STORER CD2 ON (CD2.STORERKEY = #{gStorerkey} AND CD2.CODELIST = 'STATUS_QUICK' AND CD2.BASECODE = WD_VOC_QUICK_ORDER.STATUS)  /*VOC퀵진행사항*/                
   LEFT JOIN CM_CODE_STORER CD3 ON (CD3.STORERKEY = #{gStorerkey} AND CD3.CODELIST = 'VOC_UOM'      AND CD3.BASECODE = WD_VOC_QUICK_ORDER.VOC_UOM) /*VOC단위*/
	   WHERE WD_VOC_QUICK_ORDER.STORERKEY = #{gStorerkey}   
         AND WD_VOC_QUICK_ORDER.DCCODE    = #{dccode}  /*센터*/  
	     AND WD_VOC_QUICK_ORDER.RCPT_NO   = #{rcptNo}  /*센터접수번호*/
	<choose>
	  <when test="reqFlag == '1'.toString()"><!-- 요청구분(1:집하지, 2:도착지) -->
	     /*
	       요건.VOC 2개를 한센터접수번호로 접수 시 집하지는 1곳일 수 있음
	         ->GTH_SEQ NOT NULL이면 빠지므로 1곳으로 등록가능
	     */
	     AND WD_VOC_QUICK_ORDER.GTH_SEQ IS NOT NULL	--등록된 데이터만
	    ORDER BY WD_VOC_QUICK_ORDER.GTH_SEQ /*집하지순서*/     
	  </when>
	  <otherwise>
	    ORDER BY WD_VOC_QUICK_ORDER.TO_SEQ /*고객방문순서*/   
	  </otherwise>
	</choose>		   
	                
    </select>
    
    <!-- 퀵주문접수 체크 정보 을(를) 조회 -->
    <select id="selectChkInsMaster"  parameterType="hashMap" resultType="hashMap">
        <![CDATA[
        SELECT /* [WdQuickRequestService.sqlx][WdQuickRequestService.selectChkInsMaster][퀵주문접수 체크][sss][20250717] */
               (
                SELECT CASE WHEN MAX(STATUS) <> '02' THEN 'Y'  ELSE 'N' END AS CHK1
                  FROM WD_VOC_QUICK_ORDER
                 WHERE RCPT_NO        = #{rcptNo}    
                   AND SERIALKEY      = #{serialkey} 
               ) AS STA_DT /*체크.진행상태*/
          FROM DUAL
        ]]>
    </select>    
    
    <!-- 
       퀵주문접수 API 데이터 전문 조회
         ->컬럼이 소문자인 이유 : API 전문 양식이 소문자이므로 매핑 편의 위해 소문자로 조회	
    -->       
    <select id="getOrderRequest01" resultType="cjfw.wms.wd.dto.WdQuickResAPI01Dto">
		SELECT  /* [WdQuickRequestService.sqlx][WdQuickRequestService.getOrderRequest01][퀵주문접수 API 데이터 조회][sss][20250717] */
		        MAX(A.c_code        ) AS c_code         --회사코드                                                                                
		       ,MAX(A.api_idx       ) AS api_idx        --고정값                                                                            
		       ,MAX(A.user_id       ) AS user_id        --인성과 연동된 ID 값(cjfreshway.stnlogis.com 로그인 가능 유무로 확인가능)                          
		       ,MAX(A.c_name        ) AS c_name         --접수자 이름ㆍ상호                                                                      
		       ,MAX(A.c_mobile      ) AS c_mobile       --접수자 연락처                                                                        
		       ,MAX(A.c_dept_name   ) AS c_dept_name    --접수자 부서명                                                                        
		       ,MAX(A.c_charge_name ) AS c_charge_name  --접수자 담당                                                                         
		       ,MAX(A.s_start       ) AS s_start        --출발지 상호ㆍ이름                                                                      
		       ,MAX(A.start_telno   ) AS start_telno    --출발지 전화번호                                                                       
		       ,MAX(A.dept_name     ) AS dept_name      --출발지 부서명                                                                        
		       ,MAX(A.charge_name   ) AS charge_name    --출발지 담당  
		       ,MAX(A.start_sido    ) AS start_sido     --출발지 시ㆍ도    
		       ,MAX(A.start_gugun   ) AS start_gugun    --출발지 구ㆍ군  
		       ,MAX(A.start_dong    ) AS start_dong     --출발지 동명        
		       ,MAX(A.start_ri      ) AS start_ri       --출발지 지번(리)     
		       ,MAX(A.start_location) AS start_location --출발지 상세주소      
		       ,MAX(A.s_dest        ) AS s_dest         --도착지 상호ㆍ이름         
		       ,MAX(A.dest_telno    ) AS dest_telno     --도착지 전화번호          
		       ,MAX(A.dest_dept     ) AS dest_dept      --도착지 부서명           
		       ,MAX(A.dest_charge   ) AS dest_charge    --도착지 담당            
		       ,MAX(A.dest_sido     ) AS dest_sido      --도착지 시ㆍ도      
		       ,MAX(A.dest_gugun    ) AS dest_gugun     --도착지 구ㆍ군    
		       ,MAX(A.dest_dong     ) AS dest_dong      --도착지 동명         
		       ,MAX(A.dest_ri       ) AS dest_ri        --도착지 지번(리)      
		       ,MAX(A.dest_location ) AS dest_location  --도착지 상세주소       
		       ,MAX(A.kind          ) AS kind           --배송수단(1:오토, 2:다마스, 3:트럭, 4:밴, 5:라보, 6:지하철, 7:플렉스)                                                                                                                                                                                                                                                                                                                    
		       ,MAX(A.pay_gbn       ) AS pay_gbn        --지급방법(1:선불, 2:착불, 3:신용, 4:송금, 5:수금)                                                                                                                                                                                                                                                                                                                                  
		       ,MAX(A.doc           ) AS doc            --배송방법(1:편도, 3:왕복, 5:경유)                                                                                                                                                                                                                                                                                                                                              
		       ,MAX(A.sfast         ) AS sfast          --배송선택(1:일반, 3:급송, 5:조조, 7:야간, 8:할증, 9:과적, 0:택배, A:심야, B:휴일, C:납품, D:대기, F:눈비, 4:독차, 6:혼적, G:할인, M:마일, H:우편, I:행랑, J:해외, K:신문, Q:퀵, N:보관, O:혹한, P:상하차, R:명절)                                                                                                                                                                                                          
		       ,MAX(A.item_type     ) AS item_type      --물품종류(1:서류봉투, 2:소박스, 3:중박스, 4:대박스)                                                                                                                                                                                                                                                                                                                                   
               ,MAX(A.memo          ) AS memo           --전달내용 
		       ,MAX(A.sms_telno     ) AS sms_telno      --SMS로 전달 받을 핸드폰번호                                                                                                                                                                                                                                                                                                                                                    
		       ,MAX(A.use_check     ) AS use_check      --예약시간 사용여부(체크시:3)                     
		       ,MAX(A.pickup_date   ) AS pickup_date    --예약일(오늘 기준 최대 한달까지 선택가능)              
		       ,MAX(A.pick_hour     ) AS pick_hour      --예약일(시간단위)                            
		       ,MAX(A.pick_min      ) AS pick_min       --예약일(분단위)  
		       ,MAX(A.o_etc1        ) AS o_etc1         --여분필드1
		       ,MAX(A.o_etc2        ) AS o_etc2         --여분필드3
		       ,MAX(A.o_etc3        ) AS o_etc3         --여분필드4
		       ,MAX(A.o_etc4        ) AS o_etc4         --여분필드5
		       ,MAX(A.o_etc5        ) AS o_etc5         --여분필드6
		       ,MAX(A.o_etc6        ) AS o_etc6         --여분필드7
		       ,MAX(A.o_etc7        ) AS o_etc7         --여분필드8
		       ,MAX(A.o_etc8        ) AS o_etc8         --여분필드9
		       ,MAX(A.o_etc9        ) AS o_etc9         --여분필드10
		       ,MAX(A.o_etc10       ) AS o_etc10        --여분필드11
		 FROM (        
	    SELECT  MAX(A.c_code        ) AS c_code         --회사코드                                                                                
	           ,MAX(A.api_idx       ) AS api_idx        --고정값                                                                            
	           ,MAX(A.user_id       ) AS user_id        --인성과 연동된 ID 값(cjfreshway.stnlogis.com 로그인 가능 유무로 확인가능)                          
	           ,MAX(A.c_name        ) AS c_name         --접수자 이름ㆍ상호                                                                      
	           ,MAX(A.c_mobile      ) AS c_mobile       --접수자 연락처                                                                        
	           ,MAX(A.c_dept_name   ) AS c_dept_name    --접수자 부서명                                                                        
	           ,MAX(A.c_charge_name ) AS c_charge_name  --접수자 담당                                                                         
	           ,MAX(A.s_start       ) AS s_start        --출발지 상호ㆍ이름                                                                      
	           ,MAX(A.start_telno   ) AS start_telno    --출발지 전화번호                                                                       
	           ,MAX(A.dept_name     ) AS dept_name      --출발지 부서명                                                                        
	           ,MAX(A.charge_name   ) AS charge_name    --출발지 담당  
	           ,MAX(A.start_sido    ) AS start_sido     --출발지 시ㆍ도    
	           ,MAX(A.start_gugun   ) AS start_gugun  --출발지 구ㆍ군  
	           ,MAX(A.start_dong    ) AS start_dong     --출발지 동명        
	           ,MAX(A.start_ri      ) AS start_ri       --출발지 지번(리)     
	           ,MAX(A.start_location) AS start_location --출발지 상세주소      
	           ,MAX(A.s_dest        ) AS s_dest         --도착지 상호ㆍ이름         
	           ,MAX(A.dest_telno    ) AS dest_telno     --도착지 전화번호          
	           ,MAX(A.dest_dept     ) AS dest_dept      --도착지 부서명           
	           ,MAX(A.dest_charge   ) AS dest_charge    --도착지 담당            
	           ,MAX(A.dest_sido     ) AS dest_sido      --도착지 시ㆍ도      
	           ,MAX(A.dest_gugun    ) AS dest_gugun     --도착지 구ㆍ군    
	           ,MAX(A.dest_dong     ) AS dest_dong      --도착지 동명         
	           ,MAX(A.dest_ri       ) AS dest_ri        --도착지 지번(리)      
	           ,MAX(A.dest_location ) AS dest_location  --도착지 상세주소       
	           ,MAX(A.kind          ) AS kind           --배송수단(1:오토, 2:다마스, 3:트럭, 4:밴, 5:라보, 6:지하철, 7:플렉스)                                                                                                                                                                                                                                                                                                                    
	           ,MAX(A.pay_gbn       ) AS pay_gbn        --지급방법(1:선불, 2:착불, 3:신용, 4:송금, 5:수금)                                                                                                                                                                                                                                                                                                                                  
	           ,MAX(A.doc           ) AS doc            --배송방법(1:편도, 3:왕복, 5:경유)                                                                                                                                                                                                                                                                                                                                              
	           ,MAX(A.sfast         ) AS sfast          --배송선택(1:일반, 3:급송, 5:조조, 7:야간, 8:할증, 9:과적, 0:택배, A:심야, B:휴일, C:납품, D:대기, F:눈비, 4:독차, 6:혼적, G:할인, M:마일, H:우편, I:행랑, J:해외, K:신문, Q:퀵, N:보관, O:혹한, P:상하차, R:명절)
	           ,MAX(A.item_type     ) AS item_type      --물품종류(1:서류봉투, 2:소박스, 3:중박스, 4:대박스)                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             
               ,MAX(A.memo          ) AS memo           --전달내용                 
	           ,MAX(A.sms_telno     ) AS sms_telno      --SMS로 전달 받을 핸드폰번호                                                                                                                                                                                                                                                                                                                                                    
	           ,MAX(A.use_check     ) AS use_check      --예약시간 사용여부(체크시:3)                     
	           ,MAX(A.pickup_date   ) AS pickup_date    --예약일(오늘 기준 최대 한달까지 선택가능)              
	           ,MAX(A.pick_hour     ) AS pick_hour      --예약일(시간단위)                            
	           ,MAX(A.pick_min      ) AS pick_min       --예약일(분단위)  
	           --
	           --
	           ,MAX(A.RCPT_NO       ) AS o_etc1         /*여분필드1 - 센터접수번호*/
	           ,MAX(A.VOCNO         ) AS o_etc2         /*여분필드3 - VOC번호*/
	           ,MAX(A.DCCODE        ) AS o_etc3         /*여분필드4 - 센터코드*/           
	           ,MAX(A.RESP_DEPT2    ) AS o_etc4         /*여분필드5 - 귀책부서*/           
	           ,MAX(A.RESP_REASON2  ) AS o_etc5         /*여분필드6 - 귀책사유*/               
	           ,MAX(A.RESP_EMP      ) AS o_etc6         /*여분필드7 - 귀책담당자 */
	           ,''            AS o_etc7  /*여분필드8 - 시스템 장비*/
	           ,''            AS o_etc8  /*여분필드9*/
	           ,''            AS o_etc9  /*여분필드10*/
	           ,''            AS o_etc10 /*여분필드11*/
	           --
	           --
	           ,A.GTH_SEQ                AS GTH_SEQ    /*집하지방문순서  - 집하지*/
	           ,A.GTH_NM                 AS GTH_NM     /*집하지명*/
	           ,A.GTH_ADDR               AS GTH_ADDR   /*집하지주소*/
	           ,DAMO.DEC(A.GTH_TEL)      AS GTH_TEL    /*집하지연락처*/ 
	           ,MAX(A.RMK)               AS RMK        /*전달사항*/  
               ,MAX(A.MEMO2)             AS MEMO2      /*전달사항*/
               ,MAX(A.TO_SEQ)            AS TO_SEQ     /*도착지 방문순서*/
		 FROM (   
	          SELECT '1914'                                        AS c_code         --회사코드(고정)
	                 ,'20'                                         AS api_idx        --APIID(고정)
	                 ,A.user_id                                    AS user_id        --인성과 연동된 ID 값(cjfreshway.stnlogis.com 로그인 가능 유무로 확인가능)
	                 ,A.c_name                                     AS c_name         --접수자 이름ㆍ상호
	                 ,A.c_mobile                                   AS c_mobile       --접수자 연락처
	                 ,A.c_dept_name                                AS c_dept_name    --접수자 부서명
	                 ,A.c_charge_name                              AS c_charge_name  --접수자 담당
                     --
                     ,CASE WHEN RN=1 THEN A.GTH_NM     ELSE '' END AS s_start        --출발지 상호ㆍ이름
                     ,CASE WHEN RN=1 THEN A.GTH_TEL    ELSE '' END AS start_telno    --출발지 전화번호
                     ,CASE WHEN RN=1 THEN A.GTH_NM     ELSE '' END AS dept_name      --출발지 부서명
                     ,CASE WHEN RN=1 THEN A.GTH_EMP_NM ELSE '' END AS charge_name    --출발지 담당
	                 --
	                 ,CASE WHEN RN=1 THEN NVL(LOGISONESVC.FN_ADDRESS_INFO('1',A.GTH_ADDR,'',''),SUBSTR(A.GTH_ADDR,1,INSTR(A.GTH_ADDR,' '))) ELSE '' END AS start_sido     --출발지 시ㆍ도(경기도에서 경기만 있으면 경기로 세팅)
	                 ,CASE WHEN RN=1 THEN LOGISONESVC.FN_ADDRESS_INFO('2',A.GTH_ADDR,'','') ELSE '' END AS start_gugun    --출발지 구ㆍ군
	                 ,CASE WHEN RN=1 THEN LOGISONESVC.FN_ADDRESS_INFO('3',A.GTH_ADDR,'','') ELSE '' END AS start_dong     --출발지 동명
	                 ,CASE WHEN RN=1 THEN LOGISONESVC.FN_ADDRESS_INFO('4',A.GTH_ADDR,'','') ELSE '' END AS start_ri       --출발지 지번(리)
	                 ,CASE WHEN RN=1 THEN LOGISONESVC.FN_ADDRESS_INFO('5',A.GTH_ADDR,'','') ELSE '' END AS start_location --출발지 상세주소
	                 ,CASE WHEN RN=1 THEN A.MGMT_CUSTNAME   ELSE '' END AS s_dest         --도착지 상호ㆍ이름  
	                 ,CASE WHEN RN=1 THEN DAMO.DEC(A.PHONE) ELSE '' END AS dest_telno     --도착지 전화번호   
	                 ,CASE WHEN RN=1 THEN A.MGMT_CUSTNAME   ELSE '' END AS dest_dept      --도착지 부서명    
	                 ,CASE WHEN RN=1 THEN A.MGMT_CUSTNAME   ELSE '' END AS dest_charge    --도착지 담당 
	                 ,CASE WHEN RN=1 THEN NVL(LOGISONESVC.FN_ADDRESS_INFO('1',A.ADDRESS,'',''),SUBSTR(A.ADDRESS,1,INSTR(A.ADDRESS,' '))) ELSE '' END  AS dest_sido      --도착지 시ㆍ도    
	                 ,CASE WHEN RN=1 THEN LOGISONESVC.FN_ADDRESS_INFO('2',A.ADDRESS,'','') ELSE '' END AS dest_gugun     --도착지 구ㆍ군    
	                 ,CASE WHEN RN=1 THEN LOGISONESVC.FN_ADDRESS_INFO('3',A.ADDRESS,'','') ELSE '' END AS dest_dong      --도착지 동명 
	                 ,CASE WHEN RN=1 THEN LOGISONESVC.FN_ADDRESS_INFO('4',A.ADDRESS,'','') ELSE '' END AS dest_ri        --도착지 지번(리)  
	                 ,CASE WHEN RN=1 THEN LOGISONESVC.FN_ADDRESS_INFO('5',A.ADDRESS,'','') ELSE '' END AS dest_location  --도착지 상세주소      
	                 ,A.DELIVERY_METHOD                                         AS kind           --배송수단(1:오토, 2:다마스, 3:트럭, 4:밴, 5:라보, 6:지하철, 7:플렉스)
	                 ,A.PAY_TYPE                                                AS pay_gbn        --지급방법(1:선불, 2:착불, 3:신용, 4:송금, 5:수금)
	                 ,A.DELIVERYTYPE                                            AS doc            --배송방법(1:편도, 3:왕복, 5:경유)
	                 ,A.DELIVERY_OPTION                                         AS sfast          --배송선택(1:일반, 3:급송, 5:조조, 7:야간, 8:할증, 9:과적, 0:택배, A:심야, B:휴일, C:납품, D:대기, F:눈비, 4:독차, 6:혼적, G:할인, M:마일, H:우편, I:행랑, J:해외, K:신문, Q:퀵, N:보관, O:혹한, P:상하차, R:명절)
	                 ,A.ARTICLE_TYPE                                            AS item_type      --물품종류(1:서류봉투, 2:소박스, 3:중박스, 4:대박스)
	                 ,A.DELIVERYMEMO                                            AS memo           --전달내용
	                 ,DAMO.DEC(A.PHONE)                                         AS sms_telno      --SMS로 전달 받을 핸드폰번호
	                 ,CASE WHEN LENGTH(A.RESERVEDATE) = 12 THEN 'Y' ELSE '' END AS use_check      --예약시간 사용여부(체크시:3)
	                 ,SUBSTR(A.RESERVEDATE,1,8)                                 AS pickup_date    --예약일(오늘 기준 최대 한달까지 선택가능)
	                 ,SUBSTR(A.RESERVEDATE,9,2)                                 AS pick_hour      --예약일(시간단위)
	                 ,SUBSTR(A.RESERVEDATE,11,2)                                AS pick_min       --예약일(분단위)
	                 ,'' AS pick_sec       --예약일(초단위)
	                 ,'' AS car_kind       --차종구분 코드(01: 플축카고, 11: 리프트카고, 12: 플러스리, 42: 플축리, 02: 윙바디, 03: 플러스윙, 04: 축윙, 05: 플축윙, 14: 리프트윙, 16: 플러스윙리, 17: 플축윙리, 06: 탑, 08: 리프트탑, 07: 호루, 50: 리프트호루, 47: 자바라, 51: 리프트자바라, 18: 냉동탑, 19: 냉장탑, 21: 냉동윙, 22: 냉장윙, 23: 냉동탑리, 24: 냉장탑리, 25: 냉동플축윙, 26: 냉장플축윙, 27: 냉동플축리, 28: 냉장플축리, 29: 평카, 30: 로브이, 31: 츄레라, 34: 로베드, 32: 사다리, 33: 초장축)
	                  --
	                  --
	                  --
	                   ,A.STATUSNM      AS STATUSNM   /*진행상태명*/   
	                   ,A.RCPT_NO       AS RCPT_NO    /*센터접수번호*/
	                   ,A.VOCNO         AS VOCNO      /*VOC번호 */
	                   ,A.VOCSEQ        AS VOCSEQ     /*VOC순번 */
	                   ,A.VSRNO         AS VSRNO      /*VSR번호 */           
	                   ,A.VSRTYPENM     AS VSRTYPENM  /*VSR명*/
	                   ,A.DOCNO         AS DOCNO      /*주문번호*/
	                   ,A.DOCLINE       AS DOCLINE    /*주문순번*/  
	                   ,A.SKU           AS SKU        /*상품코드*/  
	                   ,A.SKUNAME       AS SKUNAME    /*상품명*/        
	                   ,A.SKU_INFO      AS SKU_INFO   /*상품내역*/          
	                   ,A.ORDERQTY      AS ORDERQTY   /*주문량*/
	                   ,A.ORDERUOM      AS ORDERUOM   /*주문단위*/
	                   ,A.VOC_UOM       AS VOC_UOM    /*voc단위 */
	                   ,A.VOC_UOMNM     AS VOC_UOMNM  /*voc단위명*/
	                   ,A.VOC_QTY       AS VOC_QTY    /*voc량*/  
	                   --                                                                
	                   ,A.RCPT_DATE              AS RCPT_DATE  /*센터접수일자*/
	                   ,A.RCPT_HOUR              AS RCPT_HOUR  /*센터접수시간*/            
	                   --
	                   ,A.GTH_SEQ                AS GTH_SEQ    /*집하지방문순서  - 집하지*/
	                   ,A.GTH_CD                 AS GTH_CD     /*집하지코드*/ 
	                   ,A.GTH_NM                 AS GTH_NM     /*집하지명*/
	                   ,A.GTH_ADDR               AS GTH_ADDR   /*집하지주소*/
	                   ,A.GTH_EMP_NM             AS GTH_EMP_NM /*집하지담당자명*/
	                   ,DAMO.DEC(A.GTH_TEL)      AS GTH_TEL    /*집하지연락처*/   
	                   ,A.LOC                    AS LOC        /*로케이션 */         
	                 /**/
	                 ,A.SERIALKEY                        AS SERIALKEY       /*데이터번호*/   
	                 ,A.DCCODE                           AS DCCODE          /*물류센터*/  
	                 ,A.IF_SERIALKEY                     AS IF_SERIALKEY    /*IF데이터번호*/
	                 ,A.QUICK_DOCNO                      AS QUICK_DOCNO     /*퀵주문번호*/
	                 ,A.STATUS                           AS STATUS          /*진행상태(01:VOC퀵요청,02:센터접수,03:퀵주문등록,04:퀵주문취소등록,05:퀵주문처리완료,06:퀵주문취소완료)*/
	                 ,A.VSR_SEQ                          AS VSR_SEQ         /*VSR순번 */
	                 ,A.DELIVERYDATE                     AS DELIVERYDATE    /*납품일*/
	                 ,A.DEPARTMENT                       AS DEPARTMENT      /*담당부서코드*/
	                 ,A.SLST_ID                          AS SLST_ID         /*판매처코드*/
	                 ,A.SLST_NM                          AS SLST_NM         /*판매처명*/
	                 ,A.MGMT_CUSTKEY                     AS MGMT_CUSTKEY    /*관리처코드*/
	                 ,A.MGMT_CUSTNAME                    AS MGMT_CUSTNAME   /*관리처명*/
	                 ,A.UOM                              AS UOM             /*상품단위*/
	                 ,A.PO_CUSTKEY                       AS PO_CUSTKEY      /*협력사코드*/
	                 ,A.PO_CUST_TEL                      AS PO_CUST_TEL     /*협력사연락처*/
	                 ,A.WRITER                           AS WRITER          /*작성자*/
	                 ,A.WRITEDATE                        AS WRITEDATE       /*작성일자*/
	                 ,A.WRITETIME                        AS WRITETIME       /*작성시간*/
	                 ,A.REQ_DEPARTMENT                   AS REQ_DEPARTMENT  /*요청부서*/
	                 ,A.REQ_ID                           AS REQ_ID          /*요청자*/
	                 ,A.TO_SEQ                           AS TO_SEQ          /*도착지 방문순서*/
	                 ,A.ADDRESS                          AS ADDRESS         /*고객주소*/
	                 ,DAMO.DEC(A.PHONE)                  AS PHONE           /*고객전화번호*/
	                 ,A.RMK                              AS RMK             /*비고*/
	                 ,A.DELIVERYTYPE                     AS DELIVERYTYPE    /*배송방법*/
	                 ,A.DELIVERY_METHOD                  AS DELIVERY_METHOD /*배송수단*/
	                 ,A.DELIVERY_OPTION                  AS DELIVERY_OPTION /*배송선택*/
	                 ,A.ARTICLE_TYPE                     AS ARTICLE_TYPE    /*물품종류*/
	                 ,A.PAY_TYPE                         AS PAY_TYPE        /*지급구분*/
	                 ,A.RESERVEDATE                      AS RESERVEDATE     /*예약일시*/
	                 ,A.RESP_DEPT                        AS RESP_DEPT       /*귀책부서*/
	                 ,A.RESP_DEPT2                       AS RESP_DEPT2      /*귀책부서-전송용*/
	                 ,A.RESP_REASON                      AS RESP_REASON     /*귀책사유*/
	                 ,A.RESP_REASON2                     AS RESP_REASON2    /*귀책사유-전송용*/
	                 ,A.RESP_EMP                         AS RESP_EMP        /*귀책담당자*/
	                 ,A.MEMO2                            AS MEMO2           /*전달사항*/
	           FROM (  
	                  SELECT   ROW_NUMBER() OVER(PARTITION BY RCPT_NO ORDER BY VSRNO,VOCSEQ DESC) RN
	                           --
	                          ,NVL(CD41.BASEDESCR,CD4.BASEDESCR)                 AS user_id        --인성과 연동된 ID 값(cjfreshway.stnlogis.com 로그인 가능 유무로 확인가능)
	                          ,NVL(CM_USER.USERNAME,#{gUserNm})                   AS c_name        --접수자 이름ㆍ상호
	                          ,CD41.DATA2                                        AS c_mobile       --접수자 연락처
	                          ,NVL(WD_VOC_QUICK_ORDER.REQ_DEPARTMENT,CD41.DATA1) AS c_dept_name    --접수자 부서명     
	                          ,NVL(CM_USER.USERNAME,#{gUserId})                   AS c_charge_name --접수자 담당                        
	                           --
	                          ,NVL(CD2.BASEDESCR,WD_VOC_QUICK_ORDER.STATUS)       AS STATUSNM   /*진행상태명*/   
	                          ,WD_VOC_QUICK_ORDER.RCPT_NO                         AS RCPT_NO    /*센터접수번호*/
	                          ,WD_VOC_QUICK_ORDER.VOCNO                           AS VOCNO      /*VOC번호 */
	                          ,WD_VOC_QUICK_ORDER.VOCSEQ                          AS VOCSEQ     /*VOC순번 */
	                          ,WD_VOC_QUICK_ORDER.VSRNO                           AS VSRNO      /*VSR번호 */           
	                          ,NVL(CD1.BASEDESCR,WD_VOC_QUICK_ORDER.VSRTYPE)      AS VSRTYPENM  /*VSR명*/
	                          ,WD_VOC_QUICK_ORDER.DOCNO                           AS DOCNO      /*주문번호*/
	                          ,WD_VOC_QUICK_ORDER.DOCLINE                         AS DOCLINE    /*주문순번*/  
	                          ,WD_VOC_QUICK_ORDER.SKU                             AS SKU        /*상품코드*/  
	                          ,MS_SKU.DESCRIPTION                                 AS SKUNAME    /*상품명*/        
	                          ,WD_VOC_QUICK_ORDER.SKU_INFO                        AS SKU_INFO   /*상품내역*/          
	                          ,WD_VOC_QUICK_ORDER.ORDERQTY                        AS ORDERQTY   /*주문량*/
	                          ,WD_VOC_QUICK_ORDER.ORDERUOM                        AS ORDERUOM   /*주문단위*/
	                          ,WD_VOC_QUICK_ORDER.VOC_UOM                         AS VOC_UOM    /*voc단위 */
	                          ,NVL(CD3.BASEDESCR,WD_VOC_QUICK_ORDER.VOC_UOM)      AS VOC_UOMNM  /*voc단위명*/
	                          ,WD_VOC_QUICK_ORDER.VOC_QTY                         AS VOC_QTY    /*voc량*/  
	                          --                                                                
	                          ,WD_VOC_QUICK_ORDER.RCPT_DATE                       AS RCPT_DATE  /*센터접수일자*/
	                          ,WD_VOC_QUICK_ORDER.RCPT_HOUR                       AS RCPT_HOUR  /*센터접수시간*/            
	                          
	                          --
	                          ,WD_VOC_QUICK_ORDER.GTH_SEQ                         AS GTH_SEQ     /*집하지방문순서  - 집하지*/
	                          ,WD_VOC_QUICK_ORDER.GTH_CD                          AS GTH_CD      /*집하지코드*/ 
	                          ,WD_VOC_QUICK_ORDER.GTH_NM                          AS GTH_NM      /*집하지명*/
	                          ,WD_VOC_QUICK_ORDER.GTH_ADDR||' '||DAMO.DEC(WD_VOC_QUICK_ORDER.GTH_ADDRDTL) AS GTH_ADDR    /*집하지주소*/
	                          ,WD_VOC_QUICK_ORDER.GTH_EMP_NM                      AS GTH_EMP_NM  /*집하지담당자명*/
	                          ,DAMO.DEC(WD_VOC_QUICK_ORDER.GTH_TEL)               AS GTH_TEL     /*집하지연락처*/   
	                          ,MS_SKUDCSET.LOC                                    AS LOC         /*로케이션 */         
	                        /**/
	                        ,WD_VOC_QUICK_ORDER.SERIALKEY                        AS SERIALKEY       /*데이터번호*/   
	                        ,WD_VOC_QUICK_ORDER.DCCODE                           AS DCCODE          /*물류센터*/  
	                        ,WD_VOC_QUICK_ORDER.IF_SERIALKEY                     AS IF_SERIALKEY    /*IF데이터번호*/
	                        ,WD_VOC_QUICK_ORDER.QUICK_DOCNO                      AS QUICK_DOCNO     /*퀵주문번호*/
	                        ,NVL(WD_VOC_QUICK_ORDER.STATUS,'01')                 AS STATUS          /*진행상태(01:VOC퀵요청,02:센터접수,03:퀵주문등록,04:퀵주문취소등록,05:퀵주문처리완료,06:퀵주문취소완료)*/
	                        ,WD_VOC_QUICK_ORDER.VSR_SEQ                          AS VSR_SEQ         /*VSR순번 */
	                        ,WD_VOC_QUICK_ORDER.DELIVERYDATE                     AS DELIVERYDATE    /*납품일*/
	                        ,WD_VOC_QUICK_ORDER.DEPARTMENT                       AS DEPARTMENT      /*담당부서코드*/
	                        ,WD_VOC_QUICK_ORDER.SLST_ID                          AS SLST_ID         /*판매처코드*/
	                        ,WD_VOC_QUICK_ORDER.SLST_NM                          AS SLST_NM         /*판매처명*/
	                        ,WD_VOC_QUICK_ORDER.MGMT_CUSTKEY                     AS MGMT_CUSTKEY    /*관리처코드*/
	                        ,WD_VOC_QUICK_ORDER.MGMT_CUSTNAME                    AS MGMT_CUSTNAME   /*관리처명*/
	                        ,WD_VOC_QUICK_ORDER.UOM                              AS UOM             /*상품단위*/
	                        ,WD_VOC_QUICK_ORDER.PO_CUSTKEY                       AS PO_CUSTKEY      /*협력사코드*/
	                        ,WD_VOC_QUICK_ORDER.PO_CUST_TEL                      AS PO_CUST_TEL     /*협력사연락처*/
	                        ,WD_VOC_QUICK_ORDER.WRITER                           AS WRITER          /*작성자*/
	                        ,WD_VOC_QUICK_ORDER.WRITEDATE                        AS WRITEDATE       /*작성일자*/
	                        ,WD_VOC_QUICK_ORDER.WRITETIME                        AS WRITETIME       /*작성시간*/
	                        ,WD_VOC_QUICK_ORDER.REQ_DEPARTMENT                   AS REQ_DEPARTMENT  /*요청부서*/
	                        ,WD_VOC_QUICK_ORDER.REQ_ID                           AS REQ_ID          /*요청자*/
	                        ,WD_VOC_QUICK_ORDER.TO_SEQ                           AS TO_SEQ          /*도착지 방문순서*/
	                        ,WD_VOC_QUICK_ORDER.ADDRESS||' '||DAMO.DEC(WD_VOC_QUICK_ORDER.ADDRESS2) AS ADDRESS         /*고객주소*/
	                        ,DAMO.DEC(WD_VOC_QUICK_ORDER.ADDRESS2)               AS ADDRESS2        /*고객상세주소*/
	                        ,DAMO.DEC(WD_VOC_QUICK_ORDER.PHONE)                  AS PHONE           /*고객전화번호*/
	                        ,WD_VOC_QUICK_ORDER.RMK                              AS RMK             /*비고*/
	                        ,WD_VOC_QUICK_ORDER.DELIVERYTYPE                     AS DELIVERYTYPE    /*배송방법*/
	                        ,WD_VOC_QUICK_ORDER.DELIVERY_METHOD                  AS DELIVERY_METHOD /*배송수단*/
	                        ,WD_VOC_QUICK_ORDER.DELIVERY_OPTION                  AS DELIVERY_OPTION /*배송선택*/
	                        ,WD_VOC_QUICK_ORDER.ARTICLE_TYPE                     AS ARTICLE_TYPE    /*물품종류*/
	                        ,WD_VOC_QUICK_ORDER.PAY_TYPE                         AS PAY_TYPE        /*지급구분*/
	                        ,WD_VOC_QUICK_ORDER.RESERVEDATE                      AS RESERVEDATE     /*예약일시*/
	                        ,WD_VOC_QUICK_ORDER.RESP_DEPT                        AS RESP_DEPT       /*귀책부서*/
	                        ,WD_VOC_QUICK_ORDER.RESP_DEPT||':'||CD5.BASEDESCR    AS RESP_DEPT2      /*귀책부서-전송용*/
	                        ,WD_VOC_QUICK_ORDER.RESP_REASON                      AS RESP_REASON     /*귀책사유*/
	                        ,WD_VOC_QUICK_ORDER.RESP_REASON||':'||CD6.BASEDESCR  AS RESP_REASON2     /*귀책사유2-전송용*/
	                        ,WD_VOC_QUICK_ORDER.RESP_EMP                         AS RESP_EMP        /*귀책담당자*/
	                        ,WD_VOC_QUICK_ORDER.MEMO                             AS MEMO2           /*전달사항*/     
	                        ,WD_VOC_QUICK_ORDER.DELIVERYMEMO                     AS DELIVERYMEMO    /*배송메시지*/     
	                    FROM WD_VOC_QUICK_ORDER
	               LEFT JOIN MS_SKU
	                      ON MS_SKU.STORERKEY      = #{gStorerkey} 
	                     AND MS_SKU.SKU            = WD_VOC_QUICK_ORDER.SKU    
	               LEFT JOIN CM_DC ON CM_DC.DCCODE = WD_VOC_QUICK_ORDER.DCCODE
	               LEFT JOIN MS_SKUDCSET 
	                      ON MS_SKUDCSET.STORERKEY = #{gStorerkey} 
	                     AND MS_SKUDCSET.DCCODE    = WD_VOC_QUICK_ORDER.DCCODE
	                     AND MS_SKUDCSET.SKU       = WD_VOC_QUICK_ORDER.SKU    
	               LEFT JOIN CM_USER             ON (CM_USER.USERID = WD_VOC_QUICK_ORDER.REQ_ID) /*사용자명-접수자*/ 
	               LEFT JOIN CM_CODE_STORER CD1  ON (CD1.STORERKEY  = #{gStorerkey} AND CD1.CODELIST = 'VSR_TYPE'          AND CD1.BASECODE = WD_VOC_QUICK_ORDER.VSRTYPE)     /*VSR유형*/
	               LEFT JOIN CM_CODE_STORER CD2  ON (CD2.STORERKEY  = #{gStorerkey} AND CD2.CODELIST = 'STATUS_QUICK'      AND CD2.BASECODE = WD_VOC_QUICK_ORDER.STATUS)      /*VOC퀵진행사항*/                
	               LEFT JOIN CM_CODE_STORER CD3  ON (CD3.STORERKEY  = #{gStorerkey} AND CD3.CODELIST = 'VOC_UOM'           AND CD3.BASECODE = WD_VOC_QUICK_ORDER.VOC_UOM)     /*VOC단위*/
	               LEFT JOIN CM_CODE_STORER CD4  ON (CD4.STORERKEY  = #{gStorerkey} AND CD4.CODELIST = 'QUICK_ORDERER'     AND CD4.BASECODE = #{gUserId})                     /*퀵주문 - gUserId의 정보를 조회하는 거임*/
	               LEFT JOIN CM_CODE_STORER CD41 ON (CD41.STORERKEY = #{gStorerkey} AND CD41.CODELIST = 'QUICK_ORDERER'    AND CD41.BASECODE = WD_VOC_QUICK_ORDER.DCCODE)     /*퀵주문 - 센터기준기준*/
	               LEFT JOIN CM_CODE_STORER CD5  ON (CD5.STORERKEY  = #{gStorerkey} AND CD5.CODELIST = 'RESP_DEPT_QUICK'   AND CD5.BASECODE = WD_VOC_QUICK_ORDER.RESP_DEPT)   /*귀책부서*/
	               LEFT JOIN CM_CODE_STORER CD6  ON (CD6.STORERKEY  = #{gStorerkey} AND CD6.CODELIST = 'RESP_REASON_QUICK' AND CD6.BASECODE = WD_VOC_QUICK_ORDER.RESP_REASON) /*귀책사유*/
	                   WHERE WD_VOC_QUICK_ORDER.STORERKEY = #{gStorerkey}     
	                     AND WD_VOC_QUICK_ORDER.DCCODE    = #{dccode}  /*센터*/  
	                     AND WD_VOC_QUICK_ORDER.RCPT_NO   = #{rcptNo}  /*센터접수번호*/
	                ) A
            	) A
	        GROUP BY GTH_SEQ
	               , GTH_NM
	               , GTH_ADDR
	               , GTH_TEL
    	) A      
    </select>
    
 
    <!-- 집하지 처리 update -->
    <insert id="updateDetailListDelivery01">
        UPDATE WD_VOC_QUICK_ORDER
           SET GTH_SEQ     = #{gthSeq}               /*집하지방문순서*/
              ,GTH_CD      = #{gthCd}                /*집하지코드*/
              ,GTH_NM      = #{gthNm}                /*집하지명*/
              ,GTH_ADDR    = #{gthAddr}              /*집하지주소*/
              ,GTH_ADDRDTL = DAMO.ENC(#{gthAddrdtl}) /*집하지상세주소*/
              ,GTH_EMP_NM  = #{gthEmpNm}             /*집하지담당자명*/
              ,GTH_TEL     = DAMO.ENC(#{gthTel})     /*집하지연락처*/
              --           
              ,UOM         = #{uom}         /*상품단위*/
              ,VOC_QTY     = #{vocQty}      /*voc량 - 수량*/
              ,SKU         = #{sku}         /*상품코드*/          
              ,SKU_INFO    = #{skuInfo}     /*상품내역*/
              ,MEMO        = #{memo}         /*비고 */
              --            
             ,EDITDATE     = SYSDATE
             ,EDITWHO      = #{gUserId}    
        WHERE RCPT_NO      = #{rcptNo}    /*센터접수번호 - 집하지는 1곳*/  
          AND SERIALKEY    = #{serialkey} /*시리얼키*/ 
          AND STATUS       = '02'       /*상태(01:VOC퀵요청,02:센터접수,03:퀵주문등록,04:퀵주문취소등록,05:퀵주문처리완료,06:퀵주문취소완료)*/
    </insert>    
    
    <!-- 집하지 삭제처리 delete -->
    <insert id="deleteDetailListDelivery01">
        UPDATE WD_VOC_QUICK_ORDER
           SET GTH_SEQ    = null    /*집하지방문순서*/
              ,GTH_CD     = null    /*집하지코드*/
              ,GTH_NM     = null    /*집하지명*/
              ,GTH_ADDR   = null    /*집하지주소*/
              ,GTH_EMP_NM = null    /*집하지담당자명*/
              ,GTH_TEL    = null    /*집하지연락처*/
              --            
             ,EDITDATE    = SYSDATE
             ,EDITWHO     = #{gUserId}    
        WHERE RCPT_NO     = #{rcptNo}    /*센터접수번호*/  
          AND SERIALKEY   = #{serialkey} /*시리얼키*/       
          AND STATUS      = '02'       /*상태(01:VOC퀵요청,02:센터접수,03:퀵주문등록,04:퀵주문취소등록,05:퀵주문처리완료,06:퀵주문취소완료)*/
    </insert>        
    
    <!-- 도착지 처리 update -->
    <insert id="updateDetailListDestination01">
        UPDATE WD_VOC_QUICK_ORDER
            SET MGMT_CUSTNAME = #{mgmtCustname} /*관리처명-고객명*/
              , TO_SEQ        = #{toSeq}        /*도착지 방문순서*/ 
              , ADDRESS       = #{address}      /*고객주소*/
              , ADDRESS2      = DAMO.ENC(#{address2})     /*고객상세주소*/
              , PHONE         = DAMO.ENC(#{phone})        /*고객전화번호*/
              , SKU_INFO      =	#{skuInfo}	
              --
              ,EDITDATE       = SYSDATE
              ,EDITWHO        = #{gUserId}    
         WHERE RCPT_NO        = #{rcptNo}    /*센터접수번호*/  
           AND SERIALKEY      = #{serialkey} /*시리얼키*/       
           AND STATUS         = '02'       /*상태(01:VOC퀵요청,02:센터접수,03:퀵주문등록,04:퀵주문취소등록,05:퀵주문처리완료,06:퀵주문취소완료)*/
    </insert>   
    
    <!-- 
    	*******************************************************************************************************
    	* Tab3(3/3)
    	*******************************************************************************************************
    -->    
    
    <!-- 
         퀵주문번호 update
          =>마스터 항목이므로 rcptNo 기준으로 update  
    -->    
    <insert id="updateOrderRequest01">
        UPDATE WD_VOC_QUICK_ORDER
           SET QUICK_DOCNO = #{quickDocno}   /*퀵주문번호*/                   
              ,STATUS      = '03'            /*상태(01:VOC퀵요청,02:센터접수,03:퀵주문등록,04:퀵주문취소등록,05:퀵주문처리완료,06:퀵주문취소완료)*/
              ,QUICK_ORDER_RCPT_DATE = TO_CHAR(SYSDATE,'YYYYMMDD') /*퀵주문접수일자*/
              ,QUICK_ORDER_RCPT_HOUR = TO_CHAR(SYSDATE,'HH24MI') /*퀵주문접수시간*/
             --            
             , EDITDATE    = SYSDATE
             , EDITWHO     = #{gUserId}    
         WHERE RCPT_NO     = #{rcptNo}    /*센터접수번호*/  
           AND STATUS      = '02'       /*상태(01:VOC퀵요청,02:센터접수,03:퀵주문등록,04:퀵주문취소등록,05:퀵주문처리완료,06:퀵주문취소완료)*/
    </insert>    
    
    <!-- 
        귀속정보 update
          =>마스터 항목이므로 rcptNo 기준으로 update  
    -->
    <insert id="updateMasterResp">
        UPDATE WD_VOC_QUICK_ORDER
           SET 
		       --배송정보
               DELIVERYTYPE    = #{deliverytype}   /*배송방법*/                   
              ,DELIVERY_METHOD = #{deliveryMethod} /*배송수단*/                   
              ,ARTICLE_TYPE    = #{articleType}    /*물품종류*/                   
              ,PAY_TYPE        = #{payType}        /*지급구분*/                   
              ,RESERVEDATE     = #{reservedate}    /*예약일시*/             
              --귀책정보
              ,RESP_DEPT       = #{respDept}        /*귀책부서*/                   
              ,RESP_REASON     = #{respReason}      /*귀책사유*/      
              ,RESP_EMP        = #{respEmp}         /*귀책담당자*/      
              ,RMK             = #{rmk}             /*비고*/  
               --            
             , EDITDATE    = SYSDATE
             , EDITWHO     = #{gUserId}    
         WHERE RCPT_NO     = #{rcptNo}    /*센터접수번호*/  
           AND STATUS      = '02'       /*상태(01:VOC퀵요청,02:센터접수,03:퀵주문등록,04:퀵주문취소등록,05:퀵주문처리완료,06:퀵주문취소완료)*/
    </insert>   
    
    <!-- 귀속정보 update -->
    <insert id="mergeMasterCenterRecept02">
         MERGE INTO WD_VOC_QUICK_ORDER T
         USING (
             SELECT
                   #{rcptNo}            AS RCPT_NO         /* 센터접수번호 */
                  ,#{serialkey}         AS SERIALKEY       /* 시리얼키 (NEXTVAL) */
                  ,#{ifSerialkey}       AS IF_SERIALKEY    /* IF데이터번호 */
                  ,#{quickDocno}        AS QUICK_DOCNO     /* 퀵주문번호 */
                  ,#{status}            AS STATUS          /* 진행상태 */
                  ,NULL                 AS VOCNO           /* VOC번호 */
                  ,NULL                 AS VOCSEQ          /* VOC순번 */
                  ,'90'                 AS VSRTYPE         /* VSR유형(01:VOC직송의뢰,02:긴급주문직송의뢰,90:수기퀵등록) */
                  ,NULL                 AS VSRNO           /* VSR번호 */
                  ,NULL                 AS VSR_SEQ         /* VSR순번 */
                  ,#{dccode}            AS DCCODE          /* 물류센터 */
                  ,NULL                 AS DELIVERYDATE    /* 납품일 */
                  ,NULL                 AS DOCNO           /* 주문번호 */
                  ,NULL                 AS DOCLINE         /* 주문순번 */
                  ,NULL                 AS DEPARTMENT      /* 담당부서코드 */
                  --              
                  ,NULL                 AS SLST_ID         /* 판매처코드 */
                  ,NULL                 AS SLST_NM         /* 판매처명 */
                  ,NULL                 AS MGMT_CUSTKEY    /* 관리처코드 */
                  ,NULL                 AS MGMT_CUSTNAME   /* 관리처명 */
                  --            
                  ,#{sku}               AS SKU             /* 상품코드 */
                  ,#{skuInfo}           AS SKU_INFO        /* 상품내역  */
                  ,#{uom}               AS UOM             /* 상품단위 */
                  ,0                    AS ORDERQTY        /* 주문량 */
                  , NULL                AS ORDERUOM        /* 주문단위 */
                  ,#{vocUom}            AS VOC_UOM         /* voc단위 */
                  ,#{vocQty}            AS VOC_QTY         /* voc량 */
                  ,#{gthSeq}            AS GTH_SEQ         /* 집하지방문순서 */
                  ,#{gthCd}             AS GTH_CD          /* 집하지코드 */ 
                  ,#{gthNm}             AS GTH_NM          /* 집하지명 */
                  ,#{gthAddr}           AS GTH_ADDR        /* 집하지주소*/
                  ,DAMO.ENC(#{gthAddrdtl})  AS GTH_ADDRDTL     /* 집하지상세주소*/
                  ,#{gthEmpNm}          AS GTH_EMP_NM      /* 집하지담당자명 */
                  ,DAMO.ENC(#{gthTel})  AS GTH_TEL         /* 집하지연락처 */
                  ,#{poCustkey}         AS PO_CUSTKEY      /* 협력사코드 */
                  ,DAMO.ENC(#{poCustTel}) AS PO_CUST_TEL     /* 협력사연락처 */
                  ,#{writer}              AS WRITER          /* 작성자 */
                  ,TO_CHAR(SYSDATE,'YYYYMMDD') AS WRITEDATE       /* 작성일자 */
                  ,TO_CHAR(SYSDATE,'HH24MI')   AS WRITETIME       /* 작성시간 */
                  ,#{reqDepartment}       AS REQ_DEPARTMENT  /* 요청부서 */
                  ,#{reqId}               AS REQ_ID          /* 요청자 */
                  ,#{toSeq}               AS TO_SEQ          /* 도착지 방문순서 */
                  ,#{address}             AS ADDRESS         /* 고객주소 */
                  ,DAMO.ENC(#{address2})  AS ADDRESS2        /* 고객상세주소 */
                  ,DAMO.ENC(#{phone})     AS PHONE           /* 고객전화번호 */
                  --,RMK                    AS RMK             /* 비고 - Header정보라서 미update */
                  ,#{deliverytype}        AS DELIVERYTYPE    /* 배송방법 */
                  ,#{deliveryMethod}      AS DELIVERY_METHOD /* 배송수단 */
                  ,'1'                    AS DELIVERY_OPTION /* 배송선택(1:일반,2:급송) - 1:고정 */
                  ,#{articleType}         AS ARTICLE_TYPE    /* 물품종류 */
                  ,#{payType}             AS PAY_TYPE        /* 지급구분 */
                  ,#{reservedate}         AS RESERVEDATE     /* 예약일시 */
                  ,#{respDept}            AS RESP_DEPT       /* 귀책부서 */
                  ,#{respReason}          AS RESP_REASON     /* 귀책사유 */
                  ,#{respEmp}             AS RESP_EMP        /* 귀책담당자 */
                  ,#{memo}                AS MEMO            /* 전달사항 */
                  --
                  , TO_CHAR(SYSDATE,'YYYYMMDD') AS RCPT_DATE  /* 센터접수일자*/ 
                  , TO_CHAR(SYSDATE,'HH24MI')   AS RCPT_HOUR  /* 센터접수시간*/                      
                  , TO_CHAR(SYSDATE,'YYYYMMDD') AS ADDDATE    /* 최초등록시간 */
                  , TO_CHAR(SYSDATE,'YYYYMMDD') AS EDITDATE   /* 최종변경시간 */
                  , #{gUserId}                  AS ADDWHO     /* 최초등록자 */
             FROM DUAL
        LEFT JOIN MS_SKU
               ON MS_SKU.STORERKEY = #{storerkey}
              AND MS_SKU.SKU       = #{sku}
         ) S --소스
         ON (
                T.RCPT_NO   = S.RCPT_NO
            AND T.SERIALKEY = S.SERIALKEY
         )
         WHEN MATCHED THEN
                 UPDATE  
                    SET --배송정보
                        DELIVERYTYPE    = S.DELIVERYTYPE    /*배송방법*/                   
                       ,DELIVERY_METHOD = S.DELIVERY_METHOD /*배송수단*/                   
                       ,ARTICLE_TYPE    = S.ARTICLE_TYPE    /*물품종류*/                   
                       ,PAY_TYPE        = S.PAY_TYPE        /*지급구분*/                   
                       ,RESERVEDATE     = S.RESERVEDATE     /*예약일시*/  
                       --
                       --귀속정보
                       ,RESP_DEPT       = S.RESP_DEPT       /*귀책부서*/
                       ,RESP_REASON     = S.RESP_REASON     /*귀책사유*/
                       ,RESP_EMP        = S.RESP_EMP        /*귀책담당자*/
                       ,MEMO            = S.MEMO            /*전달사항*/
                       --,RMK             = S.RMK             /*비고 - Header정보라서 미update*/                           
                       ,EDITDATE        = SYSDATE
                       ,EDITWHO         = #{gUserId}    
                  WHERE RCPT_NO         = #{rcptNo}    
                    AND SERIALKEY       = #{serialkey}
         WHEN NOT MATCHED THEN
             INSERT (
                    STORERKEY              /* 고객사코드 */ 
                  , RCPT_NO                /* 센터접수번호 */                 
                  , SERIALKEY              /* 시리얼키 (NEXTVAL) */         
                  , IF_SERIALKEY           /* IF데이터번호 */                
                  , QUICK_DOCNO            /* 퀵주문번호 */                  
                  , STATUS                 /* 진행상태 */                   
                  , VOCNO                  /* VOC번호 */                  
                  , VOCSEQ                 /* VOC순번 */                  
                  , VSRTYPE                /* VSR유형 */                  
                  , VSRNO                  /* VSR번호 */                  
                  , VSR_SEQ                /* VSR순번 */                  
                  , DCCODE                 /* 물류센터 */                   
                  , DELIVERYDATE           /* 납품일 */                    
                  , DOCNO                  /* 주문번호 */                   
                  , DOCLINE                /* 주문순번 */                   
                  , DEPARTMENT             /* 담당부서코드 */                 
                  , SLST_ID                /* 판매처코드 */                  
                  , SLST_NM                /* 판매처명 */                   
                  , MGMT_CUSTKEY           /* 관리처코드 */                  
                  , MGMT_CUSTNAME          /* 관리처명 */                   
                  , SKU                    /* 상품코드 */                   
                  , SKU_INFO               /* 상품내역 */                   
                  , UOM                    /* 상품단위 */                   
                  , ORDERQTY               /* 주문량 */                    
                  , ORDERUOM               /* 주문단위 */                   
                  , VOC_UOM                /* voc단위 */                  
                  , VOC_QTY                /* voc량 */                   
                  , GTH_SEQ                /* 집하지방문순서 */                
                  , GTH_CD                 /* 집하지코드 */                  
                  , GTH_NM                 /* 집하지명 */                   
                  , GTH_ADDR               /* 집하지주소 */                  
                  , GTH_ADDRDTL            /* 집하지상세주소 */                  
                  , GTH_EMP_NM             /* 집하지담당자명 */                
                  , GTH_TEL                /* 집하지연락처 */                 
                  , PO_CUSTKEY             /* 협력사코드 */                  
                  , PO_CUST_TEL            /* 협력사연락처 */                 
                  , WRITER                 /* 작성자 */                    
                  , WRITEDATE              /* 작성일자 */                   
                  , WRITETIME              /* 작성시간 */                   
                  , REQ_DEPARTMENT         /* 요청부서 */                   
                  , REQ_ID                 /* 요청자 */                    
                  , TO_SEQ                 /* 도착지 방문순서 */               
                  , ADDRESS                /* 고객주소 */                   
                  , ADDRESS2               /* 고객상세주소 */                   
                  , PHONE                  /* 고객전화번호 */                 
                  --, RMK                    /* 비고 */                     
                  , DELIVERYTYPE           /* 배송방법 */                   
                  , DELIVERY_METHOD        /* 배송수단 */                   
                  , DELIVERY_OPTION        /* 배송선택 */                   
                  , ARTICLE_TYPE           /* 물품종류 */                   
                  , PAY_TYPE               /* 지급구분 */                   
                  , RESERVEDATE            /* 예약일시 */                   
                  , RESP_DEPT              /* 귀책부서 */                   
                  , RESP_REASON            /* 귀책사유 */                   
                  , RESP_EMP               /* 귀책담당자 */                  
                  , MEMO                   /* 전달사항 */        
                  , RCPT_DATE  /* 센터접수일자*/      
                  , RCPT_HOUR  /* 센터접수시간*/                       
                  , ADDDATE                /* 최초등록시간 */                 
                  , EDITDATE               /* 최종변경시간 */                 
                  , ADDWHO                 /* 최초등록자 */                  
             )
             VALUES (
                    #{gStorerkey}           /* 고객사코드 */ 
                  , S.RCPT_NO              /* 센터접수번호 */                 
                  , S.SERIALKEY            /* 시리얼키 */
                  , S.IF_SERIALKEY         /* IF데이터번호 */                
                  , S.QUICK_DOCNO          /* 퀵주문번호 */                  
                  , '02'                   /* 진행상태(01:VOC퀵요청,02:센터접수,03:퀵주문등록,04:퀵주문취소등록,05:퀵주문처리완료,06:퀵주문취소완료) */                   
                  , S.VOCNO                /* VOC번호 */                  
                  , S.VOCSEQ               /* VOC순번 */                  
                  , S.VSRTYPE              /* VSR유형 */                  
                  , S.VSRNO                /* VSR번호 */                  
                  , S.VSR_SEQ              /* VSR순번 */                  
                  , S.DCCODE               /* 물류센터 */                   
                  , S.DELIVERYDATE         /* 납품일 */                    
                  , S.DOCNO                /* 주문번호 */                   
                  , S.DOCLINE              /* 주문순번 */                   
                  , S.DEPARTMENT           /* 담당부서코드 */                 
                  , S.SLST_ID              /* 판매처코드 */                  
                  , S.SLST_NM              /* 판매처명 */                   
                  , S.MGMT_CUSTKEY         /* 관리처코드 */                  
                  , S.MGMT_CUSTNAME        /* 관리처명 */                   
                  , S.SKU                  /* 상품코드 */                   
                  , S.SKU_INFO             /* 상품내역 */                   
                  , S.UOM                  /* 상품단위 */                   
                  , S.ORDERQTY             /* 주문량 */                    
                  , S.ORDERUOM             /* 주문단위 */                   
                  , S.VOC_UOM              /* voc단위 */                  
                  , S.VOC_QTY              /* voc량 */                   
                  , S.GTH_SEQ              /* 집하지방문순서 */                
                  , S.GTH_CD               /* 집하지코드 */                  
                  , S.GTH_NM               /* 집하지명 */                   
                  , S.GTH_ADDR             /* 집하지주소 */                  
                  , S.GTH_ADDRDTL          /* 집하지상세주소 */                  
                  , S.GTH_EMP_NM           /* 집하지담당자명 */                
                  , S.GTH_TEL              /* 집하지연락처 */                 
                  , S.PO_CUSTKEY           /* 협력사코드 */                  
                  , S.PO_CUST_TEL          /* 협력사연락처 */                 
                  , S.WRITER               /* 작성자 */                    
                  , S.WRITEDATE            /* 작성일자 */                   
                  , S.WRITETIME            /* 작성시간 */                   
                  , S.REQ_DEPARTMENT       /* 요청부서 */                   
                  , S.REQ_ID               /* 요청자 */                    
                  , S.TO_SEQ               /* 도착지 방문순서 */               
                  , S.ADDRESS              /* 고객주소 */                   
                  , S.ADDRESS2             /* 고객상세주소 */                   
                  , S.PHONE                /* 고객전화번호 */                 
                  --, S.RMK                  /* 비고 */                     
                  , S.DELIVERYTYPE         /* 배송방법 */                   
                  , S.DELIVERY_METHOD      /* 배송수단 */                   
                  , S.DELIVERY_OPTION      /* 배송선택 */                   
                  , S.ARTICLE_TYPE         /* 물품종류 */                   
                  , S.PAY_TYPE             /* 지급구분 */                   
                  , S.RESERVEDATE          /* 예약일시 */                   
                  , S.RESP_DEPT            /* 귀책부서 */                   
                  , S.RESP_REASON          /* 귀책사유 */                   
                  , S.RESP_EMP             /* 귀책담당자 */                  
                  , S.MEMO                 /* 전달사항 */   
                  , S.RCPT_DATE            /*센터접수일자*/ 
                  , S.RCPT_HOUR            /*센터접수시간*/                  
                  , S.ADDDATE              /* 최초등록시간 */                 
                  , S.EDITDATE             /* 최종변경시간 */                 
                  , S.ADDWHO               /* 최초등록자 */                  
             )
    </insert>      
    
    
    <!-- 수기 집하지 처리 update -->
    <insert id="updateDetailListDelivery02">
        UPDATE WD_VOC_QUICK_ORDER
            SET GTH_SEQ     = #{gthSeq}      /*집하지방문순서*/
               ,GTH_CD      = #{gthCd}       /*집하지코드*/
               ,GTH_NM      = #{gthNm}       /*집하지명*/
               ,GTH_ADDR    = #{gthAddr}     /*집하지주소*/
               ,GTH_ADDRDTL = DAMO.ENC(#{gthAddrdtl})  /*집하지상세주소*/
               ,GTH_EMP_NM  = #{gthEmpNm}         /*집하지담당자명*/
               ,GTH_TEL     = DAMO.ENC(#{gthTel}) /*집하지연락처*/
               --           
               ,UOM         = #{uom}         /*상품단위*/
               ,VOC_QTY     = #{vocQty}      /*voc량 - 수량*/
               ,SKU         = #{sku}         /*상품코드*/          
               ,SKU_INFO    = #{skuInfo}     /*상품내역*/
               ,MEMO        = #{memo}        /*메모 */
               --             
              ,EDITDATE     = SYSDATE
              ,EDITWHO      = #{gUserId}    
         WHERE RCPT_NO      = #{rcptNo}    /*센터접수번호*/  
           AND SERIALKEY    = #{serialkey} /*시리얼키*/       
           AND STATUS       = '02'       /*상태(01:VOC퀵요청,02:센터접수,03:퀵주문등록,04:퀵주문취소등록,05:퀵주문처리완료,06:퀵주문취소완료)*/
    </insert>    
    
    <!-- 수기 도착지 처리 update -->
    <insert id="updateDetailListDestination02">
        UPDATE /* [WdQuickRequestService.updateDetailListDestination02][수기 도착지 수정][sss][20250717] */
               WD_VOC_QUICK_ORDER
           SET MGMT_CUSTKEY  = #{mgmtCustkey}  /*관리처코드*/ 
             , MGMT_CUSTNAME = #{mgmtCustname} /*관리처명-고객명*/
             , TO_SEQ        = #{toSeq}        /*도착지 방문순서*/
             , ADDRESS       = #{address}      /*고객주소*/
             , ADDRESS2      = DAMO.ENC(#{address2})     /*고객상세주소*/
             , PHONE         = DAMO.ENC(#{phone})        /*고객전화번호*/
             --
              ,UOM        = #{uom}         /*상품단위*/
              ,VOC_QTY    = #{vocQty}      /*voc량 - 수량*/
              ,SKU        = #{sku}         /*상품코드*/          
              ,SKU_INFO   = #{skuInfo}     /*상품내역*/
              ,MEMO        = #{memo}        /*메모 */
               --     
              ,EDITDATE       = SYSDATE
              ,EDITWHO        = #{gUserId}    
         WHERE RCPT_NO        = #{rcptNo}    /*센터접수번호*/  
           AND SERIALKEY      = #{serialkey} /*시리얼키*/       
           AND STATUS         = '02'       /*상태(01:VOC퀵요청,02:센터접수,03:퀵주문등록,04:퀵주문취소등록,05:퀵주문처리완료,06:퀵주문취소완료)*/
    </insert>      
    
    <!-- 퀵주문접수 체크 정보 을(를) 조회 -->
    <select id="selectChkDelMaster"  parameterType="hashMap" resultType="hashMap">
        <![CDATA[
        SELECT /* [WdQuickRequestService.selectChkDelMaster][퀵주문접수 체크][sss][20250717] */
               (
                SELECT CASE WHEN MAX(STATUS) = '02' THEN 'Y'  ELSE 'N' END AS CHK1 /*상태(01:VOC퀵요청,02:센터접수,03:퀵주문등록,04:퀵주문취소등록,05:퀵주문처리완료,06:퀵주문취소완료)*/
                  FROM WD_VOC_QUICK_ORDER
                 WHERE RCPT_NO        = #{rcptNo}    
                   AND SERIALKEY      = #{serialkey} 
               ) AS CHK1 /*체크.삭제가능여부*/
          FROM DUAL
        ]]>
    </select>        
    
    
    <!-- 집하지 신규/수정 -->
    <insert id="mergeMasterCenterRecept01">
         MERGE INTO WD_VOC_QUICK_ORDER T
         USING (
             SELECT
                   RCPT_NO              AS RCPT_NO         /* 센터접수번호 */
                  ,#{serialkey}         AS SERIALKEY       /* 시리얼키 (NEXTVAL) */
                  ,WD_VOC_QUICK_ORDER.IF_SERIALKEY         AS IF_SERIALKEY    /* IF데이터번호 */
                  ,WD_VOC_QUICK_ORDER.QUICK_DOCNO          AS QUICK_DOCNO     /* 퀵주문번호 */
                  ,WD_VOC_QUICK_ORDER.STATUS               AS STATUS          /* 진행상태 */
                  ,WD_VOC_QUICK_ORDER.VOCNO                AS VOCNO           /* VOC번호 */
                  ,WD_VOC_QUICK_ORDER.VOCSEQ               AS VOCSEQ          /* VOC순번 */
                  ,WD_VOC_QUICK_ORDER.VSRTYPE              AS VSRTYPE         /* VSR유형(01:VOC직송의뢰,02:긴급주문직송의뢰,90:수기퀵등록) */
                  ,WD_VOC_QUICK_ORDER.VSRNO                AS VSRNO           /* VSR번호 */
                  ,WD_VOC_QUICK_ORDER.VSR_SEQ              AS VSR_SEQ         /* VSR순번 */
                  ,WD_VOC_QUICK_ORDER.DCCODE               AS DCCODE          /* 물류센터 */
                  ,WD_VOC_QUICK_ORDER.DELIVERYDATE         AS DELIVERYDATE    /* 납품일 */
                  ,WD_VOC_QUICK_ORDER.DOCNO                AS DOCNO           /* 주문번호 */
                  ,WD_VOC_QUICK_ORDER.DOCLINE              AS DOCLINE         /* 주문순번 */
                  ,WD_VOC_QUICK_ORDER.DEPARTMENT           AS DEPARTMENT      /* 담당부서코드 */
                  --              
                  ,WD_VOC_QUICK_ORDER.SLST_ID              AS SLST_ID         /* 판매처코드 */
                  ,WD_VOC_QUICK_ORDER.SLST_NM              AS SLST_NM         /* 판매처명 */
                  ,WD_VOC_QUICK_ORDER.MGMT_CUSTKEY         AS MGMT_CUSTKEY    /* 관리처코드 */
                  ,WD_VOC_QUICK_ORDER.MGMT_CUSTNAME        AS MGMT_CUSTNAME   /* 관리처명 */
                  --            
                  ,#{sku}                   AS SKU             /* 상품코드 */
                  ,#{skuInfo}               AS SKU_INFO        /* 상품내역  */
                  ,#{uom}                   AS UOM             /* 상품단위 */
                  ,0                        AS ORDERQTY        /* 주문량 */
                  , NULL                    AS ORDERUOM        /* 주문단위 */
                  ,#{vocUom}                AS VOC_UOM         /* voc단위 */
                  ,#{vocQty}                AS VOC_QTY         /* voc량 */
                  ,#{gthSeq}                AS GTH_SEQ         /* 집하지방문순서 */
                  ,#{gthCd}                 AS GTH_CD          /* 집하지코드 */ 
                  ,#{gthNm}                 AS GTH_NM          /* 집하지명 */
                  ,#{gthAddr}               AS GTH_ADDR        /* 집하지주소*/
                  ,DAMO.ENC(#{gthAddrdtl})  AS GTH_ADDRDTL     /* 집하지상세주소*/
                  ,#{gthEmpNm}              AS GTH_EMP_NM      /* 집하지담당자명 */
                  ,DAMO.ENC(#{gthTel})      AS GTH_TEL         /* 집하지연락처 */
                  ,#{poCustkey}             AS PO_CUSTKEY      /* 협력사코드 */
                  ,DAMO.ENC(#{poCustTel})   AS PO_CUST_TEL     /* 협력사연락처 */
                  ,#{writer}                AS WRITER          /* 작성자 */
                  ,TO_CHAR(SYSDATE,'YYYYMMDD') AS WRITEDATE    /* 작성일자 */
                  ,TO_CHAR(SYSDATE,'HH24MI')   AS WRITETIME    /* 작성시간 */
                  ,WD_VOC_QUICK_ORDER.REQ_DEPARTMENT       AS REQ_DEPARTMENT  /* 요청부서 */
                  ,WD_VOC_QUICK_ORDER.REQ_ID               AS REQ_ID          /* 요청자 */
                  ,WD_VOC_QUICK_ORDER.TO_SEQ               AS TO_SEQ          /* 도착지 방문순서 */
                  ,WD_VOC_QUICK_ORDER.ADDRESS              AS ADDRESS         /* 고객주소 */
                  ,WD_VOC_QUICK_ORDER.ADDRESS2             AS ADDRESS2        /* 고객상세주소 */
                  ,WD_VOC_QUICK_ORDER.PHONE                AS PHONE           /* 고객전화번호 */
                  ,WD_VOC_QUICK_ORDER.RMK                  AS RMK             /* 비고 - Header정보라서 미update */
                  ,WD_VOC_QUICK_ORDER.DELIVERYTYPE         AS DELIVERYTYPE    /* 배송방법 */
                  ,WD_VOC_QUICK_ORDER.DELIVERY_METHOD      AS DELIVERY_METHOD /* 배송수단 */
                  ,WD_VOC_QUICK_ORDER.DELIVERY_OPTION      AS DELIVERY_OPTION /* 배송선택(1:일반,2:급송) - 1:고정 */
                  ,WD_VOC_QUICK_ORDER.ARTICLE_TYPE         AS ARTICLE_TYPE    /* 물품종류 */
                  ,WD_VOC_QUICK_ORDER.PAY_TYPE             AS PAY_TYPE        /* 지급구분 */
                  ,WD_VOC_QUICK_ORDER.RESERVEDATE          AS RESERVEDATE     /* 예약일시 */
                  ,WD_VOC_QUICK_ORDER.RESP_DEPT            AS RESP_DEPT       /* 귀책부서 */
                  ,WD_VOC_QUICK_ORDER.RESP_REASON          AS RESP_REASON     /* 귀책사유 */
                  ,WD_VOC_QUICK_ORDER.RESP_EMP             AS RESP_EMP        /* 귀책담당자 */
                  ,WD_VOC_QUICK_ORDER.MEMO                 AS MEMO            /* 전달사항 */
                  --
                  , WD_VOC_QUICK_ORDER.RCPT_DATE AS RCPT_DATE  /* 센터접수일자*/ 
                  , WD_VOC_QUICK_ORDER.RCPT_HOUR AS RCPT_HOUR  /* 센터접수시간*/                      
                  , TO_CHAR(SYSDATE,'YYYYMMDD')  AS ADDDATE    /* 최초등록시간 */
                  , TO_CHAR(SYSDATE,'YYYYMMDD')  AS EDITDATE   /* 최종변경시간 */
                  , #{gUserId}                   AS ADDWHO     /* 최초등록자 */
             FROM WD_VOC_QUICK_ORDER
        LEFT JOIN MS_SKU
               ON MS_SKU.STORERKEY = #{storerkey}
              AND MS_SKU.SKU       = #{sku}
            WHERE RCPT_NO          = #{rcptNo}    
              AND ROWNUM           = 1 /*같은	 접수번호 중 1개의 정보를 같은 값으로*/
         ) S --소스
         ON (
                T.RCPT_NO   = S.RCPT_NO
            AND T.SERIALKEY = S.SERIALKEY
         )
         WHEN MATCHED THEN
                 UPDATE 
		            SET GTH_SEQ     = S.GTH_SEQ      /*집하지방문순서*/
		               ,GTH_CD      = S.GTH_CD       /*집하지코드*/
		               ,GTH_NM      = S.GTH_NM       /*집하지명*/
		               ,GTH_ADDR    = S.GTH_ADDR     /*집하지주소*/
		               ,GTH_ADDRDTL = S.GTH_ADDRDTL  /*집하지상세주소*/
		               ,GTH_EMP_NM  = S.GTH_EMP_NM   /*집하지담당자명*/
		               ,GTH_TEL     = S.GTH_TEL      /*집하지연락처*/
		               --           
		               ,UOM         = S.UOM          /*상품단위*/
		               ,VOC_QTY     = S.VOC_QTY      /*voc량 - 수량*/
		               ,SKU         = S.SKU          /*상품코드*/          
		               ,SKU_INFO    = S.SKU_INFO     /*상품내역*/
		               ,MEMO        = S.MEMO         /*메모 */
		               --
                       ,EDITDATE    = SYSDATE
                       ,EDITWHO     = #{gUserId}    
                  WHERE RCPT_NO     = #{rcptNo}    
                    AND SERIALKEY   = #{serialkey}
         WHEN NOT MATCHED THEN
             INSERT (
                    STORERKEY              /* 고객사코드 */ 
                  , RCPT_NO                /* 센터접수번호 */                 
                  , SERIALKEY              /* 시리얼키 (NEXTVAL) */         
                  , IF_SERIALKEY           /* IF데이터번호 */                
                  , QUICK_DOCNO            /* 퀵주문번호 */                  
                  , STATUS                 /* 진행상태 */                   
                  , VOCNO                  /* VOC번호 */                  
                  , VOCSEQ                 /* VOC순번 */                  
                  , VSRTYPE                /* VSR유형 */                  
                  , VSRNO                  /* VSR번호 */                  
                  , VSR_SEQ                /* VSR순번 */                  
                  , DCCODE                 /* 물류센터 */                   
                  , DELIVERYDATE           /* 납품일 */                    
                  , DOCNO                  /* 주문번호 */                   
                  , DOCLINE                /* 주문순번 */                   
                  , DEPARTMENT             /* 담당부서코드 */                 
                  , SLST_ID                /* 판매처코드 */                  
                  , SLST_NM                /* 판매처명 */                   
                  , MGMT_CUSTKEY           /* 관리처코드 */                  
                  , MGMT_CUSTNAME          /* 관리처명 */                   
                  , SKU                    /* 상품코드 */                   
                  , SKU_INFO               /* 상품내역 */                   
                  , UOM                    /* 상품단위 */                   
                  , ORDERQTY               /* 주문량 */                    
                  , ORDERUOM               /* 주문단위 */                   
                  , VOC_UOM                /* voc단위 */                  
                  , VOC_QTY                /* voc량 */                   
                  , GTH_SEQ                /* 집하지방문순서 */                
