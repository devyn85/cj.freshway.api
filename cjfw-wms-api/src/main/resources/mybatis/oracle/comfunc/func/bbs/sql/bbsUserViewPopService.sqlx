<?xml version="1.0" encoding="UTF-8"?><!--Converted at: Mon Feb 17 11:21:55 KST 2014-->
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="bbsUserViewPopService">
	
	<!-- 공지사항 상세내용 조회 -->
	<select id="getBoardDetail" resultType="BbsBoardDetailGetResDto">
		SELECT	/* [bbsUserViewPopService.sqlx][getBoardDetail][공지사항 상세내용 조회][CWS][20200206]*/
				( SELECT CD_NM
				  FROM	 TB_CM_CD_DTL
				  WHERE  COM_GRP_CD = 'BBS_TP'
				  AND	 COM_CD = BS.BBS_TP_CD ) AS BBS_TP
		        , BS.BBS_TP_CD
		        , ( SELECT 	USER_NM 
		            FROM 	TB_CF_USERS 
		            WHERE 	USER_ID = BS.REG_ID ) AS REGR_NM
		        , BS.REG_ID
		        , TO_CHAR(BS.REG_DT, 'YYYY-MM-DD') AS REGR_DTM
		        , THRU_DT
		        , FROM_DT
		        , BS.TOP_YN
		        , BS.VW_CNT
		        , BS.BBS_TITLE
		        , TO_CHAR (BS.BBS_NOTE) AS BBS_NOTE
		        , BS.POP_YN
		        , BS.VW_YN
		        , BS.ATTCH_FILE_GRP_NO
		        , BS.BBS_SCP_CD
		FROM    TB_BS_BBS BS
		
		WHERE   BBS_SEQ = #{bbsSeq}
	</select>
	
	<!-- 첨부파일 리스트 조회 -->
	<select id="getAttachFileList" resultType="FileComInfoDto">
	
		SELECT	/* [bbsUserViewPopService.sqlx][getAttachFileList][첨부파일 리스트 조회][CWS][20200206]*/
				ROWNUM
		        , ATTCH_FILE_NM
		        , TRUNC(ATTCH_FILE_SZ/1000, 0) AS ATTCH_FILE_SZ
		        , ATTCH_FILE_GRP_NO
		        , ATTCH_FILE_NO
		        , FILE_TP_CD
		FROM 	TB_CF_ATTCHFILE 
		WHERE 	ATTCH_FILE_GRP_NO = #{attchFileGrpNo}
		ORDER BY ATTCH_FILE_NO
	</select>
	
	<!-- 공지사항 조회수 증가 -->
	<update id="updateViewCnt">
		UPDATE /* [bbsUserViewPopService.sqlx][updateViewCnt][공지사항 조회수 증가][CWS][2020.02.06] */
				TB_BS_BBS
		SET  VW_CNT         = VW_CNT + 1
	  	WHERE BBS_SEQ = #{bbsSeq}
    </update>
	
</mapper>