		  FROM IF_DM_DOCUMENT_D
		  JOIN DP_INPLAN
		    ON DP_INPLAN.STORERKEY = 'FW00'
		   AND DP_INPLAN.SLIPNO    = IF_DM_DOCUMENT_D.DOCNO
		   AND DP_INPLAN.SLIPLINE  = IF_DM_DOCUMENT_D.DOCLINE
		   AND DP_INPLAN.DEL_YN    = 'Y'
		 WHERE IF_DM_DOCUMENT_D.IF_DESTINATION      = 'ASISWMS'
		   AND IF_DM_DOCUMENT_D.IF_ID               = 'PJTWMS02'
		   AND IF_DM_DOCUMENT_D.DOCNO               = #{slipNo}
		   AND IF_DM_DOCUMENT_D.STORERKEY           = 'FW00';
