	<!-- 차량정보 정보 UPDATE -->
    <update id="updateMasterList">		
		UPDATE /* [msCarDriverService.sqlx][msCarDriverService.updateMasterList][차량정보 정보 UPDATE][jangjaehyun][20250812] */
		    CM_CAR
           SET OTHER03 = #{carOther03},
               OPT_LOAD_WEIGHT =#{optLoadWeight},
               MAXWEIGHT = #{maxWeight},
               REGISTRATIONDATE = #{registrationDate},
               CARGOCUBE = #{cargoCube},
               MAXLANDING = #{maxLanding},
               PHONE1 = DAMO.ENC(#{phone1}),
               PHONE2 = DAMO.ENC(#{phone2}),
               DRIVER1 = #{driver1},
               DRIVER2 = #{driver2},
               BTSCANNERGIVE = #{btScannerGive},
               PDAPHONE2 = #{pdaPhone2},
               SMPGIVE = #{smpGive},
               THERMOMETERNO = #{thermometerNo},
               FROMDATE = #{fromDate},               
               TODATE = #{toDate},
               TODATE2 = #{toDate2},
               CARCAPACITY = #{carCapacity},
               CAR_LENGTH = #{carLength},
               CAR_WIDTH = #{carWidth},
               VEHICLE_HEIGHT = #{vehicleHeight},
               VEHICLE_YEAR = #{vehicleYear},
               DEL_YN = #{delYn},               
               EDITDATE = SYSDATE,
               EDITWHO = #{gUserId}
         WHERE CARNO = #{carNo}
	</update>
	
	<!-- 입출차정보 정보 UPDATE -->
    <update id="updateEntryInfoList">		
		MERGE /* [msCarDriverService.sqlx][msCarDriverService.updateEntryInfoList][입출차정보 정보 UPDATE][jangjaehyun][20250904] */ INTO MS_CAR_ENTRY_INFO
             USING DUAL
                ON (SERIALKEY = #{entrySerialKey})
        WHEN MATCHED THEN
             UPDATE SET
				    DCCODE = #{dcCode},
				    OUT_GROUP_CD = #{outGroupCd},
				    POPNO = #{popno},
				    TC_DCCODE = #{tcDcCode},
				    DOCKNO = #{dockno},
				    EDITDATE = SYSDATE,
				    EDITWHO = #{gUserId}
        WHEN NOT MATCHED THEN
             INSERT (CARNO
                    ,DCCODE
                    ,OUT_GROUP_CD
                    ,POPNO
					,TC_DCCODE
                    ,DOCKNO
                    ,ADDDATE
                    ,ADDWHO
                    ,EDITDATE
                    ,EDITWHO)
            VALUES  (#{carNo}
                    ,#{dcCode}
                    ,#{outGroupCd}
                    ,#{popno}
					,#{tcDcCode}
                    ,#{dockno}
                    ,SYSDATE
                    ,#{gUserId}
                    ,SYSDATE
                    ,#{gUserId})
	</update>
	
	<!-- 입출차정보 정보 DELETE -->
    <delete id="deleteEntryInfoList">		
		DELETE /* [msCarDriverService.sqlx][msCarDriverService.updateEntryInfoList][입출차정보 정보 UPDATE][jangjaehyun][20250904] */ FROM MS_CAR_ENTRY_INFO
             WHERE SERIALKEY = #{entrySerialKey}
	</delete>
	
	<select id="update" statementType="CALLABLE" resultType="HMAP">
		<![CDATA[
        {
	        CALL  /* [msCarDriverService.sqlx][update][차량정보 정보 UPDATE][jangjaehyun][20250812] */
	        DECLARE
                V_AFTER     MS_CarDriver%rowtype;
                O_SUCCESS   NUMBER         :=  1;      /* 성공여부(1이면 성공) */
                O_ERRCODE   NUMBER         :=  0;      /* 오류 코드 */
                O_ERRMSG    VARCHAR2(4000) := '';      /* 오류 메세지 */
            BEGIN
                FOR KEY_LIST IN (
                    SELECT
                            DCCODE,	 /* 물류센터 */
                            PLANT,	 /* 플랜트 */
                            STORAGETYPE, /* 저장조건 */
                            DISTANCETYPE /* 원거리유형 */
                    FROM    MS_CarDriver
                    WHERE   DCCODE       = #{dcCode}
                      AND   PLANT        = #{plant}
                      AND   STORAGETYPE  = #{storageType}
                      AND   DISTANCETYPE = #{distanceType}
                )
                LOOP
                    BEGIN
                        SELECT  *
                        INTO    V_AFTER
                        FROM    MS_CarDriver
                        WHERE   DCCODE       = KEY_LIST.DCCODE
                          AND   PLANT        = KEY_LIST.PLANT
                          AND   STORAGETYPE  = KEY_LIST.STORAGETYPE
                          AND   DISTANCETYPE = KEY_LIST.DISTANCETYPE
                        ;
    
                       V_AFTER.DCCODE       := #{dcCode};
                       V_AFTER.PLANT        := #{plant};
                       V_AFTER.STORAGETYPE  := #{storageType};
                       V_AFTER.DISTANCETYPE := #{distanceType};
                       V_AFTER.BATCHGROUP   := #{batchGroup};
                       V_AFTER.DESCRIPTION  := #{description};
                       V_AFTER.STATUS       := #{status};
                       V_AFTER.DEL_YN       := #{delYn};
                       V_AFTER.EDITDATE     := SYSDATE;
                       V_AFTER.EDITWHO      := #{gUserId};
                       V_AFTER.ORGANIZE     := #{organize};
                       V_AFTER.AREA         := #{area};
                       V_AFTER.ORDERTYPE    := #{orderType};
                       V_AFTER.ETCCODE1     := #{etcCode1};
                       V_AFTER.ETCCODE2     := #{etcCode2};
                       V_AFTER.ETCCODE3     := #{etcCode3};
                       V_AFTER.ETCCODE4     := #{etcCode4};
                       V_AFTER.ALLO_UOM     := #{alloUom};
    
                       -- 프로시저 호출
                       TRMS_CARDRIVER.TR_UPDATE(
                                V_AFTER
                            ,   O_SUCCESS
                            ,   O_ERRCODE
                            ,   O_ERRMSG
                        );
    
                        EXIT    WHEN O_SUCCESS < 1;
    
                    END;
                END    LOOP;
    
                #{success, mode=OUT, jdbcType=INTEGER, javaType=int}    :=  O_SUCCESS;
                #{err, mode=OUT, jdbcType=INTEGER, javaType=int}        :=  O_ERRCODE;
                #{errmsg, mode=OUT, jdbcType=VARCHAR, javaType=String}  :=  O_ERRMSG;
    
            END
        }
        ]]>
    </select>
    
    <insert id="insertDriver">
        /* [msDriverService.sqlx][msDriverService.insert][기사 정보 INSERT][jangjaehyun][20250904] */
        INSERT INTO CM_DRIVER
               ( DRIVERID, DRIVERNAME, LICENSETYPE, LICENCONTDATE, OTHER01,
                 OTHER02, OTHER03, LICENSENO, LICENEXPIDATE,
                 WORK_FROMHOUR, WORK_TOHOUR, PHONE1,
                 ADDDATE, EDITDATE, ADDWHO, EDITWHO
               )
        SELECT #{driverId}, #{driverName}, #{licenseType}, #{licenContDate}, #{driverOther01},
               #{driverOther02}, #{driverOther03}, #{licenseNo}, #{licenExpiDate},
               #{workFromHour}, #{workToHour}, DAMO.ENC(#{phone1}),
               SYSDATE, SYSDATE, #{gUserId}, #{gUserId}
          FROM DUAL
    </insert>
    
    <select id="getInsertDriverId" resultType="string">
	    /* [msDriverService.sqlx][msDriverService.getInsertDriverId][기사 정보 INSERT - KEY 조회][jangjaehyun][202501121] */
	    SELECT
			    DECODE(
			        (SELECT MAX(MEMO) 
				    FROM MS_CARRIER 
				    WHERE CARRIERKEY IN (#{carAgentKey})),
				    NULL,
				    'D' || TO_CHAR(SYSDATE, 'RR') || LPAD(SEQ_CM_DRIVER_01.NEXTVAL, 4, '0'),
				    (SELECT MAX(MEMO) 
			        FROM MS_CARRIER 
			        WHERE CARRIERKEY IN (#{custKey}, #{carAgentKey})
			          AND CARRIERTYPE = 'SUBC') || TO_CHAR(SYSDATE, 'RR') || LPAD(SEQ_CM_DRIVER_01.NEXTVAL, 4, '0')
			    ) || '_WAYLO' AS DRIVERID
			FROM DUAL
    </select>

    <update id="updateDriver">
        /* [msDriverService.sqlx][msDriverService.update][기사 정보 UPDATE][jangjaehyun][20250904] */
        UPDATE CM_DRIVER
           SET DRIVERNAME = #{driverName},
               LICENSETYPE = #{licenseType},
               LICENCONTDATE = #{licenContDate},
               OTHER01 = #{driverOther01},
               OTHER02 = #{driverOther02},
               OTHER03 = #{driverOther03},
               LICENSENO = #{licenseNo},
               LICENEXPIDATE = #{licenExpiDate},
               WORK_FROMHOUR = #{workFromHour},
               WORK_TOHOUR = #{workToHour},
               PHONE1 = DAMO.ENC(#{phone1}),
               PHONE2 = DAMO.ENC(#{phone2}),
               EDITDATE = SYSDATE,
               EDITWHO = #{gUserId}
         WHERE DRIVERID = #{driverId}
    </update>

    <select id="getDataCarDriverExcelUploadResult" parameterType="map" resultType="map">
        SELECT /* [msCarDriverService.sqlx][msCarDriverService.getDataCarExcelUploadResult][Car 일괄등록 결과 조회] */
               '0' AS CHECKYN,
               SY_PROCESSTEMP_DM_D.AREA                   AS DEF_DCCODE,
               SY_PROCESSTEMP_DM_D.MALLINVOICE            AS DEF_DCNAME,
               SY_PROCESSTEMP_DM_D.INVOICETYPE            AS CONTRACTTYPE,
               SY_PROCESSTEMP_DM_D.DCCODE                 AS CARID,
               SY_PROCESSTEMP_DM_D.SOKEY                  AS CARNO,
               SY_PROCESSTEMP_DM_D.POTYPE                 AS CARCAPACITY,
               SY_PROCESSTEMP_DM_D.OPENQTY                AS MAXWEIGHT,
               SY_PROCESSTEMP_DM_D.ALTERSKU               AS CARCUBEDESCR,
               SY_PROCESSTEMP_DM_D.MERGEDOCNO             AS CARGOSIZE,
               SY_PROCESSTEMP_DM_D.MERGEDOCTYPE           AS CARGOTYPE,
               SY_PROCESSTEMP_DM_D.ORDERTYPE              AS DTGTYPE,
               SY_PROCESSTEMP_DM_D.SOLINE                 AS GPSTYPE,
               SY_PROCESSTEMP_DM_D.STORERKEY              AS REGISTRATIONDATE,
               SY_PROCESSTEMP_DM_D.DOCLINE                AS OTHER03,
               SY_PROCESSTEMP_DM_D.PLANDOCDT              AS MAXLANDING,
               SY_PROCESSTEMP_DM_D.PLANDOCTYPE            AS CARGROUP,
               SY_PROCESSTEMP_DM_D.ORGANIZE               AS CHECKCAR,
               SY_PROCESSTEMP_DM_D.DOCDT                  AS INDT,
               SY_PROCESSTEMP_DM_D.DOCNO                  AS OUTDT,
               SY_PROCESSTEMP_DM_D.INVOICELINE            AS DOCKNO,
               SY_PROCESSTEMP_DM_D.LOTTABLE01             AS LAREA,
               SY_PROCESSTEMP_DM_D.LOTTABLE02             AS MAREA,
               SY_PROCESSTEMP_DM_D.LOTTABLE03             AS SAREA,
               SY_PROCESSTEMP_DM_D.REFERENCE01            AS LINKCARNO1,
               SY_PROCESSTEMP_DM_D.REFERENCE02            AS LINKCARNAME1,
               SY_PROCESSTEMP_DM_D.REFERENCE03            AS LINKCARNO2,
               SY_PROCESSTEMP_DM_D.REFERENCE04            AS LINKCARNAME2,
               SY_PROCESSTEMP_DM_D.REFERENCE05            AS LINKCARNO3,
               SY_PROCESSTEMP_DM_D.REFERENCE06            AS LINKCARNAME3,
               SY_PROCESSTEMP_DM_D.OTHER01                AS SHORTNO,
               SY_PROCESSTEMP_DM_D.OTHER02                AS BTSCANNERGIVE,
               SY_PROCESSTEMP_DM_D.OTHER03                AS PDAPHONE2,
               SY_PROCESSTEMP_DM_D.OTHER04                AS SMPGIVE,
               SY_PROCESSTEMP_DM_D.OTHER05                AS PDAPHONE1,
               SY_PROCESSTEMP_DM_D.OTHER06                AS PDAPHONE3,
               SY_PROCESSTEMP_DM_D.OTHER07                AS PDAPHONE4,
               SY_PROCESSTEMP_DM_D.OTHER08                AS ALLOW_LOGIN_YN,
               SY_PROCESSTEMP_DM_D.REFERENCE07            AS DRIVERNM,
               DAMO.DEC(SY_PROCESSTEMP_DM_D.REFERENCE08)  AS PHONE1,
               SY_PROCESSTEMP_DM_D.REFERENCE09            AS DRIVER3,
               DAMO.DEC(SY_PROCESSTEMP_DM_D.REFERENCE10)  AS PHONE3,
               SY_PROCESSTEMP_DM_D.PACKINGNO              AS DRIVER4,
               DAMO.DEC(SY_PROCESSTEMP_DM_D.PROCESSCODE)  AS PHONE4,
               SY_PROCESSTEMP_DM_D.STRAGETYCODE           AS DEL_YN,
               SY_PROCESSTEMP_DM_D.WORKPROCESSCODE        AS EDITDATE,
               SY_PROCESSTEMP_DM_D.INTERFACEPROCESSCODE   AS EDITWHO,
               SY_PROCESSTEMP_DM_D.PROCESSFLAG            AS PROCESS_YN,
               SY_PROCESSTEMP_DM_D.PROCPOSS_MSG           AS PROCPOSS_MSG,
               CM_DC.DCNAME                               AS DEF_DCNAME
          FROM SY_PROCESSTEMP_DM_D
          LEFT OUTER JOIN CM_DC ON SY_PROCESSTEMP_DM_D.AREA = CM_DC.DCCODE
         WHERE SY_PROCESSTEMP_DM_D.PROCESSCREATOR = #{gUserId}
           AND SY_PROCESSTEMP_DM_D.PROCESSTYPE = #{processtype}
           AND SY_PROCESSTEMP_DM_D.SPID = #{gSpid}
         ORDER BY SY_PROCESSTEMP_DM_D.SERIALKEY
    </select>

