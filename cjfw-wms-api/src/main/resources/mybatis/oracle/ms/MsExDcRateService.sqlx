<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="msExDcRateService">
	
	<select id="getExDcRateList" resultType="MsExDcRateResDto">
  	 	SELECT /* [msExDCRateService.sqlx][getExDcRateList][외부창고 요율관리 조회 (목록)][박진우][20250723] */
			'0'                                                   AS CHECKYN                     /* 체크 여부 */
			, #{fixDcCode}											AS	FIXDCCODE
			, ''                                                    AS	ROWSTATUS		
			, MS_EXDCRATE.SERIALKEY                                 AS SERIALKEY                  /* 데이터번호 */
			, MS_EXDCRATE.STORERKEY                                 AS STORERKEY                  /* 고객사코드 */
			, MS_EXDCRATE.FROMDATE                                  AS FROMDATE                   /* 시작일자 */
			, MS_EXDCRATE.TODATE                                    AS TODATE                     /* 종료일자 */
			, MS_EXDCRATE.DCCODE                                    AS DCCODE                     /* 센터코드 */
			, CM_DC.DCNAME                                          AS DCNAME                     /* 센터명 */
			, MS_EXDCRATE.ORGANIZE                                  AS ORGANIZE                   /* 창고코드 */
			, CM_ORGANIZE.DESCRIPTION                               AS ORGANIZENM                 /* 창고명 */
			, MS_EXDCRATE.SPECCODE                                  AS SPECCODE                   /* 상품스펙코드 */
			, SUBSTR(MS_EXDCRATE.SPECCODE, 0, 2) AS SPECCODE_L
		     , SUBSTR(MS_EXDCRATE.SPECCODE, 0, 4) AS SPECCODE_M
		     , SUBSTR(MS_EXDCRATE.SPECCODE, 0, 6) AS SPECCODE_S
		     , SUBSTR(MS_EXDCRATE.SPECCODE, 0, 8) AS SPECCODE_D
			, MS_EXDCRATE.SKU                                       AS SKU                        /* 상품코드 */
			, MS_SKU.DESCRIPTION                                    AS SKUNAME                    /* 상품명 */
			, MS_SKU.BASEUOM                                        AS BASEUOM                    /* 기본단위 */
			, MS_EXDCRATE.CUSTKEY                                   AS CUSTKEY                    /* 고객코드 */
			<!-- , MS_CUST.DESCRIPTION                                   AS CUSTNAME                   /* 고객명 */ -->
			, MS_EXDCRATE.EXPENSETYPE                               AS EXPENSETYPE                /* 입출고비정산구분 */
			, MS_EXDCRATE.GRPRICE                                   AS GRPRICE                    /* 입고료 */
			, MS_EXDCRATE.GIPRICE                                   AS GIPRICE                    /* 출고료 */
			, MS_EXDCRATE.STORAGEPRICE                              AS STORAGEPRICE               /* 보관료 */
			, MS_EXDCRATE.AREA_PRICE_UOM                            AS AREA_PRICE_UOM             /* 창고단가 */
			, MS_EXDCRATE.WGHPRICE                                  AS WGHPRICE                   /* 계근료 */
			, MS_EXDCRATE.WORKPRICE                                 AS WORKPRICE                  /* 작업료 */
			, MS_EXDCRATE.TRUCKPRICE                                AS TRUCKPRICE                 /* 용차료 */
			, MS_EXDCRATE.STATUS                                    AS STATUS                     /* 상태 */
			, MS_EXDCRATE.DEL_YN                                    AS DEL_YN                     /* 삭제여부 */
			, MS_EXDCRATE.PLT_PRICE									AS PLT_PRICE				  /* 팔렛트단가*/
			, TO_CHAR(MS_EXDCRATE.ADDDATE, 'yyyymmddhh24miss')      AS ADDDATE                    /* 등록일시 */
			, TO_CHAR(MS_EXDCRATE.EDITDATE, 'yyyymmddhh24miss')     AS EDITDATE                   /* 수정일시 */
			, U1.USERNAME                                           AS ADDWHO                     /* 등록자ID */
			, U2.USERNAME                                           AS EDITWHO                    /* 수정자ID */
			, MS_EXDCRATE.ADDWHO									AS ADDWHOID
			, MS_EXDCRATE.EDITWHO									AS EDITWHOID 						
			, MS_EXDCRATE.EXDCRATE_RANK                             AS EXDCRATE_RANK              /* 우선순위 */
			, MS_SKU.NETWEIGHT                                      AS NETWEIGHT                  /* 실중량 */
			, MS_SKU.QTYPERBOX                                      AS QTYPERBOX                  /* 박스입수 */
			, MS_EXDCRATE.STORAGETYPE                               AS STORAGETYPE                /* 저장조건 */
			, MS_SKU.STORAGETYPE                                    AS STORAGETYPE_SKU            /* 저장조건(SKU) */
			, MS_SKU.LAYERPERPLT                                    AS LAYERPERPLT                /* 팔렛당 적재단수 */
			
		     <!-- /* === 단가 변환 (기본단위 기준) === */
		     , NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.GRPRICE,   MS_SKU.BASEUOM, MS_SKU.QTYPERBOX, NVL((A.BOXPERLAYER*A.LAYERPERPLT),0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT),0) AS GRPRICEUPPERTRANSBASEUOM   /* 입고비 */
		     , NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.GIPRICE,   MS_SKU.BASEUOM, MS_SKU.QTYPERBOX, NVL((A.BOXPERLAYER*A.LAYERPERPLT),0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT),0) AS GIPRICEUPPERTRANSBASEUOM   /* 출고비 */
		     , NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.STORAGEPRICE,MS_SKU.BASEUOM,MS_SKU.QTYPERBOX,NVL((A.BOXPERLAYER*A.LAYERPERPLT),0),MS_SKU.PACKPERBOX,MS_SKU.NETWEIGHT),0)  AS STORAGEPRICEUPPERTRANSBASEUOM /* 창고료 */
		     , NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.WGHPRICE,  MS_SKU.BASEUOM, MS_SKU.QTYPERBOX, NVL((A.BOXPERLAYER*A.LAYERPERPLT),0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT),0) AS WGHPRICEUPPERTRANSBASEUOM   /* 계근비 */
		     , NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.WORKPRICE, MS_SKU.BASEUOM, MS_SKU.QTYPERBOX, NVL((A.BOXPERLAYER*A.LAYERPERPLT),0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT),0) AS WORKPRICEUPPERTRANSBASEUOM /* 작업비 */
		     , NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.PLT_PRICE, MS_SKU.BASEUOM, MS_SKU.QTYPERBOX, NVL((A.BOXPERLAYER*A.LAYERPERPLT),0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT),0) AS PLTPRICEUPPERTRANSBASEUOM  /* 팔렛트단가 */
		
		     /* === 단가 변환 (KG 고정) === */
		     , NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.GRPRICE,   'KG', MS_SKU.QTYPERBOX, NVL((A.BOXPERLAYER*A.LAYERPERPLT),0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT),0) AS GRPRICEUPPERTRANSKG   /* 입고비(KG) */
		     , NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.GIPRICE,   'KG', MS_SKU.QTYPERBOX, NVL((A.BOXPERLAYER*A.LAYERPERPLT),0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT),0) AS GIPRICEUPPERTRANSKG   /* 출고비(KG) */
		     , NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.STORAGEPRICE,'KG',MS_SKU.QTYPERBOX,NVL((A.BOXPERLAYER*A.LAYERPERPLT),0),MS_SKU.PACKPERBOX,MS_SKU.NETWEIGHT),0) AS STORAGEPRICEUPPERTRANSKG /* 창고료(KG) */
		     , NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.WGHPRICE,  'KG', MS_SKU.QTYPERBOX, NVL((A.BOXPERLAYER*A.LAYERPERPLT),0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT),0) AS WGHPRICEUPPERTRANSKG   /* 계근비(KG) */
		     , NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.WORKPRICE, 'KG', MS_SKU.QTYPERBOX, NVL((A.BOXPERLAYER*A.LAYERPERPLT),0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT),0) AS WORKPRICEUPPERTRANSKG /* 작업비(KG) */
		     , NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.PLT_PRICE, 'KG', MS_SKU.QTYPERBOX, NVL((A.BOXPERLAYER*A.LAYERPERPLT),0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT),0) AS PLTPRICEUPPERTRANSKG  /* 팔렛트단가(KG) */ -->
		          /* === 단가 변환 (기본단위 기준) === */
		     , ROUND(NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.GRPRICE,        MS_SKU.BASEUOM, MS_SKU.QTYPERBOX, NVL((A.BOXPERLAYER * A.LAYERPERPLT), 0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT), 0), 2) AS GRPRICEUPPERTRANSBASEUOM        /* 입고비 */
		     , ROUND(NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.GIPRICE,        MS_SKU.BASEUOM, MS_SKU.QTYPERBOX, NVL((A.BOXPERLAYER * A.LAYERPERPLT), 0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT), 0), 2) AS GIPRICEUPPERTRANSBASEUOM        /* 출고비 */
		     , ROUND(NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.STORAGEPRICE,   MS_SKU.BASEUOM, MS_SKU.QTYPERBOX, NVL((A.BOXPERLAYER * A.LAYERPERPLT), 0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT), 0), 2) AS STORAGEPRICEUPPERTRANSBASEUOM   /* 창고료 */
		     , ROUND(NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.WGHPRICE,       MS_SKU.BASEUOM, MS_SKU.QTYPERBOX, NVL((A.BOXPERLAYER * A.LAYERPERPLT), 0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT), 0), 2) AS WGHPRICEUPPERTRANSBASEUOM        /* 계근비 */
		     , ROUND(NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.WORKPRICE,      MS_SKU.BASEUOM, MS_SKU.QTYPERBOX, NVL((A.BOXPERLAYER * A.LAYERPERPLT), 0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT), 0), 2) AS WORKPRICEUPPERTRANSBASEUOM       /* 작업비 */
		     , ROUND(NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.PLT_PRICE,      MS_SKU.BASEUOM, MS_SKU.QTYPERBOX, NVL((A.BOXPERLAYER * A.LAYERPERPLT), 0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT), 0), 2) AS PLTPRICEUPPERTRANSBASEUOM        /* 팔렛트단가 */

     /* === 단가 변환 (KG 고정) === */
		     , ROUND(NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.GRPRICE,        'KG', MS_SKU.QTYPERBOX, NVL((A.BOXPERLAYER * A.LAYERPERPLT), 0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT), 0), 2) AS GRPRICEUPPERTRANSKG              /* 입고비(KG) */
		     , ROUND(NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.GIPRICE,        'KG', MS_SKU.QTYPERBOX, NVL((A.BOXPERLAYER * A.LAYERPERPLT), 0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT), 0), 2) AS GIPRICEUPPERTRANSKG              /* 출고비(KG) */
		     , ROUND(NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.STORAGEPRICE,   'KG', MS_SKU.QTYPERBOX, NVL((A.BOXPERLAYER * A.LAYERPERPLT), 0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT), 0), 2) AS STORAGEPRICEUPPERTRANSKG         /* 창고료(KG) */
		     , ROUND(NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.WGHPRICE,       'KG', MS_SKU.QTYPERBOX, NVL((A.BOXPERLAYER * A.LAYERPERPLT), 0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT), 0), 2) AS WGHPRICEUPPERTRANSKG             /* 계근비(KG) */
		     , ROUND(NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.WORKPRICE,      'KG', MS_SKU.QTYPERBOX, NVL((A.BOXPERLAYER * A.LAYERPERPLT), 0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT), 0), 2) AS WORKPRICEUPPERTRANSKG            /* 작업비(KG) */
		     , ROUND(NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.PLT_PRICE,      'KG', MS_SKU.QTYPERBOX, NVL((A.BOXPERLAYER * A.LAYERPERPLT), 0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT), 0), 2) AS PLTPRICEUPPERTRANSKG             /* 팔렛트단가(KG) */
					
			, NVL((A.BOXPERLAYER	* A.LAYERPERPLT),0)				AS BOXPERPLT				  /* 팔렛당 박스수 */
			<!-- , MS_CUST.DESCRIPTION									AS CUSTNAME -->
			, CASE WHEN
					MS_EXDCRATE.CUSTKEY IS NULL THEN 'STD'
					WHEN
					MS_EXDCRATE.CUSTKEY = 'STD' THEN 'STD'
					ELSE MS_CUST.DESCRIPTION END					AS CUSTNAME
		FROM MS_EXDCRATE
		LEFT JOIN CM_DC ON CM_DC.DCCODE = MS_EXDCRATE.DCCODE
		LEFT JOIN CM_ORGANIZE ON CM_ORGANIZE.ORGANIZE = MS_EXDCRATE.ORGANIZE
		LEFT JOIN MS_SKU ON MS_SKU.STORERKEY = MS_EXDCRATE.STORERKEY AND MS_SKU.SKU = MS_EXDCRATE.SKU
		LEFT JOIN MS_CUST ON MS_CUST.STORERKEY = MS_EXDCRATE.STORERKEY AND MS_CUST.CUSTKEY = MS_EXDCRATE.CUSTKEY AND MS_CUST.CUSTTYPE = 'C'
		LEFT JOIN CM_USER U1 ON U1.USERID = MS_EXDCRATE.ADDWHO
		LEFT JOIN CM_USER U2 ON U2.USERID = MS_EXDCRATE.EDITWHO
		LEFT JOIN MS_CUST
		  ON MS_CUST.STORERKEY 	= MS_EXDCRATE.STORERKEY 
		 AND MS_CUST.CUSTKEY 	= MS_EXDCRATE.CUSTKEY
		 AND MS_CUST.CUSTTYPE = 'C'
		LEFT JOIN MS_DC_PLT_LOAD A
		      ON A.SKU = MS_EXDCRATE.SKU
			 AND A.PLANT = MS_EXDCRATE.ORGANIZE
		WHERE 1=1
		AND MS_EXDCRATE.DCCODE = #{fixDcCode}
		AND MS_EXDCRATE.STORERKEY = #{gStorerkey}
	   <if test="startdateFrom != null and startdateFrom != ''">
	       AND MS_EXDCRATE.TODATE   <![CDATA[ >= ]]> #{startdateFrom}
	   </if>
	   <if test="startdateTo != null and startdateTo != ''">
	       AND MS_EXDCRATE.FROMDATE <![CDATA[ <= ]]> #{startdateTo}
	   </if>

		<if test="delYn != null and delYn != ''">
			AND MS_EXDCRATE.DEL_YN = #{delYn}
		</if>
		<if test="storageType != null and storageType != ''">
			AND MS_SKU.STORAGETYPE = #{storageType}
			
		</if>
		<if test="specCode != null and specCode != ''">
			AND MS_EXDCRATE.SPECCODE LIKE #{specCode} || '%'
		</if>
		<if test="custKey != null and custKey != ''">
			AND MS_EXDCRATE.CUSTKEY LIKE #{custKey} || '%'
		</if>

		
		<if test="organize != null and organize != ''">
			AND MS_EXDCRATE.ORGANIZE IN (
				SELECT TRIM(REGEXP_SUBSTR(VAL, '[^,]+', 1, LEVEL)) AS ORGANIZE
				FROM (SELECT #{organize} AS VAL FROM DUAL)
				CONNECT BY INSTR(VAL, ',', 1, LEVEL - 1) > 0
			)
		</if>
		<if test="sku != null and sku != ''">
			AND MS_EXDCRATE.SKU IN (
				SELECT TRIM(REGEXP_SUBSTR(VAL, '[^,]+', 1, LEVEL)) AS SKU
				FROM (SELECT #{sku} AS VAL FROM DUAL)
				CONNECT BY INSTR(VAL, ',', 1, LEVEL - 1) > 0
			)
		</if>
	</select>
	
	<select id="getExDcRateDeleteList" resultType="MsExDcRateSaveReqDto">
		SELECT /* [msExDCRateService.sqlx][getExDcRateDeleteList][외부창고 요율관리 삭제 조회 ][ParkJinWoo][20250723]*/
			'0'                                                   AS CHECKYN                     /* 체크 여부 */
			, MS_EXDCRATE.SERIALKEY                                AS SERIALKEY                  /* 데이터번호 */
			, MS_EXDCRATE.STORERKEY                                AS STORER_KEY                  /* 고객사코드 */
			, MS_EXDCRATE.FROMDATE                                 AS FROMDATE                   /* 시작일자 */
			, MS_EXDCRATE.TODATE                                   AS TODATE                     /* 종료일자 */
			, MS_EXDCRATE.DCCODE                                   AS DCCODE                     /* 센터코드 */
			, CM_DC.DCNAME                                         AS DCNAME                     /* 센터명 */
			, MS_EXDCRATE.ORGANIZE                                 AS ORGANIZE                   /* 창고코드 */
			, CM_ORGANIZE.DESCRIPTION                              AS ORGANIZENM                 /* 창고명 */
			, MS_EXDCRATE.SPECCODE                                 AS SPECCODE                   /* 상품스펙코드 */
			, MS_EXDCRATE.SKU                                      AS SKU                        /* 상품코드 */
			, MS_SKU.DESCRIPTION                                   AS SKUNAME                    /* 상품명 */
			, MS_SKU.BASEUOM                                       AS BASEUOM                    /* 기본단위 */
			, MS_EXDCRATE.PLT_PRICE									AS PLT_PRICE				  /* 팔렛트단가*/
			, MS_EXDCRATE.CUSTKEY                                  AS CUSTKEY                    /* 고객코드 */
			, MS_CUST.DESCRIPTION                                  AS CUSTNAME                   /* 고객명 */
			, MS_EXDCRATE.EXPENSETYPE                              AS EXPENSETYPE                /* 입출고비정산구분 */
			, MS_EXDCRATE.GRPRICE                                  AS GRPRICE                    /* 입고료 */
			, MS_EXDCRATE.GIPRICE                                  AS GIPRICE                    /* 출고료 */
			, MS_EXDCRATE.STORAGEPRICE                             AS STORAGEPRICE               /* 보관료 */
			, MS_EXDCRATE.STOGRPRICE                               AS STOGRPRICE                /* 이체입고비 */
			, MS_EXDCRATE.STOGIPRICE                               AS STOGIPRICE                 /* 이체출고비 */
			, MS_EXDCRATE.WGHPRICE                               AS WGHPRICE                 /* 이체출고비 */
			, MS_EXDCRATE.AREA_PRICE_UOM                               AS AREA_PRICE_UOM                  /* 이체출고비 */
			, MS_EXDCRATE.WORKPRICE                                AS WORKPRICE                  /* 작업료 */
			, MS_EXDCRATE.TRUCKPRICE                               AS TRUCKPRICE                 /* 용차료 */
			, MS_EXDCRATE.STATUS                                   AS STATUS                     /* 상태 */
			, 'Y'                                                  AS DEL_YN                     /* 삭제여부 */
			, TO_CHAR(MS_EXDCRATE.ADDDATE, 'yyyymmddhh24miss')     AS ADDDATE                    /* 등록일시 */
			, SYSDATE                                              AS EDITDATE                   /* 수정일시 */
			, U1.USERNAME                                          AS ADDWHO                     /* 등록자ID */
			, #{gUserId}                                           AS EDITWHO                    /* 수정자ID */
			, MS_EXDCRATE.EXDCRATE_RANK                            AS EXDCRATE_RANK              /* 우선순위 */
			, MS_SKU.NETWEIGHT                                     AS NETWEIGHT                  /* 실중량 */
			, MS_SKU.QTYPERBOX                                     AS QTYPERBOX                  /* 박스입수 */
			, MS_EXDCRATE.STORAGETYPE                              AS STORAGETYPE                /* 저장조건 */
			, MS_SKU.STORAGETYPE                                   AS STORAGETYPE_SKU            /* 저장조건(SKU) */
			, MS_SKU.BOXPERPLT                                     AS BOXPERPLT                  /* 팔렛당 박스수 */
			, MS_SKU.LAYERPERPLT                                   AS LAYERPERPLT               /* 팔렛당 적재단수 */
		FROM MS_EXDCRATE
		LEFT JOIN CM_DC ON CM_DC.DCCODE = MS_EXDCRATE.DCCODE
		LEFT JOIN CM_ORGANIZE ON CM_ORGANIZE.ORGANIZE = MS_EXDCRATE.ORGANIZE
		LEFT JOIN MS_SKU ON MS_SKU.STORERKEY = MS_EXDCRATE.STORERKEY AND MS_SKU.SKU = MS_EXDCRATE.SKU
		LEFT JOIN MS_CUST ON MS_CUST.STORERKEY = MS_EXDCRATE.STORERKEY AND MS_CUST.CUSTKEY = MS_EXDCRATE.CUSTKEY AND MS_CUST.CUSTTYPE = 'C'
		LEFT JOIN CM_USER U1 ON U1.USERID = MS_EXDCRATE.ADDWHO
		LEFT JOIN CM_USER U2 ON U2.USERID = MS_EXDCRATE.EDITWHO
		WHERE 1=1
		AND MS_EXDCRATE.SERIALKEY = #{serialKey}
		AND MS_EXDCRATE.STORERKEY = #{gStorerkey}
		AND MS_EXDCRATE.SERIALKEY IN (
						SELECT TRIM(REGEXP_SUBSTR(VAL, '[^,]+', 1, LEVEL)) AS VAL
						FROM (SELECT #{serialKey} AS VAL FROM DUAL) A
						CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0
					)
	</select>

	<select id="getMsExDCRateSerialKey" resultType ="int">
		SELECT /* [msExDCRateService.sqlx][getMsExDCRateSerialKey][데이터번호 채번][ParkJinWoo][20250723] */
		        SEQ_MS_EXDCRATE.NEXTVAL   AS SERIALKEY
		FROM    DUAL

	</select>

	
	<insert id="insert">
		<![CDATA[
			INSERT 
				/* [msExDCRateService.sqlx][msExDCRateService.insert][외부창고 요율관리 INSERT][ParkJinWoo][20250723] */
				INTO MS_EXDCRATE (
				DCCODE
				, STORERKEY
				, ORGANIZE
				, FROMDATE
				, TODATE
				, SPECCODE
				, SKU
				, STORAGETYPE
				, CUSTKEY
				, EXPENSETYPE
				, GRPRICE
				, GIPRICE
				, STORAGEPRICE
				, STOGRPRICE
				, WORKPRICE
				, AREA_PRICE_UOM
				, ADDWHO
				, EDITWHO
				, EXDCRATE_RANK
				, WGHPRICE
				, PLT_PRICE
				, SERIALKEY									
			)
			SELECT
				
			      #{dcCode}
				, #{gStorerkey}
				, #{organize}
				, #{fromDate}
				, #{toDate}
				, #{specCode}
				, #{sku}
				, NVL(#{storageType}, #{storageTypeSku})
				, #{custKey}
				, #{expenseType}
				, NVL(#{grPrice},0)
				, NVL(#{giPrice},0)
				, NVL(#{storagePrice},0)
				, NVL(#{grPrice},0)
				, NVL(#{workPrice},0)
				, #{areaPriceUom}
				, #{gUserId}
				, #{gUserId}
		
				, CASE #{exDcRateRank}
					WHEN '10' THEN '10'
					WHEN '1'  THEN '10'
					WHEN '20' THEN '20'
					WHEN '2'  THEN '20'
					ELSE '10'
				END
				, NVL( #{wghPrice},0)
				, NVL(#{pltPrice},0)
				, #{serialKey}
			FROM DUAL
			WHERE NOT EXISTS (
				SELECT 1
			FROM MS_EXDCRATE
			WHERE 1=1
			AND MS_EXDCRATE.DCCODE = #{dcCode}
			AND MS_EXDCRATE.STORERKEY = #{gStorerkey}
			AND MS_EXDCRATE.ORGANIZE = #{organize}
			AND NVL(MS_EXDCRATE.CUSTKEY,'STD') = NVL(#{custKey},'STD')
			AND (
					(NVL(#{sku}, 'NULL') <> 'NULL'
						AND MS_EXDCRATE.SKU = #{sku}
					)
				OR (NVL(#{sku}, 'NULL') = 'NULL'
						AND MS_EXDCRATE.SPECCODE = #{specCode}
						AND NVL(MS_EXDCRATE.STORAGETYPE, '00') = NVL(#{storageType}, '00')
					)
				)
			AND (
					(MS_EXDCRATE.FROMDATE >= #{fromDate} OR MS_EXDCRATE.TODATE >= #{fromDate})
				AND (MS_EXDCRATE.FROMDATE <= #{toDate}   OR MS_EXDCRATE.TODATE <= #{toDate})
				)
			AND MS_EXDCRATE.DEL_YN = 'N'
		
		
			)
			]]>
	</insert>
	<select id = "updateChk" resultType="MsExDcRateSaveReqDto">
	<![CDATA[
					SELECT *
			FROM MS_EXDCRATE
			WHERE 1=1
			AND MS_EXDCRATE.DCCODE = #{dcCode}
			AND MS_EXDCRATE.STORERKEY = #{gStorerkey}
			AND MS_EXDCRATE.ORGANIZE = #{organize}
			AND NVL(MS_EXDCRATE.CUSTKEY,'STD') = NVL(#{custKey},'STD')
			AND (
					(NVL(#{sku}, 'NULL') <> 'NULL'
						AND MS_EXDCRATE.SKU = #{sku}
					)
				OR (NVL(#{sku}, 'NULL') = 'NULL'
						AND MS_EXDCRATE.SPECCODE = #{specCode}
						AND NVL(MS_EXDCRATE.STORAGETYPE, '00') = NVL(#{storageType}, '00')
					)
				)
			AND (
					(MS_EXDCRATE.FROMDATE >= #{fromDate} OR MS_EXDCRATE.TODATE >= #{fromDate})
				AND (MS_EXDCRATE.FROMDATE <= #{toDate}   OR MS_EXDCRATE.TODATE <= #{toDate})
				)
			AND MS_EXDCRATE.DEL_YN = 'N'
			AND MS_EXDCRATE.SERIALKEY <> #{serialKey}
		]]>
	</select>
	<insert id="insertIf">
	/*추후 컬럼 추가 예정*/
		INSERT	/* [msExDCRateService.sqlx][insertIf][외부창고 요율관리 IF INSERT][ParkJinWoo][20250723] */
		INTO IF_MS_EXDCRATE (
			SERIALKEY
			, STORERKEY
			, FROMDATE
			, TODATE
			, DCCODE
			, STORAGELOC
			, SKUGROUP
			, SPECCODE
			, SKU
			, CUSTKEY
			, EXPENSETYPE
			, GRPRICE
			, GIPRICE
			, STORAGEPRICE
			, STOGRPRICE
			, STOGIPRICE
			, WORKPRICE
			, TRUCKPRICE
			, STORAGETYPE
			, DEL_YN
			, ADDWHO
			, EDITWHO
			, IF_ID
			, IF_FLAG
			, WMSSERIALKEY
			, IF_DATE
			,  WGHPRICE
		    , PLT_PRICE
		    , AREA_PRICE_UOM
		)
		VALUES (
			SEQ_IF_MS_EXDCRATE.NEXTVAL
			, #{gStorerkey}
			, #{fromDate}
			, #{toDate}
			, #{dcCode}
			, REPLACE(#{organize}, '2170-', '')
			, (
				SELECT MAX(SPECCATEGORY)
				FROM IF_MS_SKUSPEC
				WHERE STORERKEY = #{gStorerkey}
				AND SPECCODE = #{specCode}
				AND IF_FLAG = 'Y'
			)
			, #{specCode}
			, #{sku}
			, #{custKey}
			, #{expenseType}
			, NVL(#{grPrice},0)
			, NVL(#{giPrice},0)
			, NVL(#{storagePrice},0)
			, NVL(#{grPrice},0)
			, NVL(#{stoGiPrice},0)
			, NVL(#{workPrice},0)
			, 0
			, NVL(#{storageType}, #{storageTypeSku})
			, 'C'
			, #{gUserId}
			, #{gUserId}
			, 'SCM0460'
			, 'N'
			, #{serialKey}
			, SYSDATE + (3 / 24 / 60 / 60)
			, NVL(#{wghPrice},0)
			, NVL(#{pltPrice},0)
		    , #{areaPriceUom}
		)
	</insert>

	<insert id="insertIfDel">
	/*추후 컬럼 추가 예정*/
		INSERT /* [msSkuService.sqlx][insertIfDel][외부창고 요율관리 IF INSERT(삭제건)][ParkJinWoo][20250723] */
		INTO IF_MS_EXDCRATE (
			SERIALKEY
			, STORERKEY
			, FROMDATE
			, TODATE
			, DCCODE
			, STORAGELOC
			, SKUGROUP
			, SPECCODE
			, SKU
			, CUSTKEY
			, EXPENSETYPE
			, GRPRICE
			, GIPRICE
			, STORAGEPRICE
			, STOGRPRICE
			, STOGIPRICE
			, WORKPRICE
			, TRUCKPRICE
			, STORAGETYPE
			, DEL_YN
			, ADDWHO
			, EDITWHO
			, IF_ID
			, IF_FLAG
			, WMSSERIALKEY
			,  WGHPRICE
		    , PLT_PRICE
		    , AREA_PRICE_UOM
		)
		SELECT
			SEQ_IF_MS_EXDCRATE.NEXTVAL
			, STORERKEY
			, FROMDATE
			, TODATE
			, DCCODE
			, REPLACE(ORGANIZE, '2170-', '')
			, (
				SELECT MAX(SPECCATEGORY)
				FROM IF_MS_SKUSPEC
				WHERE STORERKEY = MS_EXDCRATE.STORERKEY
				AND SPECCODE = MS_EXDCRATE.SPECCODE
				AND IF_FLAG = 'Y'
			)
			, SPECCODE
			, SKU
			, CUSTKEY
			, EXPENSETYPE
			, GRPRICE
			, GIPRICE
			, STORAGEPRICE
			, STOGRPRICE
			, STOGIPRICE
			, WORKPRICE
			, 0
			, STORAGETYPE
			, 'D'
			, #{gUserId}
			, #{gUserId}
			, 'SCM0460'
			, 'N'
			, #{serialKey}
		    , #{wghPrice}
			, #{pltPrice}
		    , #{areaPriceUom}
		FROM MS_EXDCRATE
		WHERE SERIALKEY = #{serialKey}
	</insert>
 
	<select id="update" statementType="CALLABLE" resultType="HMAP">
		<![CDATA[
			{CALL  /* [MsExDcRateService.sqlx][update][외부창고 요율관리 UPDATE][JinWoo.Park][2025.06.11] */
				DECLARE
					V_AFTER     MS_EXDCRATE%rowtype;
					O_SUCCESS   NUMBER  :=  1;      /* 성공여부(1이면 성공) */
					O_ERRCODE   NUMBER  :=  0;      /* 오류 코드 */
					O_ERRMSG    VARCHAR2(4000) := '';      /* 오류 메세지 */
				BEGIN
					FOR KEY_LIST IN (
						SELECT
							SERIALKEY
						FROM MS_EXDCRATE
						WHERE SERIALKEY = #{serialKey}
					)
					LOOP
						BEGIN
							SELECT  *
							INTO    V_AFTER
							FROM    MS_EXDCRATE
							WHERE   SERIALKEY = KEY_LIST.SERIALKEY;
			
							-- 컬럼별 값 대입(파라미터로)
							V_AFTER.DCCODE              := #{dcCode};
							V_AFTER.STORERKEY           := #{gStorerkey};
							V_AFTER.ORGANIZE            := #{organize};
							V_AFTER.FROMDATE            := #{fromDate};
							V_AFTER.TODATE              := #{toDate};
							V_AFTER.SPECCODE            := #{specCode};
							V_AFTER.SKU                 := #{sku};
							V_AFTER.STORAGETYPE         := NVL(#{storageType}, #{storageTypeSku});
							V_AFTER.CUSTKEY             := #{custKey};
							V_AFTER.EXPENSETYPE         := #{expenseType};
							V_AFTER.GRPRICE             := NVL(#{grPrice},0);
							V_AFTER.GIPRICE             := NVL(#{giPrice},0);
							V_AFTER.STORAGEPRICE        := NVL(#{storagePrice},0);
							V_AFTER.WGHPRICE        	:= NVL(#{wghPrice},0);
							V_AFTER.WORKPRICE           := NVL(#{workPrice},0);
							V_AFTER.AREA_PRICE_UOM      := #{areaPriceUom};
							V_AFTER.EDITDATE            := SYSDATE;
							V_AFTER.EDITWHO             := #{gUserId};
							V_AFTER.DEL_YN              := #{delYn};
							V_AFTER.AREA_PRICE_UOM      := #{areaPriceUom};
							V_AFTER.EXDCRATE_RANK       := NVL(#{exDcRateRank},0);
							V_AFTER.EXDCRATE_RANK       := NVL(#{exDcRateRank},0);
							V_AFTER.PLT_PRICE			:= NVL(#{pltPrice},0);
							
			
							-- 실제 UPDATE 프로시저 호출 (함수명은 예시)
							TRMS_EXDCRATE.TR_UPDATE(
								V_AFTER
							, O_SUCCESS
							, O_ERRCODE
							, O_ERRMSG
							);
			
							EXIT WHEN O_SUCCESS < 1;
			
						END;
					END LOOP;
			
					#{success, mode=OUT, jdbcType=INTEGER, javaType=int}    :=  O_SUCCESS;
					#{err, mode=OUT, jdbcType=INTEGER, javaType=int}        :=  O_ERRCODE;
					#{errmsg, mode=OUT, jdbcType=VARCHAR, javaType=String}  :=  O_ERRMSG;
			
				END
				]]>  
			} 
		
	</select>


	<select id="checkRateAvg" resultType="MsExDcRateCheckRateAvgResDto">
				WITH BASE AS (
	       SELECT  /* 비교 대상 샘플 풀 */
	               MS_EXDCRATE.STORERKEY                 AS STORERKEY          /* 고객사코드 */
	             , MS_EXDCRATE.DCCODE                    AS DCCODE             /* 물류센터 */
	             , MS_EXDCRATE.ORGANIZE                  AS ORGANIZE           /* 창고 */
	             , MS_EXDCRATE.SKU                       AS SKU                /* 상품코드 */
	             , MS_EXDCRATE.FROMDATE                  AS FROMDATE           /* 시작일자 */
	             , MS_EXDCRATE.TODATE                    AS TODATE             /* 종료일자 */
	             , MS_SKU.SKUGROUP                       AS SKUGROUP           /* 상품그룹 */
	             , MS_EXDCRATE.GRPRICE                   AS GRPRICE            /* 입고료 */
	             , MS_EXDCRATE.GIPRICE                   AS GIPRICE            /* 출고료 */
	             , MS_EXDCRATE.STORAGEPRICE              AS STORAGEPRICE       /* 창고료 */
	             , MS_EXDCRATE.WGHPRICE                  AS WGHPRICE           /* 계근비 */
	             , MS_EXDCRATE.WORKPRICE                 AS WORKPRICE          /* 작업비 */
	             , MS_EXDCRATE.PLT_PRICE                 AS PLT_PRICE          /* 팔렛트단가 */
	             
	       FROM     MS_EXDCRATE
	       JOIN     MS_SKU
	              ON MS_SKU.STORERKEY <![CDATA[=]]> MS_EXDCRATE.STORERKEY
	             AND MS_SKU.SKU       <![CDATA[=]]> MS_EXDCRATE.SKU
	       WHERE    MS_EXDCRATE.DCCODE     <![CDATA[=]]> #{dcCode}
	         AND    MS_EXDCRATE.STORERKEY  <![CDATA[=]]> #{gStorerkey}
	         AND    MS_EXDCRATE.ORGANIZE   <![CDATA[=]]> #{organize}
	         AND    MS_EXDCRATE.FROMDATE   <![CDATA[=]]> #{fromDate}
	         AND    MS_EXDCRATE.TODATE     <![CDATA[=]]> #{toDate}
	         AND    MS_EXDCRATE.DEL_YN     <![CDATA[=]]> #{delYn}
	),
	AGG AS (
	       SELECT  BASE.STORERKEY                                         AS STORERKEY          /* 고객사코드 */
	             , BASE.DCCODE                                            AS DCCODE             /* 물류센터 */
	             , BASE.ORGANIZE                                          AS ORGANIZE           /* 창고 */
	             , SUBSTR(BASE.SKUGROUP, 1, 2)                            AS SPECCODE_PREFIX    /* 대분류(앞 2자리) */
	             , NVL(AVG(BASE.GRPRICE)     , 0)                         AS AVG_GRPRICE        /* 평균 입고료 */
	             , NVL(AVG(BASE.GIPRICE)     , 0)                         AS AVG_GIPRICE        /* 평균 출고료 */
	             , NVL(AVG(BASE.STORAGEPRICE), 0)                         AS AVG_STORAGEPRICE   /* 평균 창고료 */
	             , NVL(AVG(BASE.WGHPRICE)    , 0)                         AS AVG_WGHPRICE       /* 평균 계근비 */
	             , NVL(AVG(BASE.WORKPRICE)   , 0)                         AS AVG_WORKPRICE      /* 평균 작업비 */
	             , NVL(AVG(BASE.PLT_PRICE)   , 0)                         AS AVG_PLT_PRICE      /* 평균 팔렛트단가 */
	       FROM    BASE
	       GROUP BY BASE.STORERKEY
	              , BASE.DCCODE
	              , BASE.ORGANIZE
	              , SUBSTR(BASE.SKUGROUP, 1, 2)
	)
	SELECT  COUNT(1)                                                      AS CHECKCNT           /* 일치 건수: 1이면 OK, 0이면 밴드 밖 */
	FROM    AGG
	WHERE   SUBSTR(TO_CHAR(#{specCode}), 1, 2) <![CDATA[=]]> AGG.SPECCODE_PREFIX
	  AND   #{grPrice}      <![CDATA[BETWEEN]]> ROUND(AGG.AVG_GRPRICE      * 0.9, 2) <![CDATA[AND]]> ROUND(AGG.AVG_GRPRICE      * 1.1, 2)
	  AND   #{giPrice}      <![CDATA[BETWEEN]]> ROUND(AGG.AVG_GIPRICE      * 0.9, 2) <![CDATA[AND]]> ROUND(AGG.AVG_GIPRICE      * 1.1, 2)
	  AND   #{storagePrice} <![CDATA[BETWEEN]]> ROUND(AGG.AVG_STORAGEPRICE * 0.9, 2) <![CDATA[AND]]> ROUND(AGG.AVG_STORAGEPRICE * 1.1, 2)
	  AND   #{wghPrice}     <![CDATA[BETWEEN]]> ROUND(AGG.AVG_WGHPRICE     * 0.9, 2) <![CDATA[AND]]> ROUND(AGG.AVG_WGHPRICE     * 1.1, 2)
	  AND   #{workPrice}    <![CDATA[BETWEEN]]> ROUND(AGG.AVG_WORKPRICE    * 0.9, 2) <![CDATA[AND]]> ROUND(AGG.AVG_WORKPRICE    * 1.1, 2)
	  AND   #{pltPrice}     <![CDATA[BETWEEN]]> ROUND(AGG.AVG_PLT_PRICE    * 0.9, 2) <![CDATA[AND]]> ROUND(AGG.AVG_PLT_PRICE    * 1.1, 2)
					
	</select>
  
  <!-- 추후 변경 예정 (컬럼 변경 사유 및 요건사항 변경 이유)-->
	<!-- <select id="getExcelCheck"  resultType="MsExDcRateExcelCheckResDto">

	SELECT /* [msExDCRateService.sqlx][msExDCRateService.getExcelCheck][엑셀업로드 데이터 체크][AhnKihyeong][20160525] */
       CASE
   		 WHEN DUPLICATION <![CDATA[>]]> 0 THEN '중복에러'                                           /* 오류메시지 */
         WHEN #{expenseType} IS NULL OR #{expenseType} = '' THEN '필수값 에러 : 입출고비 정산구분 KEY' /* 오류메시지 */
         WHEN #{organize}    IS NULL OR #{organize}    = '' THEN '필수값 에러 : 창고'                 /* 오류메시지 */
         WHEN SKU_NAME         IS NULL OR SKU_NAME        = '' THEN '필수값 에러 : 상품분류 KEY'         /* 오류메시지 */
         WHEN #{expenseType} IS NULL THEN '입출고비 정산구분 KEY 에러'                      /* 오류메시지 */
         WHEN ORGANIZE_NM IS NULL THEN '창고 에러'                                                 /* 오류메시지 */
         WHEN (#{sku} IS NOT NULL AND #{sku} <![CDATA[<>]]> '') AND SKU_NAME IS NULL THEN '상품코드 에러'         /* 오류메시지 */
         WHEN (#{sku} IS NULL OR #{sku} = '')
          AND ( #{storageTypeSku} IS NOT NULL AND  #{storageTypeSku}<![CDATA[<>]]> '')
          AND STORAGETYPE_CNT <![CDATA[=]]> 0 THEN '저장조건 KEY 에러'                               /* 오류메시지 */

         

         /* 그리드 필수값 체크 */
         WHEN AREAPRICEUOM <![CDATA[=]]> 0 THEN '단위 미입력 or 오입력'                    /* 오류메시지 */

         /* 우선순위별 금액 필수값 */
        WHEN #{grPrice}      IS NULL THEN '입고비 미입력'                                              /* 오류메시지 */
               WHEN #{giPrice}      IS NULL THEN '출고비 미입력'                                              /* 오류메시지 */
               WHEN #{storagePrice} IS NULL THEN '창고료 미입력'                                              /* 오류메시지 */
               WHEN #{wghPrice}     IS NULL THEN '계근비(출고시) 미입력'                                      /* 오류메시지 */
               WHEN #{workPrice}    IS NULL THEN '작업비(출고시) 미입력'                                      /* 오류메시지 */
               WHEN #{pltPrice}     IS NULL THEN '팔렛트단가 미입력'                                          /* 오류메시지 */
     
         ELSE ''                                                                                   /* 오류메시지 */
       END                               AS ERRMSG        /* 오류메시지 */
     , ORGANIZE_NM                       AS ORGANIZE_NM   /* 창고명 */
     , SKU_NAME                          AS SKUNAME      /* 상품명 */
     , NVL(CUST_NAME,'STD')                         AS CUST_NAME     /* 고객명 */
     , NVL(CUSTKEY,'')						     AS CUSTKEY
     , SPEC_CODE                         AS SPEC_CODE     /* 상품스펙코드 */
     , NVL(SKU,#{sku})                         		 AS SKU     /* 상품스펙코드 */
     , EXPENSETYPE                        AS EXPENSETYPE   /* 입출고비정산구분 */
     ,STORAGETYPESKU					AS STORAGETYPE
     , 'N'								AS DELYN
FROM (
    SELECT
           (SELECT MAX(DESCRIPTION)
              FROM CM_ORGANIZE
             WHERE ORGANIZE <![CDATA[=]]> #{organize}
               AND ORGANIZE <![CDATA[LIKE]]> '2170-%')                                  AS ORGANIZE_NM     /* 창고명 */
			,	(SELECT BASECODE
			  FROM CM_CODE
			 WHERE 1=1
			   AND CODELIST = 'EXPENSETYPE'
			   AND BASEDESCR = #{expenseType})											AS EXPENSETYPE
         , (SELECT MAX(DESCRIPTION)
              FROM MS_SKU
             WHERE STORERKEY <![CDATA[=]]> #{gStorerkey}
               AND SKU       <![CDATA[=]]> #{sku})                                       AS SKU_NAME        /* 상품명 */
               
          , (SELECT MAX(SKU)
              FROM MS_SKU
             WHERE STORERKEY <![CDATA[=]]> #{gStorerkey}
               AND SKU       <![CDATA[=]]> #{sku})                                       AS SKU        		/* 상품명 */      
			, (SELECT MAX(STORAGETYPE)
              FROM MS_SKU
             WHERE STORERKEY <![CDATA[=]]> #{gStorerkey}
               AND SKU       <![CDATA[=]]> #{sku})                                       AS STORAGETYPESKU        		/* 상품명 */      

         , (SELECT MAX(SKUGROUP)
              FROM MS_SKU
             WHERE STORERKEY <![CDATA[=]]> #{gStorerkey}
               AND SKU       <![CDATA[=]]> #{sku})                                       AS SPEC_CODE       /* 상품스펙코드 */

         , (SELECT MAX(DESCRIPTION)
              FROM MS_CUST
             WHERE STORERKEY <![CDATA[=]]> #{gStorerkey}
               AND CUSTTYPE  <![CDATA[=]]> 'C'
               AND CUSTKEY   <![CDATA[=]]> #{custKey})                                    AS CUST_NAME       /* 고객명 */
         , (SELECT MAX(CUSTKEY)
              FROM MS_CUST
             WHERE STORERKEY <![CDATA[=]]> #{gStorerkey}
               AND CUSTTYPE  <![CDATA[=]]> 'C'
               AND CUSTKEY   <![CDATA[=]]> #{custKey})                                    AS CUSTKEY       /* 고객명 */

         , (SELECT COUNT(1)
              FROM CM_CODE	
             WHERE STORERKEY <![CDATA[=]]> #{gStorerkey}
               AND CODELIST  <![CDATA[=]]> 'EXPENSETYPE'
               AND BASECODE  <![CDATA[=]]> #{expenseType})                                AS EXPENSETYPE_CNT /* 코드 체크(정산구분) */

         , (SELECT COUNT(1)
              FROM CM_CODE
             WHERE STORERKEY IN (#{gStorerkey}, 'STD')
               AND CODELIST  <![CDATA[=]]> 'STORAGETYPE'
               AND BASECODE  <![CDATA[=]]>  #{storageTypeSku})                                AS STORAGETYPE_CNT /* 코드 체크(저장조건) */
		, (SELECT COUNT(1)
              FROM CM_CODE
             WHERE STORERKEY IN (#{gStorerkey}, 'STD')
               AND CODELIST  <![CDATA[=]]> 'UOM'
               AND BASECODE  <![CDATA[=]]>  #{areaPriceUom})                                AS AREAPRICEUOM /* 코드 체크(저장조건) */
         , (SELECT COUNT(1)
              FROM MS_EXDCRATE
             WHERE MS_EXDCRATE.DCCODE     <![CDATA[=]]> #{dcCode}
               AND MS_EXDCRATE.STORERKEY  <![CDATA[=]]> #{gStorerkey}
               AND MS_EXDCRATE.ORGANIZE   <![CDATA[=]]> #{organize}
            AND NVL(MS_EXDCRATE.CUSTKEY,'STD') = NVL(#{custKey},'STD')
               AND (
          (NVL(#{sku}, 'NULL') <![CDATA[<>]]> 'NULL'
            AND MS_EXDCRATE.SKU = #{sku}
          )
        OR (NVL(#{sku}, 'NULL') = 'NULL'
            AND MS_EXDCRATE.SPECCODE = #{specCode}

            AND NVL(MS_EXDCRATE.STORAGETYPE, '00') = NVL((SELECT MAX(STORAGETYPE)
												              FROM MS_SKU
												             WHERE STORERKEY <![CDATA[=]]> #{gStorerkey}
												               AND SKU       <![CDATA[=]]> #{sku}), '00')
												          )
        )
               AND (
                     (MS_EXDCRATE.FROMDATE <![CDATA[>=]]> #{fromDate} OR MS_EXDCRATE.TODATE <![CDATA[>=]]> #{fromDate})
                 AND (MS_EXDCRATE.FROMDATE <![CDATA[<=]]> #{toDate}   OR MS_EXDCRATE.TODATE <![CDATA[<=]]> #{toDate})
                   )
               AND MS_EXDCRATE.DEL_YN <![CDATA[=]]> 'N'
           )                                                                              AS DUPLICATION      /* 중복건수 */
    FROM DUAL
) X

	</select> -->
	
	
<select id="getExcelCheck"  resultType="MsExDcRateExcelCheckResDto">

SELECT /* [msExDCRateService.sqlx][msExDCRateService.getExcelCheck][엑셀업로드 데이터 체크][AhnKihyeong][20160525] */
               RTRIM(
                       (CASE WHEN DUPLICATION <![CDATA[>]]> 0 THEN '중복에러| ' ELSE '' END)
               <![CDATA[||]]> (CASE WHEN EXPENSETYPE IS NULL OR #{expenseType} = '' THEN '필수값 에러 : 입출고비 정산구분 KEY| ' ELSE '' END)
               <![CDATA[||]]> (CASE WHEN ORGANIZE_NM    IS NULL OR ORGANIZE_NM    = '' THEN '필수값 에러 : 창고| ' ELSE '' END)
               <![CDATA[||]]> (CASE WHEN SKU_NAME       IS NULL OR SKU_NAME       = '' THEN '필수값 에러 : 상품분류 KEY| ' ELSE '' END)
               <![CDATA[||]]> (CASE WHEN #{expenseType} IS NULL THEN '입출고비 정산구분 KEY 에러| ' ELSE '' END)
               <![CDATA[||]]> (CASE WHEN ORGANIZE_NM    IS NULL THEN '창고 에러| ' ELSE '' END)
               <![CDATA[||]]> (CASE WHEN (#{sku} IS NOT NULL AND #{sku} <![CDATA[<>]]> '') AND SKU_NAME IS NULL THEN '상품코드 에러| ' ELSE '' END)
               <![CDATA[||]]> (CASE WHEN (#{sku} IS NULL OR #{sku} = '')
                                    AND (#{storageTypeSku} IS NOT NULL AND #{storageTypeSku} <![CDATA[<>]]> '')
                                    AND STORAGETYPE_CNT <![CDATA[=]]> 0
                                    THEN '저장조건 KEY 에러| ' ELSE '' END)

               <![CDATA[||]]> (CASE WHEN AREAPRICEUOM <![CDATA[=]]> 0 THEN '단위 미입력 or 오입력| ' ELSE '' END)

               <![CDATA[||]]> (CASE WHEN #{grPrice}      IS NULL THEN '입고비 미입력| ' ELSE '' END)
               <![CDATA[||]]> (CASE WHEN #{giPrice}      IS NULL THEN '출고비 미입력| ' ELSE '' END)
               <![CDATA[||]]> (CASE WHEN #{storagePrice} IS NULL THEN '창고료 미입력| ' ELSE '' END)
               <![CDATA[||]]> (CASE WHEN #{wghPrice}     IS NULL THEN '계근비(출고시) 미입력| ' ELSE '' END)
               <![CDATA[||]]> (CASE WHEN #{workPrice}    IS NULL THEN '작업비(출고시) 미입력| ' ELSE '' END)
               <![CDATA[||]]> (CASE WHEN #{pltPrice}     IS NULL THEN '팔렛트단가 미입력| ' ELSE '' END)
                     , '| '
               )                                            AS ERRMSG        /* 오류메시지 */
          ,    ORGANIZE_NM                                  AS ORGANIZE_NM   /* 창고명 */
          ,    SKU_NAME                                     AS SKUNAME       /* 상품명 */
          ,    NVL(CUST_NAME, 'STD')                        AS CUST_NAME     /* 고객명 */
          ,    NVL(CUSTKEY, '')                             AS CUSTKEY       /* 고객사키 */
          ,    SPEC_CODE                                    AS SPEC_CODE     /* 상품스펙코드 */
          ,    NVL(SKU, #{sku})                             AS SKU           /* 상품코드 */
          ,    EXPENSETYPE                                  AS EXPENSETYPE   /* 입출고비정산구분 */
          ,    STORAGETYPESKU                               AS STORAGETYPESKU   /* 저장조건 */
          ,    'N'                                          AS DELYN         /* 삭제여부 */
          ,	STORAGETYPESKU                   				AS STORAGETYPESKU	
          ,BASEUOM											AS BASEUOM
          ,QTYPERBOX										AS QTYPERBOX
          ,NETWEIGHT										AS NETWEIGHT
          ,SKU				        						AS SKU	
  FROM (
        SELECT
               (SELECT MAX(DESCRIPTION)
                  FROM CM_ORGANIZE
                 WHERE ORGANIZE <![CDATA[=]]> #{organize}
                   AND ORGANIZE <![CDATA[LIKE]]> '2170-%')                    AS ORGANIZE_NM       /* 창고명 */

             , (SELECT BASECODE
                  FROM CM_CODE
                 WHERE 1 <![CDATA[=]]> 1
                   AND CODELIST <![CDATA[=]]> 'EXPENSETYPE'
                   AND BASEDESCR <![CDATA[=]]> #{expenseType})                AS EXPENSETYPE       /* 입출고비정산구분 */

             , (SELECT MAX(DESCRIPTION)
                  FROM MS_SKU
                 WHERE STORERKEY <![CDATA[=]]> #{gStorerkey}
                   AND SKU       <![CDATA[=]]> #{sku}
                   AND DEL_YN     <![CDATA[=]]> 'N')                        AS SKU_NAME          /* 상품명 */
                   , (SELECT MAX(BASEUOM)
                  FROM MS_SKU
                 WHERE STORERKEY <![CDATA[=]]> #{gStorerkey}
                   AND SKU       <![CDATA[=]]> #{sku}
                   AND DEL_YN     <![CDATA[=]]> 'N')                        AS BASEUOM          /* 상품명 */

             , (SELECT MAX(SKU)
                  FROM MS_SKU
                 WHERE STORERKEY <![CDATA[=]]> #{gStorerkey}
                   AND SKU       <![CDATA[=]]> #{sku}                  
                   AND DEL_YN     <![CDATA[=]]> 'N')							      AS SKU               /* 상품코드 */

             , (SELECT MAX(STORAGETYPE)
                  FROM MS_SKU
                 WHERE STORERKEY <![CDATA[=]]> #{gStorerkey}
                   AND SKU       <![CDATA[=]]> #{sku}
				   AND DEL_YN     <![CDATA[=]]> 'N')                        AS STORAGETYPESKU     /* 저장조건 */
             , (SELECT MAX(SKUGROUP)
                  FROM MS_SKU
                 WHERE STORERKEY <![CDATA[=]]> #{gStorerkey}
                   AND SKU       <![CDATA[=]]> #{sku}
                   AND DEL_YN     <![CDATA[=]]> 'N')                        AS SPEC_CODE         /* 상품스펙코드 */
			 , (SELECT MAX(QTYPERBOX)
                  FROM MS_SKU
                 WHERE STORERKEY <![CDATA[=]]> #{gStorerkey}
                   AND SKU       <![CDATA[=]]> #{sku}
				   AND DEL_YN     <![CDATA[=]]> 'N')                        AS QTYPERBOX     /* 저장조건 */
		    , (SELECT MAX(NETWEIGHT)
                  FROM MS_SKU
                 WHERE STORERKEY <![CDATA[=]]> #{gStorerkey}
                   AND SKU       <![CDATA[=]]> #{sku}
				   AND DEL_YN     <![CDATA[=]]> 'N')                        AS NETWEIGHT     /* 저장조건 */	
             , (SELECT MAX(DESCRIPTION)
                  FROM MS_CUST
                 WHERE STORERKEY <![CDATA[=]]> #{gStorerkey}
                   AND CUSTTYPE  <![CDATA[=]]> 'C'
                   AND CUSTKEY   <![CDATA[=]]> #{custKey})                    AS CUST_NAME         /* 고객명 */

             , (SELECT MAX(CUSTKEY)
                  FROM MS_CUST
                 WHERE STORERKEY <![CDATA[=]]> #{gStorerkey}
                   AND CUSTTYPE  <![CDATA[=]]> 'C'
                   AND CUSTKEY   <![CDATA[=]]> #{custKey})                    AS CUSTKEY           /* 고객사키 */

             , (SELECT COUNT(1)
                  FROM CM_CODE
                 WHERE STORERKEY <![CDATA[=]]> #{gStorerkey}
                   AND CODELIST  <![CDATA[=]]> 'EXPENSETYPE'
                   AND BASECODE  <![CDATA[=]]> #{expenseType})                AS EXPENSETYPE_CNT   /* 코드체크(정산구분) */

             , (SELECT COUNT(1)
                  FROM CM_CODE
                 WHERE STORERKEY IN (#{gStorerkey}, 'STD')
                   AND CODELIST  <![CDATA[=]]> 'STORAGETYPE'
                   AND BASECODE  <![CDATA[=]]> #{storageTypeSku})             AS STORAGETYPE_CNT   /* 코드체크(저장조건) */

             , (SELECT COUNT(1)
                  FROM CM_CODE
                 WHERE STORERKEY IN (#{gStorerkey}, 'STD')
                   AND CODELIST  <![CDATA[=]]> 'UOM'
                   AND BASECODE  <![CDATA[=]]> #{areaPriceUom})               AS AREAPRICEUOM      /* 코드체크(UOM) */

             , (SELECT COUNT(1)
                  FROM MS_EXDCRATE
                 WHERE MS_EXDCRATE.DCCODE     <![CDATA[=]]> #{dcCode}
                   AND MS_EXDCRATE.STORERKEY  <![CDATA[=]]> #{gStorerkey}
                   AND MS_EXDCRATE.ORGANIZE   <![CDATA[=]]> #{organize}
                   AND NVL(MS_EXDCRATE.CUSTKEY, 'STD') <![CDATA[=]]> NVL(#{custKey}, 'STD')
                   AND (
                            (NVL(#{sku}, 'NULL') <![CDATA[<>]]> 'NULL' AND MS_EXDCRATE.SKU <![CDATA[=]]> #{sku})
                         OR (NVL(#{sku}, 'NULL') <![CDATA[=]]> 'NULL'
                             AND MS_EXDCRATE.SPECCODE <![CDATA[=]]> #{specCode}
                             AND NVL(MS_EXDCRATE.STORAGETYPE, '00') <![CDATA[=]]> NVL(
                                     (SELECT MAX(STORAGETYPE)
                                        FROM MS_SKU
                                       WHERE STORERKEY <![CDATA[=]]> #{gStorerkey}
                                         AND SKU       <![CDATA[=]]> #{sku})
                                     , '00'
                                 )
                            )
                       )
                   AND (
                            (MS_EXDCRATE.FROMDATE <![CDATA[>=]]> #{fromDate} OR MS_EXDCRATE.TODATE <![CDATA[>=]]> #{fromDate})
                        AND (MS_EXDCRATE.FROMDATE <![CDATA[<=]]> #{toDate}   OR MS_EXDCRATE.TODATE <![CDATA[<=]]> #{toDate})
                       )
                   AND MS_EXDCRATE.DEL_YN <![CDATA[=]]> 'N'
               )                                                                AS DUPLICATION        /* 중복건수 */
          FROM DUAL
       ) X

</select>
	
	
	 <!-- 추후 변경 예정 (컬럼 변경 사유 및 요건사항 변경 이유)-->
		<select id="getUpdateCheck"  resultType="MsExDcRateResDto">
			SELECT *
			FROM MS_EXDCRATE
			WHERE 1=1
			AND MS_EXDCRATE.DCCODE = #{dcCode}
			AND MS_EXDCRATE.STORERKEY = #{gStorerkey}
			AND NVL(MS_EXDCRATE.CUSTKEY,'STD') = NVL(#{custKey},'STD')
			AND MS_EXDCRATE.ORGANIZE = #{organize}
			AND (
					(NVL(#{sku}, 'NULL') <![CDATA[<>]]> 'NULL'
						AND MS_EXDCRATE.SKU = #{sku}
					)
				OR (NVL(#{sku}, 'NULL') = 'NULL'
						AND MS_EXDCRATE.SPECCODE = #{specCode}
						AND NVL(MS_EXDCRATE.STORAGETYPE, '00') = NVL(#{storageType},  #{storageTypeSku})
					)
				)
				AND NVL(MS_EXDCRATE.CUSTKEY,'STD') = NVL(#{custKey},'STD')
			AND (
					(MS_EXDCRATE.FROMDATE <![CDATA[ >= ]]> #{fromDate} OR MS_EXDCRATE.TODATE <![CDATA[ >= ]]> #{fromDate})
				AND (MS_EXDCRATE.FROMDATE <![CDATA[ <= ]]> #{toDate}   OR MS_EXDCRATE.TODATE <![CDATA[ <= ]]> #{toDate})
				)
			AND MS_EXDCRATE.DEL_YN = 'N'
			AND    MS_EXDCRATE.SERIALKEY    <![CDATA[<>]]>#{serialKey}
		</select>
	
	<select id="getSkuSpecForMsExDcRate" resultType="MsExDcRateGetSkuSpecResDto">
		SELECT	/* [msSkuService.sqlx][getSkuSpecForMsExDcRate][sku스펙반환][ParkJinWoo][20250723] */
			STORERKEY 
			,SPECCATEGORY 
			,SPECCODE   
			,SPECDESCR  
			,SPECCLASS   
			,SPECTYPE
			,SKUGROUP  
		FROM   MS_SKUSPEC
		WHERE  SPECCATEGORY = #{specCategory}

		<if test="storerKey != null and storerKey != ''">
			AND storerKey = #{gStorerkey}
		</if>
		<if test="specClass != null and specClass != ''">
			AND SPECCLASS = #{specClass}
		</if>
	</select>

	<select id="MsExDcRateGetSkuDataSelect" resultType="MsExDcRateGetSkuDataSelectResDto">
		SELECT	/* [msSkuService.sqlx][MsExDcRateGetSkuDataSelect][상품 정보 조회(단건)][ParkJinWoo][20250723] */ 
					MS_SKU.SERIALKEY                           AS SERIALKEY             /* 데이터번호*/
				, MS_SKU.STORERKEY                           AS STORERKEY             /* 고객사코드*/
				, MS_SKU.SKU                                 AS SKU                   /* 상품코드*/
				, MS_SKU.DESCRIPTION                         AS DESCRIPTION           /* 기본 제품명 없을경우 SKU코드*/
				, MS_SKU.INVOICEDESCR                        AS INVOICEDESCR          /* 명세서및 운송장 표기용 상품명*/
				, MS_SKU.ETC_DESCR1                          AS ETC_DESCR1            /* 기타 제품명*/
				, MS_SKU.ETC_DESCR2                          AS ETC_DESCR2            /* 기타 제품명 */
				, MS_SKU.NAMEPRINTTYPE                       AS NAMEPRINTTYPE         /* 명세서찍히는 상품명 출력방법*/
				, MS_SKU.STORAGETYPE                         AS STORAGETYPE           /** 대분류 혹은 저장 타입 1-저온 2-상온 3-제약 4-사료벌크 5-셋트 ....*/
				, MS_SKU.SKUGROUP                            AS SKUGROUP              /* 상품그룹*/
				, MS_SKU.PRODUCT                             AS PRODUCT               /* 상품종류*/
				, MS_SKU.SKUTYPE                             AS SKUTYPE               /** 상품유형 제품-FERT,상품-HAWA,반제품-HALB,원자재-ROH*/
				, MS_SKU.PUTAWAYTYPE                         AS PUTAWAYTYPE           /* 적치유형*/
				, MS_SKU.SKUCLASS                            AS SKUCLASS              /* 상품클래스*/
				, MS_SKU.UNITCODE                            AS UNITCODE              /* 단품코드*/
				, MS_SKU.ITEMCODE                            AS ITEMCODE              /* 아이템코드*/
				, MS_SKU.CUSTSKU                             AS CUSTSKU               /* 거래처상품코드*/
				, MS_SKU.SALESSKU                            AS SALESSKU              /* 판매상품코드*/
				, MS_SKU.MANUFACTURERSKU                     AS MANUFACTURERSKU       /* 생산코드*/
				, MS_SKU.ALTSKU                              AS ALTSKU                /* 대체상품코드*/
				, MS_SKU.RETAILSKU                           AS RETAILSKU             /* 판매상품코드*/
				, MS_SKU.BARCODE1                            AS BARCODE1              /* 표준 바코드*/
				, MS_SKU.BARCODE2                            AS BARCODE2              /* EAN13 바코드*/
				, MS_SKU.BARCODE3                            AS BARCODE3              /* EAN14 바코드*/
				, MS_SKU.BRANDCODE                           AS BRANDCODE             /* 제픔 브랜드 없을경우 고객사코드*/
				, MS_SKU.BRANDDESCR                          AS BRANDDESCR            /* 브랜드명*/
				, MS_SKU.SEASONYEAR                          AS SEASONYEAR            /* 시즌년도*/
				, MS_SKU.SEASONCODE                          AS SEASONCODE            /* 제품 시즌*/
				, MS_SKU.SEASONDESCR                         AS SEASONDESCR           /* 시즌명*/
				, MS_SKU.SEASONOUT                           AS SEASONOUT             /* 시즌아웃정보*/
				, MS_SKU.STYLECODE                           AS STYLECODE             /* 스타일코드 없을경우 SKU코드*/
				, MS_SKU.STYLEDESCR                          AS STYLEDESCR            /* 스타일명*/
				, MS_SKU.COLORCODE                           AS COLORCODE             /* 컬러코드 없을경우 SKU코드*/
				, MS_SKU.COLORDESCR                          AS COLORDESCR            /* 컬러명*/
				, MS_SKU.SIZECODE                            AS RICE_YN              /* 사이즈코드 없을경우 SKU코드=> 미곡여부로 변경*/
				, MS_SKU.SIZEDESCR                           AS SIZEDESCR             /* 사이즈명*/
				, MS_SKU.VENDOR                              AS VENDOR                /* 판매업체코드 없을경우 고객사코드*/
				<!-- , MS_SKU.PLACEOFORIGIN                       AS PLACEOFORIGIN         /* 원산지*/ -->
				, '['||MS_SKU.PLACEOFORIGIN||']'||(SELECT BASEDESCR FROM CM_CODE WHERE STORERKEY=MS_SKU.STORERKEY AND CM_CODE.CODELIST = 'COUNTRY' AND BASECODE=MS_SKU.PLACEOFORIGIN AND DEL_YN='N') AS PLACEOFORIGIN         /* 원산지명*/
				<!-- , MS_SKU.COUNTRYOFORIGIN                     AS COUNTRYOFORIGIN       /* 원산국*/ -->
				, '['||MS_SKU.COUNTRYOFORIGIN||']'||(SELECT BASEDESCR FROM CM_CODE WHERE STORERKEY=MS_SKU.STORERKEY AND CM_CODE.CODELIST = 'COUNTRY' AND BASECODE=MS_SKU.COUNTRYOFORIGIN AND DEL_YN='N') AS COUNTRYOFORIGIN         /* 원산국명*/
				, MS_SKU.POMDCODE                            AS POMDCODE              /* 구매담당코드*/
				, MS_SKU.POMDNAME                            AS POMDNAME              /* 구매담당명*/
				, MS_SKU.SOMDCODE                            AS SOMDCODE              /* 판매담당코드*/
				, MS_SKU.SOMDNAME                            AS SOMDNAME              /* 판매담당명*/
				, MS_SKU.PLANTCUSTKEY                        AS PLANTCUSTKEY          /* 생산업체코드 없을경우 고객사코드*/
				, MS_SKU.IMPORTCUSTKEY                       AS IMPORTCUSTKEY         /* 수입업체코드 없을경우 고객사코드*/
				, MS_SKU.DISTRIBUTIONCUSTKEY                 AS DISTRIBUTIONCUSTKEY   /* 유통업체코드  없을경우 고객사코드*/
				, MS_SKU.RETURNCUSTKEY                       AS RETURNCUSTKEY         /* 반품업체코드  없을경우 고객사코드*/
				, MS_SKU.DISUSECUSTKEY                       AS DISUSECUSTKEY         /* 폐기업체코드  없을경우 고객사코드*/
				, MS_SKU.SKUOPTIONS                          AS SKUOPTIONS            /* 상품옵션(비표등)*/
				, MS_SKU.DURATION                            AS DURATION              /* 유통기간*/
				, MS_SKU.BASEUOM                             AS BASEUOM               /* 기본 단위*/
				, MS_SKU.PURCHASEUOM                         AS PURCHASEUOM           /* 구매 단위*/
				, MS_SKU.SALESUOM                            AS SALESUOM              /* 판매 단위*/
				, MS_SKU.RETURNUOM                           AS RETURNUOM             /* 회수 돤위*/
				<!-- , MS_SKU.BOXPERPLT                           AS BOXPERPLT             /* 팔렛당 박스수*/ -->
				<!-- , NVL((A.BOXPERLAYER	* A.LAYERPERPLT),0)				AS BOXPERPLT	 -->
				, (SELECT  NVL((A.BOXPERLAYER	* A.LAYERPERPLT),0)	
				    FROM MS_DC_PLT_LOAD A
		    		  WHERE A.SKU =#{sku}
					 AND A.PLANT = #{organize})			AS BOXPERPLT			 /* 팔렛당 박스수*/
				, MS_SKU.QTYPERBOX                           AS QTYPERBOX             /* 박스당 낱개수*/
				, MS_SKU.PACKPERBOX                          AS PACKPERBOX            /* 박스당 팩수*/
				, MS_SKU.QTYPERPACK                          AS QTYPERPACK            /* 팩당 낱개수*/
				, MS_SKU.BOXPERLAYER                         AS BOXPERLAYER           /* 적재단당박스수*/
				, MS_SKU.LAYERPERPLT                         AS LAYERPERPLT           /* 팔렛당적재단수*/
				, MS_SKU.GROSSWEIGHT                         AS GROSSWEIGHT           /* 개당 총중량 Kg*/
				, MS_SKU.NETWEIGHT                           AS NETWEIGHT             /* 개당 실중량 Kg*/
				, MS_SKU.CUBE                                AS CUBE                  /* 상품 체적 cm^3 1CBM-1000000*/
				, MS_SKU.CUBEDESCR                           AS CUBEDESCR             /* 상품 체적 설명 길이(Length)-너비(Width)-높이(Height) 단위 mm*/
				, 0    		   								 AS CUBEDESCR1           /* 상품 체적 설명(장) */
				, 0    		   				                 AS CUBEDESCR2           /* 상품 체적 설명(폭) */
				, 0    		   			                     AS CUBEDESCR3           /* 상품 체적 설명(고) */
				, MS_SKU.MINTEMPERATURE                      AS MINTEMPERATURE        /* 관리온도최저값(섭씨)*/
				, MS_SKU.MAXTEMPERATURE                      AS MAXTEMPERATURE        /* 관리온도최대값(섭씨)*/
				, MS_SKU.PURCHASETYPE                        AS PURCHASETYPE          /* 구매유형*/
				, MS_SKU.PURCHASEPRICE                       AS PURCHASEPRICE         /* 구매단가*/
				, MS_SKU.PACKBOXTYPE                         AS PACKBOXTYPE           /* 포장박스유형*/
				, MS_SKU.QCTYPE                              AS QCTYPE                /* QC유형*/
				, MS_SKU.INSPECTTYPE                         AS INSPECTTYPE           /* 검수유형*/
				, MS_SKU.BOMTYPE                             AS BOMTYPE               /* FG-완성품 MTL-구성품 및 일반 PKG-팩키지상품*/
				, MS_SKU.SERIALTYPE                          AS SERIALTYPE            /* 시리얼타입*/
				, MS_SKU.SERIALYN                            AS SERIALYN              /* 시리얼관리여부*/
				, MS_SKU.MIXBOXYN                            AS MIXBOXYN              /* 합포장가능여부*/
				, MS_SKU.ABC                                 AS ABC                   /* ABC*/
				, MS_SKU.LINE01                              AS LINE01                /* 제품 생산라인1*/
				, MS_SKU.LINE02                              AS LINE02                /* 제품 생산라인2*/
				, MS_SKU.LINE03                              AS LINE03                /* 제품 생산라인3*/
				, MS_SKU.POSTRATEGY                          AS POSTRATEGY            /* 구매전략*/
				, MS_SKU.SOSTRATEGY                          AS SOSTRATEGY            /* 판매전략*/
				, MS_SKU.ROSTRATEGY                          AS ROSTRATEGY            /* 반품전략*/
				, MS_SKU.INSTRATEGY                          AS INSTRATEGY            /* 입고전략*/
				, MS_SKU.PASTRATEGY                          AS PASTRATEGY            /* 적치전략*/
				, MS_SKU.KEEPSTRATEGY                        AS KEEPSTRATEGY          /* 보관전략*/
				, MS_SKU.FIFOSTRATEGY                        AS FIFOSTRATEGY          /* FIFO전략*/
				
				, MS_SKU.DISASSEMSTRATEGY                    AS DISASSEMSTRATEGY      /* 해체전략*/
				, MS_SKU.OUTSTRATEGY                         AS OUTSTRATEGY           /* 출고전략*/
				, MS_SKU.RETURNSTRATEGY                      AS RETURNSTRATEGY        /* 회수전략*/
				, MS_SKU.PACKSTRATEGY                        AS PACKSTRATEGY          /* 패킹전략*/
				, MS_SKU.STOCKSTRATEGY                       AS STOCKSTRATEGY         /* 재고전략*/
				, MS_SKU.ADJUSTSTRATEGY                      AS ADJUSTSTRATEGY        /* 조정전략*/
				, MS_SKU.HOLDSTRATEGY                        AS HOLDSTRATEGY          /* 보류전략*/
				, MS_SKU.DISUSESTRATEGY                      AS DISUSESTRATEGY        /* 폐기전략*/
				, MS_SKU.HANDLESTRATEGY                      AS HANDLESTRATEGY        /* 취급전략*/
				, MS_SKU.OTHER01                             AS OTHER01               /* 기타정보1*/
				, MS_SKU.OTHER02                             AS OTHER02               /* 기타정보2*/
				, MS_SKU.OTHER03                             AS OTHER03               /* 기타정보3*/
				, MS_SKU.OTHER04                             AS OTHER04               /* 기타정보4*/
				, MS_SKU.OTHER05                             AS OTHER05               /* 기타정보5*/
				, MS_SKU.REFERENCE01                         AS REFERENCE01           /* 참조정보1*/
				, MS_SKU.REFERENCE02                         AS REFERENCE02           /* 참조정보2*/
				, MS_SKU.REFERENCE03                         AS REFERENCE03           /* 참조정보3*/
				, MS_SKU.REFERENCE04                         AS REFERENCE04           /* 참조정보4*/
				, MS_SKU.REFERENCE05                         AS REFERENCE05           /* 참조정보5*/
				, MS_SKU.IMAGEURL1                           AS IMAGEURL1             /* 관련이미지URL1*/
				, MS_SKU.IMAGEURL2                           AS IMAGEURL2             /* 관련이미지URL2*/
				, MS_SKU.IMAGEURL3                           AS IMAGEURL3             /* 관련이미지URL3*/
				, MS_SKU.IMAGEURL4                           AS IMAGEURL4             /* 관련이미지URL4*/
				, MS_SKU.IMAGEURL5                           AS IMAGEURL5             /* 관련이미지URL5*/
				, MS_SKU.IFFILENAME                          AS IFFILENAME            /* 인터페이스파일명*/
				, MS_SKU.STATUS                              AS STATUS                /* 상태*/
				, MS_SKU.DEL_YN                              AS DEL_YN                /* 삭제여부*/
				, MS_SKU.TRAFFICCOP                          AS TRAFFICCOP            /* 데이터흐름제어*/
				, MS_SKU.ARCHIVECOP                          AS ARCHIVECOP            /* 아카이브제어*/
				, MS_SKU.ADDWHO                              AS ADDWHO                /* 최초등록자*/
				, MS_SKU.EDITWHO                             AS EDITWHO               /* 최종변경자*/
				, MS_SKU.DURATIONTYPE                        AS DURATIONTYPE          /* 유통기한관리방법*/
				,TO_CHAR(MS_SKU.ADDDATE, 'yyyymmddhh24miss') 	   AS ADDDATE			   /* 최초등록시간 */
				,TO_CHAR(MS_SKU.EDITDATE, 'yyyymmddhh24miss')    AS EDITDATE			   /* 최종변경시간 */		
				, MS_SKU.LABELTYPE
				, FN_DESCR_SKUSPEC(MS_SKU.STORERKEY, 'SKUGROUP', MS_SKU.SKUGROUP)         AS SKU_DDESC
				, FN_DESCR_SKUSPEC(MS_SKU.STORERKEY, 'SKUGROUP', LEFT(MS_SKU.SKUGROUP,6)) AS SKU_SDESC
				, FN_DESCR_SKUSPEC(MS_SKU.STORERKEY, 'SKUGROUP', LEFT(MS_SKU.SKUGROUP,4)) AS SKU_MDESC
				, FN_DESCR_SKUSPEC(MS_SKU.STORERKEY, 'SKUGROUP', LEFT(MS_SKU.SKUGROUP,2)) AS SKU_LDESC
			FROM   MS_SKU
			JOIN   CM_USER_AUTHORITY_STORER
			ON     CM_USER_AUTHORITY_STORER.STORERKEY = MS_SKU.STORERKEY

		AND CM_USER_AUTHORITY_STORER.USERID = #{gUserId}
		WHERE 1=1
		AND MS_SKU.STORERKEY = #{gStorerkey}
		AND MS_SKU.SKU = #{sku}
	    AND MS_SKU.DEL_YN   = 'N'

	</select>
	<select id="dulChkAll"

        resultType="MsExDcRateExcelCheckResDto">

/* [msExDcRateService.sqlx][dulChkAll][엑셀업로드 내부 중복검증(전체반환)][ParkJinWoo][20260107] */
WITH NORM AS (
    <foreach collection="excelList" item="R" index="I" separator="UNION ALL">
        SELECT
               #{R.checkYn}                                  AS CHECKYN                 /* 체크 여부 */
             , TO_CHAR(#{R.fixDcCode})                                AS FIXDCCODE               /* 고정물류센터 */
             , #{R.serialKey}                                AS SERIALKEY               /* 데이터번호 */
             , #{R.storerKey}                                AS STORERKEY               /* 고객사코드 */
             , REPLACE(#{R.fromDate}, '-', '')               AS FROMDATE                /* 시작일자 */
             , REPLACE(#{R.toDate}, '-', '')                 AS TODATE                  /* 종료일자 */
             , #{R.dcCode}                                   AS DCCODE                  /* 물류센터 */
             , #{R.dcName}                                   AS DCNAME                  /* 센터명 */
             , TO_CHAR(#{R.organize})                                 AS ORGANIZE                /* 창고 */
             , #{R.organizeNm}                               AS ORGANIZENM              /* 창고명 */
             , TO_CHAR(#{R.specCode})                             AS SPECCODE                /* 상품스펙코드 */
             , TO_CHAR(#{R.sku})                                      AS SKU                     /* 상품코드 */
             , #{R.skuName}                                  AS SKUNAME                 /* 상품명 */
             , #{R.baseUom}                                  AS BASEUOM                 /* 기본단위 */
             , NVL(TO_CHAR(#{R.custKey}), '@') AS CUSTKEY /* 고객코드 */
             , #{R.custname}                                 AS CUSTNAME                /* 고객명 */
             , #{R.expenseType}                              AS EXPENSETYPE             /* 입출고비정산구분 */
             , #{R.grPrice}                                  AS GRPRICE                 /* 입고료 */
             , #{R.giPrice}                                  AS GIPRICE                 /* 출고료 */
             , TO_CHAR(#{R.storagePrice})                             AS STORAGEPRICE            /* 창고료 */
             , #{R.stoGrPrice}                               AS STOGRPRICE              /* 이체입고비 */
             , #{R.stoGiPrice}                               AS STOGIPRICE              /* 이체출고비 */
             , #{R.workPrice}                                AS WORKPRICE               /* 작업료 */
             , #{R.truckPrice}                               AS TRUCKPRICE              /* 용차료 */
             , #{R.status}                                   AS STATUS                  /* 상태 */
             , #{R.delYn}                                    AS DELYN                   /* 삭제여부 */
             , #{R.addDate}                                  AS ADDDATE                 /* 등록일시 */
             , #{R.editDate}                                 AS EDITDATE                /* 수정일시 */
             , #{R.addWho}                                   AS ADDWHO                  /* 등록자 ID */
             , #{R.editWho}                                  AS EDITWHO                 /* 수정자 ID */
             , #{R.grPriceUpper}                             AS GRPRICEUPPER            /* 1순위 입고비 */
             , #{R.giPriceUpper}                             AS GIPRICEUPPER            /* 1순위 출고비 */
             , #{R.storagePriceUpper}                        AS STORAGEPRICEUPPER       /* 1순위 창고료 */
             , #{R.stoGrPriceUpper}                          AS STOGRPRICEUPPER         /* 1순위 이체입고료 */
             , #{R.stoGiPriceUpper}                          AS STOGIPRICEUPPER         /* 1순위 이체출고료 */
             , #{R.grPriceLower}                             AS GRPRICELOWER            /* 2순위 입고비 */
             , #{R.giPriceLower}                             AS GIPRICELOWER            /* 2순위 출고비 */
             , #{R.storagePriceLower}                        AS STORAGEPRICELOWER       /* 2순위 창고료 */
             , #{R.stoGrPriceLower}                          AS STOGRPRICELOWER         /* 2순위 이체입고료 */
             , #{R.stoGiPriceLower}                          AS STOGIPRICELOWER         /* 2순위 이체출고료 */
             , #{R.exDcRateRank}                             AS EXDCRATERANK            /* 우선순위 */
             , #{R.netWeight}                                AS NETWEIGHT               /* 실중량 */
             , #{R.qtyPerBox}                                AS QTYPERBOX               /* 박스당 낱개수 */
             , #{R.storageType}                              AS STORAGETYPE             /* 저장조건 */
             , #{R.storageTypeSku}                           AS STORAGETYPESKU          /* 저장조건(SKU) */
             , #{R.grPriceUpperTrans}                        AS GRPRICEUPPERTRANS       /* 1순위 입고비 환산 */
             , #{R.giPriceUpperTrans}                        AS GIPRICEUPPERTRANS       /* 1순위 출고비 환산 */
             , #{R.storagePriceUpperTrans}                   AS STORAGEPRICEUPPERTRANS  /* 1순위 창고료 환산 */
             , #{R.stoGrPriceUpperTrans}                     AS STOGRPRICEUPPERTRANS    /* 1순위 이체입고료 환산 */
             , #{R.stoGiPriceUpperTrans}                     AS STOGIPRICEUPPERTRANS    /* 1순위 이체출고료 환산 */
             , #{R.grPriceLowerTrans}                        AS GRPRICELOWERTRANS       /* 2순위 입고비 환산 */
             , #{R.giPriceLowerTrans}                        AS GIPRICELOWERTRANS       /* 2순위 출고비 환산 */
             , #{R.storagePriceLowerTrans}                   AS STORAGEPRICELOWERTRANS  /* 2순위 창고료 환산 */
             , #{R.stoGrPriceLowerTrans}                     AS STOGRPRICELOWERTRANS    /* 2순위 이체입고료 환산 */
             , #{R.stoGiPriceLowerTrans}                     AS STOGIPRICELOWERTRANS    /* 2순위 이체출고료 환산 */
             , #{R.boxPerPlt}                                AS BOXPERPLT               /* 팔렛당 박스수 */
             , #{R.layerPerPlt}                              AS LAYERPERPLT             /* 팔렛당 층수 */
             , #{R.areaPriceUom}                             AS AREAPRICEUOM            /* 창고단가 UOM */
             , #{R.wghPrice}                                 AS WGHPRICE                /* 계근료 */
             , #{R.pltPrice}                                 AS PLTPRICE                /* 파렛트단가 */
             , #{R.uploadFlag}                               AS UPLOADFLAG              /* 업로드확인 */
             , #{R.state}                                    AS STATE                   /* 업로드상태 */
             , #{R.uploadMsg}                                AS UPLOADMSG               /* 업로드메시지 */
             , #{R.errMsg}                                   AS ERRMSG                  /* 오류메시지 */
             , #{I}                                          AS IDX                     /* 리스트인덱스 */
          FROM DUAL
    </foreach>
)
, DUPCHK AS (
    SELECT
           N.*
         , COUNT(*) OVER (
    PARTITION BY
        N.DCCODE
      , N.STORERKEY
      , N.ORGANIZE
     , NVL(N.CUSTKEY, '@')
      , CASE WHEN N.SKU IS NOT NULL THEN 'SKU' ELSE 'SPEC' END
      , CASE WHEN N.SKU IS NOT NULL THEN NVL(N.SKU, '@') ELSE '@' END
      , CASE WHEN N.SKU IS NULL     THEN NVL(N.SPECCODE, '@') ELSE '@' END
      , CASE WHEN N.SKU IS NULL     THEN NVL(N.STORAGETYPE, '00') ELSE '00' END
) AS DUP_CNT
      FROM NORM N
)
SELECT
       D.CHECKYN                                  AS CHECKYN                 /* 체크 여부 */
     , D.FIXDCCODE                                AS FIXDCCODE               /* 고정물류센터 */
     , D.SERIALKEY                                AS SERIALKEY               /* 데이터번호 */
     , D.STORERKEY                                AS STORERKEY               /* 고객사코드 */
     , D.FROMDATE                                 AS FROMDATE                /* 시작일자 */
     , D.TODATE                                   AS TODATE                  /* 종료일자 */
     , D.DCCODE                                   AS DCCODE                  /* 물류센터 */
     , D.DCNAME                                   AS DCNAME                  /* 센터명 */
     , D.ORGANIZE                                 AS ORGANIZE                /* 창고 */
     , D.ORGANIZENM                               AS ORGANIZENM              /* 창고명 */
     , D.SPECCODE                                 AS SPECCODE                /* 상품스펙코드 */
     , D.SKU                                      AS SKU                     /* 상품코드 */
     , D.SKUNAME                                  AS SKUNAME                 /* 상품명 */
     , D.BASEUOM                                  AS BASEUOM                 /* 기본단위 */
     , TO_CHAR(D.CUSTKEY)                                  AS CUSTKEY                 /* 고객코드 */
     , D.CUSTNAME                                 AS CUSTNAME                /* 고객명 */
     , D.EXPENSETYPE                              AS EXPENSETYPE             /* 입출고비정산구분 */
     , D.GRPRICE                                  AS GRPRICE                 /* 입고료 */
     , D.GIPRICE                                  AS GIPRICE                 /* 출고료 */
     , D.STORAGEPRICE                             AS STORAGEPRICE            /* 창고료 */
     , D.STOGRPRICE                               AS STOGRPRICE              /* 이체입고비 */
     , D.STOGIPRICE                               AS STOGIPRICE              /* 이체출고비 */
     , D.WORKPRICE                                AS WORKPRICE               /* 작업료 */
     , D.TRUCKPRICE                               AS TRUCKPRICE              /* 용차료 */
     , D.STATUS                                   AS STATUS                  /* 상태 */
     , D.DELYN                                    AS DELYN                   /* 삭제여부 */
     , D.ADDDATE                                  AS ADDDATE                 /* 등록일시 */
     , D.EDITDATE                                 AS EDITDATE                /* 수정일시 */
     , D.ADDWHO                                   AS ADDWHO                  /* 등록자 ID */
     , D.EDITWHO                                  AS EDITWHO                 /* 수정자 ID */
     , D.GRPRICEUPPER                             AS GRPRICEUPPER            /* 1순위 입고비 */
     , D.GIPRICEUPPER                             AS GIPRICEUPPER            /* 1순위 출고비 */
     , D.STORAGEPRICEUPPER                        AS STORAGEPRICEUPPER       /* 1순위 창고료 */
     , D.STOGRPRICEUPPER                          AS STOGRPRICEUPPER         /* 1순위 이체입고료 */
     , D.STOGIPRICEUPPER                          AS STOGIPRICEUPPER         /* 1순위 이체출고료 */
     , D.GRPRICELOWER                             AS GRPRICELOWER            /* 2순위 입고비 */
     , D.GIPRICELOWER                             AS GIPRICELOWER            /* 2순위 출고비 */
     , D.STORAGEPRICELOWER                        AS STORAGEPRICELOWER       /* 2순위 창고료 */
     , D.STOGRPRICELOWER                          AS STOGRPRICELOWER         /* 2순위 이체입고료 */
     , D.STOGIPRICELOWER                          AS STOGIPRICELOWER         /* 2순위 이체출고료 */
     , D.EXDCRATERANK                             AS EXDCRATERANK            /* 우선순위 */
     , D.NETWEIGHT                                AS NETWEIGHT               /* 실중량 */
     , D.QTYPERBOX                                AS QTYPERBOX               /* 박스당 낱개수 */
     , D.STORAGETYPE                              AS STORAGETYPE             /* 저장조건 */
     , D.STORAGETYPESKU                           AS STORAGETYPESKU          /* 저장조건(SKU) */
     , D.GRPRICEUPPERTRANS                        AS GRPRICEUPPERTRANS       /* 1순위 입고비 환산 */
     , D.GIPRICEUPPERTRANS                        AS GIPRICEUPPERTRANS       /* 1순위 출고비 환산 */
     , D.STORAGEPRICEUPPERTRANS                   AS STORAGEPRICEUPPERTRANS  /* 1순위 창고료 환산 */
     , D.STOGRPRICEUPPERTRANS                     AS STOGRPRICEUPPERTRANS    /* 1순위 이체입고료 환산 */
     , D.STOGIPRICEUPPERTRANS                     AS STOGIPRICEUPPERTRANS    /* 1순위 이체출고료 환산 */
     , D.GRPRICELOWERTRANS                        AS GRPRICELOWERTRANS       /* 2순위 입고비 환산 */
     , D.GIPRICELOWERTRANS                        AS GIPRICELOWERTRANS       /* 2순위 출고비 환산 */
     , D.STORAGEPRICELOWERTRANS                   AS STORAGEPRICELOWERTRANS  /* 2순위 창고료 환산 */
     , D.STOGRPRICELOWERTRANS                     AS STOGRPRICELOWERTRANS    /* 2순위 이체입고료 환산 */
     , D.STOGIPRICELOWERTRANS                     AS STOGIPRICELOWERTRANS    /* 2순위 이체출고료 환산 */
     , D.BOXPERPLT                                AS BOXPERPLT               /* 팔렛당 박스수 */
     , D.LAYERPERPLT                              AS LAYERPERPLT             /* 팔렛당 층수 */
     , D.AREAPRICEUOM                             AS AREAPRICEUOM            /* 창고단가 UOM */
     , D.WGHPRICE                                 AS WGHPRICE                /* 계근료 */
     , D.PLTPRICE                                 AS PLTPRICE                /* 파렛트단가 */

     , CASE
           WHEN D.UPLOADFLAG = 'E' THEN 'E'
           WHEN <![CDATA[ D.DUP_CNT > 1 ]]> THEN 'E'
           ELSE NVL(D.UPLOADFLAG, 'S')
       END                                        AS UPLOADFLAG              /* 업로드확인 */

     , D.STATE                                    AS STATE                   /* 업로드상태 */

, CASE
      /* WHEN D.UPLOADFLAG = 'E' THEN D.UPLOADMSG */
      WHEN <![CDATA[ D.DUP_CNT > 1 ]]> THEN
           CASE
               WHEN D.UPLOADMSG IS NULL OR D.UPLOADMSG = '' THEN '엑셀내 동일 키 중복'
               ELSE D.UPLOADMSG || ' / ' || '엑셀내 동일 키 중복'
           END
      ELSE D.UPLOADMSG
  END AS UPLOADMSG  /* 업로드메시지 */          /* 업로드메시지 */

     , CASE
           WHEN D.UPLOADFLAG = 'E' THEN NVL(D.ERRMSG, '엑셀내 오류')
           WHEN <![CDATA[ D.DUP_CNT > 1 ]]> THEN '엑셀내 동일 키 중복'
           ELSE D.ERRMSG
       END                                        AS ERRMSG                  /* 오류메시지 */

     , CASE
           WHEN D.UPLOADFLAG = 'E' THEN '0'
           WHEN <![CDATA[ D.DUP_CNT > 1 ]]> THEN '0'
           ELSE NVL(D.CHECKYN, '1')
       END                                        AS CHECKYN                 /* 체크 여부(최종) */

  FROM DUPCHK D
 ORDER BY D.IDX

</select>

	
</mapper> 
