<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="quartz">

    <select id="selectQuartz1" resultType="QuartzParamsUtil">
        SELECT SCHED_NAME
             , TRIGGER_NAME
             , TRIGGER_GROUP
        FROM QRTZ_TRIGGERS
    </select>

    <select id="selectQuartz2" resultType="QuartzParamsUtil">
        SELECT SCHED_NAME
             , TRIGGER_NAME
             , TRIGGER_GROUP
        FROM QRTZ_TRIGGERS
    </select>


    <select id="selectBatchList" resultType="QuartzParamsUtil">
        SELECT JOB_NAME
             , JOB_CLASS_NAME
             , CRON_EXPRESSION
        FROM BATCH_H
    </select>

    <select id="selectBatchDetail" resultType="QuartzParamsUtil">
        SELECT PARAM_NAME                       AS paramName
             , PARAM_VALUE                      AS paramValue
        FROM BATCH_D
        WHERE JOB_NAME = #{jobName}
    </select>


    <select id="selectCronTriggers" resultType="QuartzParamsUtil">
        SELECT B.SCHED_NAME
             , A.JOB_NAME
             , B.CRON_EXPRESSION
             , C.JOB_CLASS_NAME
        FROM QRTZ_TRIGGERS A
        LEFT OUTER JOIN QRTZ_CRON_TRIGGERS B
          ON A.SCHED_NAME = B.SCHED_NAME
         AND A.TRIGGER_NAME = B.TRIGGER_NAME
         AND A.TRIGGER_GROUP = B.TRIGGER_GROUP
        LEFT OUTER JOIN QRTZ_JOB_DETAILS C
          ON A.SCHED_NAME = B.SCHED_NAME
         AND A.JOB_NAME = C.JOB_NAME
         AND A.JOB_GROUP = C.JOB_GROUP
    </select>

    <select id="selectJobList" resultType="QuartzParamsUtil">
        SELECT JOB_NAME, JOB_CLASS_NAME, CRON_EXPRESSION
          FROM BATCH_H
         WHERE CRON_EXPRESSION IS NOT NULL
         <if test="useYn == 'Y'.toString()">
           AND USE_YN = 'Y'
         </if>
         <if test="useYn != 'Y'.toString()">
           AND USE_YN = 'N'
         </if>
    </select>

    <insert id="insertBatchStartLog" parameterType="BatchParamsUtil">
        <selectKey keyProperty="EXENO" resultType="String" order="BEFORE">
           SELECT SEQ_FRAMEONE_STMBATEXE_HST.NEXTVAL FROM DUAL
           /* SELECT TO_CHAR(SYSTIMESTAMP,'HH24MISSFF6')  FROM DUAL */
           /* SELECT NVL(MAX(EXE_NO), 0) + 1 FROM FRAMEONE_STMBATEXE_HST */
        </selectKey>
        INSERT /* [commonService.xml][common.insertBatchStartLog][20120102][공정일] */
        INTO FRAMEONE_STMBATEXE_HST
            (EXE_NO
            , STM_CD
            , PGM_ID
            , RUNDATE
            , START_DTM
            , PROC_SUCC_YN
            , REG_ID
            , REG_DTM
            , UPD_ID
            , UPD_DTM)
        VALUES
            (#{EXENO}
            , '01'
            , #{PGMID}
            , TO_CHAR(SYSDATE,'YYYYMMDD')
            , SYSDATE
            , #{STAT}
            , '__BATCH'
            , SYSDATE
            , '__BATCH'
            , SYSDATE)
    </insert>


    <update id="updateBatchEndLog" parameterType="BatchParamsUtil">
        UPDATE FRAMEONE_STMBATEXE_HST
           SET PROC_SUCC_YN = #{STAT}
             , MSG = #{MSG}
             , UPD_ID = '__BATCH'
             , UPD_DTM = SYSDATE
         WHERE EXE_NO = #{EXENO}
    </update>


    <delete id="deleteCronTriggers">
        DELETE QRTZ_CRON_TRIGGERS
    </delete>
    <delete id="deleteJobDetail">
        DELETE QRTZ_JOB_DETAILS
    </delete>
    <delete id="deleteLocks">
        DELETE QRTZ_LOCKS
    </delete>
    <delete id="deleteSchedulerState">
        DELETE QRTZ_SCHEDULER_STATE
    </delete>
    <delete id="deleteTriggers">
        DELETE QRTZ_TRIGGERS
    </delete>

</mapper>