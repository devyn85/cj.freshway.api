<?xml version="1.0" encoding="UTF-8"?><!--Converted at: Mon Feb 17 11:21:55 KST 2014-->
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="batch">
    
    <!-- Job List 조회 -->
    <select id="getJobList" resultType="BatchLogJobGetResDto">
		SELECT  /* [BatchLogService.sqlx][batch.getJobList] */
			A.JOB_EXECUTION_ID 		AS JOB_EXECUTION_ID 
			,A.JOB_INSTANCE_ID 		AS JOB_INSTANCE_ID
			,B.JOB_NAME 			AS JOB_NAME
			,TO_CHAR(A.START_TIME, 'YYYY-MM-DD HH24:MI:SS') AS START_TIME
			,TO_CHAR(A.END_TIME, 'YYYY-MM-DD  HH24:MI:SS')	AS END_TIME
			,A.STATUS 				AS STATUS
		FROM BATCH_JOB_EXECUTION A
		LEFT JOIN BATCH_JOB_INSTANCE B on A.JOB_INSTANCE_ID=B.JOB_INSTANCE_ID
		<trim prefix="WHERE" prefixOverrides="AND |OR">
			AND TO_CHAR(A.START_TIME, 'YYYYMMDD') <![CDATA[<=]]> REPLACE(#{thruDt}, '-', '')	/* 게시기간 */
       		AND TO_CHAR(A.END_TIME, 'YYYYMMDD') <![CDATA[>=]]> REPLACE(#{fromDt}, '-', '')	/* 게시기간 */
			<if test='jobExecutionId !=null and jobExecutionId !=""'>
				AND A.JOB_EXECUTION_ID LIKE #{jobExecutionId} || '%'
			</if>
			<if test='jobName !=null and jobName !=""'>
   				AND B.JOB_NAME LIKE #{jobName}||'%'
   			</if>
   			<if test='jobInstanceId !=null and jobInstanceId !=""'>
   				AND A.JOB_INSTANCE_ID LIKE #{jobInstanceId}||'%'
   			</if>
   			<if test='status != null and status !=""'>
				AND A.STATUS = #{status}
			</if>
   		</trim>
   		<!-- 그리드 sorting -->
		ORDER BY START_TIME DESC, JOB_EXECUTION_ID DESC 	
    </select>
    
    <!-- Step List 조회 -->
    <select id="getStepList" resultType="BatchLogStepGetResDto">
		SELECT  /* [BatchLogService.sqlx][batch.getStepList][2018.03.21][김빛나라] */
			A.JOB_EXECUTION_ID		AS JOB_EXECUTION_ID 
			,B.STEP_EXECUTION_ID	AS STEP_EXECUTION_ID
			,B.STEP_NAME			AS STEP_NAME
			,TO_CHAR(B.START_TIME, 'YYYY-MM-DD HH24:MI:SS')	 AS START_TIME
			,TO_CHAR(B.END_TIME, 'YYYY-MM-DD  HH24:MI:SS')	 AS END_TIME
			,B.READ_COUNT			AS READ_COUNT
			,B.WRITE_COUNT			AS WRITE_COUNT
			,B.STATUS   	  		AS STATUS  
		FROM BATCH_JOB_EXECUTION A
		LEFT JOIN BATCH_STEP_EXECUTION B ON A.JOB_EXECUTION_ID=B.JOB_EXECUTION_ID
		WHERE A.JOB_EXECUTION_ID = #{jobExecutionId}
   		<!-- 그리드 sorting -->
		ORDER BY START_TIME DESC
    </select>
     
	 <!-- Step Result Message 조회 -->
    <select id="getStepResultMessage" resultType="BatchLogStepMsgGetResDto">
		SELECT  /* [BatchLogService.sqlx][batch.getStepResultMessage] */
			A.JOB_EXECUTION_ID,
			 CASE
                WHEN B.STATUS = 'COMPLETED' THEN 'STEP이 성공하였습니다.'
                ELSE B.EXIT_MESSAGE
                END AS GET_LOG
		FROM BATCH_JOB_EXECUTION A
		LEFT JOIN BATCH_STEP_EXECUTION B ON A.JOB_EXECUTION_ID=B.JOB_EXECUTION_ID
		WHERE 
			A.JOB_EXECUTION_ID = #{jobExecutionId}
			AND B.STEP_EXECUTION_ID = #{stepExecutionId}
		<!--// 그리드 sorting -->
		ORDER BY JOB_EXECUTION_ID ASC
    </select>    

</mapper>