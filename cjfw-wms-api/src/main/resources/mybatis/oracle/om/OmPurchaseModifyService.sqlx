    <!-- DM_DOCUMENT_H, DM_DOCUMENT_D, DP_INPLAN, WD_INPLAN DEL_YN = 'Y' 처리 -->
    <update id="updateSTODelYn_DocNo">
    /* [omPurchaseModifyService.sqlx][omPurchaseModifyService.updateSTODelYn_DocNo] */
    BEGIN
	    <!-- DM_DOCUMENT_H DEL_YN = 'Y' 처리 (DP, WD) -->
	    UPDATE DM_DOCUMENT_H
	       SET DEL_YN   = 'Y'
	         , EDITDATE = SYSDATE
	         , EDITWHO  = #{gUserId}
	     WHERE DOCNO    = #{docNo};

	    <!-- DM_DOCUMENT_D DEL_YN = 'Y' 처리 (DP, WD) -->   
	    UPDATE DM_DOCUMENT_D
	       SET DEL_YN   = 'Y'
	         , EDITDATE = SYSDATE
	         , EDITWHO  = #{gUserId}
	     WHERE DOCNO    = #{docNo};
	    
	    <!-- WD_INPLAN DEL_YN = 'Y' 처리 -->   
	    UPDATE WD_INPLAN
	       SET DEL_YN   = 'Y'
	         , EDITDATE = SYSDATE
	         , EDITWHO  = #{gUserId}
	     WHERE DOCNO    = #{docNo};

	    <!-- DP_INPLAN DEL_YN = 'Y' 처리 -->   
	    UPDATE DP_INPLAN
	       SET DEL_YN   = 'Y'
	         , EDITDATE = SYSDATE
	         , EDITWHO  = #{gUserId}
	     WHERE DOCNO    = #{docNo};
		
    END;           
    </update>
    
    <!-- DM_DOCUMENT_H, DM_DOCUMENT_D, DP_INPLAN, WD_INPLAN DEL_YN = 'Y' 처리 -->
    <update id="updateSTODelYn">
    /* [omPurchaseModifyService.sqlx][omPurchaseModifyService.updateSTODelYn] */
    BEGIN
	    <!-- DM_DOCUMENT_D DEL_YN = 'Y' 처리 (DP, WD) -->   
	    UPDATE DM_DOCUMENT_D
	       SET DEL_YN   = 'Y'
	         , EDITDATE = SYSDATE
	         , EDITWHO  = #{gUserId}
	     WHERE DOCNO    = #{slipNo}
	       AND DOCLINE  = #{slipLine};
	    
	    <!-- WD_INPLAN DEL_YN = 'Y' 처리 -->   
	    UPDATE WD_INPLAN
	       SET DEL_YN    = 'Y'
	         , EDITDATE  = SYSDATE
	         , EDITWHO   = #{gUserId}
	     WHERE SLIPNO    = #{slipNo}
	       AND SLIPLINE  = #{slipLine};

	    <!-- DP_INPLAN DEL_YN = 'Y' 처리 -->   
	    UPDATE DP_INPLAN
	       SET DEL_YN   = 'Y'
	         , EDITDATE = SYSDATE
	         , EDITWHO  = #{gUserId}
	     WHERE SLIPNO   = #{slipNo}
	       AND SLIPLINE = #{slipLine};
		
    END;           
    </update>
    
