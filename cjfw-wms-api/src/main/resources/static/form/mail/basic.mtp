<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html>
<head>

<meta name="viewport" content="width=device-width" />
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />

</head>

<table width="100%" style="font-family:'나눔고딕',NanumGothic;">
	<tr>
		<td>
			<div style="padding: 15px;">
			<table>
				<tr>
					<td>
						<h3 style="font-weight:500; font-size:27px;">{big_title}</h3>
						<p style="font-size:17px; margin-bottom:7px;">안녕하세요! {memberName}님. OO에 대한 안내 메일입니다. 아래 내용을 확인해주세요.</p>
						<p style="font-size:17px; margin-bottom:7px;">
							{key1}
						</p>
						<p style="font-size:17px; margin-bottom:7px;">
							{key2}
						</p>
						
						<br>
						
						<table width="100%" align="left" style="padding: 8px;"  bgcolor="#d1d1d1">
							<tr>
								<td>
									<img src="{image.basePath}/images/logo.png" width="130" height="50"/>
								</td>	
								<td>
									<p style="font-size:12px;">
										본 메일은 발신전용 입니다.<br/>
									</p>
								</td>
						</table>
					</td>
				</tr>
			</table>
			</div>
		</td>
	</tr>
</table>
</body>
</html>
