<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="tmGasStationPriceService">
	<insert id="saveGasStationPrice" parameterType="hashmap">		
    	INSERT /* [tmGasStationPriceService.xml][saveGasStationPrice][오피넷 유가정보 저장][JangGwangSeok][2025.07.25] */ INTO IF_TM_GAS_STATION_PRICE 
    	(
    		 DCCODE
    		,FROMDATE
            ,GASTYPE
            ,AVG_PRICE
            ,IF_ID
            ,IF_FLAG
            ,ADDWHO
            ,ADDDATE
            ,EDITWHO
            ,EDITDATE
    	)
    	VALUES 
    	(
    		 'STD'
            ,#{TRADE_DT}
            ,#{PRODCD}
            ,#{PRICE}
            ,'ID227'
            ,'N'
            ,'__BATCH'
            ,SYSDATE
            ,'__BATCH'
            ,SYSDATE
    	)
    </insert>
    
    <sql id="procedureParams">
        #{AVC_IFID,       mode=IN, jdbcType=VARCHAR}
      , #{AVC_IFRESULT,   mode=OUT, jdbcType=VARCHAR}
    </sql>
    
      <select id = "saveTmGasStationPrice" statementType="CALLABLE" timeout="12000">
        { CALL SPIF_RECEIVEDATA_TM.P_IF_TM_GAS_STATION_PRICE( /* [tmGasStationPriceService.sqlx][saveTmGasStationPrice][유가정보 본테이블 저장][박요셉][20251014] */
               <include refid="procedureParams"/>
        ) }
    </select> 
</mapper>