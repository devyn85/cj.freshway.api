<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--
 * Copyright 2025. CJ OliveNetworks Co. all rights reserved.
 *
 * @author      : KimDongHan (liop0123@cj.net)
 * @date        : 2025.09.16
 * @description : 재고 > 재고조정 > 이력상품바코드변경 SQL
 * @issues      :
-->
<mapper namespace="stConvertIdSNService">

    <select id="getMasterList" resultType="cjfw.wms.st.dto.StConvertIdSNResDto">
		SELECT /* [stConvertIdSNService.sqlx][stConvertIdSNService.getMasterList][재고 > 재고조정 > 이력상품바코드변경 조회][KimDongHan][2025-09-16] */
		       ST_STOCK.DCCODE                                                                                                                                           AS DCCODE                /* 01 : 물류센터 */
		     , ST_STOCK.ORGANIZE                                                                                                                                         AS ORGANIZE              /* 02 : 창고 */
		     , FN_CODEDESCR(ST_STOCK.STORERKEY, 'STOCKGRADE', ST_STOCK.STOCKGRADE)                                                                                       AS STOCKGRADENAME        /* 03 : 재고속성 */
		     , FN_DESCR_SKUSPEC(MS_SKU.STORERKEY, 'SKUGROUP', MS_SKU.SKUGROUP)                                                                                           AS SKUGROUP              /* 04 : 상품분류 */	 
		     , ST_STOCK.SKU                                                                                                                                              AS SKU                   /* 05 : 상품코드 */
		     , MS_SKU.DESCRIPTION                                                                                                                                        AS SKUNAME               /* 06 : 상품명칭 */
		     , ST_STOCK.LOC                                                                                                                                              AS FROM_LOC              /* 07 : 로케이션 */
		     , ST_STOCK.UOM                                                                                                                                              AS UOM                   /* 08 : 단위 */
		     , ST_STOCK.QTY                                                                                                                                              AS QTY                   /* 09 : 현재고수량 */
		     , ST_STOCK.OPENQTY                                                                                                                                          AS OPENQTY               /* 10 : 가용재고수량 */
		     , ST_STOCK.QTYALLOCATED                                                                                                                                     AS QTYALLOCATED          /* 11 : 재고할당수량 */
		     , ST_STOCK.QTYPICKED                                                                                                                                        AS QTYPICKED             /* 12 : 피킹재고 */
		     , ST_STOCK.QTY                                                                                                                                              AS TRANQTY               /* 13 : 작업수량 */
		     , CM_LOT.LOTTABLE01                                                                                                                                         AS LOTTABLE01            /* 14 : 기준일(유통,제조) */
             , NVL(CASE WHEN MS_SKU.DURATIONTYPE = '1' AND REGEXP_LIKE(CM_LOT.LOTTABLE01, '^[0-9]{8}$')
                             THEN TO_CHAR(TO_DATE(CM_LOT.LOTTABLE01,'YYYYMMDD') - MS_SKU.DURATION, 'YYYYMMDD')
                             ELSE CM_LOT.LOTTABLE01 END,'STD')                                                                                                           AS LOT_MANUFACTURE       /* 14 : 기준일(제조) */
             , NVL(CASE WHEN MS_SKU.DURATIONTYPE != '1' AND REGEXP_LIKE(CM_LOT.LOTTABLE01, '^[0-9]{8}$')
                        THEN TO_CHAR(TO_DATE(CM_LOT.LOTTABLE01,'YYYYMMDD') + MS_SKU.DURATION, 'YYYYMMDD')
                        ELSE CM_LOT.LOTTABLE01 END,'STD')                                                                                                                AS LOT_EXPIRE            /* 14 : 기준일(소비) */			     
		     , FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'N') || '/' || MS_SKU.DURATION                                  AS DURATION_TERM         /* 15 : 유통기간(잔여/전체) */
		     , ST_SERIALINFO.SERIALNO                                                                                                                                    AS SERIALNO              /* 16 : 이력번호 */	 
		     , ST_SERIALINFO.CONVSERIALNO                                                                                                                                AS CONVSERIALNO          /* 17 : B/L 번호 */	 	
		     , ''                                                                                                                                                        AS DP_DOCNO              /* 18 : PO번호 */
		     , ST_SERIALINFO.BUTCHERYDT                                                                                                                                  AS BUTCHERYDT            /* 19 : 도축일자 */	 
		     , ST_SERIALINFO.FACTORYNAME                                                                                                                                 AS FACTORYNAME           /* 20 : 도축장 */	 
		     , FN_CODEDESCR(ST_SERIALINFO.STORERKEY, 'CONTRACTTYPE_SN', ST_SERIALINFO.CONTRACTTYPE)                                                                      AS CONTRACTTYPE          /* 21 : 계약유형 */	 
		     , ST_SERIALINFO.CONTRACTCUSTKEY                                                                                                                             AS CONTRACTCOMPANY       /* 22 : 계약업체 */
		     , (SELECT DESCRIPTION FROM MS_CUST WHERE MS_CUST.STORERKEY = ST_SERIALINFO.STORERKEY AND MS_CUST.CUSTKEY   = ST_SERIALINFO.CONTRACTCUSTKEY AND ROWNUM = 1)  AS CONTRACTCOMPANYNAME   /* 23 : 계약업체명 */
		     , ST_SERIALINFO.FROMVALIDDT                                                                                                                                 AS FROMVALIDDT           /* 24 : 유효일자(FROM) */
		     , ST_SERIALINFO.TOVALIDDT                                                                                                                                   AS TOVALIDDT             /* 25 : 유효일자(TO) */
		     , ST_STOCK.STOCKID                                                                                                                                          AS FROM_STOCKID          /* 26 : 재고ID */
		     , MS_SKU.DURATION                                                                                                                                           AS DURATION              /* DURATION */
		     , MS_SKU.DURATIONTYPE                                                                                                                                       AS DURATIONTYPE          /* DURATIONTYPE */
		     , ST_STOCK.STORERKEY                                                                                                                                        AS STORERKEY             /* STORERKEY */
		     , ST_STOCK.AREA                                                                                                                                             AS AREA                  /* AREA */
		     , fn_DESCR_AREA(ST_STOCK.STORERKEY, ST_STOCK.AREA)                                                                                                          AS AREANAME              /* AREANAME */
		     , ST_STOCK.STOCKGRADE                                                                                                                                       AS FROM_STOCKGRADE       /* FROM_STOCKGRADE */
		     , ST_STOCK.LOT                                                                                                                                              AS FROM_LOT              /* FROM_LOT */	 
		     , ST_STOCK.STOCKTYPE                                                                                                                                        AS STOCKTYPE             /* STOCKTYPE */
		     , FN_CODEDESCR(ST_STOCK.STORERKEY, 'STOCKTYPE', ST_STOCK.STOCKTYPE)                                                                                         AS STOCKTYPEDESCR        /* STOCKTYPEDESCR */
		     , ST_SERIALINFO.SERIALLEVEL                                                                                                                                 AS SERIALLEVEL           /* SERIALLEVEL */
		     , ST_SERIALINFO.SERIALTYPE                                                                                                                                  AS SERIALTYPE            /* SERIALTYPE */
		     , MS_SKU.COLORDESCR                                                                                                                                         AS COLORDESCR            /* COLORDESCR */
		     , ST_SERIALINFO.PLACEOFORIGIN                                                                                                                               AS PLACEOFORIGIN         /* PLACEOFORIGIN */
		  FROM ST_STOCK
		  <!-- 2025.09.17 김동한. 박의병 수석님 요청으로 권한 테이블을 막고, 화면에서 선택 가능한 물류센터만 조회되도록 함.
		  JOIN CM_USER_AUTHORITY
		    ON CM_USER_AUTHORITY.USERID    = #{gUserId}
		<if test="fixdccode != null and fixdccode != ''">
		   AND CM_USER_AUTHORITY.DCCODE = #{fixdccode}
		</if>
		<if test="gStorerkey != null and gStorerkey != ''">
		   AND CM_USER_AUTHORITY.STORERKEY = #{gStorerkey}
		</if>
	    <if test="gOrganize != null and gOrganize != ''">            
	       AND CM_USER_AUTHORITY.ORGANIZE IN (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
	                                            FROM (SELECT #{gOrganize} AS VAL FROM DUAL) A
	                                         CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0) 
	    </if>
		<if test="gArea != null and gArea != ''">
		   AND CM_USER_AUTHORITY.AREA = #{gArea}
		</if>
		   AND CM_USER_AUTHORITY.DCCODE    = ST_STOCK.DCCODE
		   AND CM_USER_AUTHORITY.STORERKEY = ST_STOCK.STORERKEY
		   AND CM_USER_AUTHORITY.ORGANIZE  = ST_STOCK.ORGANIZE
		   AND CM_USER_AUTHORITY.AREA      = ST_STOCK.AREA
		   -->
		  JOIN MS_SKU
		    ON MS_SKU.STORERKEY  = ST_STOCK.STORERKEY
		   AND MS_SKU.SKU        = ST_STOCK.SKU
		<if test="fixdccode != '2170'">
		   AND MS_SKU.SERIALYN = 'Y'
		</if>
		   AND MS_SKU.DEL_YN = 'N'
		   <!--
		<if test="sku != null and sku != ''">
           AND MS_SKU.SKU IN (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
                                FROM (SELECT #{sku} AS VAL FROM DUAL) A
                             CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)		                      
		</if>
		-->
	    <!-- START.상품멀티 -->
	    <if test="skuMulti != null and skuMulti != '' ">
			<trim prefix="AND (" suffix=")" prefixOverrides="OR">
				<foreach collection="skuMulti" item="item">
					OR MS_SKU.SKU IN
					<foreach collection="item" item="code" open="(" close=")" separator=",">
						#{code} 	 
		      		</foreach>
		    	</foreach>
		  	</trim>			                                    
	    </if>
	    <!-- END.상품멀티 -->			
		<if test="skugroup != null and skugroup != ''">
		   AND MS_SKU.SKUGROUP =  #{skugroup}
		</if>
		  JOIN CM_LOT
		    ON CM_LOT.STORERKEY = ST_STOCK.STORERKEY
		   AND CM_LOT.LOT       = ST_STOCK.LOT
		   AND CM_LOT.DEL_YN    = 'N'
		  JOIN MS_LOCATION
		    ON MS_LOCATION.DCCODE = ST_STOCK.DCCODE
		   AND MS_LOCATION.LOC    = ST_STOCK.LOC
		<if test="fromzone != null and fromzone != ''">
		   AND MS_LOCATION.ZONE <![CDATA[>=]]> #{fromzone}
		</if>
		<if test="tozone != null and tozone != ''">
		   AND MS_LOCATION.ZONE <![CDATA[<=]]> #{tozone}
		</if>
		  JOIN ST_SNINFO ST_SERIALINFO
		    ON ST_STOCK.STORERKEY = ST_SERIALINFO.STORERKEY
		   AND ST_STOCK.SKU       = ST_SERIALINFO.SKU
		   AND ST_STOCK.STOCKID   = ST_SERIALINFO.STOCKID
		<if test="serialno != null and serialno != ''">
		   AND ST_SERIALINFO.SERIALNO LIKE #{serialno}
		</if>
		 WHERE 1=1
		<if test="gStorerkey != null and gStorerkey != ''"> 
           AND ST_STOCK.STORERKEY            =  #{gStorerkey}   
		</if>
		<if test="fixdccode != null and fixdccode != ''">   
           AND ST_STOCK.DCCODE               =  #{fixdccode}   
		</if>		 
		   AND (ST_STOCK.QTY <![CDATA[>]]> 0 OR ST_STOCK.BOXQTY <![CDATA[>]]> 0)
		<if test="fromloc != null and fromloc != ''">
		   AND ST_STOCK.LOC <![CDATA[>=]]> #{fromloc}
		</if>
		<if test="toloc != null and toloc != ''">
		   AND ST_STOCK.LOC <![CDATA[<=]]> #{toloc}
		</if>
		 ORDER BY ST_STOCK.DCCODE
		        , ST_STOCK.ORGANIZE
		        , ST_STOCK.SKU
		    </select>
    
</mapper>