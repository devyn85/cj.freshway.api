<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="rolesMappingUsersService">
	<select id="getRolesMappingUserList" resultType="RolesMappingUsersGetResDto">
        SELECT /* [rolesMappingUsersService.sqlx][getRolesMappingUserList][권한그룹별 사용자 조회] */
	            A.USER_NM,
	            A.EMP_NO,
	            A.USER_ID,
	            (CASE WHEN D.AUTHORITY IS NULL THEN '0' ELSE '1' END) AS INCLUDE,
	            D.REG_ID,
	            TO_CHAR(D.REG_DT, 'YYYY-MM-DD') AS REG_DT,
	            #{authority} AS AUTHORITY
	      FROM  TB_CF_USERS A
	            LEFT OUTER JOIN TB_CF_AUTH D
	            	ON D.USER_ID = A.USER_ID 
	            	AND D.AUTHORITY = #{authority}
	      WHERE  A.USER_ENABLE  = '1'
          <if test='include == "1"'>
		  AND D.AUTHORITY IS NOT NULL
		  </if>   
		  <if test='userNm != null and userNm !=""'>
		  AND A.USER_NM LIKE '%'||#{userNm}||'%'
		  </if>
		  ORDER BY A.USER_NM
    </select>
   
	<insert id="insertRolesMappingUsers">
        INSERT /* [rolesMappingUsersService.sqlx][insertRolesMappingUsers][20180306][CJ Developer.] */
        INTO	TB_CF_AUTH (
        		USER_ID,
				AUTHORITY,
				REG_ID,
                REG_DT
        )
        VALUES (
        		#{userId},
				#{authority},
				#{regId},
                sysdate
        )
    </insert>
    <delete id="deleteRolesMappingAllUsers">
        DELETE /* [rolesMappingUsersService.sqlx][deleteRolesMappingAllUsers][20180306][CJ Developer.] */
        FROM	TB_CF_AUTH
        WHERE	AUTHORITY	=	#{authority}
    </delete>
    <delete id="deleteRolesMappingUsers">
        DELETE /* [rolesMappingUsersService.sqlx][deleteRolesMappingUsers][20180306][CJ Developer.] */
        FROM	TB_CF_AUTH
        WHERE	AUTHORITY	=	#{authority}
        AND		USER_ID		=	#{userId}
    </delete>
    
    <insert id="insertRolesMappingUsersLog">
        INSERT /* [rolesMappingUsersService.sqlx][insertRolesMappingUsersLog] */
        INTO	TB_CF_AUTH_CHG_LOG (
        		USER_ID,
				AUTHORITY,
				CONTENT,
				REG_ID,
                REG_DT
        )
        VALUES (
        		#{userId},
				#{authority},
				#{content},
				#{regId},
                sysdate
        )
    </insert>
</mapper>