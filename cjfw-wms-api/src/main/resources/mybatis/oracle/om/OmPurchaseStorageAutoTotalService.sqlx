<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="omPurchaseStorageAutoTotalService">
	<select id="getMasterList" resultType="OmPurchaseStorageAutoTotalResDto">
	    /* [omPurchaseStorageAutoTotalService.sqlx][omPurchaseStorageAutoTotalService.getMasterList] */
	    WITH T_ST_STOCK_PURCHASE AS ( /* 2026.01.30 CJ프레시웨이 WMS 구축  추가(ST_STOCK->VW_ST_STOCK, ST_STOCK_PURCHASE->T_ST_STOCK_PURCHASE) */
			SELECT ST_STOCK.DCCODE       AS  DCCODE
			    ,ST_STOCK.STORERKEY    AS  STORERKEY
			    ,ST_STOCK.ORGANIZE     AS  ORGANIZE
			    ,ST_STOCK.AREA         AS  AREA
			    ,ST_STOCK.SKU          AS  SKU
			    ,MAX(MS_SKU.DESCRIPTION)    AS  DESCRIPTION
			    ,ST_STOCK.UOM          AS  UOM
			    ,SUM(ST_STOCK.QTY)     AS  QTY
			    ,SUM(ST_STOCK.BOXQTY)  AS  BOXQTY
			    ,SUM(CASE WHEN (ST_STOCK.QTY-ST_STOCK.QTYALLOCATED-ST_STOCK.QTYPICKED)  <![CDATA[<]]>  0  THEN 0
			        ELSE ST_STOCK.QTY-ST_STOCK.QTYALLOCATED-ST_STOCK.QTYPICKED
			       END ) as OPENQTY
			    ,MAX(MS_LOCATION.PLT_FLG) AS PLT_FLG
			FROM   VW_ST_STOCK ST_STOCK
			JOIN   MS_SKU
			ON     MS_SKU.STORERKEY        = ST_STOCK.STORERKEY
			AND    MS_SKU.SKU              = ST_STOCK.SKU
			JOIN   MS_LOCATION
			ON     MS_LOCATION.DCCODE      = ST_STOCK.DCCODE
			AND    MS_LOCATION.LOC         = ST_STOCK.LOC
			AND    MS_LOCATION.LOCTYPE     IN ('STAGE','PICK','KEEP','CROSS','FIRSTOUT','LONGSTAY','CANCEL')
			AND    ((MS_LOCATION.LOCCATEGORY IN ('RACK','YARD') AND ST_STOCK.DCCODE NOT IN ('2690','2620')) OR (MS_LOCATION.LOCCATEGORY IN ('RACK','YARD','AUTO') AND ST_STOCK.DCCODE IN ('2690','2620')))
			AND    MS_LOCATION.LOCFLAG     = 'GOOD'
			AND    CASE WHEN MS_LOCATION.DCCODE = '2690' AND MS_LOCATION.LOCTYPE='STAGE' THEN 'Y'
			      WHEN MS_LOCATION.DCCODE = '2600' AND MS_LOCATION.LOCTYPE='STAGE' THEN 'Y'
			      ELSE MS_LOCATION.OUT_YN
			    END = 'Y'
			AND    MS_LOCATION.DEL_YN      = 'N'
			AND    MS_LOCATION.STOCKTYPE   = 'GOOD'
			JOIN   CM_LOT
			ON     CM_LOT.STORERKEY        = ST_STOCK.STORERKEY
			AND    CM_LOT.LOT              = ST_STOCK.LOT
			AND    'TRUE' = CASE
			           WHEN CM_LOT.LOTTABLE01   = 'STD' OR  MS_SKU.DURATIONTYPE = 'N'
			           THEN 'TRUE'
			           WHEN     MS_SKU.DURATIONTYPE = '1' AND FN_ISDATE(CM_LOT.LOTTABLE01) = 1
			              AND TO_DATE(CM_LOT.LOTTABLE01,'YYYYMMDD')  <![CDATA[<]]>  TRUNC(SYSDATE)
			           THEN 'FALSE'
			           WHEN     MS_SKU.DURATIONTYPE IN ('2','3') AND FN_ISDATE(CM_LOT.LOTTABLE01) = 1
			              AND TO_DATE(CM_LOT.LOTTABLE01,'YYYYMMDD') + MS_SKU.DURATION - 1  <![CDATA[<]]>  TRUNC(SYSDATE)
			           THEN 'FALSE'
			           ELSE 'TRUE'
			        END
			WHERE 1=1
			AND ST_STOCK.STOCKGRADE = 'STD'  
			    GROUP BY ST_STOCK.DCCODE
			        ,ST_STOCK.STORERKEY
			        ,ST_STOCK.ORGANIZE
			        ,ST_STOCK.AREA
			        ,ST_STOCK.SKU
			        ,ST_STOCK.UOM
		),
		ST_STOCK_SUMMARY AS (
		    SELECT 
		        ST_STOCK.STORERKEY
		        , ST_STOCK.DCCODE
		        , ST_STOCK.SKU
		        , MIN(CM_LOT.LOTTABLE01) AS MIN_LOTTABLE01
		        , MIN(FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'N') || '/' || MS_SKU.DURATION) AS DURATION_TERM
		        , SUM(ST_STOCK.QTYPICKED) AS QTYPICKED_SUM
		    FROM VW_ST_STOCK ST_STOCK
		    JOIN MS_SKU ON MS_SKU.STORERKEY = ST_STOCK.STORERKEY AND MS_SKU.SKU = ST_STOCK.SKU
		    JOIN MS_LOCATION ON MS_LOCATION.DCCODE = ST_STOCK.DCCODE AND MS_LOCATION.LOC = ST_STOCK.LOC
		    JOIN CM_LOT ON CM_LOT.STORERKEY = ST_STOCK.STORERKEY AND CM_LOT.LOT = ST_STOCK.LOT
		    WHERE MS_LOCATION.LOCTYPE IN ('STAGE','PICK','KEEP','CROSS','FIRSTOUT','LONGSTAY','CANCEL')
		      AND ((MS_LOCATION.LOCCATEGORY IN ('RACK','YARD') AND ST_STOCK.DCCODE NOT IN ('2690','2620')) 
		           OR (MS_LOCATION.LOCCATEGORY IN ('RACK','YARD','AUTO') AND ST_STOCK.DCCODE IN ('2690','2620')))
		      AND MS_LOCATION.LOCFLAG = 'GOOD'
		      AND MS_LOCATION.DEL_YN = 'N'
		      AND MS_LOCATION.STOCKTYPE = 'GOOD'
		      AND ST_STOCK.STOCKGRADE = 'STD'
		      AND 'TRUE' = CASE
		                WHEN CM_LOT.LOTTABLE01 = 'STD' OR MS_SKU.DURATIONTYPE = 'N' THEN 'FALSE'
		                WHEN MS_SKU.DURATIONTYPE = '1' AND FN_ISDATE(CM_LOT.LOTTABLE01) = 1 AND TO_DATE(CM_LOT.LOTTABLE01, 'YYYYMMDD') <![CDATA[<]]> TRUNC(SYSDATE) THEN 'FALSE'
		                WHEN MS_SKU.DURATIONTYPE IN ('2', '3') AND FN_ISDATE(CM_LOT.LOTTABLE01) = 1 AND TO_DATE(CM_LOT.LOTTABLE01, 'YYYYMMDD') + MS_SKU.DURATION - 1 <![CDATA[<]]> TRUNC(SYSDATE) THEN 'FALSE'
		                ELSE 'TRUE'
		            END
		    GROUP BY ST_STOCK.STORERKEY, ST_STOCK.DCCODE, ST_STOCK.SKU
		),
	    BASE AS (
	        SELECT K.CUSTKEY
	             , K.CUSTNAME
	             , K.ROUTE
	             , K.ROUTEORGANIZE
	             , K.ROUTEORGANIZENM
	             , K.DCCODE
	             , K.DCNAME
	             , K.ORGANIZE
	             , K.ORGANIZENAME
	             , K.SKU
	             , K.SKUNAME
	             , K.DELIVERYTYPE
	             , K.VAL_FN_GETDAYCOUNT
	             , K.BUYERKEY
	             , K.CONTROLTYPE
	             , CASE WHEN TO_CHAR(SYSDATE,'YYYYMMDD') <![CDATA[<]]> K.CONTROL_TODATE AND K.CONTROL_FROMDATE IS NOT NULL AND K.CONTROL_FROMDATE <![CDATA[<=]]> K.CONTROL_TODATE THEN K.CONTROL_FROMDATE
	                    ELSE NULL
	               END AS CONTROL_FROMDATE
	             , CASE WHEN TO_CHAR(SYSDATE,'YYYYMMDD') <![CDATA[<]]> K.CONTROL_TODATE AND K.CONTROL_TODATE IS NOT NULL AND K.CONTROL_FROMDATE <![CDATA[<=]]> K.CONTROL_TODATE THEN K.CONTROL_TODATE
	                    ELSE NULL
	               END AS CONTROL_TODATE
	             , K.QTY
	             , K.SHIPQTY
	             , K.VENDORCONFIRMQTY
	             , K.RECEIVEQTY
	             , K.AFRECEIVEQTY
	             , K.ETC_QTY1
	             , K.ETC_QTY2
	             , K.ETC_QTY3
	             , K.STOCKQTY
	             , K.BOXQTY
	             , K.STOCKQTY_DISP
	             , K.REORDERPOINT
	             , K.STOCKGOAL
	             , K.UOM
	             , K.STOCKAVGDAY
	             , K.MAXSTOCK
	             , K.SHIPDAY1W
	             , K.SHIPDAY2W
	             , K.SHIPDAY3W
	             , K.SHIPQTYCHG1W
	             , K.SHIPQTYCHG2W
	             , K.SHIPQTYCHG3W
	             , K.SHIPQTY1W
	             , K.SHIPQTY2W
	             , K.SHIPQTY3W
	             , K.ORDCNT1W
	             , K.ORDCNT2W
	             , K.ORDCNT3W
	             , K.PURCHASEUOM
	             , K.BOXPERQTY
	             , K.DURATION
	             , K.REFERENCE01
	             , K.REFERENCE02
	             , K.REFERENCE03
	             , K.REFERENCE06
	             , K.EXECDAY
	             , K.AUTO_EXECDAY
	             , K.STD_DT
	             , K.PURCHASETYPE
	             , K.PLANT
	             , K.STORAGETYPE
	             , K.STORAGETYPENM
	             , K.PURCHASEGROUP
	             , K.MINORDERQTY
	             , K.LAYERPERPLT
	             , K.BOXPERLAYER
	             , K.COEFFICIENTSAFETY
	             , K.LEADTIME
	             , K.PURINTERVAL
	             , K.DELIVERYWEEK
	             , K.RETURNTYPE
	             , K.SERIALKEY
	             , K.STORERKEY
	             , K.CUSTTYPE
	             , K.CUSTTYPENM
	             , K.AREA
	             , K.CHANNEL
	             , K.BUNJA
	             , K.BUNMO
	             , K.PALLETUNIT
	             , K.PODT
	             , K.FROM_DCCODE
	             , K.FROM_ORGANIZE
	             , K.EMPTYFIELD
	             , K.STD
	             , K.ZERO
	             , K.CHANNELNM
	             , K.SERIALYN
	             , K.LINE01
	             , K.LINE02
	             , K.BUNJA_CAL
	             , K.BUNMO_CAL
	             , K.REFERENCE04
	             , K.ADDWHO
	             , K.ADDDATE
	             , K.EDITWHO
	             , K.EDITDATE
	             <!-- , K.STOCKQTY_CONTRACT
	             , K.STOCKQTY_OUTDISP -->
	             , K.STOCKDAY
	             , K.PSBQTY
	             , K.PSBQTY2
	             , K.RECEIVEDT
	             , K.RECEIVEDT2
	             , K.POUNIT
	             , K.ORDEREDQTY
	             , CASE WHEN K.REORDERPOINT <![CDATA[>]]> ((K.PSBQTY + K.AFRECEIVEQTY) + K.RECEIVEQTY) THEN
	                   1
	               ELSE
	                   0
	               END AS DUMCOMPANY <!-- 덤발주 대상 업체 확인을 위해 화면상에서 업체별 합계가 0보다 클경우 덤발주 대상 업체임 -->
	             , CASE WHEN ((K.REORDERPOINT <![CDATA[<]]> (K.PSBQTY + K.AFRECEIVEQTY)) AND ((K.STOCKGOAL - K.REORDERPOINT) * 0.5 + K.REORDERPOINT <![CDATA[>]]> (K.PSBQTY + K.AFRECEIVEQTY))) THEN
	                   'Y'
	               ELSE
	                   'N'
	               END AS DUMYN <!-- 덤발주 대상 상품 여부 확인 [(목표재고-재발주점)*0.5+재발주점 > 가용재고]  -->
	             , (K.STOCKGOAL - K.REORDERPOINT) DUMQTY <!-- 덤발주 수량 [목표재고-가용재고]  -->
	             , CASE WHEN NVL(K.VENDORCONFIRMQTY, 0) = 0 AND NVL(K.ORDEREDQTY, 0) = 0 THEN ''
	                    WHEN NVL(K.VENDORCONFIRMQTY, 0) != 0 AND NVL(K.ORDEREDQTY, 0) = 0 THEN 'icon_bbs03'
	                    WHEN ceil(NVL(K.VENDORCONFIRMQTY, 0) / NVL(K.ORDEREDQTY, 0) * 100) <![CDATA[<]]> 80 THEN 'icon_bbs01'
	                    ELSE 'icon_bbs03'
	               END AS VENDORCONFIRM_STATUS
	             , CASE K.PURCHASETYPE <!-- 발주구분에 따른 산출량 조정 20150824 김영문님 요청 -->
	                   WHEN 'STO-ADD' THEN 0
	                   ELSE CEIL(CASE WHEN SUM(CASE WHEN K.REORDERPOINT - (K.PSBQTY + K.AFRECEIVEQTY) <![CDATA[>]]> 0 THEN 1 ELSE 0 END) OVER (PARTITION BY K.CUSTKEY, K.CUSTTYPE) <![CDATA[>]]> 0 THEN
	                       CASE WHEN K.REORDERPOINT <![CDATA[>]]> (K.PSBQTY + K.AFRECEIVEQTY) THEN
	                           CASE WHEN K.STOCKGOAL - (K.PSBQTY + K.AFRECEIVEQTY) <![CDATA[>]]> K.MINORDERQTY * K.BOXPERQTY THEN
	                               K.STOCKGOAL - (K.PSBQTY + K.AFRECEIVEQTY)
	                           ELSE K.MINORDERQTY * K.POUNIT
	                           END
	                       ELSE
	                           CASE WHEN ((K.REORDERPOINT <![CDATA[<]]> (K.PSBQTY + K.AFRECEIVEQTY)) AND ((K.STOCKGOAL - K.REORDERPOINT) * 0.5 + K.REORDERPOINT <![CDATA[>]]> (K.PSBQTY + K.AFRECEIVEQTY))) THEN
	                               (K.STOCKGOAL - (K.PSBQTY + K.AFRECEIVEQTY))
	                           ELSE
	                               0
	                           END
	                       END
	                   ELSE
	                       0
	                   END / (K.POUNIT))
	               END AS CONFIRMQTY_ADD <!-- 최종 발주산출량 -->
	             , CASE WHEN K.EXHAUSTION_STOP_YN = 'Y' THEN 0
	                    ELSE
	                        CASE K.PURCHASETYPE 
	                            WHEN 'STO-ADD' THEN 0
	                            ELSE CEIL(CASE WHEN SUM(CASE WHEN K.REORDERPOINT - (K.PSBQTY2 + K.AFRECEIVEQTY) <![CDATA[>]]> 0 THEN 1 ELSE 0 END) OVER (PARTITION BY K.CUSTKEY, K.CUSTTYPE) <![CDATA[>]]> 0 THEN
	                                CASE WHEN K.REORDERPOINT <![CDATA[>]]> (K.PSBQTY2 + K.AFRECEIVEQTY) THEN
	                                    CASE WHEN K.STOCKGOAL - (K.PSBQTY2 + K.AFRECEIVEQTY) <![CDATA[>]]> K.MINORDERQTY * K.BOXPERQTY THEN
	                                        NVL((K.MINORDERQTY * K.BOXPERQTY) + (CEIL((K.STOCKGOAL - (K.MINORDERQTY * K.BOXPERQTY) - (K.PSBQTY2 + K.AFRECEIVEQTY)) / DECODE(K.ORDERQTY_UNIT, 0, 1, NULL, 1, K.ORDERQTY_UNIT)) * DECODE(K.ORDERQTY_UNIT, 0, 1, NULL, 1, K.ORDERQTY_UNIT)), 0)
	                                    ELSE K.MINORDERQTY * K.POUNIT
	                                    END
	                                ELSE
	                                    CASE WHEN ((K.REORDERPOINT <![CDATA[<]]> (K.PSBQTY2 + K.AFRECEIVEQTY)) AND ((K.STOCKGOAL - K.REORDERPOINT) * 0.5 + K.REORDERPOINT <![CDATA[>]]> (K.PSBQTY2 + K.AFRECEIVEQTY))) THEN
	                                        NVL((K.MINORDERQTY * K.BOXPERQTY) + (CEIL((K.STOCKGOAL - (K.MINORDERQTY * K.BOXPERQTY) - (K.PSBQTY2 + K.AFRECEIVEQTY)) / DECODE(K.ORDERQTY_UNIT, 0, 1, NULL, 1, K.ORDERQTY_UNIT)) * DECODE(K.ORDERQTY_UNIT, 0, 1, NULL, 1, K.ORDERQTY_UNIT)), 0)
	                                    ELSE 0
	                                    END
	                                END
	                            ELSE
	                                0
	                            END / (K.POUNIT))
	                        END
	                END AS CONFIRMQTY <!-- 최종 발주산출량 -->
	             , K.CONFIRMQTY_EDIT_YN
	             , (SELECT FN_CONV_UOM(K.STORERKEY, K.SKU, K.PURCHASEUOM, 'EA', 1) FROM DUAL) AS EA_CAL
	             , (SELECT FN_CONV_UOM(K.STORERKEY, K.SKU, K.PURCHASEUOM, 'KG', 1) FROM DUAL) AS KG_CAL
	             , (SELECT FN_CONV_UOM(K.STORERKEY, K.SKU, K.PURCHASEUOM, 'BOX', 1) FROM DUAL) AS BOX_CAL
	             , K.RECEIVEDT AS RECEIVEDT_CAL
	             , CASE WHEN TO_NUMBER(NVL(K.LINE02, 0)) != 0
	                    AND K.CUSTKEY = '2170'
	                    AND NVL(K.LINE01, 'N') LIKE 'Y%' THEN TO_NUMBER(NVL(K.LINE02, 0))
	                    ELSE 0
	               END AS AVGWEIGHT
	             , 0 AS CALBOX
	             , 0 AS REALORDERBOX
	             , 0 AS REALCFMBOX
	             , 0 AS TRANBOX
	             , 0 AS EA
	             , 0 AS KG
	             , 0 AS BOX
	             , 'N' AS BOXFLAG
	             , K.MON_YN, K.TUE_YN, K.WED_YN, K.THU_YN, K.FRI_YN, K.SAT_YN, K.SUN_YN
	             , K.STOP_STATUS
	             , K.STOP_INFO
	             , K.ORD1DAY, K.ORD2DAY, K.ORD3DAY, K.ORD4DAY, K.ORD5DAY, K.ORD6DAY, K.ORD7DAY
	             , K.ORD8DAY, K.ORD9DAY, K.ORD10DAY, K.ORD11DAY, K.ORD12DAY, K.ORD13DAY, K.ORD14DAY
	             , K.ORDERQTY_UNIT
	             , K.QTYPICKED
	             , K.MOVE_CONFIRMQTY
	             , (K.PSBQTY2 + K.MOVE_CONFIRMQTY) AS FUSIBILITYQTY
	             , (K.STOCKQTY_DISP - K.QTY) AS FUSIBILITYQTY2
	             , ROUND(K.CONFIRMQTY1WEEK, 2) AS CONFIRMQTY1WEEK
	             , ROUND(K.CONFIRMQTY2WEEK, 2) AS CONFIRMQTY2WEEK
	             , ROUND(K.CONFIRMQTY3WEEK, 2) AS CONFIRMQTY3WEEK
	             , ROUND(K.CONFIRMQTY4WEEK, 2) AS CONFIRMQTY4WEEK
	             , K.LABEL
	             , ROUND(K.CONFIRMQTY1MONTH, 2) AS CONFIRMQTY1MONTH
	             , ROUND(K.CONFIRMQTY1MONTHAVG, 2) AS CONFIRMQTY1MONTHAVG
	             , CASE WHEN K.STOCKAVGDAY = 0 OR K.CONFIRMQTY1MONTHAVG = 0 THEN ''
	                    WHEN (K.CONFIRMQTY1MONTHAVG / K.STOCKAVGDAY) * 100 <![CDATA[>=]]> 150 THEN 'icon_bbs01'
	                    WHEN (K.CONFIRMQTY1MONTHAVG / K.STOCKAVGDAY) * 100 <![CDATA[<=]]> 50 THEN 'icon_bbs02'
	                    ELSE 'icon_bbs03'
	               END AS CONFIRMQTYCHECK
	             , K.BOXPERPLT
	             , TO_NUMBER(K.MOQ_SKU) AS MOQ_SKU
	             , K.LEADTIME2
	             , NVL(K.BOXPERPLT_QTY, 0) AS BOXPERPLT_QTY
	             , K.DURATION_TERM
	             , K.TPL_SKUGROUP
	             , K.EMPNAME1, K.EMPNAME2, K.EMPNAME3, K.EMPNAME4, K.EMPNAME5
	             , K.EMPPHONE1, K.EMPPHONE2, K.EMPPHONE3, K.EMPPHONE4, K.EMPPHONE5
	             , K.SLAVE_CUSTKEY
	             , K.SLAVE_CUSTNAME
	             , K.EXHAUSTION_STOP_YN
	             , K.STOCKSAFETY2
	             , K.STOCKDAY2
	             , K.PRE_OPENQTY
	             , K.CUSTSKU
	             , K.REFERENCE07
	             , K.BIZDATE
	             , CASE WHEN DATEDIFF <![CDATA[>=]]> 20 THEN K.BIZDATE * K.STOCKAVGDAY
	                    WHEN DATEDIFF = 1 THEN CASE WHEN (K.AFTERDAYWDQTY01 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY01 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 2 THEN CASE WHEN (K.AFTERDAYWDQTY02 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY02 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 3 THEN CASE WHEN (K.AFTERDAYWDQTY03 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY03 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 4 THEN CASE WHEN (K.AFTERDAYWDQTY04 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY04 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 5 THEN CASE WHEN (K.AFTERDAYWDQTY05 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY05 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 6 THEN CASE WHEN (K.AFTERDAYWDQTY06 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY06 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 7 THEN CASE WHEN (K.AFTERDAYWDQTY07 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY07 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 8 THEN CASE WHEN (K.AFTERDAYWDQTY08 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY08 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 9 THEN CASE WHEN (K.AFTERDAYWDQTY09 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY09 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 10 THEN CASE WHEN (K.AFTERDAYWDQTY10 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY10 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 11 THEN CASE WHEN (K.AFTERDAYWDQTY11 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY11 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 12 THEN CASE WHEN (K.AFTERDAYWDQTY12 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY12 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 13 THEN CASE WHEN (K.AFTERDAYWDQTY13 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY13 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 14 THEN CASE WHEN (K.AFTERDAYWDQTY14 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY14 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 15 THEN CASE WHEN (K.AFTERDAYWDQTY15 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY15 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 16 THEN CASE WHEN (K.AFTERDAYWDQTY16 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY16 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 17 THEN CASE WHEN (K.AFTERDAYWDQTY17 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY17 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 18 THEN CASE WHEN (K.AFTERDAYWDQTY18 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY18 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 19 THEN CASE WHEN (K.AFTERDAYWDQTY19 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY19 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                END AS DATEDIFF_QTY
	             , K.AFTERDAYWDQTY01, K.AFTERDAYWDQTY02, K.AFTERDAYWDQTY03, K.AFTERDAYWDQTY04, K.AFTERDAYWDQTY05
	             , K.AFTERDAYWDQTY06, K.AFTERDAYWDQTY07, K.AFTERDAYWDQTY08, K.AFTERDAYWDQTY09, K.AFTERDAYWDQTY10
	             , K.AFTERDAYWDQTY11, K.AFTERDAYWDQTY12, K.AFTERDAYWDQTY13, K.AFTERDAYWDQTY14, K.AFTERDAYWDQTY15
	             , K.AFTERDAYWDQTY16, K.AFTERDAYWDQTY17, K.AFTERDAYWDQTY18, K.AFTERDAYWDQTY19, K.AFTERDAYWDQTY20
	             , K.DIRECTDLV_CUSTKEY, K.DIRECTDLV_ORDERQTY, K.DIRECTDLV_UOM, K.DIRECTDLV_FROM_DCCODE
	             , K.EXCPT_DP_APPR_YN, K.PLTTRANS
	             , (K.REORDERPOINT - (K.PSBQTY + K.RECEIVEQTY)) AS NEAR_ROP
		         , CASE WHEN K.EXHAUSTION_STOP_YN = 'Y' THEN 0
		           ELSE
		             CASE K.PURCHASETYPE 
		                 WHEN 'STO-ADD' THEN 0   
		                 ELSE CEIL(CASE WHEN SUM(CASE WHEN K.REORDERPOINT - (K.PSBQTY2+K.AFRECEIVEQTY) <![CDATA[>]]> 0 THEN 1 ELSE 0 END) OVER (PARTITION BY K.CUSTKEY,K.CUSTTYPE) <![CDATA[>]]> 0 THEN 
		                               CASE WHEN K.REORDERPOINT <![CDATA[>]]> (K.PSBQTY2+K.AFRECEIVEQTY) THEN
		                                        CASE WHEN K.STOCKGOAL - (K.PSBQTY2+K.AFRECEIVEQTY) <![CDATA[>]]> K.MINORDERQTY * K.BOXPERQTY THEN
		                                             NVL((K.MINORDERQTY * K.BOXPERQTY) + (CEIL(( K.STOCKGOAL - (K.MINORDERQTY * K.BOXPERQTY) - (K.PSBQTY2+K.AFRECEIVEQTY)) / DECODE(K.ORDERQTY_UNIT,0,1,NULL,1,K.ORDERQTY_UNIT)) * DECODE(K.ORDERQTY_UNIT,0,1,NULL,1,K.ORDERQTY_UNIT)),0)
		                                        ELSE K.MINORDERQTY * K.POUNIT
		                                        END
		                                   ELSE
		                                        CASE WHEN ((K.REORDERPOINT <![CDATA[<]]> (K.PSBQTY2+K.AFRECEIVEQTY)) AND ((K.STOCKGOAL - K.REORDERPOINT)* 0.5 + K.REORDERPOINT <![CDATA[>]]> (K.PSBQTY2 + K.AFRECEIVEQTY))) THEN
		                                             NVL((K.MINORDERQTY * K.BOXPERQTY) + (CEIL(( K.STOCKGOAL - (K.MINORDERQTY * K.BOXPERQTY) - (K.PSBQTY2+K.AFRECEIVEQTY)) / DECODE(K.ORDERQTY_UNIT,0,1,NULL,1,K.ORDERQTY_UNIT)) * DECODE(K.ORDERQTY_UNIT,0,1,NULL,1,K.ORDERQTY_UNIT)),0)
		                                             ELSE 0
		                                          END
		                                   END
		                          ELSE 
		                                0 
		                           END /(K.POUNIT)) 
		             END 
		           END AS BASE_ORDERQTY
		          , NVL(K.MOQ_VENDER_PLT, K.MOQ_VENDER / K.PALLETUNIT) AS MOQ
		          , K.MOQ_SKU_PLT, K.MOQ_VENDER, K.MOQ_VENDER_PLT
	          FROM (SELECT /*+ NO_MERGE(SS) PUSH_PRED(DP_PURCHASE) PUSH_PRED(DMD) */
	                       SS.*
	                     , CASE WHEN NVL(SS.STOCKAVGDAY, 0) = 0 THEN 0
	                            ELSE ROUND(SS.STOCKQTY / SS.STOCKAVGDAY)
	                       END AS STOCKDAY
	                     , SS.STOCKQTY + SS.RECEIVEQTY - SS.QTY AS PSBQTY
	                     , SS.STOCKQTY_DISP + SS.RECEIVEQTY - SS.QTY AS PSBQTY2
	                     , CASE WHEN SS.PURCHASETYPE IN ('STO', 'STO-ADD', 'STO-AUTO') THEN TO_CHAR(SYSDATE + 1, 'YYYYMMDD')
	                            ELSE FN_CONV_RECEIVEDT(SYSDATE, NVL(SS.LEADTIME, 1) + SS.VAL_FN_GETDAYCOUNT, SS.SUN_YN, SS.MON_YN, SS.TUE_YN, SS.WED_YN, SS.THU_YN, SS.FRI_YN, SS.SAT_YN)
	                       END AS RECEIVEDT
	                     , CASE WHEN SS.PURCHASETYPE IN ('STO', 'STO-ADD', 'STO-AUTO') THEN TO_CHAR(SYSDATE + 1, 'YYYYMMDD')
	                            ELSE FN_CONV_RECEIVEDT(SYSDATE, NVL(SS.LEADTIME, 1) + SS.VAL_FN_GETDAYCOUNT2, SS.SUN_YN, SS.MON_YN, SS.TUE_YN, SS.WED_YN, SS.THU_YN, SS.FRI_YN, SS.SAT_YN)
	                       END AS RECEIVEDT2
	                     , TO_DATE(CASE WHEN SS.PURCHASETYPE IN ('STO', 'STO-ADD', 'STO-AUTO') THEN TO_CHAR(SYSDATE + 1, 'YYYYMMDD')
	                                   ELSE FN_CONV_RECEIVEDT(SYSDATE, NVL(SS.LEADTIME, 1) + SS.VAL_FN_GETDAYCOUNT, SS.SUN_YN, SS.MON_YN, SS.TUE_YN, SS.WED_YN, SS.THU_YN, SS.FRI_YN, SS.SAT_YN)
	                               END, 'YYYYMMDD') - TRUNC(SYSDATE) AS DATEDIFF
	                     , CASE WHEN SS.PURCHASETYPE IN ('STO', 'STO-ADD', 'STO-AUTO') THEN '1' - FN_GETDAYCOUNT(TO_CHAR(SYSDATE, 'YYYYMMDD'), TO_CHAR(SYSDATE + 1, 'YYYYMMDD'), '1')
	                            ELSE (TO_DATE(FN_CONV_RECEIVEDT(SYSDATE, NVL(SS.LEADTIME, 1) + SS.VAL_FN_GETDAYCOUNT, SS.SUN_YN, SS.MON_YN, SS.TUE_YN, SS.WED_YN, SS.THU_YN, SS.FRI_YN, SS.SAT_YN), 'YYYYMMDD') - TRUNC(SYSDATE)) - FN_GETDAYCOUNT(TO_CHAR(SYSDATE, 'YYYYMMDD'), FN_CONV_RECEIVEDT(SYSDATE, NVL(SS.LEADTIME, 1) + SS.VAL_FN_GETDAYCOUNT, SS.SUN_YN, SS.MON_YN, SS.TUE_YN, SS.WED_YN, SS.THU_YN, SS.FRI_YN, SS.SAT_YN), '1')
	                       END AS BIZDATE
	                     , SS.BUNJA / SS.BUNMO AS POUNIT
	                     , (SELECT SUM(DP_PURCHASE.ORDERQTY)
	                          FROM DP_PURCHASE
	                         WHERE DP_PURCHASE.STORERKEY = SS.STORERKEY AND DP_PURCHASE.DCCODE = SS.DCCODE AND DP_PURCHASE.ORGANIZE = SS.ORGANIZE
	                           AND DP_PURCHASE.AREA = SS.AREA AND DP_PURCHASE.SKU = SS.SKU
	                           AND DP_PURCHASE.REQUESTDT <![CDATA[>=]]> TO_CHAR(SYSDATE, 'YYYYMMDD') <!-- 당일이후 입고되는 발주 수량 모든 총수량 나오도록 수정 요청 함일수님 20151030 -->
	                           AND DP_PURCHASE.CUSTKEY = SS.CUSTKEY AND DP_PURCHASE.CUSTTYPE = SS.CUSTTYPE AND DP_PURCHASE.DEL_YN = 'N') AS ORDEREDQTY
	                     , (SS.CONFIRMQTY1WEEK + SS.CONFIRMQTY2WEEK + SS.CONFIRMQTY3WEEK + SS.CONFIRMQTY4WEEK) AS CONFIRMQTY1MONTH
	                     , CASE WHEN (SS.CONFIRMQTY1WEEK + SS.CONFIRMQTY2WEEK + SS.CONFIRMQTY3WEEK + SS.CONFIRMQTY4WEEK) = 0 THEN 0 ELSE ((SS.CONFIRMQTY1WEEK + SS.CONFIRMQTY2WEEK + SS.CONFIRMQTY3WEEK + SS.CONFIRMQTY4WEEK) / 24) END AS CONFIRMQTY1MONTHAVG
	                     , CASE WHEN SS.BUYERKEY_TYPE = 'P' THEN NVL(SS.QTYPICKED_SUM, 0) ELSE 0 END AS QTYPICKED
	                     , CASE WHEN SS.BUYERKEY_TYPE = 'P' THEN
	                           NVL((SELECT SUM((DMD.CONFIRMQTY - (SELECT SUM(DECODE(T.CONFIRMQTY, NULL, DMD.CONFIRMQTY, T.CONFIRMQTY))
	                                FROM DM_DOCUMENT_D T
	                               WHERE T.DELIVERYDATE BETWEEN TO_CHAR(TO_DATE(#{stdDt}, 'YYYYMMDD'), 'YYYYMMDD') AND TO_CHAR(TO_DATE(#{stdDt}, 'YYYYMMDD') + TO_NUMBER('2'), 'YYYYMMDD')
	                                 AND T.DOCNO = DMD.DOCNO AND T.DOCLINE = DMD.DOCLINE AND T.DCCODE != DMD.DCCODE
	                                 AND T.WORKPROCESSCODE = 'STO' AND T.DOCTYPE = 'DP')))
	                                FROM DM_DOCUMENT_D DMD
	                               WHERE DMD.DELIVERYDATE BETWEEN TO_CHAR(TO_DATE(#{stdDt}, 'YYYYMMDD'), 'YYYYMMDD') AND TO_CHAR(TO_DATE(#{stdDt}, 'YYYYMMDD') + TO_NUMBER('2'), 'YYYYMMDD')
	                                 AND DMD.STORERKEY = SS.STORERKEY AND DMD.DCCODE = SS.DCCODE AND DMD.SKU = SS.SKU
	                                 AND DMD.DOCTYPE = 'WD' AND DMD.DEL_YN = 'N' AND DMD.WORKPROCESSCODE = 'STO'), 0)
	                           ELSE 0
	                       END AS MOVE_CONFIRMQTY
	                     , CEIL(SS.STOCKSAFETY2) AS STOCKSAFETY3
	                     , NVL(FLOOR(SS.STOCKSAFETY2 / NULLIF(SS.STOCKAVGDAY, 0)), 0) AS STOCKDAY2
	                     , FLOOR(SS.STOCKAVGDAY + (SS.STOCKSAFETY2 / NULLIF(LEADTIME, 0))) AS PRE_OPENQTY	                     
	                  FROM (
	                        SELECT
	                          CASE WHEN MS_PURCHASECUST.CUSTKEY LIKE '2170-%' THEN '2170' ELSE TO_CHAR(MS_PURCHASECUST.CUSTKEY) END AS CUSTKEY
	                          , CASE WHEN MS_PURCHASECUST.CUSTKEY LIKE '2170-%' THEN '외부창고' ELSE TO_CHAR(MS_CUST.DESCRIPTION) END AS CUSTNAME
	                          , NVL(MS_PURCHASEMST.ROUTE, MS_PURCHASECUST.ROUTE) AS ROUTE
	                          , NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) AS ROUTEORGANIZE
	                          , NVL(DCXORG.DESCRIPTION, DCXORGNVL.DESCRIPTION) AS ROUTEORGANIZENM
	                          , MS_PURCHASECUST.DCCODE, CM_DC.DCNAME
	                          , NVL(MS_PURCHASESTATS.ORGANIZE, '') AS ORGANIZE /* 20260120 MS_PURCHASECUST.DCCODE nvl 제거 */
	                          , CM_DCXORGANIZE.DESCRIPTION AS ORGANIZENAME, MS_PURCHASECUST.SKU, MS_SKU.DESCRIPTION AS SKUNAME
	                          , (SELECT FN_CODEDESCR(MS_PURCHASEMST.STORERKEY, 'DIRECTTYPE', MS_PURCHASEMST.DELIVERYTYPE) FROM DUAL) AS DELIVERYTYPE
	                          , (SELECT FN_GETDAYCOUNT(TO_CHAR(SYSDATE, 'YYYYMMDD'), TO_CHAR(SYSDATE + NVL(MS_PURCHASEMST.LEADTIME, 1), 'YYYYMMDD'), 1) FROM DUAL) AS VAL_FN_GETDAYCOUNT
	                          , (SELECT FN_GETDAYCOUNT(TO_CHAR(SYSDATE, 'YYYYMMDD'), TO_CHAR(SYSDATE + NVL(MS_PURCHASEMST.LEADTIME, 1), 'YYYYMMDD'), 1) 
	                                  + FN_GETDAYCOUNT(TO_CHAR(SYSDATE, 'YYYYMMDD'), TO_CHAR(SYSDATE + NVL(MS_PURCHASEMST.LEADTIME, 1), 'YYYYMMDD'), 7) FROM DUAL) AS VAL_FN_GETDAYCOUNT2
	                          <!-- 입고예정일
					               발주일로부터 리드타임 기간내 일요일은 제외함
					               입고일이 일요일인경우 휴일여부(토요일 가능여부)에 따라 가능인경우 전일인 토요일로 불가인경우 다음날 월요일로 지정
					               입고일이 토요일인경우 휴일여부(토요일 가능여부)에 따라 가능인경우 토요일로  불가인경우 전날인 금요일로 지정
					               EX)리드타임은 최대 15일까지 있음
					           -->
	                          , MS_PURCHASEMST.BUYERKEY <!-- 수급담당 -->
	                          , CASE WHEN MS_PURCHASECUST.CUSTKEY LIKE '2170-%' THEN
	                                    (SELECT FN_CODEDESCR('FW00', 'CONTROLTYPE', MIN(CONTROLTYPE_TB.CONTROLTYPE) KEEP (DENSE_RANK FIRST ORDER BY CONTROLTYPE_TB.FROMDATE DESC, CONTROLTYPE_TB.TODATE ASC))
	                                       FROM MS_PURCHASECUST CONTROLTYPE_TB
	                                      WHERE CONTROLTYPE_TB.DCCODE = '2600' AND CONTROLTYPE_TB.STORERKEY = 'FW00' AND CONTROLTYPE_TB.SKU = MS_PURCHASECUST.SKU
	                                        AND CONTROLTYPE_TB.CUSTTYPE = 'P' AND TO_CHAR(SYSDATE, 'YYYYMMDD') BETWEEN CONTROLTYPE_TB.FROMDATE AND CONTROLTYPE_TB.TODATE AND CONTROLTYPE_TB.DEL_YN = 'N')
	                                 ELSE (SELECT CASE WHEN TO_CHAR(SYSDATE, 'YYYYMMDD') BETWEEN MS_PURCHASECUST.CONTROL_FROMDATE AND MS_PURCHASECUST.CONTROL_TODATE THEN FN_CODEDESCR(MS_PURCHASECUST.STORERKEY, 'CONTROLTYPE', MS_PURCHASECUST.CONTROLTYPE)
	                                                   WHEN TO_CHAR(MS_PURCHASECUST.EDITDATE, 'YYYYMMDD') <![CDATA[<]]> '20210901' THEN (SELECT FN_CODEDESCR(MS_PURCHASECUST.STORERKEY, 'CONTROLTYPE', MS_PURCHASECUST.CONTROLTYPE) FROM DUAL)
	                                                   ELSE NULL
	                                              END FROM DUAL)
	                            END AS CONTROLTYPE
	                          , MS_PURCHASECUST.CONTROL_FROMDATE, MS_PURCHASECUST.CONTROL_TODATE
	                          <!-- , MS_PURCHASECUST.FROMDATE AS CONTROL_FROMDATE
	                          , MS_PURCHASECUST.TODATE AS CONTROL_TODATE -->
	                          , NVL((CASE WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) <![CDATA[<]]> 0 THEN 0
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 0 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY01
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 1 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY02
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 2 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY03
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 3 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY04
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 4 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY05
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 5 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY06
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 6 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY07
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 7 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY08
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 8 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY09
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 9 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY10
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 10 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY11
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 11 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY12
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 12 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY13
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 13 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY14
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 14 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY15
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 15 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY16
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 16 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY17
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 17 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY18
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 18 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY19
	                                     ELSE MS_PURCHASETOTAL.AFTERDAYWDQTY20
	                                END) -
	                               (CASE WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) <![CDATA[<]]> 0 THEN 0
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 0 THEN 0
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 1 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY01
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 2 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY02
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 3 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY03
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 4 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY04
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 5 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY05
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 6 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY06
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 7 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY07
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 8 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY08
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 9 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY09
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 10 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY10
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 11 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY11
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 12 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY12
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 13 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY13
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 14 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY14
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 15 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY15
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 16 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY16
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 17 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY17
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 18 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY18
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 19 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY19
	                                     ELSE MS_PURCHASETOTAL.AFTERDAYWDQTY20
	                                END), 0) AS QTY                                            <!-- 주문량 (C) 산정기간동안의 주문량(기간 : 산정기준일~산정기준일+산정기간) -->
	                          , NVL(MS_PURCHASETOTAL.TODAYWDQTY, 0) AS SHIPQTY                 <!-- 당일출고예정량(C) -->
	                          , NVL(MS_PURCHASETOTAL.VENDORCONFIRMQTY, 0) AS VENDORCONFIRMQTY  <!-- 업체확정량(C) -->
	                          , NVL(MS_PURCHASETOTAL.TODAYDPQTY, 0) AS RECEIVEQTY              <!-- 입고예정(당일)(C) -->
	                          , NVL(MS_PURCHASETOTAL.AFTERDAYDPQTY, 0) AS AFRECEIVEQTY         <!-- 입고예정(당일이후)(C) -->
	                          , NVL(MS_PURCHASETOTAL.ETC_QTY1, 0) AS ETC_QTY1                  <!-- 업체확정량(C) -->
	                          , NVL(MS_PURCHASETOTAL.ETC_QTY2, 0) AS ETC_QTY2                  <!-- 입고예정(당일)(C) -->
	                          , NVL(MS_PURCHASETOTAL.ETC_QTY3, 0) AS ETC_QTY3                  <!-- 입고예정(당일이후)(C) -->
	                          , NVL(CASE WHEN 
	                          <if test='multiDcCode != null and multiDcCode.length > 0'>
							  	(
								<foreach item="item" collection="multiDcCode" separator=" OR ">
									#{item} = '2690'
								</foreach>
								)
							  </if>
	                          AND MS_PURCHASECUST.DCCODE = '1000' THEN 0
	                                 WHEN 
	                                 <if test='multiDcCode != null and multiDcCode.length > 0'>
									  	(
										<foreach item="item" collection="multiDcCode" separator=" OR ">
											#{item} = '2690'
										</foreach>
										)
									 </if>
	                                 THEN STP_ALL.SUM_OPENQTY
	                                 ELSE STP_ALL.SUM_OPENQTY
                                END, 0) AS STOCKQTY
                              , NVL(CASE WHEN 
	                          <if test='multiDcCode != null and multiDcCode.length > 0'>
							  	(
								<foreach item="item" collection="multiDcCode" separator=" OR ">
									#{item} = '2690'
								</foreach>
								)
							  </if>
	                          AND MS_PURCHASECUST.DCCODE = '1000' THEN 0
                                     WHEN 
                                     <if test='multiDcCode != null and multiDcCode.length > 0'>
									  	(
										<foreach item="item" collection="multiDcCode" separator=" OR ">
											#{item} = '2690'
										</foreach>
										)
									 </if>
                                     THEN STP_ALL.SUM_BOXQTY
                                     ELSE STP_ALL.SUM_BOXQTY
                                END, 0) AS BOXQTY
							  , NVL(CASE WHEN 
	                          <if test='multiDcCode != null and multiDcCode.length > 0'>
							  	(
								<foreach item="item" collection="multiDcCode" separator=" OR ">
									#{item} = '2690'
								</foreach>
								)
							  </if>
	                          AND MS_PURCHASECUST.DCCODE = '1000' THEN 0
                                     WHEN 
                                     <if test='multiDcCode != null and multiDcCode.length > 0'>
									  	(
										<foreach item="item" collection="multiDcCode" separator=" OR ">
											#{item} = '2690'
										</foreach>
										)
									 </if>
                                     THEN STP_ALL.SUM_QTY
                                     ELSE STP_ALL.SUM_QTY
                                END, 0) AS STOCKQTY_DISP                                 
	                          <!-- , NVL(CASE WHEN 
	                          <if test='multiDcCode != null and multiDcCode.length > 0'>
							  	(
								<foreach item="item" collection="multiDcCode" separator=" OR ">
									#{item} = '2690'
								</foreach>
								)
							  </if>
	                          AND MS_PURCHASECUST.DCCODE = '1000' THEN 0  20151109 2690센터는 1000센터 재고를 표시하지 않도록 수정(김영문님)
	                                     WHEN 
	                                     <if test='multiDcCode != null and multiDcCode.length > 0'>
										  	(
											<foreach item="item" collection="multiDcCode" separator=" OR ">
												#{item} = '2690'
											</foreach>
											)
										 </if>
	                                     AND NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) IS NOT NULL THEN
	                                        (SELECT SUM(OPENQTY) FROM T_ST_STOCK_PURCHASE WHERE T_ST_STOCK_PURCHASE.STORERKEY = MS_PURCHASECUST.STORERKEY AND T_ST_STOCK_PURCHASE.DCCODE = MS_PURCHASECUST.DCCODE AND T_ST_STOCK_PURCHASE.ORGANIZE = NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) AND T_ST_STOCK_PURCHASE.SKU = MS_PURCHASECUST.SKU)
	                                     ELSE (SELECT SUM(OPENQTY) FROM T_ST_STOCK_PURCHASE WHERE T_ST_STOCK_PURCHASE.STORERKEY = MS_PURCHASECUST.STORERKEY AND T_ST_STOCK_PURCHASE.DCCODE = MS_PURCHASECUST.DCCODE AND T_ST_STOCK_PURCHASE.SKU = MS_PURCHASECUST.SKU)
	                                END, 0) AS STOCKQTY
	                          , NVL(CASE WHEN
				                          <if test='multiDcCode != null and multiDcCode.length > 0'>
										  	(
											<foreach item="item" collection="multiDcCode" separator=" OR ">
												#{item} = '2690'
											</foreach>
											)
										  </if>	                          
	                           AND MS_PURCHASECUST.DCCODE = '1000' THEN 0  20151109 2690센터는 1000센터 재고를 표시하지 않도록 수정(김영문님)
	                                     ELSE (SELECT SUM(BOXQTY) FROM T_ST_STOCK_PURCHASE WHERE T_ST_STOCK_PURCHASE.STORERKEY = MS_PURCHASECUST.STORERKEY AND T_ST_STOCK_PURCHASE.DCCODE = MS_PURCHASECUST.DCCODE AND T_ST_STOCK_PURCHASE.SKU = MS_PURCHASECUST.SKU)
	                                END, 0) AS BOXQTY
	                          , NVL(CASE WHEN
	                          	         <if test='multiDcCode != null and multiDcCode.length > 0'>
										  	(
											<foreach item="item" collection="multiDcCode" separator=" OR ">
												#{item} = '2690'
											</foreach>
											)
										 </if> 
	                          AND MS_PURCHASECUST.DCCODE = '1000' THEN 0  20151109 2690센터는 1000센터 재고를 표시하지 않도록 수정(김영문님)
	                                     WHEN
	                                     <if test='multiDcCode != null and multiDcCode.length > 0'>
										  	(
											<foreach item="item" collection="multiDcCode" separator=" OR ">
												#{item} = '1000'
											</foreach>
											)
										 </if>
	                                     AND NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) IS NOT NULL THEN
	                                        (SELECT SUM(QTY) FROM T_ST_STOCK_PURCHASE WHERE T_ST_STOCK_PURCHASE.STORERKEY = MS_PURCHASECUST.STORERKEY AND T_ST_STOCK_PURCHASE.DCCODE = MS_PURCHASECUST.DCCODE AND T_ST_STOCK_PURCHASE.ORGANIZE = NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) AND T_ST_STOCK_PURCHASE.SKU = MS_PURCHASECUST.SKU)
	                                     ELSE (SELECT SUM(QTY) FROM T_ST_STOCK_PURCHASE WHERE T_ST_STOCK_PURCHASE.STORERKEY = MS_PURCHASECUST.STORERKEY AND T_ST_STOCK_PURCHASE.DCCODE = MS_PURCHASECUST.DCCODE AND T_ST_STOCK_PURCHASE.SKU = MS_PURCHASECUST.SKU)
	                                END, 0) AS STOCKQTY_DISP --> <!-- 현재고 추가 20151102 신한섭님 요청사항 로직에는 반영안함 -->
	                          , CASE WHEN NVL(MS_PURCHASEMST.EDIT_REORDERPOINT, 0) <![CDATA[>]]> 0 THEN MS_PURCHASEMST.EDIT_REORDERPOINT
	                                 ELSE NVL(ROUND((MS_PURCHASESTATS.STOCKAVGDAY * NVL(MS_PURCHASEMST.LEADTIME, 1)) + (MS_PURCHASESTATS.STDDEVIATION * (NVL(MS_PURCHASEMST.COEFFICIENTSAFETY, 0)) * POWER(NVL(MS_PURCHASEMST.LEADTIME, 1), 1 / 2))), 0)
	                            END AS REORDERPOINT
	                          , CASE WHEN NVL(MS_PURCHASEMST.EDIT_STOCKGOAL, 0) <![CDATA[>]]> 0 THEN MS_PURCHASEMST.EDIT_STOCKGOAL
	                                 ELSE NVL(ROUND(MS_PURCHASESTATS.STOCKAVGDAY * (NVL(MS_PURCHASEMST.PURINTERVAL, 1) + NVL(MS_PURCHASEMST.LEADTIME, 1)) + ((3 * MS_PURCHASESTATS.STDDEVIATION) * POWER((NVL(MS_PURCHASEMST.PURINTERVAL, 1) + NVL(MS_PURCHASEMST.LEADTIME, 1)), 1 / 2))), 0)
	                            END AS STOCKGOAL
	                          , CASE WHEN MS_PURCHASEMST.EDIT_REORDERPOINT <![CDATA[>]]> 0 OR MS_PURCHASEMST.EDIT_STOCKGOAL <![CDATA[>]]> 0 THEN 'Y' ELSE 'N' END AS CONFIRMQTY_EDIT_YN
	                          , MS_SKU.BASEUOM AS UOM
	                          , NVL(MS_PURCHASESTATS.STOCKAVGDAY, 0) AS STOCKAVGDAY
	                          <!-- , (SELECT 
								ROUND(NVL(SUM(SHIPQTY1W_SO), 0) / (SELECT SUM(CASE WHEN REST_YN = 'N' THEN 1 ELSE 0 END) 
												   FROM CM_CALENDAR 
												   WHERE YY||MM||DD BETWEEN TO_CHAR(SYSDATE - 30,'YYYYMMDD') AND TO_CHAR(SYSDATE - 1,'YYYYMMDD')
													AND CM_CALENDAR.DCCODE = 'STD' 
													AND CM_CALENDAR.CALENDAR_ID = 'STD')) AS STOCKAVGDAY 
								FROM MS_PURCHASESTATS 
								WHERE SKU = MS_SKU.SKU 
								AND STATSDT = TO_CHAR(SYSDATE,'YYYYMMDD')
								GROUP BY SKU
								) AS STOCKAVGDAY -->
	                          , MS_PURCHASESTATS.MAXSTOCK
	                          , 26 - NVL(MS_PURCHASESTATS.SHIPDAY1W, 0) AS SHIPDAY1W, 26 - NVL(MS_PURCHASESTATS.SHIPDAY2W, 0) AS SHIPDAY2W, 26 - NVL(MS_PURCHASESTATS.SHIPDAY3W, 0) AS SHIPDAY3W
	                          , CASE WHEN NVL(MS_PURCHASESTATS.SHIPQTY1W, 0) <![CDATA[>]]> NVL(MS_PURCHASESTATS.SHIPQTY2W, 0) THEN '1' WHEN NVL(MS_PURCHASESTATS.SHIPQTY1W, 0) <![CDATA[<]]> NVL(MS_PURCHASESTATS.SHIPQTY2W, 0) THEN '-1' ELSE '0' END AS SHIPQTYCHG1W
	                          , CASE WHEN NVL(MS_PURCHASESTATS.SHIPQTY2W, 0) <![CDATA[>]]> NVL(MS_PURCHASESTATS.SHIPQTY3W, 0) THEN '1' WHEN NVL(MS_PURCHASESTATS.SHIPQTY2W, 0) <![CDATA[<]]> NVL(MS_PURCHASESTATS.SHIPQTY3W, 0) THEN '-1' ELSE '0' END AS SHIPQTYCHG2W
	                          , '0' AS SHIPQTYCHG3W, NVL(MS_PURCHASESTATS.SHIPQTY1W, 0) AS SHIPQTY1W, NVL(MS_PURCHASESTATS.SHIPQTY2W, 0) AS SHIPQTY2W, NVL(MS_PURCHASESTATS.SHIPQTY3W, 0) AS SHIPQTY3W
	                          , NVL(MS_PURCHASESTATS.ORDCNT1W, 0) AS ORDCNT1W, NVL(MS_PURCHASESTATS.ORDCNT2W, 0) AS ORDCNT2W, NVL(MS_PURCHASESTATS.ORDCNT3W, 0) AS ORDCNT3W
	                          <!-- 
					             발주 단위 관련 변경사항 20151030 신한섭님 요청사항 
					             STO발주인 경우 1000,2170,2690 센터에서 공급하는 경우 발주단위 사용하며 이외 센터는 기본단위를 발주단위로 사용함
					             1000-1260,1000-1400 : 기본단위 사용함
					             수정내용 - 발주단위, BUNJA, BUNMO
					          -->
	                          <!-- , CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('STO', 'STO-ADD', 'STO-AUTO') THEN
	                                    CASE WHEN NVL(MS_PURCHASEMST.ROUTE, MS_PURCHASECUST.ROUTE) NOT IN ('2170', '2690') THEN
	                                        CASE WHEN NVL(MS_PURCHASEMST.ROUTE, MS_PURCHASECUST.ROUTE) = '1000' THEN
	                                            CASE WHEN NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) IN ('1000-1260', '1000-1400') OR (NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) = '1000-1112' AND MS_SKU.STORAGETYPE = '20') THEN MS_SKU.BASEUOM
	                                                 ELSE MS_SKU.PURCHASEUOM
	                                            END
	                                        ELSE MS_SKU.BASEUOM
	                                        END
	                                    ELSE MS_SKU.PURCHASEUOM
	                                    END
	                               ELSE MS_SKU.PURCHASEUOM
	                            END AS PURCHASEUOM -->
	                          , MS_SKU.PURCHASEUOM  
	                          , MS_SKU.QTYPERBOX AS BOXPERQTY
	                          <!-- , (SELECT FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, '', 'N') FROM DUAL) || '/' || MS_SKU.DURATION AS DURATION -->
	                          <!-- , (SELECT MIN(CM_LOT.LOTTABLE01) FROM ST_STOCK JOIN MS_SKU ON MS_SKU.STORERKEY = ST_STOCK.STORERKEY AND MS_SKU.SKU = ST_STOCK.SKU JOIN MS_LOCATION ON MS_LOCATION.DCCODE = ST_STOCK.DCCODE AND MS_LOCATION.LOC = ST_STOCK.LOC AND MS_LOCATION.LOCTYPE IN ('STAGE', 'PICK', 'KEEP', 'CROSS', 'FIRSTOUT', 'LONGSTAY', 'CANCEL') AND ((MS_LOCATION.LOCCATEGORY IN ('RACK', 'YARD') AND ST_STOCK.DCCODE NOT IN ('2690', '2620')) OR (MS_LOCATION.LOCCATEGORY IN ('RACK', 'YARD', 'AUTO') AND ST_STOCK.DCCODE IN ('2690', '2620'))) AND MS_LOCATION.LOCFLAG = 'GOOD' AND CASE WHEN MS_LOCATION.DCCODE = '2690' AND MS_LOCATION.LOCTYPE = 'STAGE' THEN 'Y' WHEN MS_LOCATION.DCCODE = '2600' AND MS_LOCATION.LOCTYPE = 'STAGE' THEN 'Y' ELSE MS_LOCATION.OUT_YN END = 'Y' AND MS_LOCATION.DEL_YN = 'N' AND MS_LOCATION.STOCKTYPE = 'GOOD' JOIN CM_LOT ON CM_LOT.STORERKEY = ST_STOCK.STORERKEY AND CM_LOT.LOT = ST_STOCK.LOT AND 'TRUE' = CASE WHEN CM_LOT.LOTTABLE01 = 'STD' OR MS_SKU.DURATIONTYPE = 'N' THEN 'FALSE' WHEN MS_SKU.DURATIONTYPE = '1' AND FN_ISDATE(CM_LOT.LOTTABLE01) = 1 AND TO_DATE(CM_LOT.LOTTABLE01, 'YYYYMMDD') <![CDATA[<]]> TRUNC(SYSDATE) THEN 'FALSE' WHEN MS_SKU.DURATIONTYPE IN ('2', '3') AND FN_ISDATE(CM_LOT.LOTTABLE01) = 1 AND TO_DATE(CM_LOT.LOTTABLE01, 'YYYYMMDD') + MS_SKU.DURATION - 1 <![CDATA[<]]> TRUNC(SYSDATE) THEN 'FALSE' ELSE 'TRUE' END WHERE 1 = 1 AND ST_STOCK.STORERKEY = MS_PURCHASECUST.STORERKEY AND ST_STOCK.DCCODE = MS_PURCHASECUST.DCCODE AND ST_STOCK.SKU = MS_PURCHASECUST.SKU GROUP BY ST_STOCK.DCCODE, ST_STOCK.STORERKEY, ST_STOCK.AREA, ST_STOCK.SKU, ST_STOCK.UOM) AS DURATION -->
	                          , MS_PURCHASEMST.REFERENCE01, MS_PURCHASEMST.REFERENCE02, MS_PURCHASEMST.REFERENCE03, MS_PURCHASEMST.REFERENCE06
	                          , CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END AS EXECDAY
	                          , #{stdDt} AS STD_DT, MS_PURCHASEMST.AUTO_EXECDAY, MS_PURCHASEMST.PURCHASETYPE, MS_PURCHASECUST.PLANT
	                          , MS_SKU.STORAGETYPE, (SELECT FN_CODEDESCR(MS_SKU.STORERKEY, 'STORAGETYPE', MS_SKU.STORAGETYPE) FROM DUAL) AS STORAGETYPENM
	                          , MS_PURCHASECUST.PURCHASEGROUP, NVL(MS_PURCHASEMST.MINORDERQTY, 0) AS MINORDERQTY, MS_SKU.LAYERPERPLT, MS_SKU.BOXPERLAYER
	                          , NVL(MS_PURCHASEMST.COEFFICIENTSAFETY, 0) AS COEFFICIENTSAFETY, NVL(MS_PURCHASEMST.LEADTIME, 1) AS LEADTIME, NVL(MS_PURCHASEMST.PURINTERVAL, 1) AS PURINTERVAL
	                          , MS_PURCHASECUST.DELIVERYWEEK, MS_PURCHASECUST.RETURNTYPE, MS_PURCHASECUST.SERIALKEY, MS_PURCHASECUST.STORERKEY, MS_PURCHASECUST.CUSTTYPE
	                          , (SELECT FN_CODEDESCR(MS_PURCHASECUST.STORERKEY, 'CUSTTYPE', MS_PURCHASECUST.CUSTTYPE) FROM DUAL) AS CUSTTYPENM
	                          , NVL(MS_PURCHASESTATS.AREA, '1000') AS AREA, MS_PURCHASECUST.CHANNEL
	                          <!-- , CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('STO', 'STO-ADD', 'STO-AUTO') THEN
	                                    CASE WHEN NVL(MS_PURCHASEMST.ROUTE, MS_PURCHASECUST.ROUTE) NOT IN ('2170', '2690') THEN
	                                        CASE WHEN NVL(MS_PURCHASEMST.ROUTE, MS_PURCHASECUST.ROUTE) = '1000' THEN
	                                            CASE WHEN NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) IN ('1000-1260', '1000-1400') OR (NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) = '1000-1112' AND MS_SKU.STORAGETYPE = '20') THEN 1
	                                                 ELSE NVL(MS_UOM.BUNJA, 1)
	                                            END
	                                        ELSE 1
	                                        END
	                                    ELSE NVL(MS_UOM.BUNJA, 1)
	                                    END
	                               ELSE NVL(MS_UOM.BUNJA, 1)
	                            END AS BUNJA -->
	                            <!-- 
					               발주 단위 관련 변경사항 20151030 신한섭님 요청사항 
					               STO발주인 경우 1000,2170,2690 센터에서 공급하는 경우 발주단위 사용하며 이외 센터는 기본단위를 발주단위로 사용함
					               1000-1260,1000-1400 : 기본단위 사용함
					               수정내용 - 발주단위, BUNJA, BUNMO
					           -->
	                          <!-- , CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('STO', 'STO-ADD', 'STO-AUTO') THEN
	                                    CASE WHEN NVL(MS_PURCHASEMST.ROUTE, MS_PURCHASECUST.ROUTE) NOT IN ('2170', '2690') THEN
	                                        CASE WHEN NVL(MS_PURCHASEMST.ROUTE, MS_PURCHASECUST.ROUTE) = '1000' THEN
	                                            CASE WHEN NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) IN ('1000-1260', '1000-1400') OR (NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) = '1000-1112' AND MS_SKU.STORAGETYPE = '20') THEN 1
	                                                 ELSE NVL(MS_UOM.BUNMO, 1)
	                                            END
	                                        ELSE 1
	                                        END
	                                    ELSE NVL(MS_UOM.BUNMO, 1)
	                                    END
	                               ELSE NVL(MS_UOM.BUNMO, 1)
	                            END AS BUNMO -->
	                          , MS_UOM.BUNJA, MS_UOM.BUNMO
	                          , CASE WHEN (MS_SKU.LAYERPERPLT * MS_SKU.BOXPERLAYER) = 0 THEN 1 ELSE (MS_SKU.LAYERPERPLT * MS_SKU.BOXPERLAYER) END AS PALLETUNIT
	                          , TO_CHAR(SYSDATE, 'YYYYMMDD') AS PODT, NVL(MS_PURCHASEMST.ROUTE, MS_PURCHASECUST.ROUTE) AS FROM_DCCODE
	                          , NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) AS FROM_ORGANIZE, '' AS EMPTYFIELD
	                          , 'STD' AS STD, 0 AS ZERO
	                          , (SELECT FN_CODEDESCR(MS_PURCHASECUST.STORERKEY, 'PUTAWAYTYPE', MS_PURCHASECUST.CHANNEL) FROM DUAL) AS CHANNELNM
	                          , (SELECT FN_CODEDESCR(MS_PURCHASECUST.STORERKEY, 'SERIALYN', MS_SKU.SERIALYN) FROM DUAL) AS SERIALYN
	                          , (SELECT FN_CODEDESCR(MS_PURCHASECUST.STORERKEY, 'YN', NVL(MS_SKU.LINE01, 'N')) FROM DUAL) AS LINE01
	                          , MS_SKU.LINE02, MS_UOM.BUNJA AS BUNJA_CAL, MS_UOM.BUNMO AS BUNMO_CAL
	                          , NVL(MS_PURCHASEMST.REFERENCE04, 'N') AS REFERENCE04
	                          , (select REPLACE(fn_getusername(MS_PURCHASECUST.ADDWHO), 'NOT FOUND', MS_PURCHASECUST.ADDWHO) from dual) AS ADDWHO
	                          , to_char(MS_PURCHASECUST.ADDDATE, 'yyyy-mm-dd hh24:mi:ss') AS ADDDATE
	                          , (select REPLACE(fn_getusername(MS_PURCHASECUST.EDITWHO), 'NOT FOUND', MS_PURCHASECUST.EDITWHO) from dual) AS EDITWHO
	                          , to_char(MS_PURCHASECUST.EDITDATE, 'yyyy-mm-dd hh24:mi:ss') AS EDITDATE
	                          <!-- , NVL((SELECT SUM(ST_STOCK.QTY) FROM ST_STOCK JOIN MS_SKU ON MS_SKU.STORERKEY = ST_STOCK.STORERKEY AND MS_SKU.SKU = ST_STOCK.SKU AND MS_SKU.DEL_YN = 'N' JOIN CM_LOT ON CM_LOT.STORERKEY = ST_STOCK.STORERKEY AND CM_LOT.LOT = ST_STOCK.LOT AND CM_LOT.DEL_YN = 'N' JOIN MS_LOCATION ON MS_LOCATION.DCCODE = ST_STOCK.DCCODE AND MS_LOCATION.LOC = ST_STOCK.LOC LEFT OUTER JOIN ST_SNINFO ON ST_STOCK.STORERKEY = ST_SNINFO.STORERKEY AND ST_STOCK.SKU = ST_SNINFO.SKU AND ST_STOCK.STOCKID = ST_SNINFO.STOCKID WHERE ST_STOCK.DCCODE = '2170' AND ST_STOCK.SKU = MS_PURCHASECUST.SKU AND ST_STOCK.STOCKGRADE = 'STD' AND ST_STOCK.STOCKTYPE = 'GOOD' AND ST_SNINFO.CONTRACTTYPE IN ('30', '30 - 계약', '30 - 계약영업')), 0) AS STOCKQTY_CONTRACT
	                          , NVL((SELECT SUM(ST_STOCK.QTY) FROM ST_STOCK JOIN MS_SKU ON MS_SKU.STORERKEY = ST_STOCK.STORERKEY AND MS_SKU.SKU = ST_STOCK.SKU AND MS_SKU.DEL_YN = 'N' JOIN CM_LOT ON CM_LOT.STORERKEY = ST_STOCK.STORERKEY AND CM_LOT.LOT = ST_STOCK.LOT AND CM_LOT.DEL_YN = 'N' JOIN MS_LOCATION ON MS_LOCATION.DCCODE = ST_STOCK.DCCODE AND MS_LOCATION.LOC = ST_STOCK.LOC LEFT OUTER JOIN ST_SNINFO ON ST_STOCK.STORERKEY = ST_SNINFO.STORERKEY AND ST_STOCK.SKU = ST_SNINFO.SKU AND ST_STOCK.STOCKID = ST_SNINFO.STOCKID WHERE ST_STOCK.DCCODE = '2170' AND ST_STOCK.SKU = MS_PURCHASECUST.SKU AND ST_STOCK.STOCKGRADE = 'STD' AND ST_STOCK.STOCKTYPE = 'GOOD' AND (ST_SNINFO.CONTRACTTYPE NOT IN ('30', '30 - 계약', '30 - 계약영업', '90', '90 - 당일매입매출') or ST_SNINFO.CONTRACTTYPE IS NULL)), 0) AS STOCKQTY_OUTDISP -->
	                          , NVL(MS_PURCHASEMST.MON_YN, '1') AS MON_YN, NVL(MS_PURCHASEMST.TUE_YN, '1') AS TUE_YN, NVL(MS_PURCHASEMST.WED_YN, '1') AS WED_YN
	                          , NVL(MS_PURCHASEMST.THU_YN, '1') AS THU_YN, NVL(MS_PURCHASEMST.FRI_YN, '1') AS FRI_YN, NVL(MS_PURCHASEMST.SAT_YN, '0') AS SAT_YN, NVL(MS_PURCHASEMST.SUN_YN, '0') AS SUN_YN
	                          , CASE WHEN TO_CHAR(SYSDATE, 'YYYYMMDD') BETWEEN ST_ALLOCATED_R.CTRL_START_DT AND ST_ALLOCATED_R.CTRL_END_DT THEN CASE WHEN ST_ALLOCATED_R.STOP_YN = 'Y' THEN 'icon_bbs01' ELSE 'icon_bbs03' END ELSE NULL END AS STOP_STATUS
	                          , CASE WHEN TO_CHAR(SYSDATE, 'YYYYMMDD') BETWEEN ST_ALLOCATED_R.CTRL_START_DT AND ST_ALLOCATED_R.CTRL_END_DT THEN CASE WHEN ST_ALLOCATED_R.ALLO_EXC_DCCODE IS NOT NULL AND ST_ALLOCATED_R.ORD_EXC_DCCODE IS NOT NULL THEN '(' || ST_ALLOCATED_R.ALLO_EXC_DCCODE || '할당제외,' || ST_ALLOCATED_R.ORD_EXC_DCCODE || '주문불가 / 주문산정기간 : ' || nvl(ST_ALLOCATED_R.ORDER_POS_QTY, 0) || ')' WHEN ST_ALLOCATED_R.ALLO_EXC_DCCODE IS NOT NULL AND ST_ALLOCATED_R.ORD_EXC_DCCODE IS NULL THEN '(' || ST_ALLOCATED_R.ALLO_EXC_DCCODE || '할당제외 / 주문산정기간 : ' || nvl(ST_ALLOCATED_R.ORDER_POS_QTY, 0) || ')' WHEN ST_ALLOCATED_R.ALLO_EXC_DCCODE IS NULL AND ST_ALLOCATED_R.ORD_EXC_DCCODE IS NOT NULL THEN '(' || ST_ALLOCATED_R.ORD_EXC_DCCODE || '주문불가 / 주문산정기간 : ' || nvl(ST_ALLOCATED_R.ORDER_POS_QTY, 0) || ')' ELSE '(주문산정기간 : ' || nvl(ST_ALLOCATED_R.ORDER_POS_QTY, 0) || ')' END ELSE null END AS STOP_INFO
	                          , NVL(MS_PURCHASESTATS.ORD1DAY, 0) AS ORD1DAY, NVL(MS_PURCHASESTATS.ORD2DAY, 0) AS ORD2DAY, NVL(MS_PURCHASESTATS.ORD3DAY, 0) AS ORD3DAY, NVL(MS_PURCHASESTATS.ORD4DAY, 0) AS ORD4DAY
	                          , NVL(MS_PURCHASESTATS.ORD5DAY, 0) AS ORD5DAY, NVL(MS_PURCHASESTATS.ORD6DAY, 0) AS ORD6DAY, NVL(MS_PURCHASESTATS.ORD7DAY, 0) AS ORD7DAY, NVL(MS_PURCHASESTATS.ORD8DAY, 0) AS ORD8DAY
	                          , NVL(MS_PURCHASESTATS.ORD9DAY, 0) AS ORD9DAY, NVL(MS_PURCHASESTATS.ORD10DAY, 0) AS ORD10DAY, NVL(MS_PURCHASESTATS.ORD11DAY, 0) AS ORD11DAY
	                          , NVL(MS_PURCHASESTATS.ORD12DAY, 0) AS ORD12DAY, NVL(MS_PURCHASESTATS.ORD13DAY, 0) AS ORD13DAY, NVL(MS_PURCHASESTATS.ORD14DAY, 0) AS ORD14DAY
	                          , MS_PURCHASEMST.ORDERQTY_UNIT, CM_CODE.DATA2 AS BUYERKEY_TYPE
	                          , NVL((SELECT T_OM_PURCHASE_RESULT.CONFIRMQTY FROM (SELECT OM_PURCHASE_RESULT.CONFIRMQTY, OM_PURCHASE_RESULT.SKU FROM OM_PURCHASE_RESULT WHERE OM_PURCHASE_RESULT.ISOWEEK_CD = FN_GETISOWEEKCD(TO_CHAR(SYSDATE, 'YYYYMMDD'), 0) ORDER BY OM_PURCHASE_RESULT.ALGO_WRK_START_DTM DESC) T_OM_PURCHASE_RESULT WHERE T_OM_PURCHASE_RESULT.SKU = MS_PURCHASECUST.SKU AND ROWNUM = 1), 0) AS CONFIRMQTY1WEEK
	                          , NVL((SELECT T_OM_PURCHASE_RESULT.CONFIRMQTY FROM (SELECT OM_PURCHASE_RESULT.CONFIRMQTY, OM_PURCHASE_RESULT.SKU FROM OM_PURCHASE_RESULT WHERE OM_PURCHASE_RESULT.ISOWEEK_CD = FN_GETISOWEEKCD(TO_CHAR(SYSDATE, 'YYYYMMDD'), 7) ORDER BY OM_PURCHASE_RESULT.ALGO_WRK_START_DTM DESC) T_OM_PURCHASE_RESULT WHERE T_OM_PURCHASE_RESULT.SKU = MS_PURCHASECUST.SKU AND ROWNUM = 1), 0) AS CONFIRMQTY2WEEK
	                          , NVL((SELECT T_OM_PURCHASE_RESULT.CONFIRMQTY FROM (SELECT OM_PURCHASE_RESULT.CONFIRMQTY, OM_PURCHASE_RESULT.SKU FROM OM_PURCHASE_RESULT WHERE OM_PURCHASE_RESULT.ISOWEEK_CD = FN_GETISOWEEKCD(TO_CHAR(SYSDATE, 'YYYYMMDD'), 14) ORDER BY OM_PURCHASE_RESULT.ALGO_WRK_START_DTM DESC) T_OM_PURCHASE_RESULT WHERE T_OM_PURCHASE_RESULT.SKU = MS_PURCHASECUST.SKU AND ROWNUM = 1), 0) AS CONFIRMQTY3WEEK
	                          , NVL((SELECT T_OM_PURCHASE_RESULT.CONFIRMQTY FROM (SELECT OM_PURCHASE_RESULT.CONFIRMQTY, OM_PURCHASE_RESULT.SKU FROM OM_PURCHASE_RESULT WHERE OM_PURCHASE_RESULT.ISOWEEK_CD = FN_GETISOWEEKCD(TO_CHAR(SYSDATE, 'YYYYMMDD'), 21) ORDER BY OM_PURCHASE_RESULT.ALGO_WRK_START_DTM DESC) T_OM_PURCHASE_RESULT WHERE T_OM_PURCHASE_RESULT.SKU = MS_PURCHASECUST.SKU AND ROWNUM = 1), 0) AS CONFIRMQTY4WEEK
	                          , (SELECT T_OM_PURCHASE_RESULT.LABEL FROM (SELECT OM_PURCHASE_RESULT.LABEL, OM_PURCHASE_RESULT.SKU FROM OM_PURCHASE_RESULT WHERE OM_PURCHASE_RESULT.ISOWEEK_CD = FN_GETISOWEEKCD(TO_CHAR(SYSDATE, 'YYYYMMDD'), 0) ORDER BY OM_PURCHASE_RESULT.ALGO_WRK_START_DTM DESC) T_OM_PURCHASE_RESULT WHERE T_OM_PURCHASE_RESULT.SKU = MS_PURCHASECUST.SKU AND ROWNUM = 1) AS LABEL
	                          , MS_DC_PLT_LOAD.BOXPERLAYER * MS_DC_PLT_LOAD.LAYERPERPLT AS BOXPERPLT
	                          , NVL(MS_SKUCHAIN_MOQ.MOQ_SKU, 0) AS MOQ_SKU, MS_SKUCHAIN_MOQ.LEADTIME AS LEADTIME2
	                          , NVL(MS_SKUCHAIN_MOQ.MOQ_SKU_PLT, 0) AS MOQ_SKU_PLT, NVL(MS_SKUCHAIN_MOQ.MOQ_VENDER, 0) AS MOQ_VENDER, NVL(MS_SKUCHAIN_MOQ.MOQ_VENDER_PLT, 0) AS MOQ_VENDER_PLT
	                          , MS_CUST_SECOND.SLAVE_CUSTKEY
	                          , CASE WHEN MS_CUST_SECOND.SLAVE_CUSTKEY IS NULL THEN '' ELSE TO_CHAR(FN_DESCR_VENDOR(MS_CUST_SECOND.STORERKEY, MS_CUST_SECOND.SLAVE_CUSTKEY)) END AS SLAVE_CUSTNAME
	                          , (CASE WHEN #{dcCode} = '2690' AND MS_PURCHASECUST.DCCODE = '1000' THEN 0 WHEN #{dcCode} = '1000' AND NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) IS NOT NULL THEN (SELECT CASE WHEN MAX(T_ST_STOCK_PURCHASE.PLT_FLG) = 'S' THEN 1 ELSE CEIL(SUM(T_ST_STOCK_PURCHASE.QTY) / MAX(MS_SKU.QTYPERBOX) / MAX(NULLIF(MS_DC_PLT_LOAD.BOXPERLAYER,0) * NULLIF(MS_DC_PLT_LOAD.LAYERPERPLT,0))) END FROM T_ST_STOCK_PURCHASE WHERE T_ST_STOCK_PURCHASE.STORERKEY = MS_PURCHASECUST.STORERKEY AND T_ST_STOCK_PURCHASE.DCCODE = MS_PURCHASECUST.DCCODE AND T_ST_STOCK_PURCHASE.ORGANIZE = NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) AND T_ST_STOCK_PURCHASE.SKU = MS_PURCHASECUST.SKU GROUP BY T_ST_STOCK_PURCHASE.DCCODE, T_ST_STOCK_PURCHASE.SKU) ELSE (SELECT CASE WHEN MAX(T_ST_STOCK_PURCHASE.PLT_FLG) = 'S' THEN 1 ELSE CEIL(SUM(T_ST_STOCK_PURCHASE.QTY) / MAX(MS_SKU.QTYPERBOX) / MAX(NULLIF(MS_DC_PLT_LOAD.BOXPERLAYER,0) * NULLIF(MS_DC_PLT_LOAD.LAYERPERPLT,0))) END FROM T_ST_STOCK_PURCHASE WHERE T_ST_STOCK_PURCHASE.STORERKEY = MS_PURCHASECUST.STORERKEY AND T_ST_STOCK_PURCHASE.DCCODE = MS_PURCHASECUST.DCCODE AND T_ST_STOCK_PURCHASE.SKU = MS_PURCHASECUST.SKU GROUP BY T_ST_STOCK_PURCHASE.DCCODE, T_ST_STOCK_PURCHASE.SKU) END) AS BOXPERPLT_QTY
	                          <!-- WHEN CM_LOT.LOTTABLE01 = 'STD' OR MS_SKU.DURATIONTYPE = 'N' 인 경우 값이 안나와서 FALSE로 수정 -->
	                          <!-- , (SELECT MIN(FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'N') || '/' || MS_SKU.DURATION) FROM ST_STOCK JOIN MS_SKU ON MS_SKU.STORERKEY = ST_STOCK.STORERKEY AND MS_SKU.SKU = ST_STOCK.SKU JOIN MS_LOCATION ON MS_LOCATION.DCCODE = ST_STOCK.DCCODE AND MS_LOCATION.LOC = ST_STOCK.LOC AND MS_LOCATION.LOCTYPE IN ('STAGE', 'PICK', 'KEEP', 'CROSS', 'FIRSTOUT', 'LONGSTAY', 'CANCEL') AND ((MS_LOCATION.LOCCATEGORY IN ('RACK', 'YARD') AND ST_STOCK.DCCODE NOT IN ('2690', '2620')) OR (MS_LOCATION.LOCCATEGORY IN ('RACK', 'YARD', 'AUTO') AND ST_STOCK.DCCODE IN ('2690', '2620'))) AND MS_LOCATION.LOCFLAG = 'GOOD' AND CASE WHEN MS_LOCATION.DCCODE = '2690' AND MS_LOCATION.LOCTYPE = 'STAGE' THEN 'Y' WHEN MS_LOCATION.DCCODE = '2600' AND MS_LOCATION.LOCTYPE = 'STAGE' THEN 'Y' ELSE MS_LOCATION.OUT_YN END = 'Y' AND MS_LOCATION.DEL_YN = 'N' AND MS_LOCATION.STOCKTYPE = 'GOOD' JOIN CM_LOT ON CM_LOT.STORERKEY = ST_STOCK.STORERKEY AND CM_LOT.LOT = ST_STOCK.LOT AND 'TRUE' = CASE WHEN CM_LOT.LOTTABLE01 = 'STD' OR MS_SKU.DURATIONTYPE = 'N' THEN 'FALSE' WHEN MS_SKU.DURATIONTYPE = '1' AND FN_ISDATE(CM_LOT.LOTTABLE01) = 1 AND TO_DATE(CM_LOT.LOTTABLE01, 'YYYYMMDD') <![CDATA[<]]> TRUNC(SYSDATE) THEN 'FALSE' WHEN MS_SKU.DURATIONTYPE IN ('2', '3') AND FN_ISDATE(CM_LOT.LOTTABLE01) = 1 AND TO_DATE(CM_LOT.LOTTABLE01, 'YYYYMMDD') + MS_SKU.DURATION - 1 <![CDATA[<]]> TRUNC(SYSDATE) THEN 'FALSE' ELSE 'TRUE' END WHERE 1 = 1 AND ST_STOCK.STORERKEY = MS_PURCHASECUST.STORERKEY AND ST_STOCK.DCCODE = MS_PURCHASECUST.DCCODE AND ST_STOCK.SKU = MS_PURCHASECUST.SKU GROUP BY ST_STOCK.DCCODE, ST_STOCK.STORERKEY, ST_STOCK.AREA, ST_STOCK.SKU, ST_STOCK.UOM) AS DURATION_TERM -->
	                          , MS_SKU.REFERENCE03 AS TPL_SKUGROUP
	                          , MS_CUST.EMPNAME1, MS_CUST.EMPNAME2, MS_CUST.EMPNAME3, MS_CUST.EMPNAME4, MS_CUST.EMPNAME5
	                          , MS_CUST.EMPPHONE1, MS_CUST.EMPPHONE2, MS_CUST.EMPPHONE3, MS_CUST.EMPPHONE4, MS_CUST.EMPPHONE5
	                          , DECODE(MS_PURCHASEMST.EXHAUSTION_STOP_YN, '0', 'N', '1', 'Y', MS_PURCHASEMST.EXHAUSTION_STOP_YN) AS EXHAUSTION_STOP_YN
	                          , ROUND(MS_PURCHASESTATS.STDDEVIATION * MS_PURCHASEMST.COEFFICIENTSAFETY * POWER(MS_PURCHASEMST.LEADTIME, 0.5), 2) AS STOCKSAFETY2
	                          , MS_SKU.CUSTSKU, MS_PURCHASEMST.REFERENCE07
	                          , NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY01, 0) AS AFTERDAYWDQTY01, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY02, 0) AS AFTERDAYWDQTY02, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY03, 0) AS AFTERDAYWDQTY03
	                          , NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY04, 0) AS AFTERDAYWDQTY04, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY05, 0) AS AFTERDAYWDQTY05, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY06, 0) AS AFTERDAYWDQTY06
	                          , NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY07, 0) AS AFTERDAYWDQTY07, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY08, 0) AS AFTERDAYWDQTY08, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY09, 0) AS AFTERDAYWDQTY09
	                          , NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY10, 0) AS AFTERDAYWDQTY10, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY11, 0) AS AFTERDAYWDQTY11, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY12, 0) AS AFTERDAYWDQTY12
	                          , NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY13, 0) AS AFTERDAYWDQTY13, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY14, 0) AS AFTERDAYWDQTY14, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY15, 0) AS AFTERDAYWDQTY15
	                          , NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY16, 0) AS AFTERDAYWDQTY16, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY17, 0) AS AFTERDAYWDQTY17, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY18, 0) AS AFTERDAYWDQTY18
	                          , NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY19, 0) AS AFTERDAYWDQTY19, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY20, 0) AS AFTERDAYWDQTY20
	                          , MS_DIRECTDLVGROUP.CUSTKEY AS DIRECTDLV_CUSTKEY
	                          , MS_DIRECTDLVGROUP.ORDERQTY AS DIRECTDLV_ORDERQTY
	                          , MS_DIRECTDLVGROUP.UOM AS DIRECTDLV_UOM
	                          , CASE WHEN SUBSTR(MS_DIRECTDLVGROUP.CUSTKEY,1,5) = '1000-' THEN '1000' WHEN SUBSTR(MS_DIRECTDLVGROUP.CUSTKEY,1,5) = '2170-' THEN '2170' ELSE '' END AS DIRECTDLV_FROM_DCCODE
	                          , MS_PURCHASEMST.EXCPT_DP_APPR_YN
	                          , NVL(CASE WHEN MS_SKU.BASEUOM = 'KG' AND MS_SKU.LINE01 = 'Y'
                                    THEN MS_SKU.LINE02 * MS_DC_PLT_LOAD.BOXPERLAYER * MS_DC_PLT_LOAD.LAYERPERPLT
                                   WHEN MS_SKU.BASEUOM = 'KG' AND MS_SKU.LINE01 !='Y'
                                    THEN MS_SKU.GROSSWEIGHT * MS_DC_PLT_LOAD.BOXPERLAYER * MS_DC_PLT_LOAD.LAYERPERPLT
                              ELSE MS_DC_PLT_LOAD.BOXPERLAYER * MS_DC_PLT_LOAD.LAYERPERPLT * MS_SKU.QTYPERBOX      /* = 상품마스터.박수입수(MS_SKU.QTYPERBOX)를 곱한다. (위 2케이스외 전부 동일 계산식) */
                              END, 0) AS PLTTRANS /* PLT변환값(환산)*/
                              , ST_SUM.MIN_LOTTABLE01 AS DURATION
		                      , ST_SUM.DURATION_TERM AS DURATION_TERM
		                      , ST_SUM.QTYPICKED_SUM
	                        FROM MS_PURCHASECUST
	                        JOIN MS_PURCHASEMST ON MS_PURCHASEMST.STORERKEY = MS_PURCHASECUST.STORERKEY AND MS_PURCHASEMST.DCCODE = MS_PURCHASECUST.DCCODE AND MS_PURCHASEMST.CUSTTYPE = MS_PURCHASECUST.CUSTTYPE AND MS_PURCHASEMST.SKU = MS_PURCHASECUST.SKU
	                        JOIN CM_DC ON CM_DC.DCCODE = MS_PURCHASECUST.DCCODE
	                        LEFT OUTER JOIN MS_PURCHASESTATS ON MS_PURCHASESTATS.DCCODE = MS_PURCHASECUST.DCCODE AND MS_PURCHASESTATS.STORERKEY = MS_PURCHASECUST.STORERKEY AND MS_PURCHASESTATS.SKU = MS_PURCHASECUST.SKU AND MS_PURCHASESTATS.PLANT = MS_PURCHASECUST.PLANT AND MS_PURCHASESTATS.STATSDT = TO_CHAR(SYSDATE, 'YYYYMMDD')
	                        LEFT OUTER JOIN CM_DCXORGANIZE ON MS_PURCHASESTATS.DCCODE = CM_DCXORGANIZE.DCCODE AND MS_PURCHASESTATS.ORGANIZE = CM_DCXORGANIZE.ORGANIZE
	                        LEFT OUTER JOIN MS_CUST ON MS_CUST.STORERKEY = MS_PURCHASECUST.STORERKEY AND MS_CUST.CUSTKEY = MS_PURCHASECUST.CUSTKEY AND MS_CUST.CUSTTYPE = MS_PURCHASECUST.CUSTTYPE
	                        JOIN MS_SKU ON MS_SKU.STORERKEY = MS_PURCHASECUST.STORERKEY AND MS_SKU.SKU = MS_PURCHASECUST.SKU
	                        <choose>
	                            <when test='reference03 == "HAW4"'>
	                                AND NVL(MS_SKU.REFERENCE03, 'N') = 'HAW4'
	                            </when>
	                            <otherwise>
	                                AND NVL(MS_SKU.REFERENCE03, 'N') <![CDATA[<>]]> 'HAW4'
	                            </otherwise>
	                        </choose>
	                        LEFT OUTER JOIN MS_UOM BOXUOM ON MS_PURCHASECUST.STORERKEY = BOXUOM.STORERKEY AND MS_PURCHASECUST.UOM = BOXUOM.BASEUOM AND MS_PURCHASECUST.SKU = BOXUOM.SKU AND BOXUOM.UOM = 'BOX' AND (MS_PURCHASECUST.UOM = 'BOX' OR BOXUOM.BUNJA <![CDATA[<>]]> BOXUOM.BUNMO)
	                        LEFT OUTER JOIN MS_UOM EAUOM ON MS_PURCHASECUST.STORERKEY = EAUOM.STORERKEY AND MS_PURCHASECUST.SKU = EAUOM.SKU AND MS_PURCHASECUST.UOM = EAUOM.BASEUOM AND EAUOM.UOM = 'EA'
	                        LEFT OUTER JOIN MS_UOM ON MS_SKU.STORERKEY = MS_UOM.STORERKEY AND MS_SKU.SKU = MS_UOM.SKU AND MS_SKU.BASEUOM = MS_UOM.BASEUOM AND MS_SKU.PURCHASEUOM = MS_UOM.UOM
	                        LEFT OUTER JOIN CM_DCXORGANIZE DCXORG ON MS_PURCHASEMST.ROUTEORGANIZE = DCXORG.ORGANIZE AND MS_PURCHASEMST.ROUTE = DCXORG.DCCODE
	                        LEFT OUTER JOIN CM_DCXORGANIZE DCXORGNVL ON MS_PURCHASECUST.ROUTEORGANIZE = DCXORGNVL.ORGANIZE AND MS_PURCHASECUST.ROUTE = DCXORGNVL.DCCODE
	                        LEFT OUTER JOIN MS_PURCHASETOTAL ON MS_PURCHASETOTAL.DCCODE = MS_PURCHASECUST.DCCODE AND MS_PURCHASETOTAL.STORERKEY = MS_PURCHASECUST.STORERKEY AND MS_PURCHASETOTAL.SKU = MS_PURCHASECUST.SKU AND MS_PURCHASETOTAL.USERID = #{gUserId}
	                        LEFT OUTER JOIN ST_ALLOCATED_R ON MS_PURCHASETOTAL.DCCODE = ST_ALLOCATED_R.DCCODE AND MS_PURCHASETOTAL.STORERKEY = ST_ALLOCATED_R.STORERKEY AND MS_PURCHASETOTAL.SKU = ST_ALLOCATED_R.SKU AND ST_ALLOCATED_R.DEL_YN = 'N' AND TO_CHAR(SYSDATE, 'YYYYMMDD') BETWEEN ST_ALLOCATED_R.CTRL_START_DT AND ST_ALLOCATED_R.CTRL_END_DT
	                        LEFT OUTER JOIN CM_CODE ON CM_CODE.BASECODE = MS_PURCHASEMST.BUYERKEY AND CM_CODE.CODELIST = 'BUYERKEY' AND CM_CODE.DEL_YN = 'N' AND CM_CODE.STORERKEY = 'FW00'	                        
	                        LEFT OUTER JOIN MS_SKUCHAIN_MOQ ON MS_PURCHASECUST.SKU = MS_SKUCHAIN_MOQ.SKU AND MS_PURCHASECUST.STORERKEY = MS_SKUCHAIN_MOQ.STORERKEY AND MS_PURCHASECUST.DCCODE = MS_SKUCHAIN_MOQ.DCCODE
	                        LEFT OUTER JOIN MS_CUST_SECOND ON MS_CUST_SECOND.STORERKEY = MS_PURCHASECUST.STORERKEY AND MS_CUST_SECOND.CUSTKEY = MS_PURCHASECUST.CUSTKEY AND MS_CUST_SECOND.SKU = MS_PURCHASECUST.SKU AND MS_CUST_SECOND.DEL_YN = 'N'
	                        LEFT OUTER JOIN MS_DIRECTDLVGROUP ON MS_DIRECTDLVGROUP.STORERKEY = MS_PURCHASECUST.STORERKEY AND MS_DIRECTDLVGROUP.DCCODE = MS_PURCHASECUST.DCCODE AND MS_DIRECTDLVGROUP.DIRECTDLVGROUP = MS_PURCHASEMST.DELIVERYTYPE
	                        /* PLT 변환값 취득 기준 변경, 센터코드 정보 없는경우, "공통"값으로 JOIN (03/14)
                            LEFT OUTER 
                            JOIN MS_DC_PLT_LOAD 
                            ON MS_DC_PLT_LOAD.SKU = MS_PURCHASECUST.SKU 
                            AND MS_DC_PLT_LOAD.STORERKEY = MS_PURCHASECUST.STORERKEY 
                            AND MS_DC_PLT_LOAD.DCCODE = MS_PURCHASECUST.DCCODE
                            */
                            LEFT OUTER
                            JOIN MS_DC_PLT_LOAD                 PLT_CHK
                             ON PLT_CHK.SKU              = MS_PURCHASECUST.SKU
                            AND PLT_CHK.STORERKEY        = MS_PURCHASECUST.STORERKEY
                            AND PLT_CHK.DCCODE           = MS_PURCHASECUST.DCCODE
                            --AND PLT_CHK.PLANT            = MS_PURCHASECUST.PLANT
                            LEFT OUTER
                            JOIN MS_DC_PLT_LOAD
                              ON MS_DC_PLT_LOAD.SKU         = MS_PURCHASECUST.SKU
                             AND MS_DC_PLT_LOAD.STORERKEY   = MS_PURCHASECUST.STORERKEY
                             AND MS_DC_PLT_LOAD.DCCODE      = CASE WHEN PLT_CHK.DCCODE IS NULL THEN '공통' ELSE PLT_CHK.DCCODE END
                             --AND MS_DC_PLT_LOAD.PLANT       = CASE WHEN PLT_CHK.PLANT  IS NULL THEN '공통' ELSE PLT_CHK.PLANT  END
                            LEFT OUTER JOIN (
                                SELECT STORERKEY, DCCODE, SKU,
                                       SUM(OPENQTY) AS SUM_OPENQTY,
                                       SUM(BOXQTY) AS SUM_BOXQTY,
                                       SUM(QTY) AS SUM_QTY
                                FROM VW_ST_STOCK
                                WHERE STOCKGRADE = 'STD' 
                                  AND STOCKTYPE = 'GOOD'
                                GROUP BY STORERKEY, DCCODE, SKU
                            ) STP_ALL ON STP_ALL.STORERKEY = MS_PURCHASECUST.STORERKEY 
                                     AND STP_ALL.DCCODE = MS_PURCHASECUST.DCCODE 
                                     AND STP_ALL.SKU = MS_PURCHASECUST.SKU
                            LEFT OUTER JOIN ST_STOCK_SUMMARY ST_SUM 
	                  		  ON ST_SUM.STORERKEY = MS_PURCHASECUST.STORERKEY 
	                 		 AND ST_SUM.DCCODE = MS_PURCHASECUST.DCCODE 
	                 		 AND ST_SUM.SKU = MS_PURCHASECUST.SKU
	                       WHERE 1 = 1
	                         AND MS_PURCHASECUST.DEL_YN = 'N'
	                         AND MS_PURCHASECUST.STORERKEY = 'FW00'
	                         AND MS_PURCHASECUST.SERIALKEY = (SELECT MIN(DD.SERIALKEY) KEEP (DENSE_RANK FIRST ORDER BY DD.FROMDATE DESC, DD.TODATE ASC)
	                                                            FROM MS_PURCHASECUST DD
	                                                           WHERE DD.DCCODE = MS_PURCHASECUST.DCCODE
	                                                             AND DD.STORERKEY = MS_PURCHASECUST.STORERKEY
	                                                             AND DD.SKU = MS_PURCHASECUST.SKU
	                                                             AND DD.CUSTTYPE = MS_PURCHASECUST.CUSTTYPE
	                                                             AND DD.CHANNEL = '1'
	                                                             AND TO_CHAR(SYSDATE, 'YYYYMMDD') BETWEEN DD.FROMDATE AND DD.TODATE
	                                                             <if test='multiDcCode != null and multiDcCode.length > 0'>
																    AND DD.DCCODE IN
															        <foreach collection="multiDcCode" item="dccodeItem" open="(" separator="," close=")">
															            #{dccodeItem}
															        </foreach>
																 </if>
	                                                             <if test='purchaseType == "PO"'>
	                                                             	 <if test='multiDcCode != null and multiDcCode.length > 0'>
																	    AND DD.PLANT IN
																        <foreach collection="multiDcCode" item="dccodeItem" open="(" separator="," close=")">
																            #{dccodeItem}
																        </foreach>
																	 </if>
	                                                             </if>
	                                                             <if test='purchaseType == "PO-MNL"'>
	                                                                 <if test='multiDcCode != null and multiDcCode.length > 0'>
																	    AND DD.PLANT IN
																        <foreach collection="multiDcCode" item="dccodeItem" open="(" separator="," close=")">
																            #{dccodeItem}
																        </foreach>
																	 </if>
	                                                             </if>
	                                                             AND DD.STORERKEY = 'FW00'
	                                                             AND DD.DEL_YN = 'N'
	                                                        )
	                        <!-- 저장품 여부 -->
	                        <if test="channel != null and channel != ''">
	                            AND MS_PURCHASECUST.CHANNEL = #{channel}
	                        </if>
	                        <!-- 수급담당 -->
	                        <if test="buyerKey != null and buyerKey != ''">
	                            AND MS_PURCHASEMST.BUYERKEY = #{buyerKey}
	                        </if>
	                        <!-- 발주구분 -->
	                        <if test='purchaseTypeArr != null and purchaseTypeArr.length > 0'>
						    	AND MS_PURCHASEMST.PURCHASETYPE IN
						        <foreach collection="purchaseTypeArr" item="typeItem" open="(" separator="," close=")">
						            #{typeItem}
						        </foreach>
							</if>
                            <!--if test='multiDcCode != null and multiDcCode.length > 0'>
						    	AND MS_PURCHASECUST.PLANT IN
						        <foreach collection="multiDcCode" item="dccodeItem" open="(" separator="," close=")">
						            #{dccodeItem}
						        </foreach>
							</if-->
	                        AND MS_PURCHASEMST.PURCHASETYPE NOT IN ('SP-PO', 'SP-STO')
	                        <!-- 협력사코드 -->
	                        <if test='multiFromCustkey != null and multiFromCustkey !=""'>
					          AND MS_PURCHASECUST.CUSTKEY IN
					          (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
					                        FROM (SELECT #{multiFromCustkey} AS VAL FROM DUAL) A
					                     CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
					        </if>
	                        <!-- 직송그룹 -->
	                        <if test='deliveryTypeArr != null and deliveryTypeArr.length > 0'>
						    	AND MS_PURCHASEMST.DELIVERYTYPE IN
						        <foreach collection="deliveryTypeArr" item="typeItem" open="(" separator="," close=")">
						            #{typeItem}
						        </foreach>
							</if>
	                        <!-- 물류센터 -->	                        
	                        <if test='multiDcCode != null and multiDcCode.length > 0'>
							    AND MS_PURCHASECUST.DCCODE IN
						        <foreach collection="multiDcCode" item="dccodeItem" open="(" separator="," close=")">
						            #{dccodeItem}
						        </foreach>
							</if>
							<!-- 물류센터 -->
	                        <if test="route != null and route != ''">
	                            AND MS_PURCHASEMST.ROUTE = #{route}
	                        </if>
	                        <!-- 상품코드 -->
	                        <if test='multiSku != null and multiSku !=""'>
					          AND MS_PURCHASECUST.SKU IN
					          (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
					                        FROM (SELECT #{multiSku} AS VAL FROM DUAL) A
					                     CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
					        </if>
	                        <!-- 저장조건 -->
	                        <if test="storageType != null and storageType != ''">
	                            AND MS_SKU.STORAGETYPE = #{storageType}
	                        </if>
	                    ) SS
	            ) K
        ),
        /* STEP 2~3: SKU_MOQ 적용 및 HOLDING_DAYS 계산 - NUM_PLT 계산 로직 보강 */
		SKU_APPLY AS (
		  SELECT
		      BASE.*,
		      /* 1. BASE_ORDERQTY (EA 단위)를 BOX 단위로 변환 */
		      CEIL(BASE_ORDERQTY / DECODE(UOM,'EA',BOXPERQTY,1 )) AS BASE_ORDERQTY_BOX,
		      /* 2. 상품 MOQ를 고려한 PLT 수량 NUM_PLT 계산 로직 (MOQ_SKU_PLT 우선 적용) */
		      CASE 
		          WHEN MOQ_SKU_PLT IS NOT NULL AND MOQ_SKU_PLT <![CDATA[>]]> 0 THEN  
		              /* MOQ_SKU_PLT와 BASE_ORDERQTY_PLT 중 큰 값을 최종 PLT로 */
		              GREATEST(
		                  CEIL(BASE_ORDERQTY / DECODE(UOM,'EA',BOXPERQTY,1 ) / PALLETUNIT),
		                  MOQ_SKU_PLT
		              )
		          WHEN MOQ_SKU IS NOT NULL AND MOQ_SKU <![CDATA[>]]> 0 THEN  
		              /* MOQ_SKU가 있을 경우, 이를 BOX 단위로 비교 후 PLT로 변환 */
		              CEIL(GREATEST(
		                  CEIL(BASE_ORDERQTY / DECODE(UOM,'EA',BOXPERQTY,1 )),
		                  MOQ_SKU
		              ) / PALLETUNIT)
		          ELSE 
		              /* MOQ가 모두 없는 경우, BASE_ORDERQTY_BOX를 PLT로 변환 */
		              CEIL(CEIL(BASE_ORDERQTY / DECODE(UOM,'EA',BOXPERQTY,1 )) / PALLETUNIT)
		      END AS NUM_PLT,
		      CASE WHEN STOCKAVGDAY <![CDATA[>]]> 0 THEN 
		            /* HOLDING_DAYS (보유일수) 계산 */
		            ROUND(GREATEST(BASE_ORDERQTY,
		                            NVL(CASE WHEN UOM ='EA' AND MOQ_SKU <![CDATA[>]]> 0 THEN BOXPERQTY * MOQ_SKU 
		                                     WHEN UOM ='EA' THEN MOQ_SKU
		                                     ELSE MOQ_SKU
		                                END , 0)
		                  ) / STOCKAVGDAY, 2)
		            ELSE 9999 
		        END AS HOLDING_DAYS
		  FROM BASE
		),
		/* STEP 4~5: 우선순위 (보유일 ASC, ROP ASC, PLT ASC) */
		GROUP_SUM AS (
		  SELECT 
		      CUSTKEY, LEADTIME,
		      SUM(NUM_PLT) AS TOTAL_PLT,
		      MIN(MOQ) AS MOQ
		  FROM SKU_APPLY
		  GROUP BY CUSTKEY, LEADTIME
		),
		DISTRIBUTE AS (
		  SELECT 
		      A.*,
		      B.TOTAL_PLT,
		      ROW_NUMBER() OVER (
		        PARTITION BY A.CUSTKEY, A.LEADTIME 
		        ORDER BY A.NEAR_ROP ASC, A.HOLDING_DAYS ASC,  A.NUM_PLT ASC, A.SKU ASC
		      ) AS RN,
		      COUNT(*) OVER (PARTITION BY A.CUSTKEY, A.LEADTIME) AS CNT
		  FROM SKU_APPLY A
		  JOIN GROUP_SUM B ON A.CUSTKEY = B.CUSTKEY AND A.LEADTIME = B.LEADTIME
		),
		FINAL AS (
		  SELECT
		      DISTRIBUTE.*
		      , CASE WHEN DISTRIBUTE.EXHAUSTION_STOP_YN = 'Y' THEN 0
                    ELSE
                       CASE 
				          /* 협력사 MOQ가 0보다 크고, 총 PLT가 협력사 MOQ보다 작을 때만 재분배 실행 (10 PLT까지 채우기) */
				          WHEN MOQ <![CDATA[>]]> 0 AND TOTAL_PLT <![CDATA[<]]> MOQ THEN 
				              CASE 
				                  WHEN RN <![CDATA[<]]> CNT THEN NUM_PLT + FLOOR((MOQ - TOTAL_PLT) / CNT)
				                  ELSE NUM_PLT + CEIL((MOQ - TOTAL_PLT) - FLOOR((MOQ - TOTAL_PLT) / CNT) * (CNT - 1))
				              END
				          /* 그 외의 경우 (협력사 MOQ가 0이거나, 이미 충족된 경우) 상품 MOQ가 반영된 NUM_PLT를 그대로 사용 */
				          ELSE NUM_PLT
				       END
                END AS FINAL_PLT <!-- 최종 발주산출량 -->  
		  FROM DISTRIBUTE
		)
		SELECT 
			A.*
		    , NVL(FLOOR(A.CONFIRMQTY * A.EA_CAL / NULLIF(A.STOCKAVGDAY, 0)), 0) AS CONFIRMQTY_STOCKDAY /* 확정오더량 보유일 */
		    , NVL(FLOOR((A.STOCKQTY_DISP - A.DATEDIFF_QTY) / NULLIF(A.STOCKAVGDAY, 0)), 0) AS STOCKQTY_DISP_STOCKDAY /* 기존재고 보유일 */
		FROM FINAL A
		ORDER BY CUSTKEY, LEADTIME, HOLDING_DAYS, NEAR_ROP, NUM_PLT
	</select>
	
	<select id="getMasterListOut" resultType="OmPurchaseStorageAutoTotalResDto">
	    /* [omPurchaseStorageAutoTotalService.sqlx][omPurchaseStorageAutoTotalService.getMasterListOut] */
	    WITH T_ST_STOCK_PURCHASE AS ( /* 2026.01.30 CJ프레시웨이 WMS 구축  추가(ST_STOCK->VW_ST_STOCK, T_ST_STOCK_PURCHASE->T_T_ST_STOCK_PURCHASE) */
			SELECT ST_STOCK.DCCODE       AS  DCCODE
			    ,ST_STOCK.STORERKEY    AS  STORERKEY
			    ,ST_STOCK.ORGANIZE     AS  ORGANIZE
			    ,ST_STOCK.AREA         AS  AREA
			    ,ST_STOCK.SKU          AS  SKU
			    ,MAX(MS_SKU.DESCRIPTION)    AS  DESCRIPTION
			    ,ST_STOCK.UOM          AS  UOM
			    ,SUM(ST_STOCK.QTY)     AS  QTY
			    ,SUM(ST_STOCK.BOXQTY)  AS  BOXQTY
			    ,SUM(CASE WHEN (ST_STOCK.QTY-ST_STOCK.QTYALLOCATED-ST_STOCK.QTYPICKED)  <![CDATA[<]]>  0  THEN 0
			        ELSE ST_STOCK.QTY-ST_STOCK.QTYALLOCATED-ST_STOCK.QTYPICKED
			       END ) as OPENQTY
			    ,MAX(MS_LOCATION.PLT_FLG) AS PLT_FLG
			FROM   VW_ST_STOCK ST_STOCK
			JOIN   MS_SKU
			ON     MS_SKU.STORERKEY        = ST_STOCK.STORERKEY
			AND    MS_SKU.SKU              = ST_STOCK.SKU
			JOIN   MS_LOCATION
			ON     MS_LOCATION.DCCODE      = ST_STOCK.DCCODE
			AND    MS_LOCATION.LOC         = ST_STOCK.LOC
			AND    MS_LOCATION.LOCTYPE     IN ('STAGE','PICK','KEEP','CROSS','FIRSTOUT','LONGSTAY','CANCEL')
			AND    ((MS_LOCATION.LOCCATEGORY IN ('RACK','YARD') AND ST_STOCK.DCCODE NOT IN ('2690','2620')) OR (MS_LOCATION.LOCCATEGORY IN ('RACK','YARD','AUTO') AND ST_STOCK.DCCODE IN ('2690','2620')))
			AND    MS_LOCATION.LOCFLAG     = 'GOOD'
			AND    CASE WHEN MS_LOCATION.DCCODE = '2690' AND MS_LOCATION.LOCTYPE='STAGE' THEN 'Y'
			      WHEN MS_LOCATION.DCCODE = '2600' AND MS_LOCATION.LOCTYPE='STAGE' THEN 'Y'
			      ELSE MS_LOCATION.OUT_YN
			    END = 'Y'
			AND    MS_LOCATION.DEL_YN      = 'N'
			AND    MS_LOCATION.STOCKTYPE   = 'GOOD'
			JOIN   CM_LOT
			ON     CM_LOT.STORERKEY        = ST_STOCK.STORERKEY
			AND    CM_LOT.LOT              = ST_STOCK.LOT
			AND    'TRUE' = CASE
			           WHEN CM_LOT.LOTTABLE01   = 'STD' OR  MS_SKU.DURATIONTYPE = 'N'
			           THEN 'TRUE'
			           WHEN     MS_SKU.DURATIONTYPE = '1' AND FN_ISDATE(CM_LOT.LOTTABLE01) = 1
			              AND TO_DATE(CM_LOT.LOTTABLE01,'YYYYMMDD')  <![CDATA[<]]>  TRUNC(SYSDATE)
			           THEN 'FALSE'
			           WHEN     MS_SKU.DURATIONTYPE IN ('2','3') AND FN_ISDATE(CM_LOT.LOTTABLE01) = 1
			              AND TO_DATE(CM_LOT.LOTTABLE01,'YYYYMMDD') + MS_SKU.DURATION - 1  <![CDATA[<]]>  TRUNC(SYSDATE)
			           THEN 'FALSE'
			           ELSE 'TRUE'
			        END
			WHERE 1=1
			AND ST_STOCK.STOCKGRADE = 'STD'  
			    GROUP BY ST_STOCK.DCCODE
			        ,ST_STOCK.STORERKEY
			        ,ST_STOCK.ORGANIZE
			        ,ST_STOCK.AREA
			        ,ST_STOCK.SKU
			        ,ST_STOCK.UOM
		),
	    BASE AS (
	        SELECT K.CUSTKEY
	             , K.CUSTNAME
	             , K.ROUTE
	             , K.ROUTEORGANIZE
	             , K.ROUTEORGANIZENM
	             , K.DCCODE
	             , K.DCNAME
	             , K.ORGANIZE
	             , K.ORGANIZENAME
	             , K.SKU
	             , K.SKUNAME
	             , K.DELIVERYTYPE
	             , K.VAL_FN_GETDAYCOUNT
	             , K.BUYERKEY
	             , K.CONTROLTYPE
	             , CASE WHEN TO_CHAR(SYSDATE,'YYYYMMDD') <![CDATA[<]]> K.CONTROL_TODATE AND K.CONTROL_FROMDATE IS NOT NULL AND K.CONTROL_FROMDATE <![CDATA[<=]]> K.CONTROL_TODATE THEN K.CONTROL_FROMDATE
	                    ELSE NULL
	               END AS CONTROL_FROMDATE
	             , CASE WHEN TO_CHAR(SYSDATE,'YYYYMMDD') <![CDATA[<]]> K.CONTROL_TODATE AND K.CONTROL_TODATE IS NOT NULL AND K.CONTROL_FROMDATE <![CDATA[<=]]> K.CONTROL_TODATE THEN K.CONTROL_TODATE
	                    ELSE NULL
	               END AS CONTROL_TODATE
	             , K.QTY
	             , K.SHIPQTY
	             , K.VENDORCONFIRMQTY
	             , K.RECEIVEQTY
	             , K.AFRECEIVEQTY
	             , K.ETC_QTY1
	             , K.ETC_QTY2
	             , K.ETC_QTY3
	             , K.STOCKQTY
	             , K.BOXQTY
	             , K.STOCKQTY_DISP
	             , K.REORDERPOINT
	             , K.STOCKGOAL
	             , K.UOM
	             , K.STOCKAVGDAY
	             , K.MAXSTOCK
	             , K.SHIPDAY1W
	             , K.SHIPDAY2W
	             , K.SHIPDAY3W
	             , K.SHIPQTYCHG1W
	             , K.SHIPQTYCHG2W
	             , K.SHIPQTYCHG3W
	             , K.SHIPQTY1W
	             , K.SHIPQTY2W
	             , K.SHIPQTY3W
	             , K.ORDCNT1W
	             , K.ORDCNT2W
	             , K.ORDCNT3W
	             , K.PURCHASEUOM
	             , K.BOXPERQTY
	             , K.DURATION
	             , K.REFERENCE01
	             , K.REFERENCE02
	             , K.REFERENCE03
	             , K.REFERENCE06
	             , K.EXECDAY
	             , K.AUTO_EXECDAY
	             , K.STD_DT
	             , K.PURCHASETYPE
	             , K.PLANT
	             , K.STORAGETYPE
	             , K.STORAGETYPENM
	             , K.PURCHASEGROUP
	             , K.MINORDERQTY
	             , K.LAYERPERPLT
	             , K.BOXPERLAYER
	             , K.COEFFICIENTSAFETY
	             , K.LEADTIME
	             , K.PURINTERVAL
	             , K.DELIVERYWEEK
	             , K.RETURNTYPE
	             , K.SERIALKEY
	             , K.STORERKEY
	             , K.CUSTTYPE
	             , K.CUSTTYPENM
	             , K.AREA
	             , K.CHANNEL
	             , K.BUNJA
	             , K.BUNMO
	             , K.PALLETUNIT
	             , K.PODT
	             , K.FROM_DCCODE
	             , K.FROM_ORGANIZE
	             , K.EMPTYFIELD
	             , K.STD
	             , K.ZERO
	             , K.CHANNELNM
	             , K.SERIALYN
	             , K.LINE01
	             , K.LINE02
	             , K.BUNJA_CAL
	             , K.BUNMO_CAL
	             , K.REFERENCE04
	             , K.ADDWHO
	             , K.ADDDATE
	             , K.EDITWHO
	             , K.EDITDATE
	             , K.STOCKQTY_CONTRACT
	             , K.STOCKQTY_OUTDISP
	             , K.STOCKDAY
	             , K.PSBQTY
	             , K.PSBQTY2
	             , K.RECEIVEDT
	             , K.RECEIVEDT2
	             , K.POUNIT
	             , K.ORDEREDQTY	             
	             , CASE WHEN K.REORDERPOINT <![CDATA[>]]> ((K.PSBQTY + K.AFRECEIVEQTY) + K.RECEIVEQTY) THEN
	                   1
	               ELSE
	                   0
	               END AS DUMCOMPANY <!-- 덤발주 대상 업체 확인을 위해 화면상에서 업체별 합계가 0보다 클경우 덤발주 대상 업체임 -->
	             , CASE WHEN ((K.REORDERPOINT <![CDATA[<]]> (K.PSBQTY + K.AFRECEIVEQTY)) AND ((K.STOCKGOAL - K.REORDERPOINT) * 0.5 + K.REORDERPOINT <![CDATA[>]]> (K.PSBQTY + K.AFRECEIVEQTY))) THEN
	                   'Y'
	               ELSE
	                   'N'
	               END AS DUMYN <!-- 덤발주 대상 상품 여부 확인 [(목표재고-재발주점)*0.5+재발주점 > 가용재고]  -->
	             , (K.STOCKGOAL - K.REORDERPOINT) DUMQTY <!-- 덤발주 수량 [목표재고-가용재고]  -->
	             , CASE WHEN NVL(K.VENDORCONFIRMQTY, 0) = 0 AND NVL(K.ORDEREDQTY, 0) = 0 THEN ''
	                    WHEN NVL(K.VENDORCONFIRMQTY, 0) != 0 AND NVL(K.ORDEREDQTY, 0) = 0 THEN 'icon_bbs03'
	                    WHEN ceil(NVL(K.VENDORCONFIRMQTY, 0) / NVL(K.ORDEREDQTY, 0) * 100) <![CDATA[<]]> 80 THEN 'icon_bbs01'
	                    ELSE 'icon_bbs03'
	               END AS VENDORCONFIRM_STATUS
	             , CASE K.PURCHASETYPE <!-- 발주구분에 따른 산출량 조정 20150824 김영문님 요청 -->
	                   WHEN 'STO-ADD' THEN 0
	                   ELSE CEIL(CASE WHEN SUM(CASE WHEN K.REORDERPOINT - (K.PSBQTY + K.AFRECEIVEQTY) <![CDATA[>]]> 0 THEN 1 ELSE 0 END) OVER (PARTITION BY K.CUSTKEY, K.CUSTTYPE) <![CDATA[>]]> 0 THEN
	                       CASE WHEN K.REORDERPOINT <![CDATA[>]]> (K.PSBQTY + K.AFRECEIVEQTY) THEN
	                           CASE WHEN K.STOCKGOAL - (K.PSBQTY + K.AFRECEIVEQTY) <![CDATA[>]]> K.MINORDERQTY * K.BOXPERQTY THEN
	                               K.STOCKGOAL - (K.PSBQTY + K.AFRECEIVEQTY)
	                           ELSE K.MINORDERQTY * K.POUNIT
	                           END
	                       ELSE
	                           CASE WHEN ((K.REORDERPOINT <![CDATA[<]]> (K.PSBQTY + K.AFRECEIVEQTY)) AND ((K.STOCKGOAL - K.REORDERPOINT) * 0.5 + K.REORDERPOINT <![CDATA[>]]> (K.PSBQTY + K.AFRECEIVEQTY))) THEN
	                               (K.STOCKGOAL - (K.PSBQTY + K.AFRECEIVEQTY))
	                           ELSE
	                               0
	                           END
	                       END
	                   ELSE
	                       0
	                   END / (K.POUNIT))
	               END AS CONFIRMQTY_ADD <!-- 최종 발주산출량 -->
	             , CASE WHEN K.REORDERPOINT <![CDATA[>]]> ((K.PSBQTY + K.AFRECEIVEQTY) + K.RECEIVEQTY) THEN <!-- [재발주점 > 가용재고+입고예정(당일)]  -->
	                   CASE WHEN K.STOCKGOAL - (K.PSBQTY + K.AFRECEIVEQTY) - K.AFRECEIVEQTY <![CDATA[>]]> K.MINORDERQTY * K.POUNIT THEN <!-- 최소발주량 보다 작을경우 최소발주량으로 -->
	                       (K.STOCKGOAL - (K.PSBQTY + K.AFRECEIVEQTY) - K.AFRECEIVEQTY) / K.POUNIT <!-- [목표재고 - 가용재고 - 입고예정(당일이후)] -->
	                   ELSE K.MINORDERQTY
	                   END
	               ELSE
	                   0
	               END AS CONFIRMQTY <!-- 외부창고 이체에선 덤발주 사용 안함 -->
	             , K.CONFIRMQTY_EDIT_YN
	             , (SELECT FN_CONV_UOM(K.STORERKEY, K.SKU, K.PURCHASEUOM, 'EA', 1) FROM DUAL) AS EA_CAL
	             , (SELECT FN_CONV_UOM(K.STORERKEY, K.SKU, K.PURCHASEUOM, 'KG', 1) FROM DUAL) AS KG_CAL
	             , (SELECT FN_CONV_UOM(K.STORERKEY, K.SKU, K.PURCHASEUOM, 'BOX', 1) FROM DUAL) AS BOX_CAL
	             , K.RECEIVEDT AS RECEIVEDT_CAL
	             , CASE WHEN TO_NUMBER(NVL(K.LINE02, 0)) != 0
	                    AND K.CUSTKEY = '2170'
	                    AND NVL(K.LINE01, 'N') LIKE 'Y%' THEN TO_NUMBER(NVL(K.LINE02, 0))
	                    ELSE 0
	               END AS AVGWEIGHT
	             , 0 AS CALBOX
	             , 0 AS REALORDERBOX
	             , 0 AS REALCFMBOX
	             , 0 AS TRANBOX
	             , 0 AS EA
	             , 0 AS KG
	             , ((NVL(STOCKQTY_CONTRACT, 0) + NVL(STOCKQTY_OUTDISP, 0))) / BOXPERQTY AS BOX
	             , CASE WHEN K.CUSTKEY = '2170'
	                    AND NVL(K.LINE01, 'N') LIKE 'Y%' THEN 'Y'
	                    ELSE 'N'
	               END AS BOXFLAG
	             , K.MON_YN, K.TUE_YN, K.WED_YN, K.THU_YN, K.FRI_YN, K.SAT_YN, K.SUN_YN
	             , K.STOP_STATUS
	             , K.STOP_INFO
	             , K.ORD1DAY, K.ORD2DAY, K.ORD3DAY, K.ORD4DAY, K.ORD5DAY, K.ORD6DAY, K.ORD7DAY
	             , K.ORD8DAY, K.ORD9DAY, K.ORD10DAY, K.ORD11DAY, K.ORD12DAY, K.ORD13DAY, K.ORD14DAY
	             , K.ORDERQTY_UNIT
	             , K.QTYPICKED
	             , K.MOVE_CONFIRMQTY
	             , (K.PSBQTY2 + K.MOVE_CONFIRMQTY) AS FUSIBILITYQTY
	             , (K.STOCKQTY_DISP - K.QTY) AS FUSIBILITYQTY2
	             , ROUND(K.CONFIRMQTY1WEEK, 2) AS CONFIRMQTY1WEEK
	             , ROUND(K.CONFIRMQTY2WEEK, 2) AS CONFIRMQTY2WEEK
	             , ROUND(K.CONFIRMQTY3WEEK, 2) AS CONFIRMQTY3WEEK
	             , ROUND(K.CONFIRMQTY4WEEK, 2) AS CONFIRMQTY4WEEK
	             , K.LABEL
	             , ROUND(K.CONFIRMQTY1MONTH, 2) AS CONFIRMQTY1MONTH
	             , ROUND(K.CONFIRMQTY1MONTHAVG, 2) AS CONFIRMQTY1MONTHAVG
	             , CASE WHEN K.STOCKAVGDAY = 0 OR K.CONFIRMQTY1MONTHAVG = 0 THEN ''
	                    WHEN (K.CONFIRMQTY1MONTHAVG / K.STOCKAVGDAY) * 100 <![CDATA[>=]]> 150 THEN 'icon_bbs01'
	                    WHEN (K.CONFIRMQTY1MONTHAVG / K.STOCKAVGDAY) * 100 <![CDATA[<=]]> 50 THEN 'icon_bbs02'
	                    ELSE 'icon_bbs03'
	               END AS CONFIRMQTYCHECK
	             , K.BOXPERPLT
	             , TO_NUMBER(K.MOQ_SKU) AS MOQ_SKU
	             , K.LEADTIME2
	             , NVL(K.BOXPERPLT_QTY, 0) AS BOXPERPLT_QTY
	             , K.DURATION_TERM
	             , K.TPL_SKUGROUP
	             , K.EMPNAME1, K.EMPNAME2, K.EMPNAME3, K.EMPNAME4, K.EMPNAME5
	             , K.EMPPHONE1, K.EMPPHONE2, K.EMPPHONE3, K.EMPPHONE4, K.EMPPHONE5
	             , K.SLAVE_CUSTKEY
	             , K.SLAVE_CUSTNAME
	             , K.EXHAUSTION_STOP_YN
	             , K.STOCKSAFETY2
	             , K.STOCKDAY2
	             , K.PRE_OPENQTY
	             , K.CUSTSKU
	             , K.REFERENCE07
	             , K.BIZDATE
	             , CASE WHEN DATEDIFF <![CDATA[>=]]> 20 THEN K.BIZDATE * K.STOCKAVGDAY
	                    WHEN DATEDIFF = 1 THEN CASE WHEN (K.AFTERDAYWDQTY01 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY01 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 2 THEN CASE WHEN (K.AFTERDAYWDQTY02 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY02 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 3 THEN CASE WHEN (K.AFTERDAYWDQTY03 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY03 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 4 THEN CASE WHEN (K.AFTERDAYWDQTY04 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY04 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 5 THEN CASE WHEN (K.AFTERDAYWDQTY05 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY05 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 6 THEN CASE WHEN (K.AFTERDAYWDQTY06 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY06 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 7 THEN CASE WHEN (K.AFTERDAYWDQTY07 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY07 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 8 THEN CASE WHEN (K.AFTERDAYWDQTY08 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY08 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 9 THEN CASE WHEN (K.AFTERDAYWDQTY09 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY09 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 10 THEN CASE WHEN (K.AFTERDAYWDQTY10 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY10 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 11 THEN CASE WHEN (K.AFTERDAYWDQTY11 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY11 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 12 THEN CASE WHEN (K.AFTERDAYWDQTY12 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY12 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 13 THEN CASE WHEN (K.AFTERDAYWDQTY13 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY13 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 14 THEN CASE WHEN (K.AFTERDAYWDQTY14 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY14 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 15 THEN CASE WHEN (K.AFTERDAYWDQTY15 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY15 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 16 THEN CASE WHEN (K.AFTERDAYWDQTY16 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY16 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 17 THEN CASE WHEN (K.AFTERDAYWDQTY17 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY17 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 18 THEN CASE WHEN (K.AFTERDAYWDQTY18 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY18 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                    WHEN DATEDIFF = 19 THEN CASE WHEN (K.AFTERDAYWDQTY19 <![CDATA[>]]> K.BIZDATE * K.STOCKAVGDAY) THEN K.AFTERDAYWDQTY19 ELSE (K.BIZDATE * K.STOCKAVGDAY) END
	                END AS DATEDIFF_QTY
	             , K.AFTERDAYWDQTY01, K.AFTERDAYWDQTY02, K.AFTERDAYWDQTY03, K.AFTERDAYWDQTY04, K.AFTERDAYWDQTY05
	             , K.AFTERDAYWDQTY06, K.AFTERDAYWDQTY07, K.AFTERDAYWDQTY08, K.AFTERDAYWDQTY09, K.AFTERDAYWDQTY10
	             , K.AFTERDAYWDQTY11, K.AFTERDAYWDQTY12, K.AFTERDAYWDQTY13, K.AFTERDAYWDQTY14, K.AFTERDAYWDQTY15
	             , K.AFTERDAYWDQTY16, K.AFTERDAYWDQTY17, K.AFTERDAYWDQTY18, K.AFTERDAYWDQTY19, K.AFTERDAYWDQTY20
	             , K.DIRECTDLV_CUSTKEY, K.DIRECTDLV_ORDERQTY, K.DIRECTDLV_UOM, K.DIRECTDLV_FROM_DCCODE
	             , K.EXCPT_DP_APPR_YN, K.PLTTRANS
	             , (K.REORDERPOINT - (K.PSBQTY + K.RECEIVEQTY)) AS NEAR_ROP
		         , CASE WHEN K.EXHAUSTION_STOP_YN = 'Y' THEN 0
		           ELSE
		             CASE K.PURCHASETYPE 
		                 WHEN 'STO-ADD' THEN 0   
		                 ELSE CEIL(CASE WHEN SUM(CASE WHEN K.REORDERPOINT - (K.PSBQTY2+K.AFRECEIVEQTY) <![CDATA[>]]> 0 THEN 1 ELSE 0 END) OVER (PARTITION BY K.CUSTKEY,K.CUSTTYPE) <![CDATA[>]]> 0 THEN 
		                               CASE WHEN K.REORDERPOINT <![CDATA[>]]> (K.PSBQTY2+K.AFRECEIVEQTY) THEN
		                                        CASE WHEN K.STOCKGOAL - (K.PSBQTY2+K.AFRECEIVEQTY) <![CDATA[>]]> K.MINORDERQTY * K.BOXPERQTY THEN
		                                             NVL((K.MINORDERQTY * K.BOXPERQTY) + (CEIL(( K.STOCKGOAL - (K.MINORDERQTY * K.BOXPERQTY) - (K.PSBQTY2+K.AFRECEIVEQTY)) / DECODE(K.ORDERQTY_UNIT,0,1,NULL,1,K.ORDERQTY_UNIT)) * DECODE(K.ORDERQTY_UNIT,0,1,NULL,1,K.ORDERQTY_UNIT)),0)
		                                        ELSE K.MINORDERQTY * K.POUNIT
		                                        END
		                                   ELSE
		                                        CASE WHEN ((K.REORDERPOINT <![CDATA[<]]> (K.PSBQTY2+K.AFRECEIVEQTY)) AND ((K.STOCKGOAL - K.REORDERPOINT)* 0.5 + K.REORDERPOINT <![CDATA[>]]> (K.PSBQTY2 + K.AFRECEIVEQTY))) THEN
		                                             NVL((K.MINORDERQTY * K.BOXPERQTY) + (CEIL(( K.STOCKGOAL - (K.MINORDERQTY * K.BOXPERQTY) - (K.PSBQTY2+K.AFRECEIVEQTY)) / DECODE(K.ORDERQTY_UNIT,0,1,NULL,1,K.ORDERQTY_UNIT)) * DECODE(K.ORDERQTY_UNIT,0,1,NULL,1,K.ORDERQTY_UNIT)),0)
		                                             ELSE 0
		                                          END
		                                   END
		                          ELSE 
		                                0 
		                           END/(K.POUNIT)) 
		             END 
		           END AS BASE_ORDERQTY
		          , NVL(K.MOQ_VENDER_PLT, K.MOQ_VENDER / K.PALLETUNIT) AS MOQ
		          , K.CONVSERIALNO, K.CONTRACTTYPE, K.PO_HOLD_YN, K.MOQ_SKU_PLT, K.MOQ_VENDER, K.MOQ_VENDER_PLT
		          , K.OUTORGANIZE, K.OUTORGANIZENAME, K.ADDRESS, K.SERIALNO, K.CONTRACTCUSTKEY, K.CONTRACTCUSTNM
		          , K.STOCKID
		          , K.STOCKGRADE
		          , K.STOCKTYPE
		          , K.WD_INPLAN_QTY
		          , K.TAXCODE
	          FROM (SELECT SS.*
	                     , CASE WHEN NVL(SS.STOCKAVGDAY, 0) = 0 THEN 0
	                            ELSE ROUND(SS.STOCKQTY / SS.STOCKAVGDAY)
	                       END AS STOCKDAY
	                     , SS.STOCKQTY + SS.RECEIVEQTY - SS.QTY AS PSBQTY
	                     , SS.STOCKQTY_DISP + SS.RECEIVEQTY - SS.QTY AS PSBQTY2
	                     , CASE WHEN SS.PURCHASETYPE IN ('STO', 'STO-ADD', 'STO-AUTO') THEN TO_CHAR(SYSDATE + 1, 'YYYYMMDD')
	                            ELSE FN_CONV_RECEIVEDT(SYSDATE, NVL(SS.LEADTIME, 1) + SS.VAL_FN_GETDAYCOUNT, SS.SUN_YN, SS.MON_YN, SS.TUE_YN, SS.WED_YN, SS.THU_YN, SS.FRI_YN, SS.SAT_YN)
	                       END AS RECEIVEDT
	                     , CASE WHEN SS.PURCHASETYPE IN ('STO', 'STO-ADD', 'STO-AUTO') THEN TO_CHAR(SYSDATE + 1, 'YYYYMMDD')
	                            ELSE FN_CONV_RECEIVEDT(SYSDATE, NVL(SS.LEADTIME, 1) + SS.VAL_FN_GETDAYCOUNT2, SS.SUN_YN, SS.MON_YN, SS.TUE_YN, SS.WED_YN, SS.THU_YN, SS.FRI_YN, SS.SAT_YN)
	                       END AS RECEIVEDT2
	                     , TO_DATE(CASE WHEN SS.PURCHASETYPE IN ('STO', 'STO-ADD', 'STO-AUTO') THEN TO_CHAR(SYSDATE + 1, 'YYYYMMDD')
	                                   ELSE FN_CONV_RECEIVEDT(SYSDATE, NVL(SS.LEADTIME, 1) + SS.VAL_FN_GETDAYCOUNT, SS.SUN_YN, SS.MON_YN, SS.TUE_YN, SS.WED_YN, SS.THU_YN, SS.FRI_YN, SS.SAT_YN)
	                               END, 'YYYYMMDD') - TRUNC(SYSDATE) AS DATEDIFF
	                     , CASE WHEN SS.PURCHASETYPE IN ('STO', 'STO-ADD', 'STO-AUTO') THEN '1' - FN_GETDAYCOUNT(TO_CHAR(SYSDATE, 'YYYYMMDD'), TO_CHAR(SYSDATE + 1, 'YYYYMMDD'), '1')
	                            ELSE (TO_DATE(FN_CONV_RECEIVEDT(SYSDATE, NVL(SS.LEADTIME, 1) + SS.VAL_FN_GETDAYCOUNT, SS.SUN_YN, SS.MON_YN, SS.TUE_YN, SS.WED_YN, SS.THU_YN, SS.FRI_YN, SS.SAT_YN), 'YYYYMMDD') - TRUNC(SYSDATE)) - FN_GETDAYCOUNT(TO_CHAR(SYSDATE, 'YYYYMMDD'), FN_CONV_RECEIVEDT(SYSDATE, NVL(SS.LEADTIME, 1) + SS.VAL_FN_GETDAYCOUNT, SS.SUN_YN, SS.MON_YN, SS.TUE_YN, SS.WED_YN, SS.THU_YN, SS.FRI_YN, SS.SAT_YN), '1')
	                       END AS BIZDATE
	                     , SS.BUNJA / SS.BUNMO AS POUNIT
	                     , (SELECT SUM(DP_PURCHASE.ORDERQTY)
	                          FROM DP_PURCHASE
	                         WHERE DP_PURCHASE.STORERKEY = SS.STORERKEY AND DP_PURCHASE.DCCODE = SS.DCCODE AND DP_PURCHASE.ORGANIZE = SS.ORGANIZE
	                           AND DP_PURCHASE.AREA = SS.AREA AND DP_PURCHASE.SKU = SS.SKU
	                           AND DP_PURCHASE.REQUESTDT <![CDATA[>=]]> TO_CHAR(SYSDATE, 'YYYYMMDD') <!-- 당일이후 입고되는 발주 수량 모든 총수량 나오도록 수정 요청 함일수님 20151030 -->
	                           AND DP_PURCHASE.CUSTKEY = SS.CUSTKEY AND DP_PURCHASE.CUSTTYPE = SS.CUSTTYPE AND DP_PURCHASE.DEL_YN = 'N') AS ORDEREDQTY
	                     , (SS.CONFIRMQTY1WEEK + SS.CONFIRMQTY2WEEK + SS.CONFIRMQTY3WEEK + SS.CONFIRMQTY4WEEK) AS CONFIRMQTY1MONTH
	                     , CASE WHEN (SS.CONFIRMQTY1WEEK + SS.CONFIRMQTY2WEEK + SS.CONFIRMQTY3WEEK + SS.CONFIRMQTY4WEEK) = 0 THEN 0 ELSE ((SS.CONFIRMQTY1WEEK + SS.CONFIRMQTY2WEEK + SS.CONFIRMQTY3WEEK + SS.CONFIRMQTY4WEEK) / 24) END AS CONFIRMQTY1MONTHAVG
	                     , CASE WHEN SS.BUYERKEY_TYPE = 'P' THEN NVL((SELECT SUM(ST_STOCK.QTYPICKED) FROM VW_ST_STOCK ST_STOCK WHERE ST_STOCK.STORERKEY = SS.STORERKEY AND ST_STOCK.DCCODE = SS.DCCODE AND ST_STOCK.SKU = SS.SKU), 0) ELSE 0 END AS QTYPICKED
	                     , CASE WHEN SS.BUYERKEY_TYPE = 'P' THEN
	                           NVL((SELECT SUM((DMD.CONFIRMQTY - (SELECT SUM(DECODE(T.CONFIRMQTY, NULL, DMD.CONFIRMQTY, T.CONFIRMQTY))
	                                FROM DM_DOCUMENT_D T
	                               WHERE T.DELIVERYDATE BETWEEN TO_CHAR(TO_DATE(#{stdDt}, 'YYYYMMDD'), 'YYYYMMDD') AND TO_CHAR(TO_DATE(#{stdDt}, 'YYYYMMDD') + TO_NUMBER('2'), 'YYYYMMDD')
	                                 AND T.DOCNO = DMD.DOCNO AND T.DOCLINE = DMD.DOCLINE AND T.DCCODE != DMD.DCCODE
	                                 AND T.WORKPROCESSCODE = 'STO' AND T.DOCTYPE = 'DP')))
	                                FROM DM_DOCUMENT_D DMD
	                               WHERE DMD.DELIVERYDATE BETWEEN TO_CHAR(TO_DATE(#{stdDt}, 'YYYYMMDD'), 'YYYYMMDD') AND TO_CHAR(TO_DATE(#{stdDt}, 'YYYYMMDD') + TO_NUMBER('2'), 'YYYYMMDD')
	                                 AND DMD.STORERKEY = SS.STORERKEY AND DMD.DCCODE = SS.DCCODE AND DMD.SKU = SS.SKU
	                                 AND DMD.DOCTYPE = 'WD' AND DMD.DEL_YN = 'N' AND DMD.WORKPROCESSCODE = 'STO'), 0)
	                           ELSE 0
	                       END AS MOVE_CONFIRMQTY
	                     , CEIL(SS.STOCKSAFETY2) AS STOCKSAFETY3
	                     , NVL(FLOOR(SS.STOCKSAFETY2 / NULLIF(SS.STOCKAVGDAY, 0)), 0) AS STOCKDAY2
	                     , FLOOR(SS.STOCKAVGDAY + (SS.STOCKSAFETY2 / NULLIF(LEADTIME, 0))) AS PRE_OPENQTY	      
	                  FROM (
	                        SELECT
	                          CASE WHEN MS_PURCHASECUST.CUSTKEY LIKE '2170-%' THEN '2170' ELSE TO_CHAR(MS_PURCHASECUST.CUSTKEY) END AS CUSTKEY
	                          , CASE WHEN MS_PURCHASECUST.CUSTKEY LIKE '2170-%' THEN '외부창고' ELSE TO_CHAR(MS_CUST.DESCRIPTION) END AS CUSTNAME
	                          , NVL(MS_PURCHASEMST.ROUTE, MS_PURCHASECUST.ROUTE) AS ROUTE
	                          , NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) AS ROUTEORGANIZE
	                          , NVL(DCXORG.DESCRIPTION, DCXORGNVL.DESCRIPTION) AS ROUTEORGANIZENM
	                          , MS_PURCHASECUST.DCCODE, CM_DC.DCNAME
	                          , NVL(MS_PURCHASESTATS.ORGANIZE, '') AS ORGANIZE /* 20260120 MS_PURCHASECUST.DCCODE nvl 제거 */
	                          , CM_DCXORGANIZE.DESCRIPTION AS ORGANIZENAME, MS_PURCHASECUST.SKU, MS_SKU.DESCRIPTION AS SKUNAME
	                          , (SELECT FN_CODEDESCR(MS_PURCHASEMST.STORERKEY, 'DIRECTTYPE', MS_PURCHASEMST.DELIVERYTYPE) FROM DUAL) AS DELIVERYTYPE
	                          , (SELECT FN_GETDAYCOUNT(TO_CHAR(SYSDATE, 'YYYYMMDD'), TO_CHAR(SYSDATE + NVL(MS_PURCHASEMST.LEADTIME, 1), 'YYYYMMDD'), 1) FROM DUAL) AS VAL_FN_GETDAYCOUNT
	                          , (SELECT FN_GETDAYCOUNT(TO_CHAR(SYSDATE, 'YYYYMMDD'), TO_CHAR(SYSDATE + NVL(MS_PURCHASEMST.LEADTIME, 1), 'YYYYMMDD'), 1) 
	                                  + FN_GETDAYCOUNT(TO_CHAR(SYSDATE, 'YYYYMMDD'), TO_CHAR(SYSDATE + NVL(MS_PURCHASEMST.LEADTIME, 1), 'YYYYMMDD'), 7) FROM DUAL) AS VAL_FN_GETDAYCOUNT2
	                          <!-- 입고예정일
					               발주일로부터 리드타임 기간내 일요일은 제외함
					               입고일이 일요일인경우 휴일여부(토요일 가능여부)에 따라 가능인경우 전일인 토요일로 불가인경우 다음날 월요일로 지정
					               입고일이 토요일인경우 휴일여부(토요일 가능여부)에 따라 가능인경우 토요일로  불가인경우 전날인 금요일로 지정
					               EX)리드타임은 최대 15일까지 있음
					           -->
	                          , MS_PURCHASEMST.BUYERKEY <!-- 수급담당 -->
	                          , CASE WHEN MS_PURCHASECUST.CUSTKEY LIKE '2170-%' THEN
	                                    (SELECT FN_CODEDESCR('FW00', 'CONTROLTYPE', MIN(CONTROLTYPE_TB.CONTROLTYPE) KEEP (DENSE_RANK FIRST ORDER BY CONTROLTYPE_TB.FROMDATE DESC, CONTROLTYPE_TB.TODATE ASC))
	                                       FROM MS_PURCHASECUST CONTROLTYPE_TB
	                                      WHERE 1=1
	                                      <if test='multiDcCode != null and multiDcCode.length > 0'>
										    AND CONTROLTYPE_TB.DCCODE IN
									        <foreach collection="multiDcCode" item="dccodeItem" open="(" separator="," close=")">
									            #{dccodeItem}
									        </foreach>
										  </if>
										    AND CONTROLTYPE_TB.STORERKEY = 'FW00' AND CONTROLTYPE_TB.SKU = MS_PURCHASECUST.SKU
	                                        AND CONTROLTYPE_TB.CUSTTYPE = 'P' AND TO_CHAR(SYSDATE, 'YYYYMMDD') BETWEEN CONTROLTYPE_TB.FROMDATE AND CONTROLTYPE_TB.TODATE AND CONTROLTYPE_TB.DEL_YN = 'N')
	                                 ELSE (SELECT CASE WHEN TO_CHAR(SYSDATE, 'YYYYMMDD') BETWEEN MS_PURCHASECUST.CONTROL_FROMDATE AND MS_PURCHASECUST.CONTROL_TODATE THEN FN_CODEDESCR(MS_PURCHASECUST.STORERKEY, 'CONTROLTYPE', MS_PURCHASECUST.CONTROLTYPE)
	                                                   WHEN TO_CHAR(MS_PURCHASECUST.EDITDATE, 'YYYYMMDD') <![CDATA[<]]> '20210901' THEN (SELECT FN_CODEDESCR(MS_PURCHASECUST.STORERKEY, 'CONTROLTYPE', MS_PURCHASECUST.CONTROLTYPE) FROM DUAL)
	                                                   ELSE NULL
	                                              END FROM DUAL)
	                            END AS CONTROLTYPE
	                          , MS_PURCHASECUST.CONTROL_FROMDATE
	                          , MS_PURCHASECUST.CONTROL_TODATE
	                          , NVL((CASE WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) <![CDATA[<]]> 0 THEN 0
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 0 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY01
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 1 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY02
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 2 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY03
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 3 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY04
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 4 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY05
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 5 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY06
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 6 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY07
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 7 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY08
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 8 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY09
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 9 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY10
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 10 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY11
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 11 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY12
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 12 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY13
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 13 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY14
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 14 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY15
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 15 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY16
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 16 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY17
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 17 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY18
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) + (CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END) = 18 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY19
	                                     ELSE MS_PURCHASETOTAL.AFTERDAYWDQTY20
	                                END) -
	                               (CASE WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) <![CDATA[<]]> 0 THEN 0
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 0 THEN 0
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 1 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY01
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 2 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY02
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 3 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY03
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 4 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY04
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 5 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY05
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 6 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY06
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 7 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY07
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 8 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY08
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 9 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY09
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 10 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY10
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 11 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY11
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 12 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY12
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 13 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY13
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 14 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY14
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 15 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY15
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 16 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY16
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 17 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY17
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 18 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY18
	                                     WHEN TO_DATE(#{stdDt}, 'YYYYMMDD') - (TRUNC(SYSDATE) + 1) = 19 THEN MS_PURCHASETOTAL.AFTERDAYWDQTY19
	                                     ELSE MS_PURCHASETOTAL.AFTERDAYWDQTY20
	                                END), 0) AS QTY                                            <!-- 주문량 (C) 산정기간동안의 주문량(기간 : 산정기준일~산정기준일+산정기간) -->
	                          , NVL(MS_PURCHASETOTAL.TODAYWDQTY, 0) AS SHIPQTY                 <!-- 당일출고예정량(C) -->
	                          , NVL(MS_PURCHASETOTAL.VENDORCONFIRMQTY, 0) AS VENDORCONFIRMQTY  <!-- 업체확정량(C) -->
	                          , NVL(MS_PURCHASETOTAL.TODAYDPQTY, 0) AS RECEIVEQTY              <!-- 입고예정(당일)(C) -->
	                          , NVL(MS_PURCHASETOTAL.AFTERDAYDPQTY, 0) AS AFRECEIVEQTY         <!-- 입고예정(당일이후)(C) -->
	                          , NVL(MS_PURCHASETOTAL.ETC_QTY1, 0) AS ETC_QTY1                  <!-- 업체확정량(C) -->
	                          , NVL(MS_PURCHASETOTAL.ETC_QTY2, 0) AS ETC_QTY2                  <!-- 입고예정(당일)(C) -->
	                          , NVL(MS_PURCHASETOTAL.ETC_QTY3, 0) AS ETC_QTY3                  <!-- 입고예정(당일이후)(C) -->
	                          , NVL(CASE WHEN #{dcCode} = '2690' AND MS_PURCHASECUST.DCCODE = '1000' THEN 0 <!-- 20151109 2690센터는 1000센터 재고를 표시하지 않도록 수정(김영문님) -->
	                                     WHEN #{dcCode} = '1000' AND NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) IS NOT NULL THEN
	                                        (SELECT SUM(OPENQTY) FROM T_ST_STOCK_PURCHASE WHERE T_ST_STOCK_PURCHASE.STORERKEY = MS_PURCHASECUST.STORERKEY AND T_ST_STOCK_PURCHASE.DCCODE = MS_PURCHASECUST.DCCODE AND T_ST_STOCK_PURCHASE.ORGANIZE = NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) AND T_ST_STOCK_PURCHASE.SKU = MS_PURCHASECUST.SKU)
	                                     ELSE (SELECT SUM(OPENQTY) FROM T_ST_STOCK_PURCHASE WHERE T_ST_STOCK_PURCHASE.STORERKEY = MS_PURCHASECUST.STORERKEY AND T_ST_STOCK_PURCHASE.DCCODE = MS_PURCHASECUST.DCCODE AND T_ST_STOCK_PURCHASE.SKU = MS_PURCHASECUST.SKU)
	                                END, 0) AS STOCKQTY
	                          , NVL(CASE WHEN #{dcCode} = '2690' AND MS_PURCHASECUST.DCCODE = '1000' THEN 0 <!-- 20151109 2690센터는 1000센터 재고를 표시하지 않도록 수정(김영문님) -->
	                                     ELSE (SELECT SUM(BOXQTY) FROM T_ST_STOCK_PURCHASE WHERE T_ST_STOCK_PURCHASE.STORERKEY = MS_PURCHASECUST.STORERKEY AND T_ST_STOCK_PURCHASE.DCCODE = MS_PURCHASECUST.DCCODE AND T_ST_STOCK_PURCHASE.SKU = MS_PURCHASECUST.SKU)
	                                END, 0) AS BOXQTY
	                          , NVL(CASE WHEN #{dcCode} = '2690' AND MS_PURCHASECUST.DCCODE = '1000' THEN 0 <!-- 20151109 2690센터는 1000센터 재고를 표시하지 않도록 수정(김영문님) -->
	                                     WHEN #{dcCode} = '1000' AND NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) IS NOT NULL THEN
	                                        (SELECT SUM(QTY) FROM T_ST_STOCK_PURCHASE WHERE T_ST_STOCK_PURCHASE.STORERKEY = MS_PURCHASECUST.STORERKEY AND T_ST_STOCK_PURCHASE.DCCODE = MS_PURCHASECUST.DCCODE AND T_ST_STOCK_PURCHASE.ORGANIZE = NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) AND T_ST_STOCK_PURCHASE.SKU = MS_PURCHASECUST.SKU)
	                                     ELSE (SELECT SUM(QTY) FROM T_ST_STOCK_PURCHASE WHERE T_ST_STOCK_PURCHASE.STORERKEY = MS_PURCHASECUST.STORERKEY AND T_ST_STOCK_PURCHASE.DCCODE = MS_PURCHASECUST.DCCODE AND T_ST_STOCK_PURCHASE.SKU = MS_PURCHASECUST.SKU)
	                                END, 0) AS STOCKQTY_DISP <!-- 현재고 추가 20151102 신한섭님 요청사항 로직에는 반영안함 -->
	                          , CASE WHEN NVL(MS_PURCHASEMST.EDIT_REORDERPOINT, 0) <![CDATA[>]]> 0 THEN MS_PURCHASEMST.EDIT_REORDERPOINT
	                                 ELSE NVL(ROUND((MS_PURCHASESTATS.STOCKAVGDAY * NVL(MS_PURCHASEMST.LEADTIME, 1)) + (MS_PURCHASESTATS.STDDEVIATION * (NVL(MS_PURCHASEMST.COEFFICIENTSAFETY, 0)) * POWER(NVL(MS_PURCHASEMST.LEADTIME, 1), 1 / 2))), 0)
	                            END AS REORDERPOINT
	                          , CASE WHEN NVL(MS_PURCHASEMST.EDIT_STOCKGOAL, 0) <![CDATA[>]]> 0 THEN MS_PURCHASEMST.EDIT_STOCKGOAL
	                                 ELSE NVL(ROUND(MS_PURCHASESTATS.STOCKAVGDAY * (NVL(MS_PURCHASEMST.PURINTERVAL, 1) + NVL(MS_PURCHASEMST.LEADTIME, 1)) + ((3 * MS_PURCHASESTATS.STDDEVIATION) * POWER((NVL(MS_PURCHASEMST.PURINTERVAL, 1) + NVL(MS_PURCHASEMST.LEADTIME, 1)), 1 / 2))), 0)
	                            END AS STOCKGOAL
	                          , CASE WHEN MS_PURCHASEMST.EDIT_REORDERPOINT <![CDATA[>]]> 0 OR MS_PURCHASEMST.EDIT_STOCKGOAL <![CDATA[>]]> 0 THEN 'Y' ELSE 'N' END AS CONFIRMQTY_EDIT_YN
	                          , MS_SKU.BASEUOM AS UOM, MS_PURCHASESTATS.STOCKAVGDAY, MS_PURCHASESTATS.MAXSTOCK
	                          , 26 - NVL(MS_PURCHASESTATS.SHIPDAY1W, 0) AS SHIPDAY1W, 26 - NVL(MS_PURCHASESTATS.SHIPDAY2W, 0) AS SHIPDAY2W, 26 - NVL(MS_PURCHASESTATS.SHIPDAY3W, 0) AS SHIPDAY3W
	                          , CASE WHEN NVL(MS_PURCHASESTATS.SHIPQTY1W, 0) <![CDATA[>]]> NVL(MS_PURCHASESTATS.SHIPQTY2W, 0) THEN '1' WHEN NVL(MS_PURCHASESTATS.SHIPQTY1W, 0) <![CDATA[<]]> NVL(MS_PURCHASESTATS.SHIPQTY2W, 0) THEN '-1' ELSE '0' END AS SHIPQTYCHG1W
	                          , CASE WHEN NVL(MS_PURCHASESTATS.SHIPQTY2W, 0) <![CDATA[>]]> NVL(MS_PURCHASESTATS.SHIPQTY3W, 0) THEN '1' WHEN NVL(MS_PURCHASESTATS.SHIPQTY2W, 0) <![CDATA[<]]> NVL(MS_PURCHASESTATS.SHIPQTY3W, 0) THEN '-1' ELSE '0' END AS SHIPQTYCHG2W
	                          , '0' AS SHIPQTYCHG3W, NVL(MS_PURCHASESTATS.SHIPQTY1W, 0) AS SHIPQTY1W, NVL(MS_PURCHASESTATS.SHIPQTY2W, 0) AS SHIPQTY2W, NVL(MS_PURCHASESTATS.SHIPQTY3W, 0) AS SHIPQTY3W
	                          , NVL(MS_PURCHASESTATS.ORDCNT1W, 0) AS ORDCNT1W, NVL(MS_PURCHASESTATS.ORDCNT2W, 0) AS ORDCNT2W, NVL(MS_PURCHASESTATS.ORDCNT3W, 0) AS ORDCNT3W
	                          <!-- , CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('STO', 'STO-ADD', 'STO-AUTO') THEN
	                                    CASE WHEN NVL(MS_PURCHASEMST.ROUTE, MS_PURCHASECUST.ROUTE) NOT IN ('2170', '2690') THEN
	                                        CASE WHEN NVL(MS_PURCHASEMST.ROUTE, MS_PURCHASECUST.ROUTE) = '1000' THEN
	                                            CASE WHEN NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) IN ('1000-1260', '1000-1400') OR (NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) = '1000-1112' AND MS_SKU.STORAGETYPE = '20') THEN MS_SKU.BASEUOM
	                                                 ELSE MS_SKU.PURCHASEUOM
	                                            END
	                                        ELSE MS_SKU.BASEUOM
	                                        END
	                                    ELSE MS_SKU.PURCHASEUOM
	                                    END
	                               ELSE MS_SKU.PURCHASEUOM
	                            END AS PURCHASEUOM -->
	                          , MS_SKU.PURCHASEUOM 
	                          , MS_SKU.QTYPERBOX AS BOXPERQTY
	                          <!-- , (SELECT FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, '', 'N') FROM DUAL) || '/' || MS_SKU.DURATION AS DURATION -->
	                          , MS_PURCHASEMST.REFERENCE01, MS_PURCHASEMST.REFERENCE02, MS_PURCHASEMST.REFERENCE03, MS_PURCHASEMST.REFERENCE06
	                          , CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('PO-AUTO', 'STO-AUTO') THEN MS_PURCHASEMST.AUTO_EXECDAY ELSE TO_NUMBER(#{execDay}) END AS EXECDAY
	                          , #{stdDt} AS STD_DT, MS_PURCHASEMST.AUTO_EXECDAY, MS_PURCHASEMST.PURCHASETYPE, MS_PURCHASECUST.PLANT
	                          , MS_SKU.STORAGETYPE, (SELECT FN_CODEDESCR(MS_SKU.STORERKEY, 'STORAGETYPE', MS_SKU.STORAGETYPE) FROM DUAL) AS STORAGETYPENM
	                          , MS_PURCHASECUST.PURCHASEGROUP, NVL(MS_PURCHASEMST.MINORDERQTY, 0) AS MINORDERQTY, MS_SKU.LAYERPERPLT, MS_SKU.BOXPERLAYER
	                          , NVL(MS_PURCHASEMST.COEFFICIENTSAFETY, 0) AS COEFFICIENTSAFETY, NVL(MS_PURCHASEMST.LEADTIME, 1) AS LEADTIME, NVL(MS_PURCHASEMST.PURINTERVAL, 1) AS PURINTERVAL
	                          , MS_PURCHASECUST.DELIVERYWEEK, MS_PURCHASECUST.RETURNTYPE, MS_PURCHASECUST.SERIALKEY, MS_PURCHASECUST.STORERKEY, MS_PURCHASECUST.CUSTTYPE
	                          , (SELECT FN_CODEDESCR(MS_PURCHASECUST.STORERKEY, 'CUSTTYPE', MS_PURCHASECUST.CUSTTYPE) FROM DUAL) AS CUSTTYPENM
	                          , NVL(MS_PURCHASESTATS.AREA, '1000') AS AREA, MS_PURCHASECUST.CHANNEL
	                          <!-- , CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('STO', 'STO-ADD', 'STO-AUTO') THEN
	                                    CASE WHEN NVL(MS_PURCHASEMST.ROUTE, MS_PURCHASECUST.ROUTE) NOT IN ('2170', '2690') THEN
	                                        CASE WHEN NVL(MS_PURCHASEMST.ROUTE, MS_PURCHASECUST.ROUTE) = '1000' THEN
	                                            CASE WHEN NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) IN ('1000-1260', '1000-1400') OR (NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) = '1000-1112' AND MS_SKU.STORAGETYPE = '20') THEN 1
	                                                 ELSE NVL(MS_UOM.BUNJA, 1)
	                                            END
	                                        ELSE 1
	                                        END
	                                    ELSE NVL(MS_UOM.BUNJA, 1)
	                                    END
	                               ELSE NVL(MS_UOM.BUNJA, 1)
	                            END AS BUNJA -->
	                            <!-- 
					               발주 단위 관련 변경사항 20151030 신한섭님 요청사항 
					               STO발주인 경우 1000,2170,2690 센터에서 공급하는 경우 발주단위 사용하며 이외 센터는 기본단위를 발주단위로 사용함
					               1000-1260,1000-1400 : 기본단위 사용함
					               수정내용 - 발주단위, BUNJA, BUNMO
					           -->
	                          <!-- , CASE WHEN MS_PURCHASEMST.PURCHASETYPE IN ('STO', 'STO-ADD', 'STO-AUTO') THEN
	                                    CASE WHEN NVL(MS_PURCHASEMST.ROUTE, MS_PURCHASECUST.ROUTE) NOT IN ('2170', '2690') THEN
	                                        CASE WHEN NVL(MS_PURCHASEMST.ROUTE, MS_PURCHASECUST.ROUTE) = '1000' THEN
	                                            CASE WHEN NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) IN ('1000-1260', '1000-1400') OR (NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) = '1000-1112' AND MS_SKU.STORAGETYPE = '20') THEN 1
	                                                 ELSE NVL(MS_UOM.BUNMO, 1)
	                                            END
	                                        ELSE 1
	                                        END
	                                    ELSE NVL(MS_UOM.BUNMO, 1)
	                                    END
	                               ELSE NVL(MS_UOM.BUNMO, 1)
	                            END AS BUNMO -->
	                          , MS_UOM.BUNJA, MS_UOM.BUNMO
	                          , CASE WHEN (MS_SKU.LAYERPERPLT * MS_SKU.BOXPERLAYER) = 0 THEN 1 ELSE (MS_SKU.LAYERPERPLT * MS_SKU.BOXPERLAYER) END AS PALLETUNIT
	                          , TO_CHAR(SYSDATE, 'YYYYMMDD') AS PODT, NVL(MS_PURCHASEMST.ROUTE, MS_PURCHASECUST.ROUTE) AS FROM_DCCODE
	                          , NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) AS FROM_ORGANIZE, '' AS EMPTYFIELD
	                          , 'STD' AS STD, 0 AS ZERO
	                          , (SELECT FN_CODEDESCR(MS_PURCHASECUST.STORERKEY, 'PUTAWAYTYPE', MS_PURCHASECUST.CHANNEL) FROM DUAL) AS CHANNELNM
	                          , (SELECT FN_CODEDESCR(MS_PURCHASECUST.STORERKEY, 'SERIALYN', MS_SKU.SERIALYN) FROM DUAL) AS SERIALYN
	                          , (SELECT FN_CODEDESCR(MS_PURCHASECUST.STORERKEY, 'YN', NVL(MS_SKU.LINE01, 'N')) FROM DUAL) AS LINE01
	                          , MS_SKU.LINE02, MS_UOM.BUNJA AS BUNJA_CAL, MS_UOM.BUNMO AS BUNMO_CAL
	                          , NVL(MS_PURCHASEMST.REFERENCE04, 'N') AS REFERENCE04
	                          , (select REPLACE(fn_getusername(MS_PURCHASECUST.ADDWHO), 'NOT FOUND', MS_PURCHASECUST.ADDWHO) from dual) AS ADDWHO
	                          , to_char(MS_PURCHASECUST.ADDDATE, 'yyyy-mm-dd hh24:mi:ss') AS ADDDATE
	                          , (select REPLACE(fn_getusername(MS_PURCHASECUST.EDITWHO), 'NOT FOUND', MS_PURCHASECUST.EDITWHO) from dual) AS EDITWHO
	                          , to_char(MS_PURCHASECUST.EDITDATE, 'yyyy-mm-dd hh24:mi:ss') AS EDITDATE
	                          , NVL((SELECT SUM(ST_STOCK.QTY) FROM ST_STOCK JOIN MS_SKU ON MS_SKU.STORERKEY = ST_STOCK.STORERKEY AND MS_SKU.SKU = ST_STOCK.SKU AND MS_SKU.DEL_YN = 'N' JOIN CM_LOT ON CM_LOT.STORERKEY = ST_STOCK.STORERKEY AND CM_LOT.LOT = ST_STOCK.LOT AND CM_LOT.DEL_YN = 'N' JOIN MS_LOCATION ON MS_LOCATION.DCCODE = ST_STOCK.DCCODE AND MS_LOCATION.LOC = ST_STOCK.LOC LEFT OUTER JOIN ST_SNINFO ON ST_STOCK.STORERKEY = ST_SNINFO.STORERKEY AND ST_STOCK.SKU = ST_SNINFO.SKU AND ST_STOCK.STOCKID = ST_SNINFO.STOCKID WHERE ST_STOCK.DCCODE = '2170' AND ST_STOCK.SKU = MS_PURCHASECUST.SKU AND ST_STOCK.STOCKGRADE = 'STD' AND ST_SNINFO.CONTRACTTYPE IN ('30', '30 - 계약', '30 - 계약영업')), 0) AS STOCKQTY_CONTRACT
	                          , NVL(ST_STOCK.QTY, 0) AS STOCKQTY_OUTDISP
	                          , NVL(MS_PURCHASEMST.MON_YN, '1') AS MON_YN, NVL(MS_PURCHASEMST.TUE_YN, '1') AS TUE_YN, NVL(MS_PURCHASEMST.WED_YN, '1') AS WED_YN
	                          , NVL(MS_PURCHASEMST.THU_YN, '1') AS THU_YN, NVL(MS_PURCHASEMST.FRI_YN, '1') AS FRI_YN, NVL(MS_PURCHASEMST.SAT_YN, '0') AS SAT_YN, NVL(MS_PURCHASEMST.SUN_YN, '0') AS SUN_YN
	                          , CASE WHEN TO_CHAR(SYSDATE, 'YYYYMMDD') BETWEEN ST_ALLOCATED_R.CTRL_START_DT AND ST_ALLOCATED_R.CTRL_END_DT THEN CASE WHEN ST_ALLOCATED_R.STOP_YN = 'Y' THEN 'icon_bbs01' ELSE 'icon_bbs03' END ELSE NULL END AS STOP_STATUS
	                          , CASE WHEN TO_CHAR(SYSDATE, 'YYYYMMDD') BETWEEN ST_ALLOCATED_R.CTRL_START_DT AND ST_ALLOCATED_R.CTRL_END_DT THEN CASE WHEN ST_ALLOCATED_R.ALLO_EXC_DCCODE IS NOT NULL AND ST_ALLOCATED_R.ORD_EXC_DCCODE IS NOT NULL THEN '(' || ST_ALLOCATED_R.ALLO_EXC_DCCODE || '할당제외,' || ST_ALLOCATED_R.ORD_EXC_DCCODE || '주문불가 / 주문산정기간 : ' || nvl(ST_ALLOCATED_R.ORDER_POS_QTY, 0) || ')' WHEN ST_ALLOCATED_R.ALLO_EXC_DCCODE IS NOT NULL AND ST_ALLOCATED_R.ORD_EXC_DCCODE IS NULL THEN '(' || ST_ALLOCATED_R.ALLO_EXC_DCCODE || '할당제외 / 주문산정기간 : ' || nvl(ST_ALLOCATED_R.ORDER_POS_QTY, 0) || ')' WHEN ST_ALLOCATED_R.ALLO_EXC_DCCODE IS NULL AND ST_ALLOCATED_R.ORD_EXC_DCCODE IS NOT NULL THEN '(' || ST_ALLOCATED_R.ORD_EXC_DCCODE || '주문불가 / 주문산정기간 : ' || nvl(ST_ALLOCATED_R.ORDER_POS_QTY, 0) || ')' ELSE '(주문산정기간 : ' || nvl(ST_ALLOCATED_R.ORDER_POS_QTY, 0) || ')' END ELSE null END AS STOP_INFO
	                          , NVL(MS_PURCHASESTATS.ORD1DAY, 0) AS ORD1DAY, NVL(MS_PURCHASESTATS.ORD2DAY, 0) AS ORD2DAY, NVL(MS_PURCHASESTATS.ORD3DAY, 0) AS ORD3DAY, NVL(MS_PURCHASESTATS.ORD4DAY, 0) AS ORD4DAY
	                          , NVL(MS_PURCHASESTATS.ORD5DAY, 0) AS ORD5DAY, NVL(MS_PURCHASESTATS.ORD6DAY, 0) AS ORD6DAY, NVL(MS_PURCHASESTATS.ORD7DAY, 0) AS ORD7DAY, NVL(MS_PURCHASESTATS.ORD8DAY, 0) AS ORD8DAY
	                          , NVL(MS_PURCHASESTATS.ORD9DAY, 0) AS ORD9DAY, NVL(MS_PURCHASESTATS.ORD10DAY, 0) AS ORD10DAY, NVL(MS_PURCHASESTATS.ORD11DAY, 0) AS ORD11DAY
	                          , NVL(MS_PURCHASESTATS.ORD12DAY, 0) AS ORD12DAY, NVL(MS_PURCHASESTATS.ORD13DAY, 0) AS ORD13DAY, NVL(MS_PURCHASESTATS.ORD14DAY, 0) AS ORD14DAY
	                          , MS_PURCHASEMST.ORDERQTY_UNIT, CM_CODE.DATA2 AS BUYERKEY_TYPE
	                          , NVL((SELECT T_OM_PURCHASE_RESULT.CONFIRMQTY FROM (SELECT OM_PURCHASE_RESULT.CONFIRMQTY, OM_PURCHASE_RESULT.SKU FROM OM_PURCHASE_RESULT WHERE OM_PURCHASE_RESULT.ISOWEEK_CD = FN_GETISOWEEKCD(TO_CHAR(SYSDATE, 'YYYYMMDD'), 0) ORDER BY OM_PURCHASE_RESULT.ALGO_WRK_START_DTM DESC) T_OM_PURCHASE_RESULT WHERE T_OM_PURCHASE_RESULT.SKU = MS_PURCHASECUST.SKU AND ROWNUM = 1), 0) AS CONFIRMQTY1WEEK
	                          , NVL((SELECT T_OM_PURCHASE_RESULT.CONFIRMQTY FROM (SELECT OM_PURCHASE_RESULT.CONFIRMQTY, OM_PURCHASE_RESULT.SKU FROM OM_PURCHASE_RESULT WHERE OM_PURCHASE_RESULT.ISOWEEK_CD = FN_GETISOWEEKCD(TO_CHAR(SYSDATE, 'YYYYMMDD'), 7) ORDER BY OM_PURCHASE_RESULT.ALGO_WRK_START_DTM DESC) T_OM_PURCHASE_RESULT WHERE T_OM_PURCHASE_RESULT.SKU = MS_PURCHASECUST.SKU AND ROWNUM = 1), 0) AS CONFIRMQTY2WEEK
	                          , NVL((SELECT T_OM_PURCHASE_RESULT.CONFIRMQTY FROM (SELECT OM_PURCHASE_RESULT.CONFIRMQTY, OM_PURCHASE_RESULT.SKU FROM OM_PURCHASE_RESULT WHERE OM_PURCHASE_RESULT.ISOWEEK_CD = FN_GETISOWEEKCD(TO_CHAR(SYSDATE, 'YYYYMMDD'), 14) ORDER BY OM_PURCHASE_RESULT.ALGO_WRK_START_DTM DESC) T_OM_PURCHASE_RESULT WHERE T_OM_PURCHASE_RESULT.SKU = MS_PURCHASECUST.SKU AND ROWNUM = 1), 0) AS CONFIRMQTY3WEEK
	                          , NVL((SELECT T_OM_PURCHASE_RESULT.CONFIRMQTY FROM (SELECT OM_PURCHASE_RESULT.CONFIRMQTY, OM_PURCHASE_RESULT.SKU FROM OM_PURCHASE_RESULT WHERE OM_PURCHASE_RESULT.ISOWEEK_CD = FN_GETISOWEEKCD(TO_CHAR(SYSDATE, 'YYYYMMDD'), 21) ORDER BY OM_PURCHASE_RESULT.ALGO_WRK_START_DTM DESC) T_OM_PURCHASE_RESULT WHERE T_OM_PURCHASE_RESULT.SKU = MS_PURCHASECUST.SKU AND ROWNUM = 1), 0) AS CONFIRMQTY4WEEK
	                          , (SELECT T_OM_PURCHASE_RESULT.LABEL FROM (SELECT OM_PURCHASE_RESULT.LABEL, OM_PURCHASE_RESULT.SKU FROM OM_PURCHASE_RESULT WHERE OM_PURCHASE_RESULT.ISOWEEK_CD = FN_GETISOWEEKCD(TO_CHAR(SYSDATE, 'YYYYMMDD'), 0) ORDER BY OM_PURCHASE_RESULT.ALGO_WRK_START_DTM DESC) T_OM_PURCHASE_RESULT WHERE T_OM_PURCHASE_RESULT.SKU = MS_PURCHASECUST.SKU AND ROWNUM = 1) AS LABEL
	                          , (MS_DC_PLT_LOAD.BOXPERLAYER * MS_DC_PLT_LOAD.LAYERPERPLT) AS BOXPERPLT, NVL(MS_SKUCHAIN_MOQ.MOQ_SKU, 0) AS MOQ_SKU, MS_SKUCHAIN_MOQ.LEADTIME AS LEADTIME2
	                          , NVL(MS_SKUCHAIN_MOQ.MOQ_SKU_PLT, 0) AS MOQ_SKU_PLT, NVL(MS_SKUCHAIN_MOQ.MOQ_VENDER, 0) AS MOQ_VENDER, NVL(MS_SKUCHAIN_MOQ.MOQ_VENDER_PLT, 0) AS MOQ_VENDER_PLT
	                          , MS_CUST_SECOND.SLAVE_CUSTKEY
	                          , CASE WHEN MS_CUST_SECOND.SLAVE_CUSTKEY IS NULL THEN '' ELSE TO_CHAR(FN_DESCR_VENDOR(MS_CUST_SECOND.STORERKEY, MS_CUST_SECOND.SLAVE_CUSTKEY)) END AS SLAVE_CUSTNAME
	                          , (CASE WHEN #{dcCode} = '2690' AND MS_PURCHASECUST.DCCODE = '1000' THEN 0 WHEN #{dcCode} = '1000' AND NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) IS NOT NULL THEN (SELECT CASE WHEN MAX(T_ST_STOCK_PURCHASE.PLT_FLG) = 'S' THEN 1 ELSE CEIL(SUM(T_ST_STOCK_PURCHASE.QTY) / MAX(MS_SKU.QTYPERBOX) / MAX(MS_DC_PLT_LOAD.BOXPERLAYER * MS_DC_PLT_LOAD.LAYERPERPLT)) END FROM T_ST_STOCK_PURCHASE WHERE T_ST_STOCK_PURCHASE.STORERKEY = MS_PURCHASECUST.STORERKEY AND T_ST_STOCK_PURCHASE.DCCODE = MS_PURCHASECUST.DCCODE AND T_ST_STOCK_PURCHASE.ORGANIZE = NVL(MS_PURCHASEMST.ROUTEORGANIZE, MS_PURCHASECUST.ROUTEORGANIZE) AND T_ST_STOCK_PURCHASE.SKU = MS_PURCHASECUST.SKU GROUP BY T_ST_STOCK_PURCHASE.DCCODE, T_ST_STOCK_PURCHASE.SKU) ELSE (SELECT CASE WHEN MAX(T_ST_STOCK_PURCHASE.PLT_FLG) = 'S' THEN 1 ELSE CEIL(SUM(T_ST_STOCK_PURCHASE.QTY) / MAX(MS_SKU.QTYPERBOX) / MAX(MS_DC_PLT_LOAD.BOXPERLAYER * MS_DC_PLT_LOAD.LAYERPERPLT)) END FROM T_ST_STOCK_PURCHASE WHERE T_ST_STOCK_PURCHASE.STORERKEY = MS_PURCHASECUST.STORERKEY AND T_ST_STOCK_PURCHASE.DCCODE = MS_PURCHASECUST.DCCODE AND T_ST_STOCK_PURCHASE.SKU = MS_PURCHASECUST.SKU GROUP BY T_ST_STOCK_PURCHASE.DCCODE, T_ST_STOCK_PURCHASE.SKU) END) AS BOXPERPLT_QTY	                          
	                          , CASE                     
					            	WHEN MS_SKU.DURATIONTYPE='2' THEN 
					              		CASE
					                	 WHEN CM_LOT.LOTTABLE01 != 'STD' THEN TO_CHAR((MS_SKU.DURATION + TO_DATE(CM_LOT.LOTTABLE01, 'YYYYMMDD')),'YYYYMMDD')
					                	 ELSE CM_LOT.LOTTABLE01
					              		END                      
					            	ELSE CM_LOT.LOTTABLE01                     
				                END                             																											AS DURATION
				              , FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'N') ||'/'|| MS_SKU.DURATION 						AS DURATION_TERM
	                          , MS_SKU.REFERENCE03 AS TPL_SKUGROUP
	                          , MS_CUST.EMPNAME1, MS_CUST.EMPNAME2, MS_CUST.EMPNAME3, MS_CUST.EMPNAME4, MS_CUST.EMPNAME5
	                          , MS_CUST.EMPPHONE1, MS_CUST.EMPPHONE2, MS_CUST.EMPPHONE3, MS_CUST.EMPPHONE4, MS_CUST.EMPPHONE5
	                          , DECODE(MS_PURCHASEMST.EXHAUSTION_STOP_YN, '0', 'N', '1', 'Y', MS_PURCHASEMST.EXHAUSTION_STOP_YN) AS EXHAUSTION_STOP_YN
	                          , ROUND(MS_PURCHASESTATS.STDDEVIATION * MS_PURCHASEMST.COEFFICIENTSAFETY * POWER(MS_PURCHASEMST.LEADTIME, 0.5), 2) AS STOCKSAFETY2
	                          , MS_SKU.CUSTSKU, MS_PURCHASEMST.REFERENCE07
	                          , NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY01, 0) AS AFTERDAYWDQTY01, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY02, 0) AS AFTERDAYWDQTY02, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY03, 0) AS AFTERDAYWDQTY03
	                          , NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY04, 0) AS AFTERDAYWDQTY04, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY05, 0) AS AFTERDAYWDQTY05, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY06, 0) AS AFTERDAYWDQTY06
	                          , NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY07, 0) AS AFTERDAYWDQTY07, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY08, 0) AS AFTERDAYWDQTY08, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY09, 0) AS AFTERDAYWDQTY09
	                          , NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY10, 0) AS AFTERDAYWDQTY10, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY11, 0) AS AFTERDAYWDQTY11, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY12, 0) AS AFTERDAYWDQTY12
	                          , NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY13, 0) AS AFTERDAYWDQTY13, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY14, 0) AS AFTERDAYWDQTY14, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY15, 0) AS AFTERDAYWDQTY15
	                          , NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY16, 0) AS AFTERDAYWDQTY16, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY17, 0) AS AFTERDAYWDQTY17, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY18, 0) AS AFTERDAYWDQTY18
	                          , NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY19, 0) AS AFTERDAYWDQTY19, NVL(MS_PURCHASETOTAL.AFTERDAYWDQTY20, 0) AS AFTERDAYWDQTY20
	                          , MS_DIRECTDLVGROUP.CUSTKEY AS DIRECTDLV_CUSTKEY
	                          , MS_DIRECTDLVGROUP.ORDERQTY AS DIRECTDLV_ORDERQTY
	                          , MS_DIRECTDLVGROUP.UOM AS DIRECTDLV_UOM
	                          , CASE WHEN SUBSTR(MS_DIRECTDLVGROUP.CUSTKEY,1,5) = '1000-' THEN '1000' WHEN SUBSTR(MS_DIRECTDLVGROUP.CUSTKEY,1,5) = '2170-' THEN '2170' ELSE '' END AS DIRECTDLV_FROM_DCCODE
	                          , MS_PURCHASEMST.EXCPT_DP_APPR_YN
	                          , NVL(CASE
	                          	  WHEN MS_SKU.BASEUOM = 'KG' AND MS_SKU.LINE01 = 'Y' THEN MS_SKU.LINE02 * (MS_DC_PLT_LOAD.BOXPERLAYER * MS_DC_PLT_LOAD.LAYERPERPLT)
							      WHEN MS_SKU.BASEUOM = 'KG' AND MS_SKU.LINE01 <![CDATA[<>]]> 'Y' THEN MS_SKU.GROSSWEIGHT * (MS_DC_PLT_LOAD.BOXPERLAYER * MS_DC_PLT_LOAD.LAYERPERPLT)
							      ELSE MS_DC_PLT_LOAD.BOXPERLAYER * MS_DC_PLT_LOAD.LAYERPERPLT
							  END, 0) 											            AS PLTTRANS 			 /* PLT변환값(환산)*/
							  , ST_SNINFO.CONVSERIALNO                                      AS CONVSERIALNO
					  		  , ST_SNINFO.CONTRACTTYPE                                      AS CONTRACTTYPE
					  		  , ST_SNINFO.PO_HOLD_YN                                        AS PO_HOLD_YN
					  		  , ST_STOCK.ORGANIZE AS OUTORGANIZE
					  		  , DCXORGST.DESCRIPTION AS OUTORGANIZENAME
					  		  ,(SELECT M.ADDRESS1||M.ADDRESS2 FROM MS_PLANTXSL M WHERE M.DCCODE=ST_STOCK.DCCODE AND M.STORAGELOC=SUBSTR(ST_STOCK.ORGANIZE, 6,9)) AS ADDRESS
					  		  , ST_SNINFO.SERIALNO AS SERIALNO
					  		  , ST_SNINFO.CONTRACTCUSTKEY AS CONTRACTCUSTKEY
					  		  , (SELECT DESCRIPTION FROM MS_CUST 
				                WHERE  MS_CUST.STORERKEY = ST_SNINFO.STORERKEY
				                AND    MS_CUST.CUSTKEY   = ST_SNINFO.CONTRACTCUSTKEY
				                AND    ROWNUM = 1 ) AS CONTRACTCUSTNM
				                
				              , ST_STOCK.STOCKID                                              AS STOCKID  
				              , ST_STOCK.STOCKGRADE                                           AS STOCKGRADE 
                              , ST_STOCK.STOCKTYPE                                            AS STOCKTYPE
                              , NVL((SELECT SUM( CASE WHEN (dmdd.OPENQTY + dmdd.OPENADJUSTQTY ) > dmdd.CONFIRMQTY  THEN
                                			(dmdd.OPENQTY + dmdd.OPENADJUSTQTY ) - dmdd.CONFIRMQTY
			                         ELSE 0
			                    END)
						        FROM   DM_DOCUMENT_D dmdd
						        WHERE  dmdd.DCCODE       = ST_STOCK.DCCODE
						        AND    dmdd.ORGANIZE     = ST_STOCK.ORGANIZE
						        AND    dmdd.DOCTYPE      = 'WD'
						        AND    dmdd.DELIVERYDATE <![CDATA[>=]]> TO_CHAR(SYSDATE,'YYYYMMDD')
						        AND    dmdd.DELIVERYDATE <![CDATA[<=]]> TO_CHAR(SYSDATE+7,'YYYYMMDD')
						        AND    dmdd.DEL_YN       = 'N'
						        AND    (dmdd.OPENQTY + dmdd.OPENADJUSTQTY ) > dmdd.CONFIRMQTY
						        AND    dmdd.STOCKID      = ST_SNINFO.STOCKID
						        AND    dmdd.SKU          = ST_SNINFO.SKU),0) AS WD_INPLAN_QTY <!-- 출고예정량 -->
						      , FN_CODEDESCR('FW00', 'TAX_CLS', MS_SKU.OTHER05) AS TAXCODE
	                        FROM MS_PURCHASECUST
	                        JOIN MS_PURCHASEMST ON MS_PURCHASEMST.STORERKEY = MS_PURCHASECUST.STORERKEY AND MS_PURCHASEMST.DCCODE = MS_PURCHASECUST.DCCODE AND MS_PURCHASEMST.CUSTTYPE = MS_PURCHASECUST.CUSTTYPE AND MS_PURCHASEMST.SKU = MS_PURCHASECUST.SKU
	                        JOIN CM_DC ON CM_DC.DCCODE = MS_PURCHASECUST.DCCODE
	                        LEFT OUTER JOIN MS_PURCHASESTATS ON MS_PURCHASESTATS.DCCODE = MS_PURCHASECUST.DCCODE AND MS_PURCHASESTATS.STORERKEY = MS_PURCHASECUST.STORERKEY AND MS_PURCHASESTATS.SKU = MS_PURCHASECUST.SKU AND MS_PURCHASESTATS.PLANT = MS_PURCHASECUST.PLANT AND MS_PURCHASESTATS.STATSDT = TO_CHAR(SYSDATE, 'YYYYMMDD')
	                        LEFT OUTER JOIN CM_DCXORGANIZE ON MS_PURCHASESTATS.DCCODE = CM_DCXORGANIZE.DCCODE AND MS_PURCHASESTATS.ORGANIZE = CM_DCXORGANIZE.ORGANIZE
	                        LEFT OUTER JOIN MS_CUST ON MS_CUST.STORERKEY = MS_PURCHASECUST.STORERKEY AND MS_CUST.CUSTKEY = MS_PURCHASECUST.CUSTKEY AND MS_CUST.CUSTTYPE = MS_PURCHASECUST.CUSTTYPE
	                        JOIN MS_SKU ON MS_SKU.STORERKEY = MS_PURCHASECUST.STORERKEY AND MS_SKU.SKU = MS_PURCHASECUST.SKU
	                        <choose>
	                            <when test='reference03 == "HAW4"'>
	                                AND NVL(MS_SKU.REFERENCE03, 'N') = 'HAW4'
	                            </when>
	                            <otherwise>
	                                AND NVL(MS_SKU.REFERENCE03, 'N') <![CDATA[<>]]> 'HAW4'
	                            </otherwise>
	                        </choose>
	                        LEFT OUTER JOIN MS_UOM BOXUOM ON MS_PURCHASECUST.STORERKEY = BOXUOM.STORERKEY AND MS_PURCHASECUST.UOM = BOXUOM.BASEUOM AND MS_PURCHASECUST.SKU = BOXUOM.SKU AND BOXUOM.UOM = 'BOX' AND (MS_PURCHASECUST.UOM = 'BOX' OR BOXUOM.BUNJA <![CDATA[<>]]> BOXUOM.BUNMO)
	                        LEFT OUTER JOIN MS_UOM EAUOM ON MS_PURCHASECUST.STORERKEY = EAUOM.STORERKEY AND MS_PURCHASECUST.SKU = EAUOM.SKU AND MS_PURCHASECUST.UOM = EAUOM.BASEUOM AND EAUOM.UOM = 'EA'
	                        LEFT OUTER JOIN MS_UOM ON MS_SKU.STORERKEY = MS_UOM.STORERKEY AND MS_SKU.SKU = MS_UOM.SKU AND MS_SKU.BASEUOM = MS_UOM.BASEUOM AND MS_SKU.PURCHASEUOM = MS_UOM.UOM
	                        LEFT OUTER JOIN CM_DCXORGANIZE DCXORG ON MS_PURCHASEMST.ROUTEORGANIZE = DCXORG.ORGANIZE AND MS_PURCHASEMST.ROUTE = DCXORG.DCCODE
	                        LEFT OUTER JOIN CM_DCXORGANIZE DCXORGNVL ON MS_PURCHASECUST.ROUTEORGANIZE = DCXORGNVL.ORGANIZE AND MS_PURCHASECUST.ROUTE = DCXORGNVL.DCCODE
	                        LEFT OUTER JOIN MS_PURCHASETOTAL ON MS_PURCHASETOTAL.DCCODE = MS_PURCHASECUST.DCCODE AND MS_PURCHASETOTAL.STORERKEY = MS_PURCHASECUST.STORERKEY AND MS_PURCHASETOTAL.SKU = MS_PURCHASECUST.SKU AND MS_PURCHASETOTAL.USERID = #{gUserId}
	                        LEFT OUTER JOIN ST_ALLOCATED_R ON MS_PURCHASETOTAL.DCCODE = ST_ALLOCATED_R.DCCODE AND MS_PURCHASETOTAL.STORERKEY = ST_ALLOCATED_R.STORERKEY AND MS_PURCHASETOTAL.SKU = ST_ALLOCATED_R.SKU AND ST_ALLOCATED_R.DEL_YN = 'N' AND TO_CHAR(SYSDATE, 'YYYYMMDD') BETWEEN ST_ALLOCATED_R.CTRL_START_DT AND ST_ALLOCATED_R.CTRL_END_DT
	                        LEFT OUTER JOIN CM_CODE ON CM_CODE.BASECODE = MS_PURCHASEMST.BUYERKEY AND CM_CODE.CODELIST = 'BUYERKEY' AND CM_CODE.DEL_YN = 'N' AND CM_CODE.STORERKEY = 'FW00'
	                        LEFT OUTER JOIN MS_SKUCHAIN_MOQ ON MS_PURCHASECUST.SKU = MS_SKUCHAIN_MOQ.SKU AND MS_PURCHASECUST.STORERKEY = MS_SKUCHAIN_MOQ.STORERKEY AND MS_PURCHASECUST.DCCODE = MS_SKUCHAIN_MOQ.DCCODE
	                        LEFT OUTER JOIN MS_CUST_SECOND ON MS_CUST_SECOND.STORERKEY = MS_PURCHASECUST.STORERKEY AND MS_CUST_SECOND.CUSTKEY = MS_PURCHASECUST.CUSTKEY AND MS_CUST_SECOND.SKU = MS_PURCHASECUST.SKU AND MS_CUST_SECOND.DEL_YN = 'N'
	                        LEFT OUTER JOIN MS_DIRECTDLVGROUP ON MS_DIRECTDLVGROUP.STORERKEY = MS_PURCHASECUST.STORERKEY AND MS_DIRECTDLVGROUP.DCCODE = MS_PURCHASECUST.DCCODE AND MS_DIRECTDLVGROUP.DIRECTDLVGROUP = MS_PURCHASEMST.DELIVERYTYPE
	                        LEFT OUTER
                            JOIN MS_DC_PLT_LOAD                 PLT_CHK
                             ON PLT_CHK.SKU              = MS_PURCHASECUST.SKU
                            AND PLT_CHK.STORERKEY        = MS_PURCHASECUST.STORERKEY
                            AND PLT_CHK.DCCODE           = MS_PURCHASECUST.DCCODE
                            LEFT OUTER
                            JOIN MS_DC_PLT_LOAD
                              ON MS_DC_PLT_LOAD.SKU         = MS_PURCHASECUST.SKU
                             AND MS_DC_PLT_LOAD.STORERKEY   = MS_PURCHASECUST.STORERKEY
                             AND MS_DC_PLT_LOAD.DCCODE      = CASE WHEN PLT_CHK.DCCODE IS NULL THEN '공통' ELSE PLT_CHK.DCCODE END
	                        JOIN VW_ST_STOCK ST_STOCK 
	                         ON MS_SKU.STORERKEY = ST_STOCK.STORERKEY 
	                        AND MS_SKU.SKU = ST_STOCK.SKU
	                        AND MS_SKU.DEL_YN = 'N'	                        
	                        JOIN MS_LOCATION
					         ON MS_LOCATION.DCCODE  = ST_STOCK.DCCODE
					        AND MS_LOCATION.LOC     = ST_STOCK.LOC
					        JOIN CM_LOT
 					         ON CM_LOT.STORERKEY    = ST_STOCK.STORERKEY
					        AND CM_LOT.LOT          = ST_STOCK.LOT
					        AND CM_LOT.DEL_YN       = 'N'
					        LEFT OUTER JOIN CM_DCXORGANIZE DCXORGST
							 ON ST_STOCK.DCCODE         = DCXORGST.DCCODE
							AND ST_STOCK.ORGANIZE       = DCXORGST.ORGANIZE
                    		JOIN ST_SNINFO ON ST_STOCK.STORERKEY = ST_SNINFO.STORERKEY AND ST_STOCK.SKU = ST_SNINFO.SKU AND ST_STOCK.STOCKID = ST_SNINFO.STOCKID
	                       WHERE 1 = 1
	                         AND MS_PURCHASECUST.DEL_YN = 'N'
	                         AND MS_PURCHASECUST.STORERKEY = 'FW00'
	                         AND MS_PURCHASECUST.SERIALKEY = (SELECT MIN(DD.SERIALKEY) KEEP (DENSE_RANK FIRST ORDER BY DD.FROMDATE DESC, DD.TODATE ASC)
	                                                            FROM MS_PURCHASECUST DD
	                                                           WHERE DD.DCCODE = MS_PURCHASECUST.DCCODE
	                                                             AND DD.STORERKEY = MS_PURCHASECUST.STORERKEY
	                                                             AND DD.SKU = MS_PURCHASECUST.SKU
	                                                             AND DD.CUSTTYPE = MS_PURCHASECUST.CUSTTYPE
	                                                             AND DD.CHANNEL = '1'
	                                                             AND TO_CHAR(SYSDATE, 'YYYYMMDD') BETWEEN DD.FROMDATE AND DD.TODATE
	                                                             <if test='multiDcCode != null and multiDcCode.length > 0'>
																    AND DD.DCCODE IN
															        <foreach collection="multiDcCode" item="dccodeItem" open="(" separator="," close=")">
															            #{dccodeItem}
															        </foreach>
																 </if>
	                                                             AND DD.STORERKEY = 'FW00'
	                                                             AND DD.DEL_YN = 'N'
	                                                        )
	                        <!-- 저장품 여부 -->
	                        <if test="channel != null and channel != ''">
	                            AND MS_PURCHASECUST.CHANNEL = #{channel}
	                        </if>
	                        <!-- 수급담당 -->
	                        <if test="buyerKey != null and buyerKey != ''">
	                            AND MS_PURCHASEMST.BUYERKEY = #{buyerKey}
	                        </if>
	                        <!-- 발주구분 -->
	                        <if test='purchaseTypeArr != null and purchaseTypeArr.length > 0'>
						    	AND MS_PURCHASEMST.PURCHASETYPE IN
						        <foreach collection="purchaseTypeArr" item="typeItem" open="(" separator="," close=")">
						            #{typeItem}
						        </foreach>
							</if>
	                            AND MS_PURCHASEMST.PURCHASETYPE NOT IN ('SP-PO', 'SP-STO')
	                        <!-- 협력사코드 -->
	                        <if test='multiFromCustkey != null and multiFromCustkey !=""'>
					          AND MS_PURCHASECUST.CUSTKEY IN
					          (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
					                        FROM (SELECT #{multiFromCustkey} AS VAL FROM DUAL) A
					                     CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
					        </if>
	                        <!-- 직송그룹 -->
	                        <if test='deliveryTypeArr != null and deliveryTypeArr.length > 0'>
						    	AND MS_PURCHASEMST.DELIVERYTYPE IN
						        <foreach collection="deliveryTypeArr" item="typeItem" open="(" separator="," close=")">
						            #{typeItem}
						        </foreach>
							</if>
	                        <!-- 물류센터 -->	                        
	                        <if test='multiDcCode != null and multiDcCode.length > 0'>
							    AND MS_PURCHASECUST.DCCODE IN
						        <foreach collection="multiDcCode" item="dccodeItem" open="(" separator="," close=")">
						            #{dccodeItem}
						        </foreach>
							</if>
							<!-- 물류센터 -->
	                        <if test="route != null and route != ''">
	                            AND MS_PURCHASEMST.ROUTE = #{route}
	                        </if>
	                        <!-- 상품코드 -->
	                        <if test='multiSku != null and multiSku !=""'>
					          AND MS_PURCHASECUST.SKU IN
					          (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
					                        FROM (SELECT #{multiSku} AS VAL FROM DUAL) A
					                     CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
					        </if>
	                        <!-- 저장조건 -->
	                        <if test="storageType != null and storageType != ''">
	                            AND MS_SKU.STORAGETYPE = #{storageType}
	                        </if>
                            AND MS_PURCHASECUST.CUSTKEY LIKE '2170-%'
                            AND    ST_STOCK.DCCODE IN ('2170')                           <!-- 외부창고의 재고만 가져옴 -->
        					AND    ST_STOCK.QTY - ST_STOCK.QTYALLOCATED - ST_STOCK.QTYPICKED > 0 <!--  이동가능한것만 표출  -->
	                        <!--if test='multiDcCode != null and multiDcCode.length > 0'>
						    	AND ST_STOCK.DCCODE IN
						        <foreach collection="multiDcCode" item="dccodeItem" open="(" separator="," close=")">
						            #{dccodeItem}
						        </foreach>
							</if-->							
							<!--if test='organizeCode != null and organizeCode !=""'>
					          AND MS_PURCHASEMST.ROUTEORGANIZE IN
					          (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
					                        FROM (SELECT #{organizeCode} AS VAL FROM DUAL) A
					                     CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
					        </if-->
					        AND ST_STOCK.STOCKGRADE = 'STD'  <!--  가용만 표시되도록 변경 (Fr김영문님20151110) -->
					        AND MS_SKU.DEL_YN = 'N'
					        AND ST_STOCK.ORGANIZE NOT LIKE '2170-Y%'
							AND ST_STOCK.ORGANIZE NOT LIKE '2170-X%'
	                    ) SS
	            ) K
        ),
        /* STEP 2~3: SKU_MOQ 적용 및 HOLDING_DAYS 계산 - NUM_PLT 계산 로직 보강 */
		SKU_APPLY AS (
		  SELECT
		      BASE.*,
		      /* 1. BASE_ORDERQTY (EA 단위)를 BOX 단위로 변환 */
		      CEIL(BASE_ORDERQTY / DECODE(UOM,'EA',BOXPERQTY,1 )) AS BASE_ORDERQTY_BOX,
		      /* 2. 상품 MOQ를 고려한 PLT 수량 NUM_PLT 계산 로직 (MOQ_SKU_PLT 우선 적용) */
		      CASE 
		          WHEN MOQ_SKU_PLT IS NOT NULL AND MOQ_SKU_PLT <![CDATA[>]]> 0 THEN  
		              /* MOQ_SKU_PLT와 BASE_ORDERQTY_PLT 중 큰 값을 최종 PLT로 */
		              GREATEST(
		                  CEIL(BASE_ORDERQTY / DECODE(UOM,'EA',BOXPERQTY,1 ) / PALLETUNIT),
		                  MOQ_SKU_PLT
		              )
		          WHEN MOQ_SKU IS NOT NULL AND MOQ_SKU <![CDATA[>]]> 0 THEN  
		              /* MOQ_SKU가 있을 경우, 이를 BOX 단위로 비교 후 PLT로 변환 */
		              CEIL(GREATEST(
		                  CEIL(BASE_ORDERQTY / DECODE(UOM,'EA',BOXPERQTY,1 )),
		                  MOQ_SKU
		              ) / PALLETUNIT)
		          ELSE 
		              /* MOQ가 모두 없는 경우, BASE_ORDERQTY_BOX를 PLT로 변환 */
		              CEIL(CEIL(BASE_ORDERQTY / DECODE(UOM,'EA',BOXPERQTY,1 )) / PALLETUNIT)
		      END AS NUM_PLT,
		      CASE WHEN STOCKAVGDAY <![CDATA[>]]> 0 THEN 
		            /* HOLDING_DAYS (보유일수) 계산 */
		            ROUND(GREATEST(BASE_ORDERQTY,
		                            NVL(CASE WHEN UOM ='EA' AND MOQ_SKU <![CDATA[>]]> 0 THEN BOXPERQTY * MOQ_SKU 
		                                     WHEN UOM ='EA' THEN MOQ_SKU
		                                     ELSE MOQ_SKU
		                                END , 0)
		                  ) / STOCKAVGDAY, 2)
		            ELSE 9999 
		        END AS HOLDING_DAYS
		  FROM BASE
		),
		/* STEP 4~5: 우선순위 (보유일 ASC, ROP ASC, PLT ASC) */
		GROUP_SUM AS (
		  SELECT 
		      CUSTKEY, LEADTIME,
		      SUM(NUM_PLT) AS TOTAL_PLT,
		      MIN(MOQ) AS MOQ
		  FROM SKU_APPLY
		  GROUP BY CUSTKEY, LEADTIME
		),
		DISTRIBUTE AS (
		  SELECT 
		      A.*,
		      B.TOTAL_PLT,
		      ROW_NUMBER() OVER (
		        PARTITION BY A.CUSTKEY, A.LEADTIME 
		        ORDER BY A.NEAR_ROP ASC, A.HOLDING_DAYS ASC,  A.NUM_PLT ASC, A.SKU ASC
		      ) AS RN,
		      COUNT(*) OVER (PARTITION BY A.CUSTKEY, A.LEADTIME) AS CNT
		  FROM SKU_APPLY A
		  JOIN GROUP_SUM B ON A.CUSTKEY = B.CUSTKEY AND A.LEADTIME = B.LEADTIME
		),
		FINAL AS (
		  SELECT
		      DISTRIBUTE.*,    
		      CASE 
		          /* 협력사 MOQ가 0보다 크고, 총 PLT가 협력사 MOQ보다 작을 때만 재분배 실행 (10 PLT까지 채우기) */
		          WHEN MOQ <![CDATA[>]]> 0 AND TOTAL_PLT <![CDATA[<]]> MOQ THEN 
		              CASE 
		                  WHEN RN <![CDATA[<]]> CNT THEN NUM_PLT + FLOOR((MOQ - TOTAL_PLT) / CNT)
		                  ELSE NUM_PLT + CEIL((MOQ - TOTAL_PLT) - FLOOR((MOQ - TOTAL_PLT) / CNT) * (CNT - 1))
		              END
		          /* 그 외의 경우 (협력사 MOQ가 0이거나, 이미 충족된 경우) 상품 MOQ가 반영된 NUM_PLT를 그대로 사용 */
		          ELSE NUM_PLT
		      END AS FINAL_PLT
		  FROM DISTRIBUTE
		)
		SELECT 
			A.*
		    , NVL(FLOOR(A.CONFIRMQTY * A.EA_CAL / NULLIF(A.STOCKAVGDAY, 0)), 0) AS CONFIRMQTY_STOCKDAY /* 확정오더량 보유일 */
		    , NVL(FLOOR((A.STOCKQTY_DISP - A.DATEDIFF_QTY) / NULLIF(A.STOCKAVGDAY, 0)), 0) AS STOCKQTY_DISP_STOCKDAY /* 기존재고 보유일 */
		FROM FINAL A
		ORDER BY ROUTEORGANIZE, SKU, CUSTKEY, LEADTIME, HOLDING_DAYS, NEAR_ROP, NUM_PLT, DURATION
	</select>
	
	<select id="getDetailLeftInfo" resultType="OmPurchaseStorageAutoTotalDetailLeftResDto">
		WITH T_ST_STOCK_PURCHASE AS ( /* 2026.01.30 CJ프레시웨이 WMS 구축  추가(ST_STOCK->VW_ST_STOCK, ST_STOCK_PURCHASE->T_ST_STOCK_PURCHASE) */
		    SELECT ST_STOCK.DCCODE       AS  DCCODE
		        ,ST_STOCK.STORERKEY    AS  STORERKEY
		        ,ST_STOCK.ORGANIZE     AS  ORGANIZE
		        ,ST_STOCK.AREA         AS  AREA
		        ,ST_STOCK.SKU          AS  SKU
		        ,MAX(MS_SKU.DESCRIPTION)    AS  DESCRIPTION
		        ,ST_STOCK.UOM          AS  UOM
		        ,SUM(ST_STOCK.QTY)     AS  QTY
		        ,SUM(ST_STOCK.BOXQTY)  AS  BOXQTY
		        ,SUM(CASE WHEN (ST_STOCK.QTY-ST_STOCK.QTYALLOCATED-ST_STOCK.QTYPICKED) <![CDATA[<]]> 0  THEN 0
		            ELSE ST_STOCK.QTY-ST_STOCK.QTYALLOCATED-ST_STOCK.QTYPICKED
		           END ) as OPENQTY
		        ,MAX(MS_LOCATION.PLT_FLG) AS PLT_FLG
		    FROM   VW_ST_STOCK ST_STOCK
		    JOIN   MS_SKU
		    ON     MS_SKU.STORERKEY        = ST_STOCK.STORERKEY
		    AND    MS_SKU.SKU              = ST_STOCK.SKU
		    JOIN   MS_LOCATION
		    ON     MS_LOCATION.DCCODE      = ST_STOCK.DCCODE
		    AND    MS_LOCATION.LOC         = ST_STOCK.LOC
		    AND    MS_LOCATION.LOCTYPE     IN ('STAGE','PICK','KEEP','CROSS','FIRSTOUT','LONGSTAY','CANCEL')
		    AND    ((MS_LOCATION.LOCCATEGORY IN ('RACK','YARD') AND ST_STOCK.DCCODE NOT IN ('2690','2620')) OR (MS_LOCATION.LOCCATEGORY IN ('RACK','YARD','AUTO') AND ST_STOCK.DCCODE IN ('2690','2620')))
		    AND    MS_LOCATION.LOCFLAG     = 'GOOD'
		    AND    CASE WHEN MS_LOCATION.DCCODE = '2690' AND MS_LOCATION.LOCTYPE='STAGE' THEN 'Y'
		          WHEN MS_LOCATION.DCCODE = '2600' AND MS_LOCATION.LOCTYPE='STAGE' THEN 'Y'
		          ELSE MS_LOCATION.OUT_YN
		        END = 'Y'
		    AND    MS_LOCATION.DEL_YN      = 'N'
		    AND    MS_LOCATION.STOCKTYPE   = 'GOOD'
		    JOIN   CM_LOT
		    ON     CM_LOT.STORERKEY        = ST_STOCK.STORERKEY
		    AND    CM_LOT.LOT              = ST_STOCK.LOT
		    AND    'TRUE' = CASE
		               WHEN CM_LOT.LOTTABLE01   = 'STD' OR  MS_SKU.DURATIONTYPE = 'N'
		               THEN 'TRUE'
		               WHEN     MS_SKU.DURATIONTYPE = '1' AND FN_ISDATE(CM_LOT.LOTTABLE01) = 1
		                  AND TO_DATE(CM_LOT.LOTTABLE01,'YYYYMMDD') <![CDATA[<]]> TRUNC(SYSDATE)
		               THEN 'FALSE'
		               WHEN     MS_SKU.DURATIONTYPE IN ('2','3') AND FN_ISDATE(CM_LOT.LOTTABLE01) = 1
		                  AND TO_DATE(CM_LOT.LOTTABLE01,'YYYYMMDD') + MS_SKU.DURATION - 1 <![CDATA[<]]> TRUNC(SYSDATE)
		               THEN 'FALSE'
		               ELSE 'TRUE'
		            END
		    WHERE 1=1
		    AND ST_STOCK.STOCKGRADE = 'STD'  <!--  가용만 표시되도록 변경 -->
		    GROUP BY ST_STOCK.DCCODE
		        ,ST_STOCK.STORERKEY
		        ,ST_STOCK.ORGANIZE
		        ,ST_STOCK.AREA
		        ,ST_STOCK.SKU
		        ,ST_STOCK.UOM
		  )
		SELECT STORERKEY                                        AS STORERKEY /* 고객사코드 */
	     , FROM_DCCODE                                          AS FROM_DCCODE /* 저장센터코드 */
	     , DCCODE                                               AS DCCODE    /* 센터코드 */
	     , SKU                                                  AS SKU       /* 상품코드 */
	     , SKUNAME                                              AS SKUNAME   /* 상품명 */
	     , UOM                                                  AS UOM       /* 단위 */
	     , NVL(CASE WHEN T.DCCODE = '1000' THEN
	                     (SELECT SUM(ST_STOCK_PURCHASE.QTY)
	                        FROM T_ST_STOCK_PURCHASE ST_STOCK_PURCHASE
	                       WHERE ST_STOCK_PURCHASE.STORERKEY = T.STORERKEY         
	                         AND ST_STOCK_PURCHASE.DCCODE    = T.DCCODE 
	                         AND ST_STOCK_PURCHASE.SKU       = T.SKU
	                         AND ST_STOCK_PURCHASE.ORGANIZE NOT IN ('1000-1050', '1000-1000') )
	                ELSE (SELECT SUM(ST_STOCK_PURCHASE.QTY)
	                        FROM T_ST_STOCK_PURCHASE ST_STOCK_PURCHASE
	                       WHERE ST_STOCK_PURCHASE.STORERKEY = T.STORERKEY         
	                         AND ST_STOCK_PURCHASE.DCCODE    = T.DCCODE     
	                         AND ST_STOCK_PURCHASE.SKU       = T.SKU )
	           END, 0)                                          AS QTY       /* 현재고수량 */
	     , NVL(CASE WHEN T.DCCODE = '1000' THEN
	                     (SELECT SUM(ST_STOCK_PURCHASE.OPENQTY)
	                        FROM T_ST_STOCK_PURCHASE ST_STOCK_PURCHASE
	                       WHERE ST_STOCK_PURCHASE.STORERKEY = T.STORERKEY         
	                         AND ST_STOCK_PURCHASE.DCCODE    = T.DCCODE 
	                         AND ST_STOCK_PURCHASE.SKU       = T.SKU
	                         AND ST_STOCK_PURCHASE.ORGANIZE NOT IN ('1000-1050', '1000-1000') )
	                ELSE (SELECT SUM(ST_STOCK_PURCHASE.OPENQTY)
	                        FROM T_ST_STOCK_PURCHASE ST_STOCK_PURCHASE
	                       WHERE ST_STOCK_PURCHASE.STORERKEY = T.STORERKEY         
	                         AND ST_STOCK_PURCHASE.DCCODE    = T.DCCODE     
	                         AND ST_STOCK_PURCHASE.SKU       = T.SKU )
	           END, 0)                                          AS OPENQTY    /* 가용재고 */
	     , NVL((SELECT SUM(DM_DOCUMENT_D.STOREROPENQTY * DM_DOCUMENT_D.BUNJA / DM_DOCUMENT_D.BUNMO)
	              FROM DM_DOCUMENT_D
	             WHERE DM_DOCUMENT_D.STORERKEY       = T.STORERKEY
	               AND DM_DOCUMENT_D.DCCODE          = T.DCCODE
	               AND DM_DOCUMENT_D.SKU             = T.SKU
	               AND DM_DOCUMENT_D.DOCTYPE         = 'WD'
	               AND DM_DOCUMENT_D.WORKPROCESSCODE IN ('SO', 'JASO')
	               AND DM_DOCUMENT_D.DELIVERYDATE BETWEEN #{stdDt} AND TO_CHAR(TO_DATE(#{stdDt}, 'YYYYMMDD') + TO_NUMBER(#{execDay}), 'YYYYMMDD')
	               AND DM_DOCUMENT_D.CHANNEL         = '1'
	               AND DM_DOCUMENT_D.DEL_YN          = 'N'), 0) AS ORDERQTY    /* 주문수량 */
	     , NVL((SELECT SUM(CASE WHEN DM_DOCUMENT_D.STOREROPENQTY > DM_DOCUMENT_D.STORERCONFIRMQTY THEN
	                                 (DM_DOCUMENT_D.STOREROPENQTY - DM_DOCUMENT_D.STORERCONFIRMQTY) * DM_DOCUMENT_D.BUNJA / DM_DOCUMENT_D.BUNMO
	                            ELSE 0
	                       END)
	              FROM DM_DOCUMENT_D
	             WHERE DM_DOCUMENT_D.STORERKEY       = T.STORERKEY
	               AND DM_DOCUMENT_D.DCCODE          = T.DCCODE
	               AND DM_DOCUMENT_D.SKU             = T.SKU
	               AND DM_DOCUMENT_D.DOCTYPE         = 'DP'
	               AND DM_DOCUMENT_D.WORKPROCESSCODE = 'STO'
	               AND DM_DOCUMENT_D.DELIVERYDATE BETWEEN #{stdDt} AND TO_CHAR(TO_DATE(#{stdDt}, 'YYYYMMDD') + TO_NUMBER(#{execDay}), 'YYYYMMDD')
	               AND DM_DOCUMENT_D.CHANNEL         = '1'
	               AND DM_DOCUMENT_D.DEL_YN          = 'N'), 0) AS STO_ORDERQTY /* 이체량 */                     
	     , NVL((SELECT SUM(ST_STOCK.QTYPICKED)
	              FROM VW_ST_STOCK ST_STOCK
	             WHERE ST_STOCK.STORERKEY = T.STORERKEY
	               AND ST_STOCK.DCCODE    = T.DCCODE
	               AND ST_STOCK.SKU       = T.SKU), 0)          AS QTYPICKED   /* 피킹재고 */
	  FROM (
	        <!-- SELECT A.STORERKEY
	             , A.ROUTE AS FROM_DCCODE
	             , A.DCCODE
	             , A.SKU
	             , #{skuName} AS SKUNAME
	             , A.UOM
	          FROM MS_PURCHASECUST A
	         WHERE A.STORERKEY = 'FW00'
	           AND A.SKU       = #{sku}
	           AND A.DEL_YN    = 'N'
	           AND A.ROUTE IN ('2600','2650','2660','2620','2630','2230','2041','2260', '7710', '7720', '7730', '7740', '7750', '7760', '7734', '7761')
	           AND A.SERIALKEY = (SELECT MIN(DD.SERIALKEY) KEEP(DENSE_RANK FIRST ORDER BY DD.FROMDATE DESC, DD.TODATE ASC)
	                                FROM MS_PURCHASECUST DD
	                               WHERE DD.DCCODE    = A.DCCODE
	                                 AND DD.STORERKEY = A.STORERKEY
	                                 AND DD.SKU       = A.SKU
	                                 AND DD.CUSTTYPE  = A.CUSTTYPE
	                                 AND DD.PLANT     = A.PLANT   
	                                 AND DD.DEL_YN    = 'N'
	                                 AND TO_CHAR(SYSDATE, 'YYYYMMDD') BETWEEN DD.FROMDATE AND DD.TODATE) 26.02.21 양준영님 요청 수정 -->
		         WITH BASE_DATA AS (
				    SELECT A.STORERKEY
				         , A.ROUTE AS FROM_DCCODE
				         , A.DCCODE
				         , A.SKU
				         , A.UOM
				      FROM MS_PURCHASECUST A
				     WHERE A.STORERKEY = 'FW00'
				       AND A.SKU       = #{sku}
				       AND A.DEL_YN    = 'N'
				       AND A.SERIALKEY = (SELECT MIN(DD.SERIALKEY) KEEP(DENSE_RANK FIRST ORDER BY DD.FROMDATE DESC, DD.TODATE ASC)
				                            FROM MS_PURCHASECUST DD
				                           WHERE DD.DCCODE    = A.DCCODE
				                             AND DD.STORERKEY = A.STORERKEY
				                             AND DD.SKU       = A.SKU
				                             AND DD.CUSTTYPE  = A.CUSTTYPE
				                             AND DD.PLANT     = A.PLANT
				                             AND DD.DEL_YN    = 'N'
				                             AND TO_CHAR(SYSDATE, 'YYYYMMDD') BETWEEN DD.FROMDATE AND DD.TODATE)
				)
				SELECT DISTINCT
				       B.STORERKEY
				     , B.FROM_DCCODE   -- 수급센터 (중간 및 최종 모두 포함)
				     , CONNECT_BY_ROOT(B.DCCODE) AS DCCODE -- 최초 시작 출고센터
				     , B.SKU
				     , #{skuName} AS SKUNAME
				     , B.UOM
				  FROM BASE_DATA B
				 START WITH B.DCCODE IN (
				       /* 원본 쿼리에서 DCCODE에 해당하는 값들 */
				       SELECT DISTINCT DCCODE FROM BASE_DATA 
				       WHERE FROM_DCCODE IN ('1000','2600','2650','2660','2620','2630','2230','2041','2250','2260', '2690', '2640', '2270', '2900', '7710', '7720', '7730', '7740', '7750', '7760', '7734', '7761')
				 )
				CONNECT BY NOCYCLE PRIOR B.FROM_DCCODE = B.DCCODE
				 ORDER BY DCCODE, FROM_DCCODE
	       ) T
	 WHERE FROM_DCCODE IN ('1000','2600','2650','2660','2620','2630','2230','2041','2250','2260', '2690', '2640', '2270', '2900', '7710', '7720', '7730', '7740', '7750', '7760', '7734', '7761')
	 GROUP BY STORERKEY, FROM_DCCODE, DCCODE, SKU, SKUNAME, UOM
	 ORDER BY DCCODE ASC
	 <!-- ORDER BY FROM_DCCODE, CASE WHEN DCCODE = '2600' THEN 1
	               WHEN DCCODE = '2620' THEN 2
	               WHEN DCCODE = '2260' THEN 3
	               WHEN DCCODE = '2230' THEN 4
	               WHEN DCCODE = '2800' THEN 5
	               WHEN DCCODE LIKE '1000%' THEN 99
	               ELSE 98
	          END -->
	</select>
	
	<select id="getDetailOrderInfo" resultType="OmPurchaseStorageAutoTotalDetailOrderResDto">
	    /* [omPurchaseStorageAutoTotalService.sqlx][omPurchaseStorageAutoTotalService.getDetailOrderList] */
	    WITH WD_TB AS(
	        SELECT NVL(MS_PURCHASETOTAL.DCCODE, '주문합계') AS DCCODE,
	               MAX(MS_PURCHASETOTAL.SKU) AS SKU,
	               <!-- SUM(CASE WHEN STOCKAVGDAY <![CDATA[>=]]> AFTERDAYWDQTY01 - TODAYWDQTY THEN CEIL(STOCKAVGDAY) ELSE AFTERDAYWDQTY01 - TODAYWDQTY END) AS WDQTY01,
	               SUM(CASE WHEN STOCKAVGDAY <![CDATA[>=]]> AFTERDAYWDQTY02 - AFTERDAYWDQTY01 THEN CEIL(STOCKAVGDAY) ELSE AFTERDAYWDQTY02 - AFTERDAYWDQTY01 END) AS WDQTY02,
	               SUM(CASE WHEN STOCKAVGDAY <![CDATA[>=]]> AFTERDAYWDQTY03 - AFTERDAYWDQTY02 THEN CEIL(STOCKAVGDAY) ELSE AFTERDAYWDQTY03 - AFTERDAYWDQTY02 END) AS WDQTY03,
	               SUM(CASE WHEN STOCKAVGDAY <![CDATA[>=]]> AFTERDAYWDQTY04 - AFTERDAYWDQTY03 THEN CEIL(STOCKAVGDAY) ELSE AFTERDAYWDQTY04 - AFTERDAYWDQTY03 END) AS WDQTY04,
	               SUM(CASE WHEN STOCKAVGDAY <![CDATA[>=]]> AFTERDAYWDQTY05 - AFTERDAYWDQTY04 THEN CEIL(STOCKAVGDAY) ELSE AFTERDAYWDQTY05 - AFTERDAYWDQTY04 END) AS WDQTY05,
	               SUM(CASE WHEN STOCKAVGDAY <![CDATA[>=]]> AFTERDAYWDQTY06 - AFTERDAYWDQTY05 THEN CEIL(STOCKAVGDAY) ELSE AFTERDAYWDQTY06 - AFTERDAYWDQTY05 END) AS WDQTY06,
	               SUM(CASE WHEN STOCKAVGDAY <![CDATA[>=]]> AFTERDAYWDQTY07 - AFTERDAYWDQTY06 THEN CEIL(STOCKAVGDAY) ELSE AFTERDAYWDQTY07 - AFTERDAYWDQTY06 END) AS WDQTY07,
	               SUM(CASE WHEN STOCKAVGDAY <![CDATA[>=]]> AFTERDAYWDQTY08 - AFTERDAYWDQTY07 THEN CEIL(STOCKAVGDAY) ELSE AFTERDAYWDQTY08 - AFTERDAYWDQTY07 END) AS WDQTY08,
	               SUM(CASE WHEN STOCKAVGDAY <![CDATA[>=]]> AFTERDAYWDQTY09 - AFTERDAYWDQTY08 THEN CEIL(STOCKAVGDAY) ELSE AFTERDAYWDQTY09 - AFTERDAYWDQTY08 END) AS WDQTY09,
	               SUM(CASE WHEN STOCKAVGDAY <![CDATA[>=]]> AFTERDAYWDQTY10 - AFTERDAYWDQTY09 THEN CEIL(STOCKAVGDAY) ELSE AFTERDAYWDQTY10 - AFTERDAYWDQTY09 END) AS WDQTY10, 0 -->
	               <!-- SUM(AFTERDAYWDQTY01 - TODAYWDQTY) AS WDQTY01, -->
	               SUM(AFTERDAYWDQTY01) AS WDQTY01,
		           SUM(AFTERDAYWDQTY02 - AFTERDAYWDQTY01) AS WDQTY02,
		           SUM(AFTERDAYWDQTY03 - AFTERDAYWDQTY02) AS WDQTY03,
		           SUM(AFTERDAYWDQTY04 - AFTERDAYWDQTY03) AS WDQTY04,
		           SUM(AFTERDAYWDQTY05 - AFTERDAYWDQTY04) AS WDQTY05,
		           SUM(AFTERDAYWDQTY06 - AFTERDAYWDQTY05) AS WDQTY06,
		           SUM(AFTERDAYWDQTY07 - AFTERDAYWDQTY06) AS WDQTY07,
		           SUM(AFTERDAYWDQTY08 - AFTERDAYWDQTY07) AS WDQTY08,
		           SUM(AFTERDAYWDQTY09 - AFTERDAYWDQTY08) AS WDQTY09,
		           SUM(AFTERDAYWDQTY10 - AFTERDAYWDQTY09) AS WDQTY10,
	               MAX(STOCKQTY) AS STOCKQTY
	          FROM MS_PURCHASETOTAL
	          LEFT OUTER JOIN (
	                SELECT MS_SKU.SKU,
	                       SUM(ST_STOCK_PURCHASE.QTY) AS STOCKQTY
	                  FROM MS_SKU
	                  LEFT OUTER JOIN ST_STOCK_PURCHASE
	                    ON MS_SKU.STORERKEY = ST_STOCK_PURCHASE.STORERKEY
	                   AND MS_SKU.SKU = ST_STOCK_PURCHASE.SKU
	                 WHERE 1=1
	                   AND MS_SKU.STORERKEY = 'FW00'
	                   AND MS_SKU.SKU = #{sku}
	                 GROUP BY MS_SKU.SKU
	              ) ST_STOCK_PURCHASE
	            ON ST_STOCK_PURCHASE.SKU = MS_PURCHASETOTAL.SKU
	          LEFT OUTER JOIN MS_PURCHASESTATS
	            ON MS_PURCHASESTATS.STATSDT = TO_CHAR(SYSDATE, 'YYYYMMDD')
	           AND MS_PURCHASESTATS.DCCODE = MS_PURCHASETOTAL.DCCODE
	           AND MS_PURCHASESTATS.PLANT = MS_PURCHASETOTAL.DCCODE
	           AND MS_PURCHASESTATS.SKU = MS_PURCHASETOTAL.SKU
	         WHERE 1=1
	           AND MS_PURCHASETOTAL.STORERKEY = 'FW00'
	           AND MS_PURCHASETOTAL.DCCODE IN ('2600','2620','2630','2650','2660','2260','2230','2041','2900')
	           AND MS_PURCHASETOTAL.USERID = #{gUserId}
	           AND MS_PURCHASETOTAL.SKU = #{sku}
	         GROUP BY ROLLUP(MS_PURCHASETOTAL.DCCODE)
	    ),
	    <!-- WD_ACCUM_TB AS (
	        SELECT '주문누적합계' AS DCCODE,
	               SKU AS SKU,
	               SUM(WDQTY01) AS WDQTY01,
	               SUM(WDQTY01 + WDQTY02) AS WDQTY02,
	               SUM(WDQTY01 + WDQTY02 + WDQTY03) AS WDQTY03,
	               SUM(WDQTY01 + WDQTY02 + WDQTY03 + WDQTY04) AS WDQTY04,
	               SUM(WDQTY01 + WDQTY02 + WDQTY03 + WDQTY04 + WDQTY05) AS WDQTY05,
	               SUM(WDQTY01 + WDQTY02 + WDQTY03 + WDQTY04 + WDQTY05 + WDQTY06) AS WDQTY06,
	               SUM(WDQTY01 + WDQTY02 + WDQTY03 + WDQTY04 + WDQTY05 + WDQTY06 + WDQTY07) AS WDQTY07,
	               SUM(WDQTY01 + WDQTY02 + WDQTY03 + WDQTY04 + WDQTY05 + WDQTY06 + WDQTY07 + WDQTY08) AS WDQTY08,
	               SUM(WDQTY01 + WDQTY02 + WDQTY03 + WDQTY04 + WDQTY05 + WDQTY06 + WDQTY07 + WDQTY08 + WDQTY09) AS WDQTY09,
	               SUM(WDQTY01 + WDQTY02 + WDQTY03 + WDQTY04 + WDQTY05 + WDQTY06 + WDQTY07 + WDQTY08 + WDQTY09 + WDQTY10) AS WDQTY10,
	               MAX(STOCKQTY) AS STOCKQTY
	          FROM WD_TB
	         WHERE DCCODE IN ('2600','2620','2630','2650','2660','2260','2230','2041','2900')
	         GROUP BY SKU
	    ), -->
	    WD_ACCUM_TB AS (
		    -- 기초 재고 정보를 가져오기 위한 CTE
		    SELECT MAX(STOCKQTY) AS START_STOCK, SKU
		      FROM WD_TB
		     WHERE DCCODE = '주문합계'
		     GROUP BY SKU
		),
	    PURCHASE_TB AS (
	        SELECT '입고정보' AS DCCODE,
	               #{sku} AS SKU,
	               NVL(SUM(CASE WHEN REQUESTDT = TO_CHAR(SYSDATE + 1, 'YYYYMMDD') THEN ORDERQTY END), 0) AS WDQTY01,
	               NVL(SUM(CASE WHEN REQUESTDT = TO_CHAR(SYSDATE + 2, 'YYYYMMDD') THEN ORDERQTY END), 0) AS WDQTY02,
	               NVL(SUM(CASE WHEN REQUESTDT = TO_CHAR(SYSDATE + 3, 'YYYYMMDD') THEN ORDERQTY END), 0) AS WDQTY03,
	               NVL(SUM(CASE WHEN REQUESTDT = TO_CHAR(SYSDATE + 4, 'YYYYMMDD') THEN ORDERQTY END), 0) AS WDQTY04,
	               NVL(SUM(CASE WHEN REQUESTDT = TO_CHAR(SYSDATE + 5, 'YYYYMMDD') THEN ORDERQTY END), 0) AS WDQTY05,
	               NVL(SUM(CASE WHEN REQUESTDT = TO_CHAR(SYSDATE + 6, 'YYYYMMDD') THEN ORDERQTY END), 0) AS WDQTY06,
	               NVL(SUM(CASE WHEN REQUESTDT = TO_CHAR(SYSDATE + 7, 'YYYYMMDD') THEN ORDERQTY END), 0) AS WDQTY07,
	               NVL(SUM(CASE WHEN REQUESTDT = TO_CHAR(SYSDATE + 8, 'YYYYMMDD') THEN ORDERQTY END), 0) AS WDQTY08,
	               NVL(SUM(CASE WHEN REQUESTDT = TO_CHAR(SYSDATE + 9, 'YYYYMMDD') THEN ORDERQTY END), 0) AS WDQTY09,
	               NVL(SUM(CASE WHEN REQUESTDT = TO_CHAR(SYSDATE + 10, 'YYYYMMDD') THEN ORDERQTY END), 0) AS WDQTY10,
	               0 AS STOCKQTY
	          FROM MS_SKU
	          LEFT OUTER JOIN DP_PURCHASE
	            ON MS_SKU.STORERKEY = DP_PURCHASE.STORERKEY
	           AND MS_SKU.SKU = DP_PURCHASE.SKU
	           AND DP_PURCHASE.DCCODE IN ('2600','2620','2630','2650','2660','2260','2230','2041','2900')
	           AND DP_PURCHASE.REQUESTDT BETWEEN TO_CHAR(SYSDATE, 'YYYYMMDD') AND TO_CHAR(SYSDATE + 10, 'YYYYMMDD')
	         WHERE 1=1
	           AND MS_SKU.STORERKEY = 'FW00'
	           AND MS_SKU.SKU = #{sku}
	         GROUP BY MS_SKU.SKU
	        UNION ALL
	        SELECT '입고누적합계' AS DCCODE,
	               #{sku} AS SKU,
	               NVL(SUM(CASE WHEN REQUESTDT = TO_CHAR(SYSDATE + 1, 'YYYYMMDD') THEN ORDERQTY END), 0) AS WDQTY01,
	               NVL(SUM(CASE WHEN REQUESTDT BETWEEN TO_CHAR(SYSDATE + 1, 'YYYYMMDD') AND TO_CHAR(SYSDATE + 2, 'YYYYMMDD') THEN ORDERQTY END), 0) AS WDQTY02,
	               NVL(SUM(CASE WHEN REQUESTDT BETWEEN TO_CHAR(SYSDATE + 1, 'YYYYMMDD') AND TO_CHAR(SYSDATE + 3, 'YYYYMMDD') THEN ORDERQTY END), 0) AS WDQTY03,
	               NVL(SUM(CASE WHEN REQUESTDT BETWEEN TO_CHAR(SYSDATE + 1, 'YYYYMMDD') AND TO_CHAR(SYSDATE + 4, 'YYYYMMDD') THEN ORDERQTY END), 0) AS WDQTY04,
	               NVL(SUM(CASE WHEN REQUESTDT BETWEEN TO_CHAR(SYSDATE + 1, 'YYYYMMDD') AND TO_CHAR(SYSDATE + 5, 'YYYYMMDD') THEN ORDERQTY END), 0) AS WDQTY05,
	               NVL(SUM(CASE WHEN REQUESTDT BETWEEN TO_CHAR(SYSDATE + 1, 'YYYYMMDD') AND TO_CHAR(SYSDATE + 6, 'YYYYMMDD') THEN ORDERQTY END), 0) AS WDQTY06,
	               NVL(SUM(CASE WHEN REQUESTDT BETWEEN TO_CHAR(SYSDATE + 1, 'YYYYMMDD') AND TO_CHAR(SYSDATE + 7, 'YYYYMMDD') THEN ORDERQTY END), 0) AS WDQTY07,
	               NVL(SUM(CASE WHEN REQUESTDT BETWEEN TO_CHAR(SYSDATE + 1, 'YYYYMMDD') AND TO_CHAR(SYSDATE + 8, 'YYYYMMDD') THEN ORDERQTY END), 0) AS WDQTY08,
	               NVL(SUM(CASE WHEN REQUESTDT BETWEEN TO_CHAR(SYSDATE + 1, 'YYYYMMDD') AND TO_CHAR(SYSDATE + 9, 'YYYYMMDD') THEN ORDERQTY END), 0) AS WDQTY09,
	               NVL(SUM(CASE WHEN REQUESTDT BETWEEN TO_CHAR(SYSDATE + 1, 'YYYYMMDD') AND TO_CHAR(SYSDATE + 10, 'YYYYMMDD') THEN ORDERQTY END), 0) AS WDQTY10,
	               0 AS STOCKQTY
	          FROM MS_SKU
	          LEFT OUTER JOIN DP_PURCHASE
	            ON MS_SKU.STORERKEY = DP_PURCHASE.STORERKEY
	           AND MS_SKU.SKU = DP_PURCHASE.SKU
	           AND DP_PURCHASE.DCCODE IN ('2600','2620','2630','2650','2660','2260','2230','2041','2900')
	           AND DP_PURCHASE.REQUESTDT BETWEEN TO_CHAR(SYSDATE, 'YYYYMMDD') AND TO_CHAR(SYSDATE + 10, 'YYYYMMDD')
	         WHERE 1=1
	           AND MS_SKU.STORERKEY = 'FW00'
	           AND MS_SKU.SKU = #{sku}
	         GROUP BY MS_SKU.SKU
	    ),	    
	    STOCK_AVGDAY AS(
             SELECT 
				T.DCCODE
				,T.SKU
				<!-- 통계검증 수정 
				,ROUND((T.SHIPQTY1W_TOTAL / T.BIZDATE))  AS WDQTY01
				,ROUND((T.SHIPQTY1W_TOTAL / T.BIZDATE))  AS WDQTY02
				,ROUND((T.SHIPQTY1W_TOTAL / T.BIZDATE))  AS WDQTY03
				,ROUND((T.SHIPQTY1W_TOTAL / T.BIZDATE))  AS WDQTY04
				,ROUND((T.SHIPQTY1W_TOTAL / T.BIZDATE))  AS WDQTY05
				,ROUND((T.SHIPQTY1W_TOTAL / T.BIZDATE))  AS WDQTY06
				,ROUND((T.SHIPQTY1W_TOTAL / T.BIZDATE))  AS WDQTY07
				,ROUND((T.SHIPQTY1W_TOTAL / T.BIZDATE))  AS WDQTY08
				,ROUND((T.SHIPQTY1W_TOTAL / T.BIZDATE))  AS WDQTY09
				,ROUND((T.SHIPQTY1W_TOTAL / T.BIZDATE))  AS WDQTY10 -->
				,T.STOCKAVGDAY AS WDQTY01
				,T.STOCKAVGDAY AS WDQTY02
				,T.STOCKAVGDAY AS WDQTY03
				,T.STOCKAVGDAY AS WDQTY04
				,T.STOCKAVGDAY AS WDQTY05
				,T.STOCKAVGDAY AS WDQTY06
				,T.STOCKAVGDAY AS WDQTY07
				,T.STOCKAVGDAY AS WDQTY08
				,T.STOCKAVGDAY AS WDQTY09
				,T.STOCKAVGDAY AS WDQTY10				
				,0 AS STOCKQTY
				FROM 
				(
				SELECT '일평균' AS DCCODE,
		               #{sku} AS SKU,
		               NVL(SUM(SHIPQTY1W_SO),0) AS SHIPQTY1W_TOTAL,
		               MAX(MS_SKU.NETWEIGHT) AS NETWEIGHT,
		               MAX(MS_PURCHASESTATS.STOCKAVGDAY) AS STOCKAVGDAY,
		               (SELECT SUM(CASE WHEN REST_YN = 'N' THEN 1 ELSE 0 END) 
					   FROM CM_CALENDAR 
					   WHERE YY||MM||DD BETWEEN TO_CHAR(SYSDATE - 30,'YYYYMMDD') AND TO_CHAR(SYSDATE - 1,'YYYYMMDD')
						AND CM_CALENDAR.DCCODE = 'STD' 
						AND CM_CALENDAR.CALENDAR_ID = 'STD') AS BIZDATE
		          FROM MS_PURCHASESTATS
		          JOIN	MS_SKU
	                ON  MS_PURCHASESTATS.STORERKEY = MS_SKU.STORERKEY
	               AND  MS_PURCHASESTATS.SKU = MS_SKU.SKU
	               WHERE 1=1
		             AND	MS_PURCHASESTATS.STORERKEY = 'FW00'
		             AND   (MS_PURCHASESTATS.DCCODE IN ('2600', '2620', '2630', '2650', '2660', '2230', '2250', '2260', '2270', '2041')
				      OR   (MS_PURCHASESTATS.DCCODE = '1000' AND MS_SKU.SKUTYPE NOT IN('20', '30'))) 
				     AND MS_PURCHASESTATS.SKU = #{sku}
				     AND MS_PURCHASESTATS.STATSDT = TO_CHAR(SYSDATE,'YYYYMMDD')
	              GROUP BY MS_PURCHASESTATS.SKU
				) T
	    ),
	    STOCK_SUMMARY_TB AS(
	            SELECT '재고현황' AS DCCODE,
		           W.SKU,
		           -- 1일차 재고: (재고현황 + 1일입고누적) - max(1일주문, 일평균)
		           -- (NVL(B.START_STOCK, 0) + P.WDQTY01) - GREATEST(W.WDQTY01, A.WDQTY01) AS WDQTY01,
		           -- 1일차 재고: 재고현황 - max(1일주문, 일평균)
		           NVL(B.START_STOCK, 0) - GREATEST(W.WDQTY01, A.WDQTY01) AS WDQTY01,
		           -- 2일차 재고: 재고현황 - (max(1일주문, 일평균) + max(2일주문, 일평균))
		           NVL(B.START_STOCK, 0) - (GREATEST(W.WDQTY01, A.WDQTY01) + GREATEST(W.WDQTY02, A.WDQTY02)) AS WDQTY02,
		           -- 3일차 재고: ... 동일한 방식으로 소요량을 누적 합산하여 차감
		           NVL(B.START_STOCK, 0) - (GREATEST(W.WDQTY01, A.WDQTY01) + GREATEST(W.WDQTY02, A.WDQTY02) + GREATEST(W.WDQTY03, A.WDQTY03)) AS WDQTY03,
		           NVL(B.START_STOCK, 0) - (GREATEST(W.WDQTY01, A.WDQTY01) + GREATEST(W.WDQTY02, A.WDQTY02) + GREATEST(W.WDQTY03, A.WDQTY03) + GREATEST(W.WDQTY04, A.WDQTY04)) AS WDQTY04,
		           NVL(B.START_STOCK, 0) - (GREATEST(W.WDQTY01, A.WDQTY01) + GREATEST(W.WDQTY02, A.WDQTY02) + GREATEST(W.WDQTY03, A.WDQTY03) + GREATEST(W.WDQTY04, A.WDQTY04) + GREATEST(W.WDQTY05, A.WDQTY05)) AS WDQTY05,
		           NVL(B.START_STOCK, 0) - (GREATEST(W.WDQTY01, A.WDQTY01) + GREATEST(W.WDQTY02, A.WDQTY02) + GREATEST(W.WDQTY03, A.WDQTY03) + GREATEST(W.WDQTY04, A.WDQTY04) + GREATEST(W.WDQTY05, A.WDQTY05) + GREATEST(W.WDQTY06, A.WDQTY06)) AS WDQTY06,
		           NVL(B.START_STOCK, 0) - (GREATEST(W.WDQTY01, A.WDQTY01) + GREATEST(W.WDQTY02, A.WDQTY02) + GREATEST(W.WDQTY03, A.WDQTY03) + GREATEST(W.WDQTY04, A.WDQTY04) + GREATEST(W.WDQTY05, A.WDQTY05) + GREATEST(W.WDQTY06, A.WDQTY06) + GREATEST(W.WDQTY07, A.WDQTY07)) AS WDQTY07,
		           NVL(B.START_STOCK, 0) - (GREATEST(W.WDQTY01, A.WDQTY01) + GREATEST(W.WDQTY02, A.WDQTY02) + GREATEST(W.WDQTY03, A.WDQTY03) + GREATEST(W.WDQTY04, A.WDQTY04) + GREATEST(W.WDQTY05, A.WDQTY05) + GREATEST(W.WDQTY06, A.WDQTY06) + GREATEST(W.WDQTY07, A.WDQTY07) + GREATEST(W.WDQTY08, A.WDQTY08)) AS WDQTY08,
		           NVL(B.START_STOCK, 0) - (GREATEST(W.WDQTY01, A.WDQTY01) + GREATEST(W.WDQTY02, A.WDQTY02) + GREATEST(W.WDQTY03, A.WDQTY03) + GREATEST(W.WDQTY04, A.WDQTY04) + GREATEST(W.WDQTY05, A.WDQTY05) + GREATEST(W.WDQTY06, A.WDQTY06) + GREATEST(W.WDQTY07, A.WDQTY07) + GREATEST(W.WDQTY08, A.WDQTY08) + GREATEST(W.WDQTY09, A.WDQTY09)) AS WDQTY09,
		           NVL(B.START_STOCK, 0) - (GREATEST(W.WDQTY01, A.WDQTY01) + GREATEST(W.WDQTY02, A.WDQTY02) + GREATEST(W.WDQTY03, A.WDQTY03) + GREATEST(W.WDQTY04, A.WDQTY04) + GREATEST(W.WDQTY05, A.WDQTY05) + GREATEST(W.WDQTY06, A.WDQTY06) + GREATEST(W.WDQTY07, A.WDQTY07) + GREATEST(W.WDQTY08, A.WDQTY08) + GREATEST(W.WDQTY09, A.WDQTY09) + GREATEST(W.WDQTY10, A.WDQTY10)) AS WDQTY10,
		           0 AS STOCKQTY
		      FROM WD_TB W
		      JOIN WD_ACCUM_TB B ON W.SKU = B.SKU
		      JOIN STOCK_AVGDAY A ON W.SKU = A.SKU
		      JOIN (SELECT * FROM PURCHASE_TB WHERE DCCODE = '입고누적합계') P ON W.SKU = P.SKU
		     WHERE W.DCCODE = '주문합계'
	    )
	    SELECT *
	      FROM (
	        SELECT DCCODE, SKU, WDQTY01, WDQTY02, WDQTY03, WDQTY04, WDQTY05,
	               WDQTY06, WDQTY07, WDQTY08, WDQTY09, WDQTY10, STOCKQTY
	          FROM WD_TB
	         UNION ALL
	        SELECT DCCODE, SKU, WDQTY01, WDQTY02, WDQTY03, WDQTY04, WDQTY05,
	               WDQTY06, WDQTY07, WDQTY08, WDQTY09, WDQTY10, STOCKQTY
	          FROM PURCHASE_TB
	         WHERE DCCODE = '입고정보'
	         UNION ALL
	        SELECT DCCODE, SKU, WDQTY01, WDQTY02, WDQTY03, WDQTY04, WDQTY05,
	               WDQTY06, WDQTY07, WDQTY08, WDQTY09, WDQTY10, STOCKQTY
	          FROM STOCK_SUMMARY_TB
	        UNION ALL
	        SELECT DCCODE, SKU, WDQTY01, WDQTY02, WDQTY03, WDQTY04, WDQTY05,
	               WDQTY06, WDQTY07, WDQTY08, WDQTY09, WDQTY10, STOCKQTY
	          FROM STOCK_AVGDAY
	      )
	     ORDER BY
	         CASE
	             WHEN DCCODE = '재고현황' THEN 1
	             WHEN DCCODE = '입고정보' THEN 2
	             WHEN DCCODE = '일평균'  THEN 3
	             WHEN DCCODE = '주문합계' THEN 4
	         END,
	         DCCODE ASC
	</select>

	<select id="getDetailRightInfo" resultType="OmPurchaseStorageAutoTotalDetailRightResDto">
	    /* [omPurchaseStorageAutoTotalService.sqlx][omPurchaseStorageAutoTotalService.getDetailRightInfo][당일이후 입고 내역 조회] */
	    SELECT TBL.DCCODE            AS DCCODE,        /* 센터코드 */
	           TBL.SKU               AS SKU,           /* 상품코드 */
	           TBL.SKUNAME           AS SKUNAME,       /* 상품명 */
	           TBL.UOM               AS UOM,           /* 단위 */
	           TBL.WORKPROCESSCODE   AS WORKPROCESSCODE, /* 주문유형 */
	           TBL.OPENQTY           AS OPENQTY,       /* 수량 */
	           <!-- TBL.PURCHASE_QTY      AS PURCHASE_QTY,  /* PO수량 */ -->
	           ''      AS PURCHASE_QTY,  /* PO수량 */
	           TBL.PREQTY            AS PREQTY,        /* 공급확정수량 */
	           TBL.CONFIRMQTY        AS CONFIRMQTY,    /* 입고확정수량 */
	           TBL.SLIPDT            AS SLIPDT,        /* 입고예정일 */
	           TBL.DOCNO             AS DOCNO,         /* 주문번호 */
	           TBL.DOCLINE           AS DOCLINE,       /* 주문상세번호 */
	           TBL.SLIPNO,
	           TBL.SLIPLINE,
	           TBL.REQUESTNO,
	           TBL.REQUESTLINE,
	           TBL.FROM_CUSTKEY      AS FROM_CUSTKEY,  /* 거래처코드 */
	           TBL.FROM_CUSTNAME     AS FROM_CUSTNAME, /* 거래처명 */
	           TBL.ORGANIZE          AS ORGANIZE,      /* 조직코드 */
	           TBL.ORGANIZENAME      AS ORGANIZENAME,  /* 조직명칭 */
	           TO_CHAR(TBL.ADDDATE, 'yyyy-mm-dd hh24:mi:ss') AS ADDDATE, /* 발주생성일 */
	           TBL.CUSTKEY,
	           TBL.CUSTTYPE,
	           TBL.STATUS_YN,
	           TBL.STOCKID
	      FROM (
	        SELECT DP_PURCHASE.DCCODE                                       AS DCCODE,
	               DP_PURCHASE.SKU                                          AS SKU,
	               MS_SKU.DESCRIPTION                                       AS SKUNAME,
	               DP_PURCHASE.UOM                                          AS UOM,
	               NULL                                                     AS WORKPROCESSCODE,
	               NVL(DP_PURCHASE.ORDERQTY, 0)                              AS OPENQTY,
	               NVL(DP_PURCHASE.ORDERQTY, 0)                             AS PURCHASE_QTY,
	               NVL(DP_PURCHASE.CONFIRMQTY, 0)                           AS PREQTY,
	               0                                                        AS CONFIRMQTY,
	               DP_PURCHASE.REQUESTDT                                    AS SLIPDT,
	               NULL                                                     AS DOCNO,
	               NULL                                                     AS DOCLINE,
	               NULL                                                     AS SLIPNO,
	               NULL                                                     AS SLIPLINE,
	               DM_DOCUMENT_H.FROM_CUSTKEY                               AS FROM_CUSTKEY,
	               DM_DOCUMENT_H.FROM_CUSTNAME                              AS FROM_CUSTNAME,
	               DP_PURCHASE.ORGANIZE                                     AS ORGANIZE,
	               CM_DCXORGANIZE.DESCRIPTION                               AS ORGANIZENAME,
	               DP_PURCHASE.ADDDATE                                      AS ADDDATE,
	               DP_PURCHASE.REQUESTNO,
	               DP_PURCHASE.REQUESTLINE,
	               DP_PURCHASE.CUSTKEY,
	               DP_PURCHASE.CUSTTYPE,
	               'Y' AS STATUS_YN,
	               '' AS STOCKID
	          FROM DP_PURCHASE
	          LEFT OUTER JOIN MS_PURCHASEMST  
		        ON MS_PURCHASEMST.STORERKEY = DP_PURCHASE.STORERKEY
		       AND MS_PURCHASEMST.DCCODE = DP_PURCHASE.DCCODE
		       AND MS_PURCHASEMST.CUSTTYPE = DP_PURCHASE.CUSTTYPE
		       AND MS_PURCHASEMST.SKU = DP_PURCHASE.SKU
	          LEFT OUTER JOIN DM_DOCUMENT_D
	            ON DM_DOCUMENT_D.STORERKEY = DP_PURCHASE.STORERKEY
	           AND DM_DOCUMENT_D.DCCODE = DP_PURCHASE.DCCODE
	           AND DM_DOCUMENT_D.SKU = DP_PURCHASE.SKU
	           AND DM_DOCUMENT_D.POKEY = DP_PURCHASE.POKEY
	           AND DM_DOCUMENT_D.POLINE = DP_PURCHASE.POLINE
	          LEFT OUTER JOIN DM_DOCUMENT_H
	            ON DM_DOCUMENT_H.STORERKEY = DM_DOCUMENT_D.STORERKEY
	           AND DM_DOCUMENT_H.DOCTYPE = DM_DOCUMENT_D.DOCTYPE
	           AND DM_DOCUMENT_H.DOCNO = DM_DOCUMENT_D.DOCNO
	           AND DM_DOCUMENT_H.DCCODE = DM_DOCUMENT_D.DCCODE
	          LEFT OUTER JOIN CM_DCXORGANIZE
	            ON CM_DCXORGANIZE.DCCODE = DP_PURCHASE.DCCODE
	           AND CM_DCXORGANIZE.ORGANIZE = DP_PURCHASE.ORGANIZE
	          LEFT OUTER JOIN MS_SKU
	            ON DP_PURCHASE.STORERKEY = MS_SKU.STORERKEY
	           AND DP_PURCHASE.SKU = MS_SKU.SKU
	         WHERE 1=1
	           AND DP_PURCHASE.STORERKEY = 'FW00'
	           AND DP_PURCHASE.REQUESTDT <![CDATA[>=]]> TO_CHAR(SYSDATE, 'YYYYMMDD')
	           AND DP_PURCHASE.DCCODE = #{dcCode}
	           AND DP_PURCHASE.SKU = #{sku}
	           AND DP_PURCHASE.DEL_YN = 'N'
	           AND DP_PURCHASE.CHANNEL = '1'
	           <if test="buyerKey != null and buyerKey != ''">
			       AND MS_PURCHASEMST.BUYERKEY = #{buyerKey}
			   </if>
	           AND DM_DOCUMENT_H.DOCNO IS NULL
	
	        UNION ALL
	
	        SELECT DP_INPLAN.DCCODE,
	               DP_INPLAN.SKU,
	               MS_SKU.DESCRIPTION AS SKUNAME,
	               DP_INPLAN.UOM,
	               <!-- CASE WHEN DM_DOCUMENT_D.IF_SEND_TYPE = 'STOFS' THEN 'STO' ELSE DM_DOCUMENT_D.WORKPROCESSCODE END AS WORKPROCESSCODE, -->
	               DM_DOCUMENT_D.WORKPROCESSCODE,
	               CASE WHEN WD_DM_D.DCCODE = '2170' OR DM_DOCUMENT_D.WORKPROCESSCODE = 'STO' OR DM_DOCUMENT_D.IF_SEND_TYPE = 'STOFS' THEN
	                  NVL((SELECT SUM(C.OPENQTY) FROM DP_INPLAN C WHERE C.DOCNO = DM_DOCUMENT_D.DOCNO AND C.DOCLINE = DM_DOCUMENT_D.DOCLINE), 0)
	               ELSE
	                  NVL((SELECT SUM(C.ORDERQTY) FROM DP_PURCHASE C WHERE C.POKEY = DM_DOCUMENT_D.POKEY AND C.POLINE = DM_DOCUMENT_D.POLINE AND C.DEL_YN = 'N'), 0)
	               END AS OPENQTY,
	               NVL((SELECT SUM(C.ORDERQTY)
	                      FROM DP_PURCHASE C
	                     WHERE C.POKEY = DM_DOCUMENT_D.POKEY
	                       AND C.POLINE = DM_DOCUMENT_D.POLINE
	                       AND C.DEL_YN = 'N'), 0) AS PURCHASE_QTY,
	               CASE
	                   WHEN DM_DOCUMENT_D.WORKPROCESSCODE = 'STO' THEN
	                       NVL((SELECT FROMSTO.STORERCONFIRMQTY
	                              FROM DM_DOCUMENT_D FROMSTO
	                             WHERE FROMSTO.WORKPROCESSCODE = 'STO'
	                               AND FROMSTO.DCCODE = CASE WHEN SUBSTR(DM_DOCUMENT_H.FROM_CUSTKEY, 0, 4) IN ('2170', '1000') THEN SUBSTR(DM_DOCUMENT_H.FROM_CUSTKEY, 0, 4) ELSE DM_DOCUMENT_H.FROM_CUSTKEY END
	                               AND FROMSTO.STORERKEY = DP_INPLAN.STORERKEY
	                               AND FROMSTO.DOCTYPE = 'WD'
	                               AND FROMSTO.DOCDT = DP_INPLAN.DOCDT
	                               AND FROMSTO.DOCLINE = DP_INPLAN.DOCLINE
	                               AND FROMSTO.DOCNO = DP_INPLAN.DOCNO), 0)
	                   ELSE NVL(DP_INPLAN.OPENQTY, 0)
	               END AS PREQTY,
	               CASE
	                   WHEN DM_DOCUMENT_D.WORKPROCESSCODE = 'STO' THEN NVL(DM_DOCUMENT_D.STORERCONFIRMQTY, 0)
	                   ELSE NVL(DP_INPLAN.CONFIRMQTY, 0)
	               END AS CONFIRMQTY,
	               DP_INPLAN.SLIPDT,
	               DP_INPLAN.DOCNO,
	               DP_INPLAN.DOCLINE,
	               DP_INPLAN.SLIPNO,
	               DP_INPLAN.SLIPLINE,
	               DM_DOCUMENT_H.FROM_CUSTKEY,
	               DM_DOCUMENT_H.FROM_CUSTNAME,
	               DM_DOCUMENT_H.ORGANIZE,
	               CM_DCXORGANIZE.DESCRIPTION AS ORGANIZENAME,
	               DP_INPLAN.ADDDATE,
	               NULL AS REQUESTNO,
	               NULL AS REQUESTLINE,
	               NULL AS CUSTKEY,
	               NULL AS CUSTTYPE,
	               CASE 
			           WHEN DM_DOCUMENT_D.STATUS = '30' AND WD_DM_D.STATUS = '30' AND DM_DOCUMENT_D.WORKPROCESSCODE <![CDATA[<>]]> 'PO' THEN 'Y'
			           ELSE 'N'
			       END AS STATUS_YN,
			       WD_DM_D.STOCKID
	          FROM DP_INPLAN
	          JOIN DM_DOCUMENT_H
	            ON DM_DOCUMENT_H.STORERKEY = DP_INPLAN.STORERKEY
	           AND DM_DOCUMENT_H.DCCODE = DP_INPLAN.DCCODE
	           AND DM_DOCUMENT_H.DOCDT = DP_INPLAN.DOCDT
	           AND DM_DOCUMENT_H.DOCNO = DP_INPLAN.DOCNO
	           AND DM_DOCUMENT_H.DOCTYPE = DP_INPLAN.DOCTYPE
	          JOIN DM_DOCUMENT_D
	            ON DM_DOCUMENT_D.DOCTYPE = DM_DOCUMENT_H.DOCTYPE
	           AND DM_DOCUMENT_D.DOCNO = DM_DOCUMENT_H.DOCNO
	           AND DM_DOCUMENT_D.DCCODE = DM_DOCUMENT_H.DCCODE
	           AND DM_DOCUMENT_D.DOCNO = DP_INPLAN.DOCNO
	           AND DM_DOCUMENT_D.DOCLINE = DP_INPLAN.DOCLINE
	          LEFT OUTER JOIN DM_DOCUMENT_D WD_DM_D  
	            ON WD_DM_D.DOCDT   = DM_DOCUMENT_D.DOCDT                                   
	           AND WD_DM_D.DOCTYPE = 'WD'                        
	           AND WD_DM_D.DOCNO   = DM_DOCUMENT_D.DOCNO                       
	           AND WD_DM_D.DOCLINE = DM_DOCUMENT_D.DOCLINE
	          LEFT OUTER JOIN CM_DCXORGANIZE
	            ON CM_DCXORGANIZE.DCCODE = DM_DOCUMENT_H.DCCODE
	           AND CM_DCXORGANIZE.ORGANIZE = DM_DOCUMENT_H.ORGANIZE
	          JOIN MS_SKU
	            ON DP_INPLAN.STORERKEY = MS_SKU.STORERKEY
	           AND DP_INPLAN.SKU = MS_SKU.SKU
	         WHERE 1=1
	           AND DP_INPLAN.STORERKEY = 'FW00'
	           AND DP_INPLAN.SLIPDT <![CDATA[>=]]> TO_CHAR(SYSDATE, 'YYYYMMDD')
	           AND DP_INPLAN.DOCTYPE = 'DP'
	           AND DP_INPLAN.DCCODE = #{dcCode}
	           AND DP_INPLAN.SKU = #{sku}
	           AND DP_INPLAN.DEL_YN = 'N'
	           AND DM_DOCUMENT_D.CHANNEL = '1'
	      ) TBL
	     ORDER BY TBL.SLIPDT, TBL.ADDDATE ASC
	</select>
	
	<!-- 입출고 당일이후 집계 최종 생성시간 조회 -->
    <select id="getLastCreation" resultType="OmPurchaseStorageAutoTotalResDto">
        SELECT /* [omPurchaseStorageAutoTotalService.sqlx][omPurchaseStorageAutoTotalService.getLastCreation][입출고 당일이후 집계 최종생성시간] */
               TO_CHAR(MAX(EDITDATE), 'YYYY-MM-DD HH24:MI:SS') AS LASTCREATION
          FROM MS_PURCHASETOTAL
         WHERE MS_PURCHASETOTAL.USERID = #{gUserId}
    </select>
    
    <!-- 입출고 당일이후 집계 처리 -->
    <update id="recreationPurchaseTotal">
    	/* [omPurchaseStorageAutoTotalService.sqlx][omPurchaseStorageAutoTotalService.recreationPurchaseTotal] */
    	BEGIN
    		SPDP_PURCHASE.RECREATION_PURCHASETOTAL(#{gUserId});
    	END;
	</update>
	
	<delete id="deleteTempTable">
        DELETE /* [omPurchaseStorageAutoTotalService.sqlx][deleteTempTable][데이터임시 Tabele 삭제][jangjaehyun][2025.10.18] */
               SY_PROCESSTEMP_ST
         WHERE PROCESSCREATOR = #{gUserId}
           AND PROCESSTYPE    = 'OM_TEMPORDER'
           AND SPID           = #{gSpid}
           AND STATUS <![CDATA[<>]]> '10'
    </delete>
    
    <insert id="insertTempTable" parameterType="java.util.List">
	    DECLARE BEGIN
	    <foreach collection="list" index="index" item="item" separator=";">
	        /* [omPurchaseStorageAutoTotalService.sqlx][insertTempTable][데이터임시 Tabele 등록][jangjaehyun][2025.10.18] */
	        INSERT INTO SY_PROCESSTEMP_ST 
	            (
	            PROCESSTYPE
	            ,PROCESSCREATOR
	            ,SPID
	            ,ADDWHO
	            ,EDITWHO
	            ,FROM_DCCODE
	            ,FROM_STORERKEY
	            ,FROM_ORGANIZE
	            ,FROM_AREA
	            ,FROM_SKU
	            ,FROM_LOC
	            ,FROM_LOT
	            ,FROM_STOCKID
	            ,FROM_STOCKGRADE
	            ,FROM_STOCKTYPE
	            ,FROM_ORDERQTY
	            ,FROM_UOM
	            ,TO_DCCODE
	            ,TO_STORERKEY
	            ,TO_ORGANIZE
	            ,TO_AREA
	            ,TO_SKU
	            ,TO_LOC
	            ,TO_LOT
	            ,TO_STOCKID
	            ,TO_STOCKGRADE
	            ,TO_STOCKTYPE
	            ,TO_ORDERQTY
	            ,TO_UOM
	            ,ETCQTY1
	            ,ETCQTY2
	            ,SRCSERIALKEY1
	            ,FROM_BUNJA
	            ,FROM_BUNMO
	            ,STATUS
	            )
	        VALUES 
	            (
	            'OM_TEMPORDER'
	            ,#{item.gUserId}
	            ,#{item.gSpid}
	            ,#{item.gUserId}
	            ,#{item.gUserId}
	            ,#{item.fromDcCode}
	            ,#{item.gStorerkey}
	            ,#{item.routeOrganize}
	            ,#{item.area}
	            ,#{item.sku}
	            ,'' /* FROM_LOC */
	            ,'' /* FROM_LOT */
	            ,'STD' /* FROM_STOCKID */
	            ,'STD' /* FROM_STOCKGRADE */            	
	            ,'' /* FROM_STOCKTYPE */
	            ,#{item.confirmQty}
	            ,#{item.uom}
	            ,#{item.dcCode}
	            ,#{item.gStorerkey}
	            ,#{item.organize}
	            ,#{item.area}
	            ,#{item.sku}
	            ,'' /* TO_LOC */
	            ,'' /* TO_LOT */
	            ,'STD' /* TO_STOCKID */
	            ,'STD' /* TO_STOCKGRADE */
	            ,'' /* TO_STOCKTYPE */
	            ,#{item.confirmQty}
	            ,#{item.uom}
	            ,0
	            ,0
	            ,#{item.receiveDt}
	            ,#{item.bunja}
	            ,#{item.bunmo}
	            ,#{item.status}
	            )
	    </foreach>
	    ; END;
	</insert>
    
    <insert id="insertTempTableOut">
        /* [omPurchaseStorageAutoTotalService.sqlx][insertTempTable][데이터임시 Tabele 등록][jangjaehyun][2025.10.18] */
		INSERT INTO SY_PROCESSTEMP_ST
		      (SERIALKEY,
		       PROCESSTYPE,
		       PROCESSCREATOR,
		       SPID,
		       
		       FROM_DCCODE,
		       FROM_STORERKEY,
		       FROM_ORGANIZE,
		       FROM_AREA,
		       FROM_SKU,
		       
		       FROM_LOC,
		       FROM_LOT,
		       FROM_STOCKID,
		       FROM_STOCKGRADE,
		       FROM_STOCKTYPE,
		       
		       FROM_ORDERQTY,
		       FROM_UOM,
		       FROM_BUNJA,
		       FROM_BUNMO,
		       
		       TO_DCCODE,
		       TO_STORERKEY,
		       TO_ORGANIZE,
		       TO_AREA,
		       TO_SKU,
		       
		       TO_LOC,
		       TO_LOT,
		       TO_STOCKID,
		       TO_STOCKGRADE,
		       TO_STOCKTYPE,
		       
		       TO_ORDERQTY,
		       TO_UOM,
		       ETCQTY1,
		       ETCQTY2,
		       SRCSERIALKEY1,
		       
		       ADDDATE,
		       EDITDATE,
		       ADDWHO,
		       EDITWHO
		       )
		       
	    SELECT SEQ_SY_PROCESSTEMP_ST.NEXTVAL,
	           'OM_TEMPORDER',
	           PROCESSCREATOR,
	           SPID,
	             
	           FROM_DCCODE,
	           FROM_STORERKEY,
	           FROM_ORGANIZE,
	           FROM_AREA,
	           FROM_SKU, 
	             
	           FROM_LOC,
	           FROM_LOT,
	           FROM_STOCKID,
	           FROM_STOCKGRADE,
	           FROM_STOCKTYPE,
	           
	           FROM_ORDERQTY,
	           FROM_UOM,
	           FROM_BUNJA,
	           FROM_BUNMO,
	             
	           TO_DCCODE,
	           TO_STORERKEY,
	           TO_ORGANIZE,
	           TO_AREA,
	           TO_SKU,
	             
	           TO_LOC,
	           TO_LOT,
	           TO_STOCKID,
	           TO_STOCKGRADE,
	           TO_STOCKTYPE,
	             
	           TO_ORDERQTY,
	           TO_UOM,
	           ETCQTY1,
	           CASE 
	            WHEN LINE01 = 'Y' THEN 
	                CASE WHEN TO_ORDERQTY <![CDATA[>]]> 0 THEN 
	                     CASE WHEN TO_ORDERQTY <![CDATA[<]]> LINE02 THEN 1 
	                          ELSE ROUND(TO_ORDERQTY / LINE02)
	                     END
	                ELSE 0
	                END
	            ELSE CASE WHEN TO_ORDERQTY <![CDATA[>]]> 0 THEN 
	                     CASE WHEN TO_ORDERQTY * BOX_CAL <![CDATA[<]]> 1 THEN 1
	                          ELSE ROUND(TO_ORDERQTY * BOX_CAL)
	                     END
	                 ELSE 0
	                 END
	           END                                         AS ETCQTY2,
	           SRCSERIALKEY1,
	           SYSDATE,
	           SYSDATE,
	           PROCESSCREATOR,
	           PROCESSCREATOR
	    FROM (
	        
	        SELECT '' AS TO_LOC,
	               <!--case
	                 when (TEMPQTY - sum(POSQTY) over(order by EXPIRY rows between unbounded preceding and current row) + POSQTY) <![CDATA[<=]]> 0 then 0
	                 when POSQTY <![CDATA[>=]]> (TEMPQTY - sum(POSQTY) over(order by EXPIRY rows between unbounded preceding and current row) + POSQTY) then (TEMPQTY - sum(POSQTY) over(order by EXPIRY rows between unbounded preceding and current row) + POSQTY)
	                 else POSQTY
	               end-->
	               TEMPQTY AS TO_ORDERQTY,
	               FROM_DCCODE,
	               FROM_STORERKEY,
	               FROM_ORGANIZE,
	               FROM_AREA,
	               FROM_SKU,
	               FROM_LOC,
	               FROM_LOT,
	               FROM_STOCKID,
	               FROM_STOCKGRADE,
	               FROM_STOCKTYPE,
	               FROM_ORDERQTY,
	               FROM_UOM,
	               FROM_BOXQTY,
	               #{dcCode}       AS TO_DCCODE,
	               #{gStorerkey}    AS TO_STORERKEY,
	               #{organize}     AS TO_ORGANIZE,
	               #{area}         AS TO_AREA,
	               TO_SKU,
	               TO_LOT,
	               TO_STOCKID,
	               TO_STOCKGRADE,
	               TO_STOCKTYPE,
	               TO_UOM,
	               ETCQTY1,
	               LINE01,
	               LINE02,
	               BOX_CAL,
	               #{receiveDt}      AS SRCSERIALKEY1,
	               #{bunja}          AS FROM_BUNJA,
	               #{bunmo}          AS FROM_BUNMO,
	               #{gUserId}        AS PROCESSCREATOR,
	               #{gSpid}          AS SPID
	               FROM (
	                    
	                     SELECT FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'N')                AS DURATION, 
	                            NVL(TO_NUMBER(#{confirmQty}), 0)                                                                              AS TEMPQTY,
	                            (NVL(ST_STOCK.QTY - ST_STOCK.QTYALLOCATED - ST_STOCK.QTYPICKED,0))/MS_SKU.QTYPERBOX                           AS POSQTY,
	                            ST_STOCK.DCCODE                                                                                               AS FROM_DCCODE,
	                            ST_STOCK.STORERKEY                                                                                            AS FROM_STORERKEY,
	                            ST_STOCK.ORGANIZE                                                                                             AS FROM_ORGANIZE,
	                            ST_STOCK.AREA                                                                                                 AS FROM_AREA,
	                            ST_STOCK.SKU                                                                                                  AS FROM_SKU,
	                            ST_STOCK.LOC                                                                                                  AS FROM_LOC,
	                            ST_STOCK.LOT                                                                                                  AS FROM_LOT,
	                            ST_STOCK.STOCKID                                                                                              AS FROM_STOCKID,
	                            ST_STOCK.STOCKGRADE                                                                                           AS FROM_STOCKGRADE,
	                            ST_STOCK.STOCKTYPE                                                                                            AS FROM_STOCKTYPE,
	                            ST_STOCK.QTY                                                                                                  AS FROM_ORDERQTY,
	                            ST_STOCK.UOM                                                                                                  AS FROM_UOM,
	                            ST_STOCK.BOXQTY                                                                                               AS FROM_BOXQTY,
	                            #{dcCode}                                                                                                     AS TO_DCCODE,
	                            #{gStorerkey}                                                                                                 AS TO_STORERKEY,
	                            #{organize}                                                                                                   AS TO_ORGANIZE,
	                            #{area}                                                                                                       AS TO_AREA,
	                            ST_STOCK.SKU                                                                                                  AS TO_SKU,
	                            ST_STOCK.LOT                                                                                                  AS TO_LOT,
	                            ST_STOCK.STOCKID                                                                                              AS TO_STOCKID,
	                            ST_STOCK.STOCKGRADE                                                                                           AS TO_STOCKGRADE,
	                            ST_STOCK.STOCKTYPE                                                                                            AS TO_STOCKTYPE,
	                            ST_STOCK.UOM                                                                                                  AS TO_UOM,
	                            ST_STOCK.QTYALLOCATED                                                                                         AS ETCQTY1,
	                            (SELECT FN_CODEDESCR(#{gStorerkey}, 'YN', NVL(MS_SKU.LINE01,'N')) 
	                               FROM DUAL)                                                                                                 AS LINE01,  
	                            TO_NUMBER(MS_SKU.LINE02)                                                                                      AS LINE02,
	                            TO_NUMBER(FN_CONV_UOM(ST_STOCK.STORERKEY, ST_STOCK.SKU, #{uom}, 'BOX', 1))                                    AS BOX_CAL,
	                            TO_NUMBER(FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'N'))     AS EXPIRY,
	                            (SELECT 1 
	                               FROM ST_SNINFO 
	                              WHERE ST_SNINFO.STOCKID = ST_STOCK.STOCKID 
	                                AND ST_SNINFO.CONVSERIALNO IS NOT NULL)                                                                   AS BLYN,
	                            (SELECT 1 
	                               FROM ST_SNINFO 
	                              WHERE ST_SNINFO.STOCKID = ST_STOCK.STOCKID 
	                                AND ST_SNINFO.CONTRACTTYPE NOT IN ('30', '30 - 계약', '30 - 계약영업', '90', '90 - 당일매입매출'))               AS CONTRACTYN
	                       FROM VW_ST_STOCK ST_STOCK
	                       JOIN MS_SKU
	                         ON MS_SKU.STORERKEY    =    ST_STOCK.STORERKEY
	                        AND MS_SKU.SKU          =    ST_STOCK.SKU
	                        AND MS_SKU.DEL_YN       =    'N'
	                       JOIN CM_LOT
	                         ON CM_LOT.STORERKEY    =    ST_STOCK.STORERKEY
	                        AND CM_LOT.LOT          =    ST_STOCK.LOT
	                        AND CM_LOT.DEL_YN       =    'N'
	                      WHERE 1 = 1
	                        AND ST_STOCK.DCCODE IN ('2170')
	                        AND ST_STOCK.QTY - ST_STOCK.QTYALLOCATED - ST_STOCK.QTYPICKED <![CDATA[>]]> 0
	                        AND ST_STOCK.SKU        = #{sku}
	                        AND ST_STOCK.STORERKEY  = #{gStorerkey}
	                        AND ST_STOCK.ORGANIZE   = #{outOrganize}
	                        AND ST_STOCK.STOCKID    = #{stockid}
	                        AND ST_STOCK.STOCKGRADE = 'STD'   
	                      ORDER BY EXPIRY
	                  ) Y
	                      WHERE 1=1
	                        <!-- AND BLYN <![CDATA[>=]]> 0
	                        AND CONTRACTYN <![CDATA[>=]]> 0
	                        AND EXPIRY <![CDATA[>]]> 0 -->
	              ) X
	     WHERE TO_ORDERQTY <![CDATA[>]]> 0
    </insert>
    
    <insert id="insertTempTableOutReorder">
    	/* [omPurchaseStorageAutoTotalService.sqlx][insertTempTable][데이터임시 Tabele 등록][jangjaehyun][2025.10.18] */
    	INSERT INTO SY_PROCESSTEMP_ST
	      (SERIALKEY,
	       PROCESSTYPE,
	       PROCESSCREATOR,
	       SPID,
	       
	       FROM_DCCODE,
	       FROM_STORERKEY,
	       FROM_ORGANIZE,
	       FROM_AREA,
	       FROM_SKU,
	       
	       FROM_LOC,
	       FROM_LOT,
	       FROM_STOCKID,
	       FROM_STOCKGRADE,
	       FROM_STOCKTYPE,
	       
	       FROM_ORDERQTY,
	       FROM_UOM,
	       FROM_BUNJA,
	       FROM_BUNMO,
	       
	       TO_DCCODE,
	       TO_STORERKEY,
	       TO_ORGANIZE,
	       TO_AREA,
	       TO_SKU,
	       
	       TO_LOC,
	       TO_LOT,
	       TO_STOCKID,
	       TO_STOCKGRADE,
	       TO_STOCKTYPE,
	       
	       TO_ORDERQTY,
	       TO_UOM,
	       ETCQTY1,
	       ETCQTY2,
	       SRCSERIALKEY1,
	       
	       ADDDATE,
	       EDITDATE,
	       ADDWHO,
	       EDITWHO
	       )
	       
	       SELECT SEQ_SY_PROCESSTEMP_ST.NEXTVAL,
           'OM_TEMPORDER',
           PROCESSCREATOR,
           SPID,
             
           FROM_DCCODE,
           FROM_STORERKEY,
           FROM_ORGANIZE,
           FROM_AREA,
           FROM_SKU, 
             
           FROM_LOC,
           FROM_LOT,
           FROM_STOCKID,
           FROM_STOCKGRADE,
           FROM_STOCKTYPE,
           
           FROM_ORDERQTY,
           FROM_UOM,
           FROM_BUNJA,
           FROM_BUNMO,
             
           TO_DCCODE,
           TO_STORERKEY,
           TO_ORGANIZE,
           TO_AREA,
           TO_SKU,
             
           TO_LOC,
           TO_LOT,
           TO_STOCKID,
           TO_STOCKGRADE,
           TO_STOCKTYPE,
             
           TO_ORDERQTY,
           TO_UOM,
           ETCQTY1,
           CASE 
            WHEN LINE01 = 'Y' THEN 
                CASE WHEN TO_ORDERQTY <![CDATA[>]]> 0 THEN 
                     CASE WHEN TO_ORDERQTY <![CDATA[<]]> LINE02 THEN 1 
                          ELSE ROUND(TO_ORDERQTY / LINE02)
                     END
                ELSE 0
                END
            ELSE CASE WHEN TO_ORDERQTY <![CDATA[>]]> 0 THEN 
                     CASE WHEN TO_ORDERQTY * BOX_CAL <![CDATA[<]]> 1 THEN 1
                          ELSE ROUND(TO_ORDERQTY * BOX_CAL)
                     END
                 ELSE 0
                 END
           END                                         AS ETCQTY2,
           SRCSERIALKEY1,
           SYSDATE,
           SYSDATE,
           PROCESSCREATOR,
           PROCESSCREATOR
        FROM (
        
        SELECT '' AS TO_LOC,
               <!-- case
                 when (TEMPQTY - sum(POSQTY) over(order by EXPIRY rows between unbounded preceding and current row) + POSQTY) <![CDATA[<=]]> 0 then 0
                 when POSQTY <![CDATA[>=]]> (TEMPQTY - sum(POSQTY) over(order by EXPIRY rows between unbounded preceding and current row) + POSQTY) then (TEMPQTY - sum(POSQTY) over(order by EXPIRY rows between unbounded preceding and current row) + POSQTY)
                 else POSQTY
               end               AS TO_ORDERQTY, -->
               TEMPQTY AS TO_ORDERQTY,
               FROM_DCCODE,
               FROM_STORERKEY,
               FROM_ORGANIZE,
               FROM_AREA,
               FROM_SKU,
               FROM_LOC,
               FROM_LOT,
               FROM_STOCKID,
               FROM_STOCKGRADE,
               FROM_STOCKTYPE,
               FROM_ORDERQTY,
               FROM_UOM,
               FROM_BOXQTY,
               #{dcCode}       AS TO_DCCODE,
               #{gStorerkey}    AS TO_STORERKEY,
               #{organize}     AS TO_ORGANIZE,
               #{area}         AS TO_AREA,
               TO_SKU,
               TO_LOT,
               TO_STOCKID,
               TO_STOCKGRADE,
               TO_STOCKTYPE,
               TO_UOM,
               ETCQTY1,
               LINE01,
               LINE02,
               BOX_CAL,
               #{receiveDt}      AS SRCSERIALKEY1,
               (SELECT NVL(BUNJA, 1) FROM MS_UOM WHERE STORERKEY = 'FW00' AND SKU = #{sku} AND UOM = #{purchaseUom}) AS FROM_BUNJA,
               (SELECT NVL(BUNMO, 1) FROM MS_UOM WHERE STORERKEY = 'FW00' AND SKU = #{sku} AND UOM = #{purchaseUom}) AS FROM_BUNMO,
               #{gUserId}        AS PROCESSCREATOR,
               #{gSpid}          AS SPID
               FROM (
                    
                     SELECT FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'N')                AS DURATION, 
                            NVL(TO_NUMBER(#{orderQty}), 0)                                                                                AS TEMPQTY,
                            (NVL(ST_STOCK.QTY - ST_STOCK.QTYALLOCATED - ST_STOCK.QTYPICKED,0))/MS_SKU.QTYPERBOX                           AS POSQTY,
                            ST_STOCK.DCCODE                                                                                               AS FROM_DCCODE,
                            ST_STOCK.STORERKEY                                                                                            AS FROM_STORERKEY,
                            ST_STOCK.ORGANIZE                                                                                             AS FROM_ORGANIZE,
                            ST_STOCK.AREA                                                                                                 AS FROM_AREA,
                            ST_STOCK.SKU                                                                                                  AS FROM_SKU,
                            ST_STOCK.LOC                                                                                                  AS FROM_LOC,
                            ST_STOCK.LOT                                                                                                  AS FROM_LOT,
                            ST_STOCK.STOCKID                                                                                              AS FROM_STOCKID,
                            ST_STOCK.STOCKGRADE                                                                                           AS FROM_STOCKGRADE,
                            ST_STOCK.STOCKTYPE                                                                                            AS FROM_STOCKTYPE,
                            ST_STOCK.QTY                                                                                                  AS FROM_ORDERQTY,
                            ST_STOCK.UOM                                                                                                  AS FROM_UOM,
                            ST_STOCK.BOXQTY                                                                                               AS FROM_BOXQTY,
                            #{dcCode}                                                                                                     AS TO_DCCODE,
                            #{gStorerkey}                                                                                                 AS TO_STORERKEY,
                            #{organize}                                                                                                   AS TO_ORGANIZE,
                            #{area}                                                                                                       AS TO_AREA,
                            ST_STOCK.SKU                                                                                                  AS TO_SKU,
                            ST_STOCK.LOT                                                                                                  AS TO_LOT,
                            ST_STOCK.STOCKID                                                                                              AS TO_STOCKID,
                            ST_STOCK.STOCKGRADE                                                                                           AS TO_STOCKGRADE,
                            ST_STOCK.STOCKTYPE                                                                                            AS TO_STOCKTYPE,
                            ST_STOCK.UOM                                                                                                  AS TO_UOM,
                            ST_STOCK.QTYALLOCATED                                                                                         AS ETCQTY1,
                            (SELECT FN_CODEDESCR(#{gStorerkey}, 'YN', NVL(MS_SKU.LINE01,'N')) 
                               FROM DUAL)                                                                                                 AS LINE01,  
                            TO_NUMBER(MS_SKU.LINE02)                                                                                      AS LINE02,
                            TO_NUMBER(FN_CONV_UOM(ST_STOCK.STORERKEY, ST_STOCK.SKU, #{uom}, 'BOX', 1))                                    AS BOX_CAL,
                            TO_NUMBER(FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'N'))     AS EXPIRY,
                            (SELECT 1 
                               FROM ST_SNINFO 
                              WHERE ST_SNINFO.STOCKID = ST_STOCK.STOCKID 
                                AND ST_SNINFO.CONVSERIALNO IS NOT NULL)                                                                   AS BLYN,
                            (SELECT 1 
                               FROM ST_SNINFO 
                              WHERE ST_SNINFO.STOCKID = ST_STOCK.STOCKID 
                                AND ST_SNINFO.CONTRACTTYPE NOT IN ('30', '30 - 계약', '30 - 계약영업', '90', '90 - 당일매입매출'))               AS CONTRACTYN
                       FROM VW_ST_STOCK ST_STOCK
                       JOIN MS_SKU
                         ON MS_SKU.STORERKEY    =    ST_STOCK.STORERKEY
                        AND MS_SKU.SKU          =    ST_STOCK.SKU
                        AND MS_SKU.DEL_YN       =    'N'
                       JOIN CM_LOT
                         ON CM_LOT.STORERKEY    =    ST_STOCK.STORERKEY
                        AND CM_LOT.LOT          =    ST_STOCK.LOT
                        AND CM_LOT.DEL_YN       =    'N'
                      WHERE 1 = 1
                        AND ST_STOCK.DCCODE IN ('2170')
                        AND ST_STOCK.QTY - ST_STOCK.QTYALLOCATED - ST_STOCK.QTYPICKED <![CDATA[>]]> 0
                        AND ST_STOCK.SKU = #{sku}
                        AND ST_STOCK.STORERKEY = #{gStorerkey}
                        AND ST_STOCK.ORGANIZE   = #{outOrganize}
	                    AND ST_STOCK.STOCKID    = #{stockid}
                        AND ST_STOCK.STOCKGRADE = 'STD'                                   
                      ORDER BY EXPIRY
                  ) Y
                      WHERE BLYN <![CDATA[>=]]> 0
                        AND CONTRACTYN <![CDATA[>=]]> 0
                        AND EXPIRY <![CDATA[>]]> 0
              ) X
        WHERE TO_ORDERQTY <![CDATA[>]]> 0
    </insert>
    
