<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="msExDCStatusService">

    <select id="getExDCStatusList" resultType="MsExDCStatusListResDto" parameterType="MsExDCStatusListReqDto">
        SELECT /* [msExDCStatusService.sqlx][getExDCStatusList][외부창고현황 기준정보 조회 (목록)][권정윤][20250616] */
               RSLT.DCCODE           AS DCCODE
             , RSLT.PLANT            AS PLANT
             , RSLT.ORGANIZE         AS ORGANIZE
             , RSLT.PLANTNAME        AS PLANTNAME
             , RSLT.STARTDATE        AS STARTDATE
             , RSLT.ENDDATE          AS ENDDATE
             , RSLT.STORAGELOC       AS STORAGELOC
             , RSLT.STORAGELOCNAME   AS STORAGELOCNAME
             , RSLT.DISTRICT         AS DISTRICT
             , RSLT.AREA             AS AREA
             , RSLT.SKU              AS SKU
             , RSLT.STORAGETYPE_LIST AS STORAGETYPE_LIST
         FROM ( SELECT BASE_RSLT.DCCODE                                                                                     AS DCCODE
                     , BASE_RSLT.PLANT                                                                                      AS PLANT
                     , BASE_RSLT.ORGANIZE                                                                                   AS ORGANIZE
                     , BASE_RSLT.PLANTNAME                                                                                  AS PLANTNAME
                     , BASE_RSLT.STARTDATE                                                                                  AS STARTDATE
                     , BASE_RSLT.ENDDATE                                                                                    AS ENDDATE
                     , BASE_RSLT.STORAGELOC                                                                                 AS STORAGELOC
                     , BASE_RSLT.STORAGELOCNAME                                                                             AS STORAGELOCNAME
                     , BASE_RSLT.DISTRICT                                                                                   AS DISTRICT
                     , BASE_RSLT.AREA                                                                                       AS AREA
                     , LISTAGG( DISTINCT EXDCRATE_RSLT.SPECDESCR, ', ') WITHIN GROUP (ORDER BY EXDCRATE_RSLT.SPECDESCR)     AS SKU
                     , LISTAGG( DISTINCT EXDCRATE_RSLT.STORAGETYPE, ', ') WITHIN GROUP (ORDER BY EXDCRATE_RSLT.STORAGETYPE) AS STORAGETYPE_LIST
                  FROM ( SELECT MS_PLANTXSL.DCCODE,
	                            MS_PLANTXSL.PLANT,
	                            MS_PLANTXSL.PLANT || '-' || MS_PLANTXSL.STORAGELOC AS ORGANIZE,
	                            MS_PLANT.DESCRIPTION                               AS PLANTNAME,
	                            MS_PLANTXSL.STARTDATE                              AS STARTDATE,
                                MS_PLANTXSL.ENDDATE                                AS ENDDATE,
	                            MS_PLANTXSL.STORAGELOC,
	                            MS_PLANTXSL.DESCRIPTION                            AS STORAGELOCNAME,
	                            MS_PLANTXSL.FAX,
	                            MS_PLANTXSL.DISTRIC                                AS DISTRICT,
	                            MS_PLANTXSL.AREA                                   AS AREA,
	                            MS_PLANTXSL.REMARK,
	                            MS_PLANTXSL.ADDWHO,
	                            MS_PLANTXSL.ADDDATE,
	                            MS_PLANTXSL.EDITDATE,
	                            MS_PLANTXSL.EDITWHO
                           FROM MS_PLANTXSL
                           JOIN MS_PLANT ON MS_PLANTXSL.PLANT = MS_PLANT.PLANT
                           LEFT JOIN MS_CUST ON MS_CUST.STORERKEY = #{gStorerkey}
                                            AND MS_CUST.CUSTKEY   = MS_PLANTXSL.MEMO
                                            AND MS_CUST.CUSTTYPE  = 'P'
	                      WHERE MS_PLANTXSL.CONTRACTYN = 'Y'
   	                      <if test="organize != null and organize != ''">
                              <choose>
	           		      <when test='fixDcCode == "2170"'>
	              	              AND CONCAT('2170-', MS_PLANTXSL.STORAGELOC) IN ( SELECT TRIM(REGEXP_SUBSTR(VAL, '[^,]+', 1, LEVEL)) AS VAL
	           		                                                             FROM ( SELECT #{organize} AS VAL FROM DUAL ) A
	           		                                                          CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0 )
                                  </when>
                                  <otherwise>
	  	          		          AND MS_PLANTXSL.STORAGELOC IN ( SELECT TRIM(REGEXP_SUBSTR(VAL, '[^,]+', 1, LEVEL)) AS VAL
	           		                                            FROM ( SELECT #{organize} AS VAL FROM DUAL ) A
	           		                                         CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0 )
                                  </otherwise>
                              </choose>
                          </if>
                          <if test="district != null and district != ''">
                              AND MS_PLANTXSL.DISTRIC LIKE '%'|| #{district} || '%'
                          </if>
                          <if test="area != null and area != ''">
                              AND MS_PLANTXSL.AREA = #{area}
                          </if>
                              AND (MS_PLANTXSL.STARTDATE BETWEEN #{fromDt} AND #{thruDt}
                                   OR
                                   MS_PLANTXSL.ENDDATE BETWEEN #{fromDt} AND #{thruDt} )
                       ) BASE_RSLT
                    LEFT OUTER JOIN ( SELECT MS_EXDCRATE.STORERKEY
                                           , MS_EXDCRATE.DCCODE
                                           , MS_EXDCRATE.ORGANIZE
                                           , MS_EXDCRATE.FROMDATE
                                           , MS_EXDCRATE.TODATE
                                           , MS_SKUSPEC.SPECDESCR
                                           , MS_EXDCRATE.STORAGETYPE
	  	                              FROM MS_EXDCRATE
	  	                              JOIN MS_SKU ON MS_EXDCRATE.SKU = MS_SKU.SKU
	  	                              JOIN MS_SKUSPEC ON SUBSTR(MS_SKU.SKUGROUP, 1, 2) = MS_SKUSPEC.SPECCODE
	  	                             WHERE MS_EXDCRATE.DCCODE    = #{fixDcCode}
	  	                               AND MS_EXDCRATE.STORERKEY = #{gStorerkey}
                       ) EXDCRATE_RSLT ON BASE_RSLT.DCCODE    = EXDCRATE_RSLT.DCCODE
                                      AND BASE_RSLT.ORGANIZE  = EXDCRATE_RSLT.ORGANIZE
                                      AND ( BASE_RSLT.STARTDATE BETWEEN EXDCRATE_RSLT.FROMDATE AND EXDCRATE_RSLT.TODATE
                                            OR
                                            BASE_RSLT.ENDDATE BETWEEN EXDCRATE_RSLT.FROMDATE AND EXDCRATE_RSLT.TODATE )
                   GROUP BY BASE_RSLT.DCCODE
                          , BASE_RSLT.PLANT
                          , BASE_RSLT.ORGANIZE
                          , BASE_RSLT.PLANTNAME
                          , BASE_RSLT.STARTDATE
                          , BASE_RSLT.ENDDATE
                          , BASE_RSLT.STORAGELOC
                          , BASE_RSLT.STORAGELOCNAME
                          , BASE_RSLT.DISTRICT
                          , BASE_RSLT.AREA
             ) RSLT
         WHERE 1 = 1
       <if test="storagetype != null and storagetype != ''">
           AND INSTR(RSLT.STORAGETYPE_LIST, #{storagetype}) > 0
       </if>
         ORDER BY RSLT.STORAGELOC
    </select>

	<select id="getExDCStatusDtl" resultType="MsExDCStatusDetailResDto" parameterType="MsExDCStatusDetailReqDto">
	    SELECT /* [msPlantXSLService.sqlx][getMsPlantXSLDetail][외부창고현황 상세 조회][권정윤][20250616] */
	        MS_PLANTXSL.PLANT         AS PLANT,
	        MS_PLANTXSL.DCCODE        AS DCCODE,
	        MS_PLANTXSL.SERIALKEY,
	        MS_PLANTXSL.STORAGELOC    AS STORAGELOC,
	        MS_PLANTXSL.DESCRIPTION   AS DESCRIPTION,
	        MS_PLANTXSL.OWNER         AS OWNER,
	        MS_PLANTXSL.SERIALKEY	  AS SERIALKEY,
	        MS_PLANTXSL.TIMEZONE      AS TIMEZONE,
	        MS_PLANTXSL.COUNTRY       AS COUNTRY,
	        MS_PLANTXSL.STATE         AS STATE,
	        MS_PLANTXSL.DISTRIC       AS DISTRICT,
	        MS_PLANTXSL.AREA          AS AREA,
	        MS_PLANTXSL.CITY          AS CITY,
	        MS_PLANTXSL.ZIPCODE       AS ZIPCODE,
	        MS_PLANTXSL.ADDRESS1      AS ADDRESS1,
	        MS_PLANTXSL.ADDRESS2      AS ADDRESS2,
	        MS_PLANTXSL.PHONE1        AS PHONE1,
	        MS_PLANTXSL.PHONE2        AS PHONE2,
	        MS_PLANTXSL.FAX           AS FAX,
	        MS_PLANTXSL.EMAIL         AS EMAIL,
	        MS_PLANTXSL.VATNO         AS VATNO,
	        MS_PLANTXSL.VATOWNER      AS VATOWNER,
	        MS_PLANTXSL.VATTYPE       AS VATTYPE,
	        MS_PLANTXSL.VATNAME       AS VATNAME,
	        MS_PLANTXSL.VATCATEGORY   AS VATCATEGORY,
	        MS_PLANTXSL.VATADDRESS1   AS VATADDRESS1,
	        MS_PLANTXSL.VATADDRESS2   AS VATADDRESS2,
	        MS_PLANTXSL.VATPHONE      AS VATPHONE,
	        MS_PLANTXSL.VATFAX        AS VATFAX,
	        MS_PLANTXSL.EMPNAME1      AS EMPNAME1,
	        MS_PLANTXSL.EMPNAME2      AS EMPNAME2,
	        MS_PLANTXSL.EMPPHONE1     AS EMPPHONE1,
	        MS_PLANTXSL.EMPPHONE2     AS EMPPHONE2,
	        TO_CHAR(TO_DATE(MS_PLANTXSL.STARTDATE, 'YYYYMMDD'), 'YYYY-MM-DD') AS CONTRACTSTARTDATE,
	    	TO_CHAR(TO_DATE(MS_PLANTXSL.ENDDATE, 'YYYYMMDD'), 'YYYY-MM-DD') AS CONTRACTENDDATE,
	        MS_PLANTXSL.FLOATMASK     AS FLOATMASK,
	        MS_PLANTXSL.MEMO          AS MEMO,
	       (	 SELECT MS_CUST.DESCRIPTION
		         FROM MS_CUST
		         WHERE MS_CUST.STORERKEY = #{gStorerkey}
	             AND MS_CUST.CUSTKEY = MS_PLANTXSL.MEMO
	             AND MS_CUST.CUSTTYPE = 'P'
	         )		 				  AS MEMONAME,
	        MS_PLANTXSL.IFFILENAME    AS IFFILENAME,
	        MS_PLANTXSL.STATUS        AS STATUS,
	        MS_PLANTXSL.DEL_YN        AS DEL_YN,
	        MS_PLANTXSL.TRAFFICCOP    AS TRAFFICCOP,
	        MS_PLANTXSL.ARCHIVECOP    AS ARCHIVECOP,
	        MS_PLANTXSL.ADDDATE       AS ADDDATE,
	        MS_PLANTXSL.EDITDATE      AS EDITDATE,
	        MS_PLANTXSL.ADDWHO        AS ADDWHO,
	        MS_PLANTXSL.EDITWHO       AS EDITWHO,
	        MS_PLANTXSL.INC_DP_DAY_YN AS INC_DP_DAY_YN,
	        MS_PLANTXSL.INC_WD_DAY_YN AS INC_WD_DAY_YN,
	        MS_PLANTXSL.EXT_COST_YN   AS EXT_COST_YN,
	        MS_PLANTXSL.FAX2          AS FAX2,
	        MS_PLANTXSL.EMAIL2        AS EMAIL2,
	        MS_PLANTXSL.COMM_CODE     AS COMMCODE,
	        MS_PLANTXSL.SAVE_CODE     AS SAVECODE,
	        MS_PLANTXSL.SITEADDR      AS SITEADDR,
	        MS_PLANTXSL.SITEID        AS SITEID,
	        MS_PLANTXSL.SITEPW        AS SITEPW,
	        MS_PLANTXSL.CONTRACTYN    AS CONTRACTYN,
	        MS_PLANTXSL.CONTRACTDATE  AS CONTRACTDATE,
	        MS_PLANTXSL.REMARK        AS REMARK,
	        MS_PLANTXSL.EMAIL_YN      AS EMAIL_YN,
	        MS_PLANTXSL.CONTRACT_CHG_NTC_YN     AS CONTRACTCHGNTCYN,
			MS_PLANTXSL.CONTRACT_RMK            AS CONTRACTRMK,
			MS_PLANTXSL.USEBYDATE_EMAIL_SEND_YN AS USEBYDATEEMAILSENDYN,
			MS_PLANTXSL.USEBYDATE_FREE_RT       AS USEBYDATEFREERT,
			(SELECT COUNT(S.SERIALKEY)
	          FROM MS_PLANTXSL_FILE S
	         WHERE S.DOC_ID = MS_PLANTXSL.SERIALKEY
	           AND S.DOC_NAME = 'MS_PLANTXSL')  AS FILE_CNT
	    FROM MS_PLANTXSL
	    WHERE MS_PLANTXSL.PLANT = #{plant}
	      AND MS_PLANTXSL.STORAGELOC = #{storageloc}
	</select>

	<select id="getExDCStatusSkuRateList" resultType="MsExDCSpecRateEntity">
	    SELECT /* [MsExDCStatusService.sqlx][msExDCStatusService.getExDCStatusSkuRateList][상품요율 정보 조회][JiHoPark][2025.12.20] */
               RSLT.SPECCODENM                                               AS SPECCODENM
             , FN_CODEDESCR(RSLT.STORERKEY, 'STORAGETYPE', RSLT.STORAGETYPE) AS STORAGETYPENM
             , RSLT.BASEUOM                                                  AS BASEUOM
             , ROUND(AVG(NVL(RSLT.GRPRICEUPPERTRANSKG, 0)), 2)               AS GRPRICEUPPERTRANSKG
             , ROUND(AVG(NVL(RSLT.GIPRICEUPPERTRANSKG, 0)), 2)               AS GIPRICEUPPERTRANSKG
             , ROUND(AVG(NVL(RSLT.STORAGEPRICEUPPERTRANSKG, 0)), 2)          AS STORAGEPRICEUPPERTRANSKG
          FROM ( SELECT MS_EXDCRATE.DCCODE                                                                                                                                                                                           AS DCCODE
                      , MS_EXDCRATE.STORERKEY                                                                                                                                                                                        AS STORERKEY
                      , MS_EXDCRATE.ORGANIZE                                                                                                                                                                                         AS ORGANIZE
                      , MS_EXDCRATE.FROMDATE                                                                                                                                                                                         AS FROMDATE
                      , MS_EXDCRATE.TODATE                                                                                                                                                                                           AS TODATE
                      , MS_EXDCRATE.SPECCODE                                                                                                                                                                                         AS SPECCODE
                      , ( SELECT MS_SKUSPEC.SPECDESCR
                            FROM MS_SKUSPEC
                           WHERE MS_SKUSPEC.STORERKEY =  #{gStorerkey}
                             AND MS_SKUSPEC.SPECCODE = SUBSTR(MS_EXDCRATE.SPECCODE, 1, 2)
                        )                                                                                                                                                                                                            AS SPECCODENM
                      , MS_EXDCRATE.SKU AS SKU
                      , MS_SKU.BASEUOM AS BASEUOM
                      , MS_EXDCRATE.AREA_PRICE_UOM AS AREA_PRICE_UOM
                      , MS_EXDCRATE.GRPRICE AS GRPRICE
                      , MS_SKU.STORAGETYPE AS STORAGETYPE
                      , NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.GRPRICE, 'KG', MS_SKU.QTYPERBOX, NVL((MS_DC_PLT_LOAD.BOXPERLAYER * MS_DC_PLT_LOAD.LAYERPERPLT), 0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT), 0)    AS GRPRICEUPPERTRANSKG   /* 입고비(KG) */
                      , NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.GIPRICE, 'KG', MS_SKU.QTYPERBOX, NVL((MS_DC_PLT_LOAD.BOXPERLAYER * MS_DC_PLT_LOAD.LAYERPERPLT), 0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT), 0)    AS GIPRICEUPPERTRANSKG   /* 출고비(KG) */
                      , NVL(FN_CONV_EXDCRATE(MS_EXDCRATE.AREA_PRICE_UOM, MS_EXDCRATE.STORAGEPRICE,'KG',MS_SKU.QTYPERBOX, NVL((MS_DC_PLT_LOAD.BOXPERLAYER * MS_DC_PLT_LOAD.LAYERPERPLT), 0), MS_SKU.PACKPERBOX, MS_SKU.NETWEIGHT), 0) AS STORAGEPRICEUPPERTRANSKG /* 창고료(KG) */
                   FROM MS_EXDCRATE
                   LEFT JOIN MS_SKU ON MS_SKU.STORERKEY = MS_EXDCRATE.STORERKEY
                                   AND MS_SKU.SKU       = MS_EXDCRATE.SKU
                   LEFT JOIN MS_DC_PLT_LOAD ON MS_DC_PLT_LOAD.SKU   = MS_EXDCRATE.SKU
                                           AND MS_DC_PLT_LOAD.PLANT = MS_EXDCRATE.ORGANIZE
                  WHERE MS_EXDCRATE.DCCODE    = #{dccode}
                    AND MS_EXDCRATE.STORERKEY = #{gStorerkey}
                    AND MS_EXDCRATE.ORGANIZE  = #{organize}
                    AND MS_EXDCRATE.DEL_YN    = 'N'
                    AND ( #{startdate} BETWEEN MS_EXDCRATE.FROMDATE AND MS_EXDCRATE.TODATE
                           OR #{enddate} BETWEEN MS_EXDCRATE.FROMDATE AND MS_EXDCRATE.TODATE )
             ) RSLT
         GROUP BY RSLT.STORERKEY
                , RSLT.SPECCODENM
                , RSLT.STORAGETYPE
                , RSLT.BASEUOM
        ORDER BY RSLT.SPECCODENM
               , RSLT.STORAGETYPE
               , RSLT.BASEUOM
	</select>

    <select id="getExDCStatusSkuRateList_before" resultType="MsExDCSpecRateEntity" parameterType="MsExDCStatusDetailReqDto">
    	        WITH T1_MS_EXDCRATE AS
	         (
	            SELECT MS_EXDCRATE.SERIALKEY,
	                   MS_EXDCRATE.STORERKEY,
	                   MS_EXDCRATE.FROMDATE,
	                   MS_EXDCRATE.TODATE,
	                   MS_EXDCRATE.DCCODE,
	                   MS_EXDCRATE.ORGANIZE,
	                   SUBSTR(SKUGROUP, 1, 2) AS SPECCODE,
	                   MS_SKU.BASEUOM,
	                   MS_EXDCRATE.SKU,
	                   MS_EXDCRATE.EXPENSETYPE,
	                   MS_EXDCRATE.WORKPRICE,
	                   MS_SKU.STORAGETYPE,
	                   MS_EXDCRATE.TRUCKPRICE,
	                   MS_EXDCRATE.STATUS,
	                   MS_EXDCRATE.DEL_YN,
	                   MS_EXDCRATE.EXDCRATE_RANK,
	                   MS_SKU.NETWEIGHT,
	                   MS_EXDCRATE.GRPRICE_UPPER,
	                   MS_EXDCRATE.GIPRICE_UPPER,
	                   MS_EXDCRATE.STORAGEPRICE_UPPER,
	                   MS_EXDCRATE.STOGRPRICE_UPPER,
	                   MS_EXDCRATE.STOGIPRICE_UPPER,
	                   MS_EXDCRATE.GRPRICE_LOWER,
	                   MS_EXDCRATE.GIPRICE_LOWER,
	                   MS_EXDCRATE.STORAGEPRICE_LOWER,
	                   MS_EXDCRATE.STOGRPRICE_LOWER,
	                   MS_EXDCRATE.STOGIPRICE_LOWER,
	                   CASE WHEN MS_EXDCRATE.EXDCRATE_RANK = '10' THEN MS_EXDCRATE.GRPRICE_UPPER ELSE ROUND(MS_EXDCRATE.GRPRICE_LOWER / MS_SKU.NETWEIGHT, 2) END AS GRPRICE_RANK,
	                   CASE WHEN MS_EXDCRATE.EXDCRATE_RANK = '10' THEN MS_EXDCRATE.GIPRICE_UPPER ELSE ROUND(MS_EXDCRATE.GIPRICE_LOWER / MS_SKU.NETWEIGHT, 2) END AS GIPRICE_RANK,
	                   CASE WHEN MS_EXDCRATE.EXDCRATE_RANK = '10' THEN MS_EXDCRATE.STORAGEPRICE_UPPER ELSE ROUND(MS_EXDCRATE.STORAGEPRICE_LOWER / MS_SKU.NETWEIGHT, 2) END AS STORAGEPRICE_RANK
	            FROM MS_EXDCRATE
	            LEFT OUTER JOIN MS_SKU ON MS_SKU.STORERKEY = MS_EXDCRATE.STORERKEY AND MS_SKU.SKU = MS_EXDCRATE.SKU
				WHERE MS_EXDCRATE.ORGANIZE = #{organize}
				AND (MS_EXDCRATE.FROMDATE BETWEEN #{fromDt} AND #{thruDt}
				     OR
				     MS_EXDCRATE.TODATE BETWEEN #{fromDt} AND #{thruDt})
	        ),
	        T2_MS_EXDCRATE AS
	         (
	            SELECT DENSE_RANK() OVER(PARTITION BY STORERKEY, DCCODE, ORGANIZE, SPECCODE, STORAGETYPE ORDER BY COUNT(1) DESC, (GRPRICE_RANK + GIPRICE_RANK + STORAGEPRICE_RANK) DESC) AS RANK,
	                   STORERKEY,
	                   DCCODE,
	                   STORAGETYPE,
	                   ORGANIZE,
	                   SPECCODE,
	                   MAX(FROMDATE),
	                   MAX(DEL_YN),
	                   GRPRICE_RANK,
	                   GIPRICE_RANK,
	                   STORAGEPRICE_RANK
	            FROM T1_MS_EXDCRATE
	            GROUP BY STORERKEY, DCCODE, ORGANIZE, SPECCODE, STORAGETYPE, GRPRICE_RANK, GIPRICE_RANK, STORAGEPRICE_RANK
	        ),
	        T3_MS_EXDCRATE AS
	         (
	            SELECT ROW_NUMBER() OVER(PARTITION BY T1.STORERKEY, T1.DCCODE, T1.ORGANIZE, T1.SPECCODE, T1.STORAGETYPE ORDER BY EXDCRATE_RANK, TODATE DESC) AS SPECCODE_RANK,
	                   T1.*
	            FROM T1_MS_EXDCRATE T1
	            JOIN T2_MS_EXDCRATE T2 ON T1.STORERKEY = T2.STORERKEY AND T1.DCCODE = T2.DCCODE AND T1.ORGANIZE = T2.ORGANIZE AND T1.SPECCODE = T2.SPECCODE
	                                      AND T1.GRPRICE_RANK = T2.GRPRICE_RANK AND T1.GIPRICE_RANK = T2.GIPRICE_RANK AND T1.STORAGEPRICE_RANK = T2.STORAGEPRICE_RANK
	        )
	    SELECT /* [msPlantXSLService.sqlx][getExDCStatusSkuRateList][외부창고 현황관리 요율 조회][권정윤][20250616] */
			    T3.SPECCODE             AS sku,
			    (
			        SELECT MS_SKUSPEC.SPECDESCR
			        FROM MS_SKUSPEC
			        WHERE MS_SKUSPEC.SPECCODE = T3.SPECCODE
			        FETCH FIRST 1 ROWS ONLY
			    ) AS skuName,
			    T3.STORAGETYPE          AS storagetype,
			    T3.BASEUOM              AS baseuom,
			    T3.GIPRICE_RANK         AS gipriceRank,
			    T3.GRPRICE_RANK         AS grpriceRank,
			    T3.STORAGEPRICE_RANK    AS storagepriceRank
			FROM (
			    SELECT * FROM T3_MS_EXDCRATE WHERE SPECCODE_RANK = '1'
			) T3
    </select>

    <select id="getDataSelectPlant" resultType="map">
			SELECT  /* [msPlantXSLService.sqlx][msPlantXSLService.getDataSelectPlant][플랜트 리스트][권정윤][20250616] */
					PLANT          	                   AS plant
			       ,'['||PLANT||']'||DESCRIPTION	   AS plantname
			FROM MS_PLANT
			WHERE PLANT IN (SELECT DCCODE FROM CM_DC WHERE DEL_YN = 'N')
    </select>

	<select id="getMsPlantxslFileList" resultType="MsPlantXSLFileEntity">
	    SELECT /* [msPlantXSLService.sqlx][getMsPlantxslFileList][권정윤][20250616] */
	           '0'                    AS CHECKYN,
	           MS_PLANTXSL_FILE.SERIALKEY             AS SERIALKEY,
	           MS_PLANTXSL_FILE.DOC_ID                AS DOC_ID,
	           MS_PLANTXSL_FILE.DOC_TYPE              AS DOC_TYPE,
	           MS_PLANTXSL_FILE.DOC_NAME              AS DOC_NAME,
	           MS_PLANTXSL_FILE.FILE_NAME             AS FILE_NAME,
	           MS_PLANTXSL_FILE.FILE_EXTENSION        AS FILE_EXTENSION,
	           MS_PLANTXSL_FILE.FILE_LOCATION         AS FILE_LOCATION,
	           MS_PLANTXSL_FILE.FILE_SIZE_BYTES       AS FILE_SIZE_BYTES,
	           MS_PLANTXSL_FILE.TRANS_FILE_NAME       AS TRANS_FILE_NAME,
	           MS_PLANTXSL_FILE.UPLOAD_HASH_ID        AS UPLOAD_HASH_ID,
	           MS_PLANTXSL_FILE.UPLOAD_RES_DOC_ID     AS UPLOAD_RES_DOC_ID,
	           MS_PLANTXSL_FILE.UPLOAD_FILE_NAME      AS UPLOAD_FILE_NAME,
	           MS_PLANTXSL_FILE.UPLOAD_WORKPLACE_ID   AS UPLOAD_WORKPLACE_ID,
	           MS_PLANTXSL_FILE.UPLOAD_LOCATION       AS UPLOAD_LOCATION,
	           MS_PLANTXSL_FILE.DOWNLOAD_COUNT        AS DOWNLOAD_COUNT,
	           MS_PLANTXSL_FILE.FILE_TYPE             AS FILE_TYPE,
	           MS_PLANTXSL_FILE.STATUS                AS STATUS,
	           MS_PLANTXSL_FILE.ADDWHO                AS ADDWHO,
	           MS_PLANTXSL_FILE.ADDDATE               AS ADDDATE,
	           TO_CHAR(MS_PLANTXSL_FILE.ADDDATE, 'yyyy-mm-dd hh24:mi:ss') AS ADDDATE,
	           TO_CHAR(MS_PLANTXSL_FILE.EDITDATE, 'yyyy-mm-dd hh24:mi:ss') AS EDITDATE
	    FROM MS_PLANTXSL_FILE
	    WHERE DOC_NAME = 'MS_PLANTXSL'
	      AND DOC_ID = #{serialkey}
	      AND STATUS = 'Y'
	    ORDER BY MS_PLANTXSL_FILE.SERIALKEY
	</select>

	<select id="getContractDateRangeList" resultType="map">
	    SELECT /* [msPlantXSLService.sqlx][getContractDateRangeList][계약기간 목록 조회][권정윤][20250610] */
			FROMDATE, TODATE
	    FROM MS_EXDCRATE
	    WHERE MS_EXDCRATE.DCCODE = #{plant}
	      AND MS_EXDCRATE.ORGANIZE = #{organize}
	    GROUP BY FROMDATE, TODATE
	</select>

</mapper>
