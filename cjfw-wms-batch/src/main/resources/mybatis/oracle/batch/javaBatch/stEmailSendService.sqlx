<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="stEmailSendService">
    <sql id="procedureParams">
          #{I_ERR,         mode=INOUT, jdbcType=INTEGER}
        , #{VC_RESULTMSG,  mode=INOUT, jdbcType=VARCHAR}
        , #{VC_RETURNMSG,  mode=INOUT, jdbcType=VARCHAR}
        , AVC_LOG_PARAMS => #{AVC_LOG_PARAMS, mode=IN , jdbcType=VARCHAR} /*(20251020) BATCH LOG관련 PARAMS.*/
    </sql>

    <select id="processRefSOderReceive" statementType="CALLABLE" parameterType="BatchParamsUtil" resultType="BatchParamsUtil" timeout="60">
        { CALL SPBT_STEMAILSEND.EXECUTE( /* [stEmailSendService.sqlx][callProcExecute][재고할당메일링][김환수][20250801] */
               <include refid="procedureParams"/>
        ) }
    </select>

</mapper>