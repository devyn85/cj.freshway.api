<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="ibExpenseService">

    <select id="getDataRead" resultType="IbExpenseResDto">
        WITH ZR_CTE AS (
             SELECT DISTINCT ZINVOICE, ZRETURN
                       FROM   IF_IB_STOCKETC_H
                       WHERE  FI_IF_STATUS = 'CNF'
             UNION ALL
             SELECT DISTINCT ZINVOICE, ZRETURN
                       FROM   IF_IB_STOCKSKU_H
                       WHERE  FI_IF_STATUS = 'CNF'
          )
        , ZRE_CTE AS (
               SELECT DISTINCT ZINVOICE, ZRE_BELNR
                       FROM   IF_IB_STOCKETC_H
                       WHERE  FI_IF_STATUS = 'CNF'
               UNION ALL
               SELECT DISTINCT ZINVOICE, ZRE_BELNR
                       FROM   IF_IB_STOCKSKU_H
                       WHERE  FI_IF_STATUS = 'CNF'
             )
        , OD AS (
            SELECT A.EXPENSE_SN
                  ,LISTAGG(DISTINCT RIGHT(A.ORGANIZE,4), ',') WITHIN GROUP (ORDER BY A.ORGANIZE) AS ORGANIZE_AGG
                  ,LISTAGG(DISTINCT FN_DESCR_ORGANIZE(A.DCCODE, A.ORGANIZE),',') WITHIN GROUP (ORDER BY A.ORGANIZE) AS ORGANIZE_NAME_AGG
            FROM IB_EXPENSE_DISTRIBUTION A 
            INNER JOIN IB_EXPENSE B 
                ON A.EXPENSE_SN = B.SERIALKEY
            WHERE    1=1
            AND    B.DCCODE                 = #{fixdccode}
            AND    B.STORERKEY              = #{gStorerkey}
        <if test="adddateFrom != null and adddateFrom != ''">                     
            AND    B.ADDDATE        <![CDATA[>=]]> TO_DATE(#{adddateFrom}      , 'yyyyMMdd')            
        </if>              
        <if test="adddateTo != null and adddateTo != ''">                       
            AND    B.ADDDATE        <![CDATA[<]]> TO_DATE(#{adddateTo}        , 'yyyyMMdd')+1          
        </if>              
        <if test="editdateFrom != null and editdateFrom != ''">                    
            AND    B.EDITDATE       <![CDATA[>=]]> TO_DATE(#{editdateFrom}     , 'yyyyMMdd')            
        </if>              
        <if test="editdateTo != null and editdateTo != ''">                      
            AND    B.EDITDATE       <![CDATA[<]]> TO_DATE(#{editdateTo}       , 'yyyyMMdd')+1          
        </if>              
        <if test="docdtFrom != null and docdtFrom != ''">                       
            AND    B.ISSUE_DATE     <![CDATA[>=]]> TO_DATE(#{docdtFrom}        , 'yyyyMMdd')            
        </if>              
        <if test="docdtTo != null and docdtTo != ''">                         
            AND    B.ISSUE_DATE     <![CDATA[<]]> TO_DATE(#{docdtTo}          , 'yyyyMMdd')+1          
        </if>              
        <if test="taxdateFrom != null and taxdateFrom != ''">                     
            AND    B.TAX_YMD        <![CDATA[>=]]> TO_DATE(#{taxdateFrom}      , 'yyyyMMdd')            
        </if>              
        <if test="taxdateTo != null and taxdateTo != ''">                       
            AND    B,TAX_YMD        <![CDATA[<]]> TO_DATE(#{taxdateTo}        , 'yyyyMMdd')+1          
        </if>              
        <if test="baselinedateFrom != null and baselinedateFrom != ''">                
            AND    B.DUE_DATE       <![CDATA[>=]]> TO_DATE(#{baselinedateFrom} , 'yyyyMMdd')            
        </if>              
        <if test="baselinedateTo != null and baselinedateTo != ''">                  
            AND    B.DUE_DATE       <![CDATA[<]]> TO_DATE(#{baselinedateTo}   , 'yyyyMMdd')+1          
        </if>              
        <if test="postingdateFrom != null and postingdateFrom != ''">                 
            AND    B.POSTING_DATE   <![CDATA[>=]]> TO_DATE(#{postingdateFrom}  , 'yyyyMMdd')            
        </if>              
        <if test="postingdateTo != null and postingdateTo != ''">                   
            AND    B.POSTING_DATE   <![CDATA[<]]> TO_DATE(#{postingdateTo}    , 'yyyyMMdd')+1          
        </if>              
        <if test="yyyymm != null and yyyymm != ''">                           
            AND    B.ATTRIBUTES1              =    #{yyyymm}                                             
        </if>              
        <if test="status != null and status != ''">                           
            AND    B.STATUS                   =    #{status}                                             
        </if>              
        <if test="ifStatus != null and ifStatus != ''">                        
            AND    B.IF_STATUS                =    #{ifStatus}                                          
        </if>              
        <if test="attributes2 != null and attributes2 != ''">                      
            AND    B.ATTRIBUTES2              =    #{attributes2}                                        
        </if>              
        <if test="keynoMulti != null and keynoMulti != ''">
            AND    B.KEY_NO      IN                                                                                    /* Document No */
            <foreach collection="keynoMulti" item="item" open="(" separator="," close=")">
                 #{item}
            </foreach> 
        </if>
        <if test="erpponoMulti != null and erpponoMulti != ''">
            AND    B.ERP_PO_NO      IN                                                                                  /* ERP 발주번호 */
            <foreach collection="erpponoMulti" item="item" open="(" separator="," close=")">
                 #{item}
            </foreach> 
        </if>
        <if test="addwho != null and addwho != ''">                           
            AND    EXISTS (SELECT 1                                               
                           FROM   FRAMEONE_USER                                              
                           WHERE  USER_ID = B.ADDWHO                                        
                           AND   (USER_ID LIKE '%' || #{addwho} || '%' 
                               OR USER_NM LIKE '%' || #{addwho} || '%'
                                 )
                           )                                                                          
        </if>
        <if test="editwho != null and editwho != ''">                          
            AND    EXISTS (SELECT 1                                               
                           FROM   FRAMEONE_USER                                              
                           WHERE  USER_ID = B.EDITWHO                                        
                           AND   (USER_ID LIKE '%' || #{editwho} || '%'
                               OR USER_NM LIKE '%' || #{editwho} || '%'
                                 )
                           )                                                                          
        </if>
        <if test="adjustmentsuppliercode != null and adjustmentsuppliercode != ''">         
            AND    B.ADJUSTMENT_SUPPLIER_CODE IN (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL                /* Supplier 코드 */  
                                                FROM (SELECT #{adjustmentsuppliercode} AS VAL FROM DUAL) A
                                                CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)                  
        </if> 
        <if test="adjustmentsuppliername != null and adjustmentsuppliername != ''">         
            AND    B.ADJUSTMENT_SUPPLIER_NAME IN (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL                /* Supplier 명 */  
                                                FROM (SELECT #{adjustmentsuppliername} AS VAL FROM DUAL) A
                                                CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0) )                     
        </if>  
        <if test="organizeMulti != null and organizeMulti != ''">
            AND    EXISTS (SELECT 1                                                                                          /* 창고 */          
                            FROM   IB_EXPENSE_DISTRIBUTION                                                              
                            WHERE  IB_EXPENSE_DISTRIBUTION.EXPENSE_SN = B.SERIALKEY 
                          <if test="organizeMulti != null and organizeMulti != ''">
                              AND  IB_EXPENSE_DISTRIBUTION.ORGANIZE      IN
                                <foreach collection="organizeMulti" item="item" open="(" separator="," close=")">
                                    #{item}
                                </foreach> 
                          </if>
                          )
        </if>
        
        <if test="supplierCode != null and supplierCode != ''">         
            AND    B.ADJUSTMENT_SUPPLIER_CODE IN (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL                /* Supplier 코드 */  
                                                FROM (SELECT #{supplierCode} AS VAL FROM DUAL) A
                                                CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)                  
        </if>
           GROUP BY A.EXPENSE_SN
            ) 
        
        SELECT    /* [ibExpenseService.sqlx][getDataRead][비용기표 목록 조회][sunho.kim][2025.08.04] */  
                EX.DCCODE                                                                AS DCCODE                                                  /* 물류센터 */       
              , EX.STATUS                                                                AS STATUS_CODE                                             /* 상태코드 */
              , CD1.BASEDESCR                                                            AS STATUS                                                  /* 상태코드명 */ 
              , (SELECT APPROVALSTATUS
                 FROM   AJ_APPRREQUEST APR
                 WHERE  APR.SLIPNO  = EX.SERIALKEY
                   AND  APR.DCCODE  = EX.DCCODE
                   AND  APR.DOCTYPE = 'IBEXPENSE'
                   AND  APR.APPROVALNO != 'STD'
                 ORDER BY ADDDATE DESC
                 FETCH FIRST 1 ROWS ONLY )                                               AS INTERNAL_APPR_STATUS                                    /* 내부결재상태 */
              , CD2.BASEDESCR                                                            AS IF_STATUS                                               /* IF Status */ 
              , EX.APPR_STATUS                                                           AS APPR_STATUS                                             /* Appr Status */   
              , DECODE(BUSINESS_TYPE_ID, 3, 'Direct'
                                       , 4, 'Local'
                                       , 'Not Defined')                                  AS BUSINESS_TYPE_ID                                        /* Business Type ID */   
              , EX.KEY_NO                                                                AS KEY_NO                                                  /* Document No */  
              , TO_CHAR(ISSUE_DATE, 'YYYYMMDD')                                          AS ISSUE_DATE                                              /* Document Date*/
              , DUE_DATE                                                                 AS DUE_DATE                                                /* Due Date */
              , ADJUSTMENT_SUPPLIER_CODE                                                 AS ADJUSTMENT_SUPPLIER_CODE                                /* Supplier Code */   
              , ADJUSTMENT_SUPPLIER_NAME                                                 AS ADJUSTMENT_SUPPLIER_NAME                                /* Supplier Name */
              , ACTUAL_SUPPLIER_CODE                                                     AS ACTUAL_SUPPLIER_CODE                                    /* ACTUAL SUPPLIER CODE */
              , ACTUAL_SUPPLIER_NAME                                                     AS ACTUAL_SUPPLIER_NAME                                    /* ACTUAL SUPPLIER NAME */
              , ADJUSTMENT_SITE_CODE                                                     AS ADJUSTMENT_SITE_CODE                                    /* ADJUSTMENT SITE CODE */
              , ADJUSTMENT_SITE_NAME                                                     AS ADJUSTMENT_SITE_NAME                                    /* ADJUSTMENT SITE NAME */ 
              , ACCOUNT_CR_CODE                                                          AS ACCOUNT_CR_CODE                                         /* 차변계정코드 */
              , ACCOUNT_CR_NAME                                                          AS ACCOUNT_CR_NAME                                         /* 차변계정명 */ 
              , NVL(EXCHANGE_RATE, 0)                                                    AS EXCHANGE_RATE                                           /* EXCHANGE RATE */
              , NVL(SUPPLY_PRICE_KRW, 0)                                                 AS SUPPLY_PRICE_KRW                                        /* SUPPLY PRICE KRW */   
              , NVL(TAX_AMOUNT_KRW, 0)                                                   AS TAX_AMOUNT_KRW                                          /* TAX AMOUNT KRW */
              , NVL(AMOUNT_KRW, 0)                                                       AS AMOUNT_KRW                                              /* AMOUN _KRW */ 
              , AMOUNT_UNIT                                                              AS AMOUNT_UNIT                                             /* 통화 */   
              , NVL(SUPPLY_PRICE, 0)                                                     AS SUPPLY_PRICE                                            /* Supply Price */
              , NVL(TAX_AMOUNT, 0)                                                       AS TAX_AMOUNT                                              /* Tax Amount */
              , EX.TAX_TYPE_CODE                                                         AS TAX_TYPE_CODE                                           /* Tax Type Code */    
              , NVL(AMOUNT, 0)                                                           AS AMOUNT                                                  /* Amount */       
              , SUMMARY                                                                  AS SUMMARY                                                 /* Summary */
              , EX.ADDWHO                                                                AS ADDWHO                                                  /* 등록자 */ 
              , USER1.USER_NM                                                            AS ADDWHO_NM                                               /* 등록자명 */
              , EX.EDITWHO                                                               AS EDITWHO                                                 /* 최종변경자 */ 
              , USER2.USER_NM                                                            AS EDITWHO_NM                                              /* 최종변경자명 */
              , TO_CHAR(EX.ADDDATE,'YYYYMMDDHH24MISS')                                   AS ADDDATE                                                 /* 등록일자 */   
              , TO_CHAR(EX.EDITDATE,'YYYYMMDDHH24MISS')                                  AS EDITDATE                                                /* 최종변경시간 */
              , EX.SERIALKEY                                                             AS SERIALKEY                                               /* 데이터번호 */   
              , MEMBER_ID                                                                AS MEMBER_ID                                               /* Member ID */
              , PURCHASING_GROUP_CODE                                                    AS PURCHASING_GROUP_CODE                                   /* PURCHASING GROUP CODE*/
              , EX.STORERKEY                                                             AS STORERKEY                                               /* 고객사코드 */
              , CMS.DESCRIPTION                                                          AS STORERNAME                                              /* 고객사명 */
              , X.ACCOUNT_DETAIL_NAME                                                    AS ACCOUNT_DETAIL                                          /* Account Detail */   
              , ED.CNT                                                                   AS LOV_ITEM                                                /* Item */
              , NVL(FILECNT.CNT, 0)                                                      AS FILE_CNT                                                /* 파일 */
              , FISCAL_YEAR                                                              AS FISCAL_YEAR                                             /* Fiscal Year */
              , TO_CHAR(POSTING_DATE, 'YYYYMMDD')                                        AS POSTING_DATE                                            /* Posting Date */
              , DECODE(EX.TRANSACTION_CD, 'FI', 'FI', 'OB', 'MIRO')                      AS TRANSACTION_CD                                          /* Transaction CD  */    
              , TRANSACTION_CD                                                           AS TRANSACTION_CD_VALUE                                    /* Transaction 명 */
              , 0                                                                        AS INTERFACE_CNT                                           /* Interface Count */   
              , ZR.ZRETURN_AGG                                                           AS INV_NO                                                  /* MM송장번호 */
              , IF_DOC_NO                                                                AS IF_DOC_NO                                               /* IF No */
              , ''                                                                       AS PO_NO                                                   /* 발주번호 */
              , ZRE.ZRE_BELNR_AGG                                                        AS SLIP_NO                                                 /* Slip No */ 
              , CD3.BASEDESCR                                                            AS ATTRIBUTES2                                             /* 비용종류 */
              , CASE WHEN IF_ID IN ('SCM0480') 
                     THEN (SELECT FI_IF_STATUS                                                
                           FROM   IF_IB_STOCKETC_H
                           WHERE  ZINVOICE = EX.IF_DOC_NO
                           AND    ROWNUM   = 1)
                     WHEN IF_ID = 'SCM0470' 
                     THEN (SELECT FI_IF_STATUS                                                
                           FROM   IF_IB_STOCKSKU_H
                           WHERE  ZINVOICE = EX.IF_DOC_NO
                           AND    ROWNUM   = 1)
                     ELSE ''
                END                                                                      AS FI_IF_STATUS                                            /* Posting Status */
              , ATTRIBUTES1                                                              AS YYYYMM                                                  /* 재고년월 */ 
              , OD.ORGANIZE_AGG                                                          AS ORGANIZE                                                /* 창고코드 */
              , OD.ORGANIZE_NAME_AGG                                                     AS ORGANIZE_NAME                                           /* 창고명 */
              , '['|| EX.TAX_TYPE_CODE||']'|| EX.TAX_TYPE_NAME                           AS TAX_TYPE_NAME                                           /* 세금코드 */
              , CD4.BASEDESCR                                                            AS TAX_TAG                                                 /* Tax Invoice */
              , EX.TAX_NO                                                                AS TAX_NO                                                  /* Tax No */
              , TO_CHAR(EX.TAX_YMD, 'YYYYMMDD')                                          AS TAX_YMD                                                 /* 증빙일 */  
              , (SELECT H.TPL_TYPE
                 FROM IB_EXPENSE  A
                 INNER JOIN ST_EXDCSTORAGE_EXPENSE B  
                    ON B.WORK_EXP_NO = A.KEY_NO
                 INNER JOIN ST_EXDCSTORAGE C 
                    ON C.SERIALKEY   = B.EXDCSTORAGEKEY   
                 INNER JOIN DM_DOCUMENT_H H 
                    ON H.DCCODE      = C.DCCODE
                   AND H.ORGANIZE    = C.ORGANIZE    
                   AND H.DOCNO       = C.DOCNO
                   AND H.DEL_YN      = 'N'
                 WHERE A.SERIALKEY   = EX.SERIALKEY
                 FETCH FIRST 1 ROWS ONLY)                                                AS TPL_TYPE                                                /* 3자물류유형코드 */
        FROM    IB_EXPENSE EX

        LEFT JOIN OD
            ON OD.EXPENSE_SN = EX.SERIALKEY

        LEFT JOIN (
             SELECT ZINVOICE
                   ,LISTAGG(DISTINCT ZRETURN, ',') WITHIN GROUP (ORDER BY ZRETURN) AS ZRETURN_AGG
             FROM  ZR_CTE
             GROUP BY ZINVOICE
            ) ZR
            ON ZR.ZINVOICE = EX.IF_DOC_NO        
        
         LEFT JOIN (
             SELECT ZINVOICE
                   ,LISTAGG(DISTINCT ZRE_BELNR, ',') WITHIN GROUP (ORDER BY ZRE_BELNR) AS ZRE_BELNR_AGG
             FROM  ZRE_CTE
             GROUP BY ZINVOICE
            ) ZRE
            ON ZRE.ZINVOICE = EX.IF_DOC_NO 
        
        LEFT JOIN   (  
             SELECT S.DOC_ID, COUNT(S.SERIALKEY) AS CNT                                          
             FROM   IB_EXPENSE_HTTP_DOC_ATTACH S                               
             WHERE  S.DOC_NAME = 'IMP_EXPENSE'
             GROUP BY S.DOC_ID        
            ) FILECNT 
            ON FILECNT.DOC_ID = EX.SERIALKEY 
        
        LEFT JOIN   (  
             SELECT ED.EXPENSE_SN, COUNT(ED.SERIALKEY) AS CNT     
             FROM   IB_EXPENSE_DISTRIBUTION ED    
             GROUP BY ED.EXPENSE_SN        
            ) ED 
            ON ED.EXPENSE_SN = EX.SERIALKEY
        
        LEFT JOIN   (  
             SELECT 
                  X.EXPENSE_SN
                 ,CASE WHEN MAX(ACCOUNT_DETAIL_CODE) IN ('K10', 'K11', 'W01', 'W02', 'W03')
                       THEN '보관료'
                       WHEN MAX(ACCOUNT_DETAIL_CODE) IN ('K09')
                       THEN '보관료(PLT)'
                       ELSE MAX(ACCOUNT_DETAIL_NAME)
                  END                                AS ACCOUNT_DETAIL_NAME
             FROM   IB_EXPENSE_DISTRIBUTION X
             LEFT OUTER JOIN CM_CODE CD
               ON CD.CODELIST  = 'JOURNALCODE'
              AND CD.BASECODE  = X.ACCOUNT_DETAIL_CODE  
             GROUP BY X.EXPENSE_SN        
            ) X 
            ON X.EXPENSE_SN = EX.SERIALKEY
        
        LEFT JOIN   (  
             SELECT CMS.STORERKEY, MAX(CMS.DESCRIPTION) AS DESCRIPTION
             FROM   CM_STORER CMS                              
             GROUP BY CMS.STORERKEY        
            ) CMS
            ON CMS.STORERKEY = EX.STORERKEY
        
        LEFT OUTER JOIN CM_CODE_STORER CD1
                    ON CD1.STORERKEY = EX.STORERKEY
                   AND CD1.CODELIST  = 'STATUS_EXPENSE'   
                   AND CD1.BASECODE  = EX.STATUS
        LEFT OUTER JOIN CM_CODE_STORER CD2
                    ON CD2.STORERKEY = EX.STORERKEY
                   AND CD2.CODELIST  = 'STATUS_EXPENSE_IF'   
                   AND CD2.BASECODE  = EX.IF_STATUS           
        LEFT OUTER JOIN CM_CODE_STORER CD3
                    ON CD3.STORERKEY = EX.STORERKEY
                   AND CD3.CODELIST  = 'EXPENSEGUBUN'   
                   AND CD3.BASECODE  = EX.ATTRIBUTES2
        LEFT OUTER JOIN CM_CODE_STORER CD4
                    ON CD4.STORERKEY = EX.STORERKEY
                   AND CD4.CODELIST  = 'TAX_TAG'   
                   AND CD4.BASECODE  = EX.TAX_TAG
        LEFT OUTER JOIN FRAMEONE_USER USER1
                    ON USER1.USER_ID = EX.ADDWHO
        LEFT OUTER JOIN FRAMEONE_USER USER2
                    ON USER2.USER_ID = EX.EDITWHO
        
        WHERE   1 = 1
            AND    EX.DCCODE                 = #{fixdccode}
            AND    EX.STORERKEY              = #{gStorerkey}
        <if test="adddateFrom != null and adddateFrom != ''">                     
            AND    EX.ADDDATE        <![CDATA[>=]]> TO_DATE(#{adddateFrom}      , 'yyyyMMdd')            
        </if>              
        <if test="adddateTo != null and adddateTo != ''">                       
            AND    EX.ADDDATE        <![CDATA[<]]> TO_DATE(#{adddateTo}        , 'yyyyMMdd')+1          
        </if>              
        <if test="editdateFrom != null and editdateFrom != ''">                    
            AND    EX.EDITDATE       <![CDATA[>=]]> TO_DATE(#{editdateFrom}     , 'yyyyMMdd')            
        </if>              
        <if test="editdateTo != null and editdateTo != ''">                      
            AND    EX.EDITDATE       <![CDATA[<]]> TO_DATE(#{editdateTo}       , 'yyyyMMdd')+1          
        </if>              
        <if test="docdtFrom != null and docdtFrom != ''">                       
            AND    EX.ISSUE_DATE     <![CDATA[>=]]> TO_DATE(#{docdtFrom}        , 'yyyyMMdd')            
        </if>              
        <if test="docdtTo != null and docdtTo != ''">                         
            AND    EX.ISSUE_DATE     <![CDATA[<]]> TO_DATE(#{docdtTo}          , 'yyyyMMdd')+1          
        </if>              
        <if test="taxdateFrom != null and taxdateFrom != ''">                     
            AND    EX.TAX_YMD        <![CDATA[>=]]> TO_DATE(#{taxdateFrom}      , 'yyyyMMdd')            
        </if>              
        <if test="taxdateTo != null and taxdateTo != ''">                       
            AND    EX.TAX_YMD        <![CDATA[<]]> TO_DATE(#{taxdateTo}        , 'yyyyMMdd')+1          
        </if>              
        <if test="baselinedateFrom != null and baselinedateFrom != ''">                
            AND    EX.DUE_DATE       <![CDATA[>=]]> TO_DATE(#{baselinedateFrom} , 'yyyyMMdd')            
        </if>              
        <if test="baselinedateTo != null and baselinedateTo != ''">                  
            AND    EX.DUE_DATE       <![CDATA[<]]> TO_DATE(#{baselinedateTo}   , 'yyyyMMdd')+1          
        </if>              
        <if test="postingdateFrom != null and postingdateFrom != ''">                 
            AND    EX.POSTING_DATE   <![CDATA[>=]]> TO_DATE(#{postingdateFrom}  , 'yyyyMMdd')            
        </if>              
        <if test="postingdateTo != null and postingdateTo != ''">                   
            AND    EX.POSTING_DATE   <![CDATA[<]]> TO_DATE(#{postingdateTo}    , 'yyyyMMdd')+1          
        </if>              
        <if test="yyyymm != null and yyyymm != ''">                           
            AND    EX.ATTRIBUTES1              =    #{yyyymm}                                             
        </if>              
        <if test="status != null and status != ''">                           
            AND    EX.STATUS                   =    #{status}                                             
        </if>              
        <if test="ifStatus != null and ifStatus != ''">                        
            AND    EX.IF_STATUS                =    #{ifStatus}                                          
        </if>              
        <if test="attributes2 != null and attributes2 != ''">                      
            AND    EX.ATTRIBUTES2              =    #{attributes2}                                        
        </if>              
        <if test="keynoMulti != null and keynoMulti != ''">
            AND    EX.KEY_NO      IN
            <foreach collection="keynoMulti" item="item" open="(" separator="," close=")">
                 #{item}
            </foreach> 
        </if>
        <if test="erpponoMulti != null and erpponoMulti != ''">
            AND    EX.ERP_PO_NO      IN                                                                                  /* ERP 발주번호 */
            <foreach collection="erpponoMulti" item="item" open="(" separator="," close=")">
                 #{item}
            </foreach> 
        </if>
        <if test="addwho != null and addwho != ''">                           
            AND    EXISTS (SELECT 1                                               
                           FROM   FRAMEONE_USER                                              
                           WHERE  USER_ID = EX.ADDWHO                                        
                           AND   (USER_ID LIKE '%' || #{addwho} || '%'
                               OR USER_NM LIKE '%' || #{addwho} || '%'
                                 )
                           )                                                                          </if>
        <if test="editwho != null and editwho != ''">                          
            AND    EXISTS (SELECT 1                                               
                           FROM   FRAMEONE_USER                                              
                           WHERE  USER_ID = EX.EDITWHO                                        
                           AND   (USER_ID LIKE '%' || #{editwho} || '%'
                               OR USER_NM LIKE '%' || #{editwho} || '%'
                                 )
                           )                                                                          </if>
        <if test="adjustmentsuppliercode != null and adjustmentsuppliercode != ''">         
            AND    EX.ADJUSTMENT_SUPPLIER_CODE IN (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL                /* Supplier 코드 */  
                                                FROM (SELECT #{adjustmentsuppliercode} AS VAL FROM DUAL) A
                                                CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)                  
        </if> 
        <if test="adjustmentsuppliername != null and adjustmentsuppliername != ''">         
            AND    EX.ADJUSTMENT_SUPPLIER_NAME IN (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL                /* Supplier 명 */  
                                                FROM (SELECT #{adjustmentsuppliername} AS VAL FROM DUAL) A
                                                CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0) )                     
        </if>  
        <if test="organizeMulti != null and organizeMulti != ''">
            AND    EXISTS (SELECT 1                                                               
                            FROM   IB_EXPENSE_DISTRIBUTION                                                              
                            WHERE  IB_EXPENSE_DISTRIBUTION.EXPENSE_SN = EX.SERIALKEY                                                               
                            <if test="organizeMulti != null and organizeMulti != ''">
                               AND IB_EXPENSE_DISTRIBUTION.ORGANIZE      IN
                                <foreach collection="organizeMulti" item="item" open="(" separator="," close=")">
                                    #{item}
                                </foreach> 
                            </if>
                          ) 
        </if>
        <if test="supplierCodeMulti != null and supplierCodeMulti != ''">
            AND    EX.ADJUSTMENT_SUPPLIER_CODE      IN                                                              /* Supplier 코드 */
            <foreach collection="supplierCodeMulti" item="item" open="(" separator="," close=")">
                 #{item}
            </foreach> 
        </if>
            AND    EXISTS (SELECT 1                                                               
                            FROM   CM_USER_AUTHORITY                                                              
                            WHERE  CM_USER_AUTHORITY.DCCODE = #{fixdccode} 
                            AND    CM_USER_AUTHORITY.USERID = #{gUserId}
                            FETCH FIRST 1 ROWS ONLY  )
        
        ORDER BY 
                EX.KEY_NO DESC
    </select>
    
    <sql id="popupDocumentInfoHeaderColumnList">
          EX.SERIALKEY                      /* 일련번호 */
		, EX.DCCODE                         /* 센터코드 */
		, EX.STORERKEY                      /* 고객사코드 */
		, EX.MEMBER_ID                      /* 법인식별번호 */
		, EX.DIVISION_ID                    /* 사업장식별번호 */
		, EX.ORGANIZATION_ID                /* 조직식별번호 */
		, EX.BUSINESS_TYPE_ID               /* 업무유형식별번호 */
		, EX.BUSINESS_TYPE_CODE             /* 업무유형코드 */
		, EX.BUSINESS_TYPE_NAME             /* 업무유형명칭 */
		, EX.KEY_NO                         /* 문서 관리번호 */
		, EX.REVISION_NO                    /* 수정횟수 */
		, TO_CHAR(EX.ISSUE_DATE, 'YYYYMMDD') AS ISSUE_DATE    /* 비용 발생일자 */
		, TO_CHAR(EX.DUE_DATE, 'YYYYMMDD')   AS DUE_DATE      /* 비용 지급 예정일 */
		, EX.ADJUSTMENT_SUPPLIER_CODE       /* 비용 발생업체 코드 */
		, EX.ADJUSTMENT_SUPPLIER_NAME       /* 비용 발생 업체 명칭 */
		, EX.ADJUSTMENT_SITE_CODE           /* 정산업체코드 */
		, EX.ADJUSTMENT_SITE_NAME           /* 정산업체명 */
		, EX.ACTUAL_SUPPLIER_CODE           /* 대체 지급처 코드 */
		, EX.ACTUAL_SUPPLIER_NAME           /* 대체 지급처 명칭 */
		, EX.PAYMENT_TERMS_ID               /* 대금 지급 방법 ID */
		, EX.PAYMENT_TERMS_CODE             /* 대금 지급 방법 코드(2AA, 2AL.. ) */
		, EX.PAYMENT_TERMS_NAME             /* 대금 지급 방법 명칭 */
		, EX.PURCHASE_PERSON_ID             /* 구매 담당장 ID */
		, EX.PURCHASE_PERSON_CODE           /* 구매 담당자 코드 */
		, EX.PURCHASE_PERSON                /* 구매 담당자 */
		, EX.ACCOUNT_KIND_ID                /* 계정분류식별자 */
		, EX.ACCOUNT_KIND_CODE              /* 계정분류코드 */
		, EX.ACCOUNT_KIND_NAME              /* 계정분류명 */
		, EX.ACCOUNT_CR_ID                  /* 대변 계정 ID */
		, EX.ACCOUNT_CR_CODE                /* 대변 계정 코드 */
		, EX.ACCOUNT_CR_NAME                /* 대변 계정 명칭 */
		, EX.ACCOUNT_DETAIL_ID              /* 계정 상세 ID */
		, EX.ACCOUNT_DETAIL_CODE            /* 계정 상세 코드 */
		----, EX.ACCOUNT_DETAIL_NAME            /* 계정 상세 명칭 */
		, EX.SUPPLY_PRICE                   /* 공급가격 */
		, EX.SUPPLY_PRICE_KRW               /* 공급원화가격 */
		, EX.AMOUNT_UNIT                    /* 금액 단위 */
		, EX.AMOUNT_UNIT_ID                 /* 금액단위 ID */
		, EX.EXCHANGE_TYPE_ID               /* 환율타입 ID */
		, EX.EXCHANGE_TYPE                  /* 환율 타입 */
		, EX.EXCHANGE_TYPE_NAME             /* 환율타입 명칭 */
		, EX.EXCHANGE_DATE                  /* 환율일자 */
		, EX.EXCHANGE_RATE                  /* 환율 */
		, EX.TAX_TYPE_ID                    /* 세금 타입 ID */
		, EX.TAX_TYPE_CODE                  /* 세금 타입 코드 */
		, EX.TAX_TYPE_NAME                  /* 세금 타입 명칭 */
		, EX.TAX_RATE                       /* Tax Rate */
		, EX.TAX_AMOUNT                     /* 세금 금액 */
		, EX.TAX_AMOUNT_KRW                 /* 원화 세금 금액 */
		, EX.AMOUNT                         /* 금액 */
		, EX.AMOUNT_KRW                     /* 원화금액 */
		, EX.SUMMARY                        /* 적요 사항 */
		, EX.SOURCE                         /* 소스 */
		, EX.STATUS                         /* ENT : 작성 / CFM : 결재승인 / SCO : 완료(인터페이스성공) */
		, EX.ATTRIBUTES1                    /* 예비필드(Attributes1) - Excel Upload SN */
		, EX.ATTRIBUTES2                    /* 비용발생 프로그램 구분 CH,NULL=수기등록 SM=STOCK MONTHLY SC=STOCK CASE PC=PURCHASE CLAIM */
		, EX.ATTRIBUTES3                    /* 예비필드(Attributes3) */
		, EX.ATTRIBUTES4                    /* 예비필드(Attributes4) */
		, EX.ATTRIBUTES5                    /* 예비필드(Attributes5) */
		, EX.ATTRIBUTES6                    /* 예비필드(Attributes6) */
		, EX.ATTRIBUTES7                    /* 예비필드(Attributes7) */
		, EX.ATTRIBUTES8                    /* 예비필드(Attributes8) */
		, EX.ATTRIBUTES9                    /* 예비필드(Attributes9) */
		, EX.ATTRIBUTES10                   /* 예비필드(Attributes10) */
		, EX.ATTRIBUTES11                   /* 예비필드(Attributes11) */
		, EX.ATTRIBUTES12                   /* 예비필드(Attributes12) */
		, EX.ATTRIBUTES13                   /* 예비필드(Attributes13) */
		, EX.ATTRIBUTES14                   /* 예비필드(Attributes14) */
		, EX.ATTRIBUTES15                   /* 예비필드(Attributes15) */
		, EX.ATTRIBUTES_DATE1               /* 예비필드(Attributes_Date1) */
		, EX.ATTRIBUTES_DATE2               /* 예비필드(Attributes_Date2) */
		, EX.ATTRIBUTES_DATE3               /* 예비필드(Attributes_Date3) */
		, EX.ATTRIBUTES_DATE4               /* 예비필드(Attributes_Date4) */
		, EX.ATTRIBUTES_DATE5               /* 예비필드(Attributes_Date5) */
		, EX.IP_STATUS                      /* 파트터사  문서 상태 N:작성상태 Y:Request 상태 */
		, EX.CUSTOMS_CODE                   /* 관세사 코드 */
		, EX.CUSTOMS_NAME                   /* 관세사 명 */
		, EX.BUSINESSPLACE_CD               /* 사업장 */
		, EX.IF_USER_ID                     /* 인터페이스 사용자 */
		, EX.IF_DATE                        /* 인터페이스 일자 */
		, EX.FISCAL_YEAR                    /* 회계년도 */
		-- , EX.SLIP_NO                        /* 전표번호 */
		, EX.POSTING_DATE                   /* Posting Date */
		, EX.ACCT_CLS                       /* 전표유형(T : 정상,  M :마이너스) */
		, TO_CHAR(EX.TAX_YMD, 'YYYYMMDD') AS TAX_YMD   /* 증빙일 */
		, EX.TAX_STTL_CLS                   /* 정산유형 */
		, EX.INV_DEPT_CD                    /* 기표부서코드 */
		, EX.COSTCD                         /* 코스트 센터(운영팀) */
		, EX.INV_USER_ID                    /* 정산담당자 (기본) */
		, EX.PAYMENT_TERM                   /* 지불조건 */
		, EX.PAYMENT_METHOD                 /* 지불방법 */
		, EX.PAYMENT_DLY                    /* 보류여부 */
		, EX.INV_NO                         /* 송장번호 - MM */
		, EX.TAX_NO                         /* 세금계산서번호 */
		, EX.JOURNAL_TYPE_CODE              /* 분개코드 */
		, EX.JOURNAL_TYPE_NAME              /* 분개 */
		, EX.IF_ID                          /* 인터페이스ID */
		, EX.IF_STATUS                      /* SCO : 요청성공 / CCO : 요청취소성공 / ERR : 인터페이스(요청/요청취소) 실패 */
		, EX.TAX_TAG                        /* T : 세금계산서, I : 거래명세서, A:계산서,  E : 기타 계산서 */
		, EX.PURCHASING_GROUP_CODE          /* 구매그룹코드 */
		, EX.ETAX_COM_CD                    /* 전자세금계산서 업체구분 (E:미연동, G:Gtax, S:SmartBill, T:KT-NET,L:KL-NET) */
		, EX.DIRE_TAG                       /* Y:정발행, N:역발행 */
		, EX.VAT_CLS                        /* 세액구분(F:면세, Y:과세, Z:영세) */
		, EX.SALE_CD                        /* 매출타입 */
		, EX.TRANSACTION_CD                 /* 트랜잭션코드(OB/FI) */
		, EX.COMPANY_ID                     /* 회사(신생법인/계열사) ID */
		, EX.APPR_STATUS                    /* 품의상태 STB(StandBy) : 품의 대기, REQ(Request) : 품의 요청 , REJ(Reject) : 품의 반려, APP(Approval) : 품의 확정 */
		, EX.APPR_DATE                      /* 품의요청/반려/승인 일자 */
		, EX.RCV_NO                         /* STOCK_IO_ITEM.DOCUMENT_NO */
		, EX.IF_DOC_NO                      /* 전표처리 인터페이스 번호 CH-YYMM-00000 => 'CH-'||TO_CHAR(SYSDATE,'YYMM')||'-'||SUBSTRB(TO_CHAR(LPAD(IB_EXPENSE_IF_S.NEXTVAL,20,0)),-5) */
		, EX.TAX_AUTO_FLAG                  /* Y=아이템에 의한 자동 설정, N=매뉴얼 선택 */
		, EX.INV_SIGN                       /* 세금계산서 역발행 여부 */
		, EX.ADDDATE                        /* 최초등록시간 */
		, EX.EDITDATE                       /* 최종변경시간 */
		, EX.ADDWHO                         /* 최초등록자 */
		, EX.EDITWHO                        /* 최종변경자 */
	</sql>
    
    <select id="getPopupDocumentInfoHeader" resultType="IbExpenseDoucmentHeaderPopupResDto">
        SELECT    /* [ibExpenseService.sqlx][getPopupDocumentInfoHeader][비용기표 Popup 헤더 조회][sunho.kim][2025.08.04] */
              <include refid="popupDocumentInfoHeaderColumnList"/>
             ,(SELECT  DESCRIPTION
               FROM    CM_STORER
               WHERE   CM_STORER.STORERKEY = EX.STORERKEY)    AS COMPANY_NAME                                                   /* 고객사명  */            
             ,(SELECT  DESCRIPTION
               FROM    CM_STORER
               WHERE   CM_STORER.STORERKEY = EX.STORERKEY)    AS BUSINESSPLACE_NAME                                             /* 고객사명 */
             ,(SELECT  DCNAME
               FROM    CM_DC
               WHERE   CM_DC.DCCODE = EX.DCCODE)              AS DCNAME                                                         /* 물류센터명  */
             , CD1.BASEDESCR                                  AS PAYMENT_METHOD_NAME                                            /* 지불방법명 */
             , CD2.BASEDESCR                                  AS PAYMENT_TERM_NAME                                              /* 지불조건명 */
             , ''                                             AS COSTCT_NM                                                      /* COSTCT_NM */
             , ''                                             AS PURCHASING_GROUP_NAME                                          /* PURCHASING_GROUP_NAME */
             , EX.TRANSACTION_CD                              AS TRANSACTION_NM                                                 /* 트랜잭션코드(OB/FI) */
             ,(SELECT  VATNO
               FROM    MS_CUST
               WHERE   MS_CUST.STORERKEY = EX.STORERKEY
               AND     MS_CUST.CUSTKEY   = EX.ADJUSTMENT_SUPPLIER_CODE
               AND     MS_CUST.CUSTTYPE  = 'P')               AS CB_REGISNO                                                     /* 사업자등록번호 */    
             , CD3.BASEDESCR                                  AS TAX_TAG_NM                                                     /* TAX_TAG_NM */
             , (SELECT SUBSTR(XMLAGG(XMLELEMENT(COL ,',', ZRE_BELNR) ORDER BY ZRE_BELNR).EXTRACT('//text()').GETSTRINGVAL(), 2)
                FROM  (SELECT DISTINCT ZINVOICE, ZRE_BELNR
                       FROM   IF_IB_STOCKETC_H
                       WHERE  FI_IF_STATUS = 'CNF'
                       UNION ALL
                       SELECT DISTINCT ZINVOICE, ZRE_BELNR
                       FROM   IF_IB_STOCKSKU_H
                       WHERE  FI_IF_STATUS = 'CNF'
                      ) AA
                WHERE  AA.ZINVOICE = EX.IF_DOC_NO)            AS SLIP_NO                                                        /* 전표번호 */     
             , (SELECT ACCOUNT_DETAIL_NAME 
                FROM IB_EXPENSE_DISTRIBUTION
                WHERE IB_EXPENSE_DISTRIBUTION.DCCODE = EX.DCCODE
                  AND IB_EXPENSE_DISTRIBUTION.KEY_NO = EX.KEY_NO
                  AND ROWNUM = 1)                             AS ACCOUNT_DETAIL_NAME                                           /* ACCOUNT_DETAIL */  
        FROM   IB_EXPENSE EX
        
        LEFT OUTER JOIN CM_CODE_STORER CD1
                    ON CD1.STORERKEY = EX.STORERKEY
                   AND CD1.CODELIST  = 'PAYMENT_METHOD'   
                   AND CD1.BASECODE  = EX.PAYMENT_METHOD
        LEFT OUTER JOIN CM_CODE_STORER CD2
                    ON CD2.STORERKEY = EX.STORERKEY
                   AND CD2.CODELIST  = 'PAYMENT_TERM'   
                   AND CD2.BASECODE  = EX.PAYMENT_TERM           
        LEFT OUTER JOIN CM_CODE_STORER CD3
                    ON CD3.STORERKEY = EX.STORERKEY
                   AND CD3.CODELIST  = 'TAX_TAG'   
                   AND CD3.BASECODE  = EX.TAX_TAG
        
        WHERE EX.SERIALKEY = #{serialkey}
    </select>
    
