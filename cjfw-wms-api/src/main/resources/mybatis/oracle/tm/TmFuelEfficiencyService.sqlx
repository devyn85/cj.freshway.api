<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace= "tmFuelEfficiencyService">
	
	<select id="getDataHeaderlist"  resultType="TmFuelEfficiencyResDto">
		<![CDATA[
			SELECT  /* [tmFuelEfficiencyMapper.xml][selectFuelEfficiency][연비 기준 정보 조회][ParkJinWoo][20250910] */
			          A.SERIALKEY             AS SERIALKEY          /* 데이터번호 */
			        , A.DCCODE                AS DCCODE             /* 센터코드 */
			        , A.YEAR_FROM             AS YEAR_FROM          /* 시작연식 */
			        , A.YEAR_TO               AS YEAR_TO            /* 종료연식 */
			        , A.TON                   AS TON                /* 톤수 */
			        , A.FUELTYPE              AS FUELTYPE           /* 유종구분 */
			        , A.FUELEFFICIENCY        AS FUELEFFICIENCY     /* 연비 */
			        , A.FROMDATE              AS FROMDATE           /* 적용시작일자 */
			        , A.TODATE                AS TODATE             /* 적용종료일자 */
			        , A.ADDDATE               AS ADDDATE            /* 최초등록시간 */
			        , A.EDITDATE              AS EDITDATE           /* 최종변경시간 */
			        , A.ADDWHO                AS ADDWHO             /* 최초등록자 */
			        , A.EDITWHO               AS EDITWHO            /* 최종변경자 */
			        , USER1.USER_NM           AS ADDWHONAME         /* 등록자명 */
			        , USER2.USER_NM           AS EDITWHONAME        /* 수정자명 */
			  FROM    TM_FUELEFFICIENCY A
			  LEFT JOIN FRAMEONE_USER USER1
			         ON USER1.USER_ID = A.ADDWHO                    /* 등록자명 */
			  LEFT JOIN FRAMEONE_USER USER2
			         ON USER2.USER_ID = A.EDITWHO                   /* 수정자명 */
			 WHERE 1=1
			 ]]>
			   <if test="dcCode != null and dcCode != ''">
			       AND A.DCCODE = <![CDATA[ #{dcCode} ]]>
			   </if>
			   <if test="serialYn neq 'true'">
				   <if test="fromDate != null and fromDate != ''">
				       AND A.TODATE   <![CDATA[ >= ]]> #{fromDate}
				   </if>
				   <if test="toDate != null and toDate != ''">
				       AND A.FROMDATE <![CDATA[ <= ]]> #{toDate}
				   </if>
			   </if>
			   <if test="ton != null and ton != ''">
			       AND A.TON = <![CDATA[ #{ton} ]]>
			   </if>
			   <if test="fuelType != null and fuelType != ''">
			       AND A.FUELTYPE = <![CDATA[ #{fuelType} ]]>
			   </if>
			   	ORDER BY 
			 		 A.DCCODE
			 		,A.YEAR_FROM
			 		,A.YEAR_TO
			 		,A.TON 
			 		,A.FUELTYPE
			 		,A.FROMDATE
			 		,A.TODATE
 	 </select>
  
	  <!-- 휴일 기준정보 INSERT -->
	<insert id="insertFuelEfficiency">
	
		  INSERT /* [tmFuelEfficiencyMapper.xml][insertFuelEfficiency][연비 정보 입력][ParkJinWoo][20250910] */
			INTO TM_FUELEFFICIENCY (
			          SERIALKEY        /* 데이터번호 */
			        , DCCODE           /* 센터코드 */
			        , YEAR_FROM        /* 시작연식 */
			        , YEAR_TO          /* 종료연식 */
			        , TON              /* 톤수 */
			        , FUELTYPE         /* 유종구분 */
			        , FUELEFFICIENCY   /* 연비 */
			        , FROMDATE         /* 적용시작일자 */
			        , TODATE           /* 적용종료일자 */
			        , ADDDATE          /* 최초등록시간 */
			        , EDITDATE         /* 최종변경시간 */
			        , ADDWHO           /* 최초등록자 */
			        , EDITWHO          /* 최종변경자 */
			)
			SELECT   (NVL((SELECT MAX(SERIALKEY) 
               FROM TM_FUELEFFICIENCY), 0) + 1) AS SERIALKEY  /* 데이터번호 */
			      , #{dcCode}                          /* 센터코드 */
			      , #{yearFrom}                        /* 시작연식 */
			      , #{yearTo}                          /* 종료연식 */
			      , #{ton}                             /* 톤수 */
			      , #{fuelType}                        /* 유종구분 */
			      , #{fuelEfficiency}                  /* 연비 */
			      , #{fromDate}                        /* 적용시작일자 */
			      , #{toDate}                          /* 적용종료일자 */
			      , SYSDATE                            /* 최초등록시간 */
			      , SYSDATE                            /* 최종변경시간 */
			      , #{gUserId}                         /* 최초등록자 */
			      , #{gUserId}                         /* 최종변경자 */
			  FROM DUAL
			 WHERE NOT EXISTS (
			       SELECT 1
			         FROM TM_FUELEFFICIENCY
			        WHERE DCCODE     = #{dcCode}
					  AND YEAR_FROM <![CDATA[ <= ]]> #{yearTo}
					  AND YEAR_TO   <![CDATA[ >= ]]> #{yearFrom}
			          AND TON        = #{ton}
			          AND FUELTYPE   = #{fuelType}
			          AND FROMDATE  <![CDATA[ <= ]]> #{toDate}
                      AND TODATE    <![CDATA[ >= ]]> #{fromDate}
			 
			)
		
		</insert>
		
		<update id="updateFuelEfficiency">
		    UPDATE /* [tmFuelEfficiencyMapper.xml][updateFuelEfficiency][연비 정보 수정][ParkJinWoo][20250910] */
		           TM_FUELEFFICIENCY A
		       SET 
		           A.FROMDATE        = #{fromDate}       /* 적용시작일자 */
		         , A.TODATE          = #{toDate}         /* 적용종료일자 */
		         , A.EDITDATE        = SYSDATE           /* 최종변경시간 */
		         , A.EDITWHO         = #{gUserId}        /* 최종변경자 */
		     WHERE A.SERIALKEY = #{serialKey}
		       AND NOT EXISTS (
		                       SELECT 1
		                         FROM TM_FUELEFFICIENCY B
		                        WHERE B.DCCODE     = #{dcCode}
                                  AND B.YEAR_FROM <![CDATA[ <= ]]> #{yearTo}
                                  AND B.YEAR_TO   <![CDATA[ >= ]]> #{yearFrom}
		                          AND B.TON        = #{ton}
		                          AND B.FUELTYPE   = #{fuelType}
		                          AND B.FROMDATE  <![CDATA[ <= ]]> #{toDate}
                                  AND B.TODATE    <![CDATA[ >= ]]> #{fromDate}
		                          AND B.SERIALKEY <![CDATA[ <> ]]> #{serialKey}
		                       )
		
		</update>
		
		<select id="chkVal" resultType="TmFuelEfficiencyResDto"> 
      SELECT /* [tmFuelEfficiencyMapper.sqlx][excelValChk][엑셀업로드 검증][ParkJinWoo][20250811] */
               (
                SELECT CASE WHEN COUNT(*) > 0 THEN 'Y' ELSE 'N' END AS CHK1
              FROM TM_FUELEFFICIENCY B
	         WHERE B.DCCODE     = #{dcCode}
               AND B.YEAR_FROM <![CDATA[ <= ]]> #{yearTo}
               AND B.YEAR_TO   <![CDATA[ >= ]]> #{yearFrom}
		       AND B.TON        = #{ton}
		       AND B.FUELTYPE   = #{fuelType}
               AND B.FROMDATE     = #{fromDate} 
               ) AS CHK1 /*체크.기존 자료가 존재하는 경우 가격 수정*/
              ,(
                SELECT CASE WHEN MAX(B.FROMDATE) IS NOT NULL THEN MAX(B.FROMDATE) ELSE '' END AS CHK2
              FROM TM_FUELEFFICIENCY B
	         WHERE B.DCCODE     = #{dcCode}
               AND B.YEAR_FROM <![CDATA[ <= ]]> #{yearTo}
               AND B.YEAR_TO   <![CDATA[ >= ]]> #{yearFrom}
		       AND B.TON        = #{ton}
		       AND B.FUELTYPE   = #{fuelType}
     		  AND  ( <![CDATA[ B.FROMDATE   < #{fromDate} ]]>)
               ) AS STA_DT /*체크.중복.시작일자가 겹치는 지 체크*/
               ,(
              SELECT  CASE WHEN TO_CHAR(MAX(B.SERIALKEY)) IS NOT NULL THEN TO_CHAR(MAX(B.SERIALKEY)) ELSE ''  END AS SERIALKEY
              FROM TM_FUELEFFICIENCY B
	         WHERE B.DCCODE     = #{dcCode}
               AND B.YEAR_FROM <![CDATA[ <= ]]> #{yearTo}
               AND B.YEAR_TO   <![CDATA[ >= ]]> #{yearFrom}
		       AND B.TON        = #{ton}
		       AND B.FUELTYPE   = #{fuelType}
     		  AND  ( <![CDATA[ B.FROMDATE   < #{fromDate} ]]>)
               ) AS SERIALKEY /*체크.중복.시작일자가 겹치는 지 체크*/
              
              ,(
                SELECT CASE WHEN MIN(B.FROMDATE) IS NOT NULL THEN TO_CHAR(TO_DATE(MIN(B.FROMDATE),'YYYYMMDD')-1,'YYYYMMDD') ELSE '' END AS END_DT
                  FROM TM_FUELEFFICIENCY B
	         WHERE B.DCCODE     = #{dcCode}
               AND B.YEAR_FROM <![CDATA[ <= ]]> #{yearTo}
               AND B.YEAR_TO   <![CDATA[ >= ]]> #{yearFrom}
		       AND B.TON        = #{ton}
		       AND B.FUELTYPE   = #{fuelType}
     		  AND  ( <![CDATA[ B.FROMDATE   > #{fromDate} ]]>)
               ) AS END_DT /*체크.중복.미래종료일자가 있는지.체크*/
          FROM DUAL
           </select>
           
           	<update id="updateFuelEfficiency01">
    UPDATE /* [tmFuelEfficiencyMapper.xml][updateFuelEfficiency01][연비 정보 수정][ParkJinWoo][20250910] */
           TM_FUELEFFICIENCY A
       SET A.FUELEFFICIENCY = #{fuelEfficiency} /* 연비 */
         , A.TODATE         = #{toDate}         /* 적용종료일자 */
         , A.EDITDATE       = SYSDATE           /* 최종변경시간 */
         , A.EDITWHO        = #{gUserId}         /* 최종변경자 */
     WHERE <![CDATA[ A.DCCODE     = #{dcCode}   ]]>
       AND <![CDATA[ A.YEAR_FROM <= #{yearTo}  ]]>
       AND <![CDATA[ A.YEAR_TO   >= #{yearFrom} ]]>
       AND <![CDATA[ A.TON       = #{ton}      ]]>
       AND <![CDATA[ A.FUELTYPE  = #{fuelType} ]]>
       AND <![CDATA[ A.FROMDATE  = #{fromDate} ]]>
		
		</update>
		  <!-- UPDATE (PK 기준) -->
<update id="updateFuelEfficiency02">
    UPDATE /* [tmFuelEfficiencyMapper.sqlx][updateFuelEfficiency02][연비 정보 이전기간 종료일 닫기][ParkJinWoo][20250811] */
           TM_FUELEFFICIENCY A
       SET A.TODATE    = TO_CHAR(TO_DATE(#{fromDate},'YYYYMMDD') - 1,'YYYYMMDD') /* 적용종료일자 */
         , A.EDITDATE  = SYSDATE                                                 /* 최종변경시간 */
         , A.EDITWHO   = #{gUserId}                                              /* 최종변경자 */
     WHERE (A.DCCODE, A.YEAR_FROM, A.YEAR_TO, A.TON, A.FUELTYPE, A.FROMDATE)
           =
           (
               SELECT X.DCCODE
                    , X.YEAR_FROM
                    , X.YEAR_TO
                    , X.TON
                    , X.FUELTYPE
                    , MAX(X.FROMDATE)
                 FROM TM_FUELEFFICIENCY X
                WHERE <![CDATA[ X.DCCODE     = #{dcCode}  ]]>
                  AND <![CDATA[ X.YEAR_FROM <= #{yearTo} ]]>
                  AND <![CDATA[ X.YEAR_TO   >= #{yearFrom} ]]>
                  AND <![CDATA[ X.TON       = #{ton}     ]]>
                  AND <![CDATA[ X.FUELTYPE  = #{fuelType} ]]>
                  AND <![CDATA[ X.FROMDATE  < #{fromDate} ]]>
                GROUP BY X.DCCODE, X.YEAR_FROM, X.YEAR_TO, X.TON, X.FUELTYPE
           )
</update>
</mapper>