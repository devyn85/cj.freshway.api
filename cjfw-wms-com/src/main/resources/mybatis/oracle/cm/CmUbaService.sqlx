<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cmUbaService">
    
    <insert id="insertUbaLog">
		INSERT /* [CmUbaService.sqlx][insertUbaLog][그룹정보유출보안관제(UBA) 로그 기록][JangGwangSeok][2025.07.28] */ INTO TB_UBA_USER_LOG
		(
             USER_ID
		    ,EMAIL_ALIAS
		    ,USER_NAME
		    ,EMPLOYEE_YN
		    ,CLIENT_IP
		    ,MENU_NAME
		    ,ACTION_CODE
		    ,SEARCH_ITEM
		    ,Q_COUNT
		    ,SEARCH_ID
		    ,DTTI
        )
        VALUES
        (
             #{userId}
		    ,#{emailAlias}
		    ,#{userName}
		    ,#{employeeYn}
		    ,#{clientIp}
		    ,#{menuName}
		    ,#{actionCode}
		    ,#{searchItem}
		    ,#{qCount}
		    ,NVL(#{searchId},'N/A')
		    ,TO_CHAR(SYSDATE, 'YYYY-MM-DD HH24:MI:SS')
        )
	</insert>

</mapper>