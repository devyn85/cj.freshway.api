<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="autocreationInstructsoService">
    <sql id="procedureParams">
          #{AVC_IFID,       mode=IN, jdbcType=VARCHAR}
        , #{AVC_IFRESULT,   mode=OUT, jdbcType=VARCHAR}
        , #{AVC_LOG_PARAMS, mode=IN , jdbcType=VARCHAR} /*(20251020) BATCH LOG관련 PARAMS.*/
    </sql>
    <select id="callProcExecute" statementType="CALLABLE" parameterType="BatchParamsUtil" resultType="BatchParamsUtil" timeout="14400">
        { CALL SP_EXDC_AUTO_WD_INSTRUCT.EXDC_WD_AUTOORD_IUD( /* [autocreationInstructsoService.sqlx][callProcExecute][신성장수기출고요청오더생성][김환수][20250801] */
               <include refid="procedureParams"/>
        ) }
    </select>
</mapper>