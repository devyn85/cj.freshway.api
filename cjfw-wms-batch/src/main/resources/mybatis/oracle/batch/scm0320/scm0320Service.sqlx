<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="scm0320Service">

    <select id="selectScm0320" resultType="cjfw.batch.scm0320.Scm0320ParamsDto">
        SELECT /* [scm0320Service.sqlx][scm0320Service.selectScm0320][MM 외부창고 입고실적 전송 대상조회][김성원][20150703] */
            IF_DM_SENDDATA.DOCNO
             ,IF_DM_SENDDATA.DOCLINE
             ,IF_DM_SENDDATA.PLANT
             ,IF_DM_SENDDATA.STOCKTRANSTYPE
             ,IF_DM_SENDDATA.EFFECTIVEDATE
             ,IF_DM_SENDDATA.POSTINGDATE
             ,IF_DM_SENDDATA.STORAGELOC
             ,IF_DM_SENDDATA.SKU
             ,IF_DM_SENDDATA.CONFIRMQTY
             ,IF_DM_SENDDATA.UOM
             ,IF_DM_SENDDATA.REASONCODE2
             ,IF_DM_SENDDATA.OTHER03
             ,NVL(IF_DM_SENDDATA.REFERENCE05, 0)                         AS REFERENCE05
             ,IF_DM_SENDDATA.REFERENCE07
             ,IF_DM_SENDDATA.POLINE
             ,IF_DM_SENDDATA.REFERENCE08
             ,IF_DM_SENDDATA.SLIPNO
             ,IF_DM_SENDDATA.SLIPLINE
             ,TO_CHAR(IF_DM_SENDDATA.EDITDATE, 'YYYYMMDDHH24MISS')       AS EDITDATE
             ,TO_CHAR(IF_DM_SENDDATA.IF_TIMESTAMP, 'YYYYMMDDHH24MISSFF') AS IF_TIMESTAMP
             ,NVL(MS_SKU.SERIALTYPE, '3') AS SERIALTYPE
             ,IF_DM_SENDDATA.CUSTKEY
             ,IF_DM_SENDDATA.CLOSECD
             ,IF_DM_SENDDATA.POKEY
             ,NVL(IF_DM_SENDDATA.MERGEDOCNO, '0')                        AS STOCK_AMOUNT
             ,NVL(IF_DM_SENDDATA.PLANDOCNO, '0')                         AS ETC_AMOUNT
        FROM   IF_DM_SENDDATA
                   JOIN   MS_SKU
                          ON     MS_SKU.STORERKEY                = IF_DM_SENDDATA.STORERKEY
                              AND    MS_SKU.SKU                      = IF_DM_SENDDATA.SKU
                   JOIN   IF_MASTER
                          ON     IF_MASTER.IF_ID                 = IF_DM_SENDDATA.IF_ID
                              AND    IF_MASTER.DEL_YN                = 'N'
        WHERE  1=1
          AND    IF_DM_SENDDATA.IF_FLAG         IN ('N', 'P')
          AND    IF_DM_SENDDATA.IF_DESTINATION   = 'MM'
          AND    IF_DM_SENDDATA.IF_ID            = 'SCM0320'
          and    ROWNUM <![CDATA[<]]> 300
        ORDER BY IF_DM_SENDDATA.IF_TIMESTAMP
    </select>

    <update id="updateScm0320">
        /* [scm0320Service.sqlx][scm0320Service.updateScm0320][MM 재고수불조정(자소,폐기,Loss등) 전송대상 처리FLAG 수정][김성원][20150703] */
        UPDATE IF_DM_SENDDATA
        SET    IF_FLAG  = #{UPDATE_IF_FLAG}
              ,IF_MEMO  = #{UPDATE_IF_MEMO}
              ,IF_DATE  = SYSDATE
              ,EDITDATE = SYSDATE
              ,EDITWHO  = 'BATCH'
        WHERE  1=1
          AND    IF_FLAG        = #{SEARCH_IF_FLAG}
          AND    IF_DESTINATION = 'MM'
          AND    IF_ID          = 'SCM0320'
          AND    IF_TIMESTAMP   = TO_TIMESTAMP(#{IFTIMESTAMP},'YYYYMMDDHH24MISSFF')
          AND    DOCNO          = #{DOCNO}
          AND    DOCLINE        = #{DOCLINE}
    </update>
</mapper>