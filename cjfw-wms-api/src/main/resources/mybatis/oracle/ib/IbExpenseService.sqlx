    <update id="saveFileDelete">
        DELETE  /* [ibExpenseService.sqlx][saveFileDelete][파일 다운로드 (IB_EXPENSE_HTTP_DOC_ATTACH UPDATE) 삭제][sunho.kim][2025.08.04] */ 
        IB_EXPENSE_HTTP_DOC_ATTACH
        WHERE  SERIALKEY            = #{serialkey}  
    </update>
    
     <update id="updateIfResultIfIbStockEtcHPosting">
        UPDATE  /* [ibExpenseService.sqlx][updateIfResultIfIbStockEtcHPosting][I/F 결과 UPDATE][sunho.kim][2025.08.04] */
        IF_IB_STOCKETC_H
        SET    FI_IF_STATUS   = 'SND'
        WHERE  EXPENSE_SN     = #{serialkey} 
        AND    ZINVOICE       = (SELECT IB_EXPENSE.IF_DOC_NO
                                 FROM   IB_EXPENSE
                                 WHERE  IB_EXPENSE.SERIALKEY = #{serialkey}
                                )
    </update>
    
    <update id="updateIfResultIfIbStockSkuHPosting">
        UPDATE  /* [ibExpenseService.sqlx][updateIfResultIfIbStockSkuHPosting][I/F 결과 UPDATE][sunho.kim][2025.08.04] */ 
        IF_IB_STOCKSKU_H
        SET    FI_IF_STATUS   = 'SND'
        WHERE  EXPENSE_SN     = #{serialkey} 
        AND    ZINVOICE       = (SELECT IB_EXPENSE.IF_DOC_NO
                                 FROM   IB_EXPENSE
                                 WHERE  IB_EXPENSE.SERIALKEY = #{serialkey}
                                )
    </update>

    <update id="updateIfResultIfIbStockEtcH">
        UPDATE  /* [ibExpenseService.sqlx][updateIfResultIfIbStockEtcH][I/F 결과 UPDATE][sunho.kim][2025.08.04] */
        IF_IB_STOCKETC_H
        SET    FI_IF_STATUS         = CASE WHEN #{ifType} IN ('POSTING_CANCEL') 
                                           THEN DECODE(#{xstat},'S','CCO',FI_IF_STATUS)
                                           ELSE DECODE(#{xstat},'S','CNF','ERR')
                                      END
             , XSTAT                = #{xstat}
             , XMSGS                = #{xmsgs}
             , ZRETURN              = CASE WHEN #{ifType} IN ('POSTING_CANCEL') 
                                           THEN ZRETURN
                                           ELSE #{zreturn}
                                      END
             , ZRE_BELNR            = CASE WHEN #{ifType} IN ('POSTING_CANCEL') 
                                           THEN ZRE_BELNR
                                           ELSE #{zreBelnr}
                                      END
             , EDITDATE             = SYSDATE
             , EDITWHO              = #{gUserId}
        WHERE  ZINVOICE             = #{zinvoice}
        AND    ZSEQ                 = NVL(#{zseq},ZSEQ)
    </update>
    
    <update id="updateIfResultIfIbStockSkuH">
        UPDATE  /* [ibExpenseService.sqlx][updateIfResultIfIbStockSkuH][I/F 결과 UPDATE][sunho.kim][2025.08.04] */ 
        IF_IB_STOCKSKU_H
        SET    FI_IF_STATUS         = CASE WHEN #{ifType} IN ('POSTING_CANCEL') 
                                           THEN DECODE(#{xstat},'S','CCO',FI_IF_STATUS)
                                           ELSE DECODE(#{xstat},'S','CNF','ERR')
                                      END
             , XSTAT                = #{xstat}
             , XMSGS                = #{xmsgs}
             , ZRETURN              = CASE WHEN #{ifType} IN ('POSTING_CANCEL') 
                                           THEN ZRETURN
                                           ELSE #{zreturn}
                                      END
             , ZRE_BELNR            = CASE WHEN #{ifType} IN ('POSTING_CANCEL') 
                                           THEN ZRE_BELNR
                                           ELSE #{zreBelnr}
                                      END
             , EDITDATE             = SYSDATE
             , EDITWHO              = #{gUserId}
        WHERE  ZINVOICE             = #{zinvoice}
        AND    ZSEQ                 = NVL(#{zseq},ZSEQ)
    </update>
    
    <update id="updateIfResultIbExpense">
        UPDATE  /* [ibExpenseService.sqlx][updateIfResultIbExpense][I/F 결과 UPDATE][sunho.kim][2025.08.04] */ 
        IB_EXPENSE
        SET    IF_STATUS = CASE WHEN #{ifType} IN ('POSTING_CANCEL') 
                                THEN DECODE(#{xstat},'S','CCO','POE','POE',IF_STATUS)
                                ELSE DECODE(#{xstat},'S','SCO','POE','POE','ERR')
                           END
             , STATUS    = CASE WHEN #{ifType} IN ('POSTING_CANCEL') 
                                THEN DECODE(#{xstat},'S','CFM','POE','POE',STATUS)
                                ELSE DECODE(#{xstat},'S','SCO','POE','POE',STATUS)
                           END
             , IF_DOC_NO = CASE WHEN #{ifType} IN ('POSTING_CANCEL') 
                                 AND #{xstat}  IN ('S')
                                THEN ''
                                ELSE IF_DOC_NO
                           END
             , EDITDATE  = SYSDATE
             , EDITWHO   = #{gUserId}
        WHERE  SERIALKEY = #{serialkey}
    </update>
    
    <select id="getCostCodeList" resultType="CmSearchCostCodePopupResDto">
        SELECT /* [ibExpenseService.sqlx][getCostCodeList][코스트코드 목록 조회][KimSunHo][2025.08.09] */
             CM_CODE.BASECODE          AS CODE                 /* 코드 */
            ,CM_CODE.BASEDESCR         AS NAME                 /* 명 */    
            ,DATA1                     AS DATA1                /* DATA1 */
            ,DATA2                     AS DATA2                /* DATA2 */
            ,DATA3                     AS DATA3                /* DATA3 */
            ,DATA4                     AS DATA4                /* DATA4 */
        FROM CM_CODE_STORER  CM_CODE                    
        WHERE 1=1    
            AND  CM_CODE.CODELIST  = 'JOURNALCODE'
            AND  CM_CODE.DEL_YN    = 'N'
        <if test='gStorerkey != null and gStorerkey != ""'>
            AND  CM_CODE.STORERKEY = #{gStorerkey}
        </if>
        
        <choose>
            <when test='codeList != null and codeList !=""'>
               AND CM_CODE.BASECODE IN (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
                                        FROM (SELECT #{codeList} AS VAL FROM DUAL) A
                                        CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
            </when>
            <otherwise>
               <if test='name != null and name !=""'>
                AND   (
                    CM_CODE.BASECODE         LIKE  #{name}||'%'
                    OR CM_CODE.BASEDESCR     LIKE  #{name}||'%' 
                )
                </if>
            </otherwise>
        </choose>   

        ORDER BY CM_CODE.SEQNO
    </select>
    
    <insert id="insertEmailLog">
        INSERT  /* [ibExpenseService.sqlx][insertEmailLog][이메일 로그 저장][KimSunHo][2025.08.09] */
        INTO FRAMEONE_EMAIL_LOG 
            ( EMAIL_NO
            , TITLE
            , CNTS 
            , SENDR_EMAIL_ADDR
            , RCVR_NM
            , RCVR_EMAIL_ADDR
            , REF_EMAIL_ADD
            , SEND_RES_CNTS
            , SEND_DY
            , SENDR_ID
            , REG_ID
            , REG_DTM
            , UPD_ID
            , UPD_DTM  )
        VALUES ( SEQ_FRAMEONE_EMAIL_LOG.NEXTVAL
            , #{title}
            , #{cnts}
            , #{sendrEmailAddr}
            , #{rcvrNm}
            , #{rcvrEmailAddr}
            , #{refEmailAddr}
            , '00'
            , SYSDATE
            , '00'
            , #{gUserId}
            , SYSDATE
            , #{gUserId}
            , SYSDATE  )
    </insert>    
    
    <update id="test">
        UPDATE  /* [ibExpenseService.sqlx][test][test UPDATE][sunho.kim][2025.08.04] */ 
        IB_EXPENSE
        SET    
               EDITDATE  = SYSDATE
             , EDITWHO   = #{gUserId}
        WHERE  SERIALKEY = #{ifDocNo}
    </update>    
    
    <select id="getKeynoList" resultType="IbExpenseResDto">
        SELECT SERIALKEY
             , KEY_NO 
        FROM  IB_EXPENSE
        WHERE SERIALKEY IN (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL 
                            FROM (SELECT #{serialkeys} AS VAL FROM DUAL) A
                            CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
        ORDER BY KEY_NO DESC
    </select>
    
    <insert id="insertSyProcessTempAJ" parameterType="java.util.List">
        INSERT    /* [ibExpenseService.sqlx][insertSyProcessTempAJ][임시저장 정보 AJ 저장][sunho.kim][2025.10.26] */
            INTO SY_PROCESSTEMP_AJ (
                PROCESSTYPE
              , PROCESSCREATOR
              , SPID
              , PROCESSFLAG
              , DCCODE
              , STORERKEY
              , DOCNO
              , LIST_NO
              , ADDDATE
              , EDITDATE 
              , ADDWHO
              , EDITWHO
        )
        <foreach collection="list" item="item" separator="UNION ALL">
            SELECT
                #{item.processtype}             AS PROCESSTYPE
              , #{item.gUserId}                 AS PROCESSCREATOR
              , #{item.gSpid}                   AS SPID
              , 'N'                             AS PROCESSFLAG
              , #{item.dccode}                  AS DCCODE
              , #{item.storerkey}               AS STORERKEY
              , #{item.docno}                   AS DOCNO
              , #{item.listno}                  AS LIST_NO
              , SYSDATE                         AS ADDDATE
              , SYSDATE                         AS EDITDATE
              , #{item.gUserId}                 AS ADDWHO
              , #{item.gUserId}                 AS EDITWHO
            FROM DUAL
        </foreach>
    </insert>
    
    <select id="selectElecApprDoctype" resultType="map">
        SELECT /* [ibExpenseService.sqlx][selectElecApprDoctype][전자결재 유형 조회][sunho.kim][2025.10.28] */
              AJ_APPRREQUEST.DOCTYPE
             ,AJ_APPRREQUEST.SLIPNO 
             ,AJ_APPRREQUEST.DOCNO
             ,AJ_APPRREQUEST.APPROVALSTATUS
             ,AJ_APPRREQUEST.ADDWHO
        FROM AJ_APPRREQUEST
        WHERE 1 = 1
            AND AJ_APPRREQUEST.DEL_YN = 'N'
            AND AJ_APPRREQUEST.APPROVALREQNO = #{approvalReauestNo}
    </select>
    
    <select id="getTaxDiff" resultType="StExDCStorageResDto">
        SELECT     /* [ibExpenseService.sqlx][getTaxDiff][비용 조회][sunho.kim][2025.07.17] */
            IB_EXPENSE.SERIALKEY AS EXPENSE_SN
           ,NVL(( CASE WHEN MAX(IB_EXPENSE.TAX_RATE) = 0 THEN 0
                 ELSE CASE WHEN TRUNC(MAX(IB_EXPENSE.SUPPLY_PRICE) / MAX(IB_EXPENSE.TAX_RATE)) <![CDATA[<>]]> SUM(IB_EXPENSE_DISTRIBUTION.TAX_AMOUNT) 
                           THEN TRUNC(MAX(IB_EXPENSE.SUPPLY_PRICE - (NVL((SELECT SUM(SUPPLY_PRICE)
                                                                     FROM IB_EXPENSE_DISTRIBUTION D
                                                                     WHERE D.EXPENSE_SN = IB_EXPENSE.SERIALKEY
                                                                       AND D.TAX_RATE = 0), 0))) / MAX(IB_EXPENSE.TAX_RATE)) 
                               - SUM(IB_EXPENSE_DISTRIBUTION.TAX_AMOUNT)   
                           ELSE 0
                      END
                 END), 0)  AS TAX_DIFF  
           ,NVL(( CASE WHEN MAX(IB_EXPENSE.TAX_RATE) = 0 THEN 0
                 ELSE CASE WHEN TRUNC(MAX(IB_EXPENSE.SUPPLY_PRICE)) <![CDATA[<>]]> SUM(IB_EXPENSE_DISTRIBUTION.SUPPLY_PRICE) 
                           THEN TRUNC(
                                MAX(IB_EXPENSE.SUPPLY_PRICE) - SUM(IB_EXPENSE_DISTRIBUTION.SUPPLY_PRICE)   
                                     )
                           ELSE 0
                      END
                 END), 0)  AS SUPPLY_PRICE_DIFF 
        FROM    IB_EXPENSE 
        JOIN    IB_EXPENSE_DISTRIBUTION
          ON    IB_EXPENSE.SERIALKEY = IB_EXPENSE_DISTRIBUTION.EXPENSE_SN
        WHERE   IB_EXPENSE.SERIALKEY = #{expenseSn}
        GROUP BY IB_EXPENSE.SERIALKEY
    </select>
    
    <select id="getSupplyPriceDiff" resultType="StExDCStorageResDto">
        SELECT     /* [ibExpenseService.sqlx][getTaxDiff][비용 조회][sunho.kim][2025.07.17] */
            IB_EXPENSE.SERIALKEY AS EXPENSE_SN
           ,NVL(( CASE WHEN MAX(IB_EXPENSE.TAX_RATE) = 0 THEN 0
                 ELSE CASE WHEN TRUNC(MAX(IB_EXPENSE.SUPPLY_PRICE)) <![CDATA[<>]]> SUM(IB_EXPENSE_DISTRIBUTION.SUPPLY_PRICE) 
                           THEN TRUNC(
                                MAX(IB_EXPENSE.SUPPLY_PRICE) - SUM(IB_EXPENSE_DISTRIBUTION.SUPPLY_PRICE)   
                                     )
                           ELSE 0
                      END
                 END), 0)  AS SUPPLY_PRICE_DIFF  
        FROM    IB_EXPENSE 
        JOIN    IB_EXPENSE_DISTRIBUTION
          ON    IB_EXPENSE.SERIALKEY = IB_EXPENSE_DISTRIBUTION.EXPENSE_SN
        WHERE   IB_EXPENSE.SERIALKEY = #{expenseSn}
        GROUP BY IB_EXPENSE.SERIALKEY
    </select>
    
</mapper>