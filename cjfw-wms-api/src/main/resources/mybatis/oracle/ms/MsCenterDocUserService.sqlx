<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="msCenterDocUserService">
	<!-- 센터서류 담당자 정보 조회(목록) -->
    <select id="getMasterList" resultType="MsCenterDocUserResDto">
    	SELECT /* [msCenterDocUserService.sqlx][msCenterDocUserService.getDataRead][센터서류 담당자관리 조회] */
	           MS_CENTER_DOC_USER.SERIALKEY,
	           MS_CENTER_DOC_USER.USERNM,
	           MS_CENTER_DOC_USER.DCCODE,
	           MS_CENTER_DOC_USER.STORERKEY,
	           MS_CENTER_DOC_USER.EMAIL,
	           FN_CODEDESCR(MS_CENTER_DOC_USER.STORERKEY, 'STATUS_USER_AUTHORITY', MS_CENTER_DOC_USER.STATUS) AS STATUS,
	           MS_CENTER_DOC_USER.DEL_YN,
	           TO_CHAR(MS_CENTER_DOC_USER.ADDDATE, 'YYYY-MM-DD hh24:mi:ss') AS ADDDATE,
	           TO_CHAR(MS_CENTER_DOC_USER.EDITDATE, 'YYYY-MM-DD hh24:mi:ss') AS EDITDATE,
	           MS_CENTER_DOC_USER.ADDWHO,
	           MS_CENTER_DOC_USER.EDITWHO,
	           USER1.USER_NM AS ADDWHO_NM,  /*등록자명*/
			   USER2.USER_NM AS EDITWHO_NM  /*수정자명*/
	      FROM MS_CENTER_DOC_USER
	      LEFT JOIN FRAMEONE_USER USER1 ON USER1.USER_ID = MS_CENTER_DOC_USER.ADDWHO  /*등록자명*/
          LEFT JOIN FRAMEONE_USER USER2 ON USER2.USER_ID = MS_CENTER_DOC_USER.EDITWHO  /*수정자명*/
	     WHERE 1=1
	    <if test="userNm != null and userNm != ''">
	       AND MS_CENTER_DOC_USER.USERNM LIKE '%' || #{userNm} || '%'
	    </if>
	    <if test="delYn != null and delYn != ''">
	       AND MS_CENTER_DOC_USER.DEL_YN LIKE #{delYn}
	    </if>
	    <if test='multiDcCode != null and multiDcCode.length > 0'>
		   AND MS_CENTER_DOC_USER.DCCODE IN
	        <foreach collection="multiDcCode" item="dccodeItem" open="(" separator="," close=")">
	            #{dccodeItem}
	        </foreach>
		</if>
		<if test="serialKey != null and serialKey != ''">
	       AND MS_CENTER_DOC_USER.SERIALKEY =  #{serialKey}
	    </if>
	     ORDER BY USERNM
    </select>
    
    
    <!-- 센터서류 담당자 정보 INSERT -->
    <insert id="insertMaster">			 
		INSERT /* [msCenterDocUserService.sqlx][msCenterDocUserService.insert][센터서류 담당자관리 INSERT] */
	      INTO MS_CENTER_DOC_USER
	         ( SERIALKEY,
	           USERNM,
	           DCCODE,
	           STORERKEY,
	           EMAIL,
	           STATUS,
	           DEL_YN,
	           ADDDATE,
	           ADDWHO
	         )
	    VALUES
	         ( SEQ_MS_CENTER_DOC_USER.NEXTVAL,
	           #{userNm},
	           #{dcCode},
	           NVL(#{storerkey}, 'FW00'),
	           #{email},
	           NVL(#{status}, '00'),
	           NVL(#{delYn}, 'N'),
	           SYSDATE,
	           #{gUserId}
	         )
    </insert>
    
    <!-- 센터서류 담당자 정보 UPDATE -->
    <!--update id="updateMaster">		
		UPDATE /* [msCenterDocUserService.sqlx][msCenterDocUserService.update][센터서류 담당자관리 UPDATE] */
	           MS_CENTER_DOC_USER
	       SET USERNM    = #{userNm},
	           DCCODE    = #{dcCode},
	           STORERKEY = #{storerkey},
	           EMAIL     = #{email},
	           STATUS    = #{status},
	           DEL_YN    = #{delYn},
	           EDITDATE  = SYSDATE,
	           EDITWHO   = #{gUserId}
	     WHERE SERIALKEY = #{serialKey}
	</update-->    
   
    <update id="updateMaster">
	    MERGE /* [msCenterDocUserService.sqlx][msCenterDocUserService.updateMaster][센터서류 담당자관리 MERGE] */
		 INTO MS_CENTER_DOC_USER T
		USING (
		    SELECT #{userNm}    AS USERNM
		         , #{dcCode}    AS DCCODE
		         , 'FW00'       AS STORERKEY
		         , #{email}     AS EMAIL
		         , #{status}    AS STATUS
		         , #{delYn}     AS DEL_YN
		         , #{gUserId}   AS WORKWHO
		    FROM DUAL
		) S
		ON (    T.USERNM = S.USERNM
		    AND T.DCCODE = S.DCCODE
		    AND T.EMAIL  = S.EMAIL )
		
		WHEN MATCHED THEN
		    UPDATE SET 
		          T.STORERKEY = S.STORERKEY
		        
		        , T.STATUS    = S.STATUS
		        , T.DEL_YN    = S.DEL_YN
		        , T.EDITDATE  = SYSDATE
		        , T.EDITWHO   = S.WORKWHO
		
		WHEN NOT MATCHED THEN
		    INSERT (
		          SERIALKEY
		        , USERNM
		        , DCCODE
		        , STORERKEY
		        , EMAIL
		        , STATUS
		        , DEL_YN
		        , ADDDATE
		        , ADDWHO
		        , EDITDATE
		        , EDITWHO
		    )
		    VALUES (
		          SEQ_MS_CENTER_DOC_USER.NEXTVAL
		        , S.USERNM
		        , S.DCCODE
		        , NVL(S.STORERKEY, 'FW00')
		        , S.EMAIL
		        , NVL(S.STATUS, '00')
		        , NVL(S.DEL_YN, 'N')
		        , SYSDATE
		        , S.WORKWHO
		        , SYSDATE
		        , S.WORKWHO
		    )
    </update>
</mapper>