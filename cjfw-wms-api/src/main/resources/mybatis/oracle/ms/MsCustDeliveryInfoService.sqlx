               , KEYDETAIL
               , DELIVERYREQUESTTIMESTART
               , DELIVERYREQUESTTIMEEND
               , DELIVERYAVAILABLETIME
               , BUILDINGOPENTIME
               , MOVEMENTENTRY
               , GOODSLOCATIONFROZEN
               , GOODSLOCATIONREFRIG
               , GOODSLOCATIONROOM
               , RETURNLOCATION
               , INITREQUESTDT
               , INITREQUESTTIMESTART
               , INITREQUESTTIMEEND
               , INITFTFINSPECTIONYN
               , INITDELIVERYCONTACT
               , INITDELIVERYDESC
               , DELIVERYTYPE
               , TEMPTARGET
               , LABELPRINTTYPE
               , DELIVERYNOTIYN
               , DELIVERYNOTIPHONE
               , DELIVERYNOTITIMESTART
               , DELIVERYNOTITIMEEND
                 
               , EMPLOEENUMBER
               , CREATEDBYEMAIL
               , CREATEDBYNAME
               , CREATEDDATE
               , EDMSFILEID
               , SOURCE_SYSTEM
               , STATUS
               , CONFIRMDATE
                 
               , ADDWHO
               , ADDDATE
               , EDITWHO
               , EDITDATE
            )
            VALUES (
                 SEQ_MS_CUSTDLVINFO.NEXTVAL
               , #{gStorerkey}
               , #{custkey}
               , #{custtype}
               , #{addressmatchyn}
               , #{truthaddress1}
               , #{truthaddress2}
               , #{truthzipcode}
               , #{faceinspect}
               , DAMO.ENC(FN_FORMAT_TELNO(#{inspectionworkerphone}))
               , #{inspectorprintyn}
               , #{parkingheight}
               , #{keytype}
               , #{keydetail}
               , #{reqdlvtime2From}
               , #{reqdlvtime2To}
               , #{deliveryavailabletime}
               , #{buildingopentime}
               , #{accessway}
               , #{freezeplace}
               , #{coldplace}
               , #{htemperature}
               , #{loadplace2}
               , #{initrequestdt}
               , #{initrequesttimestart}
               , #{initrequesttimeend}
               , #{initftfinspectionyn}
               , #{initdeliverycontact}
               , #{initdeliverydesc}
               , #{deliverytype}
               , #{temptarget}
               , #{labelprinttype}
               , #{deliverynotiyn}
               , DAMO.ENC(FN_FORMAT_TELNO(#{deliverynotiphone}))
               , #{deliverynotitimestart}
               , #{deliverynotitimeend}
                 
                 
               , #{gEmpNo}
               , #{gEmailAddr}
               , #{gUserNm}
               , SYSDATE
               , #{edmsfileid}
               , 'WMS'
               , '03'
               , SYSDATE
               , #{gUserId}
               , SYSDATE
               , #{gUserId}
               , SYSDATE
            )
    </update>
    

    <select id="getCrmCustdlvinfo_API" resultType="HMap">
        SELECT /*  [msCustDeliveryInfoService.sqlx][msCustDeliveryInfoService.getCrmCustdlvinfo_API] */
               MS_CUSTDLVINFO.CUSTKEY                               AS CUSTKEY
             , MS_CUSTDLVINFO.CUSTTYPE                              AS CUSTTYPE
             , MS_CUSTDLVINFO.ADDRESSMATCHYN                        AS ADDRESSMATCHYN
             , MS_CUSTDLVINFO.TRUTHADDRESS1                         AS ARRIVALADDRESS
             , MS_CUSTDLVINFO.TRUTHADDRESS2                         AS ARRIVALDETAILADDRESS
             , MS_CUSTDLVINFO.TRUTHZIPCODE                          AS ARRIVALPOSTALCODE
             , MS_CUSTDLVINFO.FACEINSPECT                           AS FTFINSPECTIONYN
             , DAMO.DEC(MS_CUSTDLVINFO.INSPECTIONWORKERPHONE)       AS INSPECTIONWORKERPHONE
             , MS_CUSTDLVINFO.INSPECTORPRINTYN                      AS INSPECTORPRINTYN
             , MS_CUSTDLVINFO.PARKINGHEIGHT                         AS PARKINGHEIGHT
             , MS_CUSTDLVINFO.KEYTYPE2                               AS KEYTYPE
             , MS_CUSTDLVINFO.KEYDETAIL                             AS KEYDETAIL
             , MS_CUSTDLVINFO.REQDLVTIME2_FROM                      AS DELIVERYREQUESTTIMESTART
             , MS_CUSTDLVINFO.REQDLVTIME2_TO                        AS DELIVERYREQUESTTIMEEND
             , MS_CUSTDLVINFO.DELIVERYAVAILABLETIME                 AS DELIVERYAVAILABLETIME
             , MS_CUSTDLVINFO.BUILDINGOPENTIME                      AS BUILDINGOPENTIME
             , MS_CUSTDLVINFO.ACCESSWAY                             AS MOVEMENTENTRY
             , MS_CUSTDLVINFO.FREEZEPLACE                           AS GOODSLOCATIONFROZEN
             , MS_CUSTDLVINFO.COLDPLACE                             AS GOODSLOCATIONREFRIG
             , MS_CUSTDLVINFO.HTEMPERATURE                          AS GOODSLOCATIONROOM
             , MS_CUSTDLVINFO.LOADPLACE2                            AS RETURNLOCATION
             , TO_CHAR(TO_DATE(MS_CUSTDLVINFO.INITREQUESTDT, 'YYYY-MM-DD'),'YYYY-MM-DD')               AS INITREQUESTDT
             , MS_CUSTDLVINFO.INITREQUESTTIMESTART                  AS INITREQUESTTIMESTART
             , MS_CUSTDLVINFO.INITREQUESTTIMEEND                    AS INITREQUESTTIMEEND
             , MS_CUSTDLVINFO.INITFTFINSPECTIONYN                   AS INITFTFINSPECTIONYN
             , MS_CUSTDLVINFO.INITDELIVERYCONTACT                   AS INITDELIVERYCONTACT
             , MS_CUSTDLVINFO.INITDELIVERYDESC                      AS INITDELIVERYDESC
             , MS_CUSTDLVINFO.DELIVERYTYPE                          AS DELIVERYTYPE
             , MS_CUSTDLVINFO.TEMPTARGET                            AS TEMPTARGET
             , MS_CUSTDLVINFO.LABELPRINTTYPE                        AS LABELPRINTTYPE
             , MS_CUSTDLVINFO.DELIVERYNOTIYN                        AS DELIVERYNOTIYN
             , DAMO.DEC(MS_CUSTDLVINFO.DELIVERYNOTIPHONE)           AS DELIVERYNOTIPHONE
             , MS_CUSTDLVINFO.DELIVERYNOTITIMESTART                 AS DELIVERYNOTITIMESTART
             , MS_CUSTDLVINFO.DELIVERYNOTITIMEEND                   AS DELIVERYNOTITIMEEND
             , MS_CUSTDLVINFO.EMPLOEENUMBER                         AS EMPLOEENUMBER
             , MS_CUSTDLVINFO.CREATEDBYEMAIL                        AS CREATEDBYEMAIL
             , (SELECT REPLACE(FN_GETUSERNAME(MS_CUSTDLVINFO.CREATEDBYNAME),'NOT FOUND',MS_CUSTDLVINFO.CREATEDBYNAME) from DUAL) AS CREATEDBYNAME
             , TO_CHAR(MS_CUSTDLVINFO.CREATEDDATE, 'yyyy-mm-dd hh24:mi:ss')                 AS CREATEDDATE
             , MS_CUSTDLVINFO.STORETYPE                             AS STORETYPE
             , MS_CUSTDLVINFO.EDMSFILEID                            AS EDMSFILEID
             , MS_CUSTDLVINFO.STATUS                                AS STATUS
             , TO_CHAR(MS_CUSTDLVINFO.ADDDATE, 'yyyy-mm-dd hh24:mi:ss')       AS ADDDATE
             , TO_CHAR(MS_CUSTDLVINFO.EDITDATE, 'yyyy-mm-dd hh24:mi:ss')      AS EDITDATE
             , (SELECT REPLACE(FN_GETUSERNAME(MS_CUSTDLVINFO.ADDWHO),'NOT FOUND',MS_CUSTDLVINFO.ADDWHO) from DUAL)      AS ADDWHO
             , (SELECT REPLACE(FN_GETUSERNAME(MS_CUSTDLVINFO.EDITWHO),'NOT FOUND',MS_CUSTDLVINFO.EDITWHO) from DUAL)    AS EDITWHO
         FROM MS_CUSTDLVINFO
        WHERE 1=1
          AND MS_CUSTDLVINFO.CUSTKEY   = #{custkey}
          AND ROWNUM = 1
    </select>
    
    <select id="getFileData_API" resultType="HMap">
        SELECT /* [msCustDeliveryInfoNewService.sqlx][msCustDeliveryInfoNewService.getFileData_API] */
               UPLOAD_HASH_ID                   AS TYPE
             ,  ''                              AS ID
             , FILE_NAME                        AS FILENAME
             , DECODE(STATUS, 'Y', 'N', 'D')    AS FILESTATUS
             , UPLOAD_RES_DOC_ID                AS EDMSFILEID
        FROM
            CRM_CUSTDLVINFO_FILE
        WHERE 1 = 1
            AND DOC_NAME = 'CRMDLVINFO_FILE'
            AND SEND_YN = 'N'
            AND ISSUENO = #{custkey}
    </select>
    
    <!-- 파일  전송유무 변경-->
    <update id="updateFileSendYn">
        UPDATE /* [msCustDeliveryInfoNewService.sqlx][msCustDeliveryInfoNewService.updateFileSendYn][파일 전송유무 변경][JeongHyeongCheol][20251010] */
               CRM_CUSTDLVINFO_FILE
           SET SEND_YN      = 'Y'
             , EDITDATE     = SYSDATE
             , EDITWHO      = #{gUserId}
         WHERE DOC_NAME     = 'CRMDLVINFO_FILE'
           AND ISSUENO      = #{custkey}
           AND SEND_YN      = 'N'
    </update>
    
    
    <!-- 파일 정보 불러오기 -->
	<select id="getUploadFileList" resultType="MsCustDeliveryInfoUploadFileResDto">
	    SELECT /* [msCustDeliveryInfoNewService.sqlx][msCustDeliveryInfoNewService.getPopupUploadFileList][고객배송조건 Upload File List][JeongHyeongCheol][20251010] */
	            '0'                  AS CHECKYN
	           ,SERIALKEY            AS SERIALKEY
	           ,ISSUENO              AS ISSUENO
	           ,DOC_TYPE             AS DOC_TYPE
	           ,DOC_NAME             AS DOC_NAME
	           ,FILE_NAME            AS FILE_NAME
	           ,FILE_EXTENSION       AS FILE_EXTENSION
	           ,FILE_LOCATION        AS FILE_LOCATION
	           ,FILE_SIZE_BYTES      AS FILE_SIZE_BYTES
	           ,TRANS_FILE_NAME      AS TRANS_FILE_NAME
	           ,UPLOAD_HASH_ID       AS UPLOAD_HASH_ID
	           ,UPLOAD_RES_DOC_ID    AS UPLOAD_RES_DOC_ID
	           ,UPLOAD_FILE_NAME     AS UPLOAD_FILE_NAME
	           ,UPLOAD_WORKPLACE_ID  AS UPLOAD_WORKPLACE_ID
	           ,UPLOAD_LOCATION      AS UPLOAD_LOCATION
	           ,DOWNLOAD_COUNT       AS DOWNLOAD_COUNT
	           ,FILE_TYPE            AS FILE_TYPE
	           ,STATUS               AS STATUS
	           ,ADDWHO               AS ADDWHO
	           ,ADDDATE              AS ADDDATE
	           ,EDITWHO              AS EDITWHO
	           ,EDITDATE             AS EDITDATE
	    FROM    CRM_CUSTDLVINFO_FILE
	    WHERE   DOC_NAME = 'CRMDLVINFO_FILE'
	    AND     ISSUENO  = #{issueno}
	    AND     UPLOAD_HASH_ID = #{code}
    AND     DEL_YN   = 'N'
	</select>
	
	<!-- 이미지 저장 -->
    <insert id="insertFileInfo">
		/* [msCustDeliveryInfoNewService.sqlx][msCustDeliveryInfoNewService.insertFileInfo][crm 요청관리 첨부파일 Insert] */
