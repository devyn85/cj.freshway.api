                    </foreach>
                </if>
                <if test="carnoList != null and carnoList.size > 0">
                    AND CARNO IN
                    <foreach item="carno" collection="carnoList" open="(" separator="," close=")">
                        #{carno}
                    </foreach>
                </if>
	            GROUP BY
	                  DCCODE
	                , DELIVERYDT
	                , CARNO
            ) CAR_LIST
            GROUP BY
                  CAR_LIST.DCCODE
                , ROLLUP(CAR_LIST.WORKLOGTYPE)
            ORDER BY
                  CAR_LIST.DCCODE
                , TO_NUMBER(NVL(CAR_LIST.WORKLOGTYPE, '00'))
