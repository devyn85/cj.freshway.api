<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="wdDeliveryLabelDailyService">

	<select id="getTab1MasterList" resultType="WdDeliveryLabelDailyResTab1Dto">
         SELECT /* [wdDeliveryLabelDailyService.sqlx][getTab1MasterList][일배분류서출력-일배 목록 조회][공두경][2026.02.19] */
		        DMH_SO.DCCODE                                           AS DCCODE             /*센터코드*/
               ,FN_GETDCNAME(DMH_SO.DCCODE)                             AS DCNAME             /*센터명*/
               ,DMH_SO.DELIVERYDATE                                     AS DELIVERYDATE       /*납품일자*/
               ,FN_CODEDESCR('FW00','ORDERTYPE_WD',DMH_SO.ORDERTYPE)    AS ORDERTYPE          /*주문유형*/
               ,DMD_SO.SKU                                              AS SKU                /*상품코드*/
               ,MS_SKU.DESCRIPTION                                      AS SKUNAME            /*상품명*/
               ,NVL(CD1.BASEDESCR,CD1.BASECODE)                         AS STORAGETYPENM      /*보관유형*/
               ,NVL(CD2.BASEDESCR,CD2.BASECODE)                         AS SALEGROUP          /*담당부서*/
               ,USER1.USER_NM                                           AS TO_EMPNAME         /*영업사원*/
               ,TM_INPLAN.CARNO                                         AS CARNO              /*차량번호*/
               ,TM_INPLAN.DELIVERYGROUP                                 AS DELIVERYGROUP      /*POP*/
               ,(SELECT CM_DRIVER.DRIVERNAME
                  FROM CM_CAR
                  LEFT OUTER JOIN CM_DRIVER
                    ON CM_DRIVER.DRIVERID = NVL(CM_CAR.DRIVER1, CM_CAR.DRIVER2)
                 WHERE CM_CAR.CARNO = TM_INPLAN.CARNO
                   AND CM_DRIVER.DEL_YN = 'N')                          AS DRIVERNAME         /*기사명*/
               ,DMH_SO.TO_CUSTKEY                                       AS TO_CUSTKEY         /*고객코드*/
               ,DMH_SO.TO_CUSTNAME                                      AS TO_CUSTNAME        /*고객명*/
               ,DMD_SO.STORERUOM                                        AS UOM                /*단위*/
               ,DMD_SO.STOREROPENQTY                                    AS ORDERQTY           /*주문수량*/
               ,TO_CHAR(DMH_SO.ADDDATE, 'YYYY-MM-DD HH24:MI:SS')        AS ADDDATE            /*주문시간*/
               ,DMD_SO.DOCNO                                            AS DOCNO              /*주문번호*/
               ,DMD_SO.DOCLINE                                          AS DOCLINE            /*항번*/
               ,DMD_PO.POKEY                                            AS POKEY              /*발주번호*/               
               ,DMH_PO.FROM_CUSTKEY                                     AS FROM_CUSTKEY       /*구매처*/
               ,DMH_PO.FROM_CUSTNAME                                    AS FROM_CUSTNAME      /*구매처명*/
               ,DMH_SO.MEMO1                                            AS MEMO1              /*비고(물류요청사항)*/
               ,DMD_PO.POLINE                                           AS POLINE             /**/
        FROM   DM_DOCUMENT_H DMH_SO 
        JOIN   DM_DOCUMENT_D DMD_SO          
          ON   DMH_SO.DCCODE         =  DMD_SO.DCCODE         
         AND   DMH_SO.STORERKEY      =  DMD_SO.STORERKEY               
         AND   DMH_SO.DELIVERYDATE   =  DMD_SO.DELIVERYDATE         
         AND   DMH_SO.DOCNO          =  DMD_SO.DOCNO         
         AND   DMH_SO.DOCTYPE        =  DMD_SO.DOCTYPE         
         AND   DMH_SO.DOCTYPE        = 'WD'      
        JOIN   DM_DOCUMENT_D DMD_PO
          ON   DMD_PO.STORERKEY      = DMD_SO.STORERKEY
         AND   DMD_PO.DCCODE         = DMD_SO.DCCODE
         AND   DMD_PO.ORGANIZE       = DMD_SO.ORGANIZE
         AND   DMD_PO.DELIVERYDATE   = DMD_SO.DELIVERYDATE
         AND   DMD_PO.DOCTYPE        = 'DP'
         AND   DMD_PO.DOCNO          = DMD_SO.POKEY
         AND   DMD_PO.DOCLINE        = DMD_SO.POLINE
         AND   DMD_PO.CHANNEL        = '2'
         AND   DMD_PO.DEL_YN         = 'N'
        JOIN   DM_DOCUMENT_H DMH_PO
          ON   DMH_PO.DCCODE         =  DMD_PO.DCCODE         
         AND   DMH_PO.STORERKEY      =  DMD_PO.STORERKEY               
         AND   DMH_PO.DELIVERYDATE   =  DMD_PO.DELIVERYDATE         
         AND   DMH_PO.DOCNO          =  DMD_PO.DOCNO         
         AND   DMH_PO.DOCTYPE        =  DMD_PO.DOCTYPE   
        JOIN   MS_SKU
          ON    DMD_SO.STORERKEY     = MS_SKU.STORERKEY
         AND    DMD_SO.SKU           = MS_SKU.SKU
        JOIN   MS_CUST           
          ON   MS_CUST.STORERKEY     = DMH_SO.STORERKEY          
         AND   MS_CUST.CUSTKEY       = DMH_SO.TO_CUSTKEY 
         AND   MS_CUST.CUSTTYPE      = DMH_SO.TO_CUSTTYPE
        LEFT OUTER JOIN TM_INPLAN
          ON   DMH_SO.DCCODE         = TM_INPLAN.DCCODE
         AND   DMH_SO.STORERKEY      = TM_INPLAN.STORERKEY
         AND   DMH_SO.DOCTYPE        = TM_INPLAN.DOCTYPE
         AND   DMH_SO.DELIVERYDATE   = TM_INPLAN.SLIPDT
         AND   DMH_SO.DOCNO          = TM_INPLAN.DOCNO
        LEFT JOIN FRAMEONE_USER USER1 ON USER1.EMP_NO = DMH_SO.TO_EMPNAME1
        LEFT JOIN CM_CODE_STORER CD1 ON (CD1.STORERKEY = DMH_SO.STORERKEY AND CD1.CODELIST = 'STORAGETYPE'   AND CD1.BASECODE  = MS_SKU.STORAGETYPE)
        LEFT JOIN CM_CODE_STORER CD2 ON (CD2.STORERKEY = DMH_SO.STORERKEY AND CD2.CODELIST = 'SALEGROUP'   AND CD2.BASECODE  = MS_CUST.SALEGROUP)
        WHERE  1=1
        AND    DMH_SO.STORERKEY = #{gStorerkey}
        AND    DMH_SO.DCCODE = #{gDccode}
        <if test="slipdt != null and slipdt != ''">                 AND DMH_SO.DELIVERYDATE      =  #{slipdt}           </if>
        <if test="deliverygroup != null and deliverygroup != ''">   AND TM_INPLAN.DELIVERYGROUP  =  #{deliverygroup}    </if>
        <!-- 고객 다중선택 -->
        <if test="toCustkeyMulti != null and toCustkeyMulti != '' ">
            <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                <foreach collection="toCustkeyMulti" item="item">
                    OR DMH_PO.FROM_CUSTKEY IN
                    <foreach collection="item" item="code" open="(" close=")" separator=",">
                        #{code}      
                    </foreach>
                </foreach>
            </trim>                                             
        </if>
        <if test="carnoMulti != null and carnoMulti != ''">    
               AND TM_INPLAN.CARNO IN
               <foreach collection="carnoMulti" item="code" open="(" close=")" separator=",">
                 #{code}
               </foreach>
       </if>
        AND    DMH_SO.DEL_YN = 'N'
        AND    DMH_SO.DOCTYPE IN ('WD')
        AND    DMH_SO.CHANNEL = '2'
        AND    DMH_SO.IF_SEND_TYPE <![CDATA[<>]]> 'WMSPO'
        AND    DMH_SO.WORKPROCESSCODE IN ('SO')
        AND    NOT ( DMH_SO.DOCTYPE = 'WD' AND DMH_SO.WORKPROCESSCODE = 'PO')      
        ORDER BY DMH_SO.DCCODE, DMH_SO.DELIVERYDATE, DMH_SO.ORDERTYPE    
               
    </select>
        
    
    <select id="getTab2MasterList" resultType="WdDeliveryLabelDailyResTab2Dto">       
        SELECT /* [wdDeliveryLabelDailyService.sqlx][getTab2MasterList][일배분류서출력-광역일배 목록 조회][공두경][2026.02.19] */
               SLIPDT                 AS SLIPDT             /*출고일자*/
              ,DOCNO                  AS DOCNO              /*주문번호*/
              ,WD_DCCODE              AS WD_DCCODE          /*물류센터(공급)*/
              ,MAX(WD_DCNAME)         AS WD_DCNAME          /*물류센터명(공급)*/
              ,DP_DCCODE              AS DP_DCCODE          /*물류센터(공급받는)*/
              ,MAX(DP_DCNAME)         AS DP_DCNAME          /*물류센터명(공급받는)*/
              ,P_CUSTKEY              AS CP_CUSTKEY          /*협력사코드*/
              ,MAX(P_CUSTNAME)        AS CP_CUSTNAME         /*협력사명*/
              ,C_CUSTKEY              AS CC_CUSTKEY          /*관리처코드*/
              ,MAX(C_CUSTNAME)        AS CC_CUSTNAME         /*관리처명*/
              ,SKU                    AS SKU                /*상품코드*/
              ,MAX(SKUNAME)           AS SKUNAME            /*상품명칭*/
              ,MAX(STORAGETYPE)       AS STORAGETYPE        /*저장조건*/
              ,UOM                    AS UOM                /*단위*/
              ,MAX(CARNO)             AS CARNO              /*차량번호*/
              ,MAX(DELIVERYGROUP)     AS DELIVERYGROUP      /*POP*/
              ,SUM(ORDERQTY)          AS ORDERQTY           /*주문수량*/
              ,SUM(WD_INSPECTQTY)     AS WD_INSPECTQTY      /*광역출고검수량*/
              ,SUM(DP_INSPECTQTY)     AS DP_INSPECTQTY      /*광역입고검수량*/                            
              ,CASE WHEN SUM(ORDERQTY)=SUM(WD_INSPECTQTY) THEN '일치' ELSE '불일치' END AS STATUS_INSPECT_WD /*출고*/
              ,CASE WHEN SUM(ORDERQTY)=SUM(DP_INSPECTQTY) THEN '일치' ELSE '불일치' END AS STATUS_INSPECT_DP /*입고*/              
        FROM (
                SELECT MAX(WD_INPLAN.SLIPDT)                              AS SLIPDT
                      ,DM_DOCUMENT_D.DOCNO                                AS DOCNO
                      ,MAX(DM_DOCUMENT_D.ROUTE)                           AS WD_DCCODE
                      ,MAX(WD_DC.DCNAME)                                  AS WD_DCNAME
                      ,MAX(DM_DOCUMENT_D.DCCODE)                          AS DP_DCCODE
                      ,MAX(DP_DC.DCNAME)                                  AS DP_DCNAME
                      ,MAX(DM_DOCUMENT_H_PO.FROM_CUSTKEY)                 AS P_CUSTKEY
                      ,MAX(DM_DOCUMENT_H_PO.FROM_CUSTNAME)                AS P_CUSTNAME
                      ,MAX(DM_DOCUMENT_H.TO_CUSTKEY)                      AS C_CUSTKEY
                      ,MAX(DM_DOCUMENT_H.TO_CUSTNAME)                     AS C_CUSTNAME
                      ,MAX(DM_DOCUMENT_D.SKU)                             AS SKU
                      ,MAX(MS_SKU.DESCRIPTION)                            AS SKUNAME
                      ,FN_CODEDESCR(MAX(DM_DOCUMENT_D.STORERKEY)
                                   ,'STORAGETYPE'
                                   ,MAX(MS_SKU.STORAGETYPE))              AS STORAGETYPE
                      ,MAX(DM_DOCUMENT_D.STOREROPENQTY)                   AS ORDERQTY
                      ,FN_CONV_UOM(MAX(DM_DOCUMENT_D.STORERKEY)
                                  ,MAX(DM_DOCUMENT_D.SKU)
                                  ,MAX(DM_DOCUMENT_D.UOM)
                                  ,MAX(DM_DOCUMENT_D.STORERUOM)
                                  ,NVL(SUM(WD_INVOICE.DP_INSPECTQTY),0))  AS DP_INSPECTQTY
                      ,MAX(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY
                                      ,DM_DOCUMENT_D.SKU
                                      ,DM_DOCUMENT_D.UOM
                                      ,DM_DOCUMENT_D.STORERUOM
                                      ,DM_DOCUMENT_D.ROUTEINSPECTQTY))    AS WD_INSPECTQTY
                      ,MAX(DM_DOCUMENT_D.STORERUOM)                       AS UOM
                      ,MAX(TM_INPLAN.CARNO)                               AS CARNO
                      ,MAX(TM_INPLAN.DELIVERYGROUP)                       AS DELIVERYGROUP
                FROM   DM_DOCUMENT_D

                JOIN   DM_DOCUMENT_H
                ON     DM_DOCUMENT_H.DCCODE            = DM_DOCUMENT_D.DCCODE
                AND    DM_DOCUMENT_H.STORERKEY         = DM_DOCUMENT_D.STORERKEY
                AND    DM_DOCUMENT_H.ORGANIZE          = DM_DOCUMENT_D.ORGANIZE
                AND    DM_DOCUMENT_H.DOCTYPE           = DM_DOCUMENT_D.DOCTYPE
                AND    DM_DOCUMENT_H.DELIVERYDATE      = DM_DOCUMENT_D.DELIVERYDATE
                AND    DM_DOCUMENT_H.DOCNO             = DM_DOCUMENT_D.DOCNO
                AND    DM_DOCUMENT_H.DEL_YN            = 'N'

                JOIN   WD_INPLAN
                ON     WD_INPLAN.DCCODE                = DM_DOCUMENT_D.DCCODE
                AND    WD_INPLAN.STORERKEY             = DM_DOCUMENT_D.STORERKEY
                AND    WD_INPLAN.ORGANIZE              = DM_DOCUMENT_D.ORGANIZE
                AND    WD_INPLAN.AREA                  = DM_DOCUMENT_D.AREA
                AND    WD_INPLAN.DOCTYPE               = DM_DOCUMENT_D.DOCTYPE
                AND    WD_INPLAN.SLIPDT                = DM_DOCUMENT_D.DELIVERYDATE
                AND    WD_INPLAN.DOCNO                 = DM_DOCUMENT_D.DOCNO
                AND    WD_INPLAN.DOCLINE               = DM_DOCUMENT_D.DOCLINE
                AND    WD_INPLAN.DEL_YN                = 'N'

                JOIN   DM_DOCUMENT_D DM_DOCUMENT_D_PO
                ON     DM_DOCUMENT_D_PO.DCCODE         = DM_DOCUMENT_D.DCCODE
                AND    DM_DOCUMENT_D_PO.STORERKEY      = DM_DOCUMENT_D.STORERKEY
                AND    DM_DOCUMENT_D_PO.ORGANIZE       = DM_DOCUMENT_D.ORGANIZE
                AND    DM_DOCUMENT_D_PO.AREA           = DM_DOCUMENT_D.AREA
                AND    DM_DOCUMENT_D_PO.DOCTYPE        = 'DP'
                AND    DM_DOCUMENT_D_PO.DOCNO          = DM_DOCUMENT_D.POKEY
                AND    DM_DOCUMENT_D_PO.DOCLINE        = DM_DOCUMENT_D.POLINE
                AND    DM_DOCUMENT_D_PO.DEL_YN         = 'N'

                JOIN   DM_DOCUMENT_H DM_DOCUMENT_H_PO
                ON     DM_DOCUMENT_H_PO.DCCODE         = DM_DOCUMENT_D_PO.DCCODE
                AND    DM_DOCUMENT_H_PO.STORERKEY      = DM_DOCUMENT_D_PO.STORERKEY
                AND    DM_DOCUMENT_H_PO.ORGANIZE       = DM_DOCUMENT_D_PO.ORGANIZE
                AND    DM_DOCUMENT_H_PO.DOCTYPE        = DM_DOCUMENT_D_PO.DOCTYPE
                AND    DM_DOCUMENT_H_PO.DELIVERYDATE   = DM_DOCUMENT_D_PO.DELIVERYDATE
                AND    DM_DOCUMENT_H_PO.DOCNO          = DM_DOCUMENT_D_PO.DOCNO
                AND    DM_DOCUMENT_H_PO.DEL_YN         = 'N'

                LEFT OUTER JOIN
                       WD_INVOICE
                ON     WD_INVOICE.DCCODE               = WD_INPLAN.DCCODE
                AND    WD_INVOICE.STORERKEY            = WD_INPLAN.STORERKEY
                AND    WD_INVOICE.ORGANIZE             = WD_INPLAN.ORGANIZE
                AND    WD_INVOICE.AREA                 = WD_INPLAN.AREA
                AND    WD_INVOICE.DOCTYPE              = WD_INPLAN.DOCTYPE
                AND    WD_INVOICE.DOCDT                = WD_INPLAN.DOCDT
                AND    WD_INVOICE.DOCNO                = WD_INPLAN.DOCNO
                AND    WD_INVOICE.DOCLINE              = WD_INPLAN.DOCLINE
                AND    WD_INVOICE.SLIPDT               = WD_INPLAN.SLIPDT
                AND    WD_INVOICE.SLIPNO               = WD_INPLAN.SLIPNO
                AND    WD_INVOICE.SLIPLINE             = WD_INPLAN.SLIPLINE
                AND    WD_INVOICE.DEL_YN               = 'N'

                JOIN   MS_SKU
                ON     MS_SKU.STORERKEY                = DM_DOCUMENT_D.STORERKEY
                AND    MS_SKU.SKU                      = DM_DOCUMENT_D.SKU
                AND    MS_SKU.DEL_YN                   = 'N'
                
                JOIN   CM_DC WD_DC
                ON     WD_DC.DCCODE                    = DM_DOCUMENT_D.ROUTE
                AND    WD_DC.DEL_YN                    = 'N'
                
                JOIN   CM_DC DP_DC
                ON     DP_DC.DCCODE                    = DM_DOCUMENT_D.DCCODE
                AND    DP_DC.DEL_YN                    = 'N'
                
                LEFT OUTER JOIN TM_INPLAN
                ON   TM_INPLAN.DCCODE                  = WD_INPLAN.DCCODE
                AND  TM_INPLAN.STORERKEY               = WD_INPLAN.STORERKEY
                AND  TM_INPLAN.DOCTYPE                 = WD_INPLAN.DOCTYPE
                AND  TM_INPLAN.SLIPDT                  = WD_INPLAN.SLIPDT
                AND  TM_INPLAN.SLIPNO                  = WD_INPLAN.SLIPNO
                
                WHERE  1=1
                AND    DM_DOCUMENT_D.STORERKEY         = #{gStorerkey}
                AND    DM_DOCUMENT_D.DOCTYPE           = 'WD'      
                AND    DM_DOCUMENT_D.DEL_YN            = 'N'
                AND    DM_DOCUMENT_D.CHANNEL           = '3'
                <if test="slipdt != null and slipdt != ''">                 AND DM_DOCUMENT_D.DELIVERYDATE  =  #{slipdt}        </if>
                <if test="deliverygroup != null and deliverygroup != ''">   AND TM_INPLAN.DELIVERYGROUP     =  #{deliverygroup} </if>
                <!-- 고객 다중선택 -->
                <if test="toCustkeyMulti != null and toCustkeyMulti != '' ">
                    <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                        <foreach collection="toCustkeyMulti" item="item">
                            OR DM_DOCUMENT_H_PO.FROM_CUSTKEY IN
                            <foreach collection="item" item="code" open="(" close=")" separator=",">
                                #{code}      
                            </foreach>
                        </foreach>
                    </trim>                                             
                </if>
                <if test="carnoMulti != null and carnoMulti != ''">    
                       AND TM_INPLAN.CARNO IN
                       <foreach collection="carnoMulti" item="code" open="(" close=")" separator=",">
                         #{code}
                       </foreach>
               </if>
               <if test="fromDccode != null and fromDccode != ''">  AND DM_DOCUMENT_D.ROUTE     =  #{fromDccode} </if>
               <if test="toDccode != null and toDccode != ''">      AND DM_DOCUMENT_D.DCCODE    =  #{toDccode} </if>
                GROUP BY
                       DM_DOCUMENT_D.DCCODE
                      ,DM_DOCUMENT_D.DOCDT
                      ,DM_DOCUMENT_D.DOCNO
                      ,DM_DOCUMENT_D.DOCLINE
               )
        GROUP BY
               DOCNO
              ,SLIPDT           
              ,WD_DCCODE        
              ,DP_DCCODE         
              ,P_CUSTKEY         
              ,C_CUSTKEY         
              ,SKU               
              ,UOM               
        ORDER BY
               SLIPDT
              ,WD_DCCODE        
              ,DP_DCCODE         
              ,P_CUSTKEY         
              ,C_CUSTKEY         
              ,SKU
              ,DOCNO     
    </select>   
    
    <select id="getDataPopHeaderlist" resultType="WdDeliveryLabelDailyResPrintHeaderDto">       
       SELECT /* [WdDeliveryLabelDailyService.sqlx][getDataPopHeaderlist][일배분류서출력-일배 인쇄 목록 조회(POP)][공두경][2026.02.19] */
                '일배 분류서'                                                  AS TITLE
               ,TM_INPLAN.DELIVERYGROUP                                     AS DELIVERYGROUP
               ,fn_format_mask(DMH_SO.DELIVERYDATE, '####-##-##')           AS DELIVERYDATE 
               ,DMH_SO.DCCODE                                               AS DCCODE
               ,FN_GETDCNAME(DMH_SO.DCCODE)                                 AS DCNAME
               ,COUNT(1)                                                    AS TOTALCNT
        FROM   DM_DOCUMENT_H DMH_SO 
        JOIN   DM_DOCUMENT_D DMD_SO          
          ON   DMH_SO.DCCODE         =  DMD_SO.DCCODE         
         AND   DMH_SO.STORERKEY      =  DMD_SO.STORERKEY               
         AND   DMH_SO.DELIVERYDATE   =  DMD_SO.DELIVERYDATE         
         AND   DMH_SO.DOCNO          =  DMD_SO.DOCNO         
         AND   DMH_SO.DOCTYPE        =  DMD_SO.DOCTYPE         
         AND   DMH_SO.DOCTYPE        = 'WD'      
        JOIN   DM_DOCUMENT_D DMD_PO
          ON   DMD_PO.STORERKEY      = DMD_SO.STORERKEY
         AND   DMD_PO.DCCODE         = DMD_SO.DCCODE
         AND   DMD_PO.ORGANIZE       = DMD_SO.ORGANIZE
         AND   DMD_PO.DELIVERYDATE   = DMD_SO.DELIVERYDATE
         AND   DMD_PO.DOCTYPE        = 'DP'
         AND   DMD_PO.DOCNO          = DMD_SO.POKEY
         AND   DMD_PO.DOCLINE        = DMD_SO.POLINE
         AND   DMD_PO.CHANNEL        = '2'
         AND   DMD_PO.DEL_YN         = 'N'
        JOIN   DM_DOCUMENT_H DMH_PO
          ON   DMH_PO.DCCODE         =  DMD_PO.DCCODE         
         AND   DMH_PO.STORERKEY      =  DMD_PO.STORERKEY               
         AND   DMH_PO.DELIVERYDATE   =  DMD_PO.DELIVERYDATE         
         AND   DMH_PO.DOCNO          =  DMD_PO.DOCNO         
         AND   DMH_PO.DOCTYPE        =  DMD_PO.DOCTYPE   
        JOIN   MS_SKU
          ON    DMD_SO.STORERKEY     = MS_SKU.STORERKEY
         AND    DMD_SO.SKU           = MS_SKU.SKU
        JOIN   MS_CUST           
          ON   MS_CUST.STORERKEY     = DMH_SO.STORERKEY          
         AND   MS_CUST.CUSTKEY       = DMH_SO.TO_CUSTKEY 
         AND   MS_CUST.CUSTTYPE      = DMH_SO.TO_CUSTTYPE
        LEFT OUTER JOIN TM_INPLAN
          ON   DMH_SO.DCCODE         = TM_INPLAN.DCCODE
         AND   DMH_SO.STORERKEY      = TM_INPLAN.STORERKEY
         AND   DMH_SO.DOCTYPE        = TM_INPLAN.DOCTYPE
         AND   DMH_SO.DELIVERYDATE   = TM_INPLAN.SLIPDT
         AND   DMH_SO.DOCNO          = TM_INPLAN.DOCNO
        WHERE  1=1
        AND    DMH_SO.STORERKEY = #{gStorerkey}
        AND    DMH_SO.DCCODE = #{gDccode}
        AND    DMH_SO.ORGANIZE = #{gDccode}
        <if test="slipdt != null and slipdt != ''">                 AND DMH_SO.DELIVERYDATE      =  #{slipdt}           </if>
        <if test="deliverygroup != null and deliverygroup != ''">   AND TM_INPLAN.DELIVERYGROUP  =  #{deliverygroup}    </if>
        <!-- 고객 다중선택 -->
        <if test="toCustkeyMulti != null and toCustkeyMulti != '' ">
            <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                <foreach collection="toCustkeyMulti" item="item">
                    OR DMH_PO.FROM_CUSTKEY IN
                    <foreach collection="item" item="code" open="(" close=")" separator=",">
                        #{code}      
                    </foreach>
                </foreach>
            </trim>                                             
        </if>
        <if test="carnoMulti != null and carnoMulti != ''">    
               AND TM_INPLAN.CARNO IN
               <foreach collection="carnoMulti" item="code" open="(" close=")" separator=",">
                 #{code}
               </foreach>
       </if>        
        AND    DMH_SO.DEL_YN = 'N'
        AND    DMH_SO.DOCTYPE IN ('WD')
        AND    DMH_SO.CHANNEL = '2'
        AND    DMH_SO.IF_SEND_TYPE <![CDATA[<>]]> 'WMSPO'
        AND    DMH_SO.WORKPROCESSCODE IN ('SO')
        AND    NOT ( DMH_SO.DOCTYPE = 'WD' AND DMH_SO.WORKPROCESSCODE = 'PO')      
        GROUP BY TM_INPLAN.DELIVERYGROUP, DMH_SO.DELIVERYDATE, DMH_SO.DCCODE
        ORDER BY TM_INPLAN.DELIVERYGROUP
              
    </select>      
    
    <select id="getDataCustHeaderlist" resultType="WdDeliveryLabelDailyResPrintHeaderDto">       
       SELECT /* [WdDeliveryLabelDailyService.sqlx][getDataCustHeaderlist][일배분류서출력-일배 인쇄 목록 조회(구매처)][공두경][2026.02.19] */
                '일배 분류서'                                                  AS TITLE
               ,DMH_PO.FROM_CUSTKEY                                         AS FROM_CUSTKEY
               ,DMH_PO.FROM_CUSTNAME                                        AS FROM_CUSTNAME
               ,fn_format_mask(DMH_SO.DELIVERYDATE, '####-##-##')           AS DELIVERYDATE 
               ,DMH_SO.DCCODE                                               AS DCCODE
               ,FN_GETDCNAME(DMH_SO.DCCODE)                                 AS DCNAME
               ,COUNT(1)                                                    AS TOTALCNT
        FROM   DM_DOCUMENT_H DMH_SO 
        JOIN   DM_DOCUMENT_D DMD_SO          
          ON   DMH_SO.DCCODE         =  DMD_SO.DCCODE         
         AND   DMH_SO.STORERKEY      =  DMD_SO.STORERKEY               
         AND   DMH_SO.DELIVERYDATE   =  DMD_SO.DELIVERYDATE         
         AND   DMH_SO.DOCNO          =  DMD_SO.DOCNO         
         AND   DMH_SO.DOCTYPE        =  DMD_SO.DOCTYPE         
         AND   DMH_SO.DOCTYPE        = 'WD'      
        JOIN   DM_DOCUMENT_D DMD_PO
          ON   DMD_PO.STORERKEY      = DMD_SO.STORERKEY
         AND   DMD_PO.DCCODE         = DMD_SO.DCCODE
         AND   DMD_PO.ORGANIZE       = DMD_SO.ORGANIZE
         AND   DMD_PO.DELIVERYDATE   = DMD_SO.DELIVERYDATE
         AND   DMD_PO.DOCTYPE        = 'DP'
         AND   DMD_PO.DOCNO          = DMD_SO.POKEY
         AND   DMD_PO.DOCLINE        = DMD_SO.POLINE
         AND   DMD_PO.CHANNEL        = '2'
         AND   DMD_PO.DEL_YN         = 'N'
        JOIN   DM_DOCUMENT_H DMH_PO
          ON   DMH_PO.DCCODE         =  DMD_PO.DCCODE         
         AND   DMH_PO.STORERKEY      =  DMD_PO.STORERKEY               
         AND   DMH_PO.DELIVERYDATE   =  DMD_PO.DELIVERYDATE         
         AND   DMH_PO.DOCNO          =  DMD_PO.DOCNO         
         AND   DMH_PO.DOCTYPE        =  DMD_PO.DOCTYPE   
        JOIN   MS_SKU
          ON    DMD_SO.STORERKEY     = MS_SKU.STORERKEY
         AND    DMD_SO.SKU           = MS_SKU.SKU
        JOIN   MS_CUST           
          ON   MS_CUST.STORERKEY     = DMH_SO.STORERKEY          
         AND   MS_CUST.CUSTKEY       = DMH_SO.TO_CUSTKEY 
         AND   MS_CUST.CUSTTYPE      = DMH_SO.TO_CUSTTYPE
        LEFT OUTER JOIN TM_INPLAN
          ON   DMH_SO.DCCODE         = TM_INPLAN.DCCODE
         AND   DMH_SO.STORERKEY      = TM_INPLAN.STORERKEY
         AND   DMH_SO.DOCTYPE        = TM_INPLAN.DOCTYPE
         AND   DMH_SO.DELIVERYDATE   = TM_INPLAN.SLIPDT
         AND   DMH_SO.DOCNO          = TM_INPLAN.DOCNO
        WHERE  1=1
        AND    DMH_SO.STORERKEY = #{gStorerkey}
        AND    DMH_SO.DCCODE = #{gDccode}
        AND    DMH_SO.ORGANIZE = #{gDccode}
        <if test="slipdt != null and slipdt != ''">                 AND DMH_SO.DELIVERYDATE      =  #{slipdt}           </if>
        <if test="deliverygroup != null and deliverygroup != ''">   AND TM_INPLAN.DELIVERYGROUP  =  #{deliverygroup}    </if>
        <!-- 고객 다중선택 -->
        <if test="toCustkeyMulti != null and toCustkeyMulti != '' ">
            <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                <foreach collection="toCustkeyMulti" item="item">
                    OR DMH_PO.FROM_CUSTKEY IN
                    <foreach collection="item" item="code" open="(" close=")" separator=",">
                        #{code}      
                    </foreach>
                </foreach>
            </trim>                                             
        </if>
        <if test="carnoMulti != null and carnoMulti != ''">    
               AND TM_INPLAN.CARNO IN
               <foreach collection="carnoMulti" item="code" open="(" close=")" separator=",">
                 #{code}
               </foreach>
       </if>        
        AND    DMH_SO.DEL_YN = 'N'
        AND    DMH_SO.DOCTYPE IN ('WD')
        AND    DMH_SO.CHANNEL = '2'
        AND    DMH_SO.IF_SEND_TYPE <![CDATA[<>]]> 'WMSPO'
        AND    DMH_SO.WORKPROCESSCODE IN ('SO')
        AND    NOT ( DMH_SO.DOCTYPE = 'WD' AND DMH_SO.WORKPROCESSCODE = 'PO')      
        GROUP BY DMH_PO.FROM_CUSTKEY, DMH_PO.FROM_CUSTNAME, DMH_SO.DELIVERYDATE, DMH_SO.DCCODE
        ORDER BY DMH_PO.FROM_CUSTKEY
              
    </select>
    
    <select id="getDataCarnoHeaderlist" resultType="WdDeliveryLabelDailyResPrintHeaderDto">       
       SELECT /* [WdDeliveryLabelDailyService.sqlx][getDataCarnoHeaderlist][일배분류서출력-일배 인쇄 목록 조회(차량번호)][공두경][2026.02.19] */
                '일배 분류서'                                                  AS TITLE
               ,TM_INPLAN.CARNO                                             AS CARNO
               ,(SELECT CM_DRIVER.DRIVERNAME
                   FROM CM_CAR
                   LEFT OUTER JOIN CM_DRIVER
                     ON CM_DRIVER.DRIVERID = NVL(CM_CAR.DRIVER1, CM_CAR.DRIVER2)
                  WHERE CM_CAR.CARNO = TM_INPLAN.CARNO
                    AND CM_DRIVER.DEL_YN = 'N')                             AS DRIVERNAME
               ,fn_format_mask(DMH_SO.DELIVERYDATE, '####-##-##')           AS DELIVERYDATE 
               ,DMH_SO.DCCODE                                               AS DCCODE
               ,FN_GETDCNAME(DMH_SO.DCCODE)                                 AS DCNAME
               ,COUNT(1)                                                    AS TOTALCNT
        FROM   DM_DOCUMENT_H DMH_SO 
        JOIN   DM_DOCUMENT_D DMD_SO          
          ON   DMH_SO.DCCODE         =  DMD_SO.DCCODE         
         AND   DMH_SO.STORERKEY      =  DMD_SO.STORERKEY               
         AND   DMH_SO.DELIVERYDATE   =  DMD_SO.DELIVERYDATE         
         AND   DMH_SO.DOCNO          =  DMD_SO.DOCNO         
         AND   DMH_SO.DOCTYPE        =  DMD_SO.DOCTYPE         
         AND   DMH_SO.DOCTYPE        = 'WD'      
        JOIN   DM_DOCUMENT_D DMD_PO
          ON   DMD_PO.STORERKEY      = DMD_SO.STORERKEY
         AND   DMD_PO.DCCODE         = DMD_SO.DCCODE
         AND   DMD_PO.ORGANIZE       = DMD_SO.ORGANIZE
         AND   DMD_PO.DELIVERYDATE   = DMD_SO.DELIVERYDATE
         AND   DMD_PO.DOCTYPE        = 'DP'
         AND   DMD_PO.DOCNO          = DMD_SO.POKEY
         AND   DMD_PO.DOCLINE        = DMD_SO.POLINE
         AND   DMD_PO.CHANNEL        = '2'
         AND   DMD_PO.DEL_YN         = 'N'
        JOIN   DM_DOCUMENT_H DMH_PO
          ON   DMH_PO.DCCODE         =  DMD_PO.DCCODE         
         AND   DMH_PO.STORERKEY      =  DMD_PO.STORERKEY               
         AND   DMH_PO.DELIVERYDATE   =  DMD_PO.DELIVERYDATE         
         AND   DMH_PO.DOCNO          =  DMD_PO.DOCNO         
         AND   DMH_PO.DOCTYPE        =  DMD_PO.DOCTYPE   
        JOIN   MS_SKU
          ON    DMD_SO.STORERKEY     = MS_SKU.STORERKEY
         AND    DMD_SO.SKU           = MS_SKU.SKU
        JOIN   MS_CUST           
          ON   MS_CUST.STORERKEY     = DMH_SO.STORERKEY          
         AND   MS_CUST.CUSTKEY       = DMH_SO.TO_CUSTKEY 
         AND   MS_CUST.CUSTTYPE      = DMH_SO.TO_CUSTTYPE
        LEFT OUTER JOIN TM_INPLAN
          ON   DMH_SO.DCCODE         = TM_INPLAN.DCCODE
         AND   DMH_SO.STORERKEY      = TM_INPLAN.STORERKEY
         AND   DMH_SO.DOCTYPE        = TM_INPLAN.DOCTYPE
         AND   DMH_SO.DELIVERYDATE   = TM_INPLAN.SLIPDT
         AND   DMH_SO.DOCNO          = TM_INPLAN.DOCNO
        WHERE  1=1
        AND    DMH_SO.STORERKEY = #{gStorerkey}
        AND    DMH_SO.DCCODE = #{gDccode}
        AND    DMH_SO.ORGANIZE = #{gDccode}
        <if test="slipdt != null and slipdt != ''">                 AND DMH_SO.DELIVERYDATE      =  #{slipdt}           </if>
        <if test="deliverygroup != null and deliverygroup != ''">   AND TM_INPLAN.DELIVERYGROUP  =  #{deliverygroup}    </if>
        <!-- 고객 다중선택 -->
        <if test="toCustkeyMulti != null and toCustkeyMulti != '' ">
            <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                <foreach collection="toCustkeyMulti" item="item">
                    OR DMH_PO.FROM_CUSTKEY IN
                    <foreach collection="item" item="code" open="(" close=")" separator=",">
                        #{code}      
                    </foreach>
                </foreach>
            </trim>                                             
        </if>
        <if test="carnoMulti != null and carnoMulti != ''">    
               AND TM_INPLAN.CARNO IN
               <foreach collection="carnoMulti" item="code" open="(" close=")" separator=",">
                 #{code}
               </foreach>
       </if>        
        AND    DMH_SO.DEL_YN = 'N'
        AND    DMH_SO.DOCTYPE IN ('WD')
        AND    DMH_SO.CHANNEL = '2'
        AND    DMH_SO.IF_SEND_TYPE <![CDATA[<>]]> 'WMSPO'
        AND    DMH_SO.WORKPROCESSCODE IN ('SO')
        AND    NOT ( DMH_SO.DOCTYPE = 'WD' AND DMH_SO.WORKPROCESSCODE = 'PO')      
        GROUP BY TM_INPLAN.CARNO, DMH_SO.DELIVERYDATE, DMH_SO.DCCODE
        ORDER BY TM_INPLAN.CARNO
              
    </select>  
    
    
    <select id="getDetailList" resultType="WdDeliveryLabelDailyResPrintDetailDto">       
       SELECT /* [WdDeliveryLabelDailyService.sqlx][getDetailList][일배분류서출력-일배 인쇄 상세 조회][공두경][2026.02.19] */
                DMH_SO.DCCODE                                           AS DCCODE
               ,FN_GETDCNAME(DMH_SO.DCCODE)                             AS DCNAME
               ,fn_format_mask(DMH_SO.DELIVERYDATE, '####-##-##')       AS DELIVERYDATE   
               ,FN_CODEDESCR('FW00','ORDERTYPE_WD',DMH_SO.ORDERTYPE)    AS ORDERTYPE
               ,DMH_SO.TO_EMPNAME1                                      AS TO_EMPNAME
               ,TM_INPLAN.CARNO                                         AS CARNO
               ,TM_INPLAN.DELIVERYGROUP                                 AS DELIVERYGROUP
               ,(SELECT CM_DRIVER.DRIVERNAME
                  FROM CM_CAR
                  LEFT OUTER JOIN CM_DRIVER
                    ON CM_DRIVER.DRIVERID = NVL(CM_CAR.DRIVER1, CM_CAR.DRIVER2)
                 WHERE CM_CAR.CARNO = TM_INPLAN.CARNO
                   AND CM_DRIVER.DEL_YN = 'N')                          AS DRIVERNAME
               ,FN_CODEDESCR('FW00','SALEGROUP',MS_CUST.SALEGROUP)      AS SALEGROUP
               ,(SELECT USER_NM 
                   FROM FRAMEONE_USER 
                  WHERE EMP_NO = DMH_SO.TO_EMPNAME1)                    AS TO_EMPNAME
               ,DMH_PO.FROM_CUSTKEY                                     AS FROM_CUSTKEY
               ,DMH_PO.FROM_CUSTNAME                                    AS FROM_CUSTNAME
               ,DMH_SO.TO_CUSTKEY                                       AS TO_CUSTKEY
               ,DMH_SO.TO_CUSTNAME                                      AS TO_CUSTNAME
               ,DMD_SO.DOCNO                                            AS DOCNO
               ,DMD_SO.DOCLINE                                          AS DOCLINE
               ,DMD_PO.POKEY                                            AS POKEY
               ,DMD_PO.POLINE                                           AS POLINE
               ,DMD_SO.SKU                                              AS SKU
               ,MS_SKU.DESCRIPTION                                      AS SKUNAME
               ,FN_CODEDESCR('FW00','STORAGETYPE',MS_SKU.STORAGETYPE)   AS STORAGETYPENM
               ,DMD_SO.STORERUOM                                        AS UOM
               ,DMD_SO.STORERORDERQTY                                   AS ORDERQTY
               ,TO_CHAR(DMH_SO.ADDDATE, 'YYYY-MM-DD HH24:MI:SS')        AS ADDDATE
               ,DMH_SO.MEMO1                                            AS MEMO1
        FROM   DM_DOCUMENT_H DMH_SO 
        JOIN   DM_DOCUMENT_D DMD_SO          
          ON   DMH_SO.DCCODE         =  DMD_SO.DCCODE         
         AND   DMH_SO.STORERKEY      =  DMD_SO.STORERKEY               
         AND   DMH_SO.DELIVERYDATE   =  DMD_SO.DELIVERYDATE         
         AND   DMH_SO.DOCNO          =  DMD_SO.DOCNO         
         AND   DMH_SO.DOCTYPE        =  DMD_SO.DOCTYPE         
         AND   DMH_SO.DOCTYPE        = 'WD'      
        JOIN   DM_DOCUMENT_D DMD_PO
          ON   DMD_PO.STORERKEY      = DMD_SO.STORERKEY
         AND   DMD_PO.DCCODE         = DMD_SO.DCCODE
         AND   DMD_PO.ORGANIZE       = DMD_SO.ORGANIZE
         AND   DMD_PO.DELIVERYDATE   = DMD_SO.DELIVERYDATE
         AND   DMD_PO.DOCTYPE        = 'DP'
         AND   DMD_PO.DOCNO          = DMD_SO.POKEY
         AND   DMD_PO.DOCLINE        = DMD_SO.POLINE
         AND   DMD_PO.CHANNEL        = '2'
         AND   DMD_PO.DEL_YN         = 'N'
        JOIN   DM_DOCUMENT_H DMH_PO
          ON   DMH_PO.DCCODE         =  DMD_PO.DCCODE         
         AND   DMH_PO.STORERKEY      =  DMD_PO.STORERKEY               
         AND   DMH_PO.DELIVERYDATE   =  DMD_PO.DELIVERYDATE         
         AND   DMH_PO.DOCNO          =  DMD_PO.DOCNO         
         AND   DMH_PO.DOCTYPE        =  DMD_PO.DOCTYPE   
        JOIN   MS_SKU
          ON    DMD_SO.STORERKEY     = MS_SKU.STORERKEY
         AND    DMD_SO.SKU           = MS_SKU.SKU
        JOIN   MS_CUST           
          ON   MS_CUST.STORERKEY     = DMH_SO.STORERKEY          
         AND   MS_CUST.CUSTKEY       = DMH_SO.TO_CUSTKEY 
         AND   MS_CUST.CUSTTYPE      = DMH_SO.TO_CUSTTYPE
        LEFT OUTER JOIN TM_INPLAN
          ON   DMH_SO.DCCODE         = TM_INPLAN.DCCODE
         AND   DMH_SO.STORERKEY      = TM_INPLAN.STORERKEY
         AND   DMH_SO.DOCTYPE        = TM_INPLAN.DOCTYPE
         AND   DMH_SO.DELIVERYDATE   = TM_INPLAN.SLIPDT
         AND   DMH_SO.DOCNO          = TM_INPLAN.DOCNO
        WHERE  1=1
        AND    DMH_SO.STORERKEY = #{gStorerkey}
        AND    DMH_SO.DCCODE = #{gDccode}
        AND    DMH_SO.ORGANIZE = #{gDccode}
        <if test="slipdt != null and slipdt != ''">                 AND DMH_SO.DELIVERYDATE      =  #{slipdt}           </if>
        <if test="deliverygroup != null and deliverygroup != ''">   AND TM_INPLAN.DELIVERYGROUP  =  #{deliverygroup}    </if>
        <!-- 고객 다중선택 -->
        <if test="toCustkeyMulti != null and toCustkeyMulti != '' ">
            <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                <foreach collection="toCustkeyMulti" item="item">
                    OR DMH_PO.FROM_CUSTKEY IN
                    <foreach collection="item" item="code" open="(" close=")" separator=",">
                        #{code}      
                    </foreach>
                </foreach>
            </trim>                                             
        </if>
        <if test="carnoMulti != null and carnoMulti != ''">    
               AND TM_INPLAN.CARNO IN
               <foreach collection="carnoMulti" item="code" open="(" close=")" separator=",">
                 #{code}
               </foreach>
       </if>        
        AND    DMH_SO.DEL_YN = 'N'
        AND    DMH_SO.DOCTYPE IN ('WD')
        AND    DMH_SO.CHANNEL = '2'
        AND    DMH_SO.IF_SEND_TYPE <![CDATA[<>]]> 'WMSPO'
        AND    DMH_SO.WORKPROCESSCODE IN ('SO')
        AND    NOT ( DMH_SO.DOCTYPE = 'WD' AND DMH_SO.WORKPROCESSCODE = 'PO')
        <choose>
            <when test="orderbyPick != null and orderbyPick != ''">
                <if test="orderbyPick == 'VENDOR_SKU_CUST_POP'">
                    ORDER BY DMH_PO.FROM_CUSTKEY, DMD_SO.SKU, DMH_SO.TO_CUSTKEY, TM_INPLAN.DELIVERYGROUP
                </if>
                <if test="orderbyPick == 'VENDOR_CUST_SKU_POP'">
                    ORDER BY DMH_PO.FROM_CUSTKEY, DMH_SO.TO_CUSTKEY, DMD_SO.SKU, TM_INPLAN.DELIVERYGROUP
                </if>
                <if test="orderbyPick == 'VENDOR_SKU_CUST_DRIVER'">
                    ORDER BY DMH_PO.FROM_CUSTKEY, DMD_SO.SKU, DMH_SO.TO_CUSTKEY, DRIVERNAME
                </if>
                <if test="orderbyPick == 'VENDOR_CUST_SKU_DRIVER'">
                    ORDER BY DMH_PO.FROM_CUSTKEY, DMH_SO.TO_CUSTKEY, DMD_SO.SKU, DRIVERNAME
                </if>
                <if test="orderbyPick == 'POP_DRIVER_SKU_CUST'">
                    ORDER BY TM_INPLAN.DELIVERYGROUP, DRIVERNAME, DMD_SO.SKU, DMH_SO.TO_CUSTKEY
                </if>
                <if test="orderbyPick == 'POP_DRIVER_CUST_SKU'">
                    ORDER BY TM_INPLAN.DELIVERYGROUP, DRIVERNAME, DMH_SO.TO_CUSTKEY, DMD_SO.SKU
                </if>
            </when>
        </choose>
        
    </select>
        
    <select id="getDataSTOPopHeaderlist" resultType="WdDeliveryLabelDailyResPrintHeaderDto">       
       SELECT /* [WdDeliveryLabelDailyService.sqlx][getDataSTOPopHeaderlist][일배분류서출력-광역일배 인쇄 목록 조회(POP)][공두경][2026.02.19] */
               '광역일배 분류서'                              AS TITLE  
              ,DELIVERYGROUP                              AS DELIVERYGROUP 
              ,fn_format_mask(DELIVERYDATE, '####-##-##') AS DELIVERYDATE 
              ,DCCODE                                     AS DCCODE
              ,FN_GETDCNAME(DCCODE)                       AS DCNAME
              ,COUNT(1)                                   AS TOTALCNT
        FROM (
                SELECT MAX(DM_DOCUMENT_D.DCCODE)          AS DCCODE
                      ,MAX(TM_INPLAN.DELIVERYGROUP)       AS DELIVERYGROUP         
                      ,MAX(DM_DOCUMENT_D.DELIVERYDATE)    AS DELIVERYDATE
                FROM   DM_DOCUMENT_D
                JOIN   DM_DOCUMENT_H
                ON     DM_DOCUMENT_H.DCCODE            = DM_DOCUMENT_D.DCCODE
                AND    DM_DOCUMENT_H.STORERKEY         = DM_DOCUMENT_D.STORERKEY
                AND    DM_DOCUMENT_H.ORGANIZE          = DM_DOCUMENT_D.ORGANIZE
                AND    DM_DOCUMENT_H.DOCTYPE           = DM_DOCUMENT_D.DOCTYPE
                AND    DM_DOCUMENT_H.DELIVERYDATE      = DM_DOCUMENT_D.DELIVERYDATE
                AND    DM_DOCUMENT_H.DOCNO             = DM_DOCUMENT_D.DOCNO
                AND    DM_DOCUMENT_H.DEL_YN            = 'N'
                JOIN   WD_INPLAN
                ON     WD_INPLAN.DCCODE                = DM_DOCUMENT_D.DCCODE
                AND    WD_INPLAN.STORERKEY             = DM_DOCUMENT_D.STORERKEY
                AND    WD_INPLAN.ORGANIZE              = DM_DOCUMENT_D.ORGANIZE
                AND    WD_INPLAN.AREA                  = DM_DOCUMENT_D.AREA
                AND    WD_INPLAN.DOCTYPE               = DM_DOCUMENT_D.DOCTYPE
                AND    WD_INPLAN.SLIPDT                 = DM_DOCUMENT_D.DELIVERYDATE
                AND    WD_INPLAN.DOCNO                 = DM_DOCUMENT_D.DOCNO
                AND    WD_INPLAN.DOCLINE               = DM_DOCUMENT_D.DOCLINE
                AND    WD_INPLAN.DEL_YN                = 'N'
                JOIN   DM_DOCUMENT_D DM_DOCUMENT_D_PO
                ON     DM_DOCUMENT_D_PO.DCCODE         = DM_DOCUMENT_D.DCCODE
                AND    DM_DOCUMENT_D_PO.STORERKEY      = DM_DOCUMENT_D.STORERKEY
                AND    DM_DOCUMENT_D_PO.ORGANIZE       = DM_DOCUMENT_D.ORGANIZE
                AND    DM_DOCUMENT_D_PO.AREA           = DM_DOCUMENT_D.AREA
                AND    DM_DOCUMENT_D_PO.DOCTYPE        = 'DP'
                AND    DM_DOCUMENT_D_PO.DOCNO          = DM_DOCUMENT_D.POKEY
                AND    DM_DOCUMENT_D_PO.DOCLINE        = DM_DOCUMENT_D.POLINE
                AND    DM_DOCUMENT_D_PO.DEL_YN         = 'N'
                JOIN   DM_DOCUMENT_H DM_DOCUMENT_H_PO
                ON     DM_DOCUMENT_H_PO.DCCODE         = DM_DOCUMENT_D_PO.DCCODE
                AND    DM_DOCUMENT_H_PO.STORERKEY      = DM_DOCUMENT_D_PO.STORERKEY
                AND    DM_DOCUMENT_H_PO.ORGANIZE       = DM_DOCUMENT_D_PO.ORGANIZE
                AND    DM_DOCUMENT_H_PO.DOCTYPE        = DM_DOCUMENT_D_PO.DOCTYPE
                AND    DM_DOCUMENT_H_PO.DELIVERYDATE   = DM_DOCUMENT_D_PO.DELIVERYDATE
                AND    DM_DOCUMENT_H_PO.DOCNO          = DM_DOCUMENT_D_PO.DOCNO
                AND    DM_DOCUMENT_H_PO.DEL_YN         = 'N'
                JOIN   MS_SKU
                ON     MS_SKU.STORERKEY                = DM_DOCUMENT_D.STORERKEY
                AND    MS_SKU.SKU                      = DM_DOCUMENT_D.SKU
                AND    MS_SKU.DEL_YN                   = 'N'
                LEFT JOIN TM_INPLAN
                ON     TM_INPLAN.DCCODE                = WD_INPLAN.DCCODE
                AND    TM_INPLAN.STORERKEY             = WD_INPLAN.STORERKEY
                AND    TM_INPLAN.DOCTYPE               = WD_INPLAN.DOCTYPE
                AND    TM_INPLAN.SLIPDT                = WD_INPLAN.SLIPDT
                AND    TM_INPLAN.SLIPNO                = WD_INPLAN.SLIPNO                
                WHERE  1=1
                AND    DM_DOCUMENT_D.STORERKEY         = #{gStorerkey}  
                AND    DM_DOCUMENT_D.DOCTYPE           = 'WD'      
                AND    DM_DOCUMENT_D.DEL_YN            = 'N'
                AND    DM_DOCUMENT_D.CHANNEL           = '3'
                <if test="slipdt != null and slipdt != ''">                 AND DM_DOCUMENT_D.DELIVERYDATE  =  #{slipdt}           </if>
                <if test="deliverygroup != null and deliverygroup != ''">   AND TM_INPLAN.DELIVERYGROUP     =  #{deliverygroup}    </if>
                <if test="fromDccode != null and fromDccode != ''">         AND DM_DOCUMENT_D.ROUTE         =  #{fromDccode}       </if>
                <if test="toDccode != null and toDccode != ''">             AND DM_DOCUMENT_D.DCCODE        =  #{toDccode}         </if>
                <!-- 고객 다중선택 -->
                <if test="toCustkeyMulti != null and toCustkeyMulti != '' ">
                    <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                        <foreach collection="toCustkeyMulti" item="item">
                            OR DM_DOCUMENT_H_PO.FROM_CUSTKEY IN
                            <foreach collection="item" item="code" open="(" close=")" separator=",">
                                #{code}      
                            </foreach>
                        </foreach>
                    </trim>                                             
                </if>
                <if test="carnoMulti != null and carnoMulti != ''">    
                       AND TM_INPLAN.CARNO IN
                       <foreach collection="carnoMulti" item="code" open="(" close=")" separator=",">
                         #{code}
                       </foreach>
               </if>        
                GROUP BY
                               DM_DOCUMENT_D.DCCODE
                              ,DM_DOCUMENT_D.DOCDT
                              ,DM_DOCUMENT_D.DOCNO
                              ,DM_DOCUMENT_D.DOCLINE
            )
            GROUP BY
                   DELIVERYGROUP
                  ,DELIVERYDATE           
                  ,DCCODE        
            ORDER BY
                   DELIVERYGROUP
              
    </select>  
        
    <select id="getDataSTOCustHeaderlist" resultType="WdDeliveryLabelDailyResPrintHeaderDto">       
       SELECT /* [WdDeliveryLabelDailyService.sqlx][getDataSTOCustHeaderlist][일배분류서출력-광역일배 인쇄 목록 조회(거래처)][공두경][2026.02.19] */
               '광역일배 분류서'                              AS TITLE  
              ,FROM_CUSTKEY                               AS FROM_CUSTKEY
              ,FROM_CUSTNAME                              AS FROM_CUSTNAME 
              ,fn_format_mask(DELIVERYDATE, '####-##-##') AS DELIVERYDATE 
              ,DCCODE                                     AS DCCODE
              ,FN_GETDCNAME(DCCODE)                       AS DCNAME
              ,COUNT(1)                                   AS TOTALCNT
        FROM (
                SELECT MAX(DM_DOCUMENT_D.DCCODE)          AS DCCODE
                      ,MAX(DM_DOCUMENT_H_PO.FROM_CUSTKEY) AS FROM_CUSTKEY          
                      ,MAX(DM_DOCUMENT_H_PO.FROM_CUSTNAME)AS FROM_CUSTNAME          
                      ,MAX(DM_DOCUMENT_D.DELIVERYDATE)    AS DELIVERYDATE
                FROM   DM_DOCUMENT_D
                JOIN   DM_DOCUMENT_H
                ON     DM_DOCUMENT_H.DCCODE            = DM_DOCUMENT_D.DCCODE
                AND    DM_DOCUMENT_H.STORERKEY         = DM_DOCUMENT_D.STORERKEY
                AND    DM_DOCUMENT_H.ORGANIZE          = DM_DOCUMENT_D.ORGANIZE
                AND    DM_DOCUMENT_H.DOCTYPE           = DM_DOCUMENT_D.DOCTYPE
                AND    DM_DOCUMENT_H.DELIVERYDATE      = DM_DOCUMENT_D.DELIVERYDATE
                AND    DM_DOCUMENT_H.DOCNO             = DM_DOCUMENT_D.DOCNO
                AND    DM_DOCUMENT_H.DEL_YN            = 'N'
                JOIN   WD_INPLAN
                ON     WD_INPLAN.DCCODE                = DM_DOCUMENT_D.DCCODE
                AND    WD_INPLAN.STORERKEY             = DM_DOCUMENT_D.STORERKEY
                AND    WD_INPLAN.ORGANIZE              = DM_DOCUMENT_D.ORGANIZE
                AND    WD_INPLAN.AREA                  = DM_DOCUMENT_D.AREA
                AND    WD_INPLAN.DOCTYPE               = DM_DOCUMENT_D.DOCTYPE
                AND    WD_INPLAN.SLIPDT                = DM_DOCUMENT_D.DELIVERYDATE
                AND    WD_INPLAN.DOCNO                 = DM_DOCUMENT_D.DOCNO
                AND    WD_INPLAN.DOCLINE               = DM_DOCUMENT_D.DOCLINE
                AND    WD_INPLAN.DEL_YN                = 'N'
                JOIN   DM_DOCUMENT_D DM_DOCUMENT_D_PO
                ON     DM_DOCUMENT_D_PO.DCCODE         = DM_DOCUMENT_D.DCCODE
                AND    DM_DOCUMENT_D_PO.STORERKEY      = DM_DOCUMENT_D.STORERKEY
                AND    DM_DOCUMENT_D_PO.ORGANIZE       = DM_DOCUMENT_D.ORGANIZE
                AND    DM_DOCUMENT_D_PO.AREA           = DM_DOCUMENT_D.AREA
                AND    DM_DOCUMENT_D_PO.DOCTYPE        = 'DP'
                AND    DM_DOCUMENT_D_PO.DOCNO          = DM_DOCUMENT_D.POKEY
                AND    DM_DOCUMENT_D_PO.DOCLINE        = DM_DOCUMENT_D.POLINE
                AND    DM_DOCUMENT_D_PO.DEL_YN         = 'N'
                JOIN   DM_DOCUMENT_H DM_DOCUMENT_H_PO
                ON     DM_DOCUMENT_H_PO.DCCODE         = DM_DOCUMENT_D_PO.DCCODE
                AND    DM_DOCUMENT_H_PO.STORERKEY      = DM_DOCUMENT_D_PO.STORERKEY
                AND    DM_DOCUMENT_H_PO.ORGANIZE       = DM_DOCUMENT_D_PO.ORGANIZE
                AND    DM_DOCUMENT_H_PO.DOCTYPE        = DM_DOCUMENT_D_PO.DOCTYPE
                AND    DM_DOCUMENT_H_PO.DELIVERYDATE   = DM_DOCUMENT_D_PO.DELIVERYDATE
                AND    DM_DOCUMENT_H_PO.DOCNO          = DM_DOCUMENT_D_PO.DOCNO
                AND    DM_DOCUMENT_H_PO.DEL_YN         = 'N'
                JOIN   MS_SKU
                ON     MS_SKU.STORERKEY                = DM_DOCUMENT_D.STORERKEY
                AND    MS_SKU.SKU                      = DM_DOCUMENT_D.SKU
                AND    MS_SKU.DEL_YN                   = 'N'
                LEFT JOIN TM_INPLAN
                ON     TM_INPLAN.DCCODE                = WD_INPLAN.DCCODE
                AND    TM_INPLAN.STORERKEY             = WD_INPLAN.STORERKEY
                AND    TM_INPLAN.DOCTYPE               = WD_INPLAN.DOCTYPE
                AND    TM_INPLAN.SLIPDT                = WD_INPLAN.SLIPDT
                AND    TM_INPLAN.SLIPNO                = WD_INPLAN.SLIPNO      
                WHERE  1=1
                AND    DM_DOCUMENT_D.STORERKEY         = #{gStorerkey}  
                AND    DM_DOCUMENT_D.DOCTYPE           = 'WD'      
                AND    DM_DOCUMENT_D.DEL_YN            = 'N'
                AND    DM_DOCUMENT_D.CHANNEL           = '3'
                <if test="slipdt != null and slipdt != ''">                 AND DM_DOCUMENT_D.DELIVERYDATE  =  #{slipdt}           </if>
                <if test="deliverygroup != null and deliverygroup != ''">   AND TM_INPLAN.DELIVERYGROUP     =  #{deliverygroup}    </if>
                <if test="fromDccode != null and fromDccode != ''">         AND DM_DOCUMENT_D.ROUTE         =  #{fromDccode}       </if>
                <if test="toDccode != null and toDccode != ''">             AND DM_DOCUMENT_D.DCCODE        =  #{toDccode}         </if>
                <!-- 고객 다중선택 -->
                <if test="toCustkeyMulti != null and toCustkeyMulti != '' ">
                    <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                        <foreach collection="toCustkeyMulti" item="item">
                            OR DM_DOCUMENT_H_PO.FROM_CUSTKEY IN
                            <foreach collection="item" item="code" open="(" close=")" separator=",">
                                #{code}      
                            </foreach>
                        </foreach>
                    </trim>                                             
                </if>
                <if test="carnoMulti != null and carnoMulti != ''">    
                       AND TM_INPLAN.CARNO IN
                       <foreach collection="carnoMulti" item="code" open="(" close=")" separator=",">
                         #{code}
                       </foreach>
               </if>        
                GROUP BY
                       DM_DOCUMENT_D.DCCODE
                      ,DM_DOCUMENT_D.DOCDT
                      ,DM_DOCUMENT_D.DOCNO
                      ,DM_DOCUMENT_D.DOCLINE
               )
        GROUP BY
               FROM_CUSTKEY
              ,FROM_CUSTNAME
              ,DELIVERYDATE           
              ,DCCODE        
        ORDER BY
               FROM_CUSTKEY
              
    </select>  
        
    <select id="getDataSTOCarnoHeaderlist" resultType="WdDeliveryLabelDailyResPrintHeaderDto">       
       SELECT /* [WdDeliveryLabelDailyService.sqlx][getDataSTOCarnoHeaderlist][일배분류서출력-광역일배 인쇄 목록 조회(차량번호)][공두경][2026.02.19] */
               '광역일배 분류서'                              AS TITLE  
              ,A.CARNO                                    AS CARNO
              ,(SELECT CM_DRIVER.DRIVERNAME
                  FROM CM_CAR
                  LEFT OUTER JOIN CM_DRIVER
                    ON CM_DRIVER.DRIVERID = NVL(CM_CAR.DRIVER1, CM_CAR.DRIVER2)
                 WHERE CM_CAR.CARNO = A.CARNO
                   AND CM_DRIVER.DEL_YN = 'N')            AS DRIVERNAME
              ,fn_format_mask(DELIVERYDATE, '####-##-##') AS DELIVERYDATE 
              ,DCCODE                                     AS DCCODE
              ,FN_GETDCNAME(DCCODE)                       AS DCNAME
              ,COUNT(1)                                   AS TOTALCNT
        FROM (
                SELECT MAX(DM_DOCUMENT_D.DCCODE)          AS DCCODE
                      ,MAX(TM_INPLAN.CARNO)               AS CARNO         
                      ,MAX(DM_DOCUMENT_D.DELIVERYDATE)    AS DELIVERYDATE
                FROM   DM_DOCUMENT_D
                JOIN   DM_DOCUMENT_H
                ON     DM_DOCUMENT_H.DCCODE            = DM_DOCUMENT_D.DCCODE
                AND    DM_DOCUMENT_H.STORERKEY         = DM_DOCUMENT_D.STORERKEY
                AND    DM_DOCUMENT_H.ORGANIZE          = DM_DOCUMENT_D.ORGANIZE
                AND    DM_DOCUMENT_H.DOCTYPE           = DM_DOCUMENT_D.DOCTYPE
                AND    DM_DOCUMENT_H.DELIVERYDATE      = DM_DOCUMENT_D.DELIVERYDATE
                AND    DM_DOCUMENT_H.DOCNO             = DM_DOCUMENT_D.DOCNO
                AND    DM_DOCUMENT_H.DEL_YN            = 'N'
                JOIN   WD_INPLAN
                ON     WD_INPLAN.DCCODE                = DM_DOCUMENT_D.DCCODE
                AND    WD_INPLAN.STORERKEY             = DM_DOCUMENT_D.STORERKEY
                AND    WD_INPLAN.ORGANIZE              = DM_DOCUMENT_D.ORGANIZE
                AND    WD_INPLAN.AREA                  = DM_DOCUMENT_D.AREA
                AND    WD_INPLAN.DOCTYPE               = DM_DOCUMENT_D.DOCTYPE
                AND    WD_INPLAN.SLIPDT                 = DM_DOCUMENT_D.DELIVERYDATE
                AND    WD_INPLAN.DOCNO                 = DM_DOCUMENT_D.DOCNO
                AND    WD_INPLAN.DOCLINE               = DM_DOCUMENT_D.DOCLINE
                AND    WD_INPLAN.DEL_YN                = 'N'
                JOIN   DM_DOCUMENT_D DM_DOCUMENT_D_PO
                ON     DM_DOCUMENT_D_PO.DCCODE         = DM_DOCUMENT_D.DCCODE
                AND    DM_DOCUMENT_D_PO.STORERKEY      = DM_DOCUMENT_D.STORERKEY
                AND    DM_DOCUMENT_D_PO.ORGANIZE       = DM_DOCUMENT_D.ORGANIZE
                AND    DM_DOCUMENT_D_PO.AREA           = DM_DOCUMENT_D.AREA
                AND    DM_DOCUMENT_D_PO.DOCTYPE        = 'DP'
                AND    DM_DOCUMENT_D_PO.DOCNO          = DM_DOCUMENT_D.POKEY
                AND    DM_DOCUMENT_D_PO.DOCLINE        = DM_DOCUMENT_D.POLINE
                AND    DM_DOCUMENT_D_PO.DEL_YN         = 'N'
                JOIN   DM_DOCUMENT_H DM_DOCUMENT_H_PO
                ON     DM_DOCUMENT_H_PO.DCCODE         = DM_DOCUMENT_D_PO.DCCODE
                AND    DM_DOCUMENT_H_PO.STORERKEY      = DM_DOCUMENT_D_PO.STORERKEY
                AND    DM_DOCUMENT_H_PO.ORGANIZE       = DM_DOCUMENT_D_PO.ORGANIZE
                AND    DM_DOCUMENT_H_PO.DOCTYPE        = DM_DOCUMENT_D_PO.DOCTYPE
                AND    DM_DOCUMENT_H_PO.DELIVERYDATE   = DM_DOCUMENT_D_PO.DELIVERYDATE
                AND    DM_DOCUMENT_H_PO.DOCNO          = DM_DOCUMENT_D_PO.DOCNO
                AND    DM_DOCUMENT_H_PO.DEL_YN         = 'N'
                JOIN   MS_SKU
                ON     MS_SKU.STORERKEY                = DM_DOCUMENT_D.STORERKEY
                AND    MS_SKU.SKU                      = DM_DOCUMENT_D.SKU
                AND    MS_SKU.DEL_YN                   = 'N'
                LEFT JOIN TM_INPLAN
                ON     TM_INPLAN.DCCODE                = WD_INPLAN.DCCODE
                AND    TM_INPLAN.STORERKEY             = WD_INPLAN.STORERKEY
                AND    TM_INPLAN.DOCTYPE               = WD_INPLAN.DOCTYPE
                AND    TM_INPLAN.SLIPDT                = WD_INPLAN.SLIPDT
                AND    TM_INPLAN.SLIPNO                = WD_INPLAN.SLIPNO      
                WHERE  1=1
                AND    DM_DOCUMENT_D.STORERKEY         = #{gStorerkey}  
                AND    DM_DOCUMENT_D.DOCTYPE           = 'WD'      
                AND    DM_DOCUMENT_D.DEL_YN            = 'N'
                AND    DM_DOCUMENT_D.CHANNEL           = '3'
                <if test="slipdt != null and slipdt != ''">                 AND DM_DOCUMENT_D.DELIVERYDATE  =  #{slipdt}           </if>
                <if test="deliverygroup != null and deliverygroup != ''">   AND TM_INPLAN.DELIVERYGROUP     =  #{deliverygroup}    </if>
                <if test="fromDccode != null and fromDccode != ''">         AND DM_DOCUMENT_D.ROUTE         =  #{fromDccode}       </if>
                <if test="toDccode != null and toDccode != ''">             AND DM_DOCUMENT_D.DCCODE        =  #{toDccode}         </if>
                <!-- 고객 다중선택 -->
                <if test="toCustkeyMulti != null and toCustkeyMulti != '' ">
                    <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                        <foreach collection="toCustkeyMulti" item="item">
                            OR DM_DOCUMENT_H_PO.FROM_CUSTKEY IN
                            <foreach collection="item" item="code" open="(" close=")" separator=",">
                                #{code}      
                            </foreach>
                        </foreach>
                    </trim>                                             
                </if>
                <if test="carnoMulti != null and carnoMulti != ''">    
                       AND TM_INPLAN.CARNO IN
                       <foreach collection="carnoMulti" item="code" open="(" close=")" separator=",">
                         #{code}
                       </foreach>
               </if>        
                GROUP BY
                       DM_DOCUMENT_D.DCCODE
                      ,DM_DOCUMENT_D.DOCDT
                      ,DM_DOCUMENT_D.DOCNO
                      ,DM_DOCUMENT_D.DOCLINE
               ) A
        GROUP BY
               A.CARNO
              ,DELIVERYDATE           
              ,DCCODE        
        ORDER BY
               A.CARNO
              
    </select>  
    
    
    <select id="getDetailSTOList" resultType="WdDeliveryLabelDailyResPrintDetailDto">       
       SELECT /* [WdDeliveryLabelDailyService.sqlx][getDetailSTOList][일배분류서출력-광역일배 인쇄 상세 조회][공두경][2026.02.19] */
                A.CARNO                                             AS CARNO
               ,A.DCCODE                                            AS DCCODE
               ,FN_GETDCNAME(A.DCCODE)                              AS DCNAME
               ,A.DELIVERYGROUP                                     AS DELIVERYGROUP
               ,(SELECT CM_DRIVER.DRIVERNAME
                   FROM CM_CAR
                 LEFT JOIN CM_DRIVER
                 ON        CM_DRIVER.DRIVERID = NVL(CM_CAR.DRIVER1, CM_CAR.DRIVER2)
                  WHERE CM_CAR.CARNO = A.CARNO
                    AND CM_DRIVER.DEL_YN = 'N')                     AS DRIVERNAME
               ,A.FROM_CUSTKEY                                      AS FROM_CUSTKEY 
               ,A.FROM_CUSTNAME                                     AS FROM_CUSTNAME
               ,A.ORDERQTY                                          AS ORDERQTY
               ,A.SKU                                               AS SKU
               ,A.SKUNAME                                           AS SKUNAME
               ,A.TO_CUSTKEY                                        AS TO_CUSTKEY
               ,A.TO_CUSTNAME                                       AS TO_CUSTNAME
               ,A.UOM                                               AS UOM
               ,fn_format_mask(A.DELIVERYDATE, '####-##-##')        AS DELIVERYDATE
               ,FROM_DCCODE||'('||FN_GETDCNAME(A.FROM_DCCODE)||')'  AS FROM_DCNAME 
         FROM (     
                SELECT 
                        MAX(DM_DOCUMENT_H_PO.FROM_CUSTKEY)                 AS FROM_CUSTKEY
                       ,MAX(DM_DOCUMENT_H_PO.FROM_CUSTNAME)                AS FROM_CUSTNAME
                       ,MAX(DM_DOCUMENT_H.TO_CUSTKEY)                      AS TO_CUSTKEY
                       ,MAX(DM_DOCUMENT_H.TO_CUSTNAME)                     AS TO_CUSTNAME
                       ,MAX(DM_DOCUMENT_D.SKU)                             AS SKU
                       ,MAX(MS_SKU.DESCRIPTION)                            AS SKUNAME
                       ,MAX(DM_DOCUMENT_D.STOREROPENQTY)                   AS ORDERQTY
                       ,MAX(DM_DOCUMENT_D.STORERUOM)                       AS UOM
                       ,MAX(TM_INPLAN.CARNO)                               AS CARNO
                       ,MAX(TM_INPLAN.DELIVERYGROUP)                       AS DELIVERYGROUP
                       ,MAX(DM_DOCUMENT_D.DCCODE)                          AS DCCODE
                       ,MAX(DM_DOCUMENT_D.DELIVERYDATE)                    AS DELIVERYDATE
                       ,MAX(WD_DC.DCCODE)                                  AS FROM_DCCODE               
                 FROM   DM_DOCUMENT_D
                 JOIN   DM_DOCUMENT_H
                 ON     DM_DOCUMENT_H.DCCODE            = DM_DOCUMENT_D.DCCODE
                 AND    DM_DOCUMENT_H.STORERKEY         = DM_DOCUMENT_D.STORERKEY
                 AND    DM_DOCUMENT_H.ORGANIZE          = DM_DOCUMENT_D.ORGANIZE
                 AND    DM_DOCUMENT_H.DOCTYPE           = DM_DOCUMENT_D.DOCTYPE
                 AND    DM_DOCUMENT_H.DELIVERYDATE      = DM_DOCUMENT_D.DELIVERYDATE
                 AND    DM_DOCUMENT_H.DOCNO             = DM_DOCUMENT_D.DOCNO
                 AND    DM_DOCUMENT_H.DEL_YN            = 'N'
                 JOIN   WD_INPLAN
                 ON     WD_INPLAN.DCCODE                = DM_DOCUMENT_D.DCCODE
                 AND    WD_INPLAN.STORERKEY             = DM_DOCUMENT_D.STORERKEY
                 AND    WD_INPLAN.ORGANIZE              = DM_DOCUMENT_D.ORGANIZE
                 AND    WD_INPLAN.AREA                  = DM_DOCUMENT_D.AREA
                 AND    WD_INPLAN.DOCTYPE               = DM_DOCUMENT_D.DOCTYPE
                 AND    WD_INPLAN.SLIPDT                 = DM_DOCUMENT_D.DELIVERYDATE
                 AND    WD_INPLAN.DOCNO                 = DM_DOCUMENT_D.DOCNO
                 AND    WD_INPLAN.DOCLINE               = DM_DOCUMENT_D.DOCLINE
                 AND    WD_INPLAN.DEL_YN                = 'N'
                 JOIN   DM_DOCUMENT_D DM_DOCUMENT_D_PO
                 ON     DM_DOCUMENT_D_PO.DCCODE         = DM_DOCUMENT_D.DCCODE
                 AND    DM_DOCUMENT_D_PO.STORERKEY      = DM_DOCUMENT_D.STORERKEY
                 AND    DM_DOCUMENT_D_PO.ORGANIZE       = DM_DOCUMENT_D.ORGANIZE
                 AND    DM_DOCUMENT_D_PO.AREA           = DM_DOCUMENT_D.AREA
                 AND    DM_DOCUMENT_D_PO.DOCTYPE        = 'DP'
                 AND    DM_DOCUMENT_D_PO.DOCNO          = DM_DOCUMENT_D.POKEY
                 AND    DM_DOCUMENT_D_PO.DOCLINE        = DM_DOCUMENT_D.POLINE
                 AND    DM_DOCUMENT_D_PO.DEL_YN         = 'N'
                 JOIN   DM_DOCUMENT_H DM_DOCUMENT_H_PO
                 ON     DM_DOCUMENT_H_PO.DCCODE         = DM_DOCUMENT_D_PO.DCCODE
                 AND    DM_DOCUMENT_H_PO.STORERKEY      = DM_DOCUMENT_D_PO.STORERKEY
                 AND    DM_DOCUMENT_H_PO.ORGANIZE       = DM_DOCUMENT_D_PO.ORGANIZE
                 AND    DM_DOCUMENT_H_PO.DOCTYPE        = DM_DOCUMENT_D_PO.DOCTYPE
                 AND    DM_DOCUMENT_H_PO.DELIVERYDATE   = DM_DOCUMENT_D_PO.DELIVERYDATE
                 AND    DM_DOCUMENT_H_PO.DOCNO          = DM_DOCUMENT_D_PO.DOCNO
                 AND    DM_DOCUMENT_H_PO.DEL_YN         = 'N'         
                 JOIN   MS_SKU
                 ON     MS_SKU.STORERKEY                = DM_DOCUMENT_D.STORERKEY
                 AND    MS_SKU.SKU                      = DM_DOCUMENT_D.SKU
                 AND    MS_SKU.DEL_YN                   = 'N'
                 JOIN   CM_DC WD_DC
                 ON     WD_DC.DCCODE                    = DM_DOCUMENT_D.ROUTE
                 AND    WD_DC.DEL_YN                    = 'N'
                 LEFT JOIN TM_INPLAN
                 ON     TM_INPLAN.DCCODE                = WD_INPLAN.DCCODE
                 AND    TM_INPLAN.STORERKEY             = WD_INPLAN.STORERKEY
                 AND    TM_INPLAN.DOCTYPE               = WD_INPLAN.DOCTYPE
                 AND    TM_INPLAN.SLIPDT                = WD_INPLAN.SLIPDT
                 AND    TM_INPLAN.SLIPNO                = WD_INPLAN.SLIPNO
                 WHERE  1=1
                 AND    DM_DOCUMENT_D.STORERKEY         = #{gStorerkey}  
                 AND    DM_DOCUMENT_D.DOCTYPE           = 'WD'      
                 AND    DM_DOCUMENT_D.DEL_YN            = 'N'
                 AND    DM_DOCUMENT_D.CHANNEL           = '3'
                 <if test="slipdt != null and slipdt != ''">                 AND DM_DOCUMENT_D.DELIVERYDATE  =  #{slipdt}           </if>
                 <if test="deliverygroup != null and deliverygroup != ''">   AND TM_INPLAN.DELIVERYGROUP     =  #{deliverygroup}    </if>
                 <if test="fromDccode != null and fromDccode != ''">         AND DM_DOCUMENT_D.ROUTE         =  #{fromDccode}       </if>
                 <if test="toDccode != null and toDccode != ''">             AND DM_DOCUMENT_D.DCCODE        =  #{toDccode}         </if>
                 <!-- 고객 다중선택 -->
                 <if test="toCustkeyMulti != null and toCustkeyMulti != '' ">
                    <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                        <foreach collection="toCustkeyMulti" item="item">
                            OR DM_DOCUMENT_H_PO.FROM_CUSTKEY IN
                            <foreach collection="item" item="code" open="(" close=")" separator=",">
                                #{code}      
                            </foreach>
                        </foreach>
                    </trim>                                             
                 </if>
                 <if test="carnoMulti != null and carnoMulti != ''">    
                       AND TM_INPLAN.CARNO IN
                       <foreach collection="carnoMulti" item="code" open="(" close=")" separator=",">
                         #{code}
                       </foreach>
                 </if>     
                 GROUP BY
                            DM_DOCUMENT_D.DCCODE
                           ,DM_DOCUMENT_D.DOCDT
                           ,DM_DOCUMENT_D.DOCNO
                           ,DM_DOCUMENT_D.DOCLINE
               )  A
            <choose>
                <when test="orderbyPick != null and orderbyPick != ''">
                    <if test="orderbyPick == 'VENDOR_SKU_CUST_POP'">                        
                        ORDER BY FROM_CUSTKEY ,SKU ,TO_CUSTKEY ,DELIVERYGROUP
                    </if>
                    <if test="orderbyPick == 'VENDOR_CUST_SKU_POP'">
                        ORDER BY FROM_CUSTKEY ,TO_CUSTKEY,SKU ,DELIVERYGROUP 
                    </if>
                    <if test="orderbyPick == 'VENDOR_SKU_CUST_DRIVER'">
                        ORDER BY FROM_CUSTKEY ,SKU ,TO_CUSTKEY ,DRIVERNAME 
                    </if>
                    <if test="orderbyPick == 'VENDOR_CUST_SKU_DRIVER'">
                        ORDER BY FROM_CUSTKEY ,TO_CUSTKEY,SKU ,DRIVERNAME 
                    </if>
                    <if test="orderbyPick == 'POP_DRIVER_SKU_CUST'">
                        ORDER BY DELIVERYGROUP, DRIVERNAME, SKU ,TO_CUSTKEY
                    </if>
                    <if test="orderbyPick == 'POP_DRIVER_CUST_SKU'">
                        ORDER BY DELIVERYGROUP, DRIVERNAME, TO_CUSTKEY, SKU
                    </if>
                </when>
            </choose>
        
    </select>
    
</mapper>