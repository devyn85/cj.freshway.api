<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="rtQCConfirmResultService">

    <select id="getMasterList" resultType="cjfw.wms.rt.dto.RtQCConfirmResultResDto">
        SELECT  /* [rtReceiptQCResultService.sqlx][rtReceiptQCResultService.getHeaderList][반품판정현황[2차]][추상호][20150710] */
            '0'                                                                                                                       AS CHECKYN
            , DM_DOCUMENT_H.DOCNO                                                                                                         AS DOCNO
            , DM_DOCUMENT_D.SOURCEKEY                                                                                                     AS DOCNO_WD
            , RT_RECEIPTQC.SLIPDT                                                                                                         AS SLIPDT
            , RT_RECEIPTQC.QCDT                                                                                                         AS QCDT
            , RT_RECEIPTQC.SLIPLINE                                                                                                         AS DOCLINE
            , DM_DOCUMENT_H.FROM_CUSTKEY                                                                                                  AS FROM_CUSTKEY
            , DM_DOCUMENT_H.FROM_CUSTNAME                                                                                                 AS FROM_CUSTNAME
            , MS_CUST.BILLTOCUSTKEY                                                                                                       AS BILLTOCUSTKEY
            , FN_DESCR_CUST(MS_CUST.STORERKEY, MS_CUST.BILLTOCUSTKEY)                                                                     AS BILLTOCJUSTNAME
            , FN_DESCR_CODESPEC(DM_DOCUMENT_D.STORERKEY, 'CLAIMTYPE', 'S' ,RT_CLAIMINFO.CLAIMDTLIDS)                                      AS OTHER03
            , FN_DESCR_CODESPEC(DM_DOCUMENT_D.STORERKEY, 'CLAIMTYPE', 'D' ,RT_CLAIMINFO.CLAIMDTLID)                                       AS OTHER04
            , CASE WHEN RT_CLAIMINFO.BLNGDEPTCD = '10' AND DM_DOCUMENT_D.CHANNEL <![CDATA[<>]]> '1'
            THEN FN_CODEDESCR (DM_DOCUMENT_D.STORERKEY,'VENDORETURNYN', 'Y')
            ELSE FN_CODEDESCR (DM_DOCUMENT_D.STORERKEY,'VENDORETURNYN', 'N')
            END                                                                                                                         AS VENDORETURN
            , FN_CODEDESCR(DM_DOCUMENT_D.STORERKEY,'REASONCODE_RT', DM_DOCUMENT_D.REASONCODE)                                             AS REASONCODE
            , DM_DOCUMENT_D.REASONMSG                                                                 									AS REASONMSG
            , FN_CODEDESCR(DM_DOCUMENT_D.STORERKEY, 'OTHER01_DMD', RT_CLAIMINFO.IMPUTEDEVCD)                                              AS OTHER01
            , FN_CODEDESCR(DM_DOCUMENT_D.STORERKEY, 'BLNGDEPTCD', RT_CLAIMINFO.BLNGDEPTCD)                                                AS BLNGDEPTNAME
            , FN_PURCHASECUST(DM_DOCUMENT_D.DCCODE, DM_DOCUMENT_D.STORERKEY, DM_DOCUMENT_D.SKU, DM_DOCUMENT_D.PLANT, DM_DOCUMENT_D.DELIVERYDATE) AS VENDOR
            , FN_PURCHASECUST(DM_DOCUMENT_D.DCCODE, DM_DOCUMENT_D.STORERKEY, DM_DOCUMENT_D.SKU, DM_DOCUMENT_D.PLANT, DM_DOCUMENT_D.DELIVERYDATE, 'CUSTNAME') AS VENDORNAME
            <!--2026-01-13 FWNEXTWMS-3427 차량번호가져오는방법 변경-->
	          , (
		   		SELECT TM_INPLAN.CARNO
		   		FROM TM_INPLAN
				WHERE TM_INPLAN.DCCODE = RT_INPLAN.DCCODE
				AND TM_INPLAN.STORERKEY = RT_INPLAN.STORERKEY
				AND TM_INPLAN.DOCTYPE = 'WD'
				AND TM_INPLAN.SLIPNO = DM_DOCUMENT_D.SOURCEKEY)                                                                         AS CARNO		/*반품차량번호*/
            , DM_DOCUMENT_D.SKU                                                                                                           AS SKU
            , MS_SKU.DESCRIPTION                                                                                                          AS SKUNAME
            , FN_CODEDESCR(MS_SKU.STORERKEY,'STORAGETYPE', MS_SKU.STORAGETYPE)                                                            AS STORAGETYPE
            , FN_CODEDESCR(DM_DOCUMENT_D.STORERKEY,'PUTAWAYTYPE', DM_DOCUMENT_D.CHANNEL)                                                  AS CHANNEL
            , FN_UOMCAL(DM_DOCUMENT_D.BUNMO,DM_DOCUMENT_D.BUNJA,RT_INPLAN.ORDERQTY+RT_INPLAN.CANCELQTY)                                   AS CUSTORDERQTY
            , (FN_UOMCAL(DM_DOCUMENT_D.BUNMO,DM_DOCUMENT_D.BUNJA,RT_INPLAN.ORDERQTY+RT_INPLAN.CANCELQTY))
            - FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,RT_INPLAN.CONFIRMQTY)                                                                                     AS UNRETURNQTY
            , FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,RT_INPLAN.CONFIRMQTY)                                                                                     AS CONFIRMQTY
            , FN_CONV_UOM  ( DM_DOCUMENT_D.STORERKEY, DM_DOCUMENT_D.SKU, RT_RECEIPTQC.UOM,DM_DOCUMENT_D.STORERUOM, RT_RECEIPTQC.RETURNOUTQTY)                                              AS RETURNOUTQTY
            , FN_CONV_UOM  ( DM_DOCUMENT_D.STORERKEY, DM_DOCUMENT_D.SKU, RT_RECEIPTQC.UOM,DM_DOCUMENT_D.STORERUOM, RT_RECEIPTQC.DISUSEQTY)                                                 AS DISUSEQTY
            , FN_CONV_UOM  ( DM_DOCUMENT_D.STORERKEY, DM_DOCUMENT_D.SKU, RT_RECEIPTQC.UOM,DM_DOCUMENT_D.STORERUOM, RT_RECEIPTQC.GOODQTY)                                                   AS GOODQTY
            , FN_CONV_UOM  ( DM_DOCUMENT_D.STORERKEY, DM_DOCUMENT_D.SKU, RT_RECEIPTQC.UOM,DM_DOCUMENT_D.STORERUOM, RT_RECEIPTQC.RETURNOUTCFMQTY)                                           AS RETURNOUTCFMQTY
            , FN_CONV_UOM  ( DM_DOCUMENT_D.STORERKEY, DM_DOCUMENT_D.SKU, RT_RECEIPTQC.UOM,DM_DOCUMENT_D.STORERUOM, RT_RECEIPTQC.DISUSECFMQTY)                                              AS DISUSECFMQTY
            , FN_CONV_UOM  ( DM_DOCUMENT_D.STORERKEY, DM_DOCUMENT_D.SKU, RT_RECEIPTQC.UOM,DM_DOCUMENT_D.STORERUOM, RT_RECEIPTQC.GOODCFMQTY)                                                AS GOODCFMQTY
            , FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO,DM_DOCUMENT_D.BUNJA,RT_INPLAN.CONFIRMQTY)
            -FN_CONV_UOM  ( DM_DOCUMENT_D.STORERKEY, DM_DOCUMENT_D.SKU, RT_RECEIPTQC.UOM,DM_DOCUMENT_D.STORERUOM,(NVL(RT_RECEIPTQC.RETURNOUTCFMQTY,0)+NVL(RT_RECEIPTQC.DISUSECFMQTY,0)+NVL(RT_RECEIPTQC.GOODCFMQTY,0)))                      AS UNCONFIRMQTY
            , DM_DOCUMENT_D.STORERUOM                                                                                                     AS UOM
            , NVL(ST_SNINFO.LOTTABLE01,CM_LOT.LOTTABLE01)                                                                                 AS LOTTABLE01
            , NVL(CASE WHEN MS_SKU.DURATIONTYPE = '1' AND REGEXP_LIKE(NVL(ST_SNINFO.LOTTABLE01,CM_LOT.LOTTABLE01), '^[0-9]{8}$')
            THEN TO_CHAR(TO_DATE(NVL(ST_SNINFO.LOTTABLE01,CM_LOT.LOTTABLE01),'YYYYMMDD') - (MS_SKU.DURATION - 1), 'YYYYMMDD')
            ELSE NVL(ST_SNINFO.LOTTABLE01,CM_LOT.LOTTABLE01)
            END,'STD') AS LOT_MANUFACTURE                    /** 제조 */
            , NVL(CASE WHEN MS_SKU.DURATIONTYPE != '1' AND REGEXP_LIKE(NVL(ST_SNINFO.LOTTABLE01,CM_LOT.LOTTABLE01), '^[0-9]{8}$')
            THEN TO_CHAR(TO_DATE(NVL(ST_SNINFO.LOTTABLE01,CM_LOT.LOTTABLE01),'YYYYMMDD') + (MS_SKU.DURATION - 1), 'YYYYMMDD')
            ELSE NVL(ST_SNINFO.LOTTABLE01,CM_LOT.LOTTABLE01)
            END,'STD') AS LOT_EXPIRE                         /** 유통 */
            , FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, NVL(ST_SNINFO.LOTTABLE01,CM_LOT.LOTTABLE01), 'N') ||'/'|| MS_SKU.DURATION      AS DURATION_TERM
            , ST_SNINFO.SERIALNO                                                                                                          AS SERIALNO
            , ST_SNINFO.CONVSERIALNO                                                                                                      AS CONVSERIALNO
            , ST_SNINFO.SERIALLEVEL                                                                                                       AS SERIALLEVEL
            , ST_SNINFO.SERIALTYPE                                                                                                        AS SERIALTYPE
            , ST_SNINFO.FACTORYNAME                                                                                                       AS FACTORYNAME
            , ST_SNINFO.CONTRACTCUSTKEY                                                                                                   AS CONTRACTCOMPANY
            , ( SELECT DESCRIPTION  FROM MS_CUST
            WHERE CUSTKEY = ST_SNINFO.CONTRACTCUSTKEY
            AND ROWNUM = 1 )              	                                                                                        AS CONTRACTCOMPANYNAME
            , FN_CODEDESCR (ST_SNINFO.STORERKEY,'CONTRACTTYPE_SN', ST_SNINFO.CONTRACTTYPE)              	                                AS CONTRACTTYPE
            , ST_SNINFO.BUTCHERYDT                                                                                                        AS BUTCHERYDT
            , ST_SNINFO.FROMVALIDDT                                                                                                       AS FROMVALIDDT
            , ST_SNINFO.TOVALIDDT                                                                                                         AS TOVALIDDT
            , ST_SNINFO.STOCKID                                                                                                           AS STOCKID
            , RT_INSPECT.INSPECTQTY          		                                                                                        AS SERIALORDERQTY
            , RT_INSPECT.CONFIRMQTY                                                                                                       AS SERIALINSPECTQTY
            , CASE WHEN RT_INPLAN.STORERKEY = 'CJFW' THEN CASE WHEN RT_INPLAN.UOM = 'KG' THEN RT_INSPECT.CONFIRMQTY
            ELSE RT_INSPECT.CONFIRMQTY * ST_SNINFO.NETWEIGHT
            END
            ELSE FN_CONV_UOM(RT_INPLAN.STORERKEY,RT_INPLAN.SKU,RT_INPLAN.UOM,'KG',RT_INSPECT.CONFIRMQTY)
            END                                                                                                                         AS SERIALSCANWEIGHT
            , MS_SKU.COLORDESCR                                                                                                           AS COLORDESCR
            , ST_SNINFO.PLACEOFORIGIN                                                                                                     AS PLACEOFORIGIN
            , FN_CODEDESCR(RT_RECEIPTQC.STORERKEY,'STATUS_RTQC', RT_RECEIPTQC.STATUS)                                                     AS STATUS
            , RT_RECEIPTQC.REASONMSG                                                                                                      AS REASONMSG
            , DECODE(RT_RECEIPTQC.STATUS,'90',DM_DOCUMENT_H.DOCNO,'')                                                                     AS QCDOCNO
            , MS_SKU.DURATION                                                                                                             AS DURATION
            , MS_SKU.DURATIONTYPE                                                                                                         AS DURATIONTYPE
            , DM_DOCUMENT_D.PLANT                                                                                                         AS PLANT
            , '['||DM_DOCUMENT_D.PLANT||']'||FN_DESCR_PLANT(DM_DOCUMENT_D.PLANT)                                                          AS PLANT_DESCR
            ,'0'         AS AVGWEIGHT       /* 평균중량     */
            ,'0'         AS CALORDERBOX     /* 환산주문박스 */
            ,'0'         AS CALCONFIRMBOX   /* 환산확정박스 */
            ,'0'         AS REALBOX         /* 실박스       */
            , to_char(DM_DOCUMENT_D.Confirmdate,'yyyy-mm-dd hh24:mi:ss')                                                                  AS CONFIRMDATE
            , NVL(RT_CLAIMINFO.PACKINGMETHOD,DM_DOCUMENT_D.PACKINGMETHOD)                                                                 AS PACKINGMETHOD
            , RT_RECEIPTQC.QCDT AS QCDT
        FROM RT_INPLAN
        JOIN DM_DOCUMENT_D
            ON    DM_DOCUMENT_D.DCCODE             = RT_INPLAN.DCCODE
            AND   DM_DOCUMENT_D.STORERKEY          = RT_INPLAN.STORERKEY
            AND   DM_DOCUMENT_D.ORGANIZE		      = RT_INPLAN.ORGANIZE
            AND   DM_DOCUMENT_D.DOCDT              = RT_INPLAN.DOCDT
            AND   DM_DOCUMENT_D.DOCNO              = RT_INPLAN.DOCNO
            AND   DM_DOCUMENT_D.DOCLINE            = RT_INPLAN.DOCLINE
            <if test="other03 != null and other03 != ''">            AND    DM_DOCUMENT_D.OTHER03        LIKE #{other03}                            </if>
            <if test="channel != null and channel != ''">            AND    DM_DOCUMENT_D.CHANNEL        LIKE #{channel}                            </if>
            <if test="docnoWdMulti != null and docnoWdMulti != ''">
                AND DM_DOCUMENT_D.SOURCEKEY IN
                <foreach collection="docnoWdMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
        JOIN DM_DOCUMENT_H
            ON    DM_DOCUMENT_H.DCCODE         	  = DM_DOCUMENT_D.DCCODE
            AND   DM_DOCUMENT_H.STORERKEY         = DM_DOCUMENT_D.STORERKEY
            AND   DM_DOCUMENT_H.ORGANIZE       	  = DM_DOCUMENT_D.ORGANIZE
            AND   DM_DOCUMENT_H.DOCDT          	  = DM_DOCUMENT_D.DOCDT
            AND   DM_DOCUMENT_H.DOCNO          	  = DM_DOCUMENT_D.DOCNO
            AND   DM_DOCUMENT_H.DOCTYPE           = DM_DOCUMENT_D.DOCTYPE
            AND   DM_DOCUMENT_H.DOCTYPE        	  = 'RT'
            <!-- 배송그룹 공통조회 조건 -->
            <if test="gMultiCourier != null and gMultiCourier != ''">    AND    DM_DOCUMENT_H.COURIER          =      #{gMultiCourier}                </if>
        JOIN CM_USER_AUTHORITY
            ON    CM_USER_AUTHORITY.USERID         =  #{gUserId}
            AND   CM_USER_AUTHORITY.DCCODE         = RT_INPLAN.DCCODE
            AND   CM_USER_AUTHORITY.STORERKEY      = RT_INPLAN.STORERKEY
            AND   CM_USER_AUTHORITY.ORGANIZE       = RT_INPLAN.ORGANIZE
            AND   CM_USER_AUTHORITY.AREA           = RT_INPLAN.AREA
            <if test="fixdccode != null and fixdccode != ''">    AND   CM_USER_AUTHORITY.DCCODE         = #{fixdccode}     </if>
            <if test="gStorerkey != null and gStorerkey != ''"> AND   CM_USER_AUTHORITY.STORERKEY      = #{gStorerkey}  </if>
            <if test="fixdccode != null and fixdccode != ''">  AND   CM_USER_AUTHORITY.ORGANIZE       = #{fixdccode}   </if>
            <if test="gArea != null and gArea != ''">      AND   CM_USER_AUTHORITY.AREA           = #{gArea}       </if>
        JOIN MS_SKU
            ON    MS_SKU.STORERKEY                 = DM_DOCUMENT_D.STORERKEY
            AND   MS_SKU.SKU                       = DM_DOCUMENT_D.SKU
            <!-- 상품 다중선택 -->
            <if test="skuMulti != null and skuMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="skuMulti" item="item">
                        OR MS_SKU.SKU IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
            <if test="storagetype != null and storagetype != ''">        AND    MS_SKU.STORAGETYPE        LIKE #{storagetype}                     </if>
        JOIN MS_CUST
            ON  MS_CUST.STORERKEY                   = DM_DOCUMENT_H.STORERKEY
            AND MS_CUST.CUSTKEY                     = DM_DOCUMENT_H.FROM_CUSTKEY
            AND MS_CUST.CUSTTYPE					   = 'C'
        JOIN RT_RECEIPTQC
            ON  RT_RECEIPTQC.DCCODE                  = RT_INPLAN.DCCODE
            AND RT_RECEIPTQC.STORERKEY               = RT_INPLAN.STORERKEY
            AND RT_RECEIPTQC.ORGANIZE                = RT_INPLAN.ORGANIZE
            AND RT_RECEIPTQC.SLIPDT                  = RT_INPLAN.SLIPDT
            AND RT_RECEIPTQC.SLIPNO                  = RT_INPLAN.SLIPNO
            AND RT_RECEIPTQC.SLIPLINE                = RT_INPLAN.SLIPLINE
            AND RT_RECEIPTQC.DEL_YN                  = 'N'
            <if test="qcdtFrom != null and qcdtFrom != ''">        AND    RT_RECEIPTQC.QCDT          <![CDATA[>=]]> #{qcdtFrom}              </if>
            <if test="qcdtTo != null and qcdtTo != ''">          AND    RT_RECEIPTQC.QCDT          <![CDATA[<=]]> #{qcdtTo}                </if>
            <if test="slipdtFrom != null and slipdtFrom != ''">      AND    RT_RECEIPTQC.SLIPDT        <![CDATA[>=]]> #{slipdtFrom}            </if>
            <if test="slipdtTo != null and slipdtTo != ''">        AND    RT_RECEIPTQC.SLIPDT        <![CDATA[<=]]> #{slipdtTo}              </if>
            <if test="statusRtqc != null and statusRtqc != ''">      AND    RT_RECEIPTQC.STATUS        = #{statusRtqc}                         </if>
        LEFT OUTER JOIN RT_INSPECT
            ON     RT_INSPECT.DCCODE                = RT_INPLAN.DCCODE
            AND    RT_INSPECT.STORERKEY             = RT_INPLAN.STORERKEY
            AND    RT_INSPECT.ORGANIZE              = RT_INPLAN.ORGANIZE
            AND    RT_INSPECT.AREA                  = RT_INPLAN.AREA
            AND    RT_INSPECT.SLIPDT                = RT_INPLAN.SLIPDT
            AND    RT_INSPECT.SLIPNO                = RT_INPLAN.SLIPNO
            AND    RT_INSPECT.SLIPLINE              = RT_INPLAN.SLIPLINE
            AND    RT_INSPECT.SKU                   = RT_INPLAN.SKU
            AND    RT_INSPECT.DEL_YN                = 'N'
        LEFT OUTER JOIN ST_SNINFO
            ON     RT_INSPECT.STORERKEY             = ST_SNINFO.STORERKEY
            AND    RT_INSPECT.SKU                   = ST_SNINFO.SKU
            AND    RT_INSPECT.STOCKID               = ST_SNINFO.STOCKID
            AND    RT_INSPECT.DEL_YN                = 'N'
        JOIN CM_LOT
            ON     CM_LOT.STORERKEY            	 	   =  RT_INPLAN.STORERKEY
            AND    CM_LOT.LOT                   	   =  RT_INPLAN.LOT
            AND    CM_LOT.DEL_YN                 	   = 'N'
        LEFT OUTER JOIN RT_CLAIMINFO
            ON  RT_CLAIMINFO.DCCODE    = DM_DOCUMENT_D.DCCODE
            AND RT_CLAIMINFO.STORERKEY = DM_DOCUMENT_D.STORERKEY
            AND RT_CLAIMINFO.DOCNO     = DM_DOCUMENT_D.DOCNO
            AND RT_CLAIMINFO.DOCLINE   = DM_DOCUMENT_D.DOCLINE
            AND RT_CLAIMINFO.DEL_YN    = 'N'
        WHERE 1 = 1
        <!-- 배송인도처 다중선택 -->
        <if test="fromCustkeyMulti != null and fromCustkeyMulti != '' ">
            <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                <foreach collection="fromCustkeyMulti" item="item">
                    OR RT_INPLAN.CUSTKEY IN
                    <foreach collection="item" item="code" open="(" close=")" separator=",">
                        #{code}
                    </foreach>
                </foreach>
            </trim>
        </if>
        <if test="docnoMulti != null and docnoMulti != ''">
            AND RT_INPLAN.DOCNO IN
            <foreach collection="docnoMulti" item="code" open="(" close=")" separator=",">
                #{code}
            </foreach>
        </if>
        <if test="vendoreturn == 'Y'">
            AND    DM_DOCUMENT_D.CHANNEL    <![CDATA[<>]]> '1'
            AND    RT_CLAIMINFO.BLNGDEPTCD = '10'
        </if>
        <if test="vendoreturn == 'N'">
            AND NOT (     DM_DOCUMENT_D.CHANNEL    <![CDATA[<>]]> '1'
            AND RT_CLAIMINFO.BLNGDEPTCD  = '10'   )
        </if>
        ORDER BY
        RT_INPLAN.DOCNO
        ,RT_INPLAN.CUSTKEY
    </select>

    <!-- 반품 클레임사유 조회 (세)  -->
    <select id="getClaimTypeList" resultType="map">
        SELECT
            CM_CODESPEC.SPECCODE  AS value
            , CM_CODESPEC.SPECDESCR AS label
        FROM   CM_CODESPEC
        WHERE  1 = 1
            <if test="gStorerkey != null and gStorerkey != ''">
                AND  CM_CODESPEC.STORERKEY     = #{gStorerkey}
            </if>
            AND    CM_CODESPEC.CODELIST     = 'CLAIMTYPE'
            AND    CM_CODESPEC.BASECODE     = 'S'
        ORDER BY CM_CODESPEC.SPECCODE
    </select>

    <!-- 반품 클레임사유 조회 (소)  -->
    <select id="getClaimTypeList2" resultType="map">
        SELECT
        CM_CODESPEC.SPECCODE  AS value
        , CM_CODESPEC.SPECDESCR AS label
        FROM   CM_CODESPEC
        WHERE  1 = 1
        <if test="gStorerkey != null and gStorerkey != ''">
            AND  CM_CODESPEC.STORERKEY     = #{gStorerkey}
        </if>
        AND    CM_CODESPEC.CODELIST     = 'CLAIMTYPE'
        AND    CM_CODESPEC.BASECODE     = 'M'
        ORDER BY CM_CODESPEC.SPECCODE
    </select>
</mapper>