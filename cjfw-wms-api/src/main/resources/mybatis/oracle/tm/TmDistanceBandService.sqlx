<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="tmDistanceBandService">
	
	<select id="getDataHeaderlist"  resultType="TmDistanceBandListResDto">
		 /* [courierRangeMapper.xml][selectList][운송구간/행정동 기준정보 목록 조회][ParkJinWoo][20250911] */
      WITH TEMP AS (
    /* 시도(2자리) */
    SELECT DISTINCT
               SUBSTR(A.HJDONG_CD, 1, 2)           AS CD              /* 코드(시도) */
        ,      A.CTP_KOR_NM                        AS CTP_KOR_NM      /* 시도명 */
        ,      CAST(NULL AS VARCHAR2(80))          AS SIG_KOR_NM      /* 시군구명 */
        ,      CAST(NULL AS VARCHAR2(120))         AS HJDONG_NM       /* 행정동명 */
        
  
      FROM CM_HJDONG A

    UNION ALL
    /* 시군구(5자리) */
    SELECT DISTINCT
               SUBSTR(A.HJDONG_CD, 1, 5)           AS CD              /* 코드(시군구) */
        ,      A.CTP_KOR_NM                        AS CTP_KOR_NM      /* 시도명 */
        ,      CASE WHEN A.CTP_KOR_NM = '세종특별자치시' THEN '세종특별자치시' ELSE A.SIG_KOR_NM      END                  AS SIG_KOR_NM      /* 시군구명 */
        ,      CAST(NULL AS VARCHAR2(120))         AS HJDONG_NM       /* 행정동명 */

      FROM CM_HJDONG A

    UNION ALL
    /* 행정동(전체 코드) */
    SELECT
               A.HJDONG_CD                         AS CD              /* 코드(전체) */
        ,      A.CTP_KOR_NM                        AS CTP_KOR_NM      /* 시도명 */
        , CASE WHEN A.CTP_KOR_NM = '세종특별자치시' THEN '세종특별자치시' ELSE A.SIG_KOR_NM      END                  AS SIG_KOR_NM      /* 시군구명 */
        ,      A.HJDONG_NM                         AS HJDONG_NM       /* 행정동명 */

      FROM CM_HJDONG A
),
TEMP3 AS (SELECT
               CD                                   AS HJDONG_CD             /* 코드 */
    ,          CTP_KOR_NM                           AS CTP_KOR_NM     /* 시도명 */
    ,          SIG_KOR_NM                           AS SIG_KOR_NM     /* 시군구명 */
    ,          HJDONG_NM                            AS HJDONG_NM      /* 행정동명 */
    ,          CASE
                   WHEN LENGTH(CD)  =  2  THEN NULL
                   WHEN LENGTH(CD)  =  5  THEN SUBSTR(CD, 1, 2)
                   ELSE SUBSTR(CD, 1, 5)
               END                                  AS PARENT_CD      /* 부모코드 */
    ,          CASE
                   WHEN LENGTH(CD)  =  2  THEN NVL(CTP_KOR_NM, HJDONG_NM)
                   WHEN LENGTH(CD)  =  5  THEN NVL(SIG_KOR_NM, HJDONG_NM)
                   ELSE NVL(HJDONG_NM, NVL(SIG_KOR_NM, CTP_KOR_NM))
               END                                  AS CD_NM          /* 코드명(길이별 대표명) */

  FROM TEMP
    WHERE 1=1

  ) SELECT
               A.SERIALKEY                         AS SERIALKEY        /* 데이터번호 */
            ,  A.DCCODE                            AS DCCODE           /* 센터코드 */
            ,  A.COURIER                           AS COURIER          /* 운송사코드 */
            ,  A.COURIER_RANGE                     AS COURIER_RANGE    /* 운송구간 */
            ,  A.COURIER_RANGE                     AS OLD_COURIER_RANGE    /* 운송구간 */
            ,  A.HJDONG_CD                         AS HJDONG_CD        /* 행정동코드 */
            ,  A.RMK                               AS RMK              /* 비고 */
            ,  A.FROMDATE                          AS FROMDATE         /* 적용시작일자 */
            ,  A.COURIER_RANGE_DTL				   AS COURIER_RANGE_DTL
            ,  A.TODATE                            AS TODATE           /* 적용종료일자 */
            ,  TO_CHAR(A.ADDDATE, 'YYYYMMDDHH24MISS') AS ADDDATE       /* 최초등록시간 */
            ,  TO_CHAR(A.EDITDATE,'YYYYMMDDHH24MISS') AS EDITDATE      /* 최종변경시간 */
            ,  A.ADDWHO                            AS ADDWHO           /* 최초등록자 */
            ,  A.EDITWHO                           AS EDITWHO          /* 최종변경자 */
            ,  USER1.USER_NM                       AS ADDWHONAME       /* 등록자명 */
            ,  USER2.USER_NM                       AS EDITWHONAME      /* 수정자명 */
            ,  B.CTP_KOR_NM						   AS CTPKORNM        /* 시도명 */
            ,  CASE WHEN B.SIG_KOR_NM IS NULL THEN '전체'ELSE B.SIG_KOR_NM END                        AS SIGKORNM        /* 시군구명 */
            ,  CASE WHEN B.HJDONG_NM IS NULL THEN '전체' ELSE B.HJDONG_NM END                         AS HJDONGNM       /* 읍면동명 */
            
        FROM TM_CARRIER_RANGE A
        JOIN  TEMP3 B
  		  ON A.HJDONG_CD = B.HJDONG_CD
        LEFT JOIN FRAMEONE_USER USER1 ON USER1.USER_ID = A.ADDWHO  /*등록자명*/
        LEFT JOIN FRAMEONE_USER USER2 ON USER2.USER_ID = A.EDITWHO /*수정자명*/
        WHERE 1=1
        <if test="dcCode != null and dcCode != ''">
            AND <![CDATA[ A.DCCODE = #{dcCode} ]]>
        </if>
        <if test="courier != null and courier != ''">
            AND <![CDATA[ A.COURIER = #{courier} ]]>
        </if>
        <if test="carrierRange != null and carrierRange != ''">
            AND <![CDATA[ A.COURIER_RANGE = #{carrierRange} ]]>
        </if>
        <if test="hjdongCd != null and hjdongCd != ''">
            AND <![CDATA[ A.HJDONG_CD = #{hjdongCd} ]]>
        </if>
        <if test="serialYn neq 'true'">
	        <if test="fromDate != null and fromDate != ''">
	            AND <![CDATA[ A.TODATE   >= #{fromDate} ]]>
	        </if>
	        <if test="toDate != null and toDate != ''">
	            AND <![CDATA[ A.FROMDATE <= #{toDate} ]]> 
	        </if>
        </if>
        ORDER BY
      B.CTP_KOR_NM   
     ,B.SIG_KOR_NM
     ,B.HJDONG_NM
     , CASE
         WHEN LENGTH(B.HJDONG_CD) <![CDATA[=]]> 2 THEN 1   /* 시도 */
         WHEN LENGTH(B.HJDONG_CD) <![CDATA[=]]> 5 THEN 2   /* 시군구 */
         ELSE 3                                           /* 행정동 */
       END
     , CASE
	     WHEN LENGTH(B.HJDONG_CD) = 2 THEN CTP_KOR_NM
	     WHEN LENGTH(B.HJDONG_CD) = 5 THEN SIG_KOR_NM
	     WHEN LENGTH(B.HJDONG_CD) = 10 THEN HJDONG_NM
	     ELSE B.HJDONG_CD         end    -- 행정동은 코드순
     , B.HJDONG_CD
     , A.DCCODE
     , A.COURIER
     , A.COURIER_RANGE
     , A.COURIER_RANGE_DTL
     , A.FROMDATE
     , A.TODATE 
  	</select>
  	
  
    
        <delete id="deleteDistanceBand">
        /* [courierRangeMapper.xml][delete][운송구간/행정동 기준정보 삭제][ParkJinWoo][20250911] */
        DELETE FROM TM_CARRIER_RANGE
         WHERE <![CDATA[ SERIALKEY = #{serialKey} ]]>
    </delete>
    
    <select id="getHjdCdData"  resultType="TmHjdDataListResDto">
	/* tmDistanceBandService.getHjdCdData */
	/* [cmHjdong.sql][getHjdongHierarchy][CD 길이별 부모 코드 추가][ParkJinWoo][20251014] */
	WITH TEMP_RAW  AS (
	    /* 시도(2자리) */
	    SELECT DISTINCT
	               SUBSTR(A.HJDONG_CD, 1, 2)           AS CD              /* 코드(시도) */
	        ,      A.CTP_KOR_NM                        AS CTP_KOR_NM      /* 시도명 */
	        ,      CAST(NULL AS VARCHAR2(80))          AS SIG_KOR_NM      /* 시군구명 */
	        ,      CAST(NULL AS VARCHAR2(120))         AS HJDONG_NM       /* 행정동명 */
	        ,    A.MVMN_RES_CD   
	  
	      FROM CM_HJDONG A
		 WHERE NVL( A.MVMN_RES_CD,0) <![CDATA[<>]]> '63'
	    UNION ALL
	    /* 시군구(5자리) */
	    SELECT DISTINCT
	               SUBSTR(A.HJDONG_CD, 1, 5)           AS CD              /* 코드(시군구) */
	        ,      A.CTP_KOR_NM                        AS CTP_KOR_NM      /* 시도명 */
	        ,      CASE WHEN A.CTP_KOR_NM = '세종특별자치시' THEN '세종특별자치시' ELSE A.SIG_KOR_NM      END                  AS SIG_KOR_NM      /* 시군구명 */
	        ,      CAST(NULL AS VARCHAR2(120))         AS HJDONG_NM       /* 행정동명 */
	    ,    A.MVMN_RES_CD 
	      FROM CM_HJDONG A
		 WHERE NVL( A.MVMN_RES_CD,0) <![CDATA[<>]]> '63'
	    UNION ALL
	    /* 행정동(전체 코드) */
	    SELECT
	               A.HJDONG_CD                         AS CD              /* 코드(전체) */
	        ,      A.CTP_KOR_NM                        AS CTP_KOR_NM      /* 시도명 */
	        ,      CASE WHEN A.CTP_KOR_NM = '세종특별자치시' THEN '세종특별자치시' ELSE A.SIG_KOR_NM      END                  AS SIG_KOR_NM      /* 시군구명 */
	        ,      A.HJDONG_NM                         AS HJDONG_NM       /* 행정동명 */
	    ,    A.MVMN_RES_CD   
	      FROM CM_HJDONG A
	     WHERE NVL( A.MVMN_RES_CD,0) <![CDATA[<>]]> '63'
	),
	TEMP AS (
	    SELECT
	           CD
	         , CTP_KOR_NM
	         , SIG_KOR_NM
	         , HJDONG_NM
	         , MAX(MVMN_RES_CD) KEEP (
	               DENSE_RANK LAST
	               ORDER BY CASE WHEN MVMN_RES_CD = '31' THEN 1 ELSE 2 END
	           ) AS MVMN_RES_CD
	    FROM TEMP_RAW
	    GROUP BY
	           CD
	         , CTP_KOR_NM
	         , SIG_KOR_NM
	         , HJDONG_NM
	)
	SELECT
	              CD                                   AS HJDONG_CD             /* 코드 */
	    ,          CTP_KOR_NM                           AS CTP_KOR_NM     /* 시도명 */
	    ,          SIG_KOR_NM                           AS SIG_KOR_NM     /* 시군구명 */
	    ,          HJDONG_NM                            AS HJDONG_NM      /* 행정동명 */
	    ,      MVMN_RES_CD
	    ,          CASE
	                   WHEN LENGTH(CD)  =  2  THEN NULL
	                   WHEN LENGTH(CD)  =  5  THEN SUBSTR(CD, 1, 2)
	                   ELSE SUBSTR(CD, 1, 5)
	               END                                  AS PARENT_CD      /* 부모코드 */
	    ,          CASE
	                   WHEN LENGTH(CD)  =  2  THEN NVL(CTP_KOR_NM, HJDONG_NM)
	                   WHEN LENGTH(CD)  =  5  THEN NVL(SIG_KOR_NM, HJDONG_NM)
	                   ELSE NVL(HJDONG_NM, NVL(SIG_KOR_NM, CTP_KOR_NM))
	               END                                  AS CD_NM          /* 코드명(길이별 대표명) */
	
	  FROM TEMP
	    WHERE 1=1
	     <!--  AND  NVL(MVMN_RES_CD,0)  <![CDATA[<>]]>  '63' -->
	
	   
	    
	    ORDER BY
	       CTP_KOR_NM
	     , CASE
	           WHEN LENGTH(CD) = 2 THEN 1
	           WHEN LENGTH(CD) = 5 THEN 2
	           ELSE 3
	       END
	     , CASE
	           WHEN LENGTH(CD) = 2 THEN CTP_KOR_NM
	           WHEN LENGTH(CD) = 5 THEN SIG_KOR_NM
	           WHEN LENGTH(CD) = 10 THEN HJDONG_NM
	           ELSE CD             -- 행정동은 코드순
	       END

  	</select>
  <select id="getHjdCdDataList"  resultType="TmHjdDataListResDto">	
	  	SELECT
	       A.HJDONG_CD       AS HJDONG_CD     /* 행정동코드 */
	     , A.CTP_KOR_NM      AS CTP_KOR_NM    /* 시도명 */
	     , A.SIG_KOR_NM      AS SIG_KOR_NM    /* 시군구명 */
	     , A.HJDONG_NM       AS HJDONG_NM     /* 행정동명 */
	FROM   Cm_Hjdong A
	WHERE  1=1
		<if test="hjdongCd != null and hjdongCd != ''">
        AND A.HJDONG_CD LIKE #{hjdongCd} || '%'
        </if>
        <if test="sigKorNm != null and sigKorNm != ''">
        AND A.SIG_KOR_NM LIKE #{sigKorNm} || '%'
        </if>
	  AND NOT EXISTS (
	        SELECT 1
	          FROM TM_CARRIER_RANGE B
	         WHERE B.DCCODE        = #{dcCode}
	           AND B.COURIER       = #{courier}
	          
	           AND B.HJDONG_CD     = A.HJDONG_CD
	   )    
       	</select>
    
  <select id="chkValcourierRange" resultType="TmDistanceBandListResDto">
    SELECT /* [tmDistanceBandService.xml][chkVal][운송구간/행정동 기준정보 엑셀업로드 검증][ParkJinWoo][20250911] */
           (
            SELECT CASE WHEN COUNT(*) > 0 THEN 'Y' ELSE 'N' END AS CHK1
              FROM TM_CARRIER_RANGE X
             WHERE <![CDATA[ X.DCCODE        = #{dcCode}       ]]>
               AND <![CDATA[ X.COURIER       = #{courier}      ]]>
               <!-- AND <![CDATA[ X.COURIER_RANGE = #{courierRange} ]]> -->
               AND (
                        <![CDATA[ X.HJDONG_CD = #{hjdongCd} ]]>
                    
                   )
               AND <![CDATA[ X.FROMDATE      = #{fromDate}    ]]>
           ) AS CHK1 /*체크.기존 자료가 존재하는 경우 수정 대상*/

          ,(
            SELECT CASE WHEN MAX(X.FROMDATE) IS NOT NULL THEN MAX(X.FROMDATE) ELSE '' END AS STA_DT
              FROM TM_CARRIER_RANGE X
             WHERE <![CDATA[ X.DCCODE        = #{dcCode}       ]]>
               AND <![CDATA[ X.COURIER       = #{courier}      ]]>
               <!-- AND <![CDATA[ X.COURIER_RANGE = #{courierRange} ]]> -->
               AND (
                        <![CDATA[ X.HJDONG_CD LIKE #{hjdongCd} || '%' ]]>
                     OR <![CDATA[ #{hjdongCd} LIKE X.HJDONG_CD || '%' ]]>
                   )
               AND ( <![CDATA[ X.FROMDATE < #{fromDate} ]]> )
           ) AS STA_DT /*체크.이전 시작일 존재 여부(가장 최근 시작일)*/

          ,(
            SELECT CASE WHEN MAX(T.SERIALKEY) IS NOT NULL THEN TO_CHAR(MAX(T.SERIALKEY)) ELSE '' END AS SERIALKEY
              FROM (
                    SELECT X.SERIALKEY
                      FROM TM_CARRIER_RANGE X
                     WHERE <![CDATA[ X.DCCODE        = #{dcCode}       ]]>
                       AND <![CDATA[ X.COURIER       = #{courier}      ]]>
                       <!-- AND <![CDATA[ X.COURIER_RANGE = #{courierRange} ]]> -->
                       AND (
                                <![CDATA[ X.HJDONG_CD LIKE #{hjdongCd} || '%' ]]>
                             OR <![CDATA[ #{hjdongCd} LIKE X.HJDONG_CD || '%' ]]>
                           )
                       AND ( <![CDATA[ X.FROMDATE < #{fromDate} ]]> )
                     ORDER BY X.FROMDATE DESC
                 ) T
             WHERE ROWNUM = 1
           ) AS SERIALKEY /*체크.이전 시작일 데이터의 SERIALKEY*/

          ,(
            SELECT CASE
                     WHEN MIN(X.FROMDATE) IS NOT NULL
                     THEN TO_CHAR(TO_DATE(MIN(X.FROMDATE),'YYYYMMDD') - 1, 'YYYYMMDD')
                     ELSE ''
                   END AS END_DT
              FROM TM_CARRIER_RANGE X
             WHERE <![CDATA[ X.DCCODE        = #{dcCode}       ]]>
               AND <![CDATA[ X.COURIER       = #{courier}      ]]>
               <!-- AND <![CDATA[ X.COURIER_RANGE = #{courierRange} ]]> -->
               AND (
                        <![CDATA[ X.HJDONG_CD LIKE #{hjdongCd} || '%' ]]>
                     OR <![CDATA[ #{hjdongCd} LIKE X.HJDONG_CD || '%' ]]>
                   )
               AND ( <![CDATA[ X.FROMDATE > #{fromDate} ]]> )
           ) AS END_DT /*체크.미래 시작일 존재 시 (미래시작일-1) 종료일 후보*/
      FROM DUAL
</select>

   <insert id="insertDistanceBand">
        /* [courierRangeMapper.xml][insert][운송구간/행정동 기준정보 입력][ParkJinWoo][20250911] */
        INSERT INTO TM_CARRIER_RANGE (
               SERIALKEY     /* 데이터번호 */
             , DCCODE        /* 센터코드 */
             , COURIER       /* 운송사코드 */
             , COURIER_RANGE /* 운송구간 */
             , HJDONG_CD     /* 행정동코드 */
             , RMK           /* 비고 */
             , FROMDATE      /* 적용시작일자 */
             , TODATE        /* 적용종료일자 */
             , ADDDATE       /* 최초등록시간 */
             , EDITDATE      /* 최종변경시간 */
             , ADDWHO        /* 최초등록자 */
             , EDITWHO       /* 최종변경자 */
             , COURIER_RANGE_DTL 
        )
        SELECT
               (NVL((SELECT MAX(SERIALKEY) 
               FROM TM_CARRIER_RANGE), 0) + 1) AS SERIALKEY
             , #{dcCode}       /* 센터코드 */
             , #{courier}      /* 운송사코드 */
             , #{courierRange} /* 운송구간 */
             , #{hjdongCd}     /* 행정동코드 */
             , #{rmk}          /* 비고 */
             , #{fromDate}     /* 적용시작일자 */
             , #{toDate}       /* 적용종료일자 */
             , SYSDATE         /* 최초등록시간 */
             , SYSDATE         /* 최종변경시간 */
             , #{gUserId}      /* 최초등록자(CommonDto) */
             , #{gUserId}      /* 최종변경자(CommonDto) */
             , #{courierRangeDtl}
        FROM DUAL
        WHERE NOT EXISTS (
            SELECT 1
              FROM TM_CARRIER_RANGE X
             WHERE <![CDATA[ X.DCCODE        = #{dcCode}       ]]>
               AND <![CDATA[ X.COURIER       = #{courier}      ]]>
                      AND (
                X.HJDONG_CD LIKE #{hjdongCd} || '%'
             OR #{hjdongCd} LIKE X.HJDONG_CD || '%'
          )
               
       AND NOT ( <![CDATA[ X.TODATE   < #{fromDate} ]]>
             OR <![CDATA[ X.FROMDATE > #{toDate} ]]> )
        )
    </insert>
    
    <update id="updateDistanceBand">
        /* [courierRangeMapper.xml][update][운송구간/행정동 기준정보 수정(UK 중복 방지)][ParkJinWoo][20250911] */
        UPDATE TM_CARRIER_RANGE A
           SET A.DCCODE        = #{dcCode}        /* 센터코드 */
             , A.COURIER       = #{courier}       /* 운송사코드 */
             , A.COURIER_RANGE = #{courierRange}  /* 운송구간 */
             , A.HJDONG_CD     = #{hjdongCd}      /* 행정동코드 */
             , A.RMK           = #{rmk}           /* 비고 */
             , A.FROMDATE      = #{fromDate}      /* 적용시작일자 */
             , A.TODATE        = #{toDate}        /* 적용종료일자 */
             <!-- , A.ADDDATE      = SYSDATE          /* 최종변경시간 */
             , A.ADDWHO       = #{gUserId}       /* 최종변경자(CommonDto) */ -->
             , A.EDITDATE      = SYSDATE          /* 최종변경시간 */
             , A.EDITWHO       = #{gUserId}       /* 최종변경자(CommonDto) */
         WHERE <![CDATA[ A.SERIALKEY = #{serialKey} ]]>
           AND NOT EXISTS (
                SELECT 1
                  FROM TM_CARRIER_RANGE X
                 WHERE <![CDATA[ X.DCCODE        = #{dcCode}       ]]>
                   AND <![CDATA[ X.COURIER       = #{courier}      ]]>
                   
                             AND (
					                X.HJDONG_CD LIKE #{hjdongCd} || '%'
					             OR #{hjdongCd} LIKE X.HJDONG_CD || '%'
	                                 )				         
                   AND <![CDATA[ X.SERIALKEY    <> #{serialKey}    ]]>
                       AND NOT ( <![CDATA[ X.TODATE   < #{fromDate} ]]>
             OR <![CDATA[ X.FROMDATE > #{toDate} ]]> )
           )
    </update>
 <!-- UPDATE (PK 기준) -->
  <update id="updateDistanceBand01">
    UPDATE /* [tmEntityRuleService.sqlx][updatetmEntityRuleService][정산항목 요율 수정][ParkJinWoo][20250811] */
            TM_CARRIER_RANGE A
           SET A.DCCODE        = #{dcCode}        /* 센터코드 */
             , A.COURIER       = #{courier}       /* 운송사코드 */
             , A.COURIER_RANGE = #{courierRange}  /* 운송구간 */
             , A.HJDONG_CD     = #{hjdongCd}      /* 행정동코드 */
             , A.RMK           = #{rmk}           /* 비고 */
<!--              , A.FROMDATE      = #{fromDate}      /* 적용시작일자 */
             , A.TODATE        = #{toDate}        /* 적용종료일자 */ -->
             , A.COURIER_RANGE_DTL = #{courierRangeDtl}
             <!-- , A.ADDDATE      = SYSDATE          /* 최종변경시간 */
             , A.ADDWHO        = #{gUserId}       /* 최종변경자(CommonDto) */ -->
             , A.EDITDATE      = SYSDATE          /* 최종변경시간 */
             , A.EDITWHO       = #{gUserId}       /* 최종변경자(CommonDto) */
       WHERE <![CDATA[ A.DCCODE        = #{dcCode}       ]]>
               AND <![CDATA[ A.COURIER = #{courier}      ]]>
               <!-- AND A.COURIER_RANGE = #{courierRange}  /* 운송구간 */ -->
               AND A.HJDONG_CD     = #{hjdongCd}      /* 행정동코드 */
               AND A.FROMDATE      = #{fromDate}      /* 적용시작일자 */
   

  </update>
<!-- <update id="updateDistanceBand02">
