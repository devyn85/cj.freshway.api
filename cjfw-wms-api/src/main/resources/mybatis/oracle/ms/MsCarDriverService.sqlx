<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="msCarDriverService">
	<!-- 차량정보 정보 조회(목록) -->
    <select id="getMasterList" resultType="MsCarDriverResDto">
    	SELECT /* [msCarDriverService.sqlx][msCarDriverService.getMasterList][차량정보 정보 조회(목록)][jangjaehyun][20250812] */
               DISTINCT
    	       CM_CAR.SERIALKEY,    		   
               MS_CAR_ENTRY_INFO.DCCODE         AS DCCODE,
               (SELECT DCNAME FROM CM_DC WHERE DCCODE = MS_CAR_ENTRY_INFO.DCCODE	) AS DCNAME ,
               MS_CAR_ENTRY_INFO.TC_DCCODE,
               CM_TC.TCNAME,
               CM_CAR.CONTRACTTYPE,
               CM_CAR.CARID,
               CM_CAR.CARNO,
               CM_CAR.CARCAPACITY,
               CM_CAR.OPT_LOAD_WEIGHT,
               CM_CAR.MAXWEIGHT,
               CM_CAR.CARGOSIZE,
               CM_CAR.CARGOTYPE,
               CM_CAR.DTGTYPE,
               CM_CAR.GPSTYPE,
               CM_CAR.VEHICLE_YEAR,
               CM_CAR.OTHER03                   AS CAROTHER03,
               CM_CAR.MAXLANDING,
               CM_CAR.CARGROUP,
               CM_CAR.CHECKCAR,
               CM_CAR.INDT,
               CM_CAR.OUTDT,
               CM_CAR.DOCKNO,
               CM_CAR.LAREA,
               CM_CAR.MAREA,
               CM_CAR.SAREA,
               CM_CAR.LINKCARNO1,
               CM_CAR.LINKCARNO2,
               CM_CAR.LINKCARNO3,
               CM_CAR.SHORTNO,
               CM_CAR.BTSCANNERGIVE,
               CM_CAR.PDAPHONE2,
               CM_CAR.PDAPHONE3,
               CM_CAR.PDAPHONE4,
               CM_CAR.ALLOW_LOGIN_YN,
               CM_CAR.SMPGIVE,
               CM_CAR.PDAPHONE1,
               CM_DRIVER.DRIVERNAME,
               DAMO.DEC(CM_DRIVER.PHONE1)       AS PHONE1,
               DAMO.DEC(CM_DRIVER.PHONE2)       AS PHONE2,
               DAMO.DEC(CM_CAR.PHONE3)          AS PHONE3,
               DAMO.DEC(CM_CAR.PHONE4)          AS PHONE4,
               CM_CAR.DRIVER2,
               CM_CAR.DRIVER3,
               CM_CAR.DRIVER3                   AS DRIVER3D,
               CM_CAR.DRIVER4,
               CM_CAR.DEL_YN,
               CM_CAR.EDITDATE,
               CM_CAR.CARCUBEDESCR,
               CM_DRIVER.DRIVERID               AS DRIVER1,
               CM_CAR.EDITWHO,
               CM_CAR.FROMDATE,
               CM_CAR.TODATE,
               CM_CAR.TODATE2,
               CM_CAR.ADDWHO,
               CM_CAR.ADDDATE,
               CM_CAR.CAR_WIDTH,
               CM_CAR.CAR_LENGTH,
               CM_CAR.VEHICLE_HEIGHT,
               USER1.USER_NM                    AS ADDWHO_NM,  /*등록자명*/
               USER2.USER_NM                    AS EDITWHO_NM  /*수정자명*/
          FROM CM_CAR
     LEFT JOIN CM_DRIVER ON CM_DRIVER.DRIVERID = CM_CAR.DRIVER1
     LEFT JOIN MS_CAR_ENTRY_INFO ON CM_CAR.CARNO = MS_CAR_ENTRY_INFO.CARNO
     LEFT JOIN CM_TC ON MS_CAR_ENTRY_INFO.TC_DCCODE = CM_TC.TCCODE
     LEFT JOIN FRAMEONE_USER USER1 ON USER1.USER_ID = CM_CAR.ADDWHO   /*등록자명*/
     LEFT JOIN FRAMEONE_USER USER2 ON USER2.USER_ID = CM_CAR.EDITWHO  /*수정자명*/
         WHERE 1=1		
        <!-- 차량 다중선택 -->				
        <if test='carNo != null and carNo !=""'>
           AND CM_CAR.CARNO IN
                              ( SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
                                  FROM (SELECT #{carNo} AS VAL FROM DUAL) A
                               CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
        </if>
        <if test='multiDcCode != null and multiDcCode.length > 0'>
           AND (MS_CAR_ENTRY_INFO.DCCODE IN
            <foreach collection="multiDcCode" item="dccodeItem" open="(" separator="," close=")">
                   #{dccodeItem}
            </foreach>
                OR MS_CAR_ENTRY_INFO.DCCODE IS NULL)
        </if>
        <if test="driver1 != null and driver1 != ''">
           AND CM_DRIVER.DRIVERNAME LIKE '%' || #{driver1} || '%'
        </if>
        <if test="delYn != null and delYn != ''">
           AND CM_CAR.DEL_YN LIKE #{delYn}
        </if>
        <if test="contractType != null and contractType != ''">
           AND CM_CAR.CONTRACTTYPE LIKE #{contractType}
        </if>
        <!--TC센터 검색-->
        <if test="tcDcCode != null and tcDcCode != ''">
          AND MS_CAR_ENTRY_INFO.TC_DCCODE = #{tcDcCode}
           </if>
        <!-- 운송사 다중선택 -->				
        <if test='custKey != null and custKey !=""'>
           AND CM_CAR.COURIER IN
                                (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
                                   FROM (SELECT #{custKey} AS VAL FROM DUAL) A
                                CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
        </if>
        <if test="isExpirationDateExpired != null and isExpirationDateExpired != ''">
            <choose>
                <when test='isExpirationDateExpired == "N"'>
          AND NVL(CM_CAR.FROMDATE, '19000101') <![CDATA[>=]]> TO_CHAR(SYSDATE, 'YYYYMMDD')
          AND NVL(CM_CAR.TODATE2, '19000101') <![CDATA[>=]]> TO_CHAR(SYSDATE, 'YYYYMMDD')
          AND NVL(CM_CAR.TODATE, '19000101') <![CDATA[>=]]> TO_CHAR(SYSDATE, 'YYYYMMDD')
                </when>
                 <when test='isExpirationDateExpired == "I"'>
          AND (     NVL(CM_CAR.FROMDATE, '19000101') <![CDATA[<]]> TO_CHAR(SYSDATE-14, 'YYYYMMDD')
                OR  NVL(CM_CAR.TODATE2, '19000101')  <![CDATA[<]]> TO_CHAR(SYSDATE-14, 'YYYYMMDD')
                OR  NVL(CM_CAR.TODATE, '19000101')   <![CDATA[<]]> TO_CHAR(SYSDATE-14, 'YYYYMMDD')
              )
                 </when>
                <otherwise>
          AND (     NVL(CM_CAR.FROMDATE, '19000101') <![CDATA[<]]> TO_CHAR(SYSDATE, 'YYYYMMDD')
                OR  NVL(CM_CAR.TODATE2, '19000101') <![CDATA[<]]> TO_CHAR(SYSDATE, 'YYYYMMDD')
                OR  NVL(CM_CAR.TODATE, '19000101') <![CDATA[<]]> TO_CHAR(SYSDATE, 'YYYYMMDD')
              )
                </otherwise>
            </choose>
        </if>
        ORDER BY MS_CAR_ENTRY_INFO.DCCODE ASC,  CM_CAR.CARID ASC 
        
    </select>
    
    <!-- 차량 정보 조회(단건) -->
    <select id="getMaster" resultType="MsCarDriverDetailResDto">
         SELECT /* [msCarDriverService.sqlx][msCarService.getMaster][차량 정보 조회(단건)][jangjaehyun][20250812] */
	           CM_CAR.SERIALKEY,
	           CM_CAR.SERIALKEY                               AS DRIVERSERIALKEY,
	           CM_CAR.CARID,
	           CM_CAR.CARNO,
	           CM_CAR.SHORTNO,
	           CM_CAR.CARGROUP,
	           CM_CAR.CARTYPE,
	           CM_CAR.CARCATEGORY,
	           CM_CAR.CARCAPACITY,
	           CM_CAR.CARCUBEDESCR,
	           CM_CAR.BRANDNAME,
	           CM_CAR.DEF_DCCODE                              AS DCCODE,
	           CM_CAR.DEF_DISTRICTCODE,
	           CM_CAR.DRIVER2,
	           CM_CAR.DRIVER3,
	           CM_CAR.DRIVER4,
	           CM_DRIVER2.DRIVERNAME                          AS DRIVERNAME2,
	           CM_CAR.GARAGEADDRESS1,
	           CM_CAR.GARAGEADDRESS2,
	           CM_CAR.GARAGEADDRESS3,
	           CM_CAR.GARAGEADDRESS4,
	           CM_CAR.PDAPHONE1,
	           CM_CAR.PDAPHONE2,
	           CM_CAR.PDAPHONE3,
	           CM_CAR.PDAPHONE4,
	           CM_CAR.ALLOW_LOGIN_YN,
	           CM_CAR.OWNER,
	           CM_CAR.CONTRACTTYPE,
	           CM_CAR.CONTRACTDATE,
	           CM_CAR.EXPIREDATE,
	           CM_CAR.CONTRACTPRICE,
	           CM_CAR.CARAGENTKEY,
	           MS_CARRIER2.DESCRIPTION AS CARAGENTNAME,
	           DAMO.DEC(CM_CAR.CARAGENTPHONE) AS CARAGENTPHONE,
	           CM_CAR.CARAGENTFAX,
	           CM_CAR.INSURANCE,
	           CM_CAR.INSUCONTDATE,
	           CM_CAR.INSUEXPIDATE,
	           CM_CAR.CARGOTYPE,
	           CM_CAR.CARGOSIZE,
	           CM_CAR.CARGOCUBE,
	           CM_CAR.MINCUBE,
	           CM_CAR.MAXCUBE,
	           CM_CAR.MINWEIGHT,
	           CM_CAR.MAXWEIGHT,
	           CM_CAR.DTGTYPE,
	           CM_CAR.DTGNO,
	           CM_CAR.DTGCOMMNO,
	           CM_CAR.GPSTYPE,
	           CM_CAR.GPSNO,
	           CM_CAR.GPSCOMMNO,
	           CM_CAR.THERMOMETERTYPE,
	           CM_CAR.THERMOMETERNO,
	           CM_CAR.THERMOMETERCOMMNO,
	           CM_CAR.REFRIGERATORTYPE,
	           CM_CAR.GASTYPE,
	           CM_CAR.GASCUBE,
	           CM_CAR.FUELEFFICIENCY,
	           CM_CAR.BASEFUELEFFICIENCY,
	           CM_CAR.REGISTRATIONDATE,
	           CM_CAR.OTHER01                                 AS CAROTHER01,
	           CM_CAR.OTHER02                                 AS CAROTHER02,
	           CM_CAR.OTHER03                                 AS CAROTHER03,
	           CM_CAR.STATUS,
	           CM_CAR.DEL_YN,
	           CM_CAR.TRAFFICCOP,
	           CM_CAR.ARCHIVECOP,
	           CM_CAR.ADDDATE,
	           CM_CAR.EDITDATE,	           
	           NVL(USER1.USER_NM, CM_CAR.ADDWHO) AS ADDWHO,
	           NVL(USER2.USER_NM, CM_CAR.EDITWHO) AS EDITWHO,
	           CM_CAR.PDASECURITYKEY,
	           CM_CAR.PDASECEXPIDATE,
	           CM_DRIVER1.DRIVERID,
	           CM_DRIVER1.DRIVERNAME,
	           CM_DRIVER1.DRIVERSEX,
	           CM_DRIVER1.DRIVERBIRTHDAY,
	           CM_DRIVER1.DRIVERGROUP,
	           CM_DRIVER1.DRIVERTYPE,
	           CM_DRIVER1.DRIVERCATEGORY,
	           CM_DRIVER1.ADDRESS1,
	           CM_DRIVER1.ADDRESS2,
	           CM_DRIVER1.ADDRESS3,
	           CM_DRIVER1.ADDRESS4,
	           REGEXP_REPLACE(REPLACE(DAMO.DEC(CM_DRIVER1.PHONE1), '-', ''), '([0-9]{3})([0-9]{3,4})([0-9]{4})', '\1-\2-\3')   AS PHONE1,
	           DAMO.DEC(CM_DRIVER1.PHONE2)                    AS PHONE2,
	           DAMO.DEC(CM_CAR.PHONE3)                        AS PHONE3,
	           DAMO.DEC(CM_CAR.PHONE4)                        AS PHONE4,
	           CM_DRIVER1.PDAPHONE1                           AS PDAPHONE1,
	           CM_DRIVER1.PDAPHONE2                           AS PDAPHONE2,
	           CM_DRIVER1.LICENSENO,
	           CM_DRIVER1.LICENSETYPE,
	           CM_DRIVER1.LICENCONTDATE,
	           CM_DRIVER1.LICENEXPIDATE,
	           CM_DRIVER1.VATNO,
	           CM_DRIVER1.VATNAME,
	           CM_DRIVER1.VATOWNER,
	           CM_DRIVER1.VATTYPE,
	           CM_DRIVER1.VATCATEGORY,
	           CM_DRIVER1.VATADDRESS1,
	           CM_DRIVER1.VATADDRESS2,
	           CM_DRIVER1.VATADDRESS3,
	           CM_DRIVER1.VATADDRESS4,
	           CM_DRIVER1.VATPHONE,
	           CM_DRIVER1.VATFAX,
	           CM_DRIVER1.AGENTKEY,
	           CM_DRIVER1.AGENTNAME,
	           CM_DRIVER1.CONTRACTTYPE                        AS CONTRACTTYPE,
	           CM_DRIVER1.CONTRACTDATE                        AS CONTRACTDATE,
	           CM_DRIVER1.EXPIREDATE                          AS EXPIREDATE,
	           CM_DRIVER1.CONTRACTPRICE                       AS CONTRACTPRICE,
	           CM_DRIVER1.INSUCOMPANY,
	           CM_DRIVER1.INSURANCETYPE,
	           CM_DRIVER1.INSURANCE,
	           CM_DRIVER1.INSUCONTDATE,
	           CM_DRIVER1.INSUEXPIDATE,
	           CM_DRIVER1.OTHER01                             AS DRIVEROTHER01,
	           CM_DRIVER1.OTHER02                             AS DRIVEROTHER02,
	           CM_DRIVER1.OTHER03                             AS DRIVEROTHER03,
	           CM_DRIVER1.OTHER04                             AS DRIVEROTHER04,
	           CM_DRIVER1.OTHER05                             AS DRIVEROTHER05,
	           CM_DRIVER1.OTHER05                             AS DRIVEROTHER05,
	           CM_DRIVER1.OTHER05                             AS DRIVEROTHER05,	           
	           CM_CAR.LAREA,
	           CM_CAR.MAREA,
	           CM_CAR.SAREA,
	           CM_CAR.INDT,
	           CM_CAR.OUTDT,
	           CM_CAR.DOCKNO,
	           CM_CAR.CARMEMO,
	           CM_CAR.NOTE,
	           CM_CAR.CHECKCAR,
	           CM_CAR.LINKCARNO1,
	           CM_CAR.LINKCARNO2,
	           CM_CAR.LINKCARNO3,
	           CM_CAR.BTSCANNERGIVE,
	           CM_CAR.SMPGIVE,
	           CM_CAR.DRIVERMEMO,
	           CM_CAR.DRIVERNOTE,
	           CM_CAR.CARGODIVTYPE,
	           CM_CAR.MAXLANDING,
	           (SELECT MAX(MS_DISTRICT.DISTRICTNAME)
	              FROM MS_DISTRICT
	             WHERE MS_DISTRICT.CARNO = (SELECT MAX(CARID) FROM CM_CAR M WHERE M.CARNO = CM_CAR.LINKCARNO1)
	               AND MS_DISTRICT.DCCODE = #{dcCode}) AS LINKCARNAME1,
	           (SELECT MAX(MS_DISTRICT.DISTRICTNAME)
	              FROM MS_DISTRICT
	             WHERE MS_DISTRICT.CARNO = (SELECT MAX(CARID) FROM CM_CAR M WHERE M.CARNO = CM_CAR.LINKCARNO2)
	               AND MS_DISTRICT.DCCODE = #{dcCode}) AS LINKCARNAME2,
	           (SELECT MAX(MS_DISTRICT.DISTRICTNAME)
	              FROM MS_DISTRICT
	             WHERE MS_DISTRICT.CARNO = (SELECT MAX(CARID) FROM CM_CAR M WHERE M.CARNO = CM_CAR.LINKCARNO3)
	               AND MS_DISTRICT.DCCODE = #{dcCode}) AS LINKCARNAME3,
	           (SELECT MAX(MS_DISTRICT.DISTRICTCODE)
	              FROM MS_DISTRICT
	             WHERE MS_DISTRICT.CARNO = CM_CAR.CARID
	               AND MS_DISTRICT.DCCODE = #{dcCode}) AS POPNO,
	           CM_CAR.HJDONG_CD,
	           CM_CAR.FROM_DCCODE,
	           CM_CAR.LATITUDE,
	           CM_CAR.LONGITUDE,
	           CM_CAR.OPT_LOAD_WEIGHT,
	           CM_CAR.VEHICLE_HEIGHT,
	           CM_CAR.VEHICLE_YEAR,
	           CM_CAR.VEHICLE_TYPE_CD,
	           CM_CAR.PROC_YN,
	           CM_CAR.REUSE_YN,
	           CM_CAR.PROC_TYPE_CD,
	           CM_CAR.PROC_FROMHOUR,
	           CM_CAR.PROC_TOHOUR,
	           CM_CAR.OPT_PLT,
               CM_CAR.CAR_WIDTH,
               CM_CAR.CAR_LENGTH,
               CM_CAR.DELIVERY_YN,
               CM_CAR.CARRY_YN,
               CM_CAR.PROC_SAMEDAY_YN,
               CM_CAR.PROC_STORAGE_YN,
               CM_CAR.OWN_CAR_YN,
               CM_CAR.RETURN_YN,
               CM_CAR.SUBDRIVER_YN,
               <!-- CM_CAR.CUSTKEY, -->
               CM_CAR.COURIER AS CUSTKEY,
               MS_CARRIER1.DESCRIPTION AS CUSTNAME,
               NVL(CM_CAR.STTL_YN, 'Y') AS STTL_YN,
               CM_CAR.FROMDATE,
               CM_CAR.TODATE,
               CM_CAR.TODATE2,
               CM_DRIVER1.WORK_FROMHOUR                       AS WORK_FROMHOUR,
	           CM_DRIVER1.WORK_TOHOUR                         AS WORK_TOHOUR,
	           CM_CAR.CAR_ORDERCLOSE_CD,
	           CM_CAR.RADIUS                        AS RADIUS, /* 반경 */
               CM_CAR.STYTIME                       AS STYTIME,   /* 체류시간 */ 
               CM_CAR.BASEWEIGHT_2ND,             /*2회전기본적재중량*/
               CM_CAR.MAXWEIGHT_2ND, /*2회전최대적재중량*/ 
               CM_CAR.BASELANDING_2ND, /*2회전기본착지수*/
               CM_CAR.MAXLANDING_2ND /*2회전최대착지수*/
	      FROM CM_CAR
	      LEFT OUTER JOIN CM_DRIVER CM_DRIVER1 ON CM_DRIVER1.DRIVERID = CM_CAR.DRIVER1
	      LEFT OUTER JOIN CM_DRIVER CM_DRIVER2 ON CM_DRIVER2.DRIVERID = CM_CAR.DRIVER2
	      LEFT OUTER JOIN MS_CARRIER MS_CARRIER1 ON MS_CARRIER1.CARRIERKEY = CM_CAR.COURIER AND MS_CARRIER1.CARRIERTYPE = 'LOCAL'
	      LEFT OUTER JOIN MS_CARRIER MS_CARRIER2 ON MS_CARRIER2.CARRIERKEY = CM_CAR.CARAGENTKEY AND MS_CARRIER2.CARRIERTYPE = 'SUBC'
	      LEFT JOIN FRAMEONE_USER USER1 ON USER1.USER_ID = CM_CAR.ADDWHO   /*등록자명*/
          LEFT JOIN FRAMEONE_USER USER2 ON USER2.USER_ID = CM_CAR.EDITWHO  /*수정자명*/
	     WHERE 1=1 
	    <if test="serialKey != null and serialKey != ''">
	        AND CM_CAR.SERIALKEY = #{serialKey}
	    </if>
	    <if test="carNo != null and carNo != ''">
	        AND CM_CAR.CARNO = #{carNo}
	    </if>		
	</select>
	
	<!-- 차량정보 입출차정보 조회(목록) -->
    <select id="getEntryInfoList" resultType="MsCarDriverEntryInfoResDto">
    	SELECT /* [msCarDriverService.sqlx][msCarDriverService.getEntryInfoList][차량정보 입출차정보 조회(목록)][jangjaehyun][20250904] */
    	         MS_CAR_ENTRY_INFO.SERIALKEY AS ENTRYSERIALKEY
    	       , MS_CAR_ENTRY_INFO.CARNO
    	       , MS_CAR_ENTRY_INFO.DCCODE
    	       , MS_CAR_ENTRY_INFO.OUT_GROUP_CD
    	       , MS_OUT_GROUP.IN_TIME
    	       , MS_OUT_GROUP.OUT_TIME
    	       , MS_CAR_ENTRY_INFO.POPNO
    	       , MS_CAR_ENTRY_INFO.TC_DCCODE
    	       , CM_TC.TCNAME
    	       , MS_CAR_ENTRY_INFO.DOCKNO
    	       , (SELECT LISTAGG(SUB_GROUP.OUT_GROUP_CD, ',') WITHIN GROUP (ORDER BY SUB_GROUP.OUT_GROUP_CD)
		          FROM MS_OUT_GROUP SUB_GROUP
		          WHERE SUB_GROUP.DCCODE = MS_CAR_ENTRY_INFO.DCCODE) AS OUT_GROUP_CD_LIST
		       , (SELECT LISTAGG(CM_CODE.BASEDESCR, ',') WITHIN GROUP (ORDER BY SUB_GROUP.OUT_GROUP_CD)
		          FROM MS_OUT_GROUP SUB_GROUP
		          JOIN CM_CODE ON CM_CODE.BASECODE = SUB_GROUP.OUT_GROUP_CD
		                    AND CM_CODE.CODELIST = 'CARGROUP'
		                    AND CM_CODE.DEL_YN = 'N'
		                    AND CM_CODE.STORERKEY = #{gStorerkey}
		        WHERE SUB_GROUP.DCCODE = MS_CAR_ENTRY_INFO.DCCODE) AS OUT_GROUP_NM_LIST
    	FROM MS_CAR_ENTRY_INFO
    	LEFT OUTER JOIN MS_OUT_GROUP
    	  ON  MS_CAR_ENTRY_INFO.DCCODE = MS_OUT_GROUP.DCCODE
    	 AND  MS_CAR_ENTRY_INFO.OUT_GROUP_CD = MS_OUT_GROUP.OUT_GROUP_CD
    	LEFT JOIN CM_TC
    	  ON MS_CAR_ENTRY_INFO.TC_DCCODE = CM_TC.TCCODE
        WHERE 1=1
          AND MS_CAR_ENTRY_INFO.CARNO = #{carNo}
    </select>
    
    <!-- 차량정보 정보 INSERT -->
    <insert id="insertMaster">			 
		INSERT /* [msCarDriverService.sqlx][msCarDriverService.insertMaster][차량정보 정보 INSERT][jangjaehyun][20250812] */
			INTO CM_CAR
               ( SERIALKEY, DEF_DCCODE, CARNO, CARID, SHORTNO, CARCAPACITY, CARGODIVTYPE, GARAGEADDRESS1, CARGOSIZE,
                 OTHER03, FUELEFFICIENCY, DTGTYPE, DTGNO, CARAGENTKEY, CARAGENTNAME, CARAGENTPHONE, CONTRACTTYPE,
                 MAXWEIGHT, CARGOTYPE, REGISTRATIONDATE, CARGOCUBE, MAXLANDING, BASEFUELEFFICIENCY, GPSTYPE, GPSNO,
                 CARGROUP, CHECKCAR, LAREA, MAREA, SAREA, INDT, OUTDT, DOCKNO, LINKCARNO1, LINKCARNO2, LINKCARNO3,
                 CARMEMO, NOTE, PHONE1, PHONE2, PHONE3, PHONE4, DRIVER1, DRIVER2, DRIVER3, DRIVER4, BTSCANNERGIVE,
                 PDAPHONE2, PDAPHONE3, PDAPHONE4, ALLOW_LOGIN_YN, SMPGIVE, PDAPHONE1, DRIVERMEMO, DRIVERNOTE,
                 THERMOMETERCOMMNO, CUSTKEY, CAR_LENGTH, CAR_WIDTH, VEHICLE_HEIGHT, COURIER, STTL_YN,
                 DELIVERY_YN, CARRY_YN, PROC_SAMEDAY_YN, PROC_STORAGE_YN, OWN_CAR_YN, RETURN_YN, SUBDRIVER_YN,
                 VEHICLE_YEAR, VEHICLE_TYPE_CD, OPT_LOAD_WEIGHT, LATITUDE, LONGITUDE, OPT_PLT, REUSE_YN,
                 GARAGEADDRESS2, GARAGEADDRESS3, GARAGEADDRESS4, PROC_FROMHOUR, PROC_TOHOUR, FROMDATE, TODATE, TODATE2, THERMOMETERNO, CAR_ORDERCLOSE_CD,
                 ADDDATE, EDITDATE, ADDWHO, EDITWHO, RADIUS, STYTIME ,BASEWEIGHT_2ND, MAXWEIGHT_2ND, BASELANDING_2ND, MAXLANDING_2ND
               )
        SELECT SEQ_CM_CAR.NEXTVAL,
               #{dcCode}, #{carNo}, #{carNo}, #{shortNo}, #{carCapacity}, #{cargoDivType}, #{garageAddress1}, #{cargoSize},
               #{carOther03}, #{fuelEfficiency}, #{dtgType}, #{dtgNo}, #{carAgentKey}, #{carAgentName}, #{carAgentPhone}, #{contractType},
               #{maxWeight}, #{cargoType}, #{registrationDate}, #{cargoCube}, #{maxLanding}, #{baseFuelEfficiency}, #{gpsType}, #{gpsNo},
               #{carGroup}, #{checkCar}, #{lArea}, #{mArea}, #{sArea}, #{inDt}, #{outDt}, #{dockNo}, #{linkCarNo1}, #{linkCarNo2}, #{linkCarNo3},
               #{carMemo}, #{note}, DAMO.ENC(#{phone1}), DAMO.ENC(#{phone2}), DAMO.ENC(#{phone3}), DAMO.ENC(#{phone4}),
               #{driverId}, #{driver2}, #{driver3}, #{driver4}, #{btScannerGive}, #{pdaPhone2}, #{pdaPhone3}, #{pdaPhone4},
               #{allowLoginYn}, #{smpGive}, #{pdaPhone1}, #{driverMemo}, #{driverNote}, #{thermometerCommNo},
               #{custKey}, #{carLength}, #{carWidth}, #{vehicleHeight}, #{custKey}, #{sttlYn},
               #{deliveryYn}, #{carryYn}, #{procSamedayYn}, #{procStorageYn}, #{ownCarYn}, #{returnYn}, #{subDriverYn},
               #{vehicleYear}, #{vehicleTypeCd}, #{optLoadWeight}, #{latitude}, #{longitude}, #{optPlt}, #{reuseYn}, 
               #{garageAddress2}, #{garageAddress3}, #{garageAddress4}, #{procFromHour}, #{procToHour}, #{fromDate}, #{toDate}, #{toDate2}, #{thermometerNo}, #{carOrderCloseCd},             
               SYSDATE, SYSDATE, #{gUserId}, #{gUserId}, #{radius}, #{stytime}, #{baseWeight2nd}, #{maxWeight2nd}, #{baseLanding2nd}, #{maxLanding2nd}
          FROM DUAL
    </insert>    
    
    <!-- 차량정보 정보 UPDATE -->
    <update id="updateMaster">		
		UPDATE /* [msCarDriverService.sqlx][msCarDriverService.updateMaster][차량정보 정보 UPDATE][jangjaehyun][20250812] */
		    CM_CAR
           SET DEF_DCCODE = #{dcCode},
               SHORTNO = #{shortNo},
               CARCAPACITY = #{carCapacity},
               CARGODIVTYPE = #{cargoDivType},
               GARAGEADDRESS1 = #{garageAddress1},
               GARAGEADDRESS2 = #{garageAddress2},
               GARAGEADDRESS3 = #{garageAddress3},
               GARAGEADDRESS4 = #{garageAddress4},
               CARGOSIZE = #{cargoSize},
               OTHER03 = #{carOther03},
               FUELEFFICIENCY = #{fuelEfficiency},
               DTGTYPE = #{dtgType},
               DTGNO = #{dtgNo},
               CARAGENTKEY = #{carAgentKey},
               CARAGENTNAME = #{carAgentName},
