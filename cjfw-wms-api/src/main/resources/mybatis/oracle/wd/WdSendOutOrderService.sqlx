<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="wdSendOutOrderService">

    <select id="getDatalistOrder" resultType="WdSendOutOrderResDto">
       SELECT       /* [wdSendOutOrderService.sqlx][getDatalistOrder][오더있는 출고지시서 목록 조회][sunho.kim][2025.06.19] */
            * 
       FROM 
       (
          SELECT 
             A.*
            ,T_FAX_CNT.COUNT                                          AS FAX_CNT     
            ,T_FAX_SUCC_CNT.COUNT                                     AS FAX_SUCC_CNT     
            ,T_FAX_SUCC_TR.TR_PHONE                                   AS FAX_SUCC_TR_PHONE
            ,TO_CHAR(T_FAX_SUCC_TR.TR_SENDDATE, 'YYYYMMDDHH24MI')     AS FAX_SUCC_TR_SENDDATE
            ,T_FAX_SUCC_TR.PRINTUSER                                  AS FAX_SUCC_TR_SENDUSER
            ,USER1.USER_NM                                            AS FAX_SUCC_TR_SENDNAME
            ,T_FAX_FAIL_CNT.COUNT                                     AS FAX_FAIL_CNT
            ,T_FAX_FAIL_TR.TR_PHONE                                   AS FAX_FAIL_TR_PHONE
            ,T_FAX_FAIL_TR.TR_SENDDATE                                AS FAX_FAIL_TR_SENDDATE     
            ,T_FAX_FAIL_TR.PRINTUSER                                  AS FAX_FAIL_TR_SENDUSER
            ,USER2.USER_NM                                            AS FAX_FAIL_TR_SENDNAME
            ,T_EMAIL_CNT.COUNT                                        AS EMAIL_CNT
            ,T_EMAIL_TR.TR_SENDDATE                                   AS EMAIL_TR_SENDDATE
            ,T_EMAIL_TR.PRINTUSER                                     AS EMAIL_TR_SENDUSER
            ,USER3.USER_NM                                            AS EMAIL_TR_SENDNAME
            ,T_PRT_CNT.COUNT                                          AS PRT_CNT
            ,USER4.USER_NM                                            AS ADDWHO_NM
            ,USER5.USER_NM                                            AS DOCNOCONFIRM_NM
          FROM (
              SELECT
                  'Y'                                                                                         AS CHECKTYPE 
                  ,'A'                                                                                        AS CHECKYN
                  ,MAX(DM_DOCUMENT_D.MAPKEY_NO)                                                               AS MAPKEY_NO
                  ,WD_INPLAN.DCCODE                                                                           AS DCCODE
                  ,WD_INPLAN.STORERKEY                                                                        AS STORERKEY
                  ,WD_INPLAN.ORGANIZE                                                                         AS ORGANIZE
                  ,FN_DESCR_ORGANIZE(WD_INPLAN.DCCODE, WD_INPLAN.ORGANIZE)                                    AS ORGANIZENAME
                  ,'WD'                                                                                       AS DOCTYPE
                  ,DM_DOCUMENT_D.CHANNEL                                                                      AS CHANNEL
                  ,MAX(DM_DOCUMENT_H.DOCNO)                                                                   AS NORMAL_NO
                  ,WD_INPLAN.DOCDT                                                                            AS DOCDT
                  ,WD_INPLAN.DOCNO                                                                            AS DOCNO
                  ,WD_INPLAN.DOCLINE                                                                          AS DOCLINE
                  ,WD_INPLAN.SLIPTYPE                                                                         AS SLIPTYPE
                  ,WD_INPLAN.SLIPDT                                                                           AS SLIPDT
                  ,WD_INPLAN.SLIPNO                                                                           AS SLIPNO
                  ,WD_INPLAN.SLIPLINE                                                                         AS SLIPLINE
                  ,WD_INPLAN.CUSTKEY                                                                          AS CUSTKEY
                  ,( SELECT MAX(CUST_C.DESCRIPTION)           
                     FROM MS_CUST CUST_C
                     WHERE  CUST_C.STORERKEY = WD_INPLAN.STORERKEY
                     AND    CUST_C.CUSTKEY   = WD_INPLAN.CUSTKEY )                                            AS CUSTNAME
                  ,WD_INPLAN.SKU                                                                              AS SKU
                  ,MAX(MS_SKU.DESCRIPTION)                                                                    AS SKUNAME
                  ,DM_DOCUMENT_D.STOREROPENQTY                                                                AS ORDERQTY
                  ,DM_DOCUMENT_D.STORERUOM                                                                    AS STORERUOM 
                  ,FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE), MAX(MS_SKU.DURATION)
                                              , MAX(ST_SNINFO.LOTTABLE01), 'Y')                               AS NEARDURATIONYN
                  ,MAX(ST_SNINFO.LOTTABLE01)                                                                  AS LOTTABLE01                  
                  ,CASE WHEN FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE), MAX(MS_SKU.DURATION), MAX(ST_SNINFO.LOTTABLE01), 'N') > 0 
                        THEN ROUND(FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE), MAX(MS_SKU.DURATION), MAX(ST_SNINFO.LOTTABLE01), 'N') / MAX(MS_SKU.DURATION) * 100) 
                        ELSE 0 
                   END                                                                                        AS USEBYDATE_FREE_RT   
                  ,FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE), MAX(MS_SKU.DURATION)                    
                                              , MAX(ST_SNINFO.LOTTABLE01), 'N') ||'/'|| MAX(MS_SKU.DURATION)  AS DURATION_TERM
                  ,MAX(ST_SNINFO.SERIALNO)                                                                    AS SERIALNO  
                  ,MAX(ST_SNINFO.FACTORYNAME)                                                                 AS FACTORYNAME
                  ,MAX(ST_SNINFO.PLACEOFORIGIN)                                                               AS PLACEOFORIGIN
                  ,MAX(ST_SNINFO.CONVSERIALNO)                                                                AS CONVSERIALNO
                  ,MAX(ST_SNINFO.BUTCHERYDT)                                                                  AS BUTCHERYDT
                  ,MAX(ST_SNINFO.CONTRACTCUSTKEY)                                                             AS CONTRACTCOMPANY
                  ,MAX((SELECT DESCRIPTION FROM MS_CUST                                                         
                        WHERE  MS_CUST.STORERKEY = ST_SNINFO.STORERKEY                                      
                        AND    MS_CUST.CUSTKEY   = ST_SNINFO.CONTRACTCUSTKEY                                
                        AND    ROWNUM = 1 ))                                                                  AS CONTRACTCOMPANYNAME
                  ,MAX(ST_SNINFO.FROMVALIDDT)                                                                 AS FROMVALIDDT
                  ,MAX(ST_SNINFO.TOVALIDDT)                                                                   AS TOVALIDDT
                  ,MAX(CD1.BASEDESCR)                                                                         AS CONTRACTTYPE 
                  ,MAX(ST_SNINFO.STOCKID)                                                                     AS BARCODE
                  ,MAX(WD_INVOICE_SN.WEIGHT)                                                                  AS GROSSWEIGHT
                  ,MAX(DM_DOCUMENT_D.ADDWHO)                                                                  AS ADDWHO            /*생성인*/
                  ,CASE WHEN TO_NUMBER(NVL(MS_SKU.LINE02,0)) <![CDATA[<>]]> 0 
                         AND WD_INPLAN.DCCODE      = '2170' 
                         AND NVL(MS_SKU.LINE01,'N') = 'Y'          THEN TO_NUMBER(NVL(MS_SKU.LINE02,0)) 
                        ELSE 0 
                   END                                                                                        AS AVGWEIGHT       /* 평균중량    */
                  ,ROUND(CASE WHEN TO_NUMBER(NVL(MS_SKU.LINE02,0)) <![CDATA[<>]]> 0 
                              AND WD_INPLAN.DCCODE       = '2170' 
                              AND NVL(MS_SKU.LINE01,'N') = 'Y'    THEN (MAX(DM_DOCUMENT_D.STOREROPENQTY)) / TO_NUMBER(NVL(MS_SKU.LINE02,0)) 
                              ELSE 0 
                         END ,3)                                                                              AS CALBOX          /* 환산박스    */       
                  ,CASE WHEN WD_INPLAN.DCCODE       = '2170' 
                         AND NVL(MS_SKU.LINE01,'N') = 'Y'          THEN NVL(WD_INVOICE_SN.ETCQTY1,0)                                                                                                  
                        ELSE 0
                   END                                                                                        AS REALORDERBOX    /* 실박스예정 */
                  ,CASE WHEN WD_INPLAN.DCCODE       = '2170' 
                         AND NVL(MS_SKU.LINE01,'N') = 'Y'          THEN NVL(WD_INVOICE_SN.ETCQTY2,0)
                        ELSE 0
                   END                                                                                        AS REALCFMBOX      /* 실박스확정 */
                  ,ROUND(DECODE(DM_DOCUMENT_D.STORERUOM,'KG'
                               ,MAX(DM_DOCUMENT_D.QCQTY),FN_CONV_UOM(WD_INPLAN.STORERKEY,WD_INPLAN.SKU,DM_DOCUMENT_D.STORERUOM,'BOX',DM_DOCUMENT_D.STOREROPENQTY))
                               ,3)                                                                            AS BOXQTY                 
                  ,'BOX'                                                                                      AS BOXUOM                              
                  ,CASE WHEN WD_INPLAN.DCCODE       = '2170' 
                         AND NVL(MS_SKU.LINE01,'N') = 'Y'          THEN 'Y'
                        ELSE 'N'
                   END                                                                                        AS BOXFLAG
                  ,CASE WHEN     sum(DM_DOCUMENT_D.CANCELQTY) <![CDATA[>]]> 0 
                             AND sum(DM_DOCUMENT_D.CONFIRMQTY) = 0 
                             AND min(DM_DOCUMENT_D.STATUS)     = '90'  THEN  'Y'
                        ELSE 'N'
                   END                                                                                        AS ALL_CANCEL_STATUS
                  ,MAX(CD2.BASEDESCR)                                                                         AS DELIVERYTYPENAME
                  ,MAX(MS_PLANTXSL.FAX)                                                                       AS RECVFAXNO  
                  ,MAX(MS_PLANTXSL.DESCRIPTION)                                                               AS RECVNAME
                  ,MAX(MS_PLANTXSL.EMAIL)                                                                     AS RECVEMAIL 
                  ,DM_DOCUMENT_D.MEMO1                                                                        AS MEMO1
                  ,WD_EXDC_DOCUMENT.MEMO1                                                                     AS MEMO2
                  ,MAX(MS_PLANTXSL.COMM_CODE)                                                                 AS COMM_CODE
                  ,''                                                                                         AS ADDDATE
                  ,''                                                                                         AS DOCNOCONFIRM
                  ,MAX(MS_SKU.QTYPERBOX)                                                                      AS QTYPERBOX
                   
               FROM   WD_INPLAN   
   
               JOIN   CM_USER_AUTHORITY           
               ON     1=1     
               <if test="fixdccode != null and fixdccode != ''">           
                   AND    CM_USER_AUTHORITY.DCCODE     =  #{fixdccode}          
               </if>
               <if test="gStorerkey != null and gStorerkey != ''">       
                   AND    CM_USER_AUTHORITY.STORERKEY  =  #{gStorerkey}       
               </if>
               <if test="area != null and area != ''">     
                   AND    CM_USER_AUTHORITY.AREA       =  #{area}                
               </if>    
               <if test="organizeMulti != null and organizeMulti != ''">
                   AND    CM_USER_AUTHORITY.ORGANIZE      IN
                 <foreach collection="organizeMulti" item="item" open="(" separator="," close=")">
                     #{item}
                 </foreach> 
               </if>
                   AND    CM_USER_AUTHORITY.USERID     = #{gUserId}    
                   AND    CM_USER_AUTHORITY.DCCODE     = WD_INPLAN.DCCODE             
                   AND    CM_USER_AUTHORITY.STORERKEY  = WD_INPLAN.STORERKEY          
                   AND    CM_USER_AUTHORITY.ORGANIZE   = WD_INPLAN.ORGANIZE           
                   AND    CM_USER_AUTHORITY.AREA       = WD_INPLAN.AREA                        
               JOIN DM_DOCUMENT_D           
                   ON   DM_DOCUMENT_D.DCCODE         = WD_INPLAN.DCCODE                 
                   AND  DM_DOCUMENT_D.DOCTYPE        = WD_INPLAN.DOCTYPE                
                   AND  DM_DOCUMENT_D.DELIVERYDATE   = WD_INPLAN.SLIPDT                  
                   AND  DM_DOCUMENT_D.DOCNO          = WD_INPLAN.DOCNO                  
                   AND  DM_DOCUMENT_D.DOCLINE        = WD_INPLAN.DOCLINE           
               JOIN MS_SKU          
                   ON   MS_SKU.STORERKEY             =  WD_INPLAN.STORERKEY                 
                   AND  MS_SKU.SKU                   =  WD_INPLAN.SKU        
                   AND  MS_SKU.DEL_YN                = 'N'             
               LEFT OUTER JOIN WD_INVOICE_SN              
                   ON   WD_INVOICE_SN.DCCODE         = WD_INPLAN.DCCODE                                 
                   AND  WD_INVOICE_SN.STORERKEY      = WD_INPLAN.STORERKEY                      
                   AND  WD_INVOICE_SN.DOCTYPE        = WD_INPLAN.DOCTYPE              
                   AND  WD_INVOICE_SN.WD_SLIPNO      = WD_INPLAN.SLIPNO                                            
                   AND  WD_INVOICE_SN.WD_SLIPDT      = WD_INPLAN.SLIPDT                                 
                   AND  WD_INVOICE_SN.WD_SLIPLINE    = WD_INPLAN.SLIPLINE                                 
                   AND  WD_INVOICE_SN.SKU            = WD_INPLAN.SKU                    
               LEFT OUTER JOIN ST_SNINFO                                      
                   ON    ST_SNINFO.STORERKEY         = WD_INVOICE_SN.STORERKEY               
                   AND   ST_SNINFO.SKU               = WD_INVOICE_SN.SKU                     
                   AND   ST_SNINFO.STOCKID           = WD_INVOICE_SN.STOCKID 
               LEFT OUTER JOIN MS_PLANTXSL 
                   ON  DM_DOCUMENT_D.DCCODE          = MS_PLANTXSL.DCCODE
                   AND DM_DOCUMENT_D.PLANT           = MS_PLANTXSL.PLANT
                   AND DM_DOCUMENT_D.STORAGELOC      = MS_PLANTXSL.STORAGELOC
               LEFT OUTER JOIN WD_EXDC_DOCUMENT 
                   ON   WD_EXDC_DOCUMENT.DCCODE      = WD_INPLAN.DCCODE
                   AND  WD_EXDC_DOCUMENT.STORERKEY   = WD_INPLAN.STORERKEY               
                   AND  WD_EXDC_DOCUMENT.DOCNO       = WD_INPLAN.DOCNO                  
                   AND  WD_EXDC_DOCUMENT.DOCLINE     = WD_INPLAN.DOCLINE  
               LEFT OUTER JOIN WD_AUTO_EXDCINSTRUCT
                   ON WD_AUTO_EXDCINSTRUCT.DOCNO     = WD_INPLAN.DOCNO
                   AND WD_AUTO_EXDCINSTRUCT.DOCLINE  = WD_INPLAN.DOCLINE
               LEFT OUTER JOIN DM_EXDC_AUTOORD_CHECK
                  ON DM_EXDC_AUTOORD_CHECK.SOKEY     = WD_AUTO_EXDCINSTRUCT.DOCNO
               LEFT OUTER JOIN DM_DOCUMENT_H 
                  ON   DM_DOCUMENT_H.DCCODE         = WD_INPLAN.DCCODE
                  AND  DM_DOCUMENT_H.DOCTYPE        = WD_INPLAN.DOCTYPE  
                  AND  DM_DOCUMENT_H.DELIVERYDATE   = WD_INPLAN.SLIPDT   
                  AND  DM_DOCUMENT_H.DOCNO          = WD_INPLAN.DOCNO 
                  AND  DM_DOCUMENT_H.DOCTYPE        = 'WD'
                  AND  DM_DOCUMENT_H.REAL_YN        = 'R' 
              LEFT OUTER JOIN CM_CODE_STORER CD1
                  ON   CD1.STORERKEY                = WD_INPLAN.STORERKEY
                  AND  CD1.CODELIST                 = 'CONTRACTTYPE_SN'   
                  AND  CD1.BASECODE                 = ST_SNINFO.CONTRACTTYPE
              LEFT OUTER JOIN CM_CODE_STORER CD2
                  ON   CD2.STORERKEY                = WD_INPLAN.STORERKEY
                  AND  CD2.CODELIST                 = 'DELIVERYTYPE'   
                  AND  CD2.BASECODE                 = (SELECT CASE WHEN DM_DOCUMENT_H.WORKPROCESSCODE = 'STO' THEN 'WOD'
                                                                   ELSE DM_DOCUMENT_H.DELIVERYTYPE
                                                               END
                                                       FROM  DM_DOCUMENT_H 
                                                       WHERE DM_DOCUMENT_H.DCCODE         = WD_INPLAN.DCCODE                            
                                                        AND  DM_DOCUMENT_H.DOCTYPE        = WD_INPLAN.DOCTYPE                
                                                        AND  DM_DOCUMENT_H.DELIVERYDATE   = WD_INPLAN.SLIPDT                     
                                                        AND  DM_DOCUMENT_H.DOCNO          = WD_INPLAN.DOCNO)            
           
              WHERE 1=1
                AND WD_INPLAN.DEL_YN             = 'N'
              <if test="exdcinstructtype == 'RETURN'"> 
                AND WD_INPLAN.ORDERTYPE       = 'RP'
              </if>
              <if test="exdcinstructtype == 'ORDER'">
                AND WD_INPLAN.ORDERTYPE       != 'RP'
              </if> 
                AND DM_DOCUMENT_D.STORERKEY      = #{gStorerkey}
                AND DM_DOCUMENT_D.DCCODE         = #{fixdccode}
              <if test="organizeMulti != null and organizeMulti != ''">
                AND DM_DOCUMENT_D.ORGANIZE      IN
                 <foreach collection="organizeMulti" item="item" open="(" separator="," close=")">
                     #{item}
                 </foreach> 
               </if>  
                AND DM_DOCUMENT_D.DOCTYPE        = 'WD' 
                AND DM_DOCUMENT_D.DEL_YN         = 'N'
                AND DM_DOCUMENT_D.DELIVERYDATE <![CDATA[>=]]> #{fromSlipdt}
                AND DM_DOCUMENT_D.DELIVERYDATE <![CDATA[<=]]> #{toSlipdt}
                AND DM_DOCUMENT_D.MAPKEY_NO IS NULL
              <if test="docnoMulti != null and docnoMulti != ''">
                AND DM_DOCUMENT_D.DOCNO      IN
                 <foreach collection="docnoMulti" item="item" open="(" separator="," close=")">
                     #{item}
                 </foreach> 
              </if>    
              <if test="blnoMulti != null and blnoMulti != ''">
                AND ST_SNINFO.CONVSERIALNO      IN
                 <foreach collection="blnoMulti" item="item" open="(" separator="," close=")">
                     #{item}
                 </foreach> 
              </if>        
              <if test="tocustkeyMulti != null and tocustkeyMulti != ''">
                AND WD_INPLAN.CUSTKEY IN
                <foreach collection="tocustkeyMulti" item="item" open="(" separator="," close=")">
                   #{item}
                </foreach> 
              </if>
              <if test="sku != null and sku != '' ">
                  <if test="skuMulti != null and skuMulti.size() > 0">
                      <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                          <foreach collection="skuMulti" item="item">
                        OR DM_DOCUMENT_D.SKU IN
                            <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}      
                            </foreach>
                          </foreach>
                      </trim>                                             
                  </if>
              </if>    
           GROUP BY 
                 WD_INPLAN.DCCODE                  
                ,WD_INPLAN.STORERKEY               
                ,WD_INPLAN.ORGANIZE                
                ,DM_DOCUMENT_D.CHANNEL             
                ,WD_INPLAN.DOCDT                   
                ,WD_INPLAN.DOCNO                   
                ,WD_INPLAN.DOCLINE                 
                ,WD_INPLAN.SLIPTYPE                
                ,WD_INPLAN.SLIPDT                  
                ,WD_INPLAN.SLIPNO                  
                ,WD_INPLAN.SLIPLINE                
                ,WD_INPLAN.CUSTKEY                 
                ,DM_DOCUMENT_D.STOREROPENQTY 
                ,DM_DOCUMENT_D.STORERUOM       
                ,WD_INPLAN.SKU
                ,MS_SKU.LINE01
                ,MS_SKU.LINE02
                ,WD_INVOICE_SN.ETCQTY1
                ,WD_INVOICE_SN.ETCQTY2 
                ,DM_DOCUMENT_D.MEMO1 
                ,WD_EXDC_DOCUMENT.MEMO1                     
          ) A 
                     
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY 
                                 , WD_EXDC_PRTLOG.DCCODE
                                 , WD_EXDC_PRTLOG.DOCNO
                                 , WD_EXDC_PRTLOG.DOCLINE
                                 , COUNT(1)  AS COUNT
                            FROM WD_EXDC_PRTLOG
                            --JOIN FC_META_TRAN 
                            --     ON WD_EXDC_PRTLOG.DOCNAME = FC_META_TRAN.TR_DOCNAME   
                            -- JOIN FC_MSG_TRAN
                            --     ON FC_META_TRAN.TR_BATCHID = FC_MSG_TRAN.TR_BATCHID
                            WHERE   WD_EXDC_PRTLOG.PAPERTYPE = 'FAX'
                              AND   WD_EXDC_PRTLOG.DCCODE    = #{fixdccode}
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY 
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE
                        )  T_FAX_CNT
                ON      T_FAX_CNT.STORERKEY = A.STORERKEY         
                    AND T_FAX_CNT.DCCODE    = A.DCCODE         
                    AND T_FAX_CNT.DOCNO     = A.DOCNO         
                    AND T_FAX_CNT.DOCLINE   = A.DOCLINE   
       
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY 
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , COUNT(1)  AS COUNT
                            FROM WD_EXDC_PRTLOG
                             JOIN FC_META_TRAN 
                                ON WD_EXDC_PRTLOG.DOCNAME = FC_META_TRAN.TR_DOCNAME   
                             JOIN FC_MSG_TRAN
                                ON FC_META_TRAN.TR_BATCHID = FC_MSG_TRAN.TR_BATCHID
                            WHERE   WD_EXDC_PRTLOG.PAPERTYPE = 'FAX'
                              AND   WD_EXDC_PRTLOG.DCCODE    = #{fixdccode}
                                AND FC_MSG_TRAN.TR_SENDSTAT  = '2'
                                AND FC_MSG_TRAN.TR_RSLTSTAT  = '0'
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY 
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE  
                        )  T_FAX_SUCC_CNT
                ON      T_FAX_SUCC_CNT.STORERKEY = A.STORERKEY         
                    AND T_FAX_SUCC_CNT.DCCODE    = A.DCCODE         
                    AND T_FAX_SUCC_CNT.DOCNO     = A.DOCNO         
                    AND T_FAX_SUCC_CNT.DOCLINE   = A.DOCLINE     
      
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY 
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , COUNT(1)  AS COUNT
                            FROM WD_EXDC_PRTLOG
                             JOIN FC_META_TRAN 
                                 ON WD_EXDC_PRTLOG.DOCNAME = FC_META_TRAN.TR_DOCNAME   
                             JOIN FC_MSG_TRAN
                                 ON FC_META_TRAN.TR_BATCHID = FC_MSG_TRAN.TR_BATCHID
                            WHERE   WD_EXDC_PRTLOG.PAPERTYPE = 'FAX'
                                AND WD_EXDC_PRTLOG.DCCODE    = #{fixdccode}
                                AND FC_MSG_TRAN.TR_SENDSTAT  = '2'
                                AND FC_MSG_TRAN.TR_RSLTSTAT  NOT IN ('0','-')
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY 
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE  
                        )  T_FAX_FAIL_CNT
                ON    T_FAX_FAIL_CNT.STORERKEY = A.STORERKEY         
                  AND T_FAX_FAIL_CNT.DCCODE    = A.DCCODE         
                  AND T_FAX_FAIL_CNT.DOCNO     = A.DOCNO         
                  AND T_FAX_FAIL_CNT.DOCLINE   = A.DOCLINE                                                                   

            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , MAX(WD_EXDC_PRTLOG.DOCNAME) AS DOCNAME
                                , MAX(WD_EXDC_PRTLOG.SERIALKEY) AS SERIALKEY
                                , MAX(FC_META_TRAN.TR_BATCHID) AS TR_BATCHID
                                , MAX(FC_MSG_TRAN.TR_PHONE) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_PHONE
                                , MAX(FC_META_TRAN.TR_SENDDATE) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_SENDDATE
                                , MAX(FC_META_TRAN.TR_SENDNAME) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_SENDNAME
                                , MAX(WD_EXDC_PRTLOG.PRINTUSER) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS PRINTUSER
                            FROM (SELECT WD_EXDC_PRTLOG.STORERKEY
                                        , WD_EXDC_PRTLOG.DCCODE
                                        , WD_EXDC_PRTLOG.DOCNO
                                        , WD_EXDC_PRTLOG.DOCLINE
                                        , MAX(WD_EXDC_PRTLOG.SERIALKEY) AS SERIALKEY
                                        , MAX(WD_EXDC_PRTLOG.DOCNAME) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS DOCNAME
                                        , MAX(WD_EXDC_PRTLOG.PRINTUSER) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS PRINTUSER
                                  FROM WD_EXDC_PRTLOG
                                  WHERE WD_EXDC_PRTLOG.PAPERTYPE = 'FAX'
                                    AND WD_EXDC_PRTLOG.DCCODE    = #{fixdccode}
                                  GROUP BY WD_EXDC_PRTLOG.STORERKEY
                                        , WD_EXDC_PRTLOG.DCCODE
                                        , WD_EXDC_PRTLOG.DOCNO
                                        , WD_EXDC_PRTLOG.DOCLINE
                                ) WD_EXDC_PRTLOG 
                             JOIN FC_META_TRAN 
                                 ON WD_EXDC_PRTLOG.DOCNAME = FC_META_TRAN.TR_DOCNAME   
                             JOIN FC_MSG_TRAN
                                 ON FC_META_TRAN.TR_BATCHID = FC_MSG_TRAN.TR_BATCHID
                             WHERE   FC_MSG_TRAN.TR_SENDSTAT  = '2'
                                 AND FC_MSG_TRAN.TR_RSLTSTAT  = '0'
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE
                        )  T_FAX_SUCC_TR
                ON    T_FAX_SUCC_TR.STORERKEY = A.STORERKEY         
                  AND T_FAX_SUCC_TR.DCCODE    = A.DCCODE         
                  AND T_FAX_SUCC_TR.DOCNO     = A.DOCNO         
                  AND T_FAX_SUCC_TR.DOCLINE   = A.DOCLINE      
       
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , MAX(WD_EXDC_PRTLOG.DOCNAME) AS DOCNAME
                                , MAX(WD_EXDC_PRTLOG.SERIALKEY) AS SERIALKEY
                                , MAX(FC_META_TRAN.TR_BATCHID) AS TR_BATCHID
                                , MAX(FC_MSG_TRAN.TR_PHONE) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_PHONE
                                , MAX(FC_META_TRAN.TR_SENDDATE) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_SENDDATE
                                , MAX(WD_EXDC_PRTLOG.PRINTUSER) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS PRINTUSER
                                , MAX(FC_META_TRAN.TR_SENDNAME) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_SENDNAME
                            FROM (SELECT WD_EXDC_PRTLOG.STORERKEY
                                        , WD_EXDC_PRTLOG.DCCODE
                                        , WD_EXDC_PRTLOG.DOCNO
                                        , WD_EXDC_PRTLOG.DOCLINE
                                        , MAX(WD_EXDC_PRTLOG.SERIALKEY) AS SERIALKEY
                                        , MAX(WD_EXDC_PRTLOG.DOCNAME) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS DOCNAME
                                        , MAX(WD_EXDC_PRTLOG.PRINTUSER) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS PRINTUSER
                                    FROM WD_EXDC_PRTLOG
                                    WHERE WD_EXDC_PRTLOG.PAPERTYPE = 'FAX'
                                      AND WD_EXDC_PRTLOG.DCCODE    = #{fixdccode}
                                    GROUP BY WD_EXDC_PRTLOG.STORERKEY
                                            , WD_EXDC_PRTLOG.DCCODE
                                            , WD_EXDC_PRTLOG.DOCNO
                                            , WD_EXDC_PRTLOG.DOCLINE
                                ) WD_EXDC_PRTLOG 
                            JOIN FC_META_TRAN 
                                ON WD_EXDC_PRTLOG.DOCNAME = FC_META_TRAN.TR_DOCNAME   
                            JOIN FC_MSG_TRAN
                                ON FC_META_TRAN.TR_BATCHID = FC_MSG_TRAN.TR_BATCHID
                            WHERE   FC_MSG_TRAN.TR_SENDSTAT  = '2'
                                AND FC_MSG_TRAN.TR_RSLTSTAT  NOT IN ('0','-')
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE
                        )  T_FAX_FAIL_TR
                ON    T_FAX_FAIL_TR.STORERKEY = A.STORERKEY         
                  AND T_FAX_FAIL_TR.DCCODE    = A.DCCODE         
                  AND T_FAX_FAIL_TR.DOCNO     = A.DOCNO         
                  AND T_FAX_FAIL_TR.DOCLINE   = A.DOCLINE  
       
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY 
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , COUNT(1)  AS COUNT
                            FROM WD_EXDC_PRTLOG
                            WHERE WD_EXDC_PRTLOG.PAPERTYPE = 'EMAIL'
                              AND WD_EXDC_PRTLOG.DCCODE    = #{fixdccode}
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY 
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE
                        )  T_EMAIL_CNT
                ON    T_EMAIL_CNT.STORERKEY = A.STORERKEY         
                  AND T_EMAIL_CNT.DCCODE    = A.DCCODE         
                  AND T_EMAIL_CNT.DOCNO     = A.DOCNO         
                  AND T_EMAIL_CNT.DOCLINE   = A.DOCLINE      
       
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , MAX(WD_EXDC_PRTLOG.SERIALKEY) AS SERIALKEY
                                , MAX(WD_EXDC_PRTLOG.PRINTUSER) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS PRINTUSER                     
                                , MAX(WD_EXDC_PRTLOG.PRINTDT) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_SENDDATE
                            FROM WD_EXDC_PRTLOG 
                            WHERE WD_EXDC_PRTLOG.PAPERTYPE = 'EMAIL'
                              AND WD_EXDC_PRTLOG.DCCODE    = #{fixdccode}
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE
                        )  T_EMAIL_TR
                ON    T_EMAIL_TR.STORERKEY = A.STORERKEY         
                  AND T_EMAIL_TR.DCCODE    = A.DCCODE         
                  AND T_EMAIL_TR.DOCNO     = A.DOCNO         
                  AND T_EMAIL_TR.DOCLINE   = A.DOCLINE                   
           
            LEFT OUTER JOIN(SELECT WD.STORERKEY
                                , WD.DCCODE
                                , WD.DOCNO
                                , WD.DOCLINE
                                , COUNT(1) AS COUNT
                        FROM WD_EXDC_PRTLOG WD
                        WHERE WD.PAPERTYPE = 'PRINT'
                          AND WD.DCCODE    = #{fixdccode}
                        GROUP BY WD.STORERKEY
                                , WD.DCCODE
                                , WD.DOCNO
                                , WD.DOCLINE
                      )  T_PRT_CNT
                ON    T_PRT_CNT.STORERKEY = A.STORERKEY         
                  AND T_PRT_CNT.DCCODE    = A.DCCODE         
                  AND T_PRT_CNT.DOCNO     = A.DOCNO         
                  AND T_PRT_CNT.DOCLINE   = A.DOCLINE               
            
            LEFT OUTER JOIN FRAMEONE_USER USER1
                ON   USER1.USER_ID        = T_FAX_SUCC_TR.PRINTUSER 
                
            LEFT OUTER JOIN FRAMEONE_USER USER2
                ON   USER2.USER_ID        = T_FAX_FAIL_TR.PRINTUSER
                
            LEFT OUTER JOIN FRAMEONE_USER USER3
                ON   USER3.USER_ID        = T_EMAIL_TR.PRINTUSER
             
            LEFT OUTER JOIN FRAMEONE_USER USER4
                ON   USER4.USER_ID        = A.ADDWHO   
                
            LEFT OUTER JOIN FRAMEONE_USER USER5
                ON  (USER5.USER_ID        = A.DOCNOCONFIRM 
                     OR USER5.USER_NO     = A.DOCNOCONFIRM)
          
        UNION ALL                
                
        SELECT 
              A.*
            ,T_FAX_CNT.COUNT                                          AS FAX_CNT     
            ,T_FAX_SUCC_CNT.COUNT                                     AS FAX_SUCC_CNT     
            ,T_FAX_SUCC_TR.TR_PHONE                                   AS FAX_SUCC_TR_PHONE
            ,TO_CHAR(T_FAX_SUCC_TR.TR_SENDDATE, 'YYYYMMDDHH24MI')     AS FAX_SUCC_TR_SENDDATE
            ,T_FAX_SUCC_TR.PRINTUSER                                  AS FAX_SUCC_TR_SENDUSER
            ,USER1.USER_NM                                            AS FAX_SUCC_TR_SENDNAME
            ,T_FAX_FAIL_CNT.COUNT                                     AS FAX_FAIL_CNT
            ,T_FAX_FAIL_TR.TR_PHONE                                   AS FAX_FAIL_TR_PHONE
            ,T_FAX_FAIL_TR.TR_SENDDATE                                AS FAX_FAIL_TR_SENDDATE     
            ,T_FAX_FAIL_TR.PRINTUSER                                  AS FAX_FAIL_TR_SENDUSER
            ,USER2.USER_NM                                            AS FAX_FAIL_TR_SENDNAME
            ,T_EMAIL_CNT.COUNT                                        AS EMAIL_CNT
            ,T_EMAIL_TR.TR_SENDDATE                                   AS EMAIL_TR_SENDDATE
            ,T_EMAIL_TR.PRINTUSER                                     AS EMAIL_TR_SENDUSER
            ,USER3.USER_NM                                            AS EMAIL_TR_SENDNAME
            ,T_PRT_CNT.COUNT                                          AS PRT_CNT
            ,USER4.USER_NM                                            AS ADDWHO_NM
            ,USER5.USER_NM                                            AS DOCNOCONFIRM_NM
        FROM (        
              SELECT 
                 CASE WHEN MAX(WD_AUTO_EXDCINSTRUCT.MAPKEY_NO) IS NOT NULL THEN 'Y' ELSE 'N' END          AS CHECKTYPE      
                ,'B'                                                                                      AS CHECKYN
                ,MAX(WD_AUTO_EXDCINSTRUCT.MAPKEY_NO)                                                      AS MAPKEY_NO
                ,WD_AUTO_EXDCINSTRUCT.DCCODE                                                              AS DCCODE
                ,WD_AUTO_EXDCINSTRUCT.STORERKEY                                                           AS STORERKEY
                ,WD_AUTO_EXDCINSTRUCT.ORGANIZE                                                            AS ORGANIZE
                ,FN_DESCR_ORGANIZE(WD_AUTO_EXDCINSTRUCT.DCCODE, WD_AUTO_EXDCINSTRUCT.ORGANIZE)            AS ORGANIZENAME
                ,'WD'                                                                                     AS DOCTYPE
                ,''                                                                                       AS CHANNEL
                ,''                                                                                       AS NORMAL_NO
                ,WD_AUTO_EXDCINSTRUCT.SLIPDT                                                              AS DOCDT
                ,WD_AUTO_EXDCINSTRUCT.DOCNO                                                               AS DOCNO
                ,WD_AUTO_EXDCINSTRUCT.DOCLINE                                                             AS DOCLINE
                ,''                                                                                       AS SLIPTYPE
                ,WD_AUTO_EXDCINSTRUCT.SLIPDT                                                              AS SLIPDT
                ,WD_AUTO_EXDCINSTRUCT.DOCNO                                                               AS SLIPNO
                ,WD_AUTO_EXDCINSTRUCT.DOCLINE                                                             AS SLIPLINE
                ,WD_AUTO_EXDCINSTRUCT.CUSTKEY                                                             AS CUSTKEY
                ,MAX(MS_CUST.DESCRIPTION)                                                                 AS CUSTNAME
                ,WD_AUTO_EXDCINSTRUCT.SKU                                                                 AS SKU
                ,MAX(MS_SKU.DESCRIPTION)                                                                  AS SKUNAME
                ,WD_AUTO_EXDCINSTRUCT.ORDERQTY                                                            AS ORDERQTY
                ,WD_AUTO_EXDCINSTRUCT.BASEUOM                                                             AS STORERUOM
                ,FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE)
                              , MAX(MS_SKU.DURATION)
                              , MAX(ST_SNINFO.LOTTABLE01), 'Y')                                           AS NEARDURATIONYN
                ,MAX(ST_SNINFO.LOTTABLE01)                                                                AS LOTTABLE01  
                ,CASE WHEN FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE), MAX(MS_SKU.DURATION), MAX(ST_SNINFO.LOTTABLE01), 'N') > 0 
                      THEN ROUND(FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE), MAX(MS_SKU.DURATION), MAX(ST_SNINFO.LOTTABLE01), 'N') / MAX(MS_SKU.DURATION) * 100) 
                      ELSE 0 
                  END                                                                                     AS USEBYDATE_FREE_RT
                ,FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE)
                               , MAX(MS_SKU.DURATION)                    
                               , MAX(ST_SNINFO.LOTTABLE01), 'N') ||'/'|| MAX(MS_SKU.DURATION)             AS DURATION_TERM
                ,NVL(WD_AUTO_EXDCINSTRUCT.SERIALNO, MAX(ST_SNINFO.SERIALNO))                              AS SERIALNO  
                ,''                                                                                       AS FACTORYNAME
                ,''                                                                                       AS PLACEOFORIGIN
                ,WD_AUTO_EXDCINSTRUCT.CONVERSERIALNO                                                      AS CONVSERIALNO
                ,''                                                                                       AS BUTCHERYDT
                ,MAX(ST_SNINFO.CONTRACTCUSTKEY)                                                           AS CONTRACTCOMPANY
                ,MAX((SELECT DESCRIPTION FROM MS_CUST                                                         
                       WHERE  MS_CUST.STORERKEY = ST_SNINFO.STORERKEY                                      
                       AND    MS_CUST.CUSTKEY   = ST_SNINFO.CONTRACTCUSTKEY                                
                       AND    ROWNUM = 1 ))                                                               AS CONTRACTCOMPANYNAME
                ,MAX(ST_SNINFO.FROMVALIDDT)                                                               AS FROMVALIDDT
                ,MAX(ST_SNINFO.TOVALIDDT)                                                                 AS TOVALIDDT
                ,MAX(CD2.BASEDESCR)                                                                       AS CONTRACTTYPE 
                ,MAX(ST_SNINFO.STOCKID)                                                                   AS BARCODE
                ,0                                                                                        AS GROSSWEIGHT
                ,MAX(WD_AUTO_EXDCINSTRUCT.APRV_WHO)                                                       AS ADDWHO
                ,CASE WHEN TO_NUMBER(NVL(MS_SKU.LINE02,0)) <![CDATA[<>]]> 0 
                           AND WD_AUTO_EXDCINSTRUCT.DCCODE = '2170' 
                           AND NVL(MS_SKU.LINE01,'N')      = 'Y'  
                      THEN TO_NUMBER(NVL(MS_SKU.LINE02,0)) 
                      ELSE 0  END                                                                         AS AVGWEIGHT            /* 평균중량    */
                ,ROUND(CASE WHEN TO_NUMBER(NVL(MS_SKU.LINE02,0)) <![CDATA[<]]> 0 
                                 AND WD_AUTO_EXDCINSTRUCT.DCCODE = '2170' 
                                 AND NVL(MS_SKU.LINE01,'N')      = 'Y'    
                            THEN (MAX(WD_AUTO_EXDCINSTRUCT.ORDERQTY)) / TO_NUMBER(NVL(MS_SKU.LINE02,0)) 
                            ELSE 0 
                       END ,3)                                                                           AS CALBOX                 /* 환산박스    */    
                ,WD_AUTO_EXDCINSTRUCT.BOXQTY                                                             AS REALORDERBOX           /* 실박스예정 */
                ,WD_AUTO_EXDCINSTRUCT.BOXQTY                                                             AS REALCFMBOX             /* 실박스확정 */
                ,0                                                                                       AS BOXQTY
                ,'BOX'                                                                                   AS BOXUOM
                ,'N'                                                                                     AS BOXFLAG                
                ,MAX(WD_AUTO_EXDCINSTRUCT.DEL_YN)                                                        AS ALL_CANCEL_STATUS 
                ,MAX(CD3.BASEDESCR)                                                                      AS DELIVERYTYPENAME       /* 출고방법 */ 
                ,MAX(MS_PLANTXSL.FAX )                                                                   AS RECVFAXNO
                ,MAX(MS_PLANTXSL.DESCRIPTION)                                                            AS RECVNAME 
                ,MAX(MS_PLANTXSL.EMAIL)                                                                  AS RECVEMAIL
                ,MAX(DM_DOCUMENT_D.MEMO1)                                                                AS MEMO1 
                ,WD_EXDC_DOCUMENT.MEMO1                                                                  AS MEMO2 
                ,MAX(MS_PLANTXSL.COMM_CODE)                                                              AS COMM_CODE
                ,CASE WHEN MAX(WD_AUTO_EXDCINSTRUCT.MAPKEY_NO) IS NOT NULL 
                      THEN MAX(TO_CHAR(WD_AUTO_EXDCINSTRUCT.ADDDATE,'YYYY-MM-DD HH24:MI'))
                      ELSE '' END                                                                        AS ADDDATE
                ,MAX(WD_AUTO_EXDCINSTRUCT.addwho)                                                        AS DOCNOCONFIRM
                ,MAX(MS_SKU.QTYPERBOX)                                                                   AS QTYPERBOX 
            
              FROM   WD_AUTO_EXDCINSTRUCT 
              LEFT OUTER JOIN  (
                    SELECT MS_CUST.STORERKEY, MS_CUST.CUSTKEY, MAX(MS_CUST.DESCRIPTION) AS DESCRIPTION 
                    FROM   MS_CUST 
                    GROUP  BY MS_CUST.STORERKEY, MS_CUST.CUSTKEY ) MS_CUST  
                ON   MS_CUST.STORERKEY                = #{gStorerkey}
                AND  MS_CUST.CUSTKEY                  = WD_AUTO_EXDCINSTRUCT.CUSTKEY
              LEFT OUTER  JOIN   MS_SKU
                ON   MS_SKU.STORERKEY                 = WD_AUTO_EXDCINSTRUCT.STORERKEY
                AND  MS_SKU.SKU                       = WD_AUTO_EXDCINSTRUCT.SKU
              LEFT OUTER JOIN MS_PLANTXSL 
                ON  1=1
                AND  WD_AUTO_EXDCINSTRUCT.DCCODE      = MS_PLANTXSL.PLANT
                AND  WD_AUTO_EXDCINSTRUCT.ORGANIZE    = MS_PLANTXSL.PLANT||'-'||MS_PLANTXSL.STORAGELOC
              LEFT OUTER JOIN WD_EXDC_DOCUMENT 
                ON   WD_EXDC_DOCUMENT.DCCODE         = WD_AUTO_EXDCINSTRUCT.DCCODE
                AND  WD_EXDC_DOCUMENT.STORERKEY      = WD_AUTO_EXDCINSTRUCT.STORERKEY              
                AND  WD_EXDC_DOCUMENT.DOCNO          = WD_AUTO_EXDCINSTRUCT.DOCNO                  
                AND  WD_EXDC_DOCUMENT.DOCLINE        = WD_AUTO_EXDCINSTRUCT.DOCLINE
              LEFT OUTER JOIN DM_DOCUMENT_H 
                ON   DM_DOCUMENT_H.DCCODE            = WD_AUTO_EXDCINSTRUCT.DCCODE
                AND  DM_DOCUMENT_H.STORERKEY         = WD_AUTO_EXDCINSTRUCT.STORERKEY   
                AND  DM_DOCUMENT_H.DELIVERYDATE      = WD_AUTO_EXDCINSTRUCT.SLIPDT   
                AND  DM_DOCUMENT_H.DOCNO             = WD_AUTO_EXDCINSTRUCT.DOCNO 
                AND  DM_DOCUMENT_H.DOCTYPE           = 'WD'
                AND  DM_DOCUMENT_H.REAL_YN           = 'R'
              LEFT OUTER JOIN DM_DOCUMENT_D 
                ON   DM_DOCUMENT_D.DCCODE            = DM_DOCUMENT_H.DCCODE
                AND  DM_DOCUMENT_D.STORERKEY         = DM_DOCUMENT_H.STORERKEY   
                AND  DM_DOCUMENT_D.DELIVERYDATE      = DM_DOCUMENT_H.DELIVERYDATE   
                AND  DM_DOCUMENT_D.DOCNO             = DM_DOCUMENT_H.DOCNO 
                AND  DM_DOCUMENT_D.DOCTYPE           = DM_DOCUMENT_H.DOCTYPE
              LEFT OUTER JOIN   ST_STOCK
                ON   ST_STOCK.DCCODE                 = DM_DOCUMENT_D.DCCODE
                AND  ST_STOCK.STORERKEY              = DM_DOCUMENT_D.STORERKEY
                AND  ST_STOCK.ORGANIZE               = DM_DOCUMENT_D.ORGANIZE
                AND  ST_STOCK.AREA                   = DM_DOCUMENT_D.AREA
                AND  ST_STOCK.SKU                    = DM_DOCUMENT_D.SKU
                AND  ST_STOCK.STOCKID                = DM_DOCUMENT_D.STOCKID
                AND  ST_STOCK.STOCKGRADE             = DM_DOCUMENT_D.STOCKGRADE
              LEFT OUTER JOIN ST_SNINFO
                ON   DM_DOCUMENT_D.STORERKEY     = ST_SNINFO.STORERKEY
                AND  DM_DOCUMENT_D.SKU           = ST_SNINFO.SKU
                AND  DM_DOCUMENT_D.STOCKID       = ST_SNINFO.STOCKID
              LEFT OUTER JOIN CM_CODE_STORER CD2
                ON   CD2.STORERKEY               = WD_AUTO_EXDCINSTRUCT.STORERKEY
                AND  CD2.CODELIST                = 'CONTRACTTYPE_SN'   
                AND  CD2.BASECODE                = ST_SNINFO.CONTRACTTYPE  
             LEFT OUTER JOIN CM_CODE_STORER CD3
                ON   CD3.STORERKEY                = WD_AUTO_EXDCINSTRUCT.STORERKEY
                AND  CD3.CODELIST                 = 'DELIVERYTYPE'   
                AND  CD3.BASECODE                 = (SELECT CASE WHEN DM_DOCUMENT_H.WORKPROCESSCODE = 'STO' THEN 'WOD'
                                                                 ELSE DM_DOCUMENT_H.DELIVERYTYPE
                                                             END
                                                       FROM  DM_DOCUMENT_H 
                                                       WHERE DM_DOCUMENT_H.DCCODE         = WD_AUTO_EXDCINSTRUCT.DCCODE   
                                                        AND  DM_DOCUMENT_H.DOCTYPE        = 'WD'  
                                                        AND  DM_DOCUMENT_H.DELIVERYDATE   = WD_AUTO_EXDCINSTRUCT.SLIPDT
                                                        AND  DM_DOCUMENT_H.DOCNO          = WD_AUTO_EXDCINSTRUCT.DOCNO)   
            
              WHERE  1=1 
                AND  WD_AUTO_EXDCINSTRUCT.ORDERQTY <![CDATA[>]]> 0
                AND  WD_AUTO_EXDCINSTRUCT.REFERENCE01 = '10'    
            <if test="exdcinstructtype == 'RETURN'">    
                AND  WD_AUTO_EXDCINSTRUCT.ORDERTYPE   = 'RP'
              </if>
              <if test="exdcinstructtype == 'ORDER'">
                AND  WD_AUTO_EXDCINSTRUCT.ORDERTYPE  != 'RP'
              </if>     
            <if test="organizeMulti != null and organizeMulti != ''">
                AND  WD_AUTO_EXDCINSTRUCT.ORGANIZE IN
                <foreach collection="organizeMulti" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach> 
            </if>
            <if test="fromSlipdt != null and fromSlipdt != ''">   
                AND  WD_AUTO_EXDCINSTRUCT.SLIPDT  <![CDATA[>=]]>  #{fromSlipdt}      
            </if>
            <if test="toSlipdt != null and toSlipdt != ''">     
                AND  WD_AUTO_EXDCINSTRUCT.SLIPDT <![CDATA[<=]]>  #{toSlipdt}        
            </if>
              
            <if test="docnoMulti != null and docnoMulti != ''">
                   AND    WD_AUTO_EXDCINSTRUCT.DOCNO      IN
                 <foreach collection="docnoMulti" item="item" open="(" separator="," close=")">
                     #{item}
                 </foreach> 
            </if>     
            <if test="fromcustkey != null and fromcustkey != ''">
                AND  WD_AUTO_EXDCINSTRUCT.TO_CUSTKEY IN (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
                                                         FROM (SELECT #{fromcustkey} AS VAL FROM DUAL) A
                                                         CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
            </if>
            <if test="tocustkeyMulti != null and tocustkeyMulti != ''">
                AND WD_AUTO_EXDCINSTRUCT.CUSTKEY IN
                <foreach collection="tocustkeyMulti" item="item" open="(" separator="," close=")">
                   #{item}
                </foreach> 
            </if>
            <if test="sku != null and sku != '' ">
                <if test="skuMulti != null and skuMulti.size() > 0">
                    <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                        <foreach collection="skuMulti" item="item">
                        OR WD_AUTO_EXDCINSTRUCT.SKU IN
                            <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}      
                            </foreach>
                        </foreach>
                    </trim>                                             
                </if>
            </if>         
             <if test="blnoMulti != null and blnoMulti != ''">
                   AND    WD_AUTO_EXDCINSTRUCT.CONVERSERIALNO      IN
                 <foreach collection="blnoMulti" item="item" open="(" separator="," close=")">
                     #{item}
                 </foreach> 
             </if>
              GROUP BY                                
                     WD_AUTO_EXDCINSTRUCT.DCCODE                  
                    ,WD_AUTO_EXDCINSTRUCT.STORERKEY               
                    ,WD_AUTO_EXDCINSTRUCT.ORGANIZE       
                    ,WD_AUTO_EXDCINSTRUCT.DOCNO
                    ,WD_AUTO_EXDCINSTRUCT.DOCLINE                              
                    ,WD_AUTO_EXDCINSTRUCT.SLIPDT                  
                    ,WD_AUTO_EXDCINSTRUCT.CUSTKEY                 
                    ,WD_AUTO_EXDCINSTRUCT.ORDERQTY 
                    ,WD_AUTO_EXDCINSTRUCT.BOXQTY 
                    ,WD_AUTO_EXDCINSTRUCT.BASEUOM       
                    ,WD_AUTO_EXDCINSTRUCT.SALESUOM 
                    ,WD_AUTO_EXDCINSTRUCT.SERIALNO
                    ,WD_AUTO_EXDCINSTRUCT.SKU
                    ,WD_AUTO_EXDCINSTRUCT.CONVERSERIALNO
                    ,MS_SKU.LINE01
                    ,MS_SKU.LINE02
                    ,WD_EXDC_DOCUMENT.MEMO1
                    ,DM_DOCUMENT_D.DOCNO
                    
            ) A
            
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY 
                                 , WD_EXDC_PRTLOG.DCCODE
                                 , WD_EXDC_PRTLOG.DOCNO
                                 , WD_EXDC_PRTLOG.DOCLINE
                                 , COUNT(1)  AS COUNT
                            FROM WD_EXDC_PRTLOG
                            --JOIN FC_META_TRAN 
                            --     ON WD_EXDC_PRTLOG.DOCNAME = FC_META_TRAN.TR_DOCNAME   
                            -- JOIN FC_MSG_TRAN
                            --    ON FC_META_TRAN.TR_BATCHID = FC_MSG_TRAN.TR_BATCHID
                            WHERE   WD_EXDC_PRTLOG.PAPERTYPE = 'FAX'
                              AND   WD_EXDC_PRTLOG.DCCODE    = #{fixdccode} 
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY 
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE
                        )  T_FAX_CNT
                ON      T_FAX_CNT.STORERKEY = A.STORERKEY         
                    AND T_FAX_CNT.DCCODE    = A.DCCODE         
                    AND T_FAX_CNT.DOCNO     = A.DOCNO         
                    AND T_FAX_CNT.DOCLINE   = A.DOCLINE   
       
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY 
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , COUNT(1)  AS COUNT
                            FROM WD_EXDC_PRTLOG
                            JOIN FC_META_TRAN 
                                ON WD_EXDC_PRTLOG.DOCNAME = FC_META_TRAN.TR_DOCNAME   
                            JOIN FC_MSG_TRAN
                                ON FC_META_TRAN.TR_BATCHID = FC_MSG_TRAN.TR_BATCHID
                            WHERE   WD_EXDC_PRTLOG.PAPERTYPE = 'FAX'
                                AND WD_EXDC_PRTLOG.DCCODE    = #{fixdccode}
                                AND FC_MSG_TRAN.TR_SENDSTAT  = '2'
                                AND FC_MSG_TRAN.TR_RSLTSTAT  = '0'
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY 
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE  
                        )  T_FAX_SUCC_CNT
                ON      T_FAX_SUCC_CNT.STORERKEY = A.STORERKEY         
                    AND T_FAX_SUCC_CNT.DCCODE    = A.DCCODE         
                    AND T_FAX_SUCC_CNT.DOCNO     = A.DOCNO         
                    AND T_FAX_SUCC_CNT.DOCLINE   = A.DOCLINE     
      
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY 
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , COUNT(1)  AS COUNT
                            FROM WD_EXDC_PRTLOG
                            JOIN FC_META_TRAN 
                                ON WD_EXDC_PRTLOG.DOCNAME = FC_META_TRAN.TR_DOCNAME   
                            JOIN FC_MSG_TRAN
                                ON FC_META_TRAN.TR_BATCHID = FC_MSG_TRAN.TR_BATCHID
                            WHERE   WD_EXDC_PRTLOG.PAPERTYPE = 'FAX'
                                AND WD_EXDC_PRTLOG.DCCODE    = #{fixdccode}
                                AND FC_MSG_TRAN.TR_SENDSTAT  = '2'
                                AND FC_MSG_TRAN.TR_RSLTSTAT  NOT IN ('0','-')
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY 
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE  
                        )  T_FAX_FAIL_CNT
                ON    T_FAX_FAIL_CNT.STORERKEY = A.STORERKEY         
                  AND T_FAX_FAIL_CNT.DCCODE    = A.DCCODE         
                  AND T_FAX_FAIL_CNT.DOCNO     = A.DOCNO         
                  AND T_FAX_FAIL_CNT.DOCLINE   = A.DOCLINE                                                                   

            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , MAX(WD_EXDC_PRTLOG.DOCNAME) AS DOCNAME
                                , MAX(WD_EXDC_PRTLOG.SERIALKEY) AS SERIALKEY
                                , MAX(FC_META_TRAN.TR_BATCHID) AS TR_BATCHID
                                , MAX(FC_MSG_TRAN.TR_PHONE) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_PHONE
                                , MAX(FC_META_TRAN.TR_SENDDATE) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_SENDDATE
                                , MAX(FC_META_TRAN.TR_SENDNAME) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_SENDNAME
                                , MAX(WD_EXDC_PRTLOG.PRINTUSER) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS PRINTUSER
                            FROM (SELECT WD_EXDC_PRTLOG.STORERKEY
                                        , WD_EXDC_PRTLOG.DCCODE
                                        , WD_EXDC_PRTLOG.DOCNO
                                        , WD_EXDC_PRTLOG.DOCLINE
                                        , MAX(WD_EXDC_PRTLOG.SERIALKEY) AS SERIALKEY
                                        , MAX(WD_EXDC_PRTLOG.DOCNAME) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS DOCNAME
                                        , MAX(WD_EXDC_PRTLOG.PRINTUSER) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS PRINTUSER
                                  FROM WD_EXDC_PRTLOG
                                  WHERE WD_EXDC_PRTLOG.PAPERTYPE = 'FAX'
                                    AND WD_EXDC_PRTLOG.DCCODE    = #{fixdccode}
                                  GROUP BY WD_EXDC_PRTLOG.STORERKEY
                                        , WD_EXDC_PRTLOG.DCCODE
                                        , WD_EXDC_PRTLOG.DOCNO
                                        , WD_EXDC_PRTLOG.DOCLINE
                                ) WD_EXDC_PRTLOG 
                            JOIN FC_META_TRAN 
                                ON WD_EXDC_PRTLOG.DOCNAME = FC_META_TRAN.TR_DOCNAME   
                            JOIN FC_MSG_TRAN
                                ON FC_META_TRAN.TR_BATCHID = FC_MSG_TRAN.TR_BATCHID
                            WHERE   FC_MSG_TRAN.TR_SENDSTAT  = '2'
                                AND FC_MSG_TRAN.TR_RSLTSTAT  = '0'
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE
                        )  T_FAX_SUCC_TR
                ON    T_FAX_SUCC_TR.STORERKEY = A.STORERKEY         
                  AND T_FAX_SUCC_TR.DCCODE    = A.DCCODE         
                  AND T_FAX_SUCC_TR.DOCNO     = A.DOCNO         
                  AND T_FAX_SUCC_TR.DOCLINE   = A.DOCLINE      
       
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , MAX(WD_EXDC_PRTLOG.DOCNAME) AS DOCNAME
                                , MAX(WD_EXDC_PRTLOG.SERIALKEY) AS SERIALKEY
                                , MAX(FC_META_TRAN.TR_BATCHID) AS TR_BATCHID
                                , MAX(FC_MSG_TRAN.TR_PHONE) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_PHONE
                                , MAX(FC_META_TRAN.TR_SENDDATE) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_SENDDATE
                                , MAX(WD_EXDC_PRTLOG.PRINTUSER) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS PRINTUSER
                                , MAX(FC_META_TRAN.TR_SENDNAME) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_SENDNAME
                            FROM (SELECT WD_EXDC_PRTLOG.STORERKEY
                                        , WD_EXDC_PRTLOG.DCCODE
                                        , WD_EXDC_PRTLOG.DOCNO
                                        , WD_EXDC_PRTLOG.DOCLINE
                                        , MAX(WD_EXDC_PRTLOG.SERIALKEY) AS SERIALKEY
                                        , MAX(WD_EXDC_PRTLOG.DOCNAME) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS DOCNAME
                                        , MAX(WD_EXDC_PRTLOG.PRINTUSER) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS PRINTUSER
                                    FROM WD_EXDC_PRTLOG
                                    WHERE WD_EXDC_PRTLOG.PAPERTYPE = 'FAX'
                                      AND WD_EXDC_PRTLOG.DCCODE    = #{fixdccode}
                                    GROUP BY WD_EXDC_PRTLOG.STORERKEY
                                            , WD_EXDC_PRTLOG.DCCODE
                                            , WD_EXDC_PRTLOG.DOCNO
                                            , WD_EXDC_PRTLOG.DOCLINE
                                ) WD_EXDC_PRTLOG 
                            JOIN FC_META_TRAN 
                                ON WD_EXDC_PRTLOG.DOCNAME = FC_META_TRAN.TR_DOCNAME   
                            JOIN FC_MSG_TRAN
                                ON FC_META_TRAN.TR_BATCHID = FC_MSG_TRAN.TR_BATCHID
                            WHERE   FC_MSG_TRAN.TR_SENDSTAT  = '2'
                                AND FC_MSG_TRAN.TR_RSLTSTAT  NOT IN ('0','-')
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE
                        )  T_FAX_FAIL_TR
                ON    T_FAX_FAIL_TR.STORERKEY = A.STORERKEY         
                  AND T_FAX_FAIL_TR.DCCODE    = A.DCCODE         
                  AND T_FAX_FAIL_TR.DOCNO     = A.DOCNO         
                  AND T_FAX_FAIL_TR.DOCLINE   = A.DOCLINE  
       
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY 
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , COUNT(1)  AS COUNT
                            FROM WD_EXDC_PRTLOG
                            WHERE WD_EXDC_PRTLOG.PAPERTYPE = 'EMAIL'
                              AND WD_EXDC_PRTLOG.DCCODE    = #{fixdccode}
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY 
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE
                        )  T_EMAIL_CNT
                ON    T_EMAIL_CNT.STORERKEY = A.STORERKEY         
                  AND T_EMAIL_CNT.DCCODE    = A.DCCODE         
                  AND T_EMAIL_CNT.DOCNO     = A.DOCNO         
                  AND T_EMAIL_CNT.DOCLINE   = A.DOCLINE      
       
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , MAX(WD_EXDC_PRTLOG.SERIALKEY) AS SERIALKEY
                                , MAX(WD_EXDC_PRTLOG.PRINTUSER) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS PRINTUSER                     
                                , MAX(WD_EXDC_PRTLOG.PRINTDT) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_SENDDATE
                            FROM WD_EXDC_PRTLOG 
                            WHERE WD_EXDC_PRTLOG.PAPERTYPE = 'EMAIL'
                              AND WD_EXDC_PRTLOG.DCCODE    = #{fixdccode}
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE
                        )  T_EMAIL_TR
                ON    T_EMAIL_TR.STORERKEY = A.STORERKEY         
                  AND T_EMAIL_TR.DCCODE    = A.DCCODE         
                  AND T_EMAIL_TR.DOCNO     = A.DOCNO         
                  AND T_EMAIL_TR.DOCLINE   = A.DOCLINE                   
           
            LEFT OUTER JOIN(SELECT WD.STORERKEY
                                , WD.DCCODE
                                , WD.DOCNO
                                , WD.DOCLINE
                                , COUNT(1) AS COUNT
                        FROM WD_EXDC_PRTLOG WD
                        WHERE WD.PAPERTYPE = 'PRINT'
                        GROUP BY WD.STORERKEY
                                , WD.DCCODE
                                , WD.DOCNO
                                , WD.DOCLINE
                      )  T_PRT_CNT
                ON    T_PRT_CNT.STORERKEY = A.STORERKEY         
                  AND T_PRT_CNT.DCCODE    = A.DCCODE         
                  AND T_PRT_CNT.DOCNO     = A.DOCNO         
                  AND T_PRT_CNT.DOCLINE   = A.DOCLINE  
                  
            LEFT OUTER JOIN FRAMEONE_USER USER1
                ON   USER1.USER_ID        = T_FAX_SUCC_TR.PRINTUSER 
                
            LEFT OUTER JOIN FRAMEONE_USER USER2
                ON   USER2.USER_ID        = T_FAX_FAIL_TR.PRINTUSER
                
            LEFT OUTER JOIN FRAMEONE_USER USER3
                ON   USER3.USER_ID        = T_EMAIL_TR.PRINTUSER 

            LEFT OUTER JOIN FRAMEONE_USER USER4
                ON   USER4.USER_ID        = A.ADDWHO
                
            LEFT OUTER JOIN FRAMEONE_USER USER5
                ON  (USER5.USER_ID        = A.DOCNOCONFIRM 
                     OR USER5.USER_NO     = A.DOCNOCONFIRM)        
        )
        
        WHERE   1=1
        <if test="send == 1">        
           AND  (NVL(FAX_CNT,0) = 0 AND NVL(EMAIL_CNT,0) = 0 AND NVL(PRT_CNT,0) = 0) 
        </if> 
        <if test="errorsend == 1">   
           AND  NVL(FAX_FAIL_CNT,0) != 0   
        </if>
        <if test="allCancelStatus == 1">   
           AND  ALL_CANCEL_STATUS = 'Y'       
        </if>
        <if test="mapkeyNo != null and mapkeyNo != ''">
           AND MAPKEY_NO IN (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
                             FROM (SELECT #{mapkeyNo} AS VAL FROM DUAL) A
                             CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
        </if>
        <if test="cfyn == 1">    
            AND  MAPKEY_NO IS NOT NULL     
        </if>
        <if test="noNormal == 1">    
            AND  NORMAL_NO IS NULL     
        </if>             
        ORDER BY MAPKEY_NO
                        
    </select>

    <select id="getDatalistNotOrder" resultType="WdSendOutOrderResDto">
        SELECT  /* [wdSendOutOrderService.sqlx][getDatalistNotOrder][오더없는 출고지시서 목록 조회][sunho.kim][2025.06.19] */ 
            * 
        FROM (
            SELECT 
               A.*
              ,T_FAX_CNT.COUNT                                          AS FAX_CNT     
              ,T_FAX_SUCC_CNT.COUNT                                     AS FAX_SUCC_CNT     
              ,T_FAX_SUCC_TR.TR_PHONE                                   AS FAX_SUCC_TR_PHONE
              ,TO_CHAR(T_FAX_SUCC_TR.TR_SENDDATE, 'YYYYMMDDHH24MI')     AS FAX_SUCC_TR_SENDDATE
              ,T_FAX_SUCC_TR.PRINTUSER                                  AS FAX_SUCC_TR_SENDUSER
              ,USER1.USER_NM                                            AS FAX_SUCC_TR_SENDNAME
              ,T_FAX_FAIL_CNT.COUNT                                     AS FAX_FAIL_CNT
              ,T_FAX_FAIL_TR.TR_PHONE                                   AS FAX_FAIL_TR_PHONE
              ,T_FAX_FAIL_TR.TR_SENDDATE                                AS FAX_FAIL_TR_SENDDATE     
              ,T_FAX_FAIL_TR.PRINTUSER                                  AS FAX_FAIL_TR_SENDUSER
              ,USER2.USER_NM                                            AS FAX_FAIL_TR_SENDNAME
              ,T_EMAIL_CNT.COUNT                                        AS EMAIL_CNT
              ,T_EMAIL_TR.TR_SENDDATE                                   AS EMAIL_TR_SENDDATE
              ,T_EMAIL_TR.PRINTUSER                                     AS EMAIL_TR_SENDUSER
              ,USER3.USER_NM                                            AS EMAIL_TR_SENDNAME
              ,T_PRT_CNT.COUNT                                          AS PRT_CNT
              ,USER4.USER_NM                                            AS ADDWHO_NM
              ,USER5.USER_NM                                            AS DOCNOCONFIRM_NM
           FROM (
               SELECT     
                  'Y'                                                                                           AS CHECKTYPE      
                  ,'0'                                                                                          AS CHECKYN
                  ,WD_EXDCINSTRUCT.DCCODE                                                                       AS DCCODE
                  ,WD_EXDCINSTRUCT.STORERKEY                                                                    AS STORERKEY
                  ,WD_EXDCINSTRUCT.ORGANIZE                                                                     AS ORGANIZE
                  ,FN_DESCR_ORGANIZE(WD_EXDCINSTRUCT.DCCODE, WD_EXDCINSTRUCT.ORGANIZE)                          AS ORGANIZENAME
                  ,WD_EXDCINSTRUCT.DOCTYPE                                                                      AS DOCTYPE
                  ,''                                                                                           AS CHANNEL
                  ,MAX(DM_DOCUMENT_H.DOCNO)                                                                     AS NORMAL_NO
                  ,DECODE(WD_EXDCINSTRUCT.DOCDT,NULL,WD_EXDCINSTRUCT.INSTRUCTDT, WD_EXDCINSTRUCT.DOCDT)         AS DOCDT
                  ,DECODE(WD_EXDCINSTRUCT.DOCNO,NULL,WD_EXDCINSTRUCT.INSTRUCTNO, WD_EXDCINSTRUCT.DOCNO)         AS DOCNO
                  ,DECODE(WD_EXDCINSTRUCT.DOCLINE,NULL,WD_EXDCINSTRUCT.INSTRUCTLINE, WD_EXDCINSTRUCT.DOCLINE)   AS DOCLINE
                  ,''                                                                                           AS SLIPTYPE
                  ,DECODE(WD_EXDCINSTRUCT.SLIPDT,NULL,WD_EXDCINSTRUCT.INSTRUCTDT, WD_EXDCINSTRUCT.SLIPDT)       AS SLIPDT
                  ,DECODE(WD_EXDCINSTRUCT.SLIPNO,NULL,WD_EXDCINSTRUCT.INSTRUCTNO, WD_EXDCINSTRUCT.SLIPNO)       AS SLIPNO
                  ,DECODE(WD_EXDCINSTRUCT.SLIPLINE,NULL,WD_EXDCINSTRUCT.INSTRUCTLINE, WD_EXDCINSTRUCT.SLIPLINE) AS SLIPLINE
                  ,WD_EXDCINSTRUCT.CUSTKEY                                                                      AS CUSTKEY
                  ,MAX(MS_CUST.DESCRIPTION)                                                                     AS CUSTNAME
                  ,WD_EXDCINSTRUCT.SKU                                                                          AS SKU
                  ,MAX(MS_SKU.DESCRIPTION)                                                                      AS SKUNAME
                  ,WD_EXDCINSTRUCT.ORDERQTY                                                                     AS ORDERQTY
                  ,WD_EXDCINSTRUCT.UOM                                                                          AS STORERUOM
                  ,FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE)
                              , MAX(MS_SKU.DURATION)
                              , MAX(ST_SNINFO.LOTTABLE01), 'Y')                                                 AS NEARDURATIONYN
                  ,MAX(ST_SNINFO.LOTTABLE01)                                                                    AS LOTTABLE01
                  ,CASE WHEN FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE), MAX(MS_SKU.DURATION), MAX(ST_SNINFO.LOTTABLE01), 'N') > 0 
                      THEN ROUND(FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE), MAX(MS_SKU.DURATION), MAX(ST_SNINFO.LOTTABLE01), 'N') / MAX(MS_SKU.DURATION) * 100) 
                      ELSE 0 
                   END                                                                                          AS USEBYDATE_FREE_RT
                  ,FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE)
                               , MAX(MS_SKU.DURATION)                    
                               , MAX(ST_SNINFO.LOTTABLE01), 'N') ||'/'|| MAX(MS_SKU.DURATION)                   AS DURATION_TERM
                  ,WD_EXDCINSTRUCT.SERIALNO                                                                     AS SERIALNO  
                  ,''                                                                                           AS FACTORYNAME
                  ,''                                                                                           AS PLACEOFORIGIN
                  ,WD_EXDCINSTRUCT.CONVSERIALNO                                                                 AS CONVSERIALNO
                  ,MAX(ST_SNINFO.BUTCHERYDT)                                                                    AS BUTCHERYDT
                  ,MAX(ST_SNINFO.CONTRACTCUSTKEY)                                                               AS CONTRACTCOMPANY
                  ,MAX((SELECT DESCRIPTION FROM MS_CUST                                                         
                        WHERE  MS_CUST.STORERKEY = ST_SNINFO.STORERKEY                                      
                        AND    MS_CUST.CUSTKEY   = ST_SNINFO.CONTRACTCUSTKEY                                
                        AND    ROWNUM = 1 ))                                                                    AS CONTRACTCOMPANYNAME
                  ,MAX(ST_SNINFO.FROMVALIDDT)                                                                   AS FROMVALIDDT
                  ,MAX(ST_SNINFO.TOVALIDDT)                                                                     AS TOVALIDDT
                  ,''                                                                                           AS CONTRACTTYPE
                  ,MAX(WD_EXDCINSTRUCT.STOCKID)                                                                 AS BARCODE
                  ,0                                                                                            AS GROSSWEIGHT
                  ,MAX(WD_EXDCINSTRUCT.EDITWHO)                                                                 AS ADDWHO 
                  ,CASE WHEN TO_NUMBER(NVL(MS_SKU.LINE02,0)) <![CDATA[<>]]> 0 
                             AND WD_EXDCINSTRUCT.DCCODE = '2170' 
                             AND NVL(MS_SKU.LINE01,'N') = 'Y'          
                         THEN TO_NUMBER(NVL(MS_SKU.LINE02,0)) 
                         ELSE 0 
                   END                                                                                          AS AVGWEIGHT       /* 평균중량    */
                  ,ROUND(CASE WHEN TO_NUMBER(NVL(MS_SKU.LINE02,0)) <![CDATA[<>]]> 0 
                                   AND WD_EXDCINSTRUCT.DCCODE = '2170' 
                                   AND NVL(MS_SKU.LINE01,'N') = 'Y'    
                              THEN (MAX(WD_EXDCINSTRUCT.ORDERQTY)) / TO_NUMBER(NVL(MS_SKU.LINE02,0)) 
                              ELSE 0 
                         END ,3)                                                                                AS CALBOX          /* 환산박스    */        
                  ,WD_EXDCINSTRUCT.BOXQTY                                                                       AS REALORDERBOX    /* 실박스예정 */
                  ,WD_EXDCINSTRUCT.BOXQTY                                                                       AS REALCFMBOX      /* 실박스확정 */
                  ,'0'                                                                                          AS BOXQTY
                  ,'BOX'                                                                                        AS BOXUOM
                  ,'N'                                                                                          AS BOXFLAG
                  ,WD_EXDCINSTRUCT.DEL_YN                                                                       AS ALL_CANCEL_STATUS
                  ,MAX(CD1.BASEDESCR)                                                                           AS DELIVERYTYPENAME
                  ,MAX(MS_PLANTXSL.FAX)                                                                         AS RECVFAXNO
                  ,MAX(MS_PLANTXSL.DESCRIPTION)                                                                 AS RECVNAME 
                  ,MAX(MS_PLANTXSL.EMAIL)                                                                       AS RECVEMAIL   
                  ,WD_EXDCINSTRUCT.REFERENCE01                                                                  AS MEMO1
                  ,WD_EXDC_DOCUMENT.MEMO1                                                                       AS MEMO2 
                  ,MAX(MS_PLANTXSL.COMM_CODE)                                                                   AS COMM_CODE
                  ,MAX(DM_EXDC_AUTOORD_CHECK.MAPKEY_NO)                                                         AS MAPKEY_NO
                  ,''                                                                                           AS ADDDATE
                  ,MAX(WD_EXDCINSTRUCT.ADDWHO)                                                                  AS DOCNOCONFIRM 
                  ,MAX(MS_SKU.QTYPERBOX)                                                                        AS QTYPERBOX
                  ,NVL(MAX(CD2.BASEDESCR), MAX(WD_EXDCINSTRUCT.REASONCODE))                                     AS REASONCODENAME
                  
               FROM   WD_EXDCINSTRUCT
               JOIN   CM_USER_AUTHORITY           
                 ON   1=1     
           <if test="fixdccode != null and fixdccode != ''">           
                 AND  CM_USER_AUTHORITY.DCCODE      =  #{fixdccode}          
           </if>
           <if test="gStorerkey != null and gStorerkey != ''">   
                 AND  CM_USER_AUTHORITY.STORERKEY   =  #{gStorerkey}       
           </if>
           <if test="area != null and area != ''">            
                 AND  CM_USER_AUTHORITY.AREA        =  #{area}                
           </if> 
           <if test="organizeMulti != null and organizeMulti != ''">
                 AND  CM_USER_AUTHORITY.ORGANIZE      IN
             <foreach collection="organizeMulti" item="item" open="(" separator="," close=")">
                     #{item}
             </foreach> 
            </if>
                 AND  CM_USER_AUTHORITY.USERID     = #{gUserId}    
                 AND  CM_USER_AUTHORITY.DCCODE     = WD_EXDCINSTRUCT.DCCODE             
                 AND  CM_USER_AUTHORITY.STORERKEY  = WD_EXDCINSTRUCT.STORERKEY          
                 AND  CM_USER_AUTHORITY.ORGANIZE   = WD_EXDCINSTRUCT.ORGANIZE           
                 AND  CM_USER_AUTHORITY.AREA       = WD_EXDCINSTRUCT.AREA               
              JOIN  (
                    SELECT MS_CUST.STORERKEY, MS_CUST.CUSTKEY, MAX(MS_CUST.DESCRIPTION) AS DESCRIPTION 
                    FROM   MS_CUST 
                    GROUP  BY MS_CUST.STORERKEY, MS_CUST.CUSTKEY ) MS_CUST 
                 ON   MS_CUST.STORERKEY            = WD_EXDCINSTRUCT.STORERKEY
                 AND  MS_CUST.CUSTKEY              = WD_EXDCINSTRUCT.CUSTKEY
              JOIN   MS_SKU
                 ON   MS_SKU.STORERKEY             = WD_EXDCINSTRUCT.STORERKEY
                 AND  MS_SKU.SKU                   = WD_EXDCINSTRUCT.SKU
              LEFT OUTER JOIN MS_PLANTXSL 
                 ON   WD_EXDCINSTRUCT.DCCODE       = MS_PLANTXSL.DCCODE
                 AND  WD_EXDCINSTRUCT.DCCODE       = MS_PLANTXSL.PLANT
                 AND  WD_EXDCINSTRUCT.ORGANIZE     = MS_PLANTXSL.PLANT||'-'||MS_PLANTXSL.STORAGELOC
              LEFT OUTER JOIN WD_EXDC_DOCUMENT 
                 ON   WD_EXDC_DOCUMENT.DCCODE      = WD_EXDCINSTRUCT.DCCODE
                 AND  WD_EXDC_DOCUMENT.STORERKEY   = WD_EXDCINSTRUCT.STORERKEY              
                 AND  WD_EXDC_DOCUMENT.DOCNO       = WD_EXDCINSTRUCT.INSTRUCTNO                  
                 AND  WD_EXDC_DOCUMENT.DOCLINE     = WD_EXDCINSTRUCT.INSTRUCTLINE           
              LEFT OUTER JOIN DM_EXDC_AUTOORD_CHECK
                 ON   DM_EXDC_AUTOORD_CHECK.TMP_SOKEY = WD_EXDCINSTRUCT.DOCNO
              LEFT OUTER JOIN DM_DOCUMENT_H 
                 ON   DM_DOCUMENT_H.DCCODE         = WD_EXDCINSTRUCT.DCCODE
                 AND  DM_DOCUMENT_H.STORERKEY      = WD_EXDCINSTRUCT.STORERKEY
                 AND  DM_DOCUMENT_H.DELIVERYDATE   = WD_EXDCINSTRUCT.SLIPDT      
                 AND  DM_DOCUMENT_H.DOCNO          = WD_EXDCINSTRUCT.DOCNO 
                 AND  DM_DOCUMENT_H.DOCTYPE        = 'WD'
                 AND  DM_DOCUMENT_H.REAL_YN        = 'R'
              LEFT OUTER JOIN ST_SNINFO
                ON   WD_EXDCINSTRUCT.STORERKEY     = ST_SNINFO.STORERKEY
                AND  WD_EXDCINSTRUCT.SKU           = ST_SNINFO.SKU
                AND  WD_EXDCINSTRUCT.STOCKID       = ST_SNINFO.STOCKID
             
             LEFT OUTER JOIN CM_CODE_STORER CD1
                 ON   CD1.STORERKEY               = WD_EXDCINSTRUCT.STORERKEY
                 AND  CD1.CODELIST                = 'DELIVERYTYPE_FS'   
                 AND  CD1.BASECODE                = WD_EXDCINSTRUCT.DELIVERYTYPE
             LEFT OUTER JOIN CM_CODE_STORER CD2
                 ON   CD2.STORERKEY               = WD_EXDCINSTRUCT.STORERKEY
                 AND  CD2.CODELIST                = 'WDEX_MANUAL_REASON'   
                 AND  CD2.BASECODE                = WD_EXDCINSTRUCT.REASONCODE      
                                            
             WHERE  1=1 
               AND WD_EXDCINSTRUCT.ORDERQTY  <![CDATA[>]]> 0
           <if test="organizeMulti != null and organizeMulti != ''">
               AND WD_EXDCINSTRUCT.ORGANIZE      IN
             <foreach collection="organizeMulti" item="item" open="(" separator="," close=")">
                 #{item}
             </foreach> 
           </if>
           <if test="fromSlipdt != null and fromSlipdt != ''">   
               AND NVL(WD_EXDCINSTRUCT.SLIPDT,WD_EXDCINSTRUCT.INSTRUCTDT) <![CDATA[>=]]> #{fromSlipdt}      
           </if>
           <if test="toSlipdt != null and toSlipdt != ''">     
               AND NVL(WD_EXDCINSTRUCT.SLIPDT,WD_EXDCINSTRUCT.INSTRUCTDT) <![CDATA[<=]]>  #{toSlipdt}        
           </if>
           <if test="docnoMulti != null and docnoMulti != ''">
                   AND    WD_EXDCINSTRUCT.DOCNO      IN
                 <foreach collection="docnoMulti" item="item" open="(" separator="," close=")">
                     #{item}
                 </foreach> 
                   OR    WD_EXDCINSTRUCT.INSTRUCTNO      IN
                 <foreach collection="docnoMulti" item="item" open="(" separator="," close=")">
                     #{item}
                 </foreach> 
           </if>   
           <if test="fromcustkey != null and fromcustkey != ''">
               AND WD_EXDCINSTRUCT.INSTRUCTNO IN (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
                                                  FROM (SELECT #{fromcustkey} AS VAL FROM DUAL) A
                                                  CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
           </if>
           <if test="tocustkeyMulti != null and tocustkeyMulti != ''">
               AND WD_EXDCINSTRUCT.CUSTKEY IN
                <foreach collection="tocustkeyMulti" item="item" open="(" separator="," close=")">
                   #{item}
                </foreach> 
           </if>
           <if test="sku != null and sku != '' ">
               <if test="skuMulti != null and skuMulti.size() > 0">
                   <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                       <foreach collection="skuMulti" item="item">
                        OR WD_EXDCINSTRUCT.SKU IN
                           <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}      
                           </foreach>
                       </foreach>
                   </trim>                                             
               </if>
           </if>           
           <if test="blnoMulti != null and blnoMulti != ''">
                   AND    WD_EXDCINSTRUCT.CONVSERIALNO      IN
                 <foreach collection="blnoMulti" item="item" open="(" separator="," close=")">
                     #{item}
                 </foreach> 
            </if>
         
             GROUP BY 
                  WD_EXDCINSTRUCT.DCCODE                  
                 ,WD_EXDCINSTRUCT.STORERKEY               
                 ,WD_EXDCINSTRUCT.ORGANIZE                         
                 ,WD_EXDCINSTRUCT.DOCDT        
                 ,WD_EXDCINSTRUCT.DOCTYPE           
                 ,WD_EXDCINSTRUCT.DOCNO
                 ,WD_EXDCINSTRUCT.DOCLINE                              
                 ,WD_EXDCINSTRUCT.SLIPDT                  
                 ,WD_EXDCINSTRUCT.SLIPNO                  
                 ,WD_EXDCINSTRUCT.SLIPLINE                
                 ,WD_EXDCINSTRUCT.INSTRUCTDT                  
                 ,WD_EXDCINSTRUCT.INSTRUCTNO                  
                 ,WD_EXDCINSTRUCT.INSTRUCTLINE                
                 ,WD_EXDCINSTRUCT.CUSTKEY                 
                 ,WD_EXDCINSTRUCT.ORDERQTY 
                 ,WD_EXDCINSTRUCT.BOXQTY 
                 ,WD_EXDCINSTRUCT.UOM       
                 ,WD_EXDCINSTRUCT.SKU 
                 ,WD_EXDCINSTRUCT.SERIALNO
                 ,WD_EXDCINSTRUCT.CONVSERIALNO
                 ,WD_EXDCINSTRUCT.EDITWHO
                 ,WD_EXDCINSTRUCT.DEL_YN
                 ,MS_SKU.LINE01
                 ,MS_SKU.LINE02
                 ,WD_EXDCINSTRUCT.REFERENCE01            
                 ,WD_EXDC_DOCUMENT.MEMO1                     
           ) A 
           
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY 
                                 , WD_EXDC_PRTLOG.DCCODE
                                 , WD_EXDC_PRTLOG.DOCNO
                                 , WD_EXDC_PRTLOG.DOCLINE
                                 , COUNT(1)  AS COUNT
                            FROM WD_EXDC_PRTLOG
                            JOIN FC_META_TRAN 
                                ON WD_EXDC_PRTLOG.DOCNAME = FC_META_TRAN.TR_DOCNAME   
                            JOIN FC_MSG_TRAN
                                ON FC_META_TRAN.TR_BATCHID = FC_MSG_TRAN.TR_BATCHID
                            WHERE   WD_EXDC_PRTLOG.PAPERTYPE = 'FAX'
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY 
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE
                        )  T_FAX_CNT
                ON      T_FAX_CNT.STORERKEY = A.STORERKEY         
                    AND T_FAX_CNT.DCCODE    = A.DCCODE         
                    AND T_FAX_CNT.DOCNO     = A.SLIPNO         
                    AND T_FAX_CNT.DOCLINE   = A.SLIPLINE   
       
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY 
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , COUNT(1)  AS COUNT
                            FROM WD_EXDC_PRTLOG
                            JOIN FC_META_TRAN 
                                ON WD_EXDC_PRTLOG.DOCNAME = FC_META_TRAN.TR_DOCNAME   
                            JOIN FC_MSG_TRAN
                                ON FC_META_TRAN.TR_BATCHID = FC_MSG_TRAN.TR_BATCHID
                            WHERE   WD_EXDC_PRTLOG.PAPERTYPE = 'FAX'
                                AND FC_MSG_TRAN.TR_SENDSTAT  = '2'
                                AND FC_MSG_TRAN.TR_RSLTSTAT  = '0'
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY 
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE  
                        )  T_FAX_SUCC_CNT
                ON      T_FAX_SUCC_CNT.STORERKEY = A.STORERKEY         
                    AND T_FAX_SUCC_CNT.DCCODE    = A.DCCODE         
                    AND T_FAX_SUCC_CNT.DOCNO     = A.SLIPNO         
                    AND T_FAX_SUCC_CNT.DOCLINE   = A.SLIPLINE     
      
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY 
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , COUNT(1)  AS COUNT
                            FROM WD_EXDC_PRTLOG
                            JOIN FC_META_TRAN 
                                ON WD_EXDC_PRTLOG.DOCNAME = FC_META_TRAN.TR_DOCNAME   
                            JOIN FC_MSG_TRAN
                                ON FC_META_TRAN.TR_BATCHID = FC_MSG_TRAN.TR_BATCHID
                            WHERE   WD_EXDC_PRTLOG.PAPERTYPE = 'FAX'
                                AND FC_MSG_TRAN.TR_SENDSTAT  = '2'
                                AND FC_MSG_TRAN.TR_RSLTSTAT  NOT IN ('0','-')
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY 
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE  
                        )  T_FAX_FAIL_CNT
                ON    T_FAX_FAIL_CNT.STORERKEY = A.STORERKEY         
                  AND T_FAX_FAIL_CNT.DCCODE    = A.DCCODE         
                  AND T_FAX_FAIL_CNT.DOCNO     = A.SLIPNO         
                  AND T_FAX_FAIL_CNT.DOCLINE   = A.SLIPLINE          

            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , MAX(WD_EXDC_PRTLOG.DOCNAME) AS DOCNAME
                                , MAX(WD_EXDC_PRTLOG.SERIALKEY) AS SERIALKEY
                                , MAX(FC_META_TRAN.TR_BATCHID) AS TR_BATCHID
                                , MAX(FC_MSG_TRAN.TR_PHONE) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_PHONE
                                , MAX(FC_META_TRAN.TR_SENDDATE) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_SENDDATE
                                , MAX(FC_META_TRAN.TR_SENDNAME) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_SENDNAME
                                , MAX(WD_EXDC_PRTLOG.PRINTUSER) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS PRINTUSER
                            FROM (SELECT WD_EXDC_PRTLOG.STORERKEY
                                        , WD_EXDC_PRTLOG.DCCODE
                                        , WD_EXDC_PRTLOG.DOCNO
                                        , WD_EXDC_PRTLOG.DOCLINE
                                        , MAX(WD_EXDC_PRTLOG.SERIALKEY) AS SERIALKEY
                                        , MAX(WD_EXDC_PRTLOG.DOCNAME) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS DOCNAME
                                        , MAX(WD_EXDC_PRTLOG.PRINTUSER) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS PRINTUSER
                                  FROM WD_EXDC_PRTLOG
                                  WHERE WD_EXDC_PRTLOG.PAPERTYPE = 'FAX'
                                  GROUP BY WD_EXDC_PRTLOG.STORERKEY
                                        , WD_EXDC_PRTLOG.DCCODE
                                        , WD_EXDC_PRTLOG.DOCNO
                                        , WD_EXDC_PRTLOG.DOCLINE
                                ) WD_EXDC_PRTLOG 
                            JOIN FC_META_TRAN 
                                ON WD_EXDC_PRTLOG.DOCNAME = FC_META_TRAN.TR_DOCNAME   
                            JOIN FC_MSG_TRAN
                                ON FC_META_TRAN.TR_BATCHID = FC_MSG_TRAN.TR_BATCHID
                            WHERE   FC_MSG_TRAN.TR_SENDSTAT  = '2'
                                AND FC_MSG_TRAN.TR_RSLTSTAT  = '0'
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE
                        )  T_FAX_SUCC_TR
                ON    T_FAX_SUCC_TR.STORERKEY = A.STORERKEY         
                  AND T_FAX_SUCC_TR.DCCODE    = A.DCCODE         
                  AND T_FAX_SUCC_TR.DOCNO     = A.SLIPNO         
                  AND T_FAX_SUCC_TR.DOCLINE   = A.SLIPLINE      
       
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , MAX(WD_EXDC_PRTLOG.DOCNAME) AS DOCNAME
                                , MAX(WD_EXDC_PRTLOG.SERIALKEY) AS SERIALKEY
                                , MAX(FC_META_TRAN.TR_BATCHID) AS TR_BATCHID
                                , MAX(FC_MSG_TRAN.TR_PHONE) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_PHONE
                                , MAX(FC_META_TRAN.TR_SENDDATE) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_SENDDATE
                                , MAX(WD_EXDC_PRTLOG.PRINTUSER) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS PRINTUSER
                                , MAX(FC_META_TRAN.TR_SENDNAME) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_SENDNAME
                            FROM (SELECT WD_EXDC_PRTLOG.STORERKEY
                                        , WD_EXDC_PRTLOG.DCCODE
                                        , WD_EXDC_PRTLOG.DOCNO
                                        , WD_EXDC_PRTLOG.DOCLINE
                                        , MAX(WD_EXDC_PRTLOG.SERIALKEY) AS SERIALKEY
                                        , MAX(WD_EXDC_PRTLOG.DOCNAME) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS DOCNAME
                                        , MAX(WD_EXDC_PRTLOG.PRINTUSER) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS PRINTUSER
                                    FROM WD_EXDC_PRTLOG
                                    WHERE WD_EXDC_PRTLOG.PAPERTYPE = 'FAX'
                                    GROUP BY WD_EXDC_PRTLOG.STORERKEY
                                            , WD_EXDC_PRTLOG.DCCODE
                                            , WD_EXDC_PRTLOG.DOCNO
                                            , WD_EXDC_PRTLOG.DOCLINE
                                ) WD_EXDC_PRTLOG 
                            JOIN FC_META_TRAN 
                                ON WD_EXDC_PRTLOG.DOCNAME = FC_META_TRAN.TR_DOCNAME   
                            JOIN FC_MSG_TRAN
                                ON FC_META_TRAN.TR_BATCHID = FC_MSG_TRAN.TR_BATCHID
                            WHERE   FC_MSG_TRAN.TR_SENDSTAT  = '2'
                                AND FC_MSG_TRAN.TR_RSLTSTAT  NOT IN ('0','-')
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE
                        )  T_FAX_FAIL_TR
                ON    T_FAX_FAIL_TR.STORERKEY = A.STORERKEY         
                  AND T_FAX_FAIL_TR.DCCODE    = A.DCCODE         
                  AND T_FAX_FAIL_TR.DOCNO     = A.SLIPNO         
                  AND T_FAX_FAIL_TR.DOCLINE   = A.SLIPLINE  
       
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY 
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , COUNT(1)  AS COUNT
                            FROM WD_EXDC_PRTLOG
                            WHERE WD_EXDC_PRTLOG.PAPERTYPE = 'EMAIL'
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY 
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE
                        )  T_EMAIL_CNT
                ON    T_EMAIL_CNT.STORERKEY = A.STORERKEY         
                  AND T_EMAIL_CNT.DCCODE    = A.DCCODE         
                  AND T_EMAIL_CNT.DOCNO     = A.SLIPNO         
                  AND T_EMAIL_CNT.DOCLINE   = A.SLIPLINE      
       
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , MAX(WD_EXDC_PRTLOG.SERIALKEY) AS SERIALKEY
                                , MAX(WD_EXDC_PRTLOG.PRINTUSER) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS PRINTUSER                     
                                , MAX(WD_EXDC_PRTLOG.PRINTDT) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_SENDDATE
                            FROM WD_EXDC_PRTLOG 
                            WHERE WD_EXDC_PRTLOG.PAPERTYPE = 'EMAIL'
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE
                        )  T_EMAIL_TR
                ON    T_EMAIL_TR.STORERKEY = A.STORERKEY         
                  AND T_EMAIL_TR.DCCODE    = A.DCCODE         
                  AND T_EMAIL_TR.DOCNO     = A.SLIPNO         
                  AND T_EMAIL_TR.DOCLINE   = A.SLIPLINE                   
           
            LEFT OUTER JOIN(SELECT WD.STORERKEY
                                , WD.DCCODE
                                , WD.DOCNO
                                , WD.DOCLINE
                                , COUNT(1) AS COUNT
                        FROM WD_EXDC_PRTLOG WD
                        WHERE WD.PAPERTYPE = 'PRINT'
                        GROUP BY WD.STORERKEY
                                , WD.DCCODE
                                , WD.DOCNO
                                , WD.DOCLINE
                      )  T_PRT_CNT
                ON    T_PRT_CNT.STORERKEY = A.STORERKEY         
                  AND T_PRT_CNT.DCCODE    = A.DCCODE         
                  AND T_PRT_CNT.DOCNO     = A.SLIPNO         
                  AND T_PRT_CNT.DOCLINE   = A.SLIPLINE               
            
            LEFT OUTER JOIN FRAMEONE_USER USER1
                ON   USER1.USER_ID        = T_FAX_SUCC_TR.PRINTUSER 
                
            LEFT OUTER JOIN FRAMEONE_USER USER2
                ON   USER2.USER_ID        = T_FAX_FAIL_TR.PRINTUSER
                
            LEFT OUTER JOIN FRAMEONE_USER USER3
                ON   USER3.USER_ID        = T_EMAIL_TR.PRINTUSER
             
            LEFT OUTER JOIN FRAMEONE_USER USER4
                ON   USER4.USER_ID        = A.ADDWHO   
                
            LEFT OUTER JOIN FRAMEONE_USER USER5
                ON  (USER5.USER_ID        = A.DOCNOCONFIRM 
                     OR USER5.USER_NO     = A.DOCNOCONFIRM)           
                         
        UNION ALL        
        
        SELECT 
             A.*
            ,T_FAX_CNT.COUNT                                          AS FAX_CNT     
            ,T_FAX_SUCC_CNT.COUNT                                     AS FAX_SUCC_CNT     
            ,T_FAX_SUCC_TR.TR_PHONE                                   AS FAX_SUCC_TR_PHONE
            ,TO_CHAR(T_FAX_SUCC_TR.TR_SENDDATE, 'YYYYMMDDHH24MI')     AS FAX_SUCC_TR_SENDDATE
            ,T_FAX_SUCC_TR.PRINTUSER                                  AS FAX_SUCC_TR_SENDUSER
            ,USER1.USER_NM                                            AS FAX_SUCC_TR_SENDNAME
            ,T_FAX_FAIL_CNT.COUNT                                     AS FAX_FAIL_CNT
            ,T_FAX_FAIL_TR.TR_PHONE                                   AS FAX_FAIL_TR_PHONE
            ,T_FAX_FAIL_TR.TR_SENDDATE                                AS FAX_FAIL_TR_SENDDATE     
            ,T_FAX_FAIL_TR.PRINTUSER                                  AS FAX_FAIL_TR_SENDUSER
            ,USER2.USER_NM                                            AS FAX_FAIL_TR_SENDNAME
            ,T_EMAIL_CNT.COUNT                                        AS EMAIL_CNT
            ,T_EMAIL_TR.TR_SENDDATE                                   AS EMAIL_TR_SENDDATE
            ,T_EMAIL_TR.PRINTUSER                                     AS EMAIL_TR_SENDUSER
            ,USER3.USER_NM                                            AS EMAIL_TR_SENDNAME
            ,T_PRT_CNT.COUNT                                          AS PRT_CNT
            ,USER4.USER_NM                                            AS ADDWHO_NM
            ,USER5.USER_NM                                            AS DOCNOCONFIRM_NM
        FROM ( 
        
          SELECT
             CASE WHEN MAX(WD_AUTO_EXDCINSTRUCT.MAPKEY_NO) IS NOT NULL THEN 'Y' ELSE 'N' END                    AS CHECKTYPE      
            ,'0'                                                                                                AS CHECKYN
            ,WD_AUTO_EXDCINSTRUCT.DCCODE                                                                        AS DCCODE
            ,WD_AUTO_EXDCINSTRUCT.STORERKEY                                                                     AS STORERKEY
            ,WD_AUTO_EXDCINSTRUCT.ORGANIZE                                                                      AS ORGANIZE
            ,FN_DESCR_ORGANIZE(WD_AUTO_EXDCINSTRUCT.DCCODE, WD_AUTO_EXDCINSTRUCT.ORGANIZE)                      AS ORGANIZENAME
            ,'WD'                                                                                               AS DOCTYPE
            ,''                                                                                                 AS CHANNEL
            ,MAX(DM_DOCUMENT_H.DOCNO)                                                                           AS NORMAL_NO
            ,WD_AUTO_EXDCINSTRUCT.SLIPDT                                                                        AS DOCDT
            ,WD_AUTO_EXDCINSTRUCT.DOCNO                                                                         AS DOCNO
            ,WD_AUTO_EXDCINSTRUCT.DOCLINE                                                                       AS DOCLINE
            ,''                                                                                                 AS SLIPTYPE
            ,WD_AUTO_EXDCINSTRUCT.SLIPDT                                                                        AS SLIPDT
            ,WD_AUTO_EXDCINSTRUCT.DOCNO                                                                         AS SLIPNO
            ,WD_AUTO_EXDCINSTRUCT.DOCLINE                                                                       AS SLIPLINE
            ,WD_AUTO_EXDCINSTRUCT.CUSTKEY                                                                       AS CUSTKEY
            ,MAX(MS_CUST.DESCRIPTION)                                                                           AS CUSTNAME
            ,WD_AUTO_EXDCINSTRUCT.SKU                                                                           AS SKU
            ,MAX(MS_SKU.DESCRIPTION)                                                                            AS SKUNAME
            ,WD_AUTO_EXDCINSTRUCT.ORDERQTY                                                                      AS ORDERQTY
            ,WD_AUTO_EXDCINSTRUCT.BASEUOM                                                                       AS STORERUOM
            ,FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE)
                              , MAX(MS_SKU.DURATION)
                              , MAX(ST_SNINFO.LOTTABLE01), 'Y')                                                 AS NEARDURATIONYN
            ,MAX(ST_SNINFO.LOTTABLE01)                                                                          AS LOTTABLE01
            ,CASE WHEN FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE), MAX(MS_SKU.DURATION), MAX(ST_SNINFO.LOTTABLE01), 'N') > 0 
                      THEN ROUND(FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE), MAX(MS_SKU.DURATION), MAX(ST_SNINFO.LOTTABLE01), 'N') / MAX(MS_SKU.DURATION) * 100) 
                      ELSE 0 
                  END                                                                                           AS USEBYDATE_FREE_RT
            ,FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE)
                               , MAX(MS_SKU.DURATION)                    
                               , MAX(ST_SNINFO.LOTTABLE01), 'N') ||'/'|| MAX(MS_SKU.DURATION)                   AS DURATION_TERM
            ,WD_AUTO_EXDCINSTRUCT.SERIALNO                                                                      AS SERIALNO  
            ,''                                                                                                 AS FACTORYNAME
            ,''                                                                                                 AS PLACEOFORIGIN
            ,WD_AUTO_EXDCINSTRUCT.CONVERSERIALNO                                                                AS CONVSERIALNO
            ,''                                                                                                 AS BUTCHERYDT
            ,MAX(ST_SNINFO.CONTRACTCUSTKEY)                                                                     AS CONTRACTCOMPANY
            ,MAX((SELECT DESCRIPTION FROM MS_CUST                                                         
                       WHERE  MS_CUST.STORERKEY = ST_SNINFO.STORERKEY                                      
                       AND    MS_CUST.CUSTKEY   = ST_SNINFO.CONTRACTCUSTKEY                                
                       AND    ROWNUM = 1 ))                                                                     AS CONTRACTCOMPANYNAME
            ,MAX(ST_SNINFO.FROMVALIDDT)                                                                         AS FROMVALIDDT
            ,MAX(ST_SNINFO.TOVALIDDT)                                                                           AS TOVALIDDT
            ,MAX(CD2.BASEDESCR)                                                                                 AS CONTRACTTYPE
            ,MAX(WD_AUTO_EXDCINSTRUCT.SERIALNO)                                                                 AS BARCODE
            ,0                                                                                                  AS GROSSWEIGHT
            ,MAX(WD_AUTO_EXDCINSTRUCT.APRV_WHO)                                                                 AS ADDWHO
            ,CASE WHEN TO_NUMBER(NVL(MS_SKU.LINE02,0)) <![CDATA[<>]]> 0 
                       AND WD_AUTO_EXDCINSTRUCT.DCCODE = '2170' 
                       AND NVL(MS_SKU.LINE01,'N')      = 'Y'          
                  THEN TO_NUMBER(NVL(MS_SKU.LINE02,0)) 
                  ELSE 0 
             END                                                                                                AS AVGWEIGHT       /* 평균중량 */
            ,ROUND(CASE WHEN TO_NUMBER(NVL(MS_SKU.LINE02,0)) <![CDATA[<>]]> 0 
                             AND WD_AUTO_EXDCINSTRUCT.DCCODE  = '2170' 
                             AND NVL(MS_SKU.LINE01,'N')       = 'Y'    
                        THEN (MAX(WD_AUTO_EXDCINSTRUCT.ORDERQTY)) / TO_NUMBER(NVL(MS_SKU.LINE02,0)) 
                        ELSE 0 
                   END ,3)                                                                                      AS CALBOX           /* 환산박스 */    
            ,WD_AUTO_EXDCINSTRUCT.BOXQTY                                                                        AS REALORDERBOX     /* 실박스예정 */
            ,WD_AUTO_EXDCINSTRUCT.BOXQTY                                                                        AS REALCFMBOX       /* 실박스확정 */
            ,'0'                                                                                                AS BOXQTY
            ,'BOX'                                                                                              AS BOXUOM
            ,'N'                                                                                                AS BOXFLAG            
            ,MAX(WD_AUTO_EXDCINSTRUCT.DEL_YN)                                                                   AS ALL_CANCEL_STATUS
            ,MAX(CD1.BASEDESCR)                                                                                 AS DELIVERYTYPENAME
            ,MAX(MS_PLANTXSL.FAX        )                                                                       AS RECVFAXNO
            ,MAX(MS_PLANTXSL.DESCRIPTION)                                                                       AS RECVNAME 
            ,MAX(MS_PLANTXSL.EMAIL)                                                                             AS RECVEMAIL
            ,''                                                                                                 AS MEMO1
            ,WD_EXDC_DOCUMENT.MEMO1                                                                             AS MEMO2 
            ,MAX(MS_PLANTXSL.COMM_CODE)                                                                         AS COMM_CODE
            ,MAX(WD_AUTO_EXDCINSTRUCT.MAPKEY_NO)                                                                AS MAPKEY_NO
            ,CASE WHEN MAX(WD_AUTO_EXDCINSTRUCT.MAPKEY_NO) IS NOT NULL 
                  THEN MAX(TO_CHAR(WD_AUTO_EXDCINSTRUCT.ADDDATE,'YYYY-MM-DD HH24:MI'))
                  ELSE '' END                                                                                   AS ADDDATE
            ,MAX(WD_AUTO_EXDCINSTRUCT.ADDWHO)                                                                   AS DOCNOCONFIRM  
            ,MAX(MS_SKU.QTYPERBOX)                                                                              AS QTYPERBOX
            ,NULL                                                                                               AS REASONCODENAME
            
          FROM   WD_AUTO_EXDCINSTRUCT 
          LEFT OUTER JOIN   (
                 SELECT MS_CUST.STORERKEY, MS_CUST.CUSTKEY, MAX(MS_CUST.DESCRIPTION) AS DESCRIPTION 
                 FROM   MS_CUST 
                 GROUP  BY MS_CUST.STORERKEY, MS_CUST.CUSTKEY ) MS_CUST 
            ON   MS_CUST.STORERKEY            = WD_AUTO_EXDCINSTRUCT.STORERKEY
            AND  MS_CUST.CUSTKEY              = WD_AUTO_EXDCINSTRUCT.CUSTKEY
          LEFT OUTER  JOIN MS_SKU
            ON   MS_SKU.STORERKEY             = WD_AUTO_EXDCINSTRUCT.STORERKEY
            AND  MS_SKU.SKU                   = WD_AUTO_EXDCINSTRUCT.SKU
          LEFT OUTER JOIN MS_PLANTXSL 
            ON  1=1
            AND  WD_AUTO_EXDCINSTRUCT.DCCODE     = MS_PLANTXSL.PLANT
            AND  WD_AUTO_EXDCINSTRUCT.ORGANIZE   = MS_PLANTXSL.PLANT||'-'||MS_PLANTXSL.STORAGELOC
          LEFT OUTER JOIN WD_EXDC_DOCUMENT 
            ON   WD_EXDC_DOCUMENT.DCCODE         = WD_AUTO_EXDCINSTRUCT.DCCODE
            AND  WD_EXDC_DOCUMENT.STORERKEY      = WD_AUTO_EXDCINSTRUCT.STORERKEY              
            AND  WD_EXDC_DOCUMENT.DOCNO          = WD_AUTO_EXDCINSTRUCT.DOCNO                  
            AND  WD_EXDC_DOCUMENT.DOCLINE        = WD_AUTO_EXDCINSTRUCT.DOCLINE
          LEFT OUTER JOIN DM_DOCUMENT_H 
            ON   DM_DOCUMENT_H.DCCODE            = WD_AUTO_EXDCINSTRUCT.DCCODE
            AND  DM_DOCUMENT_H.STORERKEY         = WD_AUTO_EXDCINSTRUCT.STORERKEY   
            AND  DM_DOCUMENT_H.DELIVERYDATE      = WD_AUTO_EXDCINSTRUCT.SLIPDT   
            AND  DM_DOCUMENT_H.DOCNO             = WD_AUTO_EXDCINSTRUCT.DOCNO 
            AND  DM_DOCUMENT_H.DOCTYPE           = 'WD'
            AND  DM_DOCUMENT_H.REAL_YN           = 'R' 
          LEFT OUTER JOIN DM_DOCUMENT_D 
            ON   DM_DOCUMENT_D.DCCODE            = DM_DOCUMENT_H.DCCODE
            AND  DM_DOCUMENT_D.STORERKEY         = DM_DOCUMENT_H.STORERKEY   
            AND  DM_DOCUMENT_D.DELIVERYDATE      = DM_DOCUMENT_H.DELIVERYDATE   
            AND  DM_DOCUMENT_D.DOCNO             = DM_DOCUMENT_H.DOCNO 
            AND  DM_DOCUMENT_D.DOCTYPE           = DM_DOCUMENT_H.DOCTYPE
          LEFT OUTER JOIN ST_STOCK
            ON   ST_STOCK.DCCODE                 = DM_DOCUMENT_D.DCCODE
            AND  ST_STOCK.STORERKEY              = DM_DOCUMENT_D.STORERKEY
            AND  ST_STOCK.ORGANIZE               = DM_DOCUMENT_D.ORGANIZE
            AND  ST_STOCK.AREA                   = DM_DOCUMENT_D.AREA
            AND  ST_STOCK.SKU                    = DM_DOCUMENT_D.SKU
            AND  ST_STOCK.STOCKID                = DM_DOCUMENT_D.STOCKID
            AND  ST_STOCK.STOCKGRADE             = DM_DOCUMENT_D.STOCKGRADE
          LEFT OUTER JOIN ST_SNINFO
            ON   DM_DOCUMENT_D.STORERKEY         = ST_SNINFO.STORERKEY
            AND  DM_DOCUMENT_D.SKU               = ST_SNINFO.SKU
            AND  DM_DOCUMENT_D.STOCKID           = ST_SNINFO.STOCKID
          
          LEFT OUTER JOIN CM_CODE_STORER CD1
            ON   CD1.STORERKEY                   = WD_AUTO_EXDCINSTRUCT.STORERKEY
            AND  CD1.CODELIST                    = 'DELIVERYTYPE' 
            AND  CD1.BASECODE                    = (SELECT CASE WHEN DM_DOCUMENT_H.WORKPROCESSCODE = 'STO' THEN 'WOD'
                                                                   ELSE DM_DOCUMENT_H.DELIVERYTYPE
                                                               END
                                                       FROM  DM_DOCUMENT_H 
                                                       WHERE DM_DOCUMENT_H.DCCODE         = WD_AUTO_EXDCINSTRUCT.DCCODE 
                                                        AND  DM_DOCUMENT_H.DOCTYPE        = 'WD'
                                                        AND  DM_DOCUMENT_H.DELIVERYDATE   = WD_AUTO_EXDCINSTRUCT.SLIPDT
                                                        AND  DM_DOCUMENT_H.DOCNO          = WD_AUTO_EXDCINSTRUCT.DOCNO) 
          LEFT OUTER JOIN CM_CODE_STORER CD2
            ON   CD2.STORERKEY                   = WD_AUTO_EXDCINSTRUCT.STORERKEY
            AND  CD2.CODELIST                    = 'CONTRACTTYPE_SN'   
            AND  CD2.BASECODE                    = ST_SNINFO.CONTRACTTYPE
                
          WHERE  1=1 
            AND  WD_AUTO_EXDCINSTRUCT.ORDERQTY    <![CDATA[>]]> 0
            AND  WD_AUTO_EXDCINSTRUCT.REFERENCE01        = '20'    
        <if test="organizeMulti != null and organizeMulti != ''">
            AND  WD_AUTO_EXDCINSTRUCT.ORGANIZE IN
            <foreach collection="organizeMulti" item="item" open="(" separator="," close=")">
                 #{item}
            </foreach> 
        </if>
        <if test="fromSlipdt != null and fromSlipdt != ''">   
            AND  WD_AUTO_EXDCINSTRUCT.SLIPDT  <![CDATA[>=]]>  #{fromSlipdt}      
        </if>
        <if test="toSlipdt != null and toSlipdt != ''">     
            AND  WD_AUTO_EXDCINSTRUCT.SLIPDT  <![CDATA[<=]]>  #{toSlipdt}        
        </if>

        <if test="docnoMulti != null and docnoMulti != ''">
            AND  WD_AUTO_EXDCINSTRUCT.DOCNO      IN
                 <foreach collection="docnoMulti" item="item" open="(" separator="," close=")">
                     #{item}
                 </foreach> 
           </if> 
        <if test="fromcustkey != null and fromcustkey != ''">
            AND  WD_AUTO_EXDCINSTRUCT.TO_CUSTKEY IN (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
                                                    FROM (SELECT #{fromcustkey} AS VAL FROM DUAL) A
                                                    CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
        </if>
        <if test="tocustkeyMulti != null and tocustkeyMulti != ''">
            AND  WD_AUTO_EXDCINSTRUCT.CUSTKEY IN
                <foreach collection="tocustkeyMulti" item="item" open="(" separator="," close=")">
                   #{item}
                </foreach> 
        </if>
        <if test="sku != null and sku != '' ">
            <if test="skuMulti != null and skuMulti.size() > 0">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="skuMulti" item="item">
                        OR WD_AUTO_EXDCINSTRUCT.SKU IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}      
                        </foreach>
                    </foreach>
                </trim>                                             
            </if>
        </if>  

        <if test="blnoMulti != null and blnoMulti != ''">
            AND  WD_AUTO_EXDCINSTRUCT.CONVERSERIALNO      IN
                 <foreach collection="blnoMulti" item="item" open="(" separator="," close=")">
                     #{item}
                 </foreach> 
        </if>
         
          GROUP BY 
                WD_AUTO_EXDCINSTRUCT.DCCODE                  
               ,WD_AUTO_EXDCINSTRUCT.STORERKEY               
               ,WD_AUTO_EXDCINSTRUCT.ORGANIZE       
               ,WD_AUTO_EXDCINSTRUCT.DOCNO
               ,WD_AUTO_EXDCINSTRUCT.DOCLINE                              
               ,WD_AUTO_EXDCINSTRUCT.SLIPDT                  
               ,WD_AUTO_EXDCINSTRUCT.DOCNO                  
               ,WD_AUTO_EXDCINSTRUCT.DOCLINE         
               ,WD_AUTO_EXDCINSTRUCT.CUSTKEY                 
               ,WD_AUTO_EXDCINSTRUCT.ORDERQTY 
               ,WD_AUTO_EXDCINSTRUCT.BOXQTY 
               ,WD_AUTO_EXDCINSTRUCT.BASEUOM       
               ,WD_AUTO_EXDCINSTRUCT.SALESUOM 
               ,WD_AUTO_EXDCINSTRUCT.SERIALNO
               ,WD_AUTO_EXDCINSTRUCT.SKU
               ,WD_AUTO_EXDCINSTRUCT.CONVERSERIALNO
               ,MS_SKU.LINE01
               ,MS_SKU.LINE02
               ,WD_EXDC_DOCUMENT.MEMO1 
         ) A 
         
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY 
                                 , WD_EXDC_PRTLOG.DCCODE
                                 , WD_EXDC_PRTLOG.DOCNO
                                 , WD_EXDC_PRTLOG.DOCLINE
                                 , COUNT(1)  AS COUNT
                            FROM WD_EXDC_PRTLOG
                            JOIN FC_META_TRAN 
                                ON WD_EXDC_PRTLOG.DOCNAME = FC_META_TRAN.TR_DOCNAME   
                            JOIN FC_MSG_TRAN
                                ON FC_META_TRAN.TR_BATCHID = FC_MSG_TRAN.TR_BATCHID
                            WHERE   WD_EXDC_PRTLOG.PAPERTYPE = 'FAX'
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY 
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE
                        )  T_FAX_CNT
                ON      T_FAX_CNT.STORERKEY = A.STORERKEY         
                    AND T_FAX_CNT.DCCODE    = A.DCCODE         
                    AND T_FAX_CNT.DOCNO     = A.DOCNO         
                    AND T_FAX_CNT.DOCLINE   = A.DOCLINE   
       
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY 
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , COUNT(1)  AS COUNT
                            FROM WD_EXDC_PRTLOG
                            JOIN FC_META_TRAN 
                                ON WD_EXDC_PRTLOG.DOCNAME = FC_META_TRAN.TR_DOCNAME   
                            JOIN FC_MSG_TRAN
                                ON FC_META_TRAN.TR_BATCHID = FC_MSG_TRAN.TR_BATCHID
                            WHERE   WD_EXDC_PRTLOG.PAPERTYPE = 'FAX'
                                AND FC_MSG_TRAN.TR_SENDSTAT  = '2'
                                AND FC_MSG_TRAN.TR_RSLTSTAT  = '0'
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY 
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE  
                        )  T_FAX_SUCC_CNT
                ON      T_FAX_SUCC_CNT.STORERKEY = A.STORERKEY         
                    AND T_FAX_SUCC_CNT.DCCODE    = A.DCCODE         
                    AND T_FAX_SUCC_CNT.DOCNO     = A.DOCNO         
                    AND T_FAX_SUCC_CNT.DOCLINE   = A.DOCLINE     
      
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY 
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , COUNT(1)  AS COUNT
                            FROM WD_EXDC_PRTLOG
                            JOIN FC_META_TRAN 
                                ON WD_EXDC_PRTLOG.DOCNAME = FC_META_TRAN.TR_DOCNAME   
                            JOIN FC_MSG_TRAN
                                ON FC_META_TRAN.TR_BATCHID = FC_MSG_TRAN.TR_BATCHID
                            WHERE   WD_EXDC_PRTLOG.PAPERTYPE = 'FAX'
                                AND FC_MSG_TRAN.TR_SENDSTAT  = '2'
                                AND FC_MSG_TRAN.TR_RSLTSTAT  NOT IN ('0','-')
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY 
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE  
                        )  T_FAX_FAIL_CNT
                ON    T_FAX_FAIL_CNT.STORERKEY = A.STORERKEY         
                  AND T_FAX_FAIL_CNT.DCCODE    = A.DCCODE         
                  AND T_FAX_FAIL_CNT.DOCNO     = A.DOCNO         
                  AND T_FAX_FAIL_CNT.DOCLINE   = A.DOCLINE  

            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , MAX(WD_EXDC_PRTLOG.DOCNAME) AS DOCNAME
                                , MAX(WD_EXDC_PRTLOG.SERIALKEY) AS SERIALKEY
                                , MAX(FC_META_TRAN.TR_BATCHID) AS TR_BATCHID
                                , MAX(FC_MSG_TRAN.TR_PHONE) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_PHONE
                                , MAX(FC_META_TRAN.TR_SENDDATE) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_SENDDATE
                                , MAX(FC_META_TRAN.TR_SENDNAME) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_SENDNAME
                                , MAX(WD_EXDC_PRTLOG.PRINTUSER) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS PRINTUSER
                            FROM (SELECT WD_EXDC_PRTLOG.STORERKEY
                                        , WD_EXDC_PRTLOG.DCCODE
                                        , WD_EXDC_PRTLOG.DOCNO
                                        , WD_EXDC_PRTLOG.DOCLINE
                                        , MAX(WD_EXDC_PRTLOG.SERIALKEY) AS SERIALKEY
                                        , MAX(WD_EXDC_PRTLOG.DOCNAME) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS DOCNAME
                                        , MAX(WD_EXDC_PRTLOG.PRINTUSER) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS PRINTUSER
                                  FROM WD_EXDC_PRTLOG
                                  WHERE WD_EXDC_PRTLOG.PAPERTYPE = 'FAX'
                                  GROUP BY WD_EXDC_PRTLOG.STORERKEY
                                        , WD_EXDC_PRTLOG.DCCODE
                                        , WD_EXDC_PRTLOG.DOCNO
                                        , WD_EXDC_PRTLOG.DOCLINE
                                ) WD_EXDC_PRTLOG 
                            JOIN FC_META_TRAN 
                                ON WD_EXDC_PRTLOG.DOCNAME = FC_META_TRAN.TR_DOCNAME   
                            JOIN FC_MSG_TRAN
                                ON FC_META_TRAN.TR_BATCHID = FC_MSG_TRAN.TR_BATCHID
                            WHERE   FC_MSG_TRAN.TR_SENDSTAT  = '2'
                                AND FC_MSG_TRAN.TR_RSLTSTAT  = '0'
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE
                        )  T_FAX_SUCC_TR
                ON    T_FAX_SUCC_TR.STORERKEY = A.STORERKEY         
                  AND T_FAX_SUCC_TR.DCCODE    = A.DCCODE         
                  AND T_FAX_SUCC_TR.DOCNO     = A.DOCNO         
                  AND T_FAX_SUCC_TR.DOCLINE   = A.DOCLINE      
       
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , MAX(WD_EXDC_PRTLOG.DOCNAME) AS DOCNAME
                                , MAX(WD_EXDC_PRTLOG.SERIALKEY) AS SERIALKEY
                                , MAX(FC_META_TRAN.TR_BATCHID) AS TR_BATCHID
                                , MAX(FC_MSG_TRAN.TR_PHONE) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_PHONE
                                , MAX(FC_META_TRAN.TR_SENDDATE) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_SENDDATE
                                , MAX(WD_EXDC_PRTLOG.PRINTUSER) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS PRINTUSER
                                , MAX(FC_META_TRAN.TR_SENDNAME) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_SENDNAME
                            FROM (SELECT WD_EXDC_PRTLOG.STORERKEY
                                        , WD_EXDC_PRTLOG.DCCODE
                                        , WD_EXDC_PRTLOG.DOCNO
                                        , WD_EXDC_PRTLOG.DOCLINE
                                        , MAX(WD_EXDC_PRTLOG.SERIALKEY) AS SERIALKEY
                                        , MAX(WD_EXDC_PRTLOG.DOCNAME) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS DOCNAME
                                        , MAX(WD_EXDC_PRTLOG.PRINTUSER) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS PRINTUSER
                                    FROM WD_EXDC_PRTLOG
                                    WHERE WD_EXDC_PRTLOG.PAPERTYPE = 'FAX'
                                    GROUP BY WD_EXDC_PRTLOG.STORERKEY
                                            , WD_EXDC_PRTLOG.DCCODE
                                            , WD_EXDC_PRTLOG.DOCNO
                                            , WD_EXDC_PRTLOG.DOCLINE
                                ) WD_EXDC_PRTLOG 
                            JOIN FC_META_TRAN 
                                ON WD_EXDC_PRTLOG.DOCNAME = FC_META_TRAN.TR_DOCNAME   
                            JOIN FC_MSG_TRAN
                                ON FC_META_TRAN.TR_BATCHID = FC_MSG_TRAN.TR_BATCHID
                            WHERE   FC_MSG_TRAN.TR_SENDSTAT  = '2'
                                AND FC_MSG_TRAN.TR_RSLTSTAT  NOT IN ('0','-')
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE
                        )  T_FAX_FAIL_TR
                ON    T_FAX_FAIL_TR.STORERKEY = A.STORERKEY         
                  AND T_FAX_FAIL_TR.DCCODE    = A.DCCODE         
                  AND T_FAX_FAIL_TR.DOCNO     = A.DOCNO         
                  AND T_FAX_FAIL_TR.DOCLINE   = A.DOCLINE  
       
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY 
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , COUNT(1)  AS COUNT
                            FROM WD_EXDC_PRTLOG
                            WHERE WD_EXDC_PRTLOG.PAPERTYPE = 'EMAIL'
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY 
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE
                        )  T_EMAIL_CNT
                ON    T_EMAIL_CNT.STORERKEY = A.STORERKEY         
                  AND T_EMAIL_CNT.DCCODE    = A.DCCODE         
                  AND T_EMAIL_CNT.DOCNO     = A.DOCNO         
                  AND T_EMAIL_CNT.DOCLINE   = A.DOCLINE      
       
            LEFT OUTER JOIN(SELECT WD_EXDC_PRTLOG.STORERKEY
                                , WD_EXDC_PRTLOG.DCCODE
                                , WD_EXDC_PRTLOG.DOCNO
                                , WD_EXDC_PRTLOG.DOCLINE
                                , MAX(WD_EXDC_PRTLOG.SERIALKEY) AS SERIALKEY
                                , MAX(WD_EXDC_PRTLOG.PRINTUSER) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS PRINTUSER                     
                                , MAX(WD_EXDC_PRTLOG.PRINTDT) KEEP (DENSE_RANK LAST ORDER BY WD_EXDC_PRTLOG.SERIALKEY) AS TR_SENDDATE
                            FROM WD_EXDC_PRTLOG 
                            WHERE WD_EXDC_PRTLOG.PAPERTYPE = 'EMAIL'
                            GROUP BY WD_EXDC_PRTLOG.STORERKEY
                                    , WD_EXDC_PRTLOG.DCCODE
                                    , WD_EXDC_PRTLOG.DOCNO
                                    , WD_EXDC_PRTLOG.DOCLINE
                        )  T_EMAIL_TR
                ON    T_EMAIL_TR.STORERKEY = A.STORERKEY         
                  AND T_EMAIL_TR.DCCODE    = A.DCCODE         
                  AND T_EMAIL_TR.DOCNO     = A.DOCNO         
                  AND T_EMAIL_TR.DOCLINE   = A.DOCLINE                   
           
            LEFT OUTER JOIN(SELECT WD.STORERKEY
                                , WD.DCCODE
                                , WD.DOCNO
                                , WD.DOCLINE
                                , COUNT(1) AS COUNT
                        FROM WD_EXDC_PRTLOG WD
                        WHERE WD.PAPERTYPE = 'PRINT'
                        GROUP BY WD.STORERKEY
                                , WD.DCCODE
                                , WD.DOCNO
                                , WD.DOCLINE
                      )  T_PRT_CNT
                ON    T_PRT_CNT.STORERKEY = A.STORERKEY         
                  AND T_PRT_CNT.DCCODE    = A.DCCODE         
                  AND T_PRT_CNT.DOCNO     = A.DOCNO         
                  AND T_PRT_CNT.DOCLINE   = A.DOCLINE  
                  
            LEFT OUTER JOIN FRAMEONE_USER USER1
                ON   USER1.USER_ID        = T_FAX_SUCC_TR.PRINTUSER 
                
            LEFT OUTER JOIN FRAMEONE_USER USER2
                ON   USER2.USER_ID        = T_FAX_FAIL_TR.PRINTUSER
                
            LEFT OUTER JOIN FRAMEONE_USER USER3
                ON   USER3.USER_ID        = T_EMAIL_TR.PRINTUSER 

            LEFT OUTER JOIN FRAMEONE_USER USER4
                ON   USER4.USER_ID        = A.ADDWHO
                
            LEFT OUTER JOIN FRAMEONE_USER USER5
                ON  (USER5.USER_ID        = A.DOCNOCONFIRM 
                     OR USER5.USER_NO     = A.DOCNOCONFIRM) 
         )
         
         WHERE 1=1
         <if test="send == 1">                
            AND  (NVL(FAX_CNT,0) = 0 AND NVL(EMAIL_CNT,0) = 0 AND NVL(PRT_CNT,0) = 0) 
         </if> 
         <if test="errorsend == 1">           
            AND  NVL(FAX_FAIL_CNT,0) != 0 
         </if>
         <if test="allCancelStatus == 1">    
            AND  ALL_CANCEL_STATUS = 'Y' 
         </if>           
         <if test="mapkeyNo != null and mapkeyNo != ''">
            AND  MAPKEY_NO IN (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
                              FROM (SELECT #{mapkeyNo} AS VAL FROM DUAL) A
                              CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
         </if>
         <if test="cfyn == 1">    
            AND  MAPKEY_NO IS NOT NULL     
         </if> 
         <if test="noNormal == 1">    
            AND  NORMAL_NO IS NULL     
        </if>  
         ORDER BY MAPKEY_NO
            
    </select> 

    <select id="getDataPrintListOrder" resultType="WdSendOutOrderPrintResDto">  
    SELECT 
        *    
    FROM (    
        SELECT    /* [wdSendOutOrderService.sqlx][getDataPrintListOrder][출고지시서 정보(오더있음)][sunho.kim][2025.06.16] */
              '0'                                                                                            AS CHECKYN
              ,#{gSpid}                                                                                      AS SPID
              ,MAX(FRAMEONE_USER.USER_ID)                                                                    AS USER_ID
              ,MAX(FRAMEONE_USER.USER_NM)                                                                    AS USER_NM
              ,WD_INPLAN.DCCODE                                                                              AS DCCODE
              ,WD_INPLAN.STORERKEY                                                                           AS STORERKEY
              ,WD_INPLAN.ORGANIZE                                                                            AS ORGANIZE
              ,DECODE(MS_PLANTXSL.DESCRIPTION, NULL,'창고미등록', MS_PLANTXSL.DESCRIPTION)                      AS ORGANIZENAME
              ,MAX(DAMO.DEC(FRAMEONE_EMP.COTEL_NO))                                                          AS PHONE1
              ,MAX(MS_PLANTXSL.PHONE1)                                                                       AS PHONE2
              ,'WD'                                                                                          AS DOCTYPE
              ,DM_DOCUMENT_D.CHANNEL                                                                         AS CHANNEL
              ,MAX(DM_DOCUMENT_H2.DOCNO)                                                                     AS NORMAL_NO
              ,WD_INPLAN.DOCDT                                                                               AS DOCDT
              ,WD_INPLAN.DOCNO                                                                               AS DOCNO
              ,WD_INPLAN.DOCLINE                                                                             AS DOCLINE
              ,WD_INPLAN.SLIPTYPE                                                                            AS SLIPTYPE
              ,FN_FORMAT_MASK(WD_INPLAN.SLIPDT, '####-##-##')                                                AS SLIPDT
              ,WD_INPLAN.SLIPNO                                                                              AS SLIPNO
              ,WD_INPLAN.SLIPLINE                                                                            AS SLIPLINE
              ,WD_INPLAN.SKU                                                                                 AS SKU
              ,MAX(MS_SKU.DESCRIPTION)
                ||MAX(DECODE(DM_DOCUMENT_D.UOM, 'KG','', ' 박스입수:'||MS_SKU.QTYPERBOX))               
                ||MAX(DECODE(FN_DESCR_CODE(MS_SKU.STORERKEY,'COUNTRY',MS_SKU.COUNTRYOFORIGIN) ,'NOT FOUND','','/'||FN_DESCR_CODE(MS_SKU.STORERKEY,'COUNTRY',MS_SKU.COUNTRYOFORIGIN) ))
                                                                                                             AS SKUNAME
              ,WD_INPLAN.CUSTKEY                                                                             AS CUSTKEY
              ,MAX(MS_CUST.DESCRIPTION)                                                                      AS CUSTNAME
              ,DM_DOCUMENT_D.STOREROPENQTY                                                                   AS ORDERQTY 
              ,MAX(SY_PROCESSTEMP_WD.UOM)                                                                    AS STORERUOM
              ,ROUND(DECODE(DM_DOCUMENT_D.STORERUOM,'KG',MAX(DM_DOCUMENT_D.QCQTY),FN_CONV_UOM(WD_INPLAN.STORERKEY,WD_INPLAN.SKU,DM_DOCUMENT_D.STORERUOM,'BOX',DM_DOCUMENT_D.STOREROPENQTY)),3) AS BOXQTY
              ,CASE WHEN MAX(MS_SKU.OTHER04) = 'Y' THEN MAX(MS_SKU.LINE03) ELSE MAX(DM_DOCUMENT_D.UOM) END   AS BOXUOM
              ,MAX(NVL(WD_INVOICE_SN.ETCQTY1,0))                                                             AS REALORDERBOX
              ,FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE), MAX(MS_SKU.DURATION)
                                               , MAX(ST_SNINFO.LOTTABLE01), 'Y')                             AS NEARDURATIONYN
              ,MAX(ST_SNINFO.LOTTABLE01)                                                                     AS LOTTABLE01              
              ,CASE WHEN FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE), MAX(MS_SKU.DURATION), MAX(ST_SNINFO.LOTTABLE01), 'N') > 0 
                    THEN ROUND(FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE), MAX(MS_SKU.DURATION), MAX(ST_SNINFO.LOTTABLE01), 'N') / MAX(MS_SKU.DURATION) * 100) 
                    ELSE 0 
               END                                                                                           AS USEBYDATE_FREE_RT
              ,FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE), MAX(MS_SKU.DURATION)                    
                                              , MAX(ST_SNINFO.LOTTABLE01), 'N') ||'/'|| MAX(MS_SKU.DURATION) AS DURATION_TERM
              ,MAX(ST_SNINFO.SERIALNO)                                                                       AS SERIALNO  
              ,MAX(ST_SNINFO.FACTORYNAME)                                                                    AS FACTORYNAME
              ,MAX(ST_SNINFO.PLACEOFORIGIN)                                                                  AS PLACEOFORIGIN
              ,CASE WHEN MAX(ST_SNINFO.CONTAINERNO) IS NOT NULL 
                    THEN MAX(ST_SNINFO.CONVSERIALNO) || CHR(10) || '/' || MAX(ST_SNINFO.SERIALNO) ||CHR(10) || '/' || MAX(ST_SNINFO.CONTAINERNO) 
                    ELSE MAX(ST_SNINFO.CONVSERIALNO) || CHR(10) || '/' || MAX(ST_SNINFO.SERIALNO)
                    END                                                                                      AS CONVSERIALNO
              ,MAX(ST_SNINFO.BUTCHERYDT)                                                                     AS BUTCHERYDT
              ,MAX(ST_SNINFO.CONTRACTCUSTKEY)                                                                AS CONTRACTCOMPANY
              ,MAX((SELECT DESCRIPTION FROM MS_CUST                                                         
                    WHERE  MS_CUST.STORERKEY = ST_SNINFO.STORERKEY                                      
                    AND    MS_CUST.CUSTKEY   = ST_SNINFO.CONTRACTCUSTKEY                                
                    AND    ROWNUM = 1 ))                                                                     AS CONTRACTCOMPANYNAME
              ,MAX(ST_SNINFO.FROMVALIDDT)                                                                    AS FROMVALIDDT
              ,MAX(ST_SNINFO.TOVALIDDT)                                                                      AS TOVALIDDT
              ,MAX(CD1.BASEDESCR)                                                                            AS CONTRACTTYPE
              ,MAX(ST_SNINFO.STOCKID)                                                                        AS BARCODE
              ,MAX(WD_INVOICE_SN.WEIGHT)                                                                     AS GROSSWEIGHT
              ,MAX(CD2.BASEDESCR)                                                                            AS MEMO2
              ,CASE WHEN MAX(DM_DOCUMENT_D.MEMO1) IS NULL AND MAX(WD_EXDC_DOCUMENT.MEMO1) IS NULL 
                    THEN NULL
                    WHEN MAX(DM_DOCUMENT_D.MEMO1) IS NOT NULL AND MAX(WD_EXDC_DOCUMENT.MEMO1) IS NULL
                    THEN MAX(DM_DOCUMENT_D.MEMO1)
                    WHEN MAX(DM_DOCUMENT_D.MEMO1) IS NULL AND MAX(WD_EXDC_DOCUMENT.MEMO1) IS NOT NULL
                    THEN MAX(WD_EXDC_DOCUMENT.MEMO1)
                    ELSE MAX(DM_DOCUMENT_D.MEMO1) || ', ' || MAX(WD_EXDC_DOCUMENT.MEMO1)
                 END                                                                                         AS MEMO1 
              ,MAX(DAMO.DEC(FRAMEONE_EMP.COTEL_NO))                                                          AS USER_COTEL_NO
              ,MAX(DAMO.DEC(FRAMEONE_EMP.HANDPHONE_NO))                                                      AS USER_HANDPHONE_NO
              ,ROW_NUMBER() OVER(PARTITION BY MS_PLANTXSL.DESCRIPTION, WD_INPLAN.SLIPDT, WD_INPLAN.CUSTKEY  ORDER BY MS_PLANTXSL.DESCRIPTION, WD_INPLAN.SLIPDT, WD_INPLAN.CUSTKEY) 
                                                                                                             AS ROWCNT              
              ,MAX(MS_PLANTXSL.FAX)                                                                          AS RECVFAXNO
              ,MAX(MS_PLANTXSL.DESCRIPTION)                                                                  AS RECVNAME
              ,MAX(MS_PLANTXSL.EMAIL)                                                                        AS RECVEMAIL
              ,WD_INPLAN.ORGANIZE||'_'||WD_INPLAN.SLIPDT||'_'||WD_INPLAN.CUSTKEY                             AS PRINTKEY
              ,CASE WHEN substr(WD_INPLAN.ORGANIZE,6,4) between '1000' and '4000' THEN 'TYPE_A' ELSE 'TYPE_B' END                           AS PRINTTYPE
              ,MAX((SELECT BASEDESCR FROM CM_CODE WHERE STORERKEY = 'FW00' AND CODELIST = 'STORAGETYPE' AND BASECODE = MS_SKU.STORAGETYPE)) AS STORAGETYPE
              ,MAX(MS_PLANTXSL.FAX2)                                                                         AS RECVFAXNO2
              ,MAX(MS_PLANTXSL.EMAIL2)                                                                       AS RECVEMAIL2
              ,''                                                                                            AS MAPKEY_NO
              ,MAX(OM_EXDC_DELIVERY_INFO.DELIVERY_ADDR)                                                      AS DELIVERY_ADDR
        FROM  SY_PROCESSTEMP_WD
        JOIN  WD_INPLAN
            ON    SY_PROCESSTEMP_WD.ORGANIZE        = WD_INPLAN.ORGANIZE
            AND   SY_PROCESSTEMP_WD.SLIPDT          = WD_INPLAN.SLIPDT
            AND   SY_PROCESSTEMP_WD.SLIPNO          = WD_INPLAN.SLIPNO
            AND   SY_PROCESSTEMP_WD.SLIPLINE        = WD_INPLAN.SLIPLINE
            AND   SY_PROCESSTEMP_WD.DOCNO           = WD_INPLAN.DOCNO
            AND   SY_PROCESSTEMP_WD.DOCLINE         = WD_INPLAN.DOCLINE
        JOIN   CM_USER_AUTHORITY           
            ON     1=1     
        <if test="dccode != null and dccode != ''">           
            AND    CM_USER_AUTHORITY.DCCODE     =  #{dccode}          
        </if>
        <if test="gStorerkey != null and gStorerkey != ''">     
            AND    CM_USER_AUTHORITY.STORERKEY  =  #{gStorerkey}       
        </if>
        <if test="area != null and area != ''">          
            AND    CM_USER_AUTHORITY.AREA       =  #{area}                
        </if>
        <if test="organizeMulti != null and organizeMulti != ''">
            AND    CM_USER_AUTHORITY.ORGANIZE      IN
            <foreach collection="organizeMulti" item="item" open="(" separator="," close=")">
                 #{item}
            </foreach> 
        </if>
            AND    CM_USER_AUTHORITY.USERID     = #{gUserId}    
            AND    CM_USER_AUTHORITY.DCCODE     = WD_INPLAN.DCCODE             
            AND    CM_USER_AUTHORITY.STORERKEY  = WD_INPLAN.STORERKEY          
            AND    CM_USER_AUTHORITY.ORGANIZE   = WD_INPLAN.ORGANIZE           
            AND    CM_USER_AUTHORITY.AREA       = WD_INPLAN.AREA    
        JOIN   DM_DOCUMENT_D
            ON     DM_DOCUMENT_D.DCCODE      = WD_INPLAN.DCCODE            
            AND    DM_DOCUMENT_D.STORERKEY   = WD_INPLAN.STORERKEY  
            AND    DM_DOCUMENT_D.ORGANIZE    = WD_INPLAN.ORGANIZE
            AND    DM_DOCUMENT_D.DOCTYPE     = WD_INPLAN.DOCTYPE  
            AND    DM_DOCUMENT_D.DELIVERYDATE= WD_INPLAN.SLIPDT            
            AND    DM_DOCUMENT_D.DOCNO       = WD_INPLAN.DOCNO            
            AND    DM_DOCUMENT_D.DOCLINE     = WD_INPLAN.DOCLINE            
            AND    DM_DOCUMENT_D.DEL_YN      = 'N'
        LEFT OUTER JOIN   DM_DOCUMENT_H
            ON     DM_DOCUMENT_H.DCCODE      = DM_DOCUMENT_D.DCCODE
            AND    DM_DOCUMENT_H.STORERKEY   = DM_DOCUMENT_D.STORERKEY
            AND    DM_DOCUMENT_H.ORGANIZE    = DM_DOCUMENT_D.ORGANIZE
            AND    DM_DOCUMENT_H.DOCTYPE     = DM_DOCUMENT_D.DOCTYPE
            AND    DM_DOCUMENT_H.DELIVERYDATE= DM_DOCUMENT_D.DELIVERYDATE            
            AND    DM_DOCUMENT_H.DOCNO       = DM_DOCUMENT_D.DOCNO  
        LEFT OUTER JOIN WD_INVOICE_SN
            ON     WD_INVOICE_SN.DCCODE      = DM_DOCUMENT_D.DCCODE              
            AND    WD_INVOICE_SN.STORERKEY   = DM_DOCUMENT_D.STORERKEY        
            AND    WD_INVOICE_SN.DOCTYPE     = DM_DOCUMENT_D.DOCTYPE
            AND    WD_INVOICE_SN.WD_DOCNO    = DM_DOCUMENT_D.DOCNO                              
            AND    WD_INVOICE_SN.WD_DOCDT    = DM_DOCUMENT_D.DOCDT                  
            AND    WD_INVOICE_SN.WD_DOCLINE  = DM_DOCUMENT_D.DOCLINE                   
            AND    WD_INVOICE_SN.SKU         = DM_DOCUMENT_D.SKU
            AND    WD_INVOICE_SN.DEL_YN      = 'N'  
        JOIN   MS_SKU
            ON     MS_SKU.STORERKEY          = WD_INPLAN.STORERKEY
            AND    MS_SKU.SKU                = WD_INPLAN.SKU
            AND    MS_SKU.DEL_YN             = 'N'
        LEFT OUTER JOIN WD_INVOICE_SN              
            ON   WD_INVOICE_SN.DCCODE        = WD_INPLAN.DCCODE                                 
            AND  WD_INVOICE_SN.STORERKEY     = WD_INPLAN.STORERKEY                      
            AND  WD_INVOICE_SN.DOCTYPE       = WD_INPLAN.DOCTYPE              
            AND  WD_INVOICE_SN.WD_SLIPNO     = WD_INPLAN.SLIPNO                                            
            AND  WD_INVOICE_SN.WD_SLIPDT     = WD_INPLAN.SLIPDT                                 
            AND  WD_INVOICE_SN.WD_SLIPLINE   = WD_INPLAN.SLIPLINE                                 
            AND  WD_INVOICE_SN.SKU           = WD_INPLAN.SKU                    
        LEFT OUTER JOIN   ST_SNINFO           
            ON   ST_SNINFO.STORERKEY         = WD_INVOICE_SN.STORERKEY
            AND  ST_SNINFO.SKU               = WD_INVOICE_SN.SKU
            AND  ST_SNINFO.STOCKID           = WD_INVOICE_SN.STOCKID
        LEFT OUTER JOIN   MS_PLANTXSL
            ON   MS_PLANTXSL.PLANT||'-'||MS_PLANTXSL.STORAGELOC = WD_INPLAN.ORGANIZE          
        LEFT OUTER JOIN   (
                 SELECT MS_CUST.STORERKEY, MS_CUST.CUSTKEY, MAX(MS_CUST.DESCRIPTION) AS DESCRIPTION 
                 FROM   MS_CUST 
                 GROUP  BY MS_CUST.STORERKEY, MS_CUST.CUSTKEY ) MS_CUST   
            ON   MS_CUST.STORERKEY           = WD_INPLAN.STORERKEY   
            AND  MS_CUST.CUSTKEY             = WD_INPLAN.CUSTKEY         
        LEFT OUTER JOIN   FRAMEONE_USER
            ON     FRAMEONE_USER.USER_ID     = #{gUserId}
        LEFT OUTER JOIN   FRAMEONE_EMP
            ON     FRAMEONE_USER.EMP_NO      = FRAMEONE_EMP.EMP_NO
        LEFT OUTER JOIN WD_EXDC_DOCUMENT 
            ON   WD_EXDC_DOCUMENT.DCCODE     = WD_INPLAN.DCCODE
            AND  WD_EXDC_DOCUMENT.STORERKEY  = WD_INPLAN.STORERKEY              
            AND  WD_EXDC_DOCUMENT.DOCNO      = WD_INPLAN.DOCNO                  
            AND  WD_EXDC_DOCUMENT.DOCLINE    = WD_INPLAN.DOCLINE            
        LEFT OUTER JOIN DM_DOCUMENT_H DM_DOCUMENT_H2
            ON   DM_DOCUMENT_H2.DCCODE       = WD_INPLAN.DCCODE
            AND  DM_DOCUMENT_H2.STORERKEY    = WD_INPLAN.STORERKEY   
            AND  DM_DOCUMENT_H2.DELIVERYDATE = WD_INPLAN.SLIPDT
            AND  DM_DOCUMENT_H2.DOCNO        = WD_INPLAN.DOCNO 
            AND  DM_DOCUMENT_H2.DOCTYPE      = 'WD'
            AND  DM_DOCUMENT_H2.REAL_YN      = 'R'         
        LEFT OUTER JOIN OM_EXDC_DELIVERY_INFO
            ON   OM_EXDC_DELIVERY_INFO.DOCNO   = WD_INPLAN.DOCNO 
            AND  OM_EXDC_DELIVERY_INFO.DOCLINE = WD_INPLAN.DOCLINE  
        LEFT OUTER JOIN CM_CODE_STORER CD1
            ON   CD1.STORERKEY               = WD_INPLAN.STORERKEY
            AND  CD1.CODELIST                = 'CONTRACTTYPE_SN'   
            AND  CD1.BASECODE                = ST_SNINFO.CONTRACTTYPE
        LEFT OUTER JOIN CM_CODE_STORER CD2
            ON   CD2.STORERKEY               = WD_INPLAN.STORERKEY
            AND  CD2.CODELIST                = 'DELIVERYTYPE'   
            AND  CD2.BASECODE                = (SELECT CASE WHEN MAX(DM_DOCUMENT_H.WORKPROCESSCODE) = 'STO'
                                                            THEN 'WOD'
                                                            ELSE MAX(DM_DOCUMENT_H.DELIVERYTYPE)
                                                        END
                                                FROM DM_DOCUMENT_H
                                                WHERE DM_DOCUMENT_H.DCCODE       = WD_INPLAN.DCCODE
                                                  AND DM_DOCUMENT_H.ORGANIZE     = WD_INPLAN.ORGANIZE
                                                  AND DM_DOCUMENT_H.DELIVERYDATE = WD_INPLAN.SLIPDT
                                                  AND DM_DOCUMENT_H.DOCNO        = WD_INPLAN.DOCNO
                                               ) 
        
        WHERE  1=1 
            AND   SY_PROCESSTEMP_WD.PROCESSTYPE     = #{processtype}
            AND   SY_PROCESSTEMP_WD.PROCESSCREATOR  = #{gUserId}
            AND   SY_PROCESSTEMP_WD.SPID            = #{gSpid} 
            AND   SY_PROCESSTEMP_WD.ORDERTYPE       = 'A'
        
        GROUP BY 
              WD_INPLAN.DCCODE                  
             ,WD_INPLAN.STORERKEY               
             ,WD_INPLAN.ORGANIZE                
             ,DM_DOCUMENT_D.CHANNEL           
             ,WD_INPLAN.DOCDT                   
             ,WD_INPLAN.DOCNO                   
             ,WD_INPLAN.DOCLINE                 
             ,WD_INPLAN.SLIPTYPE                
             ,WD_INPLAN.SLIPDT                  
             ,WD_INPLAN.SLIPNO                  
             ,WD_INPLAN.SLIPLINE                
             ,WD_INPLAN.CUSTKEY                 
             ,DM_DOCUMENT_D.STOREROPENQTY 
             ,DM_DOCUMENT_D.STORERUOM       
             ,WD_INPLAN.SKU                     
             ,MS_PLANTXSL.DESCRIPTION     
        
        UNION 
        
        SELECT   
            '0'                                                                                            AS CHECKYN
            ,#{gSpid}                                                                                      AS SPID
            ,MAX(FRAMEONE_USER.USER_ID)                                                                    AS USER_ID
            ,MAX(FRAMEONE_USER.USER_NM)                                                                    AS USER_NM
            ,WD_AUTO_EXDCINSTRUCT.DCCODE                                                                   AS DCCODE
            ,WD_AUTO_EXDCINSTRUCT.STORERKEY                                                                AS STORERKEY
            ,WD_AUTO_EXDCINSTRUCT.ORGANIZE                                                                 AS ORGANIZE
            ,FN_DESCR_ORGANIZE(WD_AUTO_EXDCINSTRUCT.DCCODE, WD_AUTO_EXDCINSTRUCT.ORGANIZE)                 AS ORGANIZENAME
            ,MAX(DAMO.DEC(FRAMEONE_EMP.COTEL_NO))                                                          AS PHONE1
            ,MAX(MS_PLANTXSL.PHONE1)                                                                       AS PHONE2
            ,'WD'                                                                                          AS DOCTYPE
            ,''                                                                                            AS CHANNEL
            ,MAX(DM_DOCUMENT_H.DOCNO)                                                                      AS NORMAL_NO
            ,WD_AUTO_EXDCINSTRUCT.SLIPDT                                                                   AS DOCDT
            ,WD_AUTO_EXDCINSTRUCT.DOCNO                                                                    AS DOCNO
            ,WD_AUTO_EXDCINSTRUCT.DOCLINE                                                                  AS DOCLINE
            ,''                                                                                            AS SLIPTYPE
            ,WD_AUTO_EXDCINSTRUCT.SLIPDT                                                                   AS SLIPDT
            ,WD_AUTO_EXDCINSTRUCT.DOCNO                                                                    AS SLIPNO
            ,WD_AUTO_EXDCINSTRUCT.DOCLINE                                                                  AS SLIPLINE
            ,WD_AUTO_EXDCINSTRUCT.SKU                                                                      AS SKU
            ,MAX(MS_SKU.DESCRIPTION)                                                                       AS SKUNAME
            ,WD_AUTO_EXDCINSTRUCT.CUSTKEY                                                                  AS CUSTKEY
            ,MAX(MS_CUST.DESCRIPTION)                                                                      AS CUSTNAME
            ,WD_AUTO_EXDCINSTRUCT.ORDERQTY                                                                 AS ORDERQTY 
            ,WD_AUTO_EXDCINSTRUCT.BASEUOM                                                                  AS STORERUOM
            ,0                                                                                             AS BOXQTY
            ,'BOX'                                                                                         AS BOXUOM
            ,NVL(WD_AUTO_EXDCINSTRUCT.BOXQTY, 0)                                                           AS REALORDERBOX
            ,''                                                                                            AS NEARDURATIONYN
            ,''                                                                                            AS LOTTABLE01              
            ,0                                                                                             AS USEBYDATE_FREE_RT
            ,''                                                                                            AS DURATION_TERM
            ,WD_AUTO_EXDCINSTRUCT.SERIALNO                                                                 AS SERIALNO  
            ,''                                                                                            AS FACTORYNAME
            ,''                                                                                            AS PLACEOFORIGIN
            ,WD_AUTO_EXDCINSTRUCT.CONVERSERIALNO                                                           AS CONVSERIALNO
            ,''                                                                                            AS BUTCHERYDT
            ,''                                                                                            AS CONTRACTCOMPANY
            ,''                                                                                            AS CONTRACTCOMPANYNAME
            ,''                                                                                            AS FROMVALIDDT
            ,''                                                                                            AS TOVALIDDT
            ,''                                                                                            AS CONTRACTTYPE
            ,MAX(WD_AUTO_EXDCINSTRUCT.SERIALNO)                                                            AS BARCODE
            ,0                                                                                             AS GROSSWEIGHT
            ,MAX(CD2.BASEDESCR)                                                                            AS MEMO2
            ,MAX(DM_DOCUMENT_D.MEMO1)                                                                      AS MEMO1 
            ,MAX(DAMO.DEC(FRAMEONE_EMP.COTEL_NO))                                                          AS USER_COTEL_NO
            ,MAX(DAMO.DEC(FRAMEONE_EMP.HANDPHONE_NO))                                                      AS USER_HANDPHONE_NO
            ,ROW_NUMBER() OVER(PARTITION BY MAX(MS_PLANTXSL.DESCRIPTION), WD_AUTO_EXDCINSTRUCT.SLIPDT, WD_AUTO_EXDCINSTRUCT.CUSTKEY  
                               ORDER BY MAX(MS_PLANTXSL.DESCRIPTION), WD_AUTO_EXDCINSTRUCT.SLIPDT, WD_AUTO_EXDCINSTRUCT.CUSTKEY) 
                                                                                                           AS ROWCNT  
            ,MAX(MS_PLANTXSL.FAX)                                                                          AS RECVFAXNO
            ,MAX(MS_PLANTXSL.DESCRIPTION)                                                                  AS RECVNAME
            ,MAX(MS_PLANTXSL.EMAIL)                                                                        AS RECVEMAIL
            ,WD_AUTO_EXDCINSTRUCT.ORGANIZE||'_'||WD_AUTO_EXDCINSTRUCT.SLIPDT||'_'||WD_AUTO_EXDCINSTRUCT.CUSTKEY                           AS PRINTKEY
            ,CASE WHEN substr(WD_AUTO_EXDCINSTRUCT.ORGANIZE,6,4) between '1000' and '4000' THEN 'TYPE_A' ELSE 'TYPE_B' END                AS PRINTTYPE
            ,MAX((SELECT BASEDESCR FROM CM_CODE WHERE STORERKEY = 'FW00' AND CODELIST = 'STORAGETYPE' AND BASECODE = MS_SKU.STORAGETYPE)) AS STORAGETYPE
            ,MAX(MS_PLANTXSL.FAX2)                                                                         AS RECVFAXNO2
            ,MAX(MS_PLANTXSL.EMAIL2)                                                                       AS RECVEMAIL2
            ,''                                                                                            AS MAPKEY_NO
            ,MAX(OM_EXDC_DELIVERY_INFO.DELIVERY_ADDR)                                                      AS DELIVERY_ADDR
        FROM  SY_PROCESSTEMP_WD
        JOIN  WD_AUTO_EXDCINSTRUCT
            ON    SY_PROCESSTEMP_WD.ORGANIZE   = WD_AUTO_EXDCINSTRUCT.ORGANIZE
            AND   SY_PROCESSTEMP_WD.SLIPDT     = WD_AUTO_EXDCINSTRUCT.SLIPDT
            AND   SY_PROCESSTEMP_WD.SLIPNO     = WD_AUTO_EXDCINSTRUCT.DOCNO
            AND   SY_PROCESSTEMP_WD.SLIPLINE   = WD_AUTO_EXDCINSTRUCT.DOCLINE  
            AND   SY_PROCESSTEMP_WD.DOCNO      = WD_AUTO_EXDCINSTRUCT.DOCNO
            AND   SY_PROCESSTEMP_WD.DOCLINE    = WD_AUTO_EXDCINSTRUCT.DOCLINE
        LEFT OUTER JOIN  (
                 SELECT MS_CUST.STORERKEY, MS_CUST.CUSTKEY, MAX(MS_CUST.DESCRIPTION) AS DESCRIPTION 
                 FROM   MS_CUST 
                 GROUP  BY MS_CUST.STORERKEY, MS_CUST.CUSTKEY ) MS_CUST  
          ON   MS_CUST.STORERKEY               = #{gStorerkey}
          AND  MS_CUST.CUSTKEY                 = WD_AUTO_EXDCINSTRUCT.CUSTKEY
        LEFT OUTER JOIN   MS_SKU
          ON   MS_SKU.STORERKEY                = WD_AUTO_EXDCINSTRUCT.STORERKEY
          AND  MS_SKU.SKU                      = WD_AUTO_EXDCINSTRUCT.SKU
        LEFT OUTER JOIN MS_PLANTXSL 
          ON   WD_AUTO_EXDCINSTRUCT.DCCODE     = MS_PLANTXSL.PLANT
          AND  WD_AUTO_EXDCINSTRUCT.ORGANIZE   = MS_PLANTXSL.PLANT||'-'||MS_PLANTXSL.STORAGELOC
        LEFT OUTER JOIN WD_EXDC_DOCUMENT 
          ON   WD_EXDC_DOCUMENT.DCCODE         = WD_AUTO_EXDCINSTRUCT.DCCODE
          AND  WD_EXDC_DOCUMENT.STORERKEY      = WD_AUTO_EXDCINSTRUCT.STORERKEY              
          AND  WD_EXDC_DOCUMENT.DOCNO          = WD_AUTO_EXDCINSTRUCT.DOCNO                  
          AND  WD_EXDC_DOCUMENT.DOCLINE        = WD_AUTO_EXDCINSTRUCT.DOCLINE
        LEFT OUTER JOIN DM_DOCUMENT_H 
          ON   DM_DOCUMENT_H.DCCODE            = WD_AUTO_EXDCINSTRUCT.DCCODE
          AND  DM_DOCUMENT_H.STORERKEY         = WD_AUTO_EXDCINSTRUCT.STORERKEY   
          AND  DM_DOCUMENT_H.DELIVERYDATE      = WD_AUTO_EXDCINSTRUCT.SLIPDT   
          AND  DM_DOCUMENT_H.DOCNO             = WD_AUTO_EXDCINSTRUCT.DOCNO 
          AND  DM_DOCUMENT_H.DOCTYPE           = 'WD'
          AND  DM_DOCUMENT_H.REAL_YN           = 'R'
        LEFT OUTER JOIN DM_DOCUMENT_D 
          ON   DM_DOCUMENT_D.DCCODE            = DM_DOCUMENT_H.DCCODE
          AND  DM_DOCUMENT_D.STORERKEY         = DM_DOCUMENT_H.STORERKEY   
          AND  DM_DOCUMENT_D.DELIVERYDATE      = DM_DOCUMENT_H.DELIVERYDATE   
          AND  DM_DOCUMENT_D.DOCNO             = DM_DOCUMENT_H.DOCNO 
          AND  DM_DOCUMENT_D.DOCTYPE           = DM_DOCUMENT_H.DOCTYPE
        LEFT OUTER JOIN OM_EXDC_DELIVERY_INFO
          ON   OM_EXDC_DELIVERY_INFO.DOCNO    = WD_AUTO_EXDCINSTRUCT.DOCNO 
          AND  OM_EXDC_DELIVERY_INFO.DOCLINE  = WD_AUTO_EXDCINSTRUCT.DOCLINE
        LEFT OUTER JOIN   FRAMEONE_USER
          ON  FRAMEONE_USER.USER_ID            = #{gUserId}
        LEFT OUTER JOIN   FRAMEONE_EMP
          ON  FRAMEONE_USER.EMP_NO             = FRAMEONE_EMP.EMP_NO 
        LEFT OUTER JOIN CM_CODE_STORER CD2
          ON   CD2.STORERKEY                = WD_AUTO_EXDCINSTRUCT.STORERKEY
          AND  CD2.CODELIST                 = 'DELIVERYTYPE'   
          AND  CD2.BASECODE                 = (SELECT CASE WHEN DM_DOCUMENT_H.WORKPROCESSCODE = 'STO' THEN 'WOD'
                                                           ELSE DM_DOCUMENT_H.DELIVERYTYPE
                                                       END
                                                 FROM  DM_DOCUMENT_H 
                                                 WHERE DM_DOCUMENT_H.DCCODE         = WD_AUTO_EXDCINSTRUCT.DCCODE   
                                                  AND  DM_DOCUMENT_H.DOCTYPE        = 'WD'  
                                                  AND  DM_DOCUMENT_H.DELIVERYDATE   = WD_AUTO_EXDCINSTRUCT.SLIPDT
                                                  AND  DM_DOCUMENT_H.DOCNO          = WD_AUTO_EXDCINSTRUCT.DOCNO)
        
        WHERE  1=1 
          AND  SY_PROCESSTEMP_WD.PROCESSTYPE     = #{processtype}
          AND  SY_PROCESSTEMP_WD.PROCESSCREATOR  = #{gUserId}
          AND  SY_PROCESSTEMP_WD.SPID            = #{gSpid} 
          AND  SY_PROCESSTEMP_WD.ORDERTYPE       = 'B'
        
        GROUP BY                                
              WD_AUTO_EXDCINSTRUCT.DCCODE                  
             ,WD_AUTO_EXDCINSTRUCT.STORERKEY               
             ,WD_AUTO_EXDCINSTRUCT.ORGANIZE       
             ,WD_AUTO_EXDCINSTRUCT.DOCNO
             ,WD_AUTO_EXDCINSTRUCT.DOCLINE                              
             ,WD_AUTO_EXDCINSTRUCT.SLIPDT                  
             ,WD_AUTO_EXDCINSTRUCT.CUSTKEY                 
             ,WD_AUTO_EXDCINSTRUCT.ORDERQTY 
             ,WD_AUTO_EXDCINSTRUCT.BOXQTY 
             ,WD_AUTO_EXDCINSTRUCT.BASEUOM       
             ,WD_AUTO_EXDCINSTRUCT.SALESUOM 
             ,WD_AUTO_EXDCINSTRUCT.SERIALNO
             ,WD_AUTO_EXDCINSTRUCT.SKU
             ,WD_AUTO_EXDCINSTRUCT.CONVERSERIALNO
             ,MS_SKU.LINE01
             ,MS_SKU.LINE02
             ,WD_EXDC_DOCUMENT.MEMO1
             ,DM_DOCUMENT_D.DOCNO
    ) T
    ORDER BY  T.RECVNAME, T.SLIPDT         
    </select>
     
    <select id="getDataPrintListNotOrder" resultType="WdSendOutOrderPrintResDto">
        SELECT 
            * 
        FROM 
        (         
            SELECT    /* [wdSendOutOrderService.sqlx][getDataPrintListNotOrder][출고지시서 정보(오더없음)][sunho.kim][2025.06.19] */
                 '0'                                                                                          AS CHECKYN
                ,#{gSpid}                                                                                     AS SPID
                ,MAX(FRAMEONE_USER.USER_ID)                                                                   AS USER_ID
                ,MAX(FRAMEONE_USER.USER_NM)                                                                   AS USER_NM
                ,WD_EXDCINSTRUCT.DCCODE                                                                       AS DCCODE
                ,WD_EXDCINSTRUCT.STORERKEY                                                                    AS STORERKEY
                ,WD_EXDCINSTRUCT.ORGANIZE                                                                     AS ORGANIZE
                ,DECODE(MS_PLANTXSL.DESCRIPTION,NULL,'창고미등록',MS_PLANTXSL.DESCRIPTION)                       AS ORGANIZENAME
                ,MAX(DAMO.DEC(FRAMEONE_EMP.COTEL_NO))                                                         AS PHONE1
                ,MAX(MS_PLANTXSL.PHONE1)                                                                      AS PHONE2
                ,WD_EXDCINSTRUCT.DOCTYPE                                                                      AS DOCTYPE
                ,''                                                                                           AS CHANNEL
                ,MAX(DM_DOCUMENT_H.DOCNO)                                                                     AS NORMAL_NO
                --,DECODE(WD_EXDCINSTRUCT.DOCDT,NULL,WD_EXDCINSTRUCT.INSTRUCTDT)                                AS DOCDT
                --,DECODE(WD_EXDCINSTRUCT.DOCNO,NULL,WD_EXDCINSTRUCT.INSTRUCTNO)                                AS DOCNO
                --,DECODE(WD_EXDCINSTRUCT.DOCLINE,NULL,WD_EXDCINSTRUCT.INSTRUCTLINE)                            AS DOCLINE
                ,DECODE(WD_EXDCINSTRUCT.DOCDT,NULL,WD_EXDCINSTRUCT.INSTRUCTDT, WD_EXDCINSTRUCT.DOCDT)         AS DOCDT
                ,DECODE(WD_EXDCINSTRUCT.DOCNO,NULL,WD_EXDCINSTRUCT.INSTRUCTNO, WD_EXDCINSTRUCT.DOCNO)         AS DOCNO
                ,DECODE(WD_EXDCINSTRUCT.DOCLINE,NULL,WD_EXDCINSTRUCT.INSTRUCTLINE, WD_EXDCINSTRUCT.DOCLINE)   AS DOCLINE
                ,''                                                                                           AS SLIPTYPE
                ,FN_FORMAT_MASK(DECODE(WD_EXDCINSTRUCT.SLIPDT,NULL,WD_EXDCINSTRUCT.INSTRUCTDT, WD_EXDCINSTRUCT.SLIPDT), '####-##-##') AS SLIPDT
                ,DECODE(WD_EXDCINSTRUCT.SLIPNO,NULL,WD_EXDCINSTRUCT.INSTRUCTNO,WD_EXDCINSTRUCT.SLIPNO)        AS SLIPNO
                ,DECODE(WD_EXDCINSTRUCT.SLIPLINE,NULL,WD_EXDCINSTRUCT.INSTRUCTLINE,WD_EXDCINSTRUCT.SLIPLINE)  AS SLIPLINE
                ,WD_EXDCINSTRUCT.SKU                                                                          AS SKU
                ,MAX(MS_SKU.DESCRIPTION)
                  ||MAX(DECODE(WD_EXDCINSTRUCT.UOM,'KG','',' 박스입수:'||MS_SKU.QTYPERBOX))               
                  ||MAX(DECODE(FN_DESCR_CODE(MS_SKU.STORERKEY,'COUNTRY',MS_SKU.COUNTRYOFORIGIN) ,'NOT FOUND','','/'||FN_DESCR_CODE(MS_SKU.STORERKEY,'COUNTRY',MS_SKU.COUNTRYOFORIGIN) ))
                                                                                                                 AS SKUNAME
                ,WD_EXDCINSTRUCT.CUSTKEY                                                                         AS CUSTKEY
                ,MAX(MS_CUST.DESCRIPTION)                                                                        AS CUSTNAME
                ,''                                                                                              AS TO_CUSTKEY
                ,''                                                                                              AS TO_CUSTNAME
                ,WD_EXDCINSTRUCT.ORDERQTY                                                                        AS ORDERQTY                                                          
                ,WD_EXDCINSTRUCT.UOM                                                                             AS STORERUOM
                ,ROUND(DECODE(WD_EXDCINSTRUCT.UOM,'KG',MAX(WD_EXDCINSTRUCT.BOXQTY),FN_CONV_UOM(WD_EXDCINSTRUCT.STORERKEY,WD_EXDCINSTRUCT.SKU,WD_EXDCINSTRUCT.UOM,'BOX',WD_EXDCINSTRUCT.ORDERQTY)),3) 
                                                                                                                 AS BOXQTY
                ,CASE WHEN MAX(MS_SKU.OTHER04) = 'Y' THEN MAX(MS_SKU.LINE03) ELSE MAX(WD_EXDCINSTRUCT.UOM) END AS BOXUOM
                ,NVL(WD_EXDCINSTRUCT.BOXQTY,0)                                                                   AS REALORDERBOX         
                ,''                                                                                              AS NEARDURATIONYN
                ,''                                                                                              AS LOTTABLE01
                ,0                                                                                               AS USEBYDATE_FREE_RT
                ,''                                                                                              AS DURATION_TERM
                ,MAX(WD_EXDCINSTRUCT.SERIALNO)                                                                   AS SERIALNO  
                ,''                                                                                              AS FACTORYNAME
                ,''                                                                                              AS PLACEOFORIGIN
                ,MAX(WD_EXDCINSTRUCT.CONVSERIALNO)||CHR(10)||'/'||MAX(WD_EXDCINSTRUCT.SERIALNO)                  AS CONVSERIALNO
                ,''                                                                                              AS BUTCHERYDT
                ,''                                                                                              AS CONTRACTCOMPANY
                ,''                                                                                              AS CONTRACTCOMPANYNAME
                ,''                                                                                              AS FROMVALIDDT
                ,''                                                                                              AS TOVALIDDT
                ,''                                                                                              AS CONTRACTTYPE
                ,MAX(WD_EXDCINSTRUCT.STOCKID)                                                                    AS BARCODE
                ,0                                                                                               AS GROSSWEIGHT
                ,FN_DESCR_CODE(WD_EXDCINSTRUCT.STORERKEY, 'DELIVERYTYPE_FS', MAX(WD_EXDCINSTRUCT.DELIVERYTYPE))  AS MEMO2
                ,CASE WHEN MAX(WD_EXDCINSTRUCT.REFERENCE01) IS NULL AND MAX(WD_EXDC_DOCUMENT.MEMO1) IS NULL 
                      THEN NULL
                      WHEN MAX(WD_EXDCINSTRUCT.REFERENCE01) IS NOT NULL AND MAX(WD_EXDC_DOCUMENT.MEMO1) IS NULL
                      THEN MAX(WD_EXDCINSTRUCT.REFERENCE01)
                      WHEN MAX(WD_EXDCINSTRUCT.REFERENCE01) IS NULL AND MAX(WD_EXDC_DOCUMENT.MEMO1) IS NOT NULL
                      THEN MAX(WD_EXDC_DOCUMENT.MEMO1)
                      ELSE MAX(WD_EXDCINSTRUCT.REFERENCE01) || ', ' || MAX(WD_EXDC_DOCUMENT.MEMO1)
                   END                                                                                           AS MEMO1
                ,MAX(DAMO.DEC(FRAMEONE_EMP.COTEL_NO))                                                            AS USER_COTEL_NO
                ,MAX(DAMO.DEC(FRAMEONE_EMP.HANDPHONE_NO))                                                        AS USER_HANDPHONE_NO
                ,ROW_NUMBER() OVER(PARTITION BY MS_PLANTXSL.DESCRIPTION, WD_EXDCINSTRUCT.SLIPDT, WD_EXDCINSTRUCT.CUSTKEY  ORDER BY MS_PLANTXSL.DESCRIPTION, WD_EXDCINSTRUCT.SLIPDT) 
                                                                                                                 AS ROWCNT
                ,''                                                                                              AS CONTAINERNO            
                ,MAX(MS_PLANTXSL.FAX        )                                                                    AS RECVFAXNO
                ,MAX(MS_PLANTXSL.DESCRIPTION)                                                                    AS RECVNAME
                ,MAX(MS_PLANTXSL.EMAIL)                                                                          AS RECVEMAIL  
                ,WD_EXDCINSTRUCT.ORGANIZE||'_'||NVL(WD_EXDCINSTRUCT.SLIPDT,WD_EXDCINSTRUCT.INSTRUCTDT)||'_'||WD_EXDCINSTRUCT.CUSTKEY          AS PRINTKEY
                ,CASE WHEN substr(WD_EXDCINSTRUCT.ORGANIZE,6,4) between '1000' and '4000' THEN 'TYPE_A' ELSE 'TYPE_B' END                     AS PRINTTYPE
                ,MAX((SELECT BASEDESCR FROM CM_CODE WHERE STORERKEY = 'FW00' AND CODELIST = 'STORAGETYPE' AND BASECODE = MS_SKU.STORAGETYPE)) AS STORAGETYPE
                ,MAX(MS_PLANTXSL.FAX2)                                                                           AS RECVFAXNO2
                ,MAX(MS_PLANTXSL.EMAIL2)                                                                         AS RECVEMAIL2
                ,''                                                                                              AS MAPKEY_NO
                ,''                                                                                              AS ALL_CANCEL_STATUS
                ,MAX(OM_EXDC_DELIVERY_INFO.DELIVERY_ADDR)                                                        AS DELIVERY_ADDR
            FROM  SY_PROCESSTEMP_WD
            JOIN  WD_EXDCINSTRUCT
                ON    SY_PROCESSTEMP_WD.ORGANIZE        = WD_EXDCINSTRUCT.ORGANIZE
                AND   SY_PROCESSTEMP_WD.SLIPDT          = DECODE(WD_EXDCINSTRUCT.SLIPDT,NULL,WD_EXDCINSTRUCT.INSTRUCTDT, WD_EXDCINSTRUCT.SLIPDT)
                AND   SY_PROCESSTEMP_WD.SLIPNO          = DECODE(WD_EXDCINSTRUCT.SLIPNO,NULL,WD_EXDCINSTRUCT.INSTRUCTNO, WD_EXDCINSTRUCT.SLIPNO)
                AND   SY_PROCESSTEMP_WD.SLIPLINE        = DECODE(WD_EXDCINSTRUCT.SLIPLINE,NULL,WD_EXDCINSTRUCT.INSTRUCTLINE, WD_EXDCINSTRUCT.SLIPLINE)
                AND   WD_EXDCINSTRUCT.ORDERQTY   <![CDATA[>]]> 0
                AND   WD_EXDCINSTRUCT.DEL_YN           = 'N' /*삭제건은 출력 불가하도록 조건 추가 20180622(김영문님 삭제시에도 표시되도록 기능요청)*/
            JOIN   CM_USER_AUTHORITY           
                ON     1=1
            <if test="dccode != null and dccode != ''">           
                AND    CM_USER_AUTHORITY.DCCODE     =  #{dccode}          
            </if>
            <if test="gStorerkey != null and gStorerkey != ''">  
                AND    CM_USER_AUTHORITY.STORERKEY  =  #{gStorerkey}       
            </if>
            <if test="area != null and area != ''">               
                AND    CM_USER_AUTHORITY.AREA       =  #{area}                
            </if>
            <if test="organizeMulti != null and organizeMulti != ''">
                AND    CM_USER_AUTHORITY.ORGANIZE      IN
              <foreach collection="organizeMulti" item="item" open="(" separator="," close=")">
                 #{item}
              </foreach> 
            </if>
                AND    CM_USER_AUTHORITY.USERID     = #{gUserId}    
                AND    CM_USER_AUTHORITY.DCCODE     = WD_EXDCINSTRUCT.DCCODE             
                AND    CM_USER_AUTHORITY.STORERKEY  = WD_EXDCINSTRUCT.STORERKEY          
                AND    CM_USER_AUTHORITY.ORGANIZE   = WD_EXDCINSTRUCT.ORGANIZE           
                AND    CM_USER_AUTHORITY.AREA       = WD_EXDCINSTRUCT.AREA    
            JOIN   MS_SKU
                ON     MS_SKU.STORERKEY             = WD_EXDCINSTRUCT.STORERKEY
                AND    MS_SKU.SKU                   = WD_EXDCINSTRUCT.SKU
            LEFT OUTER JOIN   MS_PLANTXSL
                ON     MS_PLANTXSL.PLANT||'-'||MS_PLANTXSL.STORAGELOC = WD_EXDCINSTRUCT.ORGANIZE        
            LEFT OUTER JOIN  (
                     SELECT MS_CUST.STORERKEY, MS_CUST.CUSTKEY, MAX(MS_CUST.DESCRIPTION) AS DESCRIPTION 
                     FROM   MS_CUST 
                     GROUP  BY MS_CUST.STORERKEY, MS_CUST.CUSTKEY ) MS_CUST   
                ON     MS_CUST.STORERKEY            = #{gStorerkey}   
                AND    MS_CUST.CUSTKEY              = WD_EXDCINSTRUCT.CUSTKEY       
            LEFT OUTER JOIN   FRAMEONE_USER
                ON     FRAMEONE_USER.USER_ID        = #{gUserId}
            LEFT OUTER JOIN   FRAMEONE_EMP
                ON     FRAMEONE_USER.EMP_NO         = FRAMEONE_EMP.EMP_NO
            LEFT OUTER JOIN WD_EXDC_DOCUMENT 
                ON   WD_EXDC_DOCUMENT.DCCODE        = WD_EXDCINSTRUCT.DCCODE
                AND  WD_EXDC_DOCUMENT.STORERKEY     = WD_EXDCINSTRUCT.STORERKEY              
                AND  WD_EXDC_DOCUMENT.DOCNO         = WD_EXDCINSTRUCT.INSTRUCTNO                  
                AND  WD_EXDC_DOCUMENT.DOCLINE       = WD_EXDCINSTRUCT.INSTRUCTLINE  
            LEFT OUTER JOIN DM_DOCUMENT_H 
               ON   DM_DOCUMENT_H.DCCODE            = WD_EXDCINSTRUCT.DCCODE
               AND  DM_DOCUMENT_H.STORERKEY         = WD_EXDCINSTRUCT.STORERKEY   
               AND  DM_DOCUMENT_H.DELIVERYDATE      = WD_EXDCINSTRUCT.SLIPDT
               AND  DM_DOCUMENT_H.DOCNO             = WD_EXDCINSTRUCT.DOCNO 
               AND  DM_DOCUMENT_H.DOCTYPE           = 'WD'
               AND  DM_DOCUMENT_H.REAL_YN           = 'R' 
            LEFT OUTER JOIN OM_EXDC_DELIVERY_INFO
               ON  OM_EXDC_DELIVERY_INFO.DOCNO     = DECODE(WD_EXDCINSTRUCT.SLIPNO,NULL,WD_EXDCINSTRUCT.INSTRUCTNO, WD_EXDCINSTRUCT.SLIPNO)
              AND  OM_EXDC_DELIVERY_INFO.DOCLINE   = DECODE(WD_EXDCINSTRUCT.SLIPLINE,NULL,WD_EXDCINSTRUCT.INSTRUCTLINE, WD_EXDCINSTRUCT.SLIPLINE)  
            
            WHERE  1=1 
                AND   SY_PROCESSTEMP_WD.PROCESSTYPE     = #{processtype}
                AND   SY_PROCESSTEMP_WD.PROCESSCREATOR  = #{gUserId}
                AND   SY_PROCESSTEMP_WD.SPID            = #{gSpid}
            
            GROUP BY 
                  WD_EXDCINSTRUCT.DCCODE                  
                 ,WD_EXDCINSTRUCT.STORERKEY               
                 ,WD_EXDCINSTRUCT.ORGANIZE                
                 ,WD_EXDCINSTRUCT.DOCDT     
                 ,WD_EXDCINSTRUCT.DOCTYPE              
                 ,WD_EXDCINSTRUCT.DOCNO                   
                 ,WD_EXDCINSTRUCT.DOCLINE                                
                 ,WD_EXDCINSTRUCT.SLIPDT                  
                 ,WD_EXDCINSTRUCT.SLIPNO                  
                 ,WD_EXDCINSTRUCT.SLIPLINE                
                 ,WD_EXDCINSTRUCT.INSTRUCTDT                  
                 ,WD_EXDCINSTRUCT.INSTRUCTNO                  
                 ,WD_EXDCINSTRUCT.INSTRUCTLINE                
                 ,WD_EXDCINSTRUCT.CUSTKEY                 
                 ,WD_EXDCINSTRUCT.ORDERQTY 
                 ,WD_EXDCINSTRUCT.BOXQTY 
                 ,WD_EXDCINSTRUCT.UOM       
                 ,WD_EXDCINSTRUCT.SKU                     
                 ,WD_EXDCINSTRUCT.DEL_YN
                 ,MS_PLANTXSL.DESCRIPTION            
                     
        UNION ALL
             
        SELECT
                 '0'                                                                                             AS CHECKYN
                ,#{gSpid}                                                                                        AS SPID
                ,MAX(FRAMEONE_USER.USER_ID)                                                                      AS USER_ID
                ,MAX(FRAMEONE_USER.USER_NM)                                                                      AS USER_NM
                ,WD_AUTO_EXDCINSTRUCT.DCCODE                                                                     AS DCCODE
                ,WD_AUTO_EXDCINSTRUCT.STORERKEY                                                                  AS STORERKEY
                ,WD_AUTO_EXDCINSTRUCT.ORGANIZE                                                                   AS ORGANIZE
                ,MAX(DECODE(MS_PLANTXSL.DESCRIPTION,NULL,'창고미등록',MS_PLANTXSL.DESCRIPTION))                     AS ORGANIZENAME
                ,MAX(DAMO.DEC(FRAMEONE_EMP.COTEL_NO))                                                            AS PHONE1
                ,MAX(MS_PLANTXSL.PHONE1)                                                                         AS PHONE2
                ,MAX('WD')                                                                                       AS DOCTYPE
                ,''                                                                                              AS CHANNEL
                ,MAX(DM_DOCUMENT_H.DOCNO)                                                                        AS NORMAL_NO
                ,WD_AUTO_EXDCINSTRUCT.SLIPDT                                                                     AS DOCDT
                ,WD_AUTO_EXDCINSTRUCT.DOCNO                                                                      AS DOCNO
                ,WD_AUTO_EXDCINSTRUCT.DOCLINE                                                                    AS DOCLINE
                ,''                                                                                              AS SLIPTYPE
                ,FN_FORMAT_MASK(WD_AUTO_EXDCINSTRUCT.SLIPDT, '####-##-##')                                       AS SLIPDT
                ,WD_AUTO_EXDCINSTRUCT.DOCNO                                                                      AS SLIPNO
                ,WD_AUTO_EXDCINSTRUCT.DOCLINE                                                                    AS SLIPLINE
                ,WD_AUTO_EXDCINSTRUCT.SKU                                                                        AS SKU
                ,MAX(MS_SKU.DESCRIPTION)
                  ||MAX(DECODE(WD_AUTO_EXDCINSTRUCT.SALESUOM,'KG','',' 박스입수:'||MS_SKU.QTYPERBOX))                 
                  ||MAX(DECODE(FN_DESCR_CODE(MS_SKU.STORERKEY,'COUNTRY',MS_SKU.COUNTRYOFORIGIN) ,'NOT FOUND','','/'||FN_DESCR_CODE(MS_SKU.STORERKEY,'COUNTRY',MS_SKU.COUNTRYOFORIGIN) ))
                                                                                                                 AS SKUNAME
                ,WD_AUTO_EXDCINSTRUCT.CUSTKEY                                                                    AS CUSTKEY
                ,MAX(MS_CUST.DESCRIPTION)                                                                        AS CUSTNAME
                ,MAX(WD_AUTO_EXDCINSTRUCT.TO_CUSTKEY)                                                            AS TO_CUSTKEY
                ,MAX(MS_TOCUST.DESCRIPTION)                                                                      AS TO_CUSTNAME
                ,MAX(WD_AUTO_EXDCINSTRUCT.ORDERQTY)                                                              AS ORDERQTY                                                          
                ,MAX(WD_AUTO_EXDCINSTRUCT.BASEUOM)                                                               AS STORERUOM
                ,ROUND(DECODE(WD_AUTO_EXDCINSTRUCT.SALESUOM,'KG',MAX(WD_AUTO_EXDCINSTRUCT.BOXQTY),FN_CONV_UOM(WD_AUTO_EXDCINSTRUCT.STORERKEY,WD_AUTO_EXDCINSTRUCT.SKU,WD_AUTO_EXDCINSTRUCT.SALESUOM,'BOX',WD_AUTO_EXDCINSTRUCT.ORDERQTY)),3) 
                                                                                                                 AS BOXQTY
                ,CASE WHEN MAX(MS_SKU.OTHER04) = 'Y' THEN MAX(MS_SKU.LINE03) ELSE MAX(WD_AUTO_EXDCINSTRUCT.BASEUOM)   END  AS BOXUOM
                ,NVL(WD_AUTO_EXDCINSTRUCT.BOXQTY,0)                                                              AS REALORDERBOX         
                ,''                                                                                              AS NEARDURATIONYN
                ,''                                                                                              AS LOTTABLE01
                ,0                                                                                               AS USEBYDATE_FREE_RT
                ,''                                                                                              AS DURATION_TERM
                ,MAX(WD_AUTO_EXDCINSTRUCT.SERIALNO)                                                              AS SERIALNO  
                ,''                                                                                              AS FACTORYNAME
                ,''                                                                                              AS PLACEOFORIGIN
                ,MAX(WD_AUTO_EXDCINSTRUCT.CONVERSERIALNO)||CHR(10)||'/'||MAX(WD_AUTO_EXDCINSTRUCT.SERIALNO)      AS CONVSERIALNO
                ,''                                                                                              AS BUTCHERYDT
                ,''                                                                                              AS CONTRACTCOMPANY
                ,''                                                                                              AS CONTRACTCOMPANYNAME
                ,''                                                                                              AS FROMVALIDDT
                ,''                                                                                              AS TOVALIDDT
                ,''                                                                                              AS CONTRACTTYPE
                ,MAX(WD_AUTO_EXDCINSTRUCT.SERIALNO)                                                              AS BARCODE
                ,0                                                                                               AS GROSSWEIGHT
                --,MAX('')                                                                                         AS MEMO1
                ,FN_DESCR_CODE(WD_AUTO_EXDCINSTRUCT.STORERKEY, 'DELIVERYTYPE_FS', MAX(''))                       AS MEMO2
                --,MAX(WD_EXDC_DOCUMENT.MEMO1)                                                                     AS MEMO3
                ,CASE WHEN MAX(WD_EXDC_DOCUMENT.MEMO1) IS NULL 
                      THEN NULL
                      WHEN MAX(WD_EXDC_DOCUMENT.MEMO1) IS NOT NULL
                      THEN MAX(WD_EXDC_DOCUMENT.MEMO1)
                   END                                                                                           AS MEMO1
                ,MAX(DAMO.DEC(FRAMEONE_EMP.COTEL_NO))                                                            AS USER_COTEL_NO
                ,MAX(DAMO.DEC(FRAMEONE_EMP.HANDPHONE_NO))                                                        AS USER_HANDPHONE_NO
                ,ROW_NUMBER() OVER(PARTITION BY MS_PLANTXSL.DESCRIPTION, WD_AUTO_EXDCINSTRUCT.SLIPDT, WD_AUTO_EXDCINSTRUCT.CUSTKEY  ORDER BY MS_PLANTXSL.DESCRIPTION, WD_AUTO_EXDCINSTRUCT.SLIPDT) 
                                                                                                                 AS ROWCNT
                ,''                                                                                              AS CONTAINERNO      
               ,MAX(MS_PLANTXSL.FAX        )                                                                     AS RECVFAXNO
               ,MAX(MS_PLANTXSL.DESCRIPTION)                                                                     AS RECVNAME
               ,MAX(MS_PLANTXSL.EMAIL)                                                                           AS RECVEMAIL  
               ,WD_AUTO_EXDCINSTRUCT.ORGANIZE||'_'||NVL(WD_AUTO_EXDCINSTRUCT.SLIPDT,WD_AUTO_EXDCINSTRUCT.SLIPDT)||'_'||WD_AUTO_EXDCINSTRUCT.CUSTKEY AS PRINTKEY
               ,CASE WHEN SUBSTR(WD_AUTO_EXDCINSTRUCT.ORGANIZE,6,4) BETWEEN '1000' AND '4000' THEN 'TYPE_A' ELSE 'TYPE_B' END AS PRINTTYPE
               ,MAX((SELECT BASEDESCR FROM CM_CODE WHERE STORERKEY = 'FW00' AND CODELIST = 'STORAGETYPE' AND BASECODE = MS_SKU.STORAGETYPE)) AS STORAGETYPE
               ,MAX(MS_PLANTXSL.FAX2)                                                                            AS RECVFAXNO2
               ,MAX(MS_PLANTXSL.EMAIL2)                                                                          AS RECVEMAIL2
               ,MAX(WD_AUTO_EXDCINSTRUCT.MAPKEY_NO)                                                              AS MAPKEY_NO
               ,MAX(WD_AUTO_EXDCINSTRUCT.DEL_YN)                                                                 AS ALL_CANCEL_STATUS
               ,MAX(OM_EXDC_DELIVERY_INFO.DELIVERY_ADDR)                                                         AS DELIVERY_ADDR
        FROM  SY_PROCESSTEMP_WD
        JOIN  WD_AUTO_EXDCINSTRUCT
            ON  SY_PROCESSTEMP_WD.ORGANIZE       = WD_AUTO_EXDCINSTRUCT.ORGANIZE
            AND  SY_PROCESSTEMP_WD.SLIPDT        = WD_AUTO_EXDCINSTRUCT.SLIPDT
            AND  SY_PROCESSTEMP_WD.SLIPNO        = WD_AUTO_EXDCINSTRUCT.DOCNO
            AND  SY_PROCESSTEMP_WD.SLIPLINE      = WD_AUTO_EXDCINSTRUCT.DOCLINE
            AND  WD_AUTO_EXDCINSTRUCT.ORDERQTY<![CDATA[>]]> 0
        LEFT  outer    JOIN   MS_SKU
            ON   MS_SKU.STORERKEY                = WD_AUTO_EXDCINSTRUCT.STORERKEY
            AND  MS_SKU.SKU                      = WD_AUTO_EXDCINSTRUCT.SKU
        LEFT OUTER JOIN   MS_PLANTXSL
            ON   MS_PLANTXSL.PLANT||'-'||MS_PLANTXSL.STORAGELOC = WD_AUTO_EXDCINSTRUCT.ORGANIZE      
        LEFT OUTER JOIN (
                 SELECT MS_CUST.STORERKEY, MS_CUST.CUSTKEY, MAX(MS_CUST.DESCRIPTION) AS DESCRIPTION 
                 FROM   MS_CUST 
                 GROUP  BY MS_CUST.STORERKEY, MS_CUST.CUSTKEY ) MS_CUST   
            ON   MS_CUST.STORERKEY              = #{gStorerkey}   
            AND  MS_CUST.CUSTKEY                = WD_AUTO_EXDCINSTRUCT.CUSTKEY   
        LEFT OUTER JOIN MS_CUST MS_TOCUST
            ON   MS_TOCUST.STORERKEY            = #{gStorerkey}
            AND  MS_TOCUST.CUSTKEY              = WD_AUTO_EXDCINSTRUCT.TO_CUSTKEY
            AND  MS_TOCUST.CUSTTYPE             = 'P'
        LEFT OUTER JOIN   FRAMEONE_USER
            ON   FRAMEONE_USER.USER_ID          = #{gUserId}
        LEFT OUTER JOIN   FRAMEONE_EMP
            ON   FRAMEONE_USER.EMP_NO           = FRAMEONE_EMP.EMP_NO
        LEFT OUTER JOIN WD_EXDC_DOCUMENT 
            ON   WD_EXDC_DOCUMENT.DCCODE        = WD_AUTO_EXDCINSTRUCT.DCCODE
            AND  WD_EXDC_DOCUMENT.STORERKEY     = WD_AUTO_EXDCINSTRUCT.STORERKEY              
            AND  WD_EXDC_DOCUMENT.DOCNO         = WD_AUTO_EXDCINSTRUCT.DOCNO                  
            AND  WD_EXDC_DOCUMENT.DOCLINE       = WD_AUTO_EXDCINSTRUCT.DOCLINE  
        LEFT OUTER JOIN DM_DOCUMENT_H 
            ON   DM_DOCUMENT_H.DCCODE           = WD_AUTO_EXDCINSTRUCT.DCCODE
            AND  DM_DOCUMENT_H.STORERKEY        = WD_AUTO_EXDCINSTRUCT.STORERKEY   
            AND  DM_DOCUMENT_H.DELIVERYDATE     = WD_AUTO_EXDCINSTRUCT.SLIPDT   
            AND  DM_DOCUMENT_H.DOCNO            = WD_AUTO_EXDCINSTRUCT.DOCNO 
            AND  DM_DOCUMENT_H.DOCTYPE          = 'WD'
            AND  DM_DOCUMENT_H.REAL_YN          = 'R'  
        LEFT OUTER JOIN OM_EXDC_DELIVERY_INFO
            ON   OM_EXDC_DELIVERY_INFO.DOCNO    = WD_AUTO_EXDCINSTRUCT.DOCNO
            AND  OM_EXDC_DELIVERY_INFO.DOCLINE  = WD_AUTO_EXDCINSTRUCT.DOCLINE 
       
        WHERE  1=1 
            AND  SY_PROCESSTEMP_WD.PROCESSTYPE     = #{processtype}
            AND  SY_PROCESSTEMP_WD.PROCESSCREATOR  = #{gUserId}
            AND  SY_PROCESSTEMP_WD.SPID            = #{gSpid}   
        GROUP BY 
                WD_AUTO_EXDCINSTRUCT.DCCODE                  
               ,WD_AUTO_EXDCINSTRUCT.STORERKEY               
               ,WD_AUTO_EXDCINSTRUCT.ORGANIZE       
               ,WD_AUTO_EXDCINSTRUCT.DOCNO                   
               ,WD_AUTO_EXDCINSTRUCT.DOCLINE                                
               ,WD_AUTO_EXDCINSTRUCT.SLIPDT                  
               ,WD_AUTO_EXDCINSTRUCT.CUSTKEY                 
               ,WD_AUTO_EXDCINSTRUCT.ORDERQTY 
               ,WD_AUTO_EXDCINSTRUCT.BOXQTY 
               ,WD_AUTO_EXDCINSTRUCT.SALESUOM       
               ,WD_AUTO_EXDCINSTRUCT.SKU            
               ,MS_PLANTXSL.DESCRIPTION                     
        )  A
        ORDER BY       ROWCNT 
    </select> 

    <select id="getDataPrintListReturn" resultType="WdSendOutOrderPrintResDto">  
        SELECT    /* [wdSendOutOrderService.sqlx][getDataPrintListReturn][출고지시서 정보(협력사반품)][sunho.kim][2025.06.19] */
               '0'                                                                                          AS CHECKYN
              ,#{gSpid}                                                                                     AS SPID
              ,MAX(FRAMEONE_USER.USER_ID)                                                                   AS USER_ID
              ,MAX(FRAMEONE_USER.USER_NM)                                                                   AS USER_NM
              ,WD_INPLAN.DCCODE                                                                             AS DCCODE
              ,WD_INPLAN.STORERKEY                                                                          AS STORERKEY
              ,WD_INPLAN.ORGANIZE                                                                           AS ORGANIZE
              ,DECODE(MS_PLANTXSL.DESCRIPTION, NULL,'창고미등록', MS_PLANTXSL.DESCRIPTION)                     AS ORGANIZENAME
              ,MAX(DAMO.DEC(FRAMEONE_EMP.COTEL_NO))                                                         AS PHONE1
              ,MAX(MS_PLANTXSL.PHONE1)                                                                      AS PHONE2
              ,'WD'                                                                                         AS DOCTYPE
              ,DM_DOCUMENT_D.CHANNEL                                                                        AS CHANNEL
              ,MAX(DM_DOCUMENT_H2.DOCNO)                                                                    AS NORMAL_NO
              ,WD_INPLAN.DOCDT                                                                              AS DOCDT
              ,WD_INPLAN.DOCNO                                                                              AS DOCNO
              ,WD_INPLAN.DOCLINE                                                                            AS DOCLINE
              ,WD_INPLAN.SLIPTYPE                                                                           AS SLIPTYPE
              ,FN_FORMAT_MASK(WD_INPLAN.SLIPDT, '####-##-##')                                               AS SLIPDT
              ,WD_INPLAN.SLIPNO                                                                             AS SLIPNO
              ,WD_INPLAN.SLIPLINE                                                                           AS SLIPLINE
              ,WD_INPLAN.SKU                                                                                AS SKU
              ,MAX(MS_SKU.DESCRIPTION)
                ||MAX(DECODE(DM_DOCUMENT_D.UOM, 'KG','', ' 박스입수:'||MS_SKU.QTYPERBOX))               
                ||MAX(DECODE(FN_DESCR_CODE(MS_SKU.STORERKEY,'COUNTRY',MS_SKU.COUNTRYOFORIGIN) ,'NOT FOUND','','/'||FN_DESCR_CODE(MS_SKU.STORERKEY,'COUNTRY',MS_SKU.COUNTRYOFORIGIN) ))
                                                                                                            AS SKUNAME
              ,WD_INPLAN.CUSTKEY                                                                            AS CUSTKEY
              ,MAX(MS_CUST.DESCRIPTION)                                                                     AS CUSTNAME
              ,DM_DOCUMENT_D.STOREROPENQTY                                                                  AS ORDERQTY                                                          
              ,DM_DOCUMENT_D.STORERUOM                                                                      AS STORERUOM
              ,ROUND(DECODE(DM_DOCUMENT_D.STORERUOM,'KG',MAX(DM_DOCUMENT_D.QCQTY),FN_CONV_UOM(WD_INPLAN.STORERKEY,WD_INPLAN.SKU,DM_DOCUMENT_D.STORERUOM,'BOX',DM_DOCUMENT_D.STOREROPENQTY)),3) AS BOXQTY
              ,'BOX'                                                                                        AS BOXUOM
              ,MAX(NVL(WD_INVOICE_SN.ETCQTY1,0))                                                            AS REALORDERBOX
              ,FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE), MAX(MS_SKU.DURATION)
                                              , MAX(ST_SNINFO.LOTTABLE01), 'Y')                             AS NEARDURATIONYN
              ,MAX(ST_SNINFO.LOTTABLE01)                                                                    AS LOTTABLE01
              ,CASE WHEN FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE), MAX(MS_SKU.DURATION), MAX(ST_SNINFO.LOTTABLE01), 'N') > 0 
                    THEN ROUND(FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE), MAX(MS_SKU.DURATION), MAX(ST_SNINFO.LOTTABLE01), 'N') / MAX(MS_SKU.DURATION) * 100) 
                    ELSE 0 
               END                                                                                          AS USEBYDATE_FREE_RT 
              ,FN_LOTDURATION(MAX(MS_SKU.STORERKEY), MAX(MS_SKU.DURATIONTYPE), MAX(MS_SKU.DURATION)                    
                                             , MAX(ST_SNINFO.LOTTABLE01), 'N') ||'/'|| MAX(MS_SKU.DURATION) AS DURATION_TERM
              ,MAX(ST_SNINFO.SERIALNO)                                                                      AS SERIALNO  
              ,MAX(ST_SNINFO.FACTORYNAME)                                                                   AS FACTORYNAME
              ,MAX(ST_SNINFO.PLACEOFORIGIN)                                                                 AS PLACEOFORIGIN
              ,CASE WHEN MAX(ST_SNINFO.CONTAINERNO) IS NOT NULL 
                    THEN MAX(ST_SNINFO.CONVSERIALNO) || CHR(10) || '/' || MAX(ST_SNINFO.SERIALNO) ||CHR(10) || '/' || MAX(ST_SNINFO.CONTAINERNO) 
                    ELSE MAX(ST_SNINFO.CONVSERIALNO) || CHR(10) || '/' || MAX(ST_SNINFO.SERIALNO)
                    END                                                                                     AS CONVSERIALNO
              ,MAX(ST_SNINFO.BUTCHERYDT)                                                                    AS BUTCHERYDT
              ,MAX(ST_SNINFO.CONTRACTCUSTKEY)                                                               AS CONTRACTCOMPANY
              ,MAX((SELECT DESCRIPTION FROM MS_CUST                                                         
                WHERE  MS_CUST.STORERKEY = ST_SNINFO.STORERKEY                                      
                AND    MS_CUST.CUSTKEY   = ST_SNINFO.CONTRACTCUSTKEY                                
                AND    ROWNUM = 1 ))                                                                        AS CONTRACTCOMPANYNAME
              ,MAX(ST_SNINFO.FROMVALIDDT)                                                                   AS FROMVALIDDT
              ,MAX(ST_SNINFO.TOVALIDDT)                                                                     AS TOVALIDDT
              ,MAX(CD1.BASEDESCR)                                                                           AS CONTRACTTYPE
              ,MAX(ST_SNINFO.STOCKID)                                                                       AS BARCODE
              ,MAX(WD_INVOICE_SN.WEIGHT)                                                                    AS GROSSWEIGHT
              --,MAX(DM_DOCUMENT_D.MEMO1)                                                                     AS MEMO1
              ,'매입 반품'                                                                                     AS MEMO2  <!-- 협력사 반품 출고방법은 매입 반품 문구 강제 삽입 김영문님 20180131 -->
              --,MAX(WD_EXDC_DOCUMENT.MEMO1)                                                                  AS MEMO3 
              ,CASE WHEN MAX(DM_DOCUMENT_D.MEMO1) IS NULL AND MAX(WD_EXDC_DOCUMENT.MEMO1) IS NULL 
                        THEN NULL
                        WHEN MAX(DM_DOCUMENT_D.MEMO1) IS NOT NULL AND MAX(WD_EXDC_DOCUMENT.MEMO1) IS NULL
                        THEN MAX(DM_DOCUMENT_D.MEMO1)
                        WHEN MAX(DM_DOCUMENT_D.MEMO1) IS NULL AND MAX(WD_EXDC_DOCUMENT.MEMO1) IS NOT NULL
                        THEN MAX(WD_EXDC_DOCUMENT.MEMO1)
                        ELSE MAX(DM_DOCUMENT_D.MEMO1) || ', ' || MAX(WD_EXDC_DOCUMENT.MEMO1)
                END                                                                                         AS MEMO1
              ,MAX(DAMO.DEC(FRAMEONE_EMP.COTEL_NO))                                                         AS USER_COTEL_NO
              ,MAX(DAMO.DEC(FRAMEONE_EMP.HANDPHONE_NO))                                                     AS USER_HANDPHONE_NO
              ,ROW_NUMBER() OVER(PARTITION BY MS_PLANTXSL.DESCRIPTION, WD_INPLAN.SLIPDT, WD_INPLAN.CUSTKEY  ORDER BY MS_PLANTXSL.DESCRIPTION, WD_INPLAN.SLIPDT, WD_INPLAN.CUSTKEY) 
                                                                                                            AS ROWCNT              
              ,MAX(MS_PLANTXSL.FAX)                                                                         AS RECVFAXNO
              ,MAX(MS_PLANTXSL.DESCRIPTION)                                                                 AS RECVNAME
              ,MAX(MS_PLANTXSL.EMAIL)                                                                       AS RECVEMAIL
              ,WD_INPLAN.ORGANIZE||'_'||WD_INPLAN.SLIPDT||'_'||WD_INPLAN.CUSTKEY                            AS PRINTKEY
              ,CASE WHEN sUBSTR(WD_INPLAN.ORGANIZE,6,4) BETWEEN '1000' AND '4000' THEN 'TYPE_A' ELSE 'TYPE_B' END AS PRINTTYPE
              ,''                                                                                           AS MAPKEY_NO
              ,MAX(OM_EXDC_DELIVERY_INFO.DELIVERY_ADDR)                                                     AS DELIVERY_ADDR
        FROM  SY_PROCESSTEMP_WD
        JOIN  WD_INPLAN
            ON    SY_PROCESSTEMP_WD.ORGANIZE        = WD_INPLAN.ORGANIZE
            AND   SY_PROCESSTEMP_WD.SLIPDT          = WD_INPLAN.SLIPDT
            AND   SY_PROCESSTEMP_WD.SLIPNO          = WD_INPLAN.SLIPNO
            AND   SY_PROCESSTEMP_WD.SLIPLINE        = WD_INPLAN.SLIPLINE
            AND   WD_INPLAN.ORDERQTY           <![CDATA[>]]> 0           
        JOIN   CM_USER_AUTHORITY           
            ON     1=1     
        <if test="dccode != null and dccode != ''">           
            AND    CM_USER_AUTHORITY.DCCODE     =  #{dccode}          
        </if>
        <if test="gStorerkey != null and gStorerkey != ''">    
            AND    CM_USER_AUTHORITY.STORERKEY  =  #{gStorerkey}       
        </if>
        <if test="area != null and area != ''">              
            AND    CM_USER_AUTHORITY.AREA       =  #{area}                
        </if> 
        <if test="organizeMulti != null and organizeMulti != ''">
            AND    CM_USER_AUTHORITY.ORGANIZE      IN
            <foreach collection="organizeMulti" item="item" open="(" separator="," close=")">
                 #{item}
            </foreach> 
        </if>
            AND CM_USER_AUTHORITY.USERID     = #{gUserId}    
            AND CM_USER_AUTHORITY.DCCODE     = WD_INPLAN.DCCODE             
            AND CM_USER_AUTHORITY.STORERKEY  = WD_INPLAN.STORERKEY          
            AND CM_USER_AUTHORITY.ORGANIZE   = WD_INPLAN.ORGANIZE           
            AND CM_USER_AUTHORITY.AREA       = WD_INPLAN.AREA    
        JOIN   DM_DOCUMENT_D
            ON  DM_DOCUMENT_D.DCCODE         = WD_INPLAN.DCCODE            
            AND DM_DOCUMENT_D.STORERKEY      = WD_INPLAN.STORERKEY  
            AND DM_DOCUMENT_D.ORGANIZE       = WD_INPLAN.ORGANIZE
            AND DM_DOCUMENT_D.DOCTYPE        = WD_INPLAN.DOCTYPE   
            AND DM_DOCUMENT_D.DELIVERYDATE   = WD_INPLAN.SLIPDT            
            AND DM_DOCUMENT_D.DOCNO          = WD_INPLAN.DOCNO            
            AND DM_DOCUMENT_D.DOCLINE        = WD_INPLAN.DOCLINE            
            AND DM_DOCUMENT_D.DEL_YN         = 'N'
        JOIN   DM_DOCUMENT_H
            ON  DM_DOCUMENT_H.DCCODE         = DM_DOCUMENT_D.DCCODE
            AND DM_DOCUMENT_H.STORERKEY      = DM_DOCUMENT_D.STORERKEY
            AND DM_DOCUMENT_H.ORGANIZE       = DM_DOCUMENT_D.ORGANIZE
            AND DM_DOCUMENT_H.DOCTYPE        = DM_DOCUMENT_D.DOCTYPE
            AND DM_DOCUMENT_H.DELIVERYDATE   = DM_DOCUMENT_D.DELIVERYDATE            
            AND DM_DOCUMENT_H.DOCNO          = DM_DOCUMENT_D.DOCNO  
        LEFT OUTER JOIN WD_INVOICE_SN
            ON  WD_INVOICE_SN.DCCODE          = DM_DOCUMENT_D.DCCODE              
            AND WD_INVOICE_SN.STORERKEY       = DM_DOCUMENT_D.STORERKEY        
            AND WD_INVOICE_SN.DOCTYPE         = DM_DOCUMENT_D.DOCTYPE
            AND WD_INVOICE_SN.WD_DOCNO        = DM_DOCUMENT_D.DOCNO                              
            AND WD_INVOICE_SN.WD_DOCDT        = DM_DOCUMENT_D.DOCDT                  
            AND WD_INVOICE_SN.WD_DOCLINE      = DM_DOCUMENT_D.DOCLINE                   
            AND WD_INVOICE_SN.SKU             = DM_DOCUMENT_D.SKU
            AND WD_INVOICE_SN.DEL_YN          = 'N'  
        JOIN   MS_SKU
            ON  MS_SKU.STORERKEY              = WD_INPLAN.STORERKEY
            AND MS_SKU.SKU                    = WD_INPLAN.SKU
            AND MS_SKU.DEL_YN                 = 'N'
        LEFT OUTER JOIN WD_INVOICE_SN              
            ON  WD_INVOICE_SN.DCCODE          = WD_INPLAN.DCCODE                                 
            AND WD_INVOICE_SN.STORERKEY       = WD_INPLAN.STORERKEY                      
            AND WD_INVOICE_SN.DOCTYPE         = WD_INPLAN.DOCTYPE              
            AND WD_INVOICE_SN.WD_SLIPNO       = WD_INPLAN.SLIPNO                                            
            AND WD_INVOICE_SN.WD_SLIPDT       = WD_INPLAN.SLIPDT                                 
            AND WD_INVOICE_SN.WD_SLIPLINE     = WD_INPLAN.SLIPLINE                                 
            AND WD_INVOICE_SN.SKU             = WD_INPLAN.SKU                    
        LEFT OUTER JOIN   ST_SNINFO           
            ON  ST_SNINFO.STORERKEY           = WD_INVOICE_SN.STORERKEY
            AND ST_SNINFO.SKU                 = WD_INVOICE_SN.SKU
            AND ST_SNINFO.STOCKID             = WD_INVOICE_SN.STOCKID
        LEFT OUTER JOIN   MS_PLANTXSL
            ON     MS_PLANTXSL.PLANT||'-'||MS_PLANTXSL.STORAGELOC         = WD_INPLAN.ORGANIZE          
        LEFT OUTER JOIN  (
                    SELECT MS_CUST.STORERKEY, MS_CUST.CUSTKEY, MAX(MS_CUST.DESCRIPTION) AS DESCRIPTION 
                    FROM   MS_CUST 
                    GROUP  BY MS_CUST.STORERKEY, MS_CUST.CUSTKEY ) MS_CUST   
            ON  MS_CUST.STORERKEY             = WD_INPLAN.STORERKEY   
            AND MS_CUST.CUSTKEY               = WD_INPLAN.CUSTKEY         
        LEFT OUTER JOIN OM_EXDC_DELIVERY_INFO
            ON  OM_EXDC_DELIVERY_INFO.DOCNO    = WD_INPLAN.DOCNO
            AND OM_EXDC_DELIVERY_INFO.DOCLINE  = WD_INPLAN.DOCLINE 
        LEFT OUTER JOIN   FRAMEONE_USER
            ON  FRAMEONE_USER.USER_ID         = #{gUserId}
        LEFT OUTER JOIN   FRAMEONE_EMP
            ON  FRAMEONE_USER.EMP_NO          = FRAMEONE_EMP.EMP_NO
        LEFT OUTER JOIN WD_EXDC_DOCUMENT 
            ON  WD_EXDC_DOCUMENT.DCCODE       = WD_INPLAN.DCCODE
            AND WD_EXDC_DOCUMENT.STORERKEY    = WD_INPLAN.STORERKEY              
            AND WD_EXDC_DOCUMENT.DOCNO        = WD_INPLAN.DOCNO                  
            AND WD_EXDC_DOCUMENT.DOCLINE      = WD_INPLAN.DOCLINE  
        LEFT OUTER JOIN DM_DOCUMENT_H DM_DOCUMENT_H2
            ON  DM_DOCUMENT_H2.DCCODE         = WD_INPLAN.DCCODE
            AND DM_DOCUMENT_H2.STORERKEY      = WD_INPLAN.STORERKEY   
            AND DM_DOCUMENT_H2.DOCNO          = WD_INPLAN.DOCNO 
            AND DM_DOCUMENT_H2.DOCTYPE        = 'WD'
            AND DM_DOCUMENT_H2.REAL_YN        = 'R'
        LEFT OUTER JOIN CM_CODE_STORER CD1
            ON  CD1.STORERKEY                 = WD_INPLAN.STORERKEY
            AND CD1.CODELIST                  = 'CONTRACTTYPE_SN'   
            AND CD1.BASECODE                  = ST_SNINFO.CONTRACTTYPE
        
        WHERE  1=1 
            AND  SY_PROCESSTEMP_WD.PROCESSTYPE     = #{processtype}
            AND  SY_PROCESSTEMP_WD.PROCESSCREATOR  = #{gUserId}
            AND  SY_PROCESSTEMP_WD.SPID            = #{gSpid} 
            
        GROUP BY 
              WD_INPLAN.DCCODE                  
             ,WD_INPLAN.STORERKEY               
             ,WD_INPLAN.ORGANIZE                
             ,DM_DOCUMENT_D.CHANNEL           
             ,WD_INPLAN.DOCDT                   
             ,WD_INPLAN.DOCNO                   
             ,WD_INPLAN.DOCLINE                 
             ,WD_INPLAN.SLIPTYPE                
             ,WD_INPLAN.SLIPDT                  
             ,WD_INPLAN.SLIPNO                  
             ,WD_INPLAN.SLIPLINE                
             ,WD_INPLAN.CUSTKEY                 
             ,DM_DOCUMENT_D.STOREROPENQTY 
             ,DM_DOCUMENT_D.STORERUOM       
             ,WD_INPLAN.SKU                     
             ,MS_PLANTXSL.DESCRIPTION                           
        ORDER BY  MS_PLANTXSL.DESCRIPTION, WD_INPLAN.SLIPDT 
    </select>

    <update id="mergeSendoutOrderMemo">
        MERGE INTO WD_EXDC_DOCUMENT /* [wdSendOutOrderService.sqlx][mergeSendoutOrderMemo][화면 메모란 MERGE][sunho.kim][2025.06.19] */
              USING DUAL ON ( DCCODE            = #{dccode}
                         AND STORERKEY          = #{gStorerkey}
                         AND DOCNO              = #{slipno}
                         AND DOCLINE            = #{slipline}
                         )
             WHEN MATCHED THEN
                UPDATE SET MEMO1                = #{memo2}
                          ,EDITDATE             = SYSDATE
                          ,EDITWHO              = #{gUserId}
             WHEN NOT MATCHED THEN
              INSERT(SERIALKEY 
                    ,STORERKEY
                    ,DCCODE
                    ,DOCNO 
                    ,DOCLINE        
                    ,MEMO1                                                           
                    ,ADDWHO 
                    ,EDITWHO
                    )
                VALUES
                    (SEQ_WD_EXDC_DOCUMENT.Nextval
                    ,#{gStorerkey}
                    ,#{dccode}
                    ,#{slipno}
                    ,#{slipline}
                    ,#{memo2}
                    ,#{gUserId}
                    ,#{gUserId}
                    )
    </update>    
    
    <insert id="insertPrintHistory">
        INSERT    /* [wdSendOutOrderService.sqlx][insertPrintHistory][출고지시서 출력이력 INSERT][sunho.kim][2025.06.19] */ 
        INTO WD_EXDC_PRTLOG (
             SERIALKEY
            ,STORERKEY
            ,DCCODE
            ,DOCNO
            ,DOCLINE
            ,PAPERTYPE
            ,CREATESOURCE
            ,PRINTDT
            ,PRINTUSER
            ,DOCNAME
        ) VALUES (
             SEQ_WD_EXDC_PRTLOG.nextval
            ,#{gStorerkey}
            ,#{dccode}
            ,#{slipno}
            ,#{slipline}
            ,#{printType}
            ,'WD_SendOutOrder'
            ,TO_CHAR(SYSDATE,'yyyymmddhh24miss')
            ,#{gUserId}
    <choose>
        <when test="docName != null and docName != ''">
            ,#{docName}
        </when>
        <otherwise>
            ,null
        </otherwise>
    </choose>
        )
    </insert>
    
    <select id="checkdeleteyn" resultType="String">
         SELECT    /* [wdSendOutOrderService.sqlx][checkdeleteyn][자소샘픔건확인][sunho.kim][2025.06.19] */ 
               '01'    AS CHECKYN       
         FROM AJ_INPLAN 
         INNER JOIN WD_EXDCINSTRUCT
             ON AJ_INPLAN.DOCNO    = WD_EXDCINSTRUCT.INSTRUCTNO
             AND AJ_INPLAN.DOCLINE = WD_EXDCINSTRUCT.INSTRUCTLINE
         WHERE 1=1
             AND  AJ_INPLAN.REASONCODE IN (SELECT BASECODE FROM CM_CODE WHERE CODELIST = 'EX_AJ_DELETE')
             AND  AJ_INPLAN.DOCNO   = #{docno}
             AND  AJ_INPLAN.DOCLINE = #{docline}
    </select>    

    <select id="getParameterForProcedure" resultType="WdSendOutOrderResDto">
        SELECT    /* [wdSendOutOrderService.sqlx][getParameterForProcedure][감모 삭제 파라미터][sunho.kim][2025.06.19] */ 
               AJ_INPLAN.DCCODE                                               AS DCCODE
              ,AJ_INPLAN.STORERKEY                                            AS STORERKEY
              ,AJ_INPLAN.ORGANIZE                                             AS ORGANIZE
              ,AJ_INPLAN.AREA                                                 AS AREA
              ,AJ_INPLAN.DOCDT                                                AS DOCDT
              ,AJ_INPLAN.DOCNO                                                AS DOCNO
              ,AJ_INPLAN.DOCLINE                                              AS DOCLINE
              ,AJ_INPLAN.SLIPDT                                               AS SLIPDT
              ,AJ_INPLAN.SLIPNO                                               AS SLIPNO
              ,AJ_INPLAN.SLIPLINE                                             AS SLIPLINE
              ,AJ_INPLAN.SLIPTYPE                                             AS SLIPTYPE  
              ,AJ_INPLAN.ORDERTYPE                                            AS ORDERTYPE
              ,AJ_INPLAN.SKU                                                  AS SKU
              ,AJ_INPLAN.UOM                                                  AS UOM
              ,AJ_INPLAN.ORDERQTY                                             AS TRANQTY
              ,AJ_INPLAN.STOCKID                                              AS STOCKID
              ,AJ_INPLAN.STOCKGRADE                                           AS STOCKGRADE
              ,AJ_INPLAN.LOC                                                  AS LOC
              ,AJ_INPLAN.LOT                                                  AS LOT
              ,AJ_INPLAN.IOTYPE                                               AS IOTYPE
        FROM   AJ_INPLAN   
        JOIN   ST_STOCK
            ON     ST_STOCK.DCCODE         = AJ_INPLAN.DCCODE
            AND    ST_STOCK.STORERKEY      = AJ_INPLAN.STORERKEY
            AND    ST_STOCK.ORGANIZE       = AJ_INPLAN.ORGANIZE
            AND    ST_STOCK.AREA           = AJ_INPLAN.AREA
            AND    ST_STOCK.SKU            = AJ_INPLAN.SKU
            AND    ST_STOCK.LOC            = AJ_INPLAN.LOC
            AND    ST_STOCK.LOT            = AJ_INPLAN.LOT
            AND    ST_STOCK.STOCKID        = AJ_INPLAN.STOCKID
            AND    ST_STOCK.STOCKGRADE     = AJ_INPLAN.STOCKGRADE
        JOIN   MS_SKU
            ON     MS_SKU.STORERKEY        = AJ_INPLAN.STORERKEY
            AND    MS_SKU.SKU              = AJ_INPLAN.SKU
            AND    MS_SKU.DEL_YN           = 'N'
        JOIN   CM_LOT
            ON     CM_LOT.STORERKEY        = AJ_INPLAN.STORERKEY
            AND    CM_LOT.LOT              = AJ_INPLAN.LOT
            AND    CM_LOT.DEL_YN           = 'N'     
        LEFT OUTER JOIN ST_SNINFO
            ON     AJ_INPLAN.STORERKEY     = ST_SNINFO.STORERKEY
            AND    AJ_INPLAN.SKU           = ST_SNINFO.SKU
            AND    AJ_INPLAN.STOCKID       = ST_SNINFO.STOCKID    
        LEFT OUTER JOIN MS_UOM
            ON     AJ_INPLAN.STORERKEY     = MS_UOM.STORERKEY
            AND    AJ_INPLAN.SKU           = MS_UOM.SKU
            AND    AJ_INPLAN.UOM           = MS_UOM.BASEUOM
            AND    MS_UOM.UOM              = 'KG'
        WHERE  1=1
        <!--   AND    AJ_INPLAN.STATUS      <![CDATA[<]]> '90'-->
            AND    AJ_INPLAN.ORDERTYPE   IN ('DDRAJ', 'DURAJ')
            AND    AJ_INPLAN.DOCNO       = #{docno} 
            AND    AJ_INPLAN.DOCLINE     = #{docline}
            AND    NOT EXISTS (SELECT 1 
                               FROM  AJ_APPRREQUEST 
                               WHERE AJ_APPRREQUEST.DCCODE             = AJ_INPLAN.DCCODE
                                   AND   AJ_APPRREQUEST.STORERKEY      = AJ_INPLAN.STORERKEY
                                   AND   AJ_APPRREQUEST.ORGANIZE       = AJ_INPLAN.ORGANIZE
                                   AND   AJ_APPRREQUEST.DOCDT          = AJ_INPLAN.DOCDT
                                   AND   AJ_APPRREQUEST.DOCNO          = AJ_INPLAN.DOCNO 
                                   AND   AJ_APPRREQUEST.SLIPDT         = AJ_INPLAN.SLIPDT
                                   AND   AJ_APPRREQUEST.SLIPNO         = AJ_INPLAN.SLIPNO
                                   AND   AJ_APPRREQUEST.APPROVALSTATUS <![CDATA[<>]]> '9') 
        
        ORDER BY AJ_INPLAN.DCCODE    
                ,AJ_INPLAN.STORERKEY
                ,AJ_INPLAN.SKU
    </select>
    
    <insert id="insertSyProcessTempWD" parameterType="java.util.List">
        INSERT    /* [wdSendOutOrderService.sqlx][insertSyProcessTempWD][임시저장 정보 ST 저장][sunho.kim][2025.07.09] */
            INTO SY_PROCESSTEMP_WD (
                PROCESSTYPE
              , PROCESSCREATOR
              , SPID
              , DCCODE
              , STORERKEY
              , ORGANIZE
              , DOCNO
              , DOCLINE
              , SLIPNO
              , SLIPLINE
              , SLIPDT
              , ORDERTYPE 
              , ADDDATE
              , EDITDATE 
              , ADDWHO
              , EDITWHO
        )
        <foreach collection="list" item="item" separator="UNION ALL">
            SELECT
                #{item.processtype}             AS PROCESSTYPE
              , #{item.gUserId}                 AS PROCESSCREATOR
              , #{item.gSpid}                   AS SPID             
              , #{item.dccode}                  AS DCCODE
              , #{item.storerkey}               AS STORERKEY              
              , #{item.organize}                AS ORGANIZE
              , #{item.docno}                   AS DOCNO
              , #{item.docline}                 AS DOCLINE
              , #{item.slipno}                  AS SLIPNO
              , #{item.slipline}                AS SLIPLINE
              , #{item.slipdt}                  AS SLIPDT
              , #{item.ordertype}               AS ORDERTYPE
              , SYSDATE                         AS ADDDATE
              , SYSDATE                         AS EDITDATE
              , #{item.gUserId}                 AS ADDWHO
              , #{item.gUserId}                 AS EDITWHO
            FROM DUAL
        </foreach>
    </insert>
    
</mapper>