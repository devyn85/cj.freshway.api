<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="ipAllowService">
	<select id="getIpAllowList" resultType="IpAllowGetResDto">
        SELECT /* [ipAllowService.sqlx][getIpAllowList] */
            USER_ID,
	        IP_ADDR,
            REASON,
	        REG_ID,
	        TO_CHAR(REG_DT, 'YYYY-MM-DD') AS REG_DT
        FROM TB_CF_ALLOWED_IP
        WHERE 1=1
        <if test='userId !=null and userId !=""'>
           AND USER_ID LIKE	'%' || #{userId} || '%'
         </if>
         <if test='ipAddr !=null and ipAddr !=""'>
           AND IP_ADDR	LIKE	'%' || #{ipAddr} || '%'
        </if>
        ORDER BY USER_ID
    </select>

    <insert id="insertIpAllow">
      INSERT /* [ipAllowService.sqlx][insertIpAllow][20200121][ssj] */
      INTO	TB_CF_ALLOWED_IP (
          USER_ID,
          IP_ADDR,
          REASON,
          REG_ID,
          REG_DT
      )
      VALUES (
          #{userId},
          #{ipAddr},
          #{reason},
          #{regId},
          SYSDATE
      )
    </insert>

    <update id="updateIpAllow">
        UPDATE /* [ipAllowService.sqlx][updateIpAllow][20200121][ssj] */
            TB_CF_ALLOWED_IP
        SET		REASON	= #{reason}
        WHERE	USER_ID	= #{userId}
        AND     IP_ADDR = #{ipAddr}
    </update>

    <delete id="deleteIpAllow">
        DELETE /* [ipAllowService.sqlx][deleteIpAllow][20180306][CJ Developer.] */
        FROM	TB_CF_ALLOWED_IP
        WHERE	USER_ID	= #{userId}
        AND     IP_ADDR = #{ipAddr}
    </delete>


</mapper>