<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cmSearch80Service">
	<!-- 귀속 부서 목록 조회 -->
<select id="getCostCenterList" resultType="CmCostCenterPopupResDto">
    SELECT
        MS_COST.COSTCODE    AS CODE,
        MS_COST.DESCRIPTION AS NAME,
        MS_COST.FROMDATE    AS FROMDATE,
        MS_COST.DESCRIPTION AS TODATE
    FROM MS_COST
    WHERE 1=1
      AND MS_COST.STORERKEY = #{gStorerkey}
      AND TO_CHAR(SYSDATE, 'YYYYMMDD') BETWEEN MS_COST.FROMDATE AND MS_COST.TODATE

    <choose>
        <when test="isEnter == 'Y'.toString()">
            <!-- 엔터검색.input/돋보기 =검색(성능) -->
            AND (MS_COST.COSTCODE = #{name} OR MS_COST.DESCRIPTION = #{name})
        </when>
        <otherwise>
            <if test="name != null and name != ''">
                <choose>
                    <when test="fixedSearchYn == null or fixedSearchYn == ''">
                        <!-- FIX검색.%1개일 때(3/4) -->
                        AND (MS_COST.COSTCODE LIKE '%' || #{name} || '%' 
                             OR MS_COST.DESCRIPTION LIKE '%' || #{name} || '%')
                    </when>
                    <when test="fixedSearchYn == 'Y'.toString()">
                        <!-- FIX검색.%1개일 때(3/4) -->
                        AND (MS_COST.COSTCODE LIKE #{name} OR MS_COST.DESCRIPTION LIKE #{name})
                    </when>
                    <otherwise>
                        <!-- 2.단일검색,5.%다중검색 -->
                        AND (MS_COST.COSTCODE LIKE '%' || #{name} || '%' OR MS_COST.DESCRIPTION LIKE '%' || #{name} || '%')
                    </otherwise>
                </choose>

                <!-- START.검색요건 -->
                <if test="name.indexOf(' ') gt 0">
                    OR REGEXP_LIKE(UPPER(MS_COST.DESCRIPTION), REGEXP_REPLACE(UPPER(#{keywordRegexp}), '[ ]+', '|'))
                </if>
                <!-- END.검색요건 -->

            </if>
        </otherwise>
    </choose>

    <!-- START.검색요건 -->
    <choose>
        <when test="name != null and name.indexOf(' ') gt 0">
            ORDER BY
                REGEXP_COUNT(UPPER(MS_COST.DESCRIPTION), REGEXP_REPLACE(UPPER(#{keywordRegexp}), '[ ]+', '|')) DESC,
                UTL_MATCH.JARO_WINKLER_SIMILARITY(MS_COST.DESCRIPTION, #{name}) DESC
        </when>
        <otherwise>
            <!-- ASIS처럼 정렬 없음 -->
        </otherwise>
    </choose>
    <!-- END.검색요건 -->

</select>

</mapper>