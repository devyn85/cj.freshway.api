<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="tmLocationMonitorService">

    <select id="getVehicleMonitoringList" resultType="TmVehicleMonitoringResDto" parameterType="TmVehicleMonitoringReqDto">
            SELECT /* [TmLocationMonitorService.sqlx][getVehicleMonitoringList][센터별 차량 모니터링 조회][이현성][2026.03.10] */
                  CAR_LIST.DCCODE
                , FN_DESCR_DC(CAR_LIST.DCCODE) AS DCNAME
                , COUNT(DISTINCT CAR_LIST.CARNO) AS CNT
            FROM (
	            SELECT
	                  DCCODE
	                , DELIVERYDT
	                , CARNO
	                , CASE WHEN DECODE(MAX(DCDEPARTUREDT), NULL, 'N', 'Y') = 'N' THEN '10'
	                       WHEN COUNT(DISTINCT CASE WHEN CUSTDEPARTUREDT IS NOT NULL THEN TRUTHCUSTKEY ELSE NULL END)
	                          = COUNT(DISTINCT TRUTHCUSTKEY) THEN '30'
	                       ELSE '20'
	                       END AS WORKLOGTYPE
	            FROM VW_TM_INPLAN_ALL
	            WHERE DCCODE = #{dccode}
	              AND DELIVERYDT = #{deliverydt}
                  AND SLIPDT BETWEEN TO_CHAR(TRUNC(ADD_MONTHS(TO_DATE(#{deliverydt}, 'YYYYMMDD'), -1), 'MM'), 'YYYYMMDD') AND #{deliverydt}
	              AND STATUS = '90'
                <choose>
                    <when test='tmDeliverytype == "1"'>
                        AND DOCTYPE IN ('WD', 'RT')
                        AND TM_DELIVERYTYPE IN ('1','2')
                    </when>
                    <when test='tmDeliverytype == "3"'>
                        AND DOCTYPE = 'DP'
                        AND TM_DELIVERYTYPE = '3'
                    </when>
                    <when test='tmDeliverytype == "4"'>
                        AND DOCTYPE = 'DP'
                        AND TM_DELIVERYTYPE = '4'
                    </when>
                    <when test='tmDeliverytype == "7"'>
                        AND DOCTYPE IN ('WD', 'DP')
                        AND TM_DELIVERYTYPE = '7'
                    </when>
                    <otherwise>
                        AND DOCTYPE = NULL
                        AND TM_DELIVERYTYPE = '0'
                    </otherwise>
                </choose>
                <if test="contracttype != null and contracttype.size > 0">
                    AND CONTRACTTYPE IN
                    <foreach item="type" collection="contracttype" open="(" separator="," close=")">
                        #{type}
                    </foreach>
                </if>
                <if test="carnoList != null and carnoList.size > 0">
                    AND CARNO IN
                    <foreach item="carno" collection="carnoList" open="(" separator="," close=")">
                        #{carno}
                    </foreach>
                </if>
	            GROUP BY
	                  DCCODE
	                , DELIVERYDT
	                , CARNO
            ) CAR_LIST
            WHERE 1=1
            <if test="deliveryStatus != null and deliveryStatus != ''">
                AND CAR_LIST.WORKLOGTYPE = #{deliveryStatus}
            </if>
            GROUP BY
                  CAR_LIST.DCCODE
    </select>

    <select id="getVehicleGroupMonitoringList" resultType="TmVehicleGroupMonitoringResDto" parameterType="TmVehicleGroupMonitoringReqDto">
            SELECT /* [TmLocationMonitorService.sqlx][getVehicleGroupMonitoringList][센터별 조차 차량 모니터링 조회][이현성][2026.03.10] */
                  CAR_LIST.DCCODE
                , CAR_LIST.OUT_GROUP_CD AS CARGROUP
                , FN_CODEDESCR('FW00', 'CARGROUP', CAR_LIST.OUT_GROUP_CD) AS CARGROUP_NAME
                , COUNT(DISTINCT CAR_LIST.CARNO) AS CNT
            FROM (
	            SELECT
	                  DCCODE
	                , DELIVERYDT
	                , OUT_GROUP_CD
	                , CARNO
	                , CASE WHEN DECODE(MAX(DCDEPARTUREDT), NULL, 'N', 'Y') = 'N' THEN '10'
	                       WHEN COUNT(DISTINCT CASE WHEN CUSTDEPARTUREDT IS NOT NULL THEN TRUTHCUSTKEY ELSE NULL END)
	                          = COUNT(DISTINCT TRUTHCUSTKEY) THEN '30'
	                       ELSE '20'
	                       END AS WORKLOGTYPE
	            FROM VW_TM_INPLAN_ALL
	            WHERE DCCODE = #{dccode}
	              AND DELIVERYDT = #{deliverydt}
                  AND SLIPDT BETWEEN TO_CHAR(TRUNC(ADD_MONTHS(TO_DATE(#{deliverydt}, 'YYYYMMDD'), -1), 'MM'), 'YYYYMMDD') AND #{deliverydt}
	              AND STATUS = '90'
                <choose>
                    <when test='tmDeliverytype == "1"'>
                        AND DOCTYPE IN ('WD', 'RT')
                        AND TM_DELIVERYTYPE IN ('1','2')
                    </when>
                    <when test='tmDeliverytype == "3"'>
                        AND DOCTYPE = 'DP'
                        AND TM_DELIVERYTYPE = '3'
                    </when>
                    <when test='tmDeliverytype == "4"'>
                        AND DOCTYPE = 'DP'
                        AND TM_DELIVERYTYPE = '4'
                    </when>
                    <when test='tmDeliverytype == "7"'>
                        AND DOCTYPE IN ('WD', 'DP')
                        AND TM_DELIVERYTYPE = '7'
                    </when>
                    <otherwise>
                        AND DOCTYPE = NULL
                        AND TM_DELIVERYTYPE = '0'
                    </otherwise>
                </choose>
                <if test="contracttype != null and contracttype.size > 0">
                    AND CONTRACTTYPE IN
                    <foreach item="type" collection="contracttype" open="(" separator="," close=")">
                        #{type}
                    </foreach>
                </if>
                <if test="carnoList != null and carnoList.size > 0">
                    AND CARNO IN
                    <foreach item="carno" collection="carnoList" open="(" separator="," close=")">
                        #{carno}
                    </foreach>
                </if>
	            GROUP BY
	                  DCCODE
	                , DELIVERYDT
	                , OUT_GROUP_CD
	                , CARNO
            ) CAR_LIST
            WHERE 1=1
            <if test="deliveryStatus != null and deliveryStatus != ''">
                AND CAR_LIST.WORKLOGTYPE = #{deliveryStatus}
            </if>
            GROUP BY
                  CAR_LIST.DCCODE
                , CAR_LIST.OUT_GROUP_CD
            ORDER BY
                  CAR_LIST.DCCODE
                , TO_NUMBER(CAR_LIST.OUT_GROUP_CD)
    </select>

    <select id="getVehicleDetailMonitoringList" resultType="TmVehicleDetailMonitoringResDto" parameterType="TmVehicleDetailMonitoringReqDto">
            SELECT /* [TmLocationMonitorService.sqlx][getVehicleDetailMonitoringList][센터별 조차별 차량 모니터링 조회][이현성][2026.03.10] */
                  CAR_LIST.DCCODE
                , CAR_LIST.OUT_GROUP_CD AS CARGROUP
                , CAR_LIST.WORKLOGTYPE AS DELIVERY_STATUS
                , FN_CODEDESCR('FW00', 'CAR_LOC_MTR_STATUS', CAR_LIST.WORKLOGTYPE) AS DELIVERY_STATUS_NAME
				, CAR_LIST.CONTRACTTYPE
				, FN_CODEVALUE('FW00', 'CONTRACTTYPE', CAR_LIST.CONTRACTTYPE, 'CONVDESCR') AS CONTRACTNAME
                , CAR_LIST.CARNO
                , CM_CAR.DRIVER1
                , CM_DRIVER.DRIVERNAME
                , ( SELECT DECODE(COUNT(1), 1, 'N', 'Y')
                    FROM TM_CAR_LOCATION_LOG
                    WHERE CARNO = CAR_LIST.CARNO
                      AND LOAD_DATE BETWEEN SYSDATE - (5/1440) AND SYSDATE
                      AND ROWNUM = 1
                  ) AS APP_DISCONNECTED_YN
            FROM (
	            SELECT
	                  DCCODE
	                , DELIVERYDT
	                , OUT_GROUP_CD
	                , CONTRACTTYPE
	                , CARNO
	                , CASE WHEN DECODE(MAX(DCDEPARTUREDT), NULL, 'N', 'Y') = 'N' THEN '10'
	                       WHEN COUNT(DISTINCT CASE WHEN CUSTDEPARTUREDT IS NOT NULL THEN TRUTHCUSTKEY ELSE NULL END)
	                          = COUNT(DISTINCT TRUTHCUSTKEY) THEN '30'
	                       ELSE '20'
	                       END AS WORKLOGTYPE
	            FROM VW_TM_INPLAN_ALL
	            WHERE DCCODE = #{dccode}
	              AND DELIVERYDT = #{deliverydt}
                  AND SLIPDT BETWEEN TO_CHAR(TRUNC(ADD_MONTHS(TO_DATE(#{deliverydt}, 'YYYYMMDD'), -1), 'MM'), 'YYYYMMDD') AND #{deliverydt}
                  AND STATUS = '90'
                <choose>
                    <when test='tmDeliverytype == "1"'>
                        AND DOCTYPE IN ('WD', 'RT')
                        AND TM_DELIVERYTYPE IN ('1','2')
                    </when>
                    <when test='tmDeliverytype == "3"'>
                        AND DOCTYPE = 'DP'
                        AND TM_DELIVERYTYPE = '3'
                    </when>
                    <when test='tmDeliverytype == "4"'>
                        AND DOCTYPE = 'DP'
                        AND TM_DELIVERYTYPE = '4'
                    </when>
                    <when test='tmDeliverytype == "7"'>
                        AND DOCTYPE IN ('WD', 'DP')
                        AND TM_DELIVERYTYPE = '7'
                    </when>
                    <otherwise>
                        AND DOCTYPE = NULL
                        AND TM_DELIVERYTYPE = '0'
                    </otherwise>
                </choose>
                <if test="contracttype != null and contracttype.size > 0">
                    AND CONTRACTTYPE IN
                    <foreach item="type" collection="contracttype" open="(" separator="," close=")">
                        #{type}
                    </foreach>
                </if>
                <if test="carnoList != null and carnoList.size > 0">
                    AND CARNO IN
                    <foreach item="carno" collection="carnoList" open="(" separator="," close=")">
                        #{carno}
                    </foreach>
                </if>
	            GROUP BY
	                  DCCODE
	                , DELIVERYDT
	                , OUT_GROUP_CD
	                , CONTRACTTYPE
	                , CARNO
            ) CAR_LIST
            LEFT JOIN CM_CAR
                ON  CM_CAR.CARNO = CAR_LIST.CARNO
            LEFT JOIN CM_DRIVER
                ON  CM_DRIVER.DRIVERID = CM_CAR.DRIVER1
            WHERE 1=1
            <if test="deliveryStatus != null and deliveryStatus != ''">
                AND CAR_LIST.WORKLOGTYPE = #{deliveryStatus}
            </if>
            ORDER BY
                  CAR_LIST.DCCODE
                , TO_NUMBER(CAR_LIST.OUT_GROUP_CD)
                , TO_NUMBER(CAR_LIST.WORKLOGTYPE)
    </select>

    <select id="getVehicleStatusCountList" resultType="TmVehicleStatusCountResDto" parameterType="TmVehicleStatusCountReqDto">
            SELECT /* [TmLocationMonitorService.sqlx][getVehicleStatusCountList][배송일자별 차량 모니터링 전체 카운트 조회][이현성][2026.03.10] */
                  CAR_LIST.DCCODE
                , NVL(CAR_LIST.WORKLOGTYPE, '00') AS DELIVERY_STATUS
                , FN_CODEDESCR('FW00', 'CAR_LOC_MTR_STATUS', NVL(CAR_LIST.WORKLOGTYPE, '00')) AS DELIVERY_STATUS_NAME
                , COUNT(DISTINCT CAR_LIST.CARNO) AS CNT
            FROM (
	            SELECT
	                  DCCODE
	                , DELIVERYDT
	                , CARNO
	                , CASE WHEN DECODE(MAX(DCDEPARTUREDT), NULL, 'N', 'Y') = 'N' THEN '10'
	                       WHEN COUNT(DISTINCT CASE WHEN CUSTDEPARTUREDT IS NOT NULL THEN TRUTHCUSTKEY ELSE NULL END)
	                          = COUNT(DISTINCT TRUTHCUSTKEY) THEN '30'
	                       ELSE '20'
	                       END AS WORKLOGTYPE
	            FROM VW_TM_INPLAN_ALL
	            WHERE DCCODE = #{dccode}
	              AND DELIVERYDT = #{deliverydt}
                  AND SLIPDT BETWEEN TO_CHAR(TRUNC(ADD_MONTHS(TO_DATE(#{deliverydt}, 'YYYYMMDD'), -1), 'MM'), 'YYYYMMDD') AND #{deliverydt}
                  AND STATUS = '90'
                <choose>
                    <when test='tmDeliverytype == "1"'>
                        AND DOCTYPE IN ('WD', 'RT')
                        AND TM_DELIVERYTYPE IN ('1','2')
                    </when>
                    <when test='tmDeliverytype == "3"'>
                        AND DOCTYPE = 'DP'
                        AND TM_DELIVERYTYPE = '3'
                    </when>
                    <when test='tmDeliverytype == "4"'>
                        AND DOCTYPE = 'DP'
                        AND TM_DELIVERYTYPE = '4'
                    </when>
                    <when test='tmDeliverytype == "7"'>
                        AND DOCTYPE IN ('WD', 'DP')
                        AND TM_DELIVERYTYPE = '7'
                    </when>
                    <otherwise>
                        AND DOCTYPE = NULL
                        AND TM_DELIVERYTYPE = '0'
                    </otherwise>
                </choose>
	            GROUP BY
	                  DCCODE
	                , DELIVERYDT
	                , CARNO
            ) CAR_LIST
            GROUP BY
                  CAR_LIST.DCCODE
                , ROLLUP(CAR_LIST.WORKLOGTYPE)
            ORDER BY
                  CAR_LIST.DCCODE
                , TO_NUMBER(NVL(CAR_LIST.WORKLOGTYPE, '00'))
    </select>

