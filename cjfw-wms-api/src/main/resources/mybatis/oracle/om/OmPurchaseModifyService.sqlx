	<select id="getScm0160Header" resultType="HMap">
	/* [omPurchaseModifyService.sqlx][omPurchaseModifyService.getScm0160Header] */
		SELECT DOCNO
		      ,ORDERTYPE
		      ,DCCODE
		      ,FROM_BILLTOKEY
		      ,STORERKEY
		      ,SHOPPINGMALL
		FROM   IF_DM_DOCUMENT_H
		WHERE  IF_FLAG        = 'Y'
		AND    IF_DESTINATION = 'MM'
		AND    IF_ID          = 'SCM0160'
		AND    STORERKEY      = 'FW00'
		AND    DOCNO          = #{docNo}
		AND    ROWNUM         = 1 <!-- 한건만 가져옴 -->
	</select>
	
	<!-- 이체 취소 detail  정보 -->
	<select id="getScm0160Detail" resultType="HMap">
	/* [omPurchaseModifyService.sqlx][omPurchaseModifyService.getScm0160Detail] */
		SELECT DOCNO
		      ,DOCLINE
		      ,DEL_YN
		      ,PLANT
		      ,STORAGELOC
		      ,SKU
		      ,STORERORDERQTY
		      ,STORERUOM
		      ,DELIVERYDATE
		FROM   IF_DM_DOCUMENT_D
		WHERE  IF_FLAG        = 'Y'
		AND    IF_DESTINATION = 'MM'
		AND    IF_ID          = 'SCM0160'
		AND    DOCNO          = #{DOCNO}
		AND    DOCLINE        = #{DOCLINE}
		AND    STORERKEY      = 'FW00'
		AND    OTHER02        = 'X' <!-- 취소내역만  -->
	</select>
    
    <delete id="deleteTempTablePO">
        DELETE /* [omPurchaseModifyService.sqlx][deleteTempTable][데이터임시 Tabele 삭제][jangjaehyun][2025.09.18] */
               SY_PROCESSTEMP_PO
         WHERE PROCESSCREATOR = #{gUserId}
           AND PROCESSTYPE    = 'PO_REQUEST'
           AND SPID           = #{gSpid}
    </delete>
    
    <insert id="insertTempTablePO" parameterType="java.util.List">
	    DECLARE BEGIN
	    <foreach collection="list" index="index" item="item" separator=";">
	        /* [omPurchaseModifyService.sqlx][insertTempTable][데이터임시 Tabele 등록][jangjaehyun][2025.09.18] */
	        INSERT INTO SY_PROCESSTEMP_PO 
	            (
	            PROCESSTYPE
	            ,PROCESSCREATOR
	            ,SPID
	            ,ADDWHO
	            ,EDITWHO
	            ,DCCODE
	            ,AREA
	            ,STORERKEY
	            ,ORGANIZE
	            ,REQUESTDT
	            ,PODT
	            ,CUSTKEY
	            ,CUSTTYPE
	            ,POTYPE
	            ,CHANNEL
	            ,PLANT
	            ,SKU
	            ,UOM
	            ,ORDERQTY
	            ,OPENQTY
	            ,ORDERCREATOR
	            )
	        VALUES 
	            (
	            'PO_REQUEST'
	            ,#{item.gUserId}
	            ,#{item.gSpid}
	            ,#{item.gUserId}
	            ,#{item.gUserId}
	            ,#{item.dcCode}
	            ,'1000'
	            ,#{item.gStorerkey}
	            ,#{item.dcCode}
	            ,NVL(#{item.requestDt}, TO_CHAR(SYSDATE, 'YYYYMMDD'))
	            ,#{item.slipDt}
	            ,#{item.custKey}
	            ,#{item.custType}
	            ,#{item.purchaseType}
	            ,'1'
	            ,#{item.dcCode}
	            ,#{item.sku}
	            ,#{item.uom}
	            ,NVL((SELECT (#{item.orderQty} * NVL(BUNJA, 1) * NVL(BUNMO, 1)) FROM MS_UOM WHERE STORERKEY = 'FW00' AND SKU = #{item.sku} AND UOM = #{item.uom}), 0)
	            ,#{item.orderQty}
	            ,#{item.buyerKey}
	            )
	    </foreach>
	    ; END;
	</insert>
    
    <delete id="deleteTempTableSTO">
        DELETE /* [omPurchaseModifyService.sqlx][deleteTempTableSTO][데이터임시 Tabele 삭제][jangjaehyun][2025.09.18] */
               SY_PROCESSTEMP_ST
         WHERE PROCESSCREATOR = #{gUserId}
           AND PROCESSTYPE    = 'OM_TEMPORDER'
           AND SPID           = #{gSpid}
    </delete>
    
    <insert id="insertTempTableSTO" parameterType="java.util.List">
	    DECLARE BEGIN
	    <foreach collection="list" index="index" item="item" separator=";">
	        /* [omPurchaseModifyService.sqlx][insertTempTableSTO][데이터임시 Tabele 등록][jangjaehyun][2025.09.18] */
	        INSERT INTO SY_PROCESSTEMP_ST 
	            (
	            PROCESSTYPE
	            ,PROCESSCREATOR
	            ,SPID
	            ,ADDWHO
	            ,EDITWHO
	            ,FROM_DCCODE
	            ,FROM_STORERKEY
	            ,FROM_ORGANIZE
	            ,FROM_AREA
	            ,FROM_SKU
	            ,FROM_LOC
	            ,FROM_LOT
	            ,FROM_STOCKID
	            ,FROM_STOCKGRADE
	            ,FROM_STOCKTYPE
	            ,FROM_ORDERQTY
	            ,FROM_UOM
	            ,TO_DCCODE
	            ,TO_STORERKEY
	            ,TO_ORGANIZE
	            ,TO_AREA
	            ,TO_SKU
	            ,TO_LOC
	            ,TO_LOT
	            ,TO_STOCKID
	            ,TO_STOCKGRADE
	            ,TO_STOCKTYPE
	            ,TO_ORDERQTY
	            ,TO_UOM
	            ,ETCQTY1
	            ,ETCQTY2
	            ,SRCSERIALKEY1
	            ,FROM_BUNJA
	            ,FROM_BUNMO
	            ,STATUS
	            )
	        VALUES 
	            (
	            'OM_TEMPORDER'
	            ,#{item.gUserId}
	            ,#{item.gSpid}
	            ,#{item.gUserId}
	            ,#{item.gUserId}
	            ,#{item.fromDcCode}
	            ,#{item.gStorerkey}
	            ,#{item.fromOrganize}
	            ,#{item.area}
	            ,#{item.sku}
	            ,'' /* FROM_LOC */
	            ,'' /* FROM_LOT */
	            ,'STD' /* FROM_STOCKID */
	            ,'STD' /* FROM_STOCKGRADE */            	
	            ,'' /* FROM_STOCKTYPE */            	
	            <choose>
	                <when test="item.bunja != null and item.bunja != ''">
	                    ,NVL((SELECT (#{item.orderQty} * NVL(BUNJA, 1) * NVL(BUNMO, 1)) FROM MS_UOM WHERE STORERKEY = 'FW00' AND SKU = #{item.sku} AND UOM = #{item.uom}), 0)
	                </when>
	                <otherwise>
	                    ,#{item.orderQty}
	                </otherwise>            	
	            </choose>
	            ,#{item.uom}
	            ,#{item.dcCode}
	            ,#{item.gStorerkey}
	            ,#{item.organize}
	            ,#{item.area}
	            ,#{item.sku}
	            ,'' /* TO_LOC */
	            ,'' /* TO_LOT */
	            ,'STD' /* TO_STOCKID */
	            ,'STD' /* TO_STOCKGRADE */
	            ,'' /* TO_STOCKTYPE */
	            <choose>
	                <when test="item.bunja != null and item.bunja != ''">
	                    ,NVL((SELECT (#{item.orderQty} * NVL(BUNJA, 1) * NVL(BUNMO, 1)) FROM MS_UOM WHERE STORERKEY = 'FW00' AND SKU = #{item.sku} AND UOM = #{item.uom}), 0)
	                </when>
	                <otherwise>
	                    ,#{item.orderQty}
	                </otherwise>            	
	            </choose>
	            ,#{item.uom}
	            ,0
	            ,0
	            ,NVL(#{item.modSlipDt}, TO_CHAR(SYSDATE, 'YYYYMMDD'))
	            ,NVL(#{item.bunja}, 1)
	            ,NVL(#{item.bunmo}, 1)
	            ,'00'
	            )
	    </foreach>
	    ; END;
	</insert>
	
	<select id="getSokeySolineList" resultType="HMap">      		
		SELECT  /* [omPurchaseModifyService.sqlx][getSokeySolineList][Sokey, Soline 조회][LeeJeongCheol][2026.03.18] */
		    A.DOCNO,
		    A.SOKEY,
		    A.SOLINE
		FROM OM_SDY_REGN_REPL_D A
		INNER JOIN DM_DOCUMENT_D B
		    ON A.SOKEY  = B.DOCNO
		   AND A.SOLINE = B.DOCLINE
		WHERE A.DOCNO = #{docno}
		  AND B.DCCODE = #{dccode}
		  AND B.SKU    = #{sku}
    </select>
    
    <delete id="deleteSdyRegn">
    DELETE /* [omPurchaseModifyService.sqlx][deleteSdyRegn][OM_SDY_REGN_REPL_D (docno, sokey, soline 조건) 삭제][LeeJeongCheol][2026.03.18] */
	    FROM OM_SDY_REGN_REPL_D
	    WHERE DOCNO = #{docno}
	      AND SOKEY = #{sokey}
	      AND SOLINE = #{soline}
	</delete>
		
</mapper>