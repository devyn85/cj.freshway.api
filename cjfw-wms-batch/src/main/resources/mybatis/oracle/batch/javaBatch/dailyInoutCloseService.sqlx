<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="dailyInoutCloseService">
    <sql id="procedureParams">
          #{AVC_INOUTDT,    mode=IN,    jdbcType=VARCHAR}
        , #{AVC_DCCODE,     mode=IN,    jdbcType=VARCHAR}
        , #{AVC_STORERKEY,  mode=IN,    jdbcType=VARCHAR}
        , #{I_ERR,          mode=INOUT, jdbcType=INTEGER}
        , #{VC_RESULTMSG,   mode=INOUT, jdbcType=VARCHAR}
        , #{VC_RETURNMSG,   mode=INOUT, jdbcType=VARCHAR}
        , AVC_LOG_PARAMS => #{AVC_LOG_PARAMS, mode=IN, jdbcType=VARCHAR} /*(20250821) BATCH LOG관련 PARAMS.*/	
    </sql>
    <select id="callProcExecute" statementType="CALLABLE" parameterType="BatchParamsUtil" resultType="BatchParamsUtil" timeout="14400">
        { CALL SPBT_DAILYINOUTCLOSE.EXECUTE( /* [dailyInoutCloseService.sqlx][callProcExecute][수불 일괄 재생성][김환수][20250801] */ 
               <include refid="procedureParams"/>
        ) }
    </select>
</mapper>