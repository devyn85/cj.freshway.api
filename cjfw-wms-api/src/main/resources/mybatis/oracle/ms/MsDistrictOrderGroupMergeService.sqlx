<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="msDistrictOrderGroupMergeService">
	<select id="getBatchKey" resultType="string">
		SELECT
			TO_CHAR(SYSTIMESTAMP, 'YYYYMMDDHH24MISS') || '_' || NVL(#{gUserId}, 'SYSTEM')
		FROM DUAL
	</select>

</mapper>