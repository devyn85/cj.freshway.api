<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper   PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="stConvertLotService">

    <!-- 유통기한변경 조회 -->
    <select id="getMasterList" resultType="cjfw.wms.st.dto.StConvertLotResDto">
	SELECT /* [StConvertLotService.sqlx][유통기한변경][sss][20250730] */
	       A.DCCODE                 AS DCCODE                 /* 센터코드 */
	     , A.STORERKEY              AS STORERKEY              /* 화주코드 */
	     , A.ORGANIZE               AS ORGANIZE               /* 조직 */
	     , A.AREA                   AS AREA                   /* 구역 */
	     , A.AREANAME               AS AREANAME               /* 구역명 */
	     , A.FROM_STOCKGRADE        AS FROM_STOCKGRADE        /* 재고등급 */
	     , A.STOCKGRADENAME         AS STOCKGRADENAME         /* 재고등급명 */
	     , A.SKU                    AS SKU                    /* 품목코드 */
	     , A.SKUNAME                AS SKUNAME                /* 품목명 */
	     , A.SKUGROUP               AS SKUGROUP               /* 품목그룹 */
	     , A.MC                     AS MC                     /* MC(규격) */
	     , A.FROM_LOC               AS FROM_LOC               /* 출고로케이션 */
	     , A.FROM_LOT               AS FROM_LOT               /* 출고로트 */
	     , A.FROM_STOCKID           AS FROM_STOCKID           /* 출고재고ID */
	     , A.FROM_STOCKTYPE         AS FROM_STOCKTYPE         /* 출고재고유형 */
	     , A.FROM_STOCKTYPEDESCR    AS FROM_STOCKTYPEDESCR    /* 출고재고유형명 */
	     , A.UOM                    AS UOM                    /* 단위 */
	     , A.QTY                    AS QTY                    /* 수량 */
	     , A.OPENQTY                AS OPENQTY                /* 가용수량 */
	     , A.QTYALLOCATED           AS QTYALLOCATED           /* 할당수량 */
	     , A.QTYPICKED              AS QTYPICKED              /* 피킹수량 */
	     , A.TRANQTY                AS TRANQTY                /* 처리수량 */
	     , A.AVGWEIGHT              AS AVGWEIGHT              /* 평균중량 */
	     , A.CALBOX                 AS CALBOX                 /* 계산박스 */
	     , A.REALOPENBOX            AS REALOPENBOX            /* 실가용박스 */
	     , A.REALCFMBOX             AS REALCFMBOX             /* 실확정박스 */
	     , A.TRANBOX                AS TRANBOX                /* 처리박스 */
	     , A.BOXFLAG                AS BOXFLAG                /* 박스처리유무 */
	     , A.FROM_LOTTABLE01        AS FROM_LOTTABLE01        /* 출고LOT속성1 */
	     , A.FROM_LOTTABLE02        AS FROM_LOTTABLE02        /* 출고LOT속성2 */
	     , A.FROM_LOTTABLE03        AS FROM_LOTTABLE03        /* 출고LOT속성3 */
	     , A.FROM_LOTTABLE04        AS FROM_LOTTABLE04        /* 출고LOT속성4 */
	     , A.FROM_LOTTABLE05        AS FROM_LOTTABLE05        /* 출고LOT속성5 */
	     , A.MANUFACTUREDT          AS MANUFACTUREDT          /* 제조일자 */
	     , A.EXPIREDT               AS EXPIREDT               /* 소비일자 */
	     , A.DURATION_TERM          AS DURATION_TERM          /* 유통기한/기간 */
	     , A.USEBYDATEFREERT        AS USEBYDATEFREERT        /* 소비기한잔여율 */
	     , A.DURATIONTYPE           AS DURATIONTYPE           /* 유통기한타입 */
	     , A.DURATION               AS DURATION               /* 유통기한 */
	     , A.SERIALNO               AS SERIALNO               /* 시리얼번호 */
	     , A.CONVSERIALNO           AS CONVSERIALNO           /* 변환시리얼번호 */
	     , A.BUTCHERYDT             AS BUTCHERYDT             /* 도축일자 */
	     , A.CONTRACTCOMPANY        AS CONTRACTCOMPANY        /* 계약업체코드 */
		 ,(SELECT DESCRIPTION FROM MS_CUST
		    WHERE MS_CUST.STORERKEY = A.STORERKEY
		      AND MS_CUST.CUSTKEY = A.CONTRACTCUSTKEY
		      AND ROWNUM = 1)                  AS CONTRACTCOMPANYNAME   /* 계약업체명 */	     
	     , A.FROMVALIDDT            AS FROMVALIDDT            /* 유효시작일 */
	     , A.TOVALIDDT              AS TOVALIDDT              /* 유효종료일 */
	     , A.CONTRACTTYPE           AS CONTRACTTYPE           /* 계약유형 */
	     , A.BARCODE                AS BARCODE                /* 바코드 */
	     , A.FACTORYNAME            AS FACTORYNAME            /* 공장명 */
	     , A.REASONCODE             AS REASONCODE             /* 사유코드-입력용 */
	     , A.REASONMSG              AS REASONMSG              /* 사유메세지-입력용 */
	     --
         ,A.LOTTABLE01             AS LOTTABLE01              /* LOT속성1 - 검색용 */
	FROM (    
		SELECT ST_STOCK.DCCODE                        AS DCCODE               /* 센터코드 */
		      ,ST_STOCK.STORERKEY                     AS STORERKEY            /* 화주코드 */
		      ,ST_STOCK.ORGANIZE                      AS ORGANIZE             /* 조직 */
		      ,ST_STOCK.AREA                          AS AREA                 /* 구역 */
		      ,CM_STORERXAREA.DESCRIPTION             AS AREANAME             /* 구역명 */
		      ,ST_STOCK.STOCKGRADE                    AS FROM_STOCKGRADE      /* 재고등급 */
		      ,NVL(CD1.BASEDESCR,ST_STOCK.STOCKGRADE) AS STOCKGRADENAME       /*재고등급명*/
		      ,ST_STOCK.SKU                           AS SKU                  /* 품목코드 */
		      ,MS_SKU.DESCRIPTION                     AS SKUNAME              /* 품목명 */
		      ,MS_SKU.SKUGROUP                        AS SKUGROUP             /* 품목그룹 */
		      ,MS_SKUSPEC.SPECDESCR                   AS MC                   /* MC(규격) */
		      ,ST_STOCK.LOC                           AS FROM_LOC             /* 출고로케이션 */
		      ,ST_STOCK.LOT                           AS FROM_LOT             /* 출고로트 */
		      ,ST_STOCK.STOCKID                       AS FROM_STOCKID         /* 출고재고ID */
		      ,ST_STOCK.STOCKTYPE                     AS FROM_STOCKTYPE       /* 출고재고유형 */
		      ,NVL(CD2.BASEDESCR,ST_STOCK.STOCKTYPE) AS FROM_STOCKTYPEDESCR   /* 출고재고유형명 */
		      ,ST_STOCK.UOM                           AS UOM                  /* 단위 */
		      ,ST_STOCK.QTY                           AS QTY                  /* 수량 */
		      ,ST_STOCK.OPENQTY                       AS OPENQTY              /* 가용수량 */
		      ,ST_STOCK.QTYALLOCATED                  AS QTYALLOCATED         /* 할당수량 */
		      ,ST_STOCK.QTYPICKED                     AS QTYPICKED            /* 피킹수량 */
		      ,ST_STOCK.OPENQTY                       AS TRANQTY              /* 처리수량 */
		      ,CASE WHEN ST_STOCK.DCCODE = '2170' AND NVL(MS_SKU.LINE01, 'N') = 'Y'
		                AND TO_NUMBER(NVL(MS_SKU.LINE02, 0)) <![CDATA[<>]]> 0
		            THEN TO_NUMBER(NVL(MS_SKU.LINE02, 0))
		            ELSE 0
		        END                                 AS AVGWEIGHT             /* 평균중량 */
		      ,ROUND(
		            CASE WHEN ST_STOCK.DCCODE = '2170'
		                      AND NVL(MS_SKU.LINE01, 'N') = 'Y'
		                      AND TO_NUMBER(NVL(MS_SKU.LINE02, 0)) <![CDATA[<>]]> 0
		                      AND ST_STOCK.UOM = 'KG'
		                 THEN ST_STOCK.QTY / TO_NUMBER(NVL(MS_SKU.LINE02, 0))
		                 ELSE 0
		            END, 2)                         AS CALBOX                /* 계산박스 */
		      ,CASE WHEN ST_STOCK.DCCODE = '2170'
		                AND NVL(MS_SKU.LINE01, 'N') = 'Y'
		            THEN ROUND(ST_STOCK.BOXQTY, 2)
		            ELSE 0
		        END                                 AS REALOPENBOX           /* 실가용박스 */
		      ,CASE WHEN ST_STOCK.DCCODE = '2170'
		                AND NVL(MS_SKU.LINE01, 'N') = 'Y'
		            THEN ROUND(ST_STOCK.BOXQTY, 2)
		            ELSE 0
		        END                                 AS REALCFMBOX            /* 실확정박스 */
		      ,0                                    AS TRANBOX               /* 처리박스 */
		      ,CASE WHEN ST_STOCK.DCCODE = '2170'
		                AND NVL(MS_SKU.LINE01, 'N') = 'Y'
		            THEN 'Y'
		            ELSE 'N'
		        END                                 AS BOXFLAG               /* 박스처리유무 */
		      ,CM_LOT.LOTTABLE01                    AS FROM_LOTTABLE01       /* 출고LOT속성1 */
		      ,CM_LOT.LOTTABLE02                    AS FROM_LOTTABLE02       /* 출고LOT속성2 */
		      ,CM_LOT.LOTTABLE03                    AS FROM_LOTTABLE03       /* 출고LOT속성3 */
		      ,CM_LOT.LOTTABLE04                    AS FROM_LOTTABLE04       /* 출고LOT속성4 */
		      ,CM_LOT.LOTTABLE05                    AS FROM_LOTTABLE05       /* 출고LOT속성5 */
              /*START.제조일자/소비일자*/
              /*
              * 기준일(제조) ~까지 : DURATIONTYPE = 1 일때(유통기한) -> LOTTABLE01 - DURATION 
              *                  DURATIONTYPE = 2 일때(제조일자) -> LOTTABLE01 
              * 기준일(소비) ~부터 : DURATIONTYPE =1 일때 LOTTABLE01
              *             DURATIONTYPE =2일때 LOTTABLE01 + DURATION  -1
              */
              --
              ,LOGISONESVC.FN_LOTTABLE_INFO('1',ST_STOCK.STORERKEY,CM_LOT.LOTTABLE01,MS_SKU.DURATIONTYPE,MS_SKU.DURATION,'')             AS MANUFACTUREDT   /*제조일자*/
              ,LOGISONESVC.FN_LOTTABLE_INFO('2',ST_STOCK.STORERKEY,CM_LOT.LOTTABLE01,MS_SKU.DURATIONTYPE,MS_SKU.DURATION,'')             AS EXPIREDT        /*소비일자*/
              --              
	         , CASE WHEN MS_SKU.DURATIONTYPE = 'N' THEN /*요건.소비기한 관리 안하면 빈값으로 처리*/
	               ''
	           ELSE 
	               FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'N0') || '/' || MS_SKU.DURATION 
	           END AS DURATION_TERM /** 유통기한/기간 */
              ,LOGISONESVC.FN_LOTDURATION('', MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'R0') AS USEBYDATEFREERT /*소비기한잔여율*/    
              /*END.제조일자/소비일자*/
		      ,MS_SKU.DURATIONTYPE                  AS DURATIONTYPE          /* 유통기한타입 */
		      ,MS_SKU.DURATION                      AS DURATION              /* 유통기한 */
		      ,ST_SERIALINFO.SERIALNO               AS SERIALNO              /* 시리얼번호 */
		      ,ST_SERIALINFO.CONVSERIALNO           AS CONVSERIALNO          /* 변환시리얼번호 */
		      ,ST_SERIALINFO.BUTCHERYDT             AS BUTCHERYDT            /* 도축일자 */
		      ,ST_SERIALINFO.CONTRACTCUSTKEY        AS CONTRACTCOMPANY       /* 계약업체코드 */
		      ,ST_SERIALINFO.CONTRACTCUSTKEY        AS CONTRACTCUSTKEY       /* 계약업체코드 */
		      ,ST_SERIALINFO.FROMVALIDDT            AS FROMVALIDDT           /* 유효시작일 */
		      ,ST_SERIALINFO.TOVALIDDT              AS TOVALIDDT             /* 유효종료일 */
		      ,NVL(CD3.BASEDESCR,ST_SERIALINFO.CONTRACTTYPE) AS CONTRACTTYPE /* 계약유형 */
		      ,ST_SERIALINFO.STOCKID                AS BARCODE               /* 바코드 */
		      ,ST_SERIALINFO.FACTORYNAME            AS FACTORYNAME           /* 공장명 */
		      ,CM_LOT.LOTTABLE01                    AS LOTTABLE01            /* LOT속성1 - 검색용 */
		      ,ST_STOCK.LOC                         AS LOC                   /* 로케이션 - 정렬용 */
		      ,''	                                AS REASONCODE            /* 사유코드-입력용 */
		      ,''                                   AS REASONMSG             /* 사유메세지-입력용 */
	    FROM ST_STOCK
	    JOIN MS_SKU
          ON MS_SKU.STORERKEY = ST_STOCK.STORERKEY
         AND MS_SKU.SKU = ST_STOCK.SKU
         AND MS_SKU.DEL_YN = 'N'
	        
	        <!-- START.상품.다중OR검색 -->
	        <if test="skuMulti != null and skuMulti != '' ">
				<trim prefix="AND (" suffix=")" prefixOverrides="OR">
					<foreach collection="skuMulti" item="item">
						OR MS_SKU.SKU IN
						<foreach collection="item" item="code" open="(" close=")" separator=",">
							#{code} 	 
			      		</foreach>
			    	</foreach>
			  	</trim>			                                    
	        </if>
	        <!-- END.상품.다중OR검색 -->	
        
	        <if test="skugroup != null and skugroup != ''">
	            AND LEFT(MS_SKU.SKUGROUP, 2) LIKE #{skugroup}
	        </if>
	    LEFT JOIN MS_SKUSPEC
          ON MS_SKU.STORERKEY        = MS_SKUSPEC.STORERKEY
         AND MS_SKU.SKUGROUP         = MS_SKUSPEC.SPECCODE
         AND MS_SKUSPEC.SPECCATEGORY = 'SKUGROUP'
         AND MS_SKUSPEC.SPECCLASS    = 'MC'
         AND MS_SKUSPEC.DEL_YN       = 'N'
        JOIN CM_LOT
          ON CM_LOT.STORERKEY = ST_STOCK.STORERKEY
         AND CM_LOT.LOT       = ST_STOCK.LOT
         AND CM_LOT.DEL_YN     = 'N'
	        <if test="lottable01 != null and lottable01 != ''">AND CM_LOT.LOTTABLE01 LIKE #{lottable01}</if>
	    JOIN MS_LOCATION
          ON MS_LOCATION.DCCODE = ST_STOCK.DCCODE
         AND MS_LOCATION.LOC = ST_STOCK.LOC 
        <if test="fromzone != null and fromzone != ''">AND MS_LOCATION.ZONE <![CDATA[>=]]> #{fromzone}</if>
        <if test="tozone != null and tozone != ''">AND MS_LOCATION.ZONE <![CDATA[<=]]> #{tozone}</if>
	    <if test="searchserial != null and searchserial != ''">
	        JOIN ST_SNINFO ST_SERIALINFO
              ON ST_STOCK.STORERKEY = ST_SERIALINFO.STORERKEY
             AND ST_STOCK.SKU       = ST_SERIALINFO.SKU
             AND ST_STOCK.STOCKID   = ST_SERIALINFO.STOCKID
	    </if>
	    <if test="searchserial == null or searchserial == ''">
	        LEFT JOIN ST_SNINFO ST_SERIALINFO
	            ON ST_STOCK.STORERKEY = ST_SERIALINFO.STORERKEY
	            AND ST_STOCK.SKU      = ST_SERIALINFO.SKU
	            AND ST_STOCK.STOCKID  = ST_SERIALINFO.STOCKID
	    </if>
        LEFT JOIN CM_STORERXAREA     ON (CM_STORERXAREA.STORERKEY = ST_STOCK.STORERKEY AND CM_STORERXAREA.AREA  = ST_STOCK.AREA) /*구역명*/       
        LEFT JOIN CM_CODE_STORER CD1 ON (CD1.STORERKEY = ST_STOCK.STORERKEY AND CD1.CODELIST = 'STOCKGRADE'      AND CD1.BASECODE = ST_STOCK.STOCKGRADE)        /*재고등급*/
        LEFT JOIN CM_CODE_STORER CD2 ON (CD2.STORERKEY = ST_STOCK.STORERKEY AND CD2.CODELIST = 'STOCKTYPE'       AND CD2.BASECODE = ST_STOCK.STOCKTYPE)         /*출고재고유형명*/
        LEFT JOIN CM_CODE_STORER CD3 ON (CD3.STORERKEY = ST_STOCK.STORERKEY AND CD3.CODELIST = 'CONTRACTTYPE_SN' AND CD3.BASECODE = ST_SERIALINFO.CONTRACTTYPE) /*계약유형*/
       WHERE ST_STOCK.DCCODE    = #{fixdccode}  /*센터*/
         AND ST_STOCK.STORERKEY = #{gStorerkey} /*고객사*/
		    <!-- START.권한센터 -->
		    AND EXISTS (SELECT 1
	                      FROM CM_USER_AUTHORITY 
	                     WHERE CM_USER_AUTHORITY.DCCODE    = ST_STOCK.DCCODE       
	                       AND CM_USER_AUTHORITY.STORERKEY = ST_STOCK.STORERKEY    
	                       AND CM_USER_AUTHORITY.ORGANIZE  = ST_STOCK.ORGANIZE     
	                       AND CM_USER_AUTHORITY.AREA      = ST_STOCK.AREA         
	                       AND CM_USER_AUTHORITY.STORERKEY = #{gStorerkey}
	                       AND CM_USER_AUTHORITY.USERID    = #{gUserId}
	                       AND CM_USER_AUTHORITY.DCCODE    = #{fixdccode}
	                       AND CM_USER_AUTHORITY.AREA      = #{gArea}   
				           <!-- 창고.다중검색 -->
				           <if test='gOrganizeMulti != null and gOrganizeMulti.length > 0'>
					           AND CM_USER_AUTHORITY.ORGANIZE IN
					           <foreach collection="gOrganizeMulti" item="code" open="(" close=")" separator=",">
					             #{code}
					           </foreach>
				           </if>                       
	                   )
		    <!-- END.권한센터	-->  
	    	    
	        <if test="fromloc != null and fromloc != ''">AND ST_STOCK.LOC <![CDATA[>=]]> #{fromloc}</if>
	        <if test="toloc != null and toloc != ''">AND ST_STOCK.LOC <![CDATA[<=]]> #{toloc}</if>
	        <if test="stockgrade != null and stockgrade != ''">AND ST_STOCK.STOCKGRADE = #{stockgrade}</if>
	        <if test="serialno != null and serialno != ''">AND ST_SERIALINFO.SERIALNO LIKE #{serialno}</if>
	        <if test="blno != null and blno != ''">AND ST_SERIALINFO.CONVSERIALNO = #{blno}</if>
	        <if test="contractcompany != null and contractcompany != ''">AND ST_SERIALINFO.CONTRACTCUSTKEY = #{contractcompany}</if>
		) A
		WHERE 1 = 1
		<!-- 날짜구분(MANUFACTUREDT:제조일자,EXPIREDT:소비기한) -->
	    <choose>
	        <when test="dtFlag == 'MANUFACTUREDT'">
	            AND (#{lottable01} IS NULL OR A.MANUFACTUREDT = #{lottable01})
	        </when>
	        <when test="dtFlag == 'EXPIREDT'">
	            AND (#{lottable01} IS NULL OR A.EXPIREDT = #{lottable01})
	        </when>
	    </choose>	
	    <!-- 정열 -->	  
	    <choose>
	        <when test="sortkey == 'LOC'">
	            ORDER BY A.DCCODE, A.ORGANIZE, A.LOC, A.SKU, A.LOTTABLE01
	        </when>
	        <when test="sortkey == 'DATE'">
	            ORDER BY A.DCCODE, A.STORERKEY, A.ORGANIZE, A.SKU, A.LOTTABLE01
	        </when>
	    </choose>
	</select>
	
	
</mapper>
