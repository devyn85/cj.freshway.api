<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="stDailyStockService">
    <!-- 시점별재고조회 배치 -->
    <insert id="saveStDailyStock">
        INSERT INTO LOGISONE.ST_DAILY_STOCK(
            STOCKDATE,
            REF_SERIALKEY,
            DCCODE,
            STORERKEY,
            ORGANIZE,
            AREA,
            SKU,
            LOC,
            LOT,
            STOCKID,
            STOCKGRADE,
            STOCKTYPE,
            UOM,
            QTY,
            OPENQTY,
            QTYEXPECTED,
            QTYRESERVE,
            QTYALLOCATED,
            QTYPICKED,
            QTYHOLD,
            CORRECTQTY,
            SERIALNO,
            CONVSERIALNO,
            ADDDATE,
            EDITDATE,
            ADDWHO,
            EDITWHO)
        SELECT
            TO_CHAR(SYSDATE - 1, 'YYYYMMDD'),
            ST_STOCK.SERIALKEY,
            ST_STOCK.DCCODE,
            ST_STOCK.STORERKEY,
            ST_STOCK.ORGANIZE,
            ST_STOCK.AREA,
            ST_STOCK.SKU,
            ST_STOCK.LOC,
            ST_STOCK.LOT,
            ST_STOCK.STOCKID,
            ST_STOCK.STOCKGRADE,
            ST_STOCK.STOCKTYPE,
            ST_STOCK.UOM,
            ST_STOCK.QTY,
            ST_STOCK.OPENQTY,
            ST_STOCK.QTYEXPECTED,
            ST_STOCK.QTYRESERVE,
            ST_STOCK.QTYALLOCATED,
            ST_STOCK.QTYPICKED,
            ST_STOCK.QTYHOLD,
            ST_STOCK.CORRECTQTY,
            ST_SERIALINFO.SERIALNO,
            ST_SERIALINFO.CONVSERIALNO,
            SYSDATE,
            SYSDATE,
            #{avc_WORKER},
            #{avc_WORKER}
        FROM LOGISONE.ST_STOCK
        LEFT OUTER JOIN ST_SNINFO ST_SERIALINFO
        ON     ST_STOCK.STORERKEY  = ST_SERIALINFO.STORERKEY
        AND    ST_STOCK.SKU        = ST_SERIALINFO.SKU
        AND    ST_STOCK.STOCKID    = ST_SERIALINFO.STOCKID
    </insert>
</mapper>
