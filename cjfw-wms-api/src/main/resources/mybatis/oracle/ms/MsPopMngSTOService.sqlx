<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="msPopMngSTOService">
    
    <!-- 거래처별POP관리(광역일배) 정보 조회 -->
	<select id="getMasterList" resultType="MsPopMngSTOResDto">
		SELECT	* /* [msPopMngSTOService.sqlx][msPopMngSTOService.getMasterList][거래처별POP관리(광역일배) 정보 조회][JeongHyeongCheol][20250626] */ 
		FROM (
        	SELECT  
        	       MS_CUSTXPOP_STO.DCCODE                   AS DCCODE
        	      ,MS_CUSTXPOP_STO.STORERKEY                AS STORERKEY
			      ,MS_CUSTXPOP_STO.TO_DCCODE                AS TO_DCCODE
			      ,MS_CUSTXPOP_STO.POPNO                    AS POPNO
			      ,'1'                                  	AS SAVED
			      ,'0' 										AS TIME_FLAG
			      ,MS_CUSTXPOP_STO.TO_DELIVERYDT           	AS TO_DELIVERYDT
			      ,MS_CUSTXPOP_STO.ADDDATE   				AS ADDDATE
				  ,MS_CUSTXPOP_STO.EDITDATE  				AS EDITDATE
			   	  ,MS_CUSTXPOP_STO.ADDWHO    				AS ADDWHO
			   	  ,MS_CUSTXPOP_STO.EDITWHO   				AS EDITWHO
			   	  ,USER1.USER_NM 							AS REG_NM				 /* 등록자명 */
				  ,USER2.USER_NM 							AS UPD_NM				 /* 수정자명 */
			  FROM MS_CUSTXPOP_STO
			  JOIN CM_USER_AUTHORITY_DCXSTORER  
		        ON CM_USER_AUTHORITY_DCXSTORER.USERID    = #{gUserId}
		       AND CM_USER_AUTHORITY_DCXSTORER.DCCODE    = #{gDccode}
			   AND CM_USER_AUTHORITY_DCXSTORER.STORERKEY =  'FW00'
		       AND CM_USER_AUTHORITY_DCXSTORER.STORERKEY = MS_CUSTXPOP_STO.STORERKEY
		 LEFT JOIN FRAMEONE_USER USER1 ON USER1.USER_ID = MS_CUSTXPOP_STO.ADDWHO  		/*등록자명*/
		 LEFT JOIN FRAMEONE_USER USER2 ON USER2.USER_ID = MS_CUSTXPOP_STO.EDITWHO  		/*수정자명*/
			 WHERE 1=1
			 <if test='dccode != null and dccode != ""'>
				AND    MS_CUSTXPOP_STO.DCCODE         = #{dccode}
			 </if>
			 <if test='popno != null and popno != ""'>
				AND    MS_CUSTXPOP_STO.POPNO         = #{popno}
			 </if>
		      )
	     ORDER BY POPNO, DCCODE
    </select>
	
    <!-- POP관리 정보 merge -->
    <update id="saveMasterList">
    	MERGE INTO MS_CUSTXPOP_STO
	          USING DUAL ON (DCCODE       = #{dccode}
			             AND STORERKEY    = 'FW00' 
			             AND TO_DCCODE      = #{toDccode}	)
			 WHEN MATCHED THEN
			 	UPDATE SET POPNO          = #{popno}
			 	          ,TO_DELIVERYDT  = #{toDeliverydt}
			              ,EDITDATE       = SYSDATE
			              ,EDITWHO        = #{gUserId}
			 WHEN NOT MATCHED THEN
			 INSERT(SERIALKEY 
					,DCCODE
					,STORERKEY 
					,TO_DCCODE
					,POPNO
					,ADDWHO 
					,EDITWHO
					,TO_DELIVERYDT
					)
				VALUES
					(SEQ_MS_CUSTXPOP_STO.NEXTVAL
					,#{dccode}
					,'FW00'
					,#{toDccode}
					,#{popno}
					,#{gUserId}
					,#{gUserId}
					,#{toDeliverydt}
					)
    </update>
    
</mapper>