<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cmFileUploadService">

	<select id="getFileInfoList" resultType="CmFileUploadResDto">
		SELECT /* [CmFileUploadService.sqlx][getFileInfoList][파일 목록 조회][JangGwangSeok][2025.08.29] */
			 TYPE
			,REF_KEY 						
			,FILE_SEQ						
			,SOURCE_FILE_NM			
			,UPLOADED_DIR_PATH		
			,UPLOADED_FILE_NM		
			,FILE_SIZE					
		FROM FRAMEONE_TPL_FILE_UPLOAD
		WHERE 1 = 1
			AND TYPE = #{type}
			<if test="refKey != null and refKey != ''">
				AND REF_KEY = #{refKey}
			</if>
			<if test="multiRefKey != null and multiRefKey != ''">
				AND REF_KEY IN (
				<foreach item="code" collection="multiRefKey.split(',')" separator="," open="" close="">
					#{code}
				</foreach>
				)
			</if>
		ORDER BY REF_KEY DESC, TO_NUMBER(FILE_SEQ)
	</select>
	
	<insert id="insertFileInfo">
		INSERT /* [CmFileUploadService.sqlx][insertFileInfo][파일 등록][JangGwangSeok][2025.08.29] */ INTO FRAMEONE_TPL_FILE_UPLOAD
		( 
			 TYPE
			,REF_KEY
			,FILE_SEQ
			,SOURCE_FILE_NM
			,UPLOADED_DIR_PATH
			,UPLOADED_FILE_NM
			,FILE_SIZE
		) 
		VALUES 
		( 
			 #{type}
			,#{refKey}
			,NVL(#{fileSeq}, (SELECT NVL(MAX(FILE_SEQ),0) + 1 FROM FRAMEONE_TPL_FILE_UPLOAD WHERE REF_KEY = #{refKey}))
			,#{sourceFileNm}
			,#{uploadedDirPath}
			,#{uploadedFileNm}
			,#{fileSize}
		)  
    </insert>
    
    <update id="deleteFileInfo">
		DELETE /* [CmFileUploadService.sqlx][deleteFileInfo][파일 삭제][JangGwangSeok][2025.08.29] */ FROM FRAMEONE_TPL_FILE_UPLOAD
		WHERE 1 = 1
			AND REF_KEY = #{refKey}
			AND FILE_SEQ = #{fileSeq}
			AND TYPE = #{type}
    </update>
    
</mapper>