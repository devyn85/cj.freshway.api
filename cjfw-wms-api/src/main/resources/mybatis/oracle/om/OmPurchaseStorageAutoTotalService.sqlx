               SY_PROCESSTEMP_PO
         WHERE PROCESSCREATOR = #{gUserId}
           AND PROCESSTYPE    = 'PO_REQUEST'
           AND SPID           = #{gSpid}
    </delete>
    
    <delete id="deleteTempTableProc">
        DELETE /* [omPurchaseStorageAutoTotalService.sqlx][deleteTempTablePO][데이터임시 Tabele 삭제][jangjaehyun][2025.10.18] */
               SY_PROCESSTEMP_PO
         WHERE PROCESSCREATOR = #{gUserId}
           AND PROCESSTYPE    = 'PO_REQUEST'
