<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kpOrderQtyStoInfoService">

	<select id="getMasterList" resultType="KpOrderQtyStoInfoResDto">		
    	/* [KpOrderQtyStoInfoService.sqlx][getMasterList][이체및출고현황 목록 조회][JeongHyeongCheol][2025.11.20] */
		WITH TON_CONVERSION AS (
			    SELECT
			         T1.STORERKEY
			        ,T1.SKU
			        ,T2.DESCRIPTION
			        ,T1.DCCODE
			        ,T1.DELIVERYDATE
			        ,T1.DOCTYPE
			        ,T1.CONFIRMQTY
			        ,T1.CONFIRMQTY * (SELECT FN_CONV_UOM(T1.STORERKEY, T1.SKU, T1.UOM, 'KG', 1) FROM DUAL) AS TOTAL_KG
			        ,(T1.CONFIRMQTY * (SELECT FN_CONV_UOM(T1.STORERKEY, T1.SKU, T1.UOM, 'KG', 1) FROM DUAL)) / 1000 AS TOTAL_TON
			        ,(SELECT FN_CODEDESCR(T2.STORERKEY, 'STORAGETYPE', T2.STORAGETYPE) FROM DUAL) AS STORAGE_TYPE
			        ,T1.DCCODE AS CENTER_DCCODE
			    FROM DM_DOCUMENT_D T1
			    LEFT JOIN MS_SKU T2 ON T1.STORERKEY = T2.STORERKEY AND T1.SKU = T2.SKU
			    WHERE
			        T1.STORERKEY = 'FW00'
			        AND T1.WORKPROCESSCODE = 'STO'
			        AND T1.STATUS = '90'
			        AND T1.DELIVERYDATE BETWEEN #{deliverydate}||'01' AND #{deliverydate}||'31'
			        AND T1.CHANNEL = '1'
			        AND T1.DEL_YN = 'N'
			        AND T1.DCCODE IN ('2600', '2620', '2630', '2650', '2660', '2260', '2250', '2607')      
		    ),
		    IncomingData AS (
		        SELECT
		            T.*
		            ,CD1.BASEDESCR AS IN_CENTER_NAME
		            ,CASE
		                 WHEN T.CENTER_DCCODE IN ('2600','2620', '2630', '2650', '2660') THEN '수도권'
		                 WHEN T.CENTER_DCCODE IN ('2250','2260') THEN '수도권_기타'
		                 ELSE '비수도권'
		             END AS IN_REGION_GROUP
		            ,CASE
		                 WHEN T.TOTAL_TON <![CDATA[<]]> 1      THEN '1톤미만'
		                 WHEN T.TOTAL_TON <![CDATA[<]]> 2.5 AND T.TOTAL_TON <![CDATA[>=]]> 1   THEN '2.5톤미만'
		                 WHEN T.TOTAL_TON <![CDATA[<]]> 5   AND T.TOTAL_TON <![CDATA[>=]]> 2.5   THEN '5톤미만'
		                 WHEN T.TOTAL_TON <![CDATA[<]]> 10  AND T.TOTAL_TON <![CDATA[>=]]> 5   THEN '10톤미만'
		                 ELSE '10톤이상'
		             END AS TON_GROUP
		        FROM TON_CONVERSION T
		        LEFT JOIN CM_CODE CD1
		          ON CD1.STORERKEY = 'FW00'
		          AND CD1.CODELIST = 'WMS_MNG_DC'
		          AND CD1.BASECODE = T.CENTER_DCCODE
		        WHERE T.DOCTYPE = 'DP'
		    ),
		    OutgoingData AS (
		        SELECT
		            T.*
		            ,CD1.BASEDESCR AS OUT_CENTER_NAME
		            ,CASE
		                 WHEN T.TOTAL_TON <![CDATA[<]]> 1       THEN '1톤미만'
		                 WHEN T.TOTAL_TON <![CDATA[<]]> 2.5 AND T.TOTAL_TON <![CDATA[>=]]> 1   THEN '2.5톤미만'
		                 WHEN T.TOTAL_TON <![CDATA[<]]> 5   AND T.TOTAL_TON <![CDATA[>=]]> 2.5   THEN '5톤미만'
		                 WHEN T.TOTAL_TON <![CDATA[<]]> 10  AND T.TOTAL_TON <![CDATA[>=]]> 5   THEN '10톤미만'
		                 ELSE '10톤이상'
		             END AS TON_GROUP
		        FROM TON_CONVERSION T
		        LEFT JOIN CM_CODE CD1
		          ON CD1.STORERKEY = 'FW00'
		          AND CD1.CODELIST = 'WMS_MNG_DC'
		          AND CD1.BASECODE = T.CENTER_DCCODE
		        WHERE T.DOCTYPE = 'WD'
		    ),
				-- 💡 1. DC 코드별 정렬 순서 CTE 추가
				DC_ORDER AS (
						SELECT '2600' AS BASECODE, 3 AS DC_SORT_ORDER FROM DUAL UNION ALL -- 이천
						SELECT '2620' AS BASECODE, 4 AS DC_SORT_ORDER FROM DUAL UNION ALL -- 수원1
						SELECT '2630' AS BASECODE, 5 AS DC_SORT_ORDER FROM DUAL UNION ALL -- 수원2
						SELECT '2650' AS BASECODE, 6 AS DC_SORT_ORDER FROM DUAL UNION ALL -- 동탄1
						SELECT '2660' AS BASECODE, 7 AS DC_SORT_ORDER FROM DUAL UNION ALL -- 동탄2
						SELECT '2260' AS BASECODE, 8 AS DC_SORT_ORDER FROM DUAL UNION ALL -- 양산직수입
						SELECT '2250' AS BASECODE, 9 AS DC_SORT_ORDER FROM DUAL         -- 양산
				),
		    AggregatedIncoming AS (
		        SELECT 1 AS CENTER_SORT_ORDER
		          		,'전체' AS CENTER_GROUP
		              ,T.STORAGE_TYPE
		              ,T.CENTER_DCCODE
		              ,T.TON_GROUP
		              ,SUM(T.CONFIRMQTY) AS TOTAL_QTY
		              ,COUNT(DISTINCT T.SKU) AS UNIQUE_SKU_COUNT
		              ,COUNT(DISTINCT T.DELIVERYDATE) AS TOTAL_DAYS
		        FROM IncomingData T
		        GROUP BY T.STORAGE_TYPE, T.TON_GROUP, T.CENTER_DCCODE
		    
		        UNION ALL
		        SELECT 2 AS CENTER_SORT_ORDER
		          		,'수도권' AS CENTER_GROUP
		              ,T.STORAGE_TYPE
		              ,T.CENTER_DCCODE
		              ,T.TON_GROUP
		              ,SUM(T.CONFIRMQTY) AS TOTAL_QTY
		              ,COUNT(DISTINCT T.SKU) AS UNIQUE_SKU_COUNT
		              ,COUNT(DISTINCT T.DELIVERYDATE) AS TOTAL_DAYS
		        FROM IncomingData T
		        WHERE T.IN_REGION_GROUP IN ('수도권', '수도권_기타')
		        GROUP BY T.STORAGE_TYPE, T.TON_GROUP, T.CENTER_DCCODE
		    
		        UNION ALL
		        SELECT DO.DC_SORT_ORDER AS CENTER_SORT_ORDER
									,T.IN_CENTER_NAME AS CENTER_GROUP
		              ,T.STORAGE_TYPE
		              ,T.CENTER_DCCODE
		              ,T.TON_GROUP
		              ,SUM(T.CONFIRMQTY) AS TOTAL_QTY
		              ,COUNT(DISTINCT T.SKU) AS UNIQUE_SKU_COUNT
		              ,COUNT(DISTINCT T.DELIVERYDATE) AS TOTAL_DAYS
		        FROM IncomingData T
						LEFT JOIN DC_ORDER DO ON T.CENTER_DCCODE = DO.BASECODE
		        GROUP BY T.IN_CENTER_NAME, T.STORAGE_TYPE, T.TON_GROUP, T.CENTER_DCCODE, DO.DC_SORT_ORDER
		    ),
		    
		    AggregatedOutgoing AS (
		        SELECT
		             T.OUT_CENTER_NAME
		            ,T.CENTER_DCCODE
		            ,T.STORAGE_TYPE
		            ,T.TON_GROUP
		            ,SUM(T.TOTAL_TON) AS OUT_TOTAL_TON
		        FROM OutgoingData T
		        GROUP BY T.OUT_CENTER_NAME, T.STORAGE_TYPE, T.TON_GROUP, T.CENTER_DCCODE
		    )
		
		    SELECT
		         I.CENTER_GROUP AS CENTER_GROUP
		        ,MAX(I.CENTER_DCCODE) AS CENTER_DCCODE
				,MAX(I.CENTER_SORT_ORDER) AS CENTER_SORT_ORDER
		        ,CASE WHEN GROUPING(I.STORAGE_TYPE) = 1 THEN '총합' ELSE I.STORAGE_TYPE END AS STORAGE_TYPE
		        
		        ,ROUND(SUM(I.TOTAL_QTY),2) AS IN_TOTAL_QTY
		        ,CASE WHEN SUM(I.TOTAL_DAYS) > 0 THEN ROUND(SUM(I.TOTAL_QTY) / SUM(I.TOTAL_DAYS), 0) ELSE 0 END AS IN_QTY_AVG
		               
						-- INCOMING 상세 집계 (기존 로직)
		        ,ROUND(SUM(CASE WHEN I.CENTER_DCCODE = '2600' THEN I.TOTAL_QTY ELSE 0 END),2) AS IN_QTY_2600
		        ,ROUND(SUM(CASE WHEN I.CENTER_DCCODE = '2620' THEN I.TOTAL_QTY ELSE 0 END),2) AS IN_QTY_2620
		        ,ROUND(SUM(CASE WHEN I.CENTER_DCCODE = '2630' THEN I.TOTAL_QTY ELSE 0 END),2) AS IN_QTY_2630
		        ,ROUND(SUM(CASE WHEN I.CENTER_DCCODE = '2650' THEN I.TOTAL_QTY ELSE 0 END),2) AS IN_QTY_2650
		        ,ROUND(SUM(CASE WHEN I.CENTER_DCCODE = '2660' THEN I.TOTAL_QTY ELSE 0 END),2) AS IN_QTY_2660
		        ,ROUND(SUM(CASE WHEN I.CENTER_DCCODE = '2260' THEN I.TOTAL_QTY ELSE 0 END),2) AS IN_QTY_2260
		        ,ROUND(SUM(CASE WHEN I.CENTER_DCCODE = '2250' THEN I.TOTAL_QTY ELSE 0 END),2) AS IN_QTY_2250
		
		        -- IN_SKU_COUNT 상세 집계 (기존 로직)
		        ,ROUND(SUM(I.UNIQUE_SKU_COUNT),2) AS IN_TOTAL_SKU_COUNT
		        ,ROUND(SUM(CASE WHEN I.TON_GROUP = '1톤미만'   THEN I.UNIQUE_SKU_COUNT ELSE 0 END),2) AS IN_SKU_COUNT_LESS_1
		        ,ROUND(SUM(CASE WHEN I.TON_GROUP = '2.5톤미만' THEN I.UNIQUE_SKU_COUNT ELSE 0 END),2) AS IN_SKU_COUNT_LESS_25
		        ,ROUND(SUM(CASE WHEN I.TON_GROUP = '5톤미만'   THEN I.UNIQUE_SKU_COUNT ELSE 0 END),2) AS IN_SKU_COUNT_LESS_5
		        ,ROUND(SUM(CASE WHEN I.TON_GROUP = '10톤미만'  THEN I.UNIQUE_SKU_COUNT ELSE 0 END),2) AS IN_SKU_COUNT_LESS_10
		        ,ROUND(SUM(CASE WHEN I.TON_GROUP = '10톤이상'  THEN I.UNIQUE_SKU_COUNT ELSE 0 END),2) AS IN_SKU_COUNT_OVER_10
		        
		        -- OUTGOING 상세 집계 (기존 로직)
		        -- MAX(CASE WHEN O.CENTER_DCCODE = '2600' THEN O.OUT_CENTER_NAME ELSE '' END) AS OUT_CENTER_NAME_2600
		        -- ... (나머지 O.OUT_CENTER_NAME_2620 ~ 2250도 동일)
		        ,MAX(CASE WHEN O.CENTER_DCCODE = '2600' THEN O.OUT_CENTER_NAME ELSE '' END) AS OUT_CENTER_NAME_2600
		        ,MAX(CASE WHEN O.CENTER_DCCODE = '2620' THEN O.OUT_CENTER_NAME ELSE '' END) AS OUT_CENTER_NAME_2620
		        ,MAX(CASE WHEN O.CENTER_DCCODE = '2630' THEN O.OUT_CENTER_NAME ELSE '' END) AS OUT_CENTER_NAME_2630
		        ,MAX(CASE WHEN O.CENTER_DCCODE = '2650' THEN O.OUT_CENTER_NAME ELSE '' END) AS OUT_CENTER_NAME_2650
		        ,MAX(CASE WHEN O.CENTER_DCCODE = '2660' THEN O.OUT_CENTER_NAME ELSE '' END) AS OUT_CENTER_NAME_2660
		        ,MAX(CASE WHEN O.CENTER_DCCODE = '2260' THEN O.OUT_CENTER_NAME ELSE '' END) AS OUT_CENTER_NAME_2260
		        ,MAX(CASE WHEN O.CENTER_DCCODE = '2250' THEN O.OUT_CENTER_NAME ELSE '' END) AS OUT_CENTER_NAME_2250
		
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2600' THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2600_TOTAL
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2600' AND O.TON_GROUP = '1톤미만'   THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2600_LESS_1
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2600' AND O.TON_GROUP = '2.5톤미만' THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2600_LESS_25
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2600' AND O.TON_GROUP = '5톤미만'   THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2600_LESS_5
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2600' AND O.TON_GROUP = '10톤미만'  THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2600_LESS_10
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2600' AND O.TON_GROUP = '10톤이상'  THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2600_OVER_10
		        
		        -- 2620 ~ 2250의 상세 OUTGOING 집계는 동일한 패턴으로 반복
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2620' THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2620_TOTAL
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2620' AND O.TON_GROUP = '1톤미만'   THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2620_LESS_1
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2620' AND O.TON_GROUP = '2.5톤미만' THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2620_LESS_25
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2620' AND O.TON_GROUP = '5톤미만'   THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2620_LESS_5
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2620' AND O.TON_GROUP = '10톤미만'  THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2620_LESS_10
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2620' AND O.TON_GROUP = '10톤이상'  THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2620_OVER_10
		        
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2630' THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2630_TOTAL
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2630' AND O.TON_GROUP = '1톤미만'   THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2630_LESS_1
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2630' AND O.TON_GROUP = '2.5톤미만' THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2630_LESS_25
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2630' AND O.TON_GROUP = '5톤미만'   THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2630_LESS_5
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2630' AND O.TON_GROUP = '10톤미만'  THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2630_LESS_10
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2630' AND O.TON_GROUP = '10톤이상'  THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2630_OVER_10
		        
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2650' THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2650_TOTAL
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2650' AND O.TON_GROUP = '1톤미만'   THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2650_LESS_1
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2650' AND O.TON_GROUP = '2.5톤미만' THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2650_LESS_25
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2650' AND O.TON_GROUP = '5톤미만'   THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2650_LESS_5
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2650' AND O.TON_GROUP = '10톤미만'  THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2650_LESS_10
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2650' AND O.TON_GROUP = '10톤이상'  THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2650_OVER_10
		        
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2660' THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2660_TOTAL
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2660' AND O.TON_GROUP = '1톤미만'   THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2660_LESS_1
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2660' AND O.TON_GROUP = '2.5톤미만' THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2660_LESS_25
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2660' AND O.TON_GROUP = '5톤미만'   THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2660_LESS_5
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2660' AND O.TON_GROUP = '10톤미만'  THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2660_LESS_10
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2660' AND O.TON_GROUP = '10톤이상'  THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2660_OVER_10
		        
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2260' THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2260_TOTAL
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2260' AND O.TON_GROUP = '1톤미만'   THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2260_LESS_1
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2260' AND O.TON_GROUP = '2.5톤미만' THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2260_LESS_25
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2260' AND O.TON_GROUP = '5톤미만'   THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2260_LESS_5
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2260' AND O.TON_GROUP = '10톤미만'  THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2260_LESS_10
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2260' AND O.TON_GROUP = '10톤이상'  THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2260_OVER_10
		        
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2250' THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2250_TOTAL
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2250' AND O.TON_GROUP = '1톤미만'   THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2250_LESS_1
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2250' AND O.TON_GROUP = '2.5톤미만' THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2250_LESS_25
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2250' AND O.TON_GROUP = '5톤미만'   THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2250_LESS_5
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2250' AND O.TON_GROUP = '10톤미만'  THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2250_LESS_10
		        ,ROUND(SUM(CASE WHEN O.CENTER_DCCODE = '2250' AND O.TON_GROUP = '10톤이상'  THEN O.OUT_TOTAL_TON ELSE 0 END),2) AS OUT_TON_2250_OVER_10
		        
		    FROM AggregatedIncoming I
		    LEFT JOIN AggregatedOutgoing O 
		        ON I.STORAGE_TYPE = O.STORAGE_TYPE
		        AND I.TON_GROUP = O.TON_GROUP
		    GROUP BY  I.CENTER_GROUP, ROLLUP(I.STORAGE_TYPE)
		
		ORDER BY
		    MAX(I.CENTER_SORT_ORDER),
	    	CASE 
				WHEN GROUPING(I.STORAGE_TYPE) = 1 THEN 1 
				WHEN STORAGE_TYPE = '냉동' THEN 2 
				WHEN STORAGE_TYPE = '냉장' THEN 3 
				WHEN STORAGE_TYPE = '실온' THEN 4 
			ELSE 5 END
	</select>
	
	<select id="getDetailList" resultType="KpOrderQtyStoInfoDetailResDto">		
    	/* [KpOrderQtyStoInfoService.sqlx][getMaster][이체및출고현황 목록 조회][JeongHyeongCheol][2025.11.20] */
		SELECT
		    C.SKU AS SKU--상품코드
		    ,C.DESCRIPTION AS SKUNAME--상품명
		    ,FN_CODEDESCR(C.STORERKEY, 'STORAGETYPE', C.STORAGETYPE)  AS STORAGETYPE--저장조건
		    ,FN_DESCR_SKUSPEC(C.STORERKEY, 'SKUGROUP', LEFT(C.SKUGROUP,2)) AS SKU_LDESC --상품대분류
		    ,C.REFERENCE15  AS REFERENCE15 -- 전용 : Y, 범용 : N
		    , MAX(CASE
		            WHEN C.LINE01 = 'Y' THEN C.LINE02
		            ELSE TO_CHAR(C.GROSSWEIGHT)
		        END) AS GROSSWEIGHT 
		    ,C.QTYPERBOX AS QTYPERBOX--박스입수
		    ,C.BOXPERPLT AS BOXPERPLT--PLT입수
		    ,A.BUYERKEY AS BUYERKEY--수급담당
		    ,B.BASEDESCR AS BUYER_NAME -- 수급담당자 이름 (BASEDESCR)
		    --배치센터 이천
		    --배치센터 수원
		    --배치센터수원2
		    --배치센터동탄
		    --배치센터동탄2
		    --배치센터양산
		    ,SUM(DDD.CONFIRMQTY) AS CONFIRMQTY--월출고량 전체
		    ,SUM(CASE WHEN DDD.DCCODE IN ('2600','2620', '2630', '2650', '2660') THEN DDD.CONFIRMQTY ELSE 0 END) AS CONFIRMQTY_S--월출고량 수도권
		    ,SUM(CASE WHEN DDD.DCCODE = '2600' THEN DDD.CONFIRMQTY ELSE 0 END) 				AS CONFIRMQTY_2600--월출고량 이천
		    ,SUM(CASE WHEN DDD.DCCODE IN ('2620', '2630') THEN DDD.CONFIRMQTY ELSE 0 END) 	AS CONFIRMQTY_SUWON--월출고량 수원단지
		    ,SUM(CASE WHEN DDD.DCCODE IN ('2650', '2660') THEN DDD.CONFIRMQTY ELSE 0 END) 	AS CONFIRMQTY_DONGTAN--월출고량 동탄단지
		    ,SUM(CASE WHEN DDD.DCCODE = '2041' THEN DDD.CONFIRMQTY ELSE 0 END) 				AS CONFIRMQTY_2041--월출고량 제주
		    ,SUM(CASE WHEN DDD.DCCODE = '2260' THEN DDD.CONFIRMQTY ELSE 0 END) 				AS CONFIRMQTY_2260--월출고량 양산
		    ,SUM(CASE WHEN DDD.DCCODE = '2230' THEN DDD.CONFIRMQTY ELSE 0 END) 				AS CONFIRMQTY_2230--월출고량 장성
		    ,SUM(CASE WHEN DDD.DCCODE = '1000' THEN DDD.CONFIRMQTY ELSE 0 END) 				AS CONFIRMQTY_1000--월출고량 KX센터
		
			,SUM(DDD2.CONFIRMQTY) AS CONFIRMQTY_STO--이체출고량 전체
		    ,SUM(CASE WHEN DDD2.DCCODE IN ('2600','2620', '2630', '2650', '2660') THEN DDD2.CONFIRMQTY ELSE 0 END) AS CONFIRMQTY_S_STO--이체출고량 수도권
		    ,SUM(CASE WHEN DDD2.DCCODE = '2600' THEN DDD2.CONFIRMQTY ELSE 0 END) 			AS CONFIRMQTY_2600_STO--이체출고량 이천
		    ,SUM(CASE WHEN DDD2.DCCODE IN ('2620', '2630') THEN DDD2.CONFIRMQTY ELSE 0 END) AS CONFIRMQTY_SUWON_STO--이체출고량 수원단지
		    ,SUM(CASE WHEN DDD2.DCCODE IN ('2650', '2660') THEN DDD2.CONFIRMQTY ELSE 0 END) AS CONFIRMQTY_DONGTAN_STO--이체출고량 동탄단지
		    ,SUM(CASE WHEN DDD2.DCCODE = '2041' THEN DDD2.CONFIRMQTY ELSE 0 END) 			AS CONFIRMQTY_2041_STO--이체출고량 제주
		    ,SUM(CASE WHEN DDD2.DCCODE = '2260' THEN DDD2.CONFIRMQTY ELSE 0 END) 			AS CONFIRMQTY_2260_STO--이체출고량 양산
		    ,SUM(CASE WHEN DDD2.DCCODE = '2230' THEN DDD2.CONFIRMQTY ELSE 0 END) 			AS CONFIRMQTY_2230_STO--이체출고량 장성
		    ,SUM(CASE WHEN DDD2.DCCODE = '1000' THEN DDD2.CONFIRMQTY ELSE 0 END) 			AS CONFIRMQTY_1000_STO--이체출고량 KX센터
		    ,ROUND(SUM(DDD.CONFIRMQTY) / (SUM(DDD.CONFIRMQTY) + SUM(DDD2.CONFIRMQTY)),2) AS RATIO_QTY--자체출고비중
			,ROUND(SUM(DDD2.CONFIRMQTY) / (SUM(DDD.CONFIRMQTY) + SUM(DDD2.CONFIRMQTY)),2) AS RATIO_QTY_STO--이체출고비중
		    
		    
		    --이체등    
		   
		    
		FROM
		    MS_PURCHASECUST A
		JOIN
		    CM_CODE B
		    ON A.STORERKEY = B.STORERKEY
		    AND A.BUYERKEY  = B.BASECODE
		JOIN MS_SKU C
		    ON A.SKU = C.SKU  
		    AND A.STORERKEY = C.STORERKEY
		LEFT JOIN DM_DOCUMENT_D DDD 
		    ON DDD.STORERKEY = C.STORERKEY 
		    AND DDD.SKU = C.SKU
		    AND DDD.DOCTYPE = 'WD'
			AND DDD.WORKPROCESSCODE != 'STO'
			AND DDD.DELIVERYDATE BETWEEN #{deliverydate}||'01' AND #{deliverydate}||'31'
			<if test='multiDccode != null and multiDccode.length > 0'>
				AND DDD.DCCODE IN
		        <foreach collection="multiDccode" item="item" open="(" separator="," close=")">
		            #{item}
		        </foreach>
			</if>
		LEFT JOIN DM_DOCUMENT_D DDD2 
		    ON DDD2.STORERKEY = C.STORERKEY 
		    AND DDD2.SKU = C.SKU
		    AND DDD2.DOCTYPE = 'WD'
			AND DDD2.WORKPROCESSCODE = 'STO'
			AND DDD2.DELIVERYDATE BETWEEN #{deliverydate}||'01' AND #{deliverydate}||'31'
			<if test='multiDccode != null and multiDccode.length > 0'>
				AND DDD2.DCCODE IN
		        <foreach collection="multiDccode" item="item" open="(" separator="," close=")">
		            #{item}
		        </foreach>
			</if>
		WHERE
		    A.BUYERKEY != 'STD'
		    AND B.CODELIST = 'BUYERKEY'
		    AND B.STORERKEY = 'FW00'    
		    AND B.DEL_YN = 'N'
		    --AND A.BUYERKEY ='FS소진'
		    <if test='multiDccode != null and multiDccode.length > 0'>
				AND A.DCCODE IN
		        <foreach collection="multiDccode" item="item" open="(" separator="," close=")">
		            #{item}
		        </foreach>
			</if>
		GROUP BY
		    C.SKU,
		    C.DESCRIPTION,
		   FN_CODEDESCR(C.STORERKEY, 'STORAGETYPE', C.STORAGETYPE),
		    FN_DESCR_SKUSPEC(C.STORERKEY, 'SKUGROUP', LEFT(C.SKUGROUP,2)), -- SKU_LDESC
		    C.REFERENCE15,
		    
		    C.QTYPERBOX,
		    C.BOXPERPLT,
		    A.BUYERKEY,
		    B.BASEDESCR, -- BUYER_NAME
		    A.CUSTKEY
		ORDER BY
		    A.BUYERKEY , 
		    C.REFERENCE15 
	</select>
	
    
</mapper>