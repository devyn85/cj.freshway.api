<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="loggingService">

    <insert id="saveApiLog">
        INSERT /* [loggingService.sqlx][logging.saveApiLog][20250721][변지훈] */
          INTO MG_APILOG
            ( /* SERIALKEY */ --COLUMN DEFUALT
              STORERKEY
            , LOGDATE
            , HTTPMETHOD
            , URL
            , SOURCEIP
            , REQUESTBODY
            , RESPONSEBODY
            , STATUS
            , ERRORMESSAGE
            , ERRORSTACKTRACE
            , REQUESTTIME
            , RESPONSETIME
            , LATENCY
            , WORKER
            )
        VALUES
            ( /* SEQ_MG_APILOG.NEXTVAL */
              'FW00'
            , TO_CHAR(SYSDATE, 'YYYYMMDD')
            , #{HTTPMETHOD}
            , #{URL}
            , #{SOURCEIP}
            , #{REQUESTBODY}
            , #{RESPONSEBODY}
            , #{STATUS}
            , #{ERRORMESSAGE}
            , #{ERRORSTACKTRACE}
            , #{REQUESTTIME}
            , #{RESPONSETIME}
            , #{LATENCY}
            , #{WORKER})
    </insert>

</mapper>