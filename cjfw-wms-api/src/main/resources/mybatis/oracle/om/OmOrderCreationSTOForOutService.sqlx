<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="omOrderCreationSTOForOutService">

    <select id="getDataHeaderlist" resultType="OmOrderCreationSTOForOutResDto">		
        SELECT  /* [omOrderCreationSTOForOutServic.sqlx][getDataHeaderlist][이동대상 목록 조회][sunho.kim][2025.07.08] */
               ST_STOCK.DCCODE                                                                                AS DCCODE
              ,ST_STOCK.STORERKEY                                                                             AS STORERKEY
              ,ST_STOCK.ORGANIZE                                                                              AS ORGANIZE
              ,(SELECT CM_DCXORGANIZE.Description 
                FROM   CM_DCXORGANIZE 
                WHERE  CM_DCXORGANIZE.dccode   = ST_STOCK.DCCODE
                AND    CM_DCXORGANIZE.organize = ST_STOCK.ORGANIZE)                                           AS ORGANIZE_NAME
              ,ST_STOCK.AREA                                                                                  AS AREA
              ,ST_STOCK.LOT                                                                                   AS LOT
              ,ST_STOCK.STOCKID                                                                               AS STOCKID 
              ,ST_STOCK.STOCKGRADE                                                                            AS STOCKGRADE
              ,ST_STOCK.STOCKTYPE                                                                             AS STOCKTYPE
              ,CD1.BASEDESCR                                                                                  AS STOCKTYPENAME 
              ,CD2.BASEDESCR                                                                                  AS STOCKGRADENAME
              ,ST_STOCK.LOC                                                                                   AS LOC
              ,ST_STOCK.SKU                                                                                   AS SKU
              ,MS_SKU.DESCRIPTION                                                                             AS SKUNAME
              ,ST_STOCK.UOM                                                                                   AS UOM
              ,ST_STOCK.QTY                                                                                   AS QTY
              ,ST_STOCK.BOXQTY                                                                                AS BOXQTY
              ,ST_STOCK.QTYALLOCATED                                                                          AS QTYALLOCATED
              ,ST_STOCK.QTYPICKED                                                                             AS QTYPICKED
              ,ST_STOCK.QTY - ST_STOCK.QTYALLOCATED - ST_STOCK.QTYPICKED                                      AS POSBQTY
              ,FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'Y') AS NEARDURATIONYN              
              ,CASE WHEN FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'N') > 0 
                    THEN ROUND(FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'N') / MS_SKU.DURATION * 100) 
                    ELSE 0 
                END                                                                                                                    AS USEBYDATE_FREE_RT   
              ,CM_LOT.LOTTABLE01                                                                              AS LOTTABLE01
              ,FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'N') ||'/'|| MS_SKU.DURATION  AS DURATION_TERM
              ,ST_SERIALINFO.SERIALNO                                                                         AS SERIALNO
              ,CD3.BASEDESCR                                                                                  AS STORAGETYPE
              ,MS_SKU.DURATION                                                                                AS DURATION
              ,MS_SKU.DURATIONTYPE                                                                            AS DURATIONTYPE
              ,ST_STOCK.DCCODE                                                                                AS FROM_DCCODE
              ,ST_STOCK.STORERKEY                                                                             AS FROM_STORERKEY
              ,ST_STOCK.ORGANIZE                                                                              AS FROM_ORGANIZE
              ,ST_STOCK.AREA                                                                                  AS FROM_AREA
              ,ST_STOCK.SKU                                                                                   AS FROM_SKU
              ,ST_STOCK.LOC                                                                                   AS FROM_LOC
              ,ST_STOCK.LOT                                                                                   AS FROM_LOT
              ,ST_STOCK.STOCKID                                                                               AS FROM_STOCKID
              ,ST_STOCK.STOCKGRADE                                                                            AS FROM_STOCKGRADE
              ,ST_STOCK.STOCKTYPE                                                                             AS FROM_STOCKTYPE
              ,ST_STOCK.QTY                                                                                   AS FROM_ORDERQTY
              ,ST_STOCK.UOM                                                                                   AS FROM_UOM
              ,ST_STOCK.DCCODE                                                                                AS TO_DCCODE
              ,ST_STOCK.STORERKEY                                                                             AS TO_STORERKEY
              ,ST_STOCK.AREA                                                                                  AS TO_AREA
              ,ST_STOCK.SKU                                                                                   AS TO_SKU
              ,ST_STOCK.LOC                                                                                   AS TO_LOC
              ,ST_STOCK.LOT                                                                                   AS TO_LOT
              ,ST_STOCK.STOCKID                                                                               AS TO_STOCKID
              ,ST_STOCK.STOCKGRADE                                                                            AS TO_STOCKGRADE
              ,ST_STOCK.STOCKTYPE                                                                             AS TO_STOCKTYPE
              ,0                                                                                              AS TO_ORDERQTY
              ,ST_STOCK.UOM                                                                                   AS TO_UOM
              ,ST_STOCK.QTYALLOCATED                                                                          AS ETCQTY1
              ,ST_STOCK.QTYPICKED                                                                             AS ETCQTY2
              ,ST_SERIALINFO.FACTORYNAME                                                                      AS FACTORYNAME
              ,ST_SERIALINFO.CONVSERIALNO                                                                     AS CONVSERIALNO
              ,ST_SERIALINFO.BUTCHERYDT                                                                       AS BUTCHERYDT
              ,ST_SERIALINFO.CONTRACTCUSTKEY                                                                  AS CONTRACTCOMPANY
              ,(SELECT DESCRIPTION FROM MS_CUST 
                WHERE  MS_CUST.STORERKEY = ST_SERIALINFO.STORERKEY
                AND    MS_CUST.CUSTKEY   = ST_SERIALINFO.CONTRACTCUSTKEY
                AND    ROWNUM = 1 )                                                                           AS CONTRACTCOMPANYNAME
              ,ST_SERIALINFO.FROMVALIDDT                                                                      AS FROMVALIDDT
              ,ST_SERIALINFO.TOVALIDDT                                                                        AS TOVALIDDT
              ,CD4.BASEDESCR                                                                                  AS CONTRACTTYPE
              ,ST_SERIALINFO.STOCKID                                                                          AS BARCODE
              ,ST_STOCK.UOM                                                                                   AS PURCHASEUOM
              ,FN_CONV_UOM(ST_STOCK.STORERKEY, ST_STOCK.SKU, ST_STOCK.UOM, 'BOX', 1)                          AS BOX_CAL        /* BOX 단위 환산 */
              ,nvl(MS_SKU.LINE01,'N')                                                                         AS LINE01         /* 비정량여부 */
              ,nvl(case when ms_sku.line01='Y' then ms_sku.line02 end,0)                                      AS LINE02         /* 표준중량 */
              ,nvl(MS_SKU.QTYPERBOX,0)                                                                        AS QTYPERBOX      /* 박스입수량 */
              ,''                                                                                             AS MEMO1          /* 메모 */
              ,CASE WHEN TO_NUMBER(NVL(MS_SKU.LINE02,0)) <![CDATA[<>]]> 0 
                    AND  ST_STOCK.DCCODE       = '2170' 
                    AND NVL(MS_SKU.LINE01,'N') = 'Y'          THEN TO_NUMBER(NVL(MS_SKU.LINE02,0)) 
                    ELSE 0 
               END                                                                                            AS AVGWEIGHT       /* 평균중량 */
              ,0                                                                                              AS CALBOX          /* 환산박스 */      
              ,0                                                                                              AS REALORDERBOX    /* 실박스예정 */
              ,0                                                                                              AS REALCFMBOX      /* 실박스확정 */
              ,'0'                                                                                            AS TRANBOX         /* 작업박스 */
              ,CASE WHEN ST_STOCK.DCCODE       = '2170' 
                    AND NVL(MS_SKU.LINE01,'N') = 'Y'          THEN 'Y'
                    ELSE 'N'
               END                                                                                            AS BOXFLAG         /* 박스처리유무 */
              ,ROUND (
                      CASE WHEN TO_NUMBER(NVL(MS_SKU.LINE02, 0)) <![CDATA[<>]]> 0 THEN
                        (ST_STOCK.QTY) / TO_NUMBER(NVL(MS_SKU.LINE02, 0))
                      ELSE
                        FN_CONV_UOM(ST_STOCK.STORERKEY, ST_STOCK.SKU, ST_STOCK.UOM, 'BOX', 1) * ST_STOCK.QTY
                      END
                ,2)                                                                                           AS STBOX
        FROM   ST_STOCK ST_STOCK
        JOIN   MS_SKU
            ON     MS_SKU.STORERKEY    = ST_STOCK.STORERKEY
            AND    MS_SKU.SKU          = ST_STOCK.SKU
            AND    MS_SKU.DEL_YN       = 'N'
        <if test="sku != null and sku != '' ">
            <if test="skuMulti != null and skuMulti.size() > 0">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="skuMulti" item="item">
                        OR MS_SKU.SKU IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}      
                        </foreach>
                    </foreach>
                </trim>                                             
            </if>
        </if>
        <if test="storagetype != null and storagetype !=''">
            AND    MS_SKU.STORAGETYPE  = #{storagetype}                     
        </if>     
        JOIN   CM_LOT
            ON     CM_LOT.STORERKEY    = ST_STOCK.STORERKEY
            AND    CM_LOT.LOT          = ST_STOCK.LOT
            AND    CM_LOT.DEL_YN       = 'N'
        JOIN   MS_LOCATION
            ON     MS_LOCATION.DCCODE  = ST_STOCK.DCCODE
            AND    MS_LOCATION.LOC     = ST_STOCK.LOC
        JOIN ST_SNINFO ST_SERIALINFO
            ON     ST_STOCK.STORERKEY  = ST_SERIALINFO.STORERKEY
            AND    ST_STOCK.SKU        = ST_SERIALINFO.SKU
            AND    ST_STOCK.STOCKID    = ST_SERIALINFO.STOCKID    
        LEFT OUTER JOIN CM_CODE_STORER CD1
            ON CD1.STORERKEY            = ST_STOCK.STORERKEY
           AND CD1.CODELIST             = 'STOCKTYPE'   
           AND CD1.BASECODE             = ST_STOCK.STOCKTYPE
        LEFT OUTER JOIN CM_CODE_STORER CD2
            ON CD2.STORERKEY            = ST_STOCK.STORERKEY
           AND CD2.CODELIST             = 'STOCKGRADE'   
           AND CD2.BASECODE             = ST_STOCK.STOCKGRADE
        LEFT OUTER JOIN CM_CODE_STORER CD3
            ON CD3.STORERKEY            = MS_SKU.STORERKEY
           AND CD3.CODELIST             = 'STORAGETYPE'   
           AND CD3.BASECODE             = MS_SKU.STORAGETYPE
        LEFT OUTER JOIN CM_CODE_STORER CD4
            ON CD4.STORERKEY            = ST_STOCK.STORERKEY
           AND CD4.CODELIST             = 'CONTRACTTYPE_SN'   
           AND CD4.BASECODE             = ST_SERIALINFO.CONTRACTTYPE    
        
        WHERE  ST_STOCK.DCCODE                  = #{fromDccode}
            AND ST_STOCK.STORERKEY              = #{gStorerkey} 
            AND ST_STOCK.STOCKGRADE             = 'STD'
            AND ST_STOCK.OPENQTY <![CDATA[>]]> 0 /* 이동가능한것만 표출 */
        <if test="serialno != null and serialno !=''">
            AND ST_SERIALINFO.SERIALNO          = #{serialno}    
        </if>
<!--         <if test="blno != null and blno !=''">       
            AND ST_SERIALINFO.CONVSERIALNO      = #{blno}        
        </if> -->
        <if test="blnoMulti != null and blnoMulti != ''">
            AND    ST_SERIALINFO.CONVSERIALNO      IN
          <foreach collection="blnoMulti" item="item" open="(" separator="," close=")">
                     #{item}
          </foreach> 
        </if>
        <if test="contractcompanyMulti != null and contractcompanyMulti != ''">
            AND ST_SERIALINFO.CONTRACTCUSTKEY      IN
            <foreach collection="contractcompanyMulti" item="item" open="(" separator="," close=")">
                 #{item}
            </foreach> 
        </if>
        <if test="organizeMulti != null and organizeMulti != ''">
            AND ST_STOCK.ORGANIZE      IN
            <foreach collection="organizeMulti" item="item" open="(" separator="," close=")">
                 #{item}
            </foreach> 
        </if>
        ORDER BY ST_STOCK.DCCODE
                ,ST_STOCK.LOC
                ,ST_STOCK.STORERKEY
                ,ST_STOCK.SKU
    </select>
    
    <select id="getDataExcelResultlist" resultType="OmOrderCreationSTOForOutResDto">
        SELECT    /* [omOrderCreationSTOForOutServic.sqlx][getDataExcelResultlist][엑셀업로드 처리결과 조회][sunho.kim][2025.07.08] */
               ST_STOCK.DCCODE                                                                                AS DCCODE
              ,ST_STOCK.STORERKEY                                                                             AS STORERKEY
              ,ST_STOCK.ORGANIZE                                                                              AS ORGANIZE
              ,(SELECT CM_DCXORGANIZE.Description 
                FROM   CM_DCXORGANIZE 
                WHERE  CM_DCXORGANIZE.dccode   = ST_STOCK.DCCODE
                AND    CM_DCXORGANIZE.organize = ST_STOCK.ORGANIZE)                                           AS ORGANIZE_NAME
              ,ST_STOCK.AREA                                                                                  AS AREA
              ,ST_STOCK.LOT                                                                                   AS LOT
              ,ST_STOCK.STOCKID                                                                               AS STOCKID 
              ,ST_STOCK.STOCKGRADE                                                                            AS STOCKGRADE
              ,ST_STOCK.STOCKTYPE                                                                             AS STOCKTYPE
              ,CD1.BASEDESCR                                                                                  AS STOCKTYPENAME 
              ,CD2.BASEDESCR                                                                                  AS STOCKGRADENAME
              ,ST_STOCK.LOC                                                                                   AS LOC
              ,ST_STOCK.SKU                                                                                   AS SKU
              ,MS_SKU.DESCRIPTION                                                                             AS SKUNAME
              ,ST_STOCK.UOM                                                                                   AS UOM
              ,ST_STOCK.QTY                                                                                   AS QTY
              ,ST_STOCK.BOXQTY                                                                                AS BOXQTY
              ,ST_STOCK.QTYALLOCATED                                                                          AS QTYALLOCATED
              ,ST_STOCK.QTYPICKED                                                                             AS QTYPICKED
              ,ST_STOCK.QTY - ST_STOCK.QTYALLOCATED - ST_STOCK.QTYPICKED                                      AS POSBQTY
              ,FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'Y') AS NEARDURATIONYN              
              ,CASE WHEN FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'N') > 0 
                    THEN ROUND(FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'N') / MS_SKU.DURATION * 100) 
                    ELSE 0 
                END                                                                                                                    AS USEBYDATE_FREE_RT   
              ,CM_LOT.LOTTABLE01                                                                              AS LOTTABLE01
              ,FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'N') ||'/'|| MS_SKU.DURATION  AS DURATION_TERM
              ,ST_SERIALINFO.SERIALNO                                                                         AS SERIALNO
              ,CD3.BASEDESCR                                                                                  AS STORAGETYPE
              ,MS_SKU.DURATION                                                                                AS DURATION
              ,MS_SKU.DURATIONTYPE                                                                            AS DURATIONTYPE
              ,ST_STOCK.DCCODE                                                                                AS FROM_DCCODE
              ,ST_STOCK.STORERKEY                                                                             AS FROM_STORERKEY
              ,ST_STOCK.ORGANIZE                                                                              AS FROM_ORGANIZE
              ,ST_STOCK.AREA                                                                                  AS FROM_AREA
              ,ST_STOCK.SKU                                                                                   AS FROM_SKU
              ,ST_STOCK.LOC                                                                                   AS FROM_LOC
              ,ST_STOCK.LOT                                                                                   AS FROM_LOT
              ,ST_STOCK.STOCKID                                                                               AS FROM_STOCKID
              ,ST_STOCK.STOCKGRADE                                                                            AS FROM_STOCKGRADE
              ,ST_STOCK.STOCKTYPE                                                                             AS FROM_STOCKTYPE
              ,ST_STOCK.QTY                                                                                   AS FROM_ORDERQTY
              ,ST_STOCK.UOM                                                                                   AS FROM_UOM
              ,ST_STOCK.DCCODE                                                                                AS TO_DCCODE
              ,ST_STOCK.STORERKEY                                                                             AS TO_STORERKEY
              ,ST_STOCK.AREA                                                                                  AS TO_AREA
              ,ST_STOCK.SKU                                                                                   AS TO_SKU
              ,ST_STOCK.LOC                                                                                   AS TO_LOC
              ,ST_STOCK.LOT                                                                                   AS TO_LOT
              ,ST_STOCK.STOCKID                                                                               AS TO_STOCKID
              ,ST_STOCK.STOCKGRADE                                                                            AS TO_STOCKGRADE
              ,ST_STOCK.STOCKTYPE                                                                             AS TO_STOCKTYPE
              ,SY_PROCESSTEMP_ST.TO_ORDERQTY                                                                  AS TO_ORDERQTY
              ,ST_STOCK.UOM                                                                                   AS TO_UOM
              ,ST_STOCK.QTYALLOCATED                                                                          AS ETCQTY1
              ,ST_STOCK.QTYPICKED                                                                             AS ETCQTY2
              ,ST_SERIALINFO.FACTORYNAME                                                                      AS FACTORYNAME
              ,ST_SERIALINFO.CONVSERIALNO                                                                     AS CONVSERIALNO
              ,ST_SERIALINFO.BUTCHERYDT                                                                       AS BUTCHERYDT
              ,ST_SERIALINFO.CONTRACTCUSTKEY                                                                  AS CONTRACTCOMPANY
              ,(SELECT DESCRIPTION FROM MS_CUST 
                WHERE  MS_CUST.STORERKEY = ST_SERIALINFO.STORERKEY
                AND    MS_CUST.CUSTKEY   = ST_SERIALINFO.CONTRACTCUSTKEY
                AND    ROWNUM = 1 )                                                                           AS CONTRACTCOMPANYNAME
              ,ST_SERIALINFO.FROMVALIDDT                                                                      AS FROMVALIDDT
              ,ST_SERIALINFO.TOVALIDDT                                                                        AS TOVALIDDT
              ,CD4.BASEDESCR                                                                                  AS CONTRACTTYPE
              ,ST_SERIALINFO.STOCKID                                                                          AS BARCODE
              ,ST_STOCK.UOM                                                                                   AS PURCHASEUOM
              ,FN_CONV_UOM(ST_STOCK.STORERKEY, ST_STOCK.SKU, ST_STOCK.UOM, 'BOX', 1)                          AS BOX_CAL        /* BOX 단위 환산 */
              ,nvl(MS_SKU.LINE01,'N')                                                                         AS LINE01         /* 비정량여부 */
              ,nvl(case when ms_sku.line01='Y' then ms_sku.line02 end,0)                                      AS LINE02         /* 표준중량 */
              ,nvl(MS_SKU.QTYPERBOX,0)                                                                        AS QTYPERBOX      /* 박스입수량 */
              ,SY_PROCESSTEMP_ST.MEMO1                                                                        AS MEMO1          /* 메모 */
              ,CASE WHEN TO_NUMBER(NVL(MS_SKU.LINE02,0)) <![CDATA[<>]]> 0 
                    AND  ST_STOCK.DCCODE       = '2170' 
                    AND NVL(MS_SKU.LINE01,'N') = 'Y'          THEN TO_NUMBER(NVL(MS_SKU.LINE02,0)) 
                    ELSE 0 
               END                                                                                            AS AVGWEIGHT       /* 평균중량 */
              ,0                                                                                              AS CALBOX          /* 환산박스 */      
              ,0                                                                                              AS REALORDERBOX    /* 실박스예정 */
              ,0                                                                                              AS REALCFMBOX      /* 실박스확정 */
              ,'0'                                                                                            AS TRANBOX         /* 작업박스 */
              ,CASE WHEN ST_STOCK.DCCODE       = '2170' 
                    AND NVL(MS_SKU.LINE01,'N') = 'Y'          THEN 'Y'
                    ELSE 'N'
               END                                                                                            AS BOXFLAG         /* 박스처리유무 */
              ,ROUND (
                      CASE WHEN TO_NUMBER(NVL(MS_SKU.LINE02, 0)) <![CDATA[<>]]> 0 THEN
                        (ST_STOCK.QTY) / TO_NUMBER(NVL(MS_SKU.LINE02, 0))
                      ELSE
                        FN_CONV_UOM(ST_STOCK.STORERKEY, ST_STOCK.SKU, ST_STOCK.UOM, 'BOX', 1) * ST_STOCK.QTY
                      END
                ,2)                                                                                           AS STBOX
              ,SY_PROCESSTEMP_ST.PROCESSFLAG                                                                  AS PROCESSFLAG
              ,SY_PROCESSTEMP_ST.PROCESSMSG                                                                   AS PROCESSMSG  
        FROM  ST_STOCK ST_STOCK
            
        JOIN   MS_SKU
            ON     MS_SKU.STORERKEY    = ST_STOCK.STORERKEY
            AND    MS_SKU.SKU          = ST_STOCK.SKU
            AND    MS_SKU.DEL_YN       = 'N'
        <if test="sku != null and sku != '' ">
            <if test="skuMulti != null and skuMulti.size() > 0">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="skuMulti" item="item">
                        OR MS_SKU.SKU IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}      
                        </foreach>
                    </foreach>
                </trim>                                             
            </if>
        </if>
        <if test="storagetype != null and storagetype !=''">
            AND    MS_SKU.STORAGETYPE  = #{storagetype}                     
        </if>     
        JOIN   CM_LOT
            ON     CM_LOT.STORERKEY    = ST_STOCK.STORERKEY
            AND    CM_LOT.LOT          = ST_STOCK.LOT
            AND    CM_LOT.DEL_YN       = 'N'
        JOIN   MS_LOCATION
            ON     MS_LOCATION.DCCODE  = ST_STOCK.DCCODE
            AND    MS_LOCATION.LOC     = ST_STOCK.LOC
        JOIN ST_SNINFO ST_SERIALINFO
            ON     ST_STOCK.STORERKEY  = ST_SERIALINFO.STORERKEY
            AND    ST_STOCK.SKU        = ST_SERIALINFO.SKU
            AND    ST_STOCK.STOCKID    = ST_SERIALINFO.STOCKID    
        
        JOIN   SY_PROCESSTEMP_ST
            ON     SY_PROCESSTEMP_ST.FROM_DCCODE     = ST_STOCK.DCCODE
            AND    SY_PROCESSTEMP_ST.FROM_ORGANIZE   = ST_STOCK.ORGANIZE
            AND    SY_PROCESSTEMP_ST.FROM_SKU        = ST_STOCK.SKU
            AND    SY_PROCESSTEMP_ST.FROM_STOCKID    = ST_STOCK.STOCKID
            AND    SY_PROCESSTEMP_ST.FROM_STOCKGRADE = ST_STOCK.STOCKGRADE 
            AND    SY_PROCESSTEMP_ST.FROM_LOC        = ST_STOCK.LOC
            AND    SY_PROCESSTEMP_ST.PROCESSTYPE     = 'SPOM_ORDERCREATIONSTO_FO'
            AND    SY_PROCESSTEMP_ST.PROCESSCREATOR  = #{gUserId}
            AND    ST_STOCK.STOCKTYPE                = 'GOOD'
        
        LEFT OUTER JOIN CM_CODE_STORER CD1
            ON CD1.STORERKEY            = ST_STOCK.STORERKEY
           AND CD1.CODELIST             = 'STOCKTYPE'   
           AND CD1.BASECODE             = ST_STOCK.STOCKTYPE
        LEFT OUTER JOIN CM_CODE_STORER CD2
            ON CD2.STORERKEY            = ST_STOCK.STORERKEY
           AND CD2.CODELIST             = 'STOCKGRADE'   
           AND CD2.BASECODE             = ST_STOCK.STOCKGRADE
        LEFT OUTER JOIN CM_CODE_STORER CD3
            ON CD3.STORERKEY            = MS_SKU.STORERKEY
           AND CD3.CODELIST             = 'STORAGETYPE'   
           AND CD3.BASECODE             = MS_SKU.STORAGETYPE
        LEFT OUTER JOIN CM_CODE_STORER CD4
            ON CD4.STORERKEY            = ST_STOCK.STORERKEY
           AND CD4.CODELIST             = 'CONTRACTTYPE_SN'   
           AND CD4.BASECODE             = ST_SERIALINFO.CONTRACTTYPE    
        
        WHERE  ST_STOCK.DCCODE                  = #{fromDccode}
            AND ST_STOCK.STORERKEY              = #{gStorerkey} 
            AND ST_STOCK.STOCKGRADE             = 'STD'
            AND ST_STOCK.OPENQTY <![CDATA[>]]> 0 /* 이동가능한것만 표출 */
        <if test="serialno != null and serialno !=''">
            AND ST_SERIALINFO.SERIALNO          = #{serialno}    
        </if>
        <if test="blno != null and blno !=''">       
            AND ST_SERIALINFO.CONVSERIALNO      = #{blno}        
        </if>
        <if test="contractcompanyMulti != null and contractcompanyMulti != ''">
            AND ST_SERIALINFO.CONTRACTCUSTKEY      IN
            <foreach collection="contractcompanyMulti" item="item" open="(" separator="," close=")">
                 #{item}
            </foreach> 
        </if>
        <if test="organizeMulti != null and organizeMulti != ''">
            AND ST_STOCK.ORGANIZE      IN
            <foreach collection="organizeMulti" item="item" open="(" separator="," close=")">
                 #{item}
            </foreach> 
        </if>
    </select>
    
    <select id="getDataResultlist" resultType="OmOrderCreationSTOForOutResDto">
        SELECT    /* [omOrderCreationSTOForOutServic.sqlx][getDataResultlist][처리결과 조회][sunho.kim][2025.07.08] */
               SY_PROCESSTEMP_ST.FROM_STORERKEY
              ,SY_PROCESSTEMP_ST.FROM_DCCODE
              ,SY_PROCESSTEMP_ST.FROM_ORGANIZE
              ,SY_PROCESSTEMP_ST.FROM_AREA
              ,SY_PROCESSTEMP_ST.FROM_SKU
              ,SY_PROCESSTEMP_ST.FROM_UOM
              ,SY_PROCESSTEMP_ST.FROM_STOCKGRADE
              ,SY_PROCESSTEMP_ST.FROM_STOCKID
              ,SY_PROCESSTEMP_ST.TO_ORDERQTY
              ,SY_PROCESSTEMP_ST.TO_DCCODE
              ,SY_PROCESSTEMP_ST.TO_ORGANIZE
              ,SY_PROCESSTEMP_ST.TO_AREA
              ,SY_PROCESSTEMP_ST.TO_SKU
              ,SY_PROCESSTEMP_ST.TO_UOM
              ,SY_PROCESSTEMP_ST.TO_STOCKGRADE
              ,SY_PROCESSTEMP_ST.PROCESSFLAG
              ,SY_PROCESSTEMP_ST.PROCESSMSG
              ,MS_SKU.DESCRIPTION AS DESCRIPTION
              ,(SELECT DCNAME FROM CM_DC WHERE CM_DC.DCCODE = SY_PROCESSTEMP_ST.FROM_DCCODE AND ROWNUM = 1) AS FROM_DCNAME
              ,(SELECT DCNAME FROM CM_DC WHERE CM_DC.DCCODE = SY_PROCESSTEMP_ST.TO_DCCODE AND ROWNUM = 1) AS TO_DCNAME
        FROM   SY_PROCESSTEMP_ST 
        JOIN   MS_SKU
        ON     MS_SKU.STORERKEY         = SY_PROCESSTEMP_ST.FROM_STORERKEY
        AND    MS_SKU.SKU               = SY_PROCESSTEMP_ST.FROM_SKU
        AND    MS_SKU.DEL_YN            = 'N'
        WHERE  SY_PROCESSTEMP_ST.PROCESSTYPE    = 'SPOM_ORDERCREATIONSTO_FO'
        AND    SY_PROCESSTEMP_ST.PROCESSCREATOR = #{gUserId}
        AND    SY_PROCESSTEMP_ST.SPID           = #{gSpid}
        ORDER BY SY_PROCESSTEMP_ST.FROM_DCCODE
                ,SY_PROCESSTEMP_ST.FROM_LOC
                ,SY_PROCESSTEMP_ST.FROM_STORERKEY
                ,SY_PROCESSTEMP_ST.FROM_SKU
    </select>       
    
    <insert id="insertSyProcessTempST" parameterType="java.util.List">
        INSERT    /* [cmTempTableService.sqlx][insertSyProcessTempSt][임시저장 정보 ST 저장][sunho.kim][2025.07.09] */
            INTO SY_PROCESSTEMP_ST (
                PROCESSTYPE
              , PROCESSCREATOR
              , SPID
              , PROCESSFLAG
              , FROM_DCCODE
              , FROM_STORERKEY
              , FROM_ORGANIZE
              , FROM_AREA
              , FROM_SKU
              , FROM_STOCKGRADE
              , FROM_STOCKTYPE
              , FROM_UOM
              , FROM_STOCKID
              , FROM_LOC
              , FROM_LOT 
              , TO_ORDERQTY
              , TO_DCCODE
              , TO_STORERKEY
              , TO_ORGANIZE
              , TO_AREA
              , TO_SKU
              , TO_STOCKID
              , TO_STOCKGRADE 
              , TO_STOCKTYPE
              , TO_UOM
              , ETCQTY2
              , MEMO1
              , ADDDATE
              , EDITDATE 
              , ADDWHO
              , EDITWHO
        )
        <foreach collection="list" item="item" separator="UNION ALL">
            SELECT
                #{item.processtype}             AS PROCESSTYPE
              , #{item.gUserId}                 AS PROCESSCREATOR
              , #{item.gSpid}                   AS SPID
              , 'N'                             AS PROCESSFLAG
              , #{item.fromDccode}              AS FROM_DCCODE
              , #{item.fromStorerkey}           AS FROM_STORERKEY
              , #{item.fromOrganize}            AS FROM_ORGANIZE
              , #{item.fromArea}                AS FROM_AREA
              , #{item.fromSku}                 AS FROM_SKU     
              , #{item.fromStockgrade}          AS FROM_STOCKGRADE
              , #{item.fromStocktype}           AS FROM_STOCKTYPE
              , #{item.fromUom}                 AS FROM_UOM
              , #{item.fromStockid}             AS FROM_STOCKID
              , #{item.fromLoc}                 AS FROM_LOC
              , #{item.fromLot}                 AS FROM_LOT
              , #{item.toOrderqty}              AS TO_ORDERQTY
              , #{item.toDccode}                AS TO_DCCODE
              , #{item.toStorerkey}             AS TO_STORERKEY
              , #{item.toOrganize}              AS TO_ORGANIZE
              , #{item.toArea}                  AS TO_AREA
              , #{item.toSku}                   AS TO_SKU
              , #{item.toStockid}               AS TO_STOCKID
              , #{item.toStockgrade}            AS TO_STOCKGRADE
              , #{item.toStocktype}             AS TO_STOCKTYPE
              , #{item.toUom}                   AS TO_UOM
              , #{item.etcqty2}                 AS ETCQTY2
              , #{item.memo1}                   AS MEMO1
              , SYSDATE                         AS ADDDATE
              , SYSDATE                         AS EDITDATE
              , #{item.gUserId}                 AS ADDWHO
              , #{item.gUserId}                 AS EDITWHO
            FROM DUAL
        </foreach>
    </insert>
    
    
    <select id="getWithTempTable" parameterType="java.util.List" resultType="OmOrderCreationSTOForOutResDto">
        WITH TEMP AS (    /* [OmOrderCreationSTOForOutService.sqlx][getWithTempTable][외부센터 보충발주 엑셀업로드 검증][sunho.kim][2025.10.22] */
        <foreach collection="saveList" item="item" separator="UNION ALL">
            SELECT 
                   #{item.storerkey}        AS STORERKEY
                 , #{item.organize}         AS ORGANIZE
                 , #{item.fromDccode}       AS FROM_DCCODE
                 , #{item.fromStocktype}    AS FROM_STOCKTYPE
                 , #{item.fromStockgrade}   AS FROM_STOCKGRADE
                 , #{item.loc}              AS LOC
                 , #{item.sku}              AS SKU
                 , #{item.storagetype}      AS STORAGETYPE
                 , #{item.uom}              AS UOM
                 , #{item.qty}              AS QTY
                 , #{item.boxqty}           AS BOXQTY
                 , #{item.qtyallocated}     AS QTYALLOCATED
                 , #{item.qtypicked}        AS QTYPICKED
                 , #{item.posbqty}          AS POSBQTY
                 , #{item.qtyperbox}        AS QTYPERBOX
                 , #{item.stbox}            AS STBOX
                 , #{item.line02}           AS LINE02
                 , #{item.toOrderqty}       AS TO_ORDERQTY
                 , #{item.purchaseuom}      AS PURCHASEUOM
                 , #{item.etcqty1}          AS ETCQTY1
                 , #{item.etcqty2}          AS ETCQTY2
                 , #{item.avgweight}        AS AVGWEIGHT
                 , #{item.calbox}           AS CALBOX
                 , #{item.realorderbox}     AS REALORDERBOX
                 , #{item.usebydateFreeRt}  AS USEBYDATE_FREE_RT
                 , #{item.lottable01}       AS LOTTABLE01 
                 , #{item.durationTerm}     AS DURATION_TERM
                 , #{item.serialno}         AS SERIALNO
                 , #{item.barcode}          AS BARCODE
                 , #{item.convserialno}     AS CONVSERIALNO 
                 , DECODE(TRIM(#{item.butcherydt}), '　', NULL, #{item.butcherydt})      AS BUTCHERYDT
                 , #{item.factoryname}      AS FACTORYNAME
                 , #{item.contracttype}     AS CONTRACTTYPE 
                 , #{item.contractcompany}  AS CONTRACTCOMPANY 
                 , #{item.contractcompanyname}                                           AS CONTRACTCOMPANYNAME 
                 , DECODE(TRIM(#{item.fromvaliddt}), '　', NULL, #{item.fromvaliddt})    AS FROMVALIDDT
                 , DECODE(TRIM(#{item.tovaliddt}), '　', NULL, #{item.tovaliddt})        AS TOVALIDDT
                 , #{item.fromLot}          AS FROM_LOT
                 , #{item.fromStockid}      AS FROM_STOCKID
                 , #{item.fromArea}         AS FROM_AREA
                 , #{item.memo1}            AS MEMO1
                 , #{item.toDccode}         AS TO_DCCODE 
                 , 'N'                      AS DEL_YN
                 , NULL                     AS SERIALKEY
            FROM DUAL
        </foreach>
        )
        
        SELECT
               TEMP.FROM_DCCODE                                                                               AS DCCODE
              ,TEMP.STORERKEY                                                                                 AS STORERKEY
              ,TEMP.ORGANIZE                                                                                  AS ORGANIZE
              ,(SELECT CM_DCXORGANIZE.Description 
                FROM   CM_DCXORGANIZE 
                WHERE  CM_DCXORGANIZE.dccode   = TEMP.FROM_DCCODE
                AND    CM_DCXORGANIZE.organize = TEMP.ORGANIZE)                                               AS ORGANIZE_NAME
              ,TEMP.FROM_AREA                                                                                 AS AREA
              ,TEMP.FROM_LOT                                                                                  AS LOT
              ,TEMP.FROM_STOCKID                                                                              AS STOCKID 
              ,TEMP.FROM_STOCKGRADE                                                                           AS STOCKGRADE
              ,TEMP.FROM_STOCKTYPE                                                                            AS STOCKTYPE
              ,CD1.BASEDESCR                                                                                  AS STOCKTYPENAME 
              ,CD2.BASEDESCR                                                                                  AS STOCKGRADENAME
              ,TEMP.LOC                                                                                       AS LOC
              ,TEMP.SKU                                                                                       AS SKU
              ,MS_SKU.DESCRIPTION                                                                             AS SKUNAME
              ,TEMP.UOM                                                                                       AS UOM
              ,TEMP.QTY                                                                                       AS QTY
              ,TEMP.BOXQTY                                                                                    AS BOXQTY
              ,TEMP.QTYALLOCATED                                                                              AS QTYALLOCATED
              ,TEMP.QTYPICKED                                                                                 AS QTYPICKED
              ,TEMP.POSBQTY                                                                                   AS POSBQTY
              ,FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'Y') AS NEARDURATIONYN              
              ,TEMP.USEBYDATE_FREE_RT                                                                         AS USEBYDATE_FREE_RT   
              ,TEMP.LOTTABLE01                                                                                AS LOTTABLE01
              ,TEMP.DURATION_TERM                                                                             AS DURATION_TERM
              ,TEMP.SERIALNO                                                                                  AS SERIALNO
              ,TEMP.STORAGETYPE                                                                               AS STORAGETYPE
              ,MS_SKU.DURATION                                                                                AS DURATION
              ,MS_SKU.DURATIONTYPE                                                                            AS DURATIONTYPE
              ,TEMP.FROM_DCCODE                                                                               AS FROM_DCCODE
              ,TEMP.STORERKEY                                                                                 AS FROM_STORERKEY
              ,TEMP.ORGANIZE                                                                                  AS FROM_ORGANIZE
              ,TEMP.FROM_AREA                                                                                 AS FROM_AREA
              ,TEMP.SKU                                                                                       AS FROM_SKU
              ,TEMP.LOC                                                                                       AS FROM_LOC
              ,TEMP.FROM_LOT                                                                                  AS FROM_LOT
              ,TEMP.FROM_STOCKID                                                                              AS FROM_STOCKID
              ,TEMP.FROM_STOCKGRADE                                                                           AS FROM_STOCKGRADE
              ,TEMP.FROM_STOCKTYPE                                                                            AS FROM_STOCKTYPE
              ,TEMP.QTY                                                                                       AS FROM_ORDERQTY
              ,TEMP.UOM                                                                                       AS FROM_UOM
              ,TEMP.TO_DCCODE                                                                                 AS TO_DCCODE
              ,TEMP.STORERKEY                                                                                 AS TO_STORERKEY
              ,TEMP.TO_DCCODE                                                                                 AS TO_ORGANIZE
              ,TEMP.FROM_AREA                                                                                 AS TO_AREA
              ,TEMP.SKU                                                                                       AS TO_SKU
              ,TEMP.LOC                                                                                       AS TO_LOC
              ,TEMP.FROM_LOT                                                                                  AS TO_LOT
              ,TEMP.FROM_STOCKID                                                                              AS TO_STOCKID
              ,TEMP.FROM_STOCKGRADE                                                                           AS TO_STOCKGRADE
              ,TEMP.FROM_STOCKTYPE                                                                            AS TO_STOCKTYPE
              ,TEMP.TO_ORDERQTY                                                                               AS TO_ORDERQTY
              ,TEMP.UOM                                                                                       AS TO_UOM
              ,TEMP.ETCQTY1                                                                                   AS ETCQTY1
              ,TEMP.ETCQTY2                                                                                   AS ETCQTY2
              ,TEMP.FACTORYNAME                                                                               AS FACTORYNAME
              ,TEMP.CONVSERIALNO                                                                              AS CONVSERIALNO
              ,TEMP.BUTCHERYDT                                                                                AS BUTCHERYDT
              ,TEMP.CONTRACTCOMPANY                                                                           AS CONTRACTCOMPANY
              ,(SELECT DESCRIPTION FROM MS_CUST 
                WHERE  MS_CUST.STORERKEY = TEMP.STORERKEY
                AND    MS_CUST.CUSTKEY   = TEMP.CONTRACTCOMPANY
                AND    ROWNUM = 1 )                                                                           AS CONTRACTCOMPANYNAME
              ,TEMP.FROMVALIDDT                                                                               AS FROMVALIDDT
              ,TEMP.TOVALIDDT                                                                                 AS TOVALIDDT
              ,TEMP.CONTRACTTYPE                                                                              AS CONTRACTTYPE
              ,TEMP.BARCODE                                                                                   AS BARCODE
              ,TEMP.PURCHASEUOM                                                                               AS PURCHASEUOM
              ,FN_CONV_UOM(TEMP.STORERKEY, TEMP.SKU, TEMP.UOM, 'BOX', 1)                                      AS BOX_CAL        /* BOX 단위 환산 */
              ,nvl(MS_SKU.LINE01,'N')                                                                         AS LINE01         /* 비정량여부 */
              ,nvl(case when ms_sku.line01='Y' then ms_sku.line02 end,0)                                      AS LINE02         /* 표준중량 */
              ,nvl(MS_SKU.QTYPERBOX,0)                                                                        AS QTYPERBOX      /* 박스입수량 */
              ,TEMP.MEMO1                                                                                     AS MEMO1          /* 메모 */
              ,CASE WHEN TO_NUMBER(NVL(MS_SKU.LINE02,0)) <![CDATA[<>]]> 0 
                    AND  TEMP.FROM_DCCODE      = '2170' 
                    AND NVL(MS_SKU.LINE01,'N') = 'Y'          THEN TO_NUMBER(NVL(MS_SKU.LINE02,0)) 
                    ELSE 0 
               END                                                                                            AS AVGWEIGHT       /* 평균중량 */
              ,0                                                                                              AS CALBOX          /* 환산박스 */      
              ,0                                                                                              AS REALORDERBOX    /* 실박스예정 */
              ,0                                                                                              AS REALCFMBOX      /* 실박스확정 */
              ,'0'                                                                                            AS TRANBOX         /* 작업박스 */
              ,CASE WHEN TEMP.FROM_DCCODE      = '2170' 
                    AND NVL(MS_SKU.LINE01,'N') = 'Y'          THEN 'Y'
                    ELSE 'N'
               END                                                                                            AS BOXFLAG         /* 박스처리유무 */
              ,ROUND (
                      CASE WHEN TO_NUMBER(NVL(MS_SKU.LINE02, 0)) <![CDATA[<>]]> 0 THEN
                        (TEMP.QTY) / TO_NUMBER(NVL(MS_SKU.LINE02, 0))
                      ELSE
                        FN_CONV_UOM(TEMP.STORERKEY, TEMP.SKU, TEMP.UOM, 'BOX', 1) * TEMP.QTY
                      END
                ,2)                                                                                           AS STBOX
        
        FROM   TEMP
        
        LEFT OUTER JOIN   MS_SKU
            ON     MS_SKU.STORERKEY    = TEMP.STORERKEY
            AND    MS_SKU.SKU          = TEMP.SKU
            AND    MS_SKU.DEL_YN       = 'N'
        LEFT OUTER JOIN   CM_LOT
            ON     CM_LOT.STORERKEY    = TEMP.STORERKEY
            AND    CM_LOT.LOT          = TEMP.FROM_LOT
            AND    CM_LOT.DEL_YN       = 'N'
        LEFT OUTER JOIN   MS_LOCATION
            ON     MS_LOCATION.DCCODE  = TEMP.FROM_DCCODE
            AND    MS_LOCATION.LOC     = TEMP.LOC

        LEFT OUTER JOIN CM_CODE_STORER CD1
            ON CD1.STORERKEY            = TEMP.STORERKEY
           AND CD1.CODELIST             = 'STOCKTYPE'   
           AND CD1.BASECODE             = TEMP.FROM_STOCKTYPE
        LEFT OUTER JOIN CM_CODE_STORER CD2
            ON CD2.STORERKEY            = TEMP.STORERKEY
           AND CD2.CODELIST             = 'STOCKGRADE'   
           AND CD2.BASECODE             = TEMP.FROM_STOCKGRADE
            
    </select>
    
    <select id="getWithTempTable2" parameterType="java.util.List" resultType="OmOrderCreationSTOForOutResDto">
        WITH TEMP AS (    /* [OmOrderCreationSTOForOutService.sqlx][getWithTempTable][외부센터 보충발주 엑셀업로드 검증][sunho.kim][2025.10.22] */
        <foreach collection="list" item="item" separator="UNION ALL">
            SELECT 
                   #{item.storerkey}        AS STORERKEY
                 , #{item.organize}         AS ORGANIZE
                 , #{item.fromDccode}       AS FROM_DCCODE
                 , #{item.fromStocktype}    AS FROM_STOCKTYPE
                 , #{item.fromStockgrade}   AS FROM_STOCKGRADE
                 , #{item.loc}              AS LOC
                 , #{item.sku}              AS SKU
                 , #{item.storagetype}      AS STORAGETYPE
                 , #{item.uom}              AS UOM
                 , #{item.qty}              AS QTY
                 , #{item.boxqty}           AS BOXQTY
                 , #{item.qtyallocated}     AS QTYALLOCATED
                 , #{item.qtypicked}        AS QTYPICKED
                 , #{item.posbqty}          AS POSBQTY
                 , #{item.qtyperbox}        AS QTYPERBOX
                 , #{item.stbox}            AS STBOX
                 , #{item.line02}           AS LINE02
                 , #{item.toOrderqty}       AS TO_ORDERQTY
                 , #{item.purchaseuom}      AS PURCHASEUOM
                 , #{item.etcqty2}          AS ETCQTY2
                 , #{item.avgweight}        AS AVGWEIGHT
                 , #{item.calbox}           AS CALBOX
                 , #{item.realorderbox}     AS REALORDERBOX
                 , #{item.usebydateFreeRt}  AS USEBYDATE_FREE_RT
                 , #{item.lottable01}       AS LOTTABLE01 
                 , #{item.durationTerm}     AS DURATION_TERM
                 , #{item.serialno}         AS SERIALNO
                 , #{item.barcode}          AS BARCODE
                 , #{item.convserialno}     AS CONVSERIALNO 
                 , DECODE(TRIM(#{item.butcherydt}), '　', NULL, #{item.butcherydt})      AS BUTCHERYDT
                 , #{item.factoryname}      AS FACTORYNAME
                 , #{item.contracttype}     AS CONTRACTTYPE 
                 , #{item.contractcompany}  AS CONTRACTCOMPANY 
                 , #{item.contractcompanyname}                                           AS CONTRACTCOMPANYNAME 
                 , DECODE(TRIM(#{item.fromvaliddt}), '　', NULL, #{item.fromvaliddt})    AS FROMVALIDDT
                 , DECODE(TRIM(#{item.tovaliddt}), '　', NULL, #{item.tovaliddt})        AS TOVALIDDT
                 , #{item.fromLot}          AS FROM_LOT
                 , #{item.fromStockid}      AS FROM_STOCKID
                 , #{item.fromArea}         AS FROM_AREA
                 , #{item.memo1}            AS MEMO1
                 , 'N'                      AS DEL_YN
                 , NULL                     AS SERIALKEY
            FROM DUAL
        </foreach>
        )
        SELECT 
               T.FROM_DCCODE                                                                                  AS DCCODE
              ,T.STORERKEY                                                                                    AS STORERKEY
              ,T.ORGANIZE                                                                                     AS ORGANIZE
              ,(SELECT CM_DCXORGANIZE.Description 
                FROM   CM_DCXORGANIZE 
                WHERE  CM_DCXORGANIZE.dccode   = T.FROM_DCCODE
                AND    CM_DCXORGANIZE.organize = T.ORGANIZE)                                                  AS ORGANIZE_NAME
              ,T.FROM_AREA                                                                                    AS AREA
              ,T.FROM_LOT                                                                                     AS LOT
              ,T.FROM_STOCKID                                                                                 AS STOCKID 
              ,T.FROM_STOCKGRADE                                                                              AS STOCKGRADE
              ,T.FROM_STOCKTYPE                                                                               AS STOCKTYPE
              ,CD1.BASEDESCR                                                                                  AS STOCKTYPENAME 
              ,CD2.BASEDESCR                                                                                  AS STOCKGRADENAME
              ,T.LOC                                                                                          AS LOC
              ,T.SKU                                                                                          AS SKU
              ,MS_SKU.DESCRIPTION                                                                             AS SKUNAME
              ,T.UOM                                                                                          AS UOM
              ,T.QTY                                                                                          AS QTY
              ,T.BOXQTY                                                                                       AS BOXQTY
              ,T.QTYALLOCATED                                                                                 AS QTYALLOCATED
              ,T.QTYPICKED                                                                                    AS QTYPICKED
              ,T.QTY - T.QTYALLOCATED - T.QTYPICKED                                                           AS POSBQTY
              ,FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'Y') AS NEARDURATIONYN              
              ,CASE WHEN FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'N') > 0 
                    THEN ROUND(FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'N') / MS_SKU.DURATION * 100) 
                    ELSE 0 
                END                                                                                           AS USEBYDATE_FREE_RT   
              ,CM_LOT.LOTTABLE01                                                                              AS LOTTABLE01
              ,FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'N') ||'/'|| MS_SKU.DURATION  AS DURATION_TERM
              ,T.SERIALNO                                                                                     AS SERIALNO
              ,CD3.BASEDESCR                                                                                  AS STORAGETYPE
              ,MS_SKU.DURATION                                                                                AS DURATION
              ,MS_SKU.DURATIONTYPE                                                                            AS DURATIONTYPE
              ,T.FROM_DCCODE                                                                                  AS FROM_DCCODE
              ,T.STORERKEY                                                                                    AS FROM_STORERKEY
              ,T.ORGANIZE                                                                                     AS FROM_ORGANIZE
              ,T.FROM_AREA                                                                                    AS FROM_AREA
              ,T.SKU                                                                                          AS FROM_SKU
              ,T.LOC                                                                                          AS FROM_LOC
              ,T.FROM_LOT                                                                                     AS FROM_LOT
              ,T.FROM_STOCKID                                                                                 AS FROM_STOCKID
              ,T.FROM_STOCKGRADE                                                                              AS FROM_STOCKGRADE
              ,T.FROM_STOCKTYPE                                                                               AS FROM_STOCKTYPE
              ,T.QTY                                                                                          AS FROM_ORDERQTY
              ,T.UOM                                                                                          AS FROM_UOM
              ,T.FROM_DCCODE                                                                                  AS TO_DCCODE
              ,T.STORERKEY                                                                                    AS TO_STORERKEY
              ,T.ORGANIZE                                                                                     AS TO_ORGANIZE
              ,T.FROM_AREA                                                                                    AS TO_AREA
              ,T.SKU                                                                                          AS TO_SKU
              ,T.LOC                                                                                          AS TO_LOC
              ,T.FROM_LOT                                                                                     AS TO_LOT
              ,T.FROM_STOCKID                                                                                 AS TO_STOCKID
              ,T.FROM_STOCKGRADE                                                                              AS TO_STOCKGRADE
              ,T.FROM_STOCKTYPE                                                                               AS TO_STOCKTYPE
              ,T.TO_ORDERQTY                                                                                  AS TO_ORDERQTY
              ,T.UOM                                                                                          AS TO_UOM
              ,T.QTYALLOCATED                                                                                 AS ETCQTY1
              ,T.QTYPICKED                                                                                    AS ETCQTY2
              ,T.FACTORYNAME                                                                                  AS FACTORYNAME
              ,T.CONVSERIALNO                                                                                 AS CONVSERIALNO
              ,T.BUTCHERYDT                                                                                   AS BUTCHERYDT
              ,ST_SERIALINFO.CONTRACTCUSTKEY                                                                  AS CONTRACTCOMPANY
              ,(SELECT DESCRIPTION FROM MS_CUST 
                WHERE  MS_CUST.STORERKEY = ST_SERIALINFO.STORERKEY
                AND    MS_CUST.CUSTKEY   = ST_SERIALINFO.CONTRACTCUSTKEY
                AND    ROWNUM = 1 )                                                                           AS CONTRACTCOMPANYNAME
              ,ST_SERIALINFO.FROMVALIDDT                                                                      AS FROMVALIDDT
              ,ST_SERIALINFO.TOVALIDDT                                                                        AS TOVALIDDT
              ,CD4.BASEDESCR                                                                                  AS CONTRACTTYPE
              ,ST_SERIALINFO.STOCKID                                                                          AS BARCODE
              ,T.UOM                                                                                          AS PURCHASEUOM
              ,FN_CONV_UOM(T.STORERKEY, T.SKU, T.UOM, 'BOX', 1)                                               AS BOX_CAL        /* BOX 단위 환산 */
              ,nvl(MS_SKU.LINE01,'N')                                                                         AS LINE01         /* 비정량여부 */
              ,nvl(CASE WHEN MS_SKU.LINE01 = 'Y' THEN MS_SKU.LINE02 END, 0)                                   AS LINE02         /* 표준중량 */
              ,nvl(MS_SKU.QTYPERBOX,0)                                                                        AS QTYPERBOX      /* 박스입수량 */
              ,''                                                                                             AS MEMO1          /* 메모 */
              ,CASE WHEN TO_NUMBER(NVL(MS_SKU.LINE02,0)) <![CDATA[<>]]> 0 
                    AND  T.FROM_DCCODE         = '2170' 
                    AND NVL(MS_SKU.LINE01,'N') = 'Y'          THEN TO_NUMBER(NVL(MS_SKU.LINE02,0)) 
                    ELSE 0 
               END                                                                                            AS AVGWEIGHT       /* 평균중량 */
              ,0                                                                                              AS CALBOX          /* 환산박스 */      
              ,0                                                                                              AS REALORDERBOX    /* 실박스예정 */
              ,0                                                                                              AS REALCFMBOX      /* 실박스확정 */
              ,'0'                                                                                            AS TRANBOX         /* 작업박스 */
              ,CASE WHEN T.FROM_DCCODE        = '2170' 
                    AND NVL(MS_SKU.LINE01,'N') = 'Y'          THEN 'Y'
                    ELSE 'N'
               END                                                                                            AS BOXFLAG         /* 박스처리유무 */
              ,ROUND (
                      CASE WHEN TO_NUMBER(NVL(MS_SKU.LINE02, 0)) <![CDATA[<>]]> 0 THEN
                        (T.QTY) / TO_NUMBER(NVL(MS_SKU.LINE02, 0))
                      ELSE
                        FN_CONV_UOM(T.STORERKEY, T.SKU, T.UOM, 'BOX', 1) * T.QTY
                      END
                ,2)                                                                                           AS STBOX
            
         FROM TEMP T
         JOIN   MS_SKU
             ON    MS_SKU.STORERKEY    = T.STORERKEY
            AND    MS_SKU.SKU          = T.SKU
            AND    MS_SKU.DEL_YN       = 'N'
         JOIN   CM_LOT
             ON    CM_LOT.STORERKEY    = T.STORERKEY
            AND    CM_LOT.LOT          = T.FROM_LOT
            AND    CM_LOT.DEL_YN       = 'N'
         JOIN   MS_LOCATION
             ON    MS_LOCATION.DCCODE  = T.FROM_DCCODE
            AND    MS_LOCATION.LOC     = T.LOC
         JOIN ST_SNINFO ST_SERIALINFO
             ON    T.STORERKEY         = ST_SERIALINFO.STORERKEY
            AND    T.SKU               = ST_SERIALINFO.SKU
            AND    T.FROM_STOCKID      = ST_SERIALINFO.STOCKID    
         LEFT OUTER JOIN CM_CODE_STORER CD1
            ON CD1.STORERKEY            = T.STORERKEY
           AND CD1.CODELIST             = 'STOCKTYPE'   
           AND CD1.BASECODE             = T.FROM_STOCKTYPE
         LEFT OUTER JOIN CM_CODE_STORER CD2
            ON CD2.STORERKEY            = T.STORERKEY
           AND CD2.CODELIST             = 'STOCKGRADE'   
           AND CD2.BASECODE             = T.FROM_STOCKGRADE
         LEFT OUTER JOIN CM_CODE_STORER CD3
            ON CD3.STORERKEY            = MS_SKU.STORERKEY
           AND CD3.CODELIST             = 'STORAGETYPE'   
           AND CD3.BASECODE             = MS_SKU.STORAGETYPE
         LEFT OUTER JOIN CM_CODE_STORER CD4
            ON CD4.STORERKEY            = T.STORERKEY
           AND CD4.CODELIST             = 'CONTRACTTYPE_SN'   
           AND CD4.BASECODE             = ST_SERIALINFO.CONTRACTTYPE    
    </select>
  
</mapper>
