    <!-- 수급 보조지표 이미지 호출 로그 생성 -->
    <insert id="saveSuppImgLog">
		INSERT INTO WD_SUPPIMG_LOG
			   (SERIALKEY
			    ,STORERKEY
			    ,LOG_KEY
			    ,LOG_ID
			    ,LOG_TYPE
			    ,USER_ID
			    ,DCCODE
			    ,SKU
			    ,ADDWHO
			    ,ADDDATE
			    ,EDITWHO
			    ,EDITDATE			    
			    )
		SELECT SEQ_WD_SUPPIMG_LOG.NEXTVAL
			   ,'FW00'
			   ,#{logKey}
			   ,#{logId}
			   ,CM_CODE.BASEDESCR 
			   ,#{gUserId}
			   ,#{dcCode}
			   ,#{sku}
			   ,#{gUserId}
			   ,SYSDATE
			   ,#{gUserId}
			   ,SYSDATE
		FROM   CM_CODE
		WHERE  1=1
		AND	   CODELIST  = 'LOGTYPE'
		AND	   STORERKEY = 'FW00'
		AND	   BASECODE  = #{logId}
    </insert>
    
    <select id="getScm0160Header" resultType="HMap">
	/* [omPurchaseStorageAutoTotalService.sqlx][omPurchaseStorageAutoTotalService.getScm0160Header] */
		SELECT DOCNO
		      ,ORDERTYPE
		      ,DCCODE
		      ,FROM_BILLTOKEY
		      ,STORERKEY
		      ,SHOPPINGMALL
		FROM   IF_DM_DOCUMENT_H
		WHERE  IF_FLAG        = 'N'
		AND    IF_DESTINATION = 'MM'
		AND    IF_ID          = 'SCM0160'
		AND    ADDWHO         = #{userId}
		AND    STORERKEY      = 'FW00'		
	</select>
	
	<select id="getScm0160Detail" resultType="HMap">
		SELECT /* [omPurchaseStorageAutoTotalService.sqlx][omPurchaseStorageAutoTotalService.getScm0160Detail] */
		       DOCNO
		      ,DOCLINE
		      ,DEL_YN
		      ,PLANT
		      ,STORAGELOC
		      ,SKU
		      ,STORERORDERQTY
		      ,STORERUOM
		      ,DELIVERYDATE
		FROM   IF_DM_DOCUMENT_D
		WHERE  IF_FLAG        = 'P'
		AND    IF_DESTINATION = 'MM'
		AND    IF_ID          = 'SCM0160'
		AND    DOCNO          = #{docNo}
		AND    STORERKEY      = 'FW00'
	</select>
	
	<update id="updateScm0160Header" parameterType="HMap">
		/* [omPurchaseStorageAutoTotalService.sqlx][omPurchaseStorageAutoTotalService.updateScm0160Header] */
		UPDATE IF_DM_DOCUMENT_H
		SET    IF_FLAG = #{updateIfFlag}
		      ,IF_MEMO = #{updateIfMemo}
		WHERE  1=1
		AND    IF_FLAG        = #{searchIfFlag}
		AND    IF_DESTINATION = 'MM'
		AND    IF_ID          = 'SCM0160'
		AND    DOCNO          = #{docNo}
		AND    STORERKEY      = 'FW00'
	</update>
	
	<update id="updateScm0160Detail" parameterType="HMap">
		/* [omPurchaseStorageAutoTotalService.sqlx][omPurchaseStorageAutoTotalService.updateScm0160Detail] */
		UPDATE IF_DM_DOCUMENT_D
		SET    IF_FLAG = #{updateIfFlag}
		      ,IF_MEMO = #{updateIfMemo}
		WHERE  1=1
		AND    IF_FLAG        = #{searchIfFlag}
		AND    IF_DESTINATION = 'MM'
		AND    IF_ID          = 'SCM0160'
		AND    DOCNO          = #{docNo}
		AND    STORERKEY      = 'FW00'
	</update>
	
	<delete id="deleteTempTablePOReorder">
        DELETE /* [omPurchaseModifyService.sqlx][deleteTempTable][데이터임시 Tabele 삭제][jangjaehyun][2025.09.18] */
               SY_PROCESSTEMP_PO
         WHERE PROCESSCREATOR = #{gUserId}
           AND PROCESSTYPE    = 'PO_REQUEST'
           AND SPID           = #{gSpid}
    </delete>
    
    <insert id="insertTempTablePOReorder" parameterType="java.util.List">
	    DECLARE BEGIN
	    <foreach collection="list" index="index" item="item" separator=";">
	        /* [omPurchaseModifyService.sqlx][insertTempTable][데이터임시 Tabele 등록][jangjaehyun][2025.09.18] */
	        INSERT INTO SY_PROCESSTEMP_PO 
	            (
	            PROCESSTYPE
	            ,PROCESSCREATOR
	            ,SPID
	            ,ADDWHO
	            ,EDITWHO
	            ,DCCODE
	            ,AREA
	            ,STORERKEY
	            ,ORGANIZE
	            ,REQUESTDT
	            ,PODT
	            ,CUSTKEY
	            ,CUSTTYPE
	            ,POTYPE
	            ,CHANNEL
	            ,PLANT
	            ,SKU
	            ,UOM
	            ,ORDERQTY
	            ,OPENQTY
	            ,ORDERCREATOR
	            ,STORAGELOC
	            )
	        VALUES 
	            (
	            'PO_REQUEST'
	            ,#{item.gUserId}
	            ,#{item.gSpid}
	            ,#{item.gUserId}
	            ,#{item.gUserId}
	            ,#{item.dcCode}
	            ,#{item.area}
	            ,#{item.gStorerkey}
	            ,#{item.dcCode}
	            ,NVL(#{item.requestDt}, TO_CHAR(SYSDATE, 'YYYYMMDD'))
	            ,#{item.slipDt}
	            ,#{item.custKey}
	            ,#{item.custType}
	            ,#{item.purchaseType}
	            ,#{item.channel}
	            ,#{item.dcCode}
	            ,#{item.sku}
	            ,#{item.uom}
	            ,NVL((SELECT (#{item.orderQty} * NVL(BUNJA, 1) * NVL(BUNMO, 1)) FROM MS_UOM WHERE STORERKEY = 'FW00' AND SKU = #{item.sku} AND UOM = #{item.purchaseUom}), 0)
	            ,#{item.orderQty}
	            ,#{item.buyerKey}
	            ,#{item.routeOrganize}                
	            )
	    </foreach>
	    ; END;
	</insert>
    
    <delete id="deleteTempTableSTOReorder">
        DELETE /* [omPurchaseModifyService.sqlx][deleteTempTableSTO][데이터임시 Tabele 삭제][jangjaehyun][2025.09.18] */
               SY_PROCESSTEMP_ST
         WHERE PROCESSCREATOR = #{gUserId}
           AND PROCESSTYPE    = 'OM_TEMPORDER'
           AND SPID           = #{gSpid}
    </delete>
    
    <insert id="insertTempTableSTOReorder" parameterType="java.util.List">
	    DECLARE BEGIN
	    <foreach collection="list" index="index" item="item" separator=";">
	        /* [omPurchaseModifyService.sqlx][insertTempTableSTO][데이터임시 Tabele 등록][jangjaehyun][2025.09.18] */
	        INSERT INTO SY_PROCESSTEMP_ST 
	            (
	            PROCESSTYPE
	            ,PROCESSCREATOR
	            ,SPID
	            ,ADDWHO
	            ,EDITWHO
	            ,FROM_DCCODE
	            ,FROM_STORERKEY
	            ,FROM_ORGANIZE
	            ,FROM_AREA
	            ,FROM_SKU
	            ,FROM_LOC
	            ,FROM_LOT
	            ,FROM_STOCKID
	            ,FROM_STOCKGRADE
	            ,FROM_STOCKTYPE
	            ,FROM_ORDERQTY
	            ,FROM_UOM
	            ,TO_DCCODE
	            ,TO_STORERKEY
	            ,TO_ORGANIZE
	            ,TO_AREA
	            ,TO_SKU
	            ,TO_LOC
	            ,TO_LOT
	            ,TO_STOCKID
	            ,TO_STOCKGRADE
	            ,TO_STOCKTYPE
	            ,TO_ORDERQTY
	            ,TO_UOM
	            ,ETCQTY1
	            ,ETCQTY2
	            ,SRCSERIALKEY1
	            ,FROM_BUNJA
	            ,FROM_BUNMO
	            ,STATUS
	            )
	        VALUES 
	            (
	            'OM_TEMPORDER'
	            ,#{item.gUserId}
	            ,#{item.gSpid}
	            ,#{item.gUserId}
	            ,#{item.gUserId}
	            ,#{item.fromDcCode}
	            ,#{item.gStorerkey}
	            ,#{item.fromOrganize}
	            ,#{item.area}
	            ,#{item.sku}
	            ,'' /* FROM_LOC */
	            ,'' /* FROM_LOT */
	            ,'STD' /* FROM_STOCKID */
	            ,'STD' /* FROM_STOCKGRADE */            	
	            ,'' /* FROM_STOCKTYPE */            	
	            ,#{item.orderQty}
	            ,#{item.uom}
	            ,#{item.dcCode}
	            ,#{item.gStorerkey}
	            ,#{item.organize}
	            ,#{item.area}
	            ,#{item.sku}
	            ,'' /* TO_LOC */
	            ,'' /* TO_LOT */
	            ,'STD' /* TO_STOCKID */
	            ,'STD' /* TO_STOCKGRADE */
	            ,'' /* TO_STOCKTYPE */
	            ,#{item.orderQty}
	            ,#{item.uom}
	            ,0
	            ,0
	            ,NVL(#{item.modSlipDt}, TO_CHAR(SYSDATE, 'YYYYMMDD'))
	            ,(SELECT NVL(BUNJA, 1) FROM MS_UOM WHERE STORERKEY = 'FW00' AND SKU = #{item.sku} AND UOM = #{item.purchaseUom})
	            ,(SELECT NVL(BUNMO, 1) FROM MS_UOM WHERE STORERKEY = 'FW00' AND SKU = #{item.sku} AND UOM = #{item.purchaseUom})
	            ,'00'
	            )
	    </foreach>
	    ; END;
	</insert>
    
    <update id="updatePoHoldYn">
		/* [omPurchaseStorageAutoTotalService.sqlx][omPurchaseStorageAutoTotalService.updatePoHoldYn] */
		UPDATE ST_STOCK_SERIALINFODETAIL 
        SET PO_HOLD_YN = #{poHoldYn}
        WHERE STOCKID = #{stockid} AND SKU = #{sku}
	</update>
</mapper>