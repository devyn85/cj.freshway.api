    <select id="getPopupDocumentInfoDetail" resultType="IbExpenseDoucmentDetailPopupResDto">
        SELECT     /* [ibExpenseService.sqlx][getPopupDocumentInfoDetail][비용기표 Popup 상세 조회][sunho.kim][2025.08.04] */
              T.*
            , ROUND(T.KG_CAL / SUM(T.KG_CAL) OVER() * 100,2)                         AS RATE_QTY                    /* KG비중 */
            , ROUND(SUM(T.SUPPLY_PRICE) OVER() * (T.KG_CAL / SUM(T.KG_CAL) OVER()))  AS DIS_COST                    /* KG 비용분배 */           
        FROM( 
            SELECT 
                  <include refid="popupDocumentInfoDetailColumnList"/>
                 , SK.QTYPERBOX                                                                                  AS QTYPERBOX               /* 박스당수량 */                                  
                 , SK.NETWEIGHT                                                                                  AS NETWEIGHT               /* 순중량 */
                 , SK.BASEUOM                                                                                    AS BASEUOM                 /* 기본단위 */  
                 , SK.PURCHASEUOM                                                                                AS PURCHASEUOM             /* 구매단위 */ 
                 , SK.RETURNUOM                                                                                  AS RETURNUOM               /* 반품단위 */
                 , ES.QUANTITY                                                                                   AS QUANTITY                /* 직송수량 */
                 , ROUND((SELECT FN_CONV_UOM(SK.STORERKEY, SK.SKU, SK.BASEUOM, 'KG', ES.QUANTITY) FROM DUAL),2)  AS KG_CAL                  /* 직송단위 환산 [KG] */
                 , '10000'                                                                                       AS SUPPLY_PRICE_NEW        /* SUPPLY_PRICE_NEW */
                 , TRUNC(10000 * ED.TAX_RATE/100)                                                                AS TAX_AMOUNT_NEW          /* TAX_AMOUNT_NEW */
                 , CASE WHEN ED.TAX_FLAG='Y' THEN 10000 + TRUNC( 10000 * ED.TAX_RATE /100) ELSE 0 END            AS AMOUNT_NEW              /* AMOUNT_NEW */
                 , CASE WHEN SK.BASEUOM='EA' THEN ( 1 * SK.NETWEIGHT )
                        WHEN SK.BASEUOM='BOX' THEN ( 1 * SK.QTYPERBOX * SK.NETWEIGHT ) ELSE 1 END KG_CH
                 , FN_DESCR_ORGANIZE(ED.DCCODE, ED.ORGANIZE)                                                     AS ORGANIZENAME            /* 창고명 */
                 , SK.DESCRIPTION                                                                                AS SKUNAME                 /* 품목명 */
                 , CD1.BASEDESCR                                                                                 AS STORAGETYPENAME         /* 저장조건명 */                 
                 , ''                                                                                            AS ORDERTYPENAME           /* 주문유형명 */            
                 , DM_DOCUMENT_H.TO_CUSTKEY                                                                      AS TO_CUSTKEY              /* 관리처코드 */   
                 , DM_DOCUMENT_H.TO_CUSTNAME                                                                     AS TO_CUSTNAME             /* 관리처명 */
                 , ES.CONVSERIALNO                                                                               AS CONVSERIALNO            /* B/L번호 */
            FROM IB_EXPENSE_DISTRIBUTION ED
            LEFT OUTER JOIN MS_SKU SK 
                ON  ED.ITEM_CODE = SK.SKU 
                AND ED.STORERKEY = SK.STORERKEY
            LEFT OUTER JOIN ST_EXDCSTORAGE ES 
                ON  ED.DOCUMENT_SN = ES.SERIALKEY 
                AND ES.YYYYMM      = ED.ATTRIBUTE3 
                AND ES.ORGANIZE    = ED.ORGANIZE
            LEFT OUTER JOIN DM_DOCUMENT_H DM_DOCUMENT_H
                ON  DM_DOCUMENT_H.STORERKEY  = ES.STORERKEY
                AND DM_DOCUMENT_H.DCCODE     = ES.DCCODE
                AND DM_DOCUMENT_H.ORGANIZE   = ES.ORGANIZE
                AND DM_DOCUMENT_H.DOCNO      = ES.DOCNO
                AND DM_DOCUMENT_H.DOCTYPE    = 'WD'
                
            LEFT OUTER JOIN CM_CODE_STORER CD1
                ON  CD1.STORERKEY = SK.STORERKEY
                AND CD1.CODELIST  = 'STORAGETYPE'   
                AND CD1.BASECODE  = SK.STORAGETYPE        
                
            WHERE  EXPENSE_SN = #{serialkey}
         ) T
        ORDER BY T.DOCUMENT_TYPE_CODE
               , T.ACCOUNT_DETAIL_CODE
               , T.SERIALKEY 
    </select>
    
    <select id="getPopupApprovalExpenseInfo" resultType="IbExpenseDoucmentHeaderPopupResDto">
        SELECT    /* [ibExpenseService.sqlx][getPopupApprovalExpenseInfo][비용기표 Popup 내부결재 Expense 조회][sunho.kim][2025.08.04] */
               SERIALKEY                                                            /* 데이터번호 */
              ,KEY_NO                                                               /* 문서번호 */         
              ,ADJUSTMENT_SUPPLIER_CODE                                             /* 비용 발생업체 코드 */      
              ,ADJUSTMENT_SUPPLIER_NAME                                             /* 비용 발생 업체 명칭 */    
              ,LTRIM(TO_CHAR(NVL(AMOUNT,0),'9,999,999,999,990.99')) AS AMOUNT       /* 금액 */
              ,AMOUNT_UNIT                                                          /* 금액 단위 */
              ,SUMMARY                                                              /* 적요 사항 */    
              ,TRANSACTION_CD                                                       /* 트랜잭션코드(OB/FI)  */ 
        FROM   IB_EXPENSE EX
        WHERE  SERIALKEY = #{serialkey}
    </select>
    
    <select id="getPopupSupplierInfo" resultType="Hmap">
        SELECT    /* [ibExpenseService.sqlx][getPopupSupplierInfo][비용기표 Popup SUPPLILER 조회][sunho.kim][2025.08.04] */
               CUSTKEY                   AS CODE                                    /* 고객사코드 */ 
             , DESCRIPTION               AS NAME                                    /* 고객사명 */
             , VATNO                     AS VATNO                                   /* 사업자등록번호 */
             , OTHER01                   AS PAYMENT_TERM                            /* 결제조건 */  
             , CD1.BASEDESCR             AS PAYMENT_TERM_NAME                       /* 결제조건명 */
        FROM   MS_CUST 
        
        LEFT OUTER JOIN CM_CODE_STORER CD1
                    ON CD1.STORERKEY = MS_CUST.STORERKEY
                   AND CD1.CODELIST  = 'PAYMENT_TERM'   
                   AND CD1.BASECODE  = MS_CUST.OTHER01
                   
        WHERE  STORERKEY = #{gStorerkey}
            AND    CUSTTYPE  = 'P'
            AND    DEL_YN    = 'N'
        <if test="codenm != null and codenm != ''">
            AND   (CUSTKEY     LIKE #{codenm}||'%'
                OR DESCRIPTION LIKE #{codenm}||'%')
        </if>
        <if test="code != null and code != ''">
            AND    CUSTKEY     LIKE #{code}||'%'
        </if>
        <if test="name != null and name != ''">
            AND    DESCRIPTION LIKE #{name}||'%'
        </if>
    </select>
    
    <select id="getApprStatus" resultType="IbExpenseDoucmentHeaderPopupResDto">
        SELECT   /* [ibExpenseService.sqlx][getApprStatus][비용기표 내부결재 상태 조회][sunho.kim][2025.08.04] */
               STATUS                         AS STATUS                         /* 상태코드 */
             , (SELECT APPROVALSTATUS
                 FROM   AJ_APPRREQUEST APR
                 WHERE  APR.SLIPNO  = IB_EXPENSE.SERIALKEY
                   AND  APR.DCCODE  = IB_EXPENSE.DCCODE
                   AND  APR.DOCTYPE = 'IBEXPENSE'
                   AND  APR.APPROVALNO != 'STD'  
                 ORDER BY ADDDATE DESC
                 FETCH FIRST 1 ROWS ONLY )    AS INTERNAL_APPR_STATUS           /* 내부결재상태 */
             , IF_STATUS                      AS IF_STATUS                      /* IF 상태 */
             , APPR_STATUS                    AS APPR_STATUS                    /* 결재상태 */
             , KEY_NO                         AS KEY_NO                         /* 문서번호 */
             , IF_DOC_NO                      AS IF_DOC_NO                      /* IF 문서번호 */
             , CASE WHEN IF_ID IN ('SCM0480') 
                     THEN (SELECT FI_IF_STATUS                                                
                           FROM   IF_IB_STOCKETC_H
                           WHERE  ZINVOICE = IB_EXPENSE.IF_DOC_NO
                           AND    ROWNUM   = 1)
                     WHEN IF_ID = 'SCM0470' 
                     THEN (SELECT FI_IF_STATUS                                                
                           FROM   IF_IB_STOCKSKU_H
                           WHERE  ZINVOICE = IB_EXPENSE.IF_DOC_NO
                           AND    ROWNUM   = 1)
                     ELSE ''
                END                           AS FI_IF_STATUS                   /* Posting 상태 */
             , IF_ID                          AS IF_ID                          /* IF ID */
             , (SELECT H.TPL_TYPE
                 FROM IB_EXPENSE  A
                 INNER JOIN ST_EXDCSTORAGE_EXPENSE B  
                    ON B.WORK_EXP_NO = A.KEY_NO
                 INNER JOIN ST_EXDCSTORAGE C 
                    ON C.SERIALKEY   = B.EXDCSTORAGEKEY   
                 INNER JOIN DM_DOCUMENT_H H 
                    ON H.DCCODE      = C.DCCODE
                   AND H.ORGANIZE    = C.ORGANIZE    
                   AND H.DOCNO       = C.DOCNO
                   AND H.DEL_YN      = 'N'
                 WHERE A.SERIALKEY   = IB_EXPENSE.SERIALKEY
                 FETCH FIRST 1 ROWS ONLY)     AS TPL_TYPE                       /* 3자물류유형코드 */
        FROM   IB_EXPENSE 
        WHERE  SERIALKEY = #{serialkey}
    </select>
    
    <select id="getExdcClose" resultType="String">
        SELECT   /* [ibExpenseService.sqlx][getExdcClose][비용기표 정산마감 상태 조회][sunho.kim][2025.08.04] */
               NVL(MAX(IB_EXDCCLOSE.CLOSEYN),'N')   AS CLOSEYN                  /* 정산마감여부 */
        FROM   IB_EXPENSE
        JOIN   IB_EXPENSE_DISTRIBUTION
        ON     IB_EXPENSE_DISTRIBUTION.EXPENSE_SN = IB_EXPENSE.SERIALKEY
        JOIN   ST_EXDCSTORAGE
        ON     ST_EXDCSTORAGE.SERIALKEY           = IB_EXPENSE_DISTRIBUTION.DOCUMENT_SN
        JOIN   IB_EXDCCLOSE
        ON     IB_EXDCCLOSE.YYYYMM                = ST_EXDCSTORAGE.YYYYMM
        AND    IB_EXDCCLOSE.STORAGELOCATION       = RIGHT(ST_EXDCSTORAGE.ORGANIZE,4)
        AND    IB_EXDCCLOSE.CLOSEYN               = 'Y'
        WHERE  IB_EXPENSE.SERIALKEY               = #{serialkey}
    </select>
    
    <select id="getIbClose" resultType="String">
        SELECT   /* [ibExpenseService.sqlx][getIbClose][마감 상태 조회][sunho.kim][2025.08.04] */
            CASE WHEN COUNT(1) = 1 THEN 'Y' ELSE 'N' END  AS CLOSEYN                  /* 정산마감여부 */
        FROM   IB_CLOSE
        WHERE CLOSEDT = #{yyyymm}
          AND DCCODE  = '2170'
          AND DEL_YN  = 'N'
    </select>
    
    <select id="getDummyLineNo" resultType="long">
        SELECT  /* [ibExpenseService.sqlx][getDummyLineNo][비용기표 내부결재 DummyLineNo 채번][sunho.kim][2025.08.04] */
               SEQ_IB_APPROVAL_DUMMY_LINE_NO.NEXTVAL AS DUMMY_LINE_NO
        FROM   DUAL
    </select>
    
    <select id="getPopupApprovalUserInfo" resultType="IbExpenseApprovalUserPopupResDto">
        SELECT  /* [ibExpenseService.sqlx][getPopupApprovalUserInfo][비용기표 Popup ApprovalRequest UserInfo 조회][sunho.kim][2025.08.04] */        
            A.*
            ,DECODE(REQUESTTYPE, '0', '기안', '2', '결재', REQUESTTYPE) REQUESTTYPENAME
            ,
                    DECODE(REQUESTTYPE, '0', '기안', '2', '결재', REQUESTTYPE) || ' / ' ||
                    USER_ID || ' / ' ||
                    USER_NM || ' ' ||
                    STORERNM || '/' ||
                    DEPTNM                                             AS DESCRIPTION               /* 결재선 */
        FROM (    
            SELECT  /* [ibExpenseService.sqlx][getPopupApprovalUserInfo][비용기표 Popup ApprovalRequest UserInfo 조회][sunho.kim][2025.08.04] */
                   '0'                                                 AS REQUESTTYPE               /* 0 : 기안, 2 : 결재 */
                 , USER_ID                                             AS USER_ID                   /* 사용자ID */
                 , USER_NM                                             AS USER_NM                   /* 사용자명 */
                 , ''                                                  AS DUTY                      /* 직책 */
                 , NVL((SELECT CM_STORER.DESCRIPTION 
                        FROM   CM_STORER
                        WHERE  CM_STORER.STORERKEY = #{gStorerkey})
                       ,FRAMEONE_USER.DEF_STORERKEY
                      )                                                AS STORERNM                  /* 고객사명 */
                 , NVL((SELECT FRAMEONE_EMP.DEPTHR_NM
                        FROM   FRAMEONE_EMP
                        WHERE  FRAMEONE_EMP.COM_CD = FRAMEONE_EMP.COM_CD
                        AND    FRAMEONE_EMP.EMP_NO = FRAMEONE_USER.EMP_NO
                        AND    ROWNUM = 1)
                       ,NVL((SELECT CM_STORER.DESCRIPTION 
                             FROM   CM_STORER
                             WHERE  CM_STORER.STORERKEY = #{gStorerkey})
                            ,FRAMEONE_USER.DEF_STORERKEY)
                      )                                                AS DEPTNM                    /* 부서명 */
                 ,(SELECT MAIL_ID
                   FROM   FRAMEONE_EMP
                   WHERE  FRAMEONE_EMP.COM_CD = FRAMEONE_EMP.COM_CD
                   AND    FRAMEONE_EMP.EMP_NO = FRAMEONE_USER.EMP_NO
                   AND    ROWNUM = 1)                                  AS EMAIL                     /* 이메일 */             
            FROM   FRAMEONE_USER
            WHERE  USER_ID = #{gUserId}
        <if test="requesttype != 0"> 
                AND 1=2 
        </if>
        <if test="requesttype == 0"> 
            UNION ALL
            SELECT 
                   '2'                                                  AS REQUESTTYPE              /* 0 : 기안, 2 : 결재 */
                  ,PERSON_LIST.USER_ID                                  AS USER_ID                  /* 사용자ID */
                  ,PERSON_LIST.USER_NM                                  AS USER_NM                  /* 사용자명 */
                  ,''                                                   AS DUTY                     /* 직책 */
                  ,NVL((SELECT CM_STORER.DESCRIPTION
                       FROM   CM_STORER
                       WHERE  cm_storer.storerkey = #{gStorerkey}
                       )
                      ,PERSON_LIST.DEF_STORERKEY)                       AS STORERNM                 /* 고객사명 */
                  ,NVL((SELECT FRAMEONE_EMP.DEPTHR_NM
                       FROM   FRAMEONE_EMP
                       WHERE  FRAMEONE_EMP.COM_CD = FRAMEONE_EMP.COM_CD
                       AND    FRAMEONE_EMP.EMP_NO = PERSON_LIST.EMP_NO
                       AND    ROWNUM = 1)
                      ,NVL((SELECT CM_STORER.DESCRIPTION
                           FROM   CM_STORER
                           WHERE  CM_STORER.STORERKEY = #{gStorerkey}
                           )
                          ,PERSON_LIST.DEF_STORERKEY))                  AS DEPTNM                   /* 부서명 */
                  ,(SELECT MAIL_ID
                    FROM   FRAMEONE_EMP
                    WHERE  FRAMEONE_EMP.COM_CD = FRAMEONE_EMP.COM_CD
                    AND    FRAMEONE_EMP.EMP_NO = PERSON_LIST.EMP_NO
                    AND    ROWNUM = 1)                                  AS EMAIL                    /* 이메일 */ 
            FROM   (SELECT TG_LIST.USER_ID
                      ,TG_LIST.USER_NM
                      ,TG_LIST.EMP_NO  
                      ,TG_LIST.DEF_STORERKEY
                    FROM  ( SELECT USER_ID
                              ,USER_NM
                              ,EMP_NO   
                              ,DEF_STORERKEY   
                        FROM  FRAMEONE_USER 
                        WHERE FRAMEONE_USER.USER_ID IN (SELECT MAX(IB_APPROVAL_LINE.PERSON_ID) KEEP(DENSE_RANK FIRST ORDER BY IB_APPROVAL_LINE.APPR_SN DESC) AS PERSON_ID
                                                        FROM   IB_APPROVAL_LINE 
                                                        WHERE  IB_APPROVAL_LINE.ADDWHO = #{gUserId}
                                                        AND    IB_APPROVAL_LINE.LINE_TYPE = '2')
                        AND   FRAMEONE_USER.DEL_YN = 'N'
                        UNION ALL
                        SELECT USER_ID
                              ,USER_NM
                              ,EMP_NO  
                              ,DEF_STORERKEY    
                        FROM   FRAMEONE_USER
                        WHERE  1 = 1
                        AND    USER_ID IN (SELECT BASECODE
                                           FROM   CM_CODE
                                           WHERE  STORERKEY = #{gStorerkey}
                                           AND    CODELIST  = 'APPROVALUSER'
                                           AND    DEL_YN    = 'N')
                        AND    USER_ID = (SELECT MAX(BASECODE) KEEP(DENSE_RANK FIRST ORDER BY SEQNO)
                                          FROM   CM_CODE
                                          WHERE  storerkey = #{gStorerkey}
                                          AND    CODELIST  = 'APPROVALUSER'
                                          AND    DEL_YN    = 'N')) TG_LIST
                WHERE ROWNUM = 1) PERSON_LIST
        </if>
        <if test="requesttype == 1"> 
            UNION ALL
            SELECT 
                   '2'                                                 AS REQUESTTYPE               /* 0 : 기안, 2 : 결재 */
                 , USER_ID                                             AS USER_ID                   /* 사용자ID */
                 , USER_NM                                             AS USER_NM                   /* 사용자명 */
                 , ''                                                  AS DUTY                      /* 직책 */
                 , NVL((SELECT CM_STORER.DESCRIPTION 
                        FROM   CM_STORER
                        WHERE  CM_STORER.STORERKEY = #{gStorerkey})
                       ,FRAMEONE_USER.DEF_STORERKEY
                      )                                                AS STORERNM                  /* 고객사명 */
                 , NVL((SELECT FRAMEONE_EMP.DEPTHR_NM
                        FROM   FRAMEONE_EMP
                        WHERE  FRAMEONE_EMP.COM_CD = FRAMEONE_EMP.COM_CD
                        AND    FRAMEONE_EMP.EMP_NO = FRAMEONE_USER.EMP_NO
                        AND    ROWNUM = 1)
                       ,NVL((SELECT CM_STORER.DESCRIPTION 
                             FROM   CM_STORER
                             WHERE  CM_STORER.STORERKEY = #{gStorerkey})
                            ,FRAMEONE_USER.DEF_STORERKEY)
                      )                                                AS DEPTNM                    /* 부서명 */
                 ,(SELECT MAIL_ID
                   FROM   FRAMEONE_EMP
                   WHERE  FRAMEONE_EMP.COM_CD = FRAMEONE_EMP.COM_CD
                   AND    FRAMEONE_EMP.EMP_NO = FRAMEONE_USER.EMP_NO
                   AND    ROWNUM = 1)                                  AS EMAIL                     /* 이메일 */
            FROM   FRAMEONE_USER
            WHERE  1=1
                AND    USER_ID IN (SELECT BASECODE
                               FROM   CM_CODE
                               WHERE  STORERKEY = #{gStorerkey}
                               AND    CODELIST  = 'APPROVALUSER'
                               AND    DEL_YN    = 'N'
                              )
            <if test="useridnm != null and useridnm != ''">
                AND   (USER_ID LIKE #{useridnm}||'%'
                    OR USER_NM LIKE #{useridnm}||'%')
            </if>
            <if test="userid != null and userid != ''">
                AND    USER_ID LIKE #{userid}||'%'
            </if>
            <if test="usernm != null and usernm != ''">
                AND    USER_NM LIKE #{usernm}||'%'
            </if>
            <if test="userdept != null and userdept != ''">
                AND    EXISTS (SELECT 1 
                               FROM   FRAMEONE_EMP
                               WHERE  DEPTHR_NM LIKE #{userdept}||'%'
                               AND    COM_CD = COM_CD
                               AND    EMP_NO = FRAMEONE_USER.EMP_NO)
            </if>
        </if>
        ) A
        
    </select>
    
    <select id="getPopupUploadFileList" resultType="IbExpenseFilePopupResDto">
        SELECT  /* [ibExpenseService.sqlx][getPopupUploadFileList][비용기표 Popup Upload File List 조회][sunho.kim][2025.08.04] */
                SERIALKEY              AS SERIALKEY             /* 일련번호 */
               ,DOC_ID                 AS DOC_ID                /* 문서ID */             
               ,DOC_TYPE               AS DOC_TYPE              /* 문문서유형코드서타입 */       
               ,DOC_NAME               AS DOC_NAME              /* 문서구분명 */          
               ,FILE_NAME              AS FILE_NM               /* 파일명 */         
               ,FILE_EXTENSION         AS ATTCH_FILE_EXT_NM     /* 파일확장자 */                   
               ,FILE_LOCATION          AS FILE_LOCATION         /* 업로드 대상 파일 경로 */    
               ,FILE_SIZE_BYTES        AS ATTCH_FILE_SZ         /* 파일크기(byte) */                  
               ,TRANS_FILE_NAME        AS ATTCH_FILE_NM         /* 채번 변환된 파일명 */
               ,UPLOAD_HASH_ID         AS UPLOAD_HASH_ID        /* 서버전송 후 리턴받은 HASH_ID(2015.4.21 기준 미사용) */    
               ,UPLOAD_RES_DOC_ID      AS UPLOAD_RES_DOC_ID     /* 서버전송 후 리턴받은 고유파일ID(HASH_ID + TRNAS_FILE_NAME) */
               ,UPLOAD_FILE_NAME       AS UPLOAD_FILE_NAME      /* 변환 후 업로드된 파일명 */
               ,UPLOAD_WORKPLACE_ID    AS UPLOAD_WORKPLACE_ID   /* 업무모듈별 WORKPLACE ID */
               ,UPLOAD_LOCATION        AS UPLOAD_LOCATION       /* 업로드된 서버 위치(2015.04.21 기준 미사용) */ 
               ,DOWNLOAD_COUNT         AS DOWNLOAD_COUNT        /* 다운로드 횟수 */  
               ,FILE_TYPE              AS FILE_TYPE             /* FILE_TYPE */  
               ,STATUS                 AS STATUS                /* 상태 */       
               ,ADDWHO                 AS ADDWHO                /* 최초등록자 */       
               ,ADDDATE                AS ADDDATE               /* 최초등록시간 */           
               ,EDITWHO                AS EDITWHO               /* 최종변경자 */  
               ,EDITDATE               AS EDITDATE              /* 최종변경시간 */
        FROM    IB_EXPENSE_HTTP_DOC_ATTACH
        WHERE   DOC_NAME = 'IMP_EXPENSE'
        AND     DOC_ID   = #{serialkey}
        AND     STATUS   = 'Y'
    </select>
    
    <select id="getPopupIFStatus" resultType="IbExpenseIfStatusPopupResDto">
        SELECT  /* [ibExpenseService.sqlx][getPopupIFStatus][비용기표 Popup IFStatus 조회][sunho.kim][2025.08.04] */
               'Purchase Expense'                                           AS TRANSACTION_CD          /* 트랜잭션코드 */
              ,IF_IB_STOCKETC_H.ZINVOICE                                    AS ZINVOICE                /* 송장관리번호 */
              ,TO_NUMBER(IF_IB_STOCKETC_H.ZSEQ)                             AS ZSEQ                    /* 순번(처리횟수) */
              ,IF_IB_STOCKETC_H.ZRETURN                                     AS ZRETURN                 /* 생성문서번호 */
              ,IB_EXPENSE.IF_ID                                             AS IF_ID                   /* 인터페이스ID */
              ,CD1.BASEDESCR                                                AS FI_IF_STATUS            /* 전송상태 */
              ,IF_IB_STOCKETC_H.XMSGS                                       AS XMSGS                   /* 에러메세지 */
              ,TO_CHAR(IF_IB_STOCKETC_H.EDITDATE,'YYYY-MM-DD HH24:MI:SS')   AS EDITDATE                /* 최종변경시간 */              
              ,(SELECT MAX(USER_NM)                                               
                FROM   FRAMEONE_USER                                              
                WHERE  USER_ID = IF_IB_STOCKETC_H.EDITWHO)                  AS EDITWHO                 /* 최종변경자 */
        FROM   IB_EXPENSE
        JOIN   IF_IB_STOCKETC_H
            ON IF_IB_STOCKETC_H.EXPENSE_SN = IB_EXPENSE.SERIALKEY
        LEFT OUTER JOIN CM_CODE_STORER CD1
            ON CD1.STORERKEY               = IB_EXPENSE.STORERKEY
           AND CD1.CODELIST                = 'STATUS_FI_IF'   
           AND CD1.BASECODE                = IF_IB_STOCKETC_H.FI_IF_STATUS        
        WHERE  IB_EXPENSE.SERIALKEY        = #{serialkey}
        UNION ALL
        SELECT 'Purchase Expense'                                           AS TRANSACTION_CD          /* 트랜잭션코드 */
              ,IF_IB_STOCKSKU_H.ZINVOICE                                    AS ZINVOICE                /* 송장관리번호 */
              ,IF_IB_STOCKSKU_H.ZSEQ                                        AS ZSEQ                    /* 순번(처리횟수) */
              ,IF_IB_STOCKSKU_H.ZRETURN                                     AS ZRETURN                 /* 생성문서번호 */
              ,IB_EXPENSE.IF_ID                                             AS IF_ID                   /* 인터페이스ID */
              ,CD1.BASEDESCR                                                AS FI_IF_STATUS            /* 전송상태 */  
              ,IF_IB_STOCKSKU_H.XMSGS                                       AS XMSGS                   /* 에러메세지 */
              ,TO_CHAR(IF_IB_STOCKSKU_H.EDITDATE,'YYYY-MM-DD HH24:MI:SS')   AS EDITDATE                /* 최종변경시간 */ 
              ,(SELECT MAX(USER_NM)                                               
                FROM   FRAMEONE_USER                                              
                WHERE  USER_ID = IF_IB_STOCKSKU_H.EDITWHO)                  AS EDITWHO                 /* 최종변경자 */
        FROM   IB_EXPENSE
        JOIN   IF_IB_STOCKSKU_H
            ON IF_IB_STOCKSKU_H.EXPENSE_SN = IB_EXPENSE.SERIALKEY
        LEFT OUTER JOIN CM_CODE_STORER CD1
            ON CD1.STORERKEY               = IB_EXPENSE.STORERKEY
           AND CD1.CODELIST                = 'STATUS_FI_IF'   
           AND CD1.BASECODE                = IF_IB_STOCKSKU_H.FI_IF_STATUS
        WHERE  IB_EXPENSE.SERIALKEY        = #{serialkey}
        ORDER BY 
               ZINVOICE
             , ZSEQ
    </select>
    
    <select id="getElecTaxRead" resultType="IbExpenseElecTaxPopupResDto">
    <!-- deprecated -->>
        SELECT  /* [ibExpenseService.sqlx][getElecTaxRead][전자세금계산서 dataset정보 조회][sunho.kim][2025.08.04] */
                '0'                    AS CHECKYN
               ,''                     AS BUKRS             /* 회사코드 */
               ,''                     AS ISSUE_ID          /* 세금계산서 승인번호 */  
               ,''                     AS INV_SEQ           /* 세금계산서 일련번호(년월일+회사코드+12) 내부사용 */   
               ,''                     AS CHARGETOTAL       /* 총 공급가 */
               ,''                     AS TAXTOTAL          /* 총 세액 */
               ,''                     AS GRANDTOTAL        /* 총액(공급가액+세액) */ 
               ,''                     AS BP_ADDR           /* 수탁사업자 주소 */
               ,''                     AS BP_REPRES         /* 수탁사업자 대표자명 */
               ,''                     AS BP_DEPTNAME       /* 수탁사업자 담당부서 */
               ,''                     AS BP_PERSNAME       /* 수탁사업자 담당자명 */
               ,''                     AS ISSUE_DT          /* 전자세금계산서 발행일시 */
               ,''                     AS ISSUE_DATE        /* 전자세금계산서 작성일자 */
               ,''                     AS AEDAT             /* 변경일 */
               ,''                     AS INV_SIGN          /* 역발행여부 */
        FROM    DUAL
    </select>
    
    <select id="getIF_IB_STOCKETC_H" resultType="IfIbStocketcHDto">
        SELECT  /* [ibExpenseService.sqlx][getIF_IB_STOCKETC_H][I/F 데이터 조회(IF_IB_STOCKETC_H)][sunho.kim][2025.08.04] */
                SERIALKEY
              , ZINVOICE
              , ZSEQ
              , XRECH
              , ZLAST
              , BUKRS
              , LIFNR
              , EMPFB
              , TO_CHAR(BLDAT, 'YYYYMMDD') AS BLDAT
              , TO_CHAR(BUDAT, 'YYYYMMDD') AS BUDAT
              , WAERS
              , MWSKZ1
              , ZTERM
              , TO_CHAR(ZFBDT, 'YYYYMMDD') AS ZFBDT
              , TO_CHAR(RMWWR ) AS RMWWR 
              , TO_CHAR(WMWST1) AS WMWST1
              , KIDNO
              , BKTXT
              , ZGUBUN
              , ZBILLNO
              , CARD_NO
              , APPR_DATE
              , APPR_DOCU
              , CNCL_FLAG
              , SELL_DOCU
              , ZTEXT1
              , ZTEXT2
              , ZTEXT3
              , ZTEXT4
              , ZTEXT5
              , XDATS
              , XTIMS
              , XUSER
              , XSTAT
              , XMSGS
              , ZRETURN
              , ZRE_BELNR
              , EXPENSE_SN
              , ADDDATE
              , EDITDATE
              , ADDWHO
              , EDITWHO
              , FI_IF_STATUS
              , (SELECT IF_ID
                 FROM   IB_EXPENSE
                 WHERE  SERIALKEY = IF_IB_STOCKETC_H.EXPENSE_SN) AS IF_ID
        FROM    IF_IB_STOCKETC_H
        WHERE   EXPENSE_SN   = #{serialkey}
        AND     ZINVOICE     = (SELECT IF_DOC_NO 
                                FROM   IB_EXPENSE
                                WHERE  SERIALKEY = #{serialkey})
        AND     FI_IF_STATUS = DECODE(#{ifType},'POSTING','SND','POSTING_CANCEL','CNF','X')
        ORDER BY
                TO_NUMBER(ZSEQ)             
    </select>
    
