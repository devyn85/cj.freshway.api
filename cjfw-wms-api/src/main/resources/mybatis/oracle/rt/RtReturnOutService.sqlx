<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="rtReturnOutService">
    <!-- 협력사반품지시 그리드 조회 (Header) -->
    <select id="getMasterList" resultType="cjfw.wms.rt.dto.RtReturnOutResDto">
        SELECT /* [rtReturnOutService.sqlx][rtReturnOutService.getMasterList][협력사반품지시] */
        '0'                                                                                                                       AS CHECKYN
        ,ST_STOCK.DCCODE                                                                                                          AS DCCODE
        ,CM_DC.DCNAME																									    		AS DCNAME
        ,ST_STOCK.ORGANIZE                                                                                                        AS ORGANIZE
        ,ST_STOCK.STORERKEY 																										AS STORERKEY
        ,ST_STOCK.ORGANIZE 																										AS ORGANIZE
        ,ST_STOCK.AREA																											AS AREA
        ,MS_CUST.CUSTKEY                                                                                                  		AS CUSTKEY
        ,MS_CUST.DESCRIPTION                                                                                                 		AS CUSTNAME
        ,ST_STOCK.SKU                                                                                                             AS SKU
        ,MS_SKU.DESCRIPTION                                                                                                  		AS SKUNAME
        ,CASE WHEN ST_STOCK.DCCODE IN ('1000','2170') THEN SUBSTR(ST_STOCK.ORGANIZE, INSTR(ST_STOCK.ORGANIZE,'-')+1)
        ELSE ST_STOCK.DCCODE
        END																														AS PALNT
        ,MS_PLANT.DESCRIPTION                                                                                                  	AS PLANT_DESCR
        ,FN_CODEDESCR(MS_SKU.STORERKEY, 'STORAGETYPE', MS_SKU.STORAGETYPE)                                                   		AS STORAGETYPE
        ,MS_SKU.SERIALYN																											AS SERIALYN
        ,FN_CODEDESCR(MS_SKU.STORERKEY, 'SERIALYN', MS_SKU.SERIALYN)                                                         		AS SERIALYNNAME
        ,NULL                                                                                                                        AS WD_QTY
        ,ST_STOCK.OPENQTY                                                                                                    		AS QTY
        ,ST_STOCK.UOM                                                                                                        		AS UOM
        ,ST_STOCK.LOC                                                                                                             AS LOC
        ,ST_STOCK.LOT                                                                                                        		AS LOT
        ,ST_STOCK.STOCKTYPE																										AS STOCKTYPE
        ,FN_CODEDESCR(ST_STOCK.STORERKEY, 'STOCKTYPE', ST_STOCK.STOCKTYPE)                                                  		AS STOCKTYPENAME
        ,ST_STOCK.STOCKGRADE																										AS STOCKGRADE
        ,FN_CODEDESCR(ST_STOCK.STORERKEY, 'STOCKGRADE', ST_STOCK.STOCKGRADE)                                                 		AS STOCKGRADENAME
        ,''                                                                                                                       AS REASONCODE
        ,''                                                                                                                       AS OTHER03
        ,''                                                                                                                       AS OTHER04
        ,''                                                                                                                       AS OTHER01
        ,''                                                                                                                       AS OTHER05
        ,''                                                                                                                       AS BLNGDEPTCD
        ,CM_LOT.LOTTABLE01				                                                                                        AS LOTTABLE01
        , NVL(CASE WHEN MS_SKU.DURATIONTYPE = '1' AND REGEXP_LIKE(CM_LOT.LOTTABLE01, '^[0-9]{8}$')
        THEN TO_CHAR(TO_DATE(CM_LOT.LOTTABLE01,'YYYYMMDD') - (MS_SKU.DURATION - 1), 'YYYYMMDD')
        ELSE CM_LOT.LOTTABLE01
        END,'STD') AS LOT_MANUFACTURE                    /** 제조 */
        , NVL(CASE WHEN MS_SKU.DURATIONTYPE != '1' AND REGEXP_LIKE(CM_LOT.LOTTABLE01, '^[0-9]{8}$')
        THEN TO_CHAR(TO_DATE(CM_LOT.LOTTABLE01,'YYYYMMDD') + (MS_SKU.DURATION - 1), 'YYYYMMDD')
        ELSE CM_LOT.LOTTABLE01
        END,'STD') AS LOT_EXPIRE                         /** 유통 */
        ,FN_LOTDURATION(MS_SKU.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, CM_LOT.LOTTABLE01, 'N0') ||'/'|| MS_SKU.DURATION   AS DURATION_TERM
        ,ST_STOCK.STOCKID																											AS STOCKID
        ,ST_STOCK.STOCKID																											AS BARCODE
        ,ST_SNINFO.SERIALNO                                                                                             		AS SERIALNO
        ,ST_SNINFO.CONVSERIALNO	                                                                                     		AS CONVSERIALNO
        ,ST_SNINFO.SERIALLEVEL                                                                                          		AS SERIALLEVEL
        ,ST_SNINFO.SERIALTYPE                                                                                           		AS SERIALTYPE
        ,ST_SNINFO.FACTORYNAME                                                                                          		AS FACTORYNAME
        ,MS_SKU.COLORDESCR                                                                                                        AS COLORDESCR
        ,ST_SNINFO.PLACEOFORIGIN                                                                                        		AS PLACEOFORIGIN
        ,MS_SKU.DURATION																											AS DURATION
        ,MS_SKU.DURATIONTYPE																										AS DURATIONTYPE
        ,ST_SNINFO.CONTRACTCUSTKEY                                                                                            AS CONTRACTCOMPANY
        ,MS_CUST_WD.DESCRIPTION                                                                                                   AS CONTRACTCOMPANYNAME
        ,FN_CODEDESCR(ST_SNINFO.STORERKEY,'CONTRACTTYPE_SN',ST_SNINFO.CONTRACTTYPE)                                       AS CONTRACTTYPE
        ,ST_SNINFO.BUTCHERYDT                                                                                                 AS BUTCHERYDT
        ,ST_SNINFO.FROMVALIDDT                                                                                                AS FROMVALIDDT
        ,ST_SNINFO.TOVALIDDT                                                                                                  AS TOVALIDDT
        ,CASE WHEN ST_STOCK.DCCODE IN ('1000','2170') THEN SUBSTR(ST_STOCK.ORGANIZE, INSTR(ST_STOCK.ORGANIZE,'-')+1)
        ELSE DECODE(ST_STOCK.STOCKTYPE, 'GOOD', '1000', 'BAD', '2000')
        END																													AS STORAGELOC
        ,CASE WHEN ST_STOCK.DCCODE IN ('2170') AND NVL(MS_SKU.LINE01,'N') = 'Y' THEN NULL
        ELSE NULL
        END																													AS ETCQTY1
        ,CASE WHEN NVL(ST_STOCK.STOCKID, 'STD') = 'STD' AND MS_SKU.SERIALYN = 'Y' THEN 'N' ELSE 'Y' END                       AS CHECK_FLAG
        ,CASE WHEN TO_NUMBER(NVL(MS_SKU.LINE02,0)) <![CDATA[<>]]> 0
        AND ST_STOCK.DCCODE       = '2170'
        AND NVL(MS_SKU.LINE01,'N') = 'Y'          THEN TO_NUMBER(NVL(MS_SKU.LINE02,0))
        ELSE 0
        END                                                                                                                           AS AVGWEIGHT       /* 평균중량    */
        ,ROUND(CASE WHEN TO_NUMBER(NVL(MS_SKU.LINE02,0)) <![CDATA[<>]]> 0
        AND ST_STOCK.DCCODE       = '2170'
        AND NVL(MS_SKU.LINE01,'N') = 'Y'    THEN (ST_STOCK.OPENQTY) / TO_NUMBER(NVL(MS_SKU.LINE02,0))
        ELSE 0
        END ,2)                                                                                                                 AS CALBOX          /* 환산박스    */
        ,CASE WHEN ST_STOCK.DCCODE       = '2170'
        AND NVL(MS_SKU.LINE01,'N') = 'Y'          THEN NVL(ST_STOCK.BOXQTY,0)
        ELSE 0
        END                                                                                                                           AS REALORDERBOX    /* 실박스예정 */
        ,CASE WHEN ST_STOCK.DCCODE       = '2170'
        AND NVL(MS_SKU.LINE01,'N') = 'Y'          THEN NVL(ST_STOCK.BOXQTY,0)
        ELSE 0
        END                                                                                                                           AS REALCFMBOX      /* 실박스확정 */
        <!-- 			 ,'0'                                                                                                                           AS TRANBOX         /* 작업박스    */ -->
        ,CASE WHEN ST_STOCK.DCCODE       = '2170'
        AND NVL(MS_SKU.LINE01,'N') = 'Y'          THEN 'Y'
        ELSE 'N'
        END                                                                                                                           AS BOXFLAG         /* 박스처리유무    */
        FROM   ST_STOCK
        JOIN   CM_USER_AUTHORITY
        ON  1=1
        <if test="fixdccode != null and fixdccode != ''">    AND    CM_USER_AUTHORITY.DCCODE    = #{fixdccode}       </if>
        <if test="gStorerkey != null and gStorerkey != ''"> AND    CM_USER_AUTHORITY.STORERKEY = #{gStorerkey}    </if>
        <if test="fixdccode != null and fixdccode != ''">  AND    CM_USER_AUTHORITY.ORGANIZE  = #{fixdccode}     </if>
        <if test="gArea != null and gArea != ''">      AND    CM_USER_AUTHORITY.AREA      = #{gArea}         </if>
        <if test="gMultiArea != null and gMultiArea != ''">       AND    CM_USER_AUTHORITY.AREA    =  #{gMultiArea}    </if>
        AND    CM_USER_AUTHORITY.USERID        = #{gUserId}
        AND    CM_USER_AUTHORITY.DCCODE        = ST_STOCK.DCCODE
         AND    CM_USER_AUTHORITY.STORERKEY     = ST_STOCK.STORERKEY
        AND    CM_USER_AUTHORITY.ORGANIZE      = ST_STOCK.ORGANIZE
        AND    CM_USER_AUTHORITY.AREA          = ST_STOCK.AREA
        LEFT OUTER JOIN
        MS_CUST
        ON     MS_CUST.STORERKEY               = ST_STOCK.STORERKEY
        AND    MS_CUST.CUSTTYPE                = 'P'
        AND    MS_CUST.CUSTKEY                 = FN_PURCHASECUST(ST_STOCK.DCCODE
        ,ST_STOCK.STORERKEY
        ,ST_STOCK.SKU
        ,ST_STOCK.DCCODE
        ,NVL(#{docdt},TO_CHAR(SYSDATE, 'YYYYMMDD')))
        AND    MS_CUST.DEL_YN                  = 'N'
        LEFT OUTER JOIN	MS_PLANT
        ON     MS_PLANT.PLANT                  = CASE WHEN ST_STOCK.DCCODE IN ('1000','2170') THEN SUBSTR(ST_STOCK.ORGANIZE, INSTR(ST_STOCK.ORGANIZE,'-')+1)
        ELSE ST_STOCK.DCCODE
        END
        JOIN    MS_SKU
        ON     MS_SKU.STORERKEY                = ST_STOCK.STORERKEY
        AND    MS_SKU.SKU                      = ST_STOCK.SKU
        AND    MS_SKU.DEL_YN                   = 'N'
        <!-- 상품 다중선택 -->
        <if test="skuMulti != null and skuMulti != '' ">
            <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                <foreach collection="skuMulti" item="item">
                    OR MS_SKU.SKU IN
                    <foreach collection="item" item="code" open="(" close=")" separator=",">
                        #{code}
                    </foreach>
                </foreach>
            </trim>
        </if>
        <if test="serialyn != null and serialyn != ''">    AND MS_SKU.SERIALYN              =  #{serialyn}    </if>
        LEFT OUTER JOIN    ST_SNINFO
        ON    ST_STOCK.STORERKEY     = ST_SNINFO.STORERKEY
        AND    ST_STOCK.SKU           = ST_SNINFO.SKU
        AND    ST_STOCK.STOCKID       = ST_SNINFO.STOCKID
        AND    ST_SNINFO.DEL_YN       = 'N'
        LEFT OUTER JOIN	  MS_CUST MS_CUST_WD
        ON    ST_SNINFO.CONTRACTCUSTKEY = MS_CUST_WD.CUSTKEY
        AND	   ST_SNINFO.STORERKEY 		 = MS_CUST_WD.STORERKEY
        JOIN    CM_LOT
        ON    ST_STOCK.STORERKEY 	  = CM_LOT.STORERKEY
        AND    ST_STOCK.LOT		      = CM_LOT.LOT
        AND    CM_LOT.DEL_YN          = 'N'
        JOIN    MS_LOCATION
        ON     MS_LOCATION.DCCODE          = ST_STOCK.DCCODE
        AND    MS_LOCATION.LOC             = ST_STOCK.LOC
        <!-- 2025-12-26 FWNEXTWMS-5299 모든불량 다보이게 -->
<!--        AND    MS_LOCATION.LOCTYPE         = DECODE(ST_STOCK.DCCODE,'2170',MS_LOCATION.LOCTYPE,'RETURN')-->
<!--        AND    MS_LOCATION.LOC             = DECODE(ST_STOCK.DCCODE,'2170',MS_LOCATION.LOC,'RTN-'||#{fixdccode})-->
        JOIN    CM_DC
        ON 	   CM_DC.DCCODE           	   = ST_STOCK.DCCODE
        AND     CM_DC.DEL_YN           	   = 'N'
        WHERE  1=1
        <if test="stocktype != null and stocktype != ''">   AND ST_STOCK.STOCKTYPE            =  #{stocktype}   </if>
        <if test="stockgrade != null and stockgrade != ''">  AND ST_STOCK.STOCKGRADE           =  #{stockgrade}  </if>
        <if test="fromloc != null and fromloc != ''">     AND ST_STOCK.LOC <![CDATA[>=]]>  #{fromloc}         </if>
        <if test="toloc != null and toloc != ''">       AND ST_STOCK.LOC <![CDATA[<=]]>  #{toloc}           </if>

        <if test="blno != null and blno != ''">        AND ST_SNINFO.CONVSERIALNO    =  #{blno}        </if>
        <if test="serialno != null and serialno != ''">    AND ST_SNINFO.SERIALNO        =  #{serialno}    </if>
        <if test="wdCustkey != null and wdCustkey != ''">  AND ST_SNINFO.CONTRACTCUSTKEY =  #{wdCustkey}  </if>
        <!-- 협력사 다중선택 -->
        <if test="fromCustkeyMulti != null and fromCustkeyMulti != '' ">
            <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                <foreach collection="fromCustkeyMulti" item="item">
                    OR MS_CUST.CUSTKEY IN
                    <foreach collection="item" item="code" open="(" close=")" separator=",">
                        #{code}
                    </foreach>
                </foreach>
            </trim>
        </if>
        AND    ST_STOCK.OPENQTY             <![CDATA[>]]>  0
        ORDER BY ST_STOCK.DCCODE
        ,ST_STOCK.ORGANIZE
        ,MS_CUST.CUSTKEY
        ,ST_STOCK.SKU
    </select>
</mapper>