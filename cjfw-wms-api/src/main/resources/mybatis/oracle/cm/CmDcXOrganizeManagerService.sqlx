<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cmDcXOrganizeManagerService">

	<select id="getMasterList" resultType="CmDcXOrganizeManagerResDto">
		SELECT /* [cmDcXOrganizeService.sqlx][cmDcXOrganizeService.getMasterList][센터별취급조직 기준정보 조회 (목록)][jangjaehyun][20250717] */
               CM_DCXORGANIZE.SERIALKEY    AS SERIALKEY,    /* 데이터번호 */
               CM_DCXORGANIZE.DCCODE       AS DCCODE,       /* 센터코드 */
               CM_DCXORGANIZE.ORGANIZE     AS ORGANIZE,     /* 조직코드 */
               CM_DCXORGANIZE.DESCRIPTION  AS DESCRIPTION,  /* 내역 */
               CM_DCXORGANIZE.STATUS       AS STATUS,       /* 상태 */
               CM_DCXORGANIZE.DEL_YN       AS DEL_YN,       /* 삭제여부 */
               CM_DCXORGANIZE.ADDDATE      AS ADDDATE,      /* 최초등록시간 */
               CM_DCXORGANIZE.EDITDATE     AS EDITDATE,     /* 최종변경시간 */
               CM_DCXORGANIZE.ADDWHO,
               CM_DCXORGANIZE.EDITWHO,
               USER1.USER_NM AS ADDWHO_NM,  /*등록자명*/
			   USER2.USER_NM AS EDITWHO_NM  /*수정자명*/
          FROM CM_DCXORGANIZE
          LEFT JOIN FRAMEONE_USER USER1 ON USER1.USER_ID = CM_DCXORGANIZE.ADDWHO  /*등록자명*/
          LEFT JOIN FRAMEONE_USER USER2 ON USER2.USER_ID = CM_DCXORGANIZE.EDITWHO  /*수정자명*/
         WHERE 1=1
         <if test='multiDcCode != null and multiDcCode.length > 0'>
		   AND CM_DCXORGANIZE.DCCODE IN
	        <foreach collection="multiDcCode" item="dccodeItem" open="(" separator="," close=")">
	            #{dccodeItem}
	        </foreach>
		 </if>
    </select>
        
    <insert id="insertMaster">
	    INSERT /* [cmDcXOrganizeService.sqlx][cmDcXOrganizeService.insert][센터별취급조직 기준정보 INSERT][jangjaehyun][20250717] */
          INTO CM_DCXORGANIZE
             ( SERIALKEY,
               DCCODE,
               ORGANIZE,
               DESCRIPTION,
               ADDWHO,
               EDITWHO
             )
        VALUES
             ( SEQ_CM_DCXORGANIZE.NEXTVAL,
               #{dcCode},       /* 센터코드 */
               #{organize},     /* 조직코드 */
               #{description},  /* 내역 */
               #{gUserId},      /* 최초등록자 */
               #{gUserId}       /* 최종변경자 */
             )
	</insert>
	
	<update id="updateMaster">
	    UPDATE /* [cmDcXOrganizeService.sqlx][cmDcXOrganizeService.update][센터별취급조직 기준정보 UPDATE][jangjaehyun][20250717] */
               CM_DCXORGANIZE
           SET ORGANIZE = #{organize},   /* 조직코드 */
               DESCRIPTION = #{description}, /* 내역 */
               STATUS   = #{status},     /* 상태 */
               DEL_YN   = #{delYn},      /* 삭제여부 */
               EDITDATE = SYSDATE,       /* 최종변경시간 */
               EDITWHO  = #{gUserId}     /* 최종변경자 */
         WHERE SERIALKEY = #{serialKey}
	</update>
	
	
	<select id="getOrganizeList" resultType="cjfw.wms.cm.dto.CmDcXOrganizeManagerResDto">
	    SELECT	/* [cmDcXOrganizeService.sqlx][cmDcXOrganizeService.getOrganizeList][창고 코드리스트 조회][Kihyeong Ahn][20250717] */ 
  			   CM_DCXORGANIZE.ORGANIZE AS COM_CD	/* 창고코드 */
         	  ,'['||CM_DCXORGANIZE.ORGANIZE||']'||CM_DCXORGANIZE.DESCRIPTION AS COM_NM	/* 창고명 */
         	   /**/
         	  ,CM_DCXORGANIZE.DCCODE
          FROM CM_DCXORGANIZE
         WHERE DEL_YN ='N'
    </select>    	
	
	
	
    
</mapper>