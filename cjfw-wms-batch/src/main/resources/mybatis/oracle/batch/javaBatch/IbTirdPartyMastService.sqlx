<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--
 * Copyright 2025. CJ OliveNetworks Co. all rights reserved.
 *
 * @author      : KimDongHan (liop0123@cj.net)
 * @date        : 2025.12.15
 * @description : 3PL물류대행수수료정산 협력사관리_탭 협력사 관리 배치 SQL
 * @issues      :
-->

<mapper namespace="IbTirdPartyMastService">

	<select id="selectMasterList" resultType="cjfw.batch.dto.IbTirdPartyMastResDto">
		SELECT /* [IbTirdPartyMastService.sqlx][selectMasterList][3PL물류대행수수료정산 협력사관리_탭 협력사 관리 배치 INSERT 대상 조회][KimDongHan][2025-12-15] */
		       DISTINCT 
		       DM_DOCUMENT_H.DCCODE             AS DCCODE
		     , DM_DOCUMENT_H.FROM_CUSTKEY       AS CUSTKEY
		     , DM_DOCUMENT_H.STORERKEY          AS STORERKEY
		  FROM DM_DOCUMENT_H
		 WHERE 1=1
		   AND DM_DOCUMENT_H.DOCTYPE         = 'DP'
		   AND DM_DOCUMENT_H.WORKPROCESSCODE = 'PO'
		   AND DM_DOCUMENT_H.DELIVERYDATE    = TO_CHAR(SYSDATE-1,'YYYYMMDD') 
	</select>
	
	<select id="selectCount" resultType="cjfw.batch.dto.IbTirdPartyMastResDto">
		SELECT /* [IbTirdPartyMastService.sqlx][selectCount][3PL물류대행수수료정산 협력사관리_탭 협력사 관리 배치 중복 여부 조회][KimDongHan][2025-12-15] */
		       COUNT(*) AS CNT
		  FROM MS_3PLCUST
		 WHERE 1=1
		   AND DCCODE    = #{dccode} 
		   AND CUSTKEY   = #{custkey} 
		   AND STORERKEY = #{storerkey}
	</select>
	
    <insert id="insertMaster">
		INSERT /* [IbTirdPartyMastService.sqlx][insertMaster][3PL물류대행수수료정산 협력사관리_탭 협력사 관리 INSERT][KimDongHan][2025-12-15] */
		  INTO MS_3PLCUST
		     ( SERIALKEY                           /* SERIALKEY */
			 , STORERKEY                           /* STORERKEY */ 
			 , CUSTKEY                             /* CUSTKEY */
			 , DCCODE                              /* DCCODE */
			 , US_YN                               /* US_YN */
			 , ADDDATE                             /* ADDDATE */
			 , EDITDATE                            /* EDITDATE */
			 , ADDWHO                              /* ADDWHO */
			 , EDITWHO                             /* EDITWHO */
		     ) VALUES (	 
		       SEQ_MS_3PLCUST.NEXTVAL              /* SERIALKEY */
			 , #{storerkey}                        /* STORERKEY */ 
			 , #{custkey}                          /* CUSTKEY */
			 , #{dccode}                           /* DCCODE */
			 , '1'                                 /* US_YN */
			 , SYSDATE                             /* ADDDATE */
			 , SYSDATE                             /* EDITDATE */
			 , 'BATCHSYSTEM'                       /* ADDWHO */
			 , 'BATCHSYSTEM'                       /* EDITWHO */
			 )
    </insert>
    	
</mapper>
