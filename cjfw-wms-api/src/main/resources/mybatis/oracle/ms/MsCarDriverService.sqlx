    <insert id="insertCmCarHttpDocAttach">
        <selectKey resultType="string" keyProperty="carId" order="BEFORE">
            SELECT SEQ_CM_CAR_HTTP_DOC_ATTACH.NEXTVAL AS CARID FROM DUAL
        </selectKey>
        INSERT /* [msCarDriverService.sqlx][msCarDriverService.insertCmCarHttpDocAttach] */
          INTO CM_CAR_HTTP_DOC_ATTACH
               ( SERIALKEY, DOC_ID, DOC_TYPE, DOC_NAME, FILE_NAME,
                 FILE_EXTENSION, FILE_LOCATION, FILE_SIZE_BYTES, TRANS_FILE_NAME, UPLOAD_HASH_ID,
                 UPLOAD_RES_DOC_ID, UPLOAD_FILE_NAME, UPLOAD_WORKPLACE_ID, UPLOAD_LOCATION, DOWNLOAD_COUNT,
                 FILE_CONTENT, FILE_TYPE, STATUS, ADDWHO, ADDDATE,
                 EDITWHO, EDITDATE
               )
