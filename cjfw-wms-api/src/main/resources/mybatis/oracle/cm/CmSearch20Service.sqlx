<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cmSearch20Service">
	<select id="getCarrierList" resultType="cjfw.wms.cm.dto.CmCarrierPopupResDto">
		SELECT DISTINCT/* [CmSearchService.sqlx][getCarrierList][운송사 목록 조회][KimSunHo][2025.05.09] */
	           MS_CARRIER.CARRIERKEY  	AS 	CODE 		/* 운송사코드 	*/
	          ,MS_CARRIER.DESCRIPTION 	AS 	NAME 		/* 운송사명 	*/
			  ,MS_CARRIER.CARRIERTYPE	AS	CARRIERTYPE	/* 운송사유형 	*/
			  ,MS_CARRIER.PHONE1		AS	PHONE1	/* 전화번호 	*/
		FROM MS_CARRIER
		
	    WHERE MS_CARRIER.STORERKEY = #{gStorerkey}
	    
		<!-- 운송사유형-->
		<if test='carrierType != null and carrierType !=""'>
			AND MS_CARRIER.CARRIERTYPE = #{carrierType}
		</if>
		
		<!-- 운송사팝업의 경우 사용여부를 보여주는 컬럼이 없어서 추가 -->
		AND DEL_YN = 'N'
		
        <choose>
	        <!-- START.운송사.다중검색 -->
	        <when test="multiSelectMulti != null and multiSelectMulti != ''">    
		       AND MS_CARRIER.CARRIERKEY IN
		       <foreach collection="multiSelectMulti" item="code" open="(" close=")" separator=",">
		         #{code}
		       </foreach>
	        </when>   
	        <!-- END.운송사.다중검색 -->
        <otherwise>
	        <choose>
		        <when test="isEnter == 'Y'.toString()"> <!-- 엔터검색.input/돋보기 =검색(성능) -->
			          AND (MS_CARRIER.CARRIERKEY = #{name}  OR MS_CARRIER.DESCRIPTION = #{name}) /*엔터검색*/
		        </when>
	        <otherwise>
		        <if test='name != null and name != ""'>
			        <choose>
			        	<when test="fixedSearchYn == '' and fixedSearchYn == null"> <!-- FIX검색.%1개일 때(3/4) -->
					     AND (
					          MS_CARRIER.CARRIERKEY 	 LIKE '%'||#{code}||'%'
					       OR MS_CARRIER.CARRIERKEY    LIKE '%'||#{name}||'%' 
                           OR MS_CARRIER.DESCRIPTION LIKE '%'||#{name}||'%')
				        </when>
			        
				        <when test="fixedSearchYn == 'Y'.toString()"> <!-- FIX검색.%1개일 때(3/4) -->
					          AND (MS_CARRIER.CARRIERKEY LIKE #{name} OR MS_CARRIER.DESCRIPTION LIKE #{name} )
				        </when>
			        <otherwise><!-- 2.단일검색,5.%다중검색  -->
				        AND (MS_CARRIER.CARRIERKEY LIKE '%'||#{name}||'%' OR MS_CARRIER.DESCRIPTION LIKE '%'||#{name}||'%' )
			        </otherwise>
			        </choose>		            
		                
	                <!-- START.검색요건 -->
                       <if test= 'name != null and name.indexOf(" ") gt 0 '>
                           OR REGEXP_LIKE (UPPER(MS_CARRIER.DESCRIPTION), REGEXP_REPLACE (UPPER(#{keywordRegexp}), '[ ]+', '|'))
                       </if>
                    <!-- END.검색요건 -->     
		        </if>
	        </otherwise>
	        </choose>

        </otherwise>
        </choose>
        
        <!-- START.검색요건 -->
        <choose>
            <when test='name != null and name.indexOf(" ") gt 0 '>
                ORDER BY
                        REGEXP_COUNT(UPPER(MS_CARRIER.DESCRIPTION), REGEXP_REPLACE (UPPER(#{keywordRegexp}), '[ ]+', '|')) DESC, /*매치 검색 count*/
                        UTL_MATCH.JARO_WINKLER_SIMILARITY(MS_CARRIER.DESCRIPTION, #{name}) DESC 
                            
            </when>
            <otherwise>
               /*ASIS처럼 정열 없음*/
            </otherwise>
        </choose>     
        <!-- END.검색요건 -->          
        
    </select>     
    
    
    <select id="getCarrierDropList" resultType="CmCarrierPopupResDto">
		SELECT DISTINCT/* [CmSearchService.sqlx][getCarrierDropList][운송사 목록 (드랍다운)조회][KimSunHo][2025.05.09] */
		     MS_CARRIER.CARRIERKEY  AS 	CODE 		/* 운송사코드 	*/
		    ,MS_CARRIER.DESCRIPTION AS 	NAME 		/* 운송사명 	*/
		    <if test="carrierTypeHiddenYn != 'Y'.toString()">
		    	,CM_CODE.BASEDESCR 	AS	CARRIERTYPE	/* 운송사유형 	*/
		    </if>
		    ,MS_CARRIER.PHONE1	AS	PHONE1	/* 전화번호 	*/

		FROM MS_CARRIER
		JOIN CM_CODE
		  ON  CM_CODE.CODELIST LIKE 'CARRIERTYPE'
		 AND MS_CARRIER.CARRIERTYPE = CM_CODE.BASECODE
		WHERE 1=1		
		<if test='gStorerkey != null and gStorerkey != ""'>
			AND MS_CARRIER.STORERKEY = #{gStorerkey}
		</if>
		/*운송사유형*/
		<if test='carrierType != null and carrierType !=""'>
			AND MS_CARRIER.CARRIERTYPE = #{carrierType}
		</if>
		
	
        <choose>
        <when test='multiSelect != null and multiSelect != ""'>
	        AND MS_CARRIER.CARRIERKEY IN (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
			                     FROM (SELECT #{multiSelect} AS VAL FROM DUAL) A
			                  CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
        </when>		
        
        <otherwise>
	        <choose>
		        <when test="isEnter == 'Y'.toString()"> <!-- 엔터검색.input/돋보기 =검색(성능) -->
			          AND (MS_CARRIER.CARRIERKEY = #{name}  OR MS_CARRIER.DESCRIPTION = #{name}) /*엔터검색*/
		        </when>
	        <otherwise>     
		        <if test='name != null and name != ""'>
			        <choose>
			        	<when test="fixedSearchYn == '' and fixedSearchYn == null"> <!-- FIX검색.%1개일 때(3/4) -->
					     AND (MS_CARRIER.CARRIERKEY  LIKE '%'||#{name}||'%' 
                           OR MS_CARRIER.DESCRIPTION LIKE '%'||#{name}||'%')
				        </when>
			        
				        <when test="fixedSearchYn == 'Y'.toString()"> <!-- FIX검색.%1개일 때(3/4) -->
					          AND (MS_CARRIER.CARRIERKEY LIKE #{name} OR MS_CARRIER.DESCRIPTION LIKE #{name} )
				        </when>
			        <otherwise><!-- 2.단일검색,5.%다중검색  -->
				        AND (MS_CARRIER.CARRIERKEY LIKE '%'||#{name}||'%' OR MS_CARRIER.DESCRIPTION LIKE '%'||#{name}||'%' )
			        </otherwise>
			        </choose>	
			        	
	                <!-- START.검색요건 -->
                       <if test= 'name != null and name.indexOf(" ") gt 0 '>
                           OR REGEXP_LIKE (UPPER(MS_CARRIER.DESCRIPTION), REGEXP_REPLACE (UPPER(#{keywordRegexp}), '[ ]+', '|'))
                       </if>
                    <!-- END.검색요건 -->     
		        </if>
	        </otherwise>
	        </choose>
        </otherwise>
        </choose>	        

		<!-- START.검색요건 -->
        <choose>
            <when test='name != null and name.indexOf(" ") gt 0 '>
                ORDER BY
                        REGEXP_COUNT(UPPER(MS_CARRIER.DESCRIPTION), REGEXP_REPLACE (UPPER(#{keywordRegexp}), '[ ]+', '|')) DESC, /*매치 검색 count*/
                        UTL_MATCH.JARO_WINKLER_SIMILARITY(MS_CARRIER.DESCRIPTION, #{name}) DESC 
                            
            </when>
            <otherwise>
               /*ASIS처럼 정열 없음*/
            </otherwise>
        </choose>     
        <!-- END.검색요건 -->
    </select>     
    
    <select id="getSkuSpecList" resultType="CmSkuSpecPopupResDto">
    	SELECT	/* [cmSearchService.sqlx][getSkuSpecList][상품 정보 리스트 조회][20250512][KimSunHo] */  
			   STORERKEY
		      ,SPECCATEGORY
		      ,SPECCODE   
		      ,SPECDESCR  
		      ,SPECCLASS   
		      ,SPECTYPE
		      ,SKUGROUP  
		      ,SPECCODE AS ROW_ID
		      ,'[' || SPECCODE || '] ' || SPECDESCR AS SPEC
		FROM   MS_SKUSPEC
		WHERE  SPECCATEGORY = #{speccategory}		
		<if test='storerkey != null and storerkey != ""'>
			AND (STORERKEY = #{storerkey})
		</if>
		<if test='specclass != null and specclass != ""'>
			AND (SPECCLASS = #{specclass})
		</if>
		<if test='name != null and name !=""'>
		AND   (
			SPECCODE         =  #{name}
			OR SPECDESCR     =  #{name}
		)
		</if>
		
		ORDER BY SPECCODE
    </select>
</mapper>