<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--
 * Copyright 2025. CJ OliveNetworks Co. all rights reserved.
 *
 * @author      : KimDongHan (liop0123@cj.net)
 * @date        : 2025.12.01
 * @description : 입고 > 입고현황 > 입고 예정진행 현황(입차시간) SQL
 * @issues      :
-->
<mapper namespace="dpInplanTimeService">

	<select id="getMasterList" resultType="cjfw.wms.dp.dto.DpInplanTimeResDto">
		SELECT /* [dpInplanTimeService.sqlx][dpInplanTimeService.getMasterList][입고 예정진행 현황(입차시간) 조회][KimDongHan][20250926] */ 
		       T.DCCODE              AS DCCODE           /* 물류센터 */
		     , T.DCNAME              AS DCNAME           /* 물류센터명*/
		     , T.DELIVERYDATE        AS DELIVERYDATE     /* 입고일자 */
		     , T.FROM_INTIME         AS FROM_INTIME      /* FROM_입고예정시간 */
		     , T.TO_INTIME           AS TO_INTIME        /* TO_입고예정시간 */
		     , T.FROM_CUSTKEY        AS FROM_CUSTKEY     /* 협력사 */
		     , T.FROM_CUSTTYPE       AS FROM_CUSTTYPE    /* 협력사유형 */
		     , T.CUSTNAME            AS CUSTNAME         /* 협력사명 */
		     , T.DOCNO               AS DOCNO            /* 입고전표번호 */
		     , T.REAL_INTIME         AS REAL_INTIME      /* QR 입문시간 */
		     , T.TEMPERATURE1        AS TEMPERATURE1     /* 냉장온도 */
		     , T.TEMPERATURE2        AS TEMPERATURE2     /* 냉동온도 */
		     , T.DELIVERYTIME        AS DELIVERYTIME     /* 하차검수시간 */
		     , T.CHANNEL             AS CHANNEL          /* 저장유무 */
		     , T.CHANNEL_NAME        AS CHANNEL_NAME     /* 저장유무명 */
		     <!--, T.DIFF_HHMI           AS DIFF_HHMI        /* TO_INTIME - REAL_INTIME */-->
             , CASE WHEN T.MINUTES_DIFF IS NULL THEN NULL
                    ELSE (CASE WHEN T.MINUTES_DIFF <![CDATA[<]]> 0 THEN '-' ELSE '' END)
                      || LPAD(TO_CHAR(TRUNC(ABS(T.MINUTES_DIFF) / 60)), 2, '0')
                      || ':' ||
                         LPAD(TO_CHAR(MOD(ABS(T.MINUTES_DIFF), 60)), 2, '0')
                END AS DIFF_HHMI		                      /* TO_INTIME - REAL_INTIME */
		     , CASE WHEN T.MINUTES_DIFF IS NULL THEN NULL
		            WHEN T.MINUTES_DIFF <![CDATA[<]]> 0 THEN 'M'
		            ELSE 'P'
		       END                   AS DIFF_FLAG	
             , CASE WHEN T.MINUTES_DIFF IS NULL THEN NULL
                    WHEN T.MINUTES_DIFF BETWEEN -30 AND 30 THEN 'Y'
                    ELSE 'N'
                    END AS COMPLY_30MIN
              ,CASE WHEN T.MINUTES_DIFF IS NULL THEN NULL
                    WHEN T.MINUTES_DIFF BETWEEN -60 AND 60 THEN 'Y'
                    ELSE 'N'
                   END AS COMPLY_1HOUR
		  FROM ( SELECT A.DCCODE              AS DCCODE           /* 물류센터 */
		              , A.DCNAME              AS DCNAME           /* 물류센터명*/
		              , A.DELIVERYDATE        AS DELIVERYDATE     /* 입고일자 */
		              , A.FROM_INTIME         AS FROM_INTIME      /* FROM_입고예정시간 */
		              , A.TO_INTIME           AS TO_INTIME        /* TO_입고예정시간 */
		              , A.FROM_CUSTKEY        AS FROM_CUSTKEY     /* 협력사 */
		              , A.FROM_CUSTTYPE       AS FROM_CUSTTYPE    /* 협력사유형 */
		              , A.CUSTNAME            AS CUSTNAME         /* 협력사명 */
		              , A.DOCNO               AS DOCNO            /* 입고전표번호 */
		              , A.REAL_INTIME         AS REAL_INTIME      /* QR 입문시간 */
		              , A.TEMPERATURE1        AS TEMPERATURE1     /* 냉장온도 */
		              , A.TEMPERATURE2        AS TEMPERATURE2     /* 냉동온도 */
		              , A.DELIVERYTIME        AS DELIVERYTIME     /* 하차검수시간 */
		              , A.CHANNEL             AS CHANNEL          /* 저장유무 */
		              , A.CHANNEL_NAME        AS CHANNEL_NAME     /* 저장유무명 */
                      , CASE WHEN A.REAL_INTIME IS NULL OR TRIM(A.REAL_INTIME) = '' OR A.TO_INTIME IS NULL OR TRIM(A.TO_INTIME) = ''
                             THEN NULL
                             ELSE (TO_NUMBER(SUBSTR(A.REAL_INTIME,1,2)) * 60 + TO_NUMBER(SUBSTR(A.REAL_INTIME,4,2)))
                                 -(TO_NUMBER(SUBSTR(A.TO_INTIME,1,2))   * 60 + TO_NUMBER(SUBSTR(A.TO_INTIME,4,2)))
                            END AS MINUTES_DIFF                      		              
		              , CASE WHEN A.REAL_INTIME IS NULL OR TRIM(A.REAL_INTIME) = '' OR A.TO_INTIME IS NULL OR TRIM(A.TO_INTIME) = ''
			                 THEN NULL
			                 ELSE ( CASE WHEN (TO_NUMBER(SUBSTR(A.REAL_INTIME,1,2))*60 + TO_NUMBER(SUBSTR(A.REAL_INTIME,4,2))) <![CDATA[<]]> (TO_NUMBER(SUBSTR(A.TO_INTIME,1,2))*60 + TO_NUMBER(SUBSTR(A.TO_INTIME,4,2)))
						                 THEN '-'
						                 ELSE ''
						            END )
			            ||LPAD(TO_CHAR(TRUNC(ABS((TO_NUMBER(SUBSTR(A.REAL_INTIME,1,2))*60 + TO_NUMBER(SUBSTR(A.REAL_INTIME,4,2))) - (TO_NUMBER(SUBSTR(A.TO_INTIME,1,2))*60 + TO_NUMBER(SUBSTR(A.TO_INTIME,4,2)))) / 60)), 2, '0') 
			            || ':' 
			            ||LPAD(TO_CHAR(MOD(ABS((TO_NUMBER(SUBSTR(A.REAL_INTIME,1,2))*60 + TO_NUMBER(SUBSTR(REAL_INTIME,4,2))) - (TO_NUMBER(SUBSTR(A.TO_INTIME,1,2))*60 + TO_NUMBER(SUBSTR(A.TO_INTIME,4,2)))), 60)), 2, '0')
		                END AS DIFF_HHMI        
		           FROM ( SELECT DM_DOCUMENT_H.DCCODE                                                                      AS DCCODE        /* 물류센터 */
		                       , FN_GETDCNAME(DM_DOCUMENT_H.DCCODE)                                                        AS DCNAME        /* 물류센터명*/
		                       , DM_DOCUMENT_H.DELIVERYDATE                                                                AS DELIVERYDATE  /* 입고일자 */
		                       , FROM_INTIME                                             AS FROM_INTIME   /* FROM_입고예정시간 */
		                       , TO_INTIME                                               AS TO_INTIME     /* TO_입고예정시간 */
		                       , DM_DOCUMENT_H.FROM_CUSTKEY                                                                AS FROM_CUSTKEY  /* 협력사 */
		                       , DM_DOCUMENT_H.FROM_CUSTTYPE                                                               AS FROM_CUSTTYPE /* 협력사유형 */
		                       , MS_CUST.DESCRIPTION                                                                       AS CUSTNAME      /* 협력사명 */
		                       , DM_DOCUMENT_H.DOCNO                                                                       AS DOCNO         /* 입고전표번호 */
		                       , TO_CHAR(DP_QRSCANLOG.ADDDATE,'HH24:MI')                                                   AS REAL_INTIME   /* QR 입문시간 */
		                       , DP_UNLOADCARLOG.TEMPERATURE1                                                              AS TEMPERATURE1  /* 냉장온도 */
		                       , DP_UNLOADCARLOG.TEMPERATURE2                                                              AS TEMPERATURE2  /* 냉동온도 */
		                       , CASE WHEN DP_UNLOADCARLOG.DELIVERYTIME IS NOT NULL AND DP_UNLOADCARLOG.DELIVERYTIME != 'null'
		                              THEN SUBSTR(LPAD(TO_CHAR(DP_UNLOADCARLOG.DELIVERYTIME),4,'0'),1,2) || ':' || 
		                                   SUBSTR(LPAD(TO_CHAR(DP_UNLOADCARLOG.DELIVERYTIME),4,'0'),3,2) 
		                              ELSE '' END                                                                          AS DELIVERYTIME  /* 하차검수시간 */
		                       , DM_DOCUMENT_H.CHANNEL                                                                     AS CHANNEL       /* 저장유무 */
		                       , FN_CODEDESCR(DM_DOCUMENT_H.STORERKEY,'PUTAWAYTYPE', DM_DOCUMENT_H.CHANNEL)                AS CHANNEL_NAME  /* 저장유무명 */
		                    FROM DM_DOCUMENT_H
		                    LEFT OUTER JOIN MS_INTIME DP_INPLAN_TIME
		                      ON DP_INPLAN_TIME.STORERKEY    = DM_DOCUMENT_H.STORERKEY
		                     AND DP_INPLAN_TIME.CHANNEL = DM_DOCUMENT_H.CHANNEL
		                     AND DP_INPLAN_TIME.DCCODE       = DM_DOCUMENT_H.DCCODE
		                     AND DP_INPLAN_TIME.CUSTKEY      = DM_DOCUMENT_H.FROM_CUSTKEY
                             --
                            LEFT JOIN DP_QRSCANLOG
                                ON  DM_DOCUMENT_H.STORERKEY     = DP_QRSCANLOG.STORERKEY
                                AND DM_DOCUMENT_H.DCCODE        = DP_QRSCANLOG.DCCODE
                                AND  DM_DOCUMENT_H.DELIVERYDATE = DP_QRSCANLOG.DELIVERYDATE
                                AND DM_DOCUMENT_H.DOCNO         = DP_QRSCANLOG.DOCNO
                                AND  DM_DOCUMENT_H.FROM_CUSTKEY = DP_QRSCANLOG.CUSTKEY                                                             
                             --
                            LEFT OUTER JOIN DP_UNLOADCARLOG
								ON DM_DOCUMENT_H.DCCODE = DP_UNLOADCARLOG.DCCODE
								AND DM_DOCUMENT_H.STORERKEY = DP_UNLOADCARLOG.STORERKEY
								AND DM_DOCUMENT_H.DELIVERYDATE = DP_UNLOADCARLOG.SLIPDT
								AND DM_DOCUMENT_H.FROM_CUSTKEY = DP_UNLOADCARLOG.CUSTKEY
								AND DM_DOCUMENT_H.DOCNO = DP_UNLOADCARLOG.DOCNO
								AND DP_QRSCANLOG.DELIVERYGROUP = DP_UNLOADCARLOG.DELIVERYGROUP
		                    JOIN MS_CUST
		                      ON MS_CUST.STORERKEY           = DM_DOCUMENT_H.STORERKEY
		                     AND MS_CUST.CUSTKEY             = DM_DOCUMENT_H.FROM_CUSTKEY
		                     AND MS_CUST.CUSTTYPE            = 'P'
		                   WHERE 1=1
		                     AND DM_DOCUMENT_H.STORERKEY     = #{gStorerkey}
		                     AND DM_DOCUMENT_H.DOCTYPE       = 'DP'
							<if test="dccode != null and dccode != ''">   
		                     AND DM_DOCUMENT_H.DCCODE        = #{dccode}
							</if>		    
							<if test="deliverydateFrom != null and deliverydateFrom != ''">    		
		                     AND DM_DOCUMENT_H.DELIVERYDATE<![CDATA[>=]]> #{deliverydateFrom}   
							</if>
							<if test="deliverydateTo != null and deliverydateTo != ''">      		
		                     AND DM_DOCUMENT_H.DELIVERYDATE<![CDATA[<=]]> #{deliverydateTo}     
							</if>	 
							<if test="channel != null and channel != ''">   
		                     AND DM_DOCUMENT_H.CHANNEL       = #{channel}
							</if>
							<if test="docno != null and docno != ''">   
		                     AND DM_DOCUMENT_H.DOCNO         = #{docno}
							</if>
							<!-- START.협력사 -->
							<if test="custkeyMulti != null and custkeyMulti != '' ">
								<trim prefix="AND (" suffix=")" prefixOverrides="OR">
									<foreach collection="custkeyMulti" item="item">
		                     OR DM_DOCUMENT_H.FROM_CUSTKEY IN
										<foreach collection="item" item="code" open="(" close=")" separator=",">
										#{code} 	 
										</foreach>
									</foreach>
								</trim>			                                    
							</if>
							<!-- END.협력사 -->	
		                ) A
		       ) T
		  WHERE 1=1
		<if test="complyYn == 'Y'.toString()">
            AND T.MINUTES_DIFF BETWEEN -30 AND 30
		</if>
		<if test="complyYn == 'N'.toString()">
            AND T.MINUTES_DIFF IS NOT NULL
            AND (T.MINUTES_DIFF <![CDATA[<]]> -30 OR T.MINUTES_DIFF > 30)
		</if>  	
		<if test="diffHourFrom != null and diffHourFrom != ''">
            AND T.MINUTES_DIFF IS NOT NULL		
            AND T.MINUTES_DIFF BETWEEN LEAST(TRUNC(#{diffHourFrom}), TRUNC(#{diffHourTo})) * 60 AND GREATEST(TRUNC(#{diffHourFrom}), TRUNC(#{diffHourTo})) * 60            
		</if>
		<if test="diffHourFrom == '0'.toString()">
            AND T.MINUTES_DIFF IS NOT NULL		
            AND T.MINUTES_DIFF BETWEEN LEAST(TRUNC(#{diffHourFrom}), TRUNC(#{diffHourTo})) * 60 AND GREATEST(TRUNC(#{diffHourFrom}), TRUNC(#{diffHourTo})) * 60            
		</if>
          ORDER BY T.DELIVERYDATE DESC		
	</select>

    <select id="getMasterList_backup" resultType="cjfw.wms.dp.dto.DpInplanTimeResDto">
		SELECT /* [DpInplanTimeService.sqlx][DpInplanTimeService.getMasterList][입고 예정진행 현황(입차시간) 조회][KimDongHan][2025-12-01] */ 
		       DCCODE              AS DCCODE           /* 물류센터 */
		     , DCNAME              AS DCNAME           /* 물류센터명*/
		     , DELIVERYDATE        AS DELIVERYDATE     /* 입고일자 */
		     , FROM_INTIME         AS FROM_INTIME      /* FROM_입고예정시간 */
		     , TO_INTIME           AS TO_INTIME        /* TO_입고예정시간 */
		     , FROM_CUSTKEY        AS FROM_CUSTKEY     /* 협력사 */
		     , FROM_CUSTTYPE       AS FROM_CUSTTYPE    /* 협력사유형 */
		     , CUSTNAME            AS CUSTNAME         /* 협력사명 */
		     , DOCNO               AS DOCNO            /* 입고전표번호 */
		     , REAL_INTIEM         AS REAL_INTIEM      /* QR 입문시간 */
		     , TEMPERATURE1        AS TEMPERATURE1     /* 냉장온도 */
		     , TEMPERATURE2        AS TEMPERATURE2     /* 냉동온도 */
		     , DELIVERYTIME        AS DELIVERYTIME     /* 하차검수시간 */
		     , CHANNEL             AS CHANNEL          /* 저장유무 */
		     , CHANNEL_NAME        AS CHANNEL_NAME     /* 저장유무명 */
		     , CASE WHEN   TO_DATE(REAL_INTIEM,'HH24:MI') <![CDATA[>=]]>TO_DATE(TO_INTIME,'HH24:MI')
		            THEN  (TO_DATE(REAL_INTIEM,'HH24:MI')   - TO_DATE(TO_INTIME,'HH24:MI')) * 24 * 60
		            ELSE ((TO_DATE(REAL_INTIEM,'HH24:MI')   - TO_DATE(TO_INTIME,'HH24:MI')) + 1) * 24 * 60
		        END AS DIFF_MIN                       /* 시간차이 분으로 표현 */
		     , LPAD(TRUNC((CASE WHEN   TO_DATE(REGEXP_REPLACE(REAL_INTIEM,'[^0-9:]',''),'HH24:MI')    <![CDATA[>=]]>TO_DATE(REGEXP_REPLACE(TO_INTIME,'[^0-9:]',''),'HH24:MI')
		                        THEN  (TO_DATE(REGEXP_REPLACE(REAL_INTIEM,'[^0-9:]',''),'HH24:MI')      - TO_DATE(REGEXP_REPLACE(TO_INTIME,'[^0-9:]',''),'HH24:MI')) * 24 * 60
		                        ELSE ((TO_DATE(REGEXP_REPLACE(REAL_INTIEM,'[^0-9:]',''),'HH24:MI')      - TO_DATE(REGEXP_REPLACE(TO_INTIME,'[^0-9:]',''),'HH24:MI')) + 1) * 24 * 60
		                    END) / 60), 2, '0')|| ':' ||
		       LPAD(MOD(TRUNC((CASE WHEN   TO_DATE(REGEXP_REPLACE(REAL_INTIEM,'[^0-9:]',''),'HH24:MI')<![CDATA[>=]]>TO_DATE(REGEXP_REPLACE(TO_INTIME,'[^0-9:]',''),'HH24:MI')
		                            THEN  (TO_DATE(REGEXP_REPLACE(REAL_INTIEM,'[^0-9:]',''),'HH24:MI')  - TO_DATE(REGEXP_REPLACE(TO_INTIME,'[^0-9:]',''),'HH24:MI')) * 24 * 60
		                            ELSE ((TO_DATE(REGEXP_REPLACE(REAL_INTIEM,'[^0-9:]',''),'HH24:MI')  - TO_DATE(REGEXP_REPLACE(TO_INTIME,'[^0-9:]',''),'HH24:MI')) + 1) * 24 * 60
		                    END)), 60), 2, '0') AS DIFF_HHMI /* 시간차이 HH:MI 로 표현*/
		  FROM ( SELECT DM_DOCUMENT_H.DCCODE                                                                                                                               AS DCCODE              /* 물류센터 */
		              , FN_GETDCNAME(DM_DOCUMENT_H.DCCODE)                                                                                                                 AS DCNAME              /* 물류센터명*/
		              , DM_DOCUMENT_H.DELIVERYDATE                                                                                                                         AS DELIVERYDATE        /* 입고일자 */
		              , TO_CHAR(DP_INPLAN_TIME.FROM_INTIME,'HH24:MI')                                                                                                      AS FROM_INTIME         /* FROM_입고예정시간 */
		              , TO_CHAR(DP_INPLAN_TIME.TO_INTIME,'HH24:MI')                                                                                                        AS TO_INTIME           /* TO_입고예정시간 */
		              , DM_DOCUMENT_H.FROM_CUSTKEY                                                                                                                         AS FROM_CUSTKEY        /* 협력사 */
		              , DM_DOCUMENT_H.FROM_CUSTTYPE                                                                                                                        AS FROM_CUSTTYPE       /* 협력사유형 */
		              , MS_CUST.DESCRIPTION                                                                                                                                AS CUSTNAME            /* 협력사명 */
		              , DM_DOCUMENT_H.DOCNO                                                                                                                                AS DOCNO               /* 입고전표번호 */
		              , TO_CHAR((SELECT ADDDATE 
			                       FROM DP_QRSCANLOG SA 
			                      WHERE 1=1
			                        AND SA.STORERKEY    = DM_DOCUMENT_H.STORERKEY
			                        AND SA.DCCODE       = DM_DOCUMENT_H.DCCODE
			                        AND SA.DELIVERYDATE = DM_DOCUMENT_H.DELIVERYDATE 
			                        AND SA.CUSTKEY      = DM_DOCUMENT_H.FROM_CUSTKEY 
			                        AND SA.DOCNO        = DM_DOCUMENT_H.DOCNO),'HH24:MI')                                                                                  AS REAL_INTIEM         /* QR 입문시간 */
		              , DP_UNLOADCARLOG.TEMPERATURE1                                                                                                                       AS TEMPERATURE1        /* 냉장온도 */
		              , DP_UNLOADCARLOG.TEMPERATURE2                                                                                                                       AS TEMPERATURE2        /* 냉동온도 */
		              , CASE WHEN DP_UNLOADCARLOG.DELIVERYTIME IS NOT NULL
			                 THEN SUBSTR(LPAD(TO_CHAR(DP_UNLOADCARLOG.DELIVERYTIME),4,'0'),1,2) || ':' || SUBSTR(LPAD(TO_CHAR(DP_UNLOADCARLOG.DELIVERYTIME),4,'0'),3,2) 
			                 ELSE '' END                                                                                                                                   AS DELIVERYTIME        /* 하차검수시간 */
		              , DM_DOCUMENT_H.CHANNEL                                                                                                                              AS CHANNEL             /* 저장유무 */
		              , FN_CODEDESCR(DM_DOCUMENT_H.STORERKEY,'PUTAWAYTYPE', DM_DOCUMENT_H.CHANNEL)                                                                         AS CHANNEL_NAME        /* 저장유무명 */
		           FROM DM_DOCUMENT_H
		           LEFT OUTER JOIN DP_INPLAN_TIME
		             ON DP_INPLAN_TIME.STORERKEY    = DM_DOCUMENT_H.STORERKEY
		            AND DP_INPLAN_TIME.DELIVERYDATE = DM_DOCUMENT_H.DELIVERYDATE
		            AND DP_INPLAN_TIME.DCCODE       = DM_DOCUMENT_H.DCCODE
		            AND DP_INPLAN_TIME.CUSTKEY      = DM_DOCUMENT_H.FROM_CUSTKEY
		           LEFT OUTER JOIN DP_UNLOADCARLOG
		             ON DP_UNLOADCARLOG.STORERKEY   = DM_DOCUMENT_H.STORERKEY
		            AND DP_UNLOADCARLOG.SLIPNO      = DM_DOCUMENT_H.DOCNO 
		            AND DP_UNLOADCARLOG.SLIPDT      = DM_DOCUMENT_H.DELIVERYDATE 
		            AND DP_UNLOADCARLOG.CUSTKEY     = DM_DOCUMENT_H.FROM_CUSTKEY
		           JOIN MS_CUST
		             ON MS_CUST.STORERKEY           = DM_DOCUMENT_H.STORERKEY
		            AND MS_CUST.CUSTKEY             = DM_DOCUMENT_H.FROM_CUSTKEY
		            AND MS_CUST.CUSTTYPE            = 'P'
		          WHERE 1=1
		            AND DM_DOCUMENT_H.STORERKEY     = #{gStorerkey}
		            AND DM_DOCUMENT_H.DOCTYPE       = 'DP'
				<if test="dccode != null and dccode != ''">   
		            AND DM_DOCUMENT_H.DCCODE        = #{dccode}
				</if>		    
				<if test="deliverydateFrom != null and deliverydateFrom != ''">    		
		            AND DM_DOCUMENT_H.DELIVERYDATE<![CDATA[>=]]> #{deliverydateFrom}   
				</if>
				<if test="deliverydateTo != null and deliverydateTo != ''">      		
		            AND DM_DOCUMENT_H.DELIVERYDATE<![CDATA[<=]]> #{deliverydateTo}     
				</if>	 
				<if test="channel != null and channel != ''">   
		            AND DM_DOCUMENT_H.CHANNEL       = #{channel}
				</if>
				<if test="docno != null and docno != ''">   
		            AND DM_DOCUMENT_H.DOCNO         = #{docno}
				</if>
			    <!-- START.협력사 -->
			    <if test="custkeyMulti != null and custkeyMulti != '' ">
					<trim prefix="AND (" suffix=")" prefixOverrides="OR">
						<foreach collection="custkeyMulti" item="item">
		            OR DM_DOCUMENT_H.FROM_CUSTKEY IN
							<foreach collection="item" item="code" open="(" close=")" separator=",">
								#{code} 	 
				      		</foreach>
				    	</foreach>
				  	</trim>			                                    
			    </if>
			    <!-- END.협력사 -->	
            )
        WHERE 1=1	  
		<if test="diffHour != null and diffHour != ''">   
		  AND REAL_INTIEM IS NOT NULL
		  AND TO_INTIME   IS NOT NULL
          AND ( CASE WHEN   TO_DATE(REGEXP_REPLACE(REAL_INTIEM,'[^0-9:]',''),'HH24:MI')<![CDATA[>=]]> TO_DATE(REGEXP_REPLACE(TO_INTIME,'[^0-9:]',''),'HH24:MI')
                     THEN  (TO_DATE(REGEXP_REPLACE(REAL_INTIEM,'[^0-9:]',''),'HH24:MI')  - TO_DATE(REGEXP_REPLACE(TO_INTIME,'[^0-9:]',''),'HH24:MI')) * 24 * 60
                     ELSE (((TO_DATE(REGEXP_REPLACE(REAL_INTIEM,'[^0-9:]',''),'HH24:MI') - TO_DATE(REGEXP_REPLACE(TO_INTIME,'[^0-9:]',''),'HH24:MI')) + 1) * 24 * 60)
                 END ) <![CDATA[>=]]> (#{diffHour} * 60)
		</if> 		     	
    </select>
    
</mapper>