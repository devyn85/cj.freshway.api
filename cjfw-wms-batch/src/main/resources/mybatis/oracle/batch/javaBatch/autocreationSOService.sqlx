<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="autocreationSOService">
    <sql id="procedureParams">
          AVC_IFID       => #{AVC_IFID,       mode=IN , jdbcType=VARCHAR}
        , AVC_IFRESULT   => #{AVC_IFRESULT,   mode=OUT, jdbcType=VARCHAR}
        , AVC_LOG_PARAMS => #{AVC_LOG_PARAMS, mode=IN , jdbcType=VARCHAR} /*(20250815) BATCH LOG관련 PARAMS.*/	
    </sql>
    <select id="callProcExecute" statementType="CALLABLE" parameterType="BatchParamsUtil" resultType="BatchParamsUtil" timeout="240">
        { CALL SPIF_RECEIVEDATA_REWORK.P_IF_DM_DOCUMENT_FS_EXDC( /* [autocreationSOService.sqlx][callProcExecute][당일매입매출오더수신재처리][김환수][20250801] */
               <include refid="procedureParams"/>
        ) }
    </select>
</mapper>