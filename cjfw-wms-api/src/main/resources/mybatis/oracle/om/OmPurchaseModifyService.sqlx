		      ,IF_DM_DOCUMENT_D.ISSUE_NO
		      ,IF_DM_DOCUMENT_D.MOVE_YN
		      ,IF_DM_DOCUMENT_D.TEMP_YN
		      ,IF_DM_DOCUMENT_D.ADD_YN
		      ,IF_DM_DOCUMENT_D.REF_DOC_NO
		      ,IF_DM_DOCUMENT_D.REF_DOC_LINE
		      ,IF_DM_DOCUMENT_D.QUICK_YN
		      ,IF_DM_DOCUMENT_D.CANCEL_END_YN
		      ,IF_DM_DOCUMENT_D.REF_DOCID
		      ,IF_DM_DOCUMENT_D.REF_CUST_DOCID
		      ,OPEN_TIME
		      ,SYSDATE <!-- ADDDATE -->
		      ,SYSDATE <!-- EDITDATE -->
		      ,#{gUserId} <!-- ADDWHO -->
		      ,#{gUserId} <!-- EDITWHO -->
		  FROM IF_DM_DOCUMENT_D
		 WHERE 1=1
		   AND IF_FLAG        = 'S'
		   AND IF_DESTINATION = 'ASISWMS'
		   AND IF_ID          = 'PJTWMS02'
		   AND DOCNO          = #{slipNo}
		   AND DOCLINE        = #{slipLine}
		   AND (OTHER02       IS NULL OR OTHER02 != 'X')
		   AND STORERKEY      = 'FW00';
		 
		 INSERT INTO IF_RT_FOREQUEST(
                SERIALKEY
               ,STORERKEY
               ,DOCDT
               ,REQUESTDT
               ,REQUESTNO
               ,REQUESTLINE
               ,SKU
               ,UOM
               ,ORDERQTY
               ,IF_DESTINATION
               ,IF_ID
               ,IF_FLAG
               ,IF_SEND_TYPE
               ,IF_SEND_FILE
               ,ADDWHO
               ,EDITWHO
               ,DEL_YN
               )
         SELECT
                SEQ_IF_RT_FOREQUEST.NEXTVAL
               ,STORERKEY
               ,DOCDT
               ,REQUESTDT
               ,REQUESTNO
               ,REQUESTLINE
               ,SKU
               ,UOM
               ,ORDERQTY
               ,IF_DESTINATION
               ,IF_ID
               ,'N'
               ,IF_SEND_TYPE
               ,TO_CHAR(SYSDATE, 'YYYYMMDD:HH24MISS.')||TO_CHAR(SYSTIMESTAMP, 'FF6')
               ,#{gUserId}
               ,#{gUserId}
               ,'D'
          FROM  IF_RT_FOREQUEST
          WHERE REQUESTNO   = #{slipNo}
          AND	REQUESTLINE = #{slipLine}
          AND	DEL_YN      = 'C'
		  ;

    END;           
    </update>
    
    <!-- DEL_YN = 'N'인 DP_INPLAN 건이 있는지 확인 -->
	<select id="getDpInplanDelynN" resultType="HMap">
	/* [omPurchaseModifyService.sqlx][omPurchaseModifyService.getDpInplanDelynN] */
		SELECT SLIPNO
	         , SLIPLINE
		  FROM DP_INPLAN
		 WHERE STORERKEY      = 'FW00'
		   AND SLIPNO         = #{slipNo}
		   AND DEL_YN         = 'N'
	</select>
	
