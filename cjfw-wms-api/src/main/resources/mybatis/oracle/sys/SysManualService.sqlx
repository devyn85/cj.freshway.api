<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="sysManualService">

	<select id="getManualList" resultType="SysManualResDto">
        SELECT /* [sysManualService.sqlx][getManualList][매뉴얼 목록 검색 조회][JGS][2026.01.29] */
		     PROG_CD 									/* 프로그램코드 */      
		    ,PROG_NM 									/* 프로그램명 */      
		    ,SYSTEM_CL 									/* 시스템구분 */   
		    ,PROG_LVL 									/* 프로그램레벨 */     
		    ,PROG_NO 									/* 프로그램내부순번 */      
		    ,PROG_CD AS ROW_ID 							/* 프로그램코드 rowid */
		    ,(
		    	SELECT 
		    		COUNT(*) 
		    	FROM FRAMEONE_TPL_FILE_UPLOAD 
		    	WHERE FRAMEONE_TPL_FILE_UPLOAD.REF_KEY = FRAMEONE_PROGRAM.PROG_CD
		     ) AS FILE_CNT								/* 첨부파일개수 */
		FROM FRAMEONE_PROGRAM
		WHERE 1 = 1
			AND SYSTEM_CL = 'LOGISONE'
			AND USE_YN = '1'
		ORDER BY PROG_NO
    </select>
    
</mapper>