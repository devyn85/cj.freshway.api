<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="omPurchaseModifyService">
	<select id="getMasterListPO" resultType="OmPurchaseModifyResDto">
		SELECT * FROM (
			SELECT /* [omPurchaseModifyService.sqlx][omPurchaseModifyService.getMasterListPO][저장품발주수정 PO HEADER] */
		           '0'                      AS CHECKYN,
		           DP_PURCHASE.REQUESTDT    AS SLIPDT,
		           DP_PURCHASE.DCCODE       AS DCCODE,
		           CM_DC.DCNAME             AS DCNAME,
		           DP_PURCHASE.CUSTKEY      AS CUSTKEY,
		           MS_CUST.DESCRIPTION      AS CUSTNAME,
		           DP_PURCHASE.CUSTTYPE     AS CUSTTYPE,
		           DP_PURCHASE.REQUESTNO    AS REQUESTNO,
		           DP_PURCHASE.REQUESTLINE  AS REQUESTLINE,
		           ''                       AS FROM_DCCODE,
		           ''                       AS FROM_DCNAME,
		           DP_PURCHASE.ORGANIZE     AS ORGANIZE,
		           ''                       AS ORGANIZENAME,
		           DP_PURCHASE.STORERKEY    AS STORERKEY,
		           MS_PURCHASEMST.PURCHASETYPE,
		           MS_PURCHASEMST.DELIVERYTYPE,
		           DP_PURCHASE.POKEY,
		           DP_PURCHASE.POLINE,
		           DP_PURCHASE.SKU,
		           MS_SKU.DESCRIPTION                                                                       AS SKUNAME,
		           DP_PURCHASE.UOM,
		           MS_SKU.PURCHASEUOM,
		           ROUND(DP_PURCHASE.ORDERQTY / NVL(MS_UOM.BUNJA, 1) / NVL(MS_UOM.BUNMO, 1))                 AS ORDERQTY,
		           <!-- DP_PURCHASE.ORDERQTY, -->
		           ST_SNINFO.SERIALNO,
		           ST_SNINFO.STOCKID                                                                        AS BARCODE_SN,
		           ST_SNINFO.CONVSERIALNO,
		           ST_SNINFO.BUTCHERYDT,
		           ST_SNINFO.FACTORYNAME,
		           ST_SNINFO.CONTRACTTYPE              AS CONTRACTTYPE,
		           ST_SNINFO.CONTRACTCUSTKEY                                                                AS CONTRACTCOMPANY,
		           (SELECT DESCRIPTION FROM MS_CUST WHERE CUSTKEY = ST_SNINFO.CONTRACTCUSTKEY AND ROWNUM = 1) AS CONTRACTCOMPANYNAME,
		           ST_SNINFO.FROMVALIDDT,
		           ST_SNINFO.TOVALIDDT,
		           DP_INVOICE_SN.ORDERQTY                                                                   AS SERIALORDERQTY,
		           DP_INVOICE_SN.CONFIRMQTY                                                                 AS SERIALINSPECTQTY,	           
				   FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU, DP_INPLAN.UOM, 'KG', DP_INVOICE_SN.CONFIRMQTY) AS SERIALSCANWEIGHT,
				   DP_PURCHASE.DEL_YN,
				   DP_PURCHASE.ADDWHO AS ADDWHO,
		           DP_PURCHASE.ADDDATE,
		           DP_PURCHASE.EDITWHO AS EDITWHO,
		           DP_PURCHASE.EDITDATE,
		           USER1.USER_NM AS ADDWHO_NM,  /*등록자명*/
				   USER2.USER_NM AS EDITWHO_NM,  /*수정자명*/
				   DP_PURCHASE.CHANNEL,
				   DP_PURCHASE.AREA,
				   MS_PURCHASEMST.ROUTEORGANIZE AS ROUTEORGANIZE,
				   NVL(MS_UOM.BUNJA, 1) AS BUNJA,
				   NVL(MS_UOM.BUNMO, 1) AS BUNMO,
				   CASE
				   WHEN NVL(DP_INPLAN.OPENQTY, 0) = 0 THEN 'Y' ELSE 'N'
				   END AS delProcYn
		      FROM DP_PURCHASE
		      JOIN CM_DC
		        ON CM_DC.DCCODE = DP_PURCHASE.DCCODE
		      JOIN MS_SKU
		        ON DP_PURCHASE.STORERKEY = MS_SKU.STORERKEY
		       AND DP_PURCHASE.SKU = MS_SKU.SKU
		      JOIN MS_CUST
		        ON MS_CUST.STORERKEY = DP_PURCHASE.STORERKEY
		       AND MS_CUST.CUSTKEY = DP_PURCHASE.CUSTKEY
		       AND MS_CUST.CUSTTYPE = DP_PURCHASE.CUSTTYPE	     
		      <choose>
		        <when test='chkPurchase == "Y"'>
		            JOIN MS_PURCHASEMST
		        </when>
		        <otherwise>
		            LEFT OUTER JOIN MS_PURCHASEMST
		        </otherwise>
		      </choose>	      
		        ON MS_PURCHASEMST.STORERKEY = DP_PURCHASE.STORERKEY
		       AND MS_PURCHASEMST.DCCODE = DP_PURCHASE.DCCODE
		       AND MS_PURCHASEMST.CUSTTYPE = DP_PURCHASE.CUSTTYPE
		       AND MS_PURCHASEMST.SKU = DP_PURCHASE.SKU
		      LEFT OUTER JOIN MS_UOM
		        ON MS_SKU.STORERKEY = MS_UOM.STORERKEY
		       AND MS_SKU.SKU = MS_UOM.SKU
		       AND MS_SKU.BASEUOM = MS_UOM.BASEUOM
		       AND MS_SKU.PURCHASEUOM = MS_UOM.UOM
		      LEFT OUTER JOIN MS_UOM
	            ON MS_SKU.STORERKEY   = MS_UOM.STORERKEY
	           AND MS_SKU.SKU         = MS_UOM.SKU
	           AND MS_SKU.BASEUOM     = MS_UOM.BASEUOM
	           AND MS_SKU.PURCHASEUOM = MS_UOM.UOM
		      LEFT OUTER JOIN DM_DOCUMENT_D
		        ON DP_PURCHASE.DCCODE = DM_DOCUMENT_D.DCCODE
		       AND DP_PURCHASE.STORERKEY = DM_DOCUMENT_D.STORERKEY
		       AND DP_PURCHASE.POKEY = DM_DOCUMENT_D.POKEY
		       AND DP_PURCHASE.POLINE = DM_DOCUMENT_D.POLINE
		      LEFT OUTER JOIN DP_INPLAN
		        ON DP_INPLAN.DCCODE = DM_DOCUMENT_D.DCCODE
		       AND DP_INPLAN.STORERKEY = DM_DOCUMENT_D.STORERKEY
		       AND DP_INPLAN.ORGANIZE = DM_DOCUMENT_D.ORGANIZE
		       AND DP_INPLAN.AREA = DM_DOCUMENT_D.AREA
		       AND DP_INPLAN.DOCDT = DM_DOCUMENT_D.DOCDT
		       AND DP_INPLAN.DOCNO = DM_DOCUMENT_D.DOCNO
		       AND DP_INPLAN.DOCLINE = DM_DOCUMENT_D.DOCLINE
		       AND DP_INPLAN.DOCTYPE = DM_DOCUMENT_D.DOCTYPE
		      LEFT OUTER JOIN DP_INVOICE_SN
		        ON DP_INVOICE_SN.DCCODE = DP_INPLAN.DCCODE
		       AND DP_INVOICE_SN.STORERKEY = DP_INPLAN.STORERKEY
		       AND DP_INVOICE_SN.SLIPNO = DP_INPLAN.SLIPNO
		       AND DP_INVOICE_SN.SLIPDT = DP_INPLAN.SLIPDT
		       AND DP_INVOICE_SN.SLIPLINE = DP_INPLAN.SLIPLINE
		       AND DP_INVOICE_SN.DOCTYPE = DP_INPLAN.DOCTYPE
		       AND DP_INVOICE_SN.SKU = DP_INPLAN.SKU
		       AND DP_INVOICE_SN.DEL_YN = 'N'
		      LEFT OUTER JOIN ST_SNINFO
		        ON DP_INVOICE_SN.STORERKEY = ST_SNINFO.STORERKEY
		       AND DP_INVOICE_SN.SKU = ST_SNINFO.SKU
		       AND DP_INVOICE_SN.SERIALNO = ST_SNINFO.SERIALNO
		       AND DP_INVOICE_SN.STOCKID = ST_SNINFO.STOCKID
		       AND DP_INVOICE_SN.DEL_YN = 'N'
		      LEFT JOIN FRAMEONE_USER USER1 ON USER1.USER_ID = DP_PURCHASE.ADDWHO   /*등록자명*/
	          LEFT JOIN FRAMEONE_USER USER2 ON USER2.USER_ID = DP_PURCHASE.EDITWHO  /*수정자명*/	
		     WHERE 1 = 1
		       AND DP_PURCHASE.STORERKEY = #{gStorerkey}
		       AND DP_PURCHASE.REQUESTDT BETWEEN #{slipDtFrom} AND #{slipDtTo}
	        <if test='multiDcCode != null and multiDcCode.length > 0'>
			  AND DP_PURCHASE.DCCODE IN
		        <foreach collection="multiDcCode" item="dccodeItem" open="(" separator="," close=")">
		            #{dccodeItem}
		        </foreach>
			</if>
		    <if test="docNo != null and docNo != ''">
		       AND DP_PURCHASE.POKEY = #{docNo}
		    </if>
		    <if test='partnerCode != null and partnerCode !=""'>
	           AND DP_PURCHASE.CUSTKEY IN
	           (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
	                        FROM (SELECT #{partnerCode} AS VAL FROM DUAL) A
	                     CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
	        </if>
	        <if test='skuCode != null and skuCode !=""'>
	           AND DP_PURCHASE.SKU IN
	           (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
	                        FROM (SELECT #{skuCode} AS VAL FROM DUAL) A
	                     CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
	        </if>
		    <if test="purchaseType != null and purchaseType != ''">
		       AND MS_PURCHASEMST.PURCHASETYPE = #{purchaseType}
		    </if>
		    <if test="deliveryType != null and deliveryType != ''">
		       AND MS_PURCHASEMST.DELIVERYTYPE = #{deliveryType}
		    </if>
		    <if test="buyerKey != null and buyerKey != ''">
		       AND MS_PURCHASEMST.BUYERKEY = #{buyerKey}
		    </if>
		    UNION ALL
			SELECT 
		           '0'                      AS CHECKYN,
		           DP_DM_D.DELIVERYDATE     AS SLIPDT,
		           DP_DM_D.DCCODE           AS DCCODE,
		           CM_DC.DCNAME             AS DCNAME,
		           DP_DM_H.FROM_CUSTKEY     AS CUSTKEY,
		           DP_DM_H.FROM_CUSTNAME    AS CUSTNAME,
		           PC.CUSTTYPE              AS CUSTTYPE,
		           ''                       AS REQUESTNO,
		           ''                       AS REQUESTLINE,
		           ''                       AS FROM_DCCODE,
		           ''                       AS FROM_DCNAME,
		           DP_DM_D.ORGANIZE         AS ORGANIZE,
		           ''                       AS ORGANIZENAME,
		           DP_DM_D.STORERKEY        AS STORERKEY,
		           PC.PURCHASETYPE          AS PURCHASETYPE,
		           'STD'                    AS DELIVERYTYPE,
		           DP_DM_D.DOCNO            AS POKEY,
		           DP_DM_D.DOCLINE          AS POLINE,
		           DP_DM_D.SKU              AS SKU,
		           MS_SKU.DESCRIPTION       AS SKUNAME,
		           DP_DM_D.UOM              AS UOM,
		           MS_SKU.PURCHASEUOM       AS PURCHASEUOM,       
		           DP_DM_D.ORDERQTY         AS ORDERQTY,
		           ST_SNINFO.SERIALNO       AS SERIALNO,
		           ST_SNINFO.STOCKID        AS BARCODE_SN,
		           ST_SNINFO.CONVSERIALNO   AS CONVSERIALNO,
		           ST_SNINFO.BUTCHERYDT     AS BUTCHERYDT,
		           ST_SNINFO.FACTORYNAME    AS FACTORYNAME,
		           ST_SNINFO.CONTRACTTYPE   AS CONTRACTTYPE,
		           ST_SNINFO.CONTRACTCUSTKEY AS CONTRACTCOMPANY,
		           SUB_CUST2.DESCRIPTION    AS CONTRACTCOMPANYNAME,
		           ST_SNINFO.FROMVALIDDT    AS FROMVALIDDT,
		           ST_SNINFO.TOVALIDDT      AS TOVALIDDT,
		           DP_INVOICE_SN.ORDERQTY   AS SERIALORDERQTY,
		           DP_INVOICE_SN.CONFIRMQTY AS SERIALINSPECTQTY,	           
		           FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU, DP_INPLAN.UOM, 'KG', DP_INVOICE_SN.CONFIRMQTY) AS SERIALSCANWEIGHT,
		           DP_DM_D.DEL_YN           AS DEL_YN,
		           DP_DM_D.ADDWHO           AS ADDWHO,
		           DP_DM_D.ADDDATE          AS ADDDATE,
		           DP_DM_D.EDITWHO          AS EDITWHO,
		           DP_DM_D.EDITDATE         AS EDITDATE,
		           USER1.USER_NM            AS ADDWHO_NM,
		           USER2.USER_NM            AS EDITWHO_NM,
		           DP_DM_D.CHANNEL          AS CHANNEL,
		           DP_DM_D.AREA             AS AREA,
		           ''                       AS ROUTEORGANIZE,
		           NVL(DP_DM_D.BUNJA, 1)    AS BUNJA,
		           NVL(DP_DM_D.BUNMO, 1)    AS BUNMO,
		           'N'                      AS DELPROCYN
		      FROM DM_DOCUMENT_D DP_DM_D
		      JOIN DM_DOCUMENT_H DP_DM_H 
		           ON DP_DM_H.DOCDT = DP_DM_D.DOCDT AND DP_DM_H.DOCNO = DP_DM_D.DOCNO 
		           AND DP_DM_H.DELIVERYDATE = DP_DM_D.DELIVERYDATE AND DP_DM_H.DOCTYPE = 'DP'
		      JOIN CM_DC ON CM_DC.DCCODE = DP_DM_D.DCCODE
		      JOIN MS_SKU ON DP_DM_D.STORERKEY = MS_SKU.STORERKEY AND DP_DM_D.SKU = MS_SKU.SKU
		      LEFT OUTER JOIN (
		          SELECT STORERKEY, DCCODE, SKU, MAX(CUSTTYPE) AS CUSTTYPE, MAX(PURCHASETYPE) AS PURCHASETYPE, MAX(BUYERKEY) AS BUYERKEY
		          FROM MS_PURCHASECUST
		          WHERE SERIALKEY = (SELECT MIN(DD.SERIALKEY) KEEP (DENSE_RANK FIRST ORDER BY DD.FROMDATE DESC, DD.TODATE ASC)
	                                                  FROM MS_PURCHASECUST DD
	                                                 WHERE DD.DCCODE = MS_PURCHASECUST.DCCODE
	                                                   AND DD.STORERKEY = MS_PURCHASECUST.STORERKEY
	                                                   AND DD.SKU = MS_PURCHASECUST.SKU
	                                                   AND DD.CHANNEL = MS_PURCHASECUST.CHANNEL
	                                                   AND DD.PLANT = MS_PURCHASECUST.PLANT
	                                                   AND DD.CUSTKEY = MS_PURCHASECUST.CUSTKEY
	                                                   AND TO_CHAR(SYSDATE, 'YYYYMMDD') BETWEEN DD.FROMDATE AND DD.TODATE)
		          GROUP BY STORERKEY, DCCODE, SKU
		      ) PC ON PC.STORERKEY = DP_DM_D.STORERKEY AND PC.DCCODE = DP_DM_D.DCCODE AND PC.SKU = DP_DM_D.SKU
		      LEFT OUTER JOIN DP_INPLAN 
		           ON DP_INPLAN.DCCODE = DP_DM_D.DCCODE AND DP_INPLAN.STORERKEY = DP_DM_D.STORERKEY 
		           AND DP_INPLAN.ORGANIZE = DP_DM_D.ORGANIZE AND DP_INPLAN.AREA = DP_DM_D.AREA 
		           AND DP_INPLAN.DOCDT = DP_DM_D.DOCDT AND DP_INPLAN.DOCNO = DP_DM_D.DOCNO 
		           AND DP_INPLAN.DOCLINE = DP_DM_D.DOCLINE AND DP_INPLAN.DOCTYPE = DP_DM_D.DOCTYPE
		      LEFT OUTER JOIN DP_INVOICE_SN 
		           ON DP_INVOICE_SN.DCCODE = DP_INPLAN.DCCODE AND DP_INVOICE_SN.STORERKEY = DP_INPLAN.STORERKEY 
		           AND DP_INVOICE_SN.SLIPNO = DP_INPLAN.SLIPNO AND DP_INVOICE_SN.SLIPDT = DP_INPLAN.SLIPDT 
		           AND DP_INVOICE_SN.SLIPLINE = DP_INPLAN.SLIPLINE AND DP_INVOICE_SN.DOCTYPE = DP_INPLAN.DOCTYPE 
		           AND DP_INVOICE_SN.SKU = DP_INPLAN.SKU AND DP_INVOICE_SN.DEL_YN = 'N'
		      LEFT OUTER JOIN ST_SNINFO 
		           ON DP_INVOICE_SN.STORERKEY = ST_SNINFO.STORERKEY AND DP_INVOICE_SN.SKU = ST_SNINFO.SKU 
		           AND DP_INVOICE_SN.SERIALNO = ST_SNINFO.SERIALNO AND DP_INVOICE_SN.STOCKID = ST_SNINFO.STOCKID AND ST_SNINFO.DEL_YN = 'N'
		      LEFT OUTER JOIN MS_CUST SUB_CUST2 ON SUB_CUST2.CUSTKEY = ST_SNINFO.CONTRACTCUSTKEY 
		      LEFT JOIN FRAMEONE_USER USER1 ON USER1.USER_ID = DP_DM_D.ADDWHO
		      LEFT JOIN FRAMEONE_USER USER2 ON USER2.USER_ID = DP_DM_D.EDITWHO
		     WHERE DP_DM_D.WORKPROCESSCODE = 'PO'
		       AND DP_DM_D.IF_SEND_TYPE = 'STOFS'
		       AND DP_DM_D.IF_SEND_FILE = 'CK'
		       AND DP_DM_D.DELIVERYDATE BETWEEN #{slipDtFrom} AND #{slipDtTo}
		       <if test='multiDcCode != null and multiDcCode.length > 0'>
			   AND DP_DM_D.DCCODE IN
		        <foreach collection="multiDcCode" item="dccodeItem" open="(" separator="," close=")">
		            #{dccodeItem}
		        </foreach>
			   </if>
			   <if test="docNo != null and docNo != ''">
			       AND DP_DM_D.DOCNO = #{docNo}
			   </if>
			   <if test='partnerCode != null and partnerCode !=""'>
		           AND DP_DM_H.FROM_CUSTKEY IN
		           (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
		                        FROM (SELECT #{partnerCode} AS VAL FROM DUAL) A
		                     CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
		       </if>
		       <if test='skuCode != null and skuCode !=""'>
		           AND DP_DM_D.SKU IN
		           (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
		                        FROM (SELECT #{skuCode} AS VAL FROM DUAL) A
		                     CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
		       </if>
			   <if test="purchaseType != null and purchaseType != ''">
			       AND PC.PURCHASETYPE = #{purchaseType}
			   </if>
			   <if test="deliveryType != null and deliveryType != ''">
			       AND PC.DELIVERYTYPE = #{deliveryType}
			   </if>
			   <if test="buyerKey != null and buyerKey != ''">
			       AND PC.BUYERKEY = #{buyerKey}
			   </if>
		)
		ORDER BY SLIPDT, DCCODE, CUSTKEY, REQUESTNO	
	</select>

	<!--select id="getMasterListPO" resultType="OmPurchaseModifyResDto">
		SELECT /* [omPurchaseModifyService.sqlx][omPurchaseModifyService.getMasterListPO][저장품발주수정 PO HEADER] */
	           '0'                      AS CHECKYN,
	           DP_PURCHASE.REQUESTDT    AS SLIPDT,
	           DP_PURCHASE.DCCODE       AS DCCODE,
	           CM_DC.DCNAME             AS DCNAME,
	           DP_PURCHASE.CUSTKEY      AS CUSTKEY,
	           MS_CUST.DESCRIPTION      AS CUSTNAME,
	           DP_PURCHASE.CUSTTYPE     AS CUSTTYPE,
	           DP_PURCHASE.REQUESTNO    AS REQUESTNO,
	           ''                       AS FROM_DCCODE,
	           ''                       AS FROM_DCNAME,
	           ''                       AS ORGANIZE,
	           ''                       AS ORGANIZENAME,
	           DP_PURCHASE.STORERKEY    AS STORERKEY
	      FROM DP_PURCHASE
	      JOIN CM_DC
	        ON CM_DC.DCCODE = DP_PURCHASE.DCCODE
	      JOIN MS_SKU
	        ON DP_PURCHASE.STORERKEY = MS_SKU.STORERKEY
	       AND DP_PURCHASE.SKU = MS_SKU.SKU
	      JOIN MS_CUST
	        ON MS_CUST.STORERKEY = DP_PURCHASE.STORERKEY
	       AND MS_CUST.CUSTKEY = DP_PURCHASE.CUSTKEY
	       AND MS_CUST.CUSTTYPE = DP_PURCHASE.CUSTTYPE
	    <choose>
	        <when test='chkPurchase == "Y"'>
	            JOIN MS_PURCHASEMST
	        </when>
	        <otherwise>
	            LEFT OUTER JOIN MS_PURCHASEMST
	        </otherwise>
	    </choose>
	        ON MS_PURCHASEMST.STORERKEY = DP_PURCHASE.STORERKEY
	       AND MS_PURCHASEMST.DCCODE = DP_PURCHASE.DCCODE
	       AND MS_PURCHASEMST.CUSTTYPE = DP_PURCHASE.CUSTTYPE
	       AND MS_PURCHASEMST.SKU = DP_PURCHASE.SKU
	     WHERE 1 = 1
	       AND DP_PURCHASE.STORERKEY = #{gStorerkey}
	       AND DP_PURCHASE.REQUESTDT BETWEEN #{slipDtFrom} AND #{slipDtTo}
	       AND DP_PURCHASE.DCCODE = #{dcCode}
	    <if test="docNo != null and docNo != ''">
	        AND DP_PURCHASE.POKEY = #{docNo}
	    </if>
	    <if test='partnerCode != null and partnerCode !=""'>
          AND DP_PURCHASE.CUSTKEY IN
          (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
                        FROM (SELECT #{partnerCode} AS VAL FROM DUAL) A
                     CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
        </if>
        <if test='skuCode != null and skuCode !=""'>
          AND DP_PURCHASE.SKU IN
          (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
                        FROM (SELECT #{skuCode} AS VAL FROM DUAL) A
                     CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
        </if>
	    <if test="purchaseType != null and purchaseType != ''">
	        AND MS_PURCHASEMST.PURCHASETYPE = #{purchaseType}
	    </if>
	    <if test="deliveryType != null and deliveryType != ''">
	        AND MS_PURCHASEMST.DELIVERYTYPE = #{deliveryType}
	    </if>
	    <if test="buyerKey != null and buyerKey != ''">
	        AND MS_PURCHASEMST.BUYERKEY = #{buyerKey}
	    </if>
	     GROUP BY DP_PURCHASE.REQUESTDT,
	              DP_PURCHASE.DCCODE,
	              CM_DC.DCNAME,
	              DP_PURCHASE.CUSTKEY,
	              MS_CUST.DESCRIPTION,
	              DP_PURCHASE.CUSTTYPE,
	              DP_PURCHASE.REQUESTNO,
	              DP_PURCHASE.STORERKEY
	     ORDER BY DP_PURCHASE.REQUESTDT,
	              DP_PURCHASE.DCCODE,
	              DP_PURCHASE.CUSTKEY,
	              DP_PURCHASE.REQUESTNO

    <select-->
    
    <select id="getDetailListPO" resultType="OmPurchaseModifyResDto">
		SELECT /* [omPurchaseModifyService.sqlx][omPurchaseModifyService.getDetailListPO][저장품발주수정 PO DETAIL 조회] */
	           '0'                                                                                      AS CHECKYN,
	           FN_CODEDESCR(MS_PURCHASEMST.STORERKEY, 'PURCHASETYPE_PO', MS_PURCHASEMST.PURCHASETYPE)     AS PURCHASETYPE,
	           FN_CODEDESCR(MS_PURCHASEMST.STORERKEY, 'DIRECTTYPE', MS_PURCHASEMST.DELIVERYTYPE)         AS DELIVERYTYPE,
	           DP_PURCHASE.POKEY,
	           DP_PURCHASE.POLINE,
	           DP_PURCHASE.SKU,
	           MS_SKU.DESCRIPTION                                                                       AS SKUNAME,
	           DP_PURCHASE.UOM,
	           MS_SKU.PURCHASEUOM,
	           ROUND(DP_PURCHASE.ORDERQTY / NVL(MS_UOM.BUNJA, 1) / NVL(MS_UOM.BUNMO, 1))                 AS ORDERQTY,
	           ST_SNINFO.SERIALNO,
	           ST_SNINFO.STOCKID                                                                        AS BARCODE_SN,
	           ST_SNINFO.CONVSERIALNO,
	           ST_SNINFO.BUTCHERYDT,
	           ST_SNINFO.FACTORYNAME,
	           FN_CODEDESCR(ST_SNINFO.STORERKEY, 'CONTRACTTYPE_SN', ST_SNINFO.CONTRACTTYPE)              AS CONTRACTTYPE,
	           ST_SNINFO.CONTRACTCUSTKEY                                                                AS CONTRACTCOMPANY,
	           (SELECT DESCRIPTION FROM MS_CUST WHERE CUSTKEY = ST_SNINFO.CONTRACTCUSTKEY AND ROWNUM = 1) AS CONTRACTCOMPANYNAME,
	           ST_SNINFO.FROMVALIDDT,
	           ST_SNINFO.TOVALIDDT,
	           DP_INVOICE_SN.ORDERQTY                                                                   AS SERIALORDERQTY,
	           DP_INVOICE_SN.CONFIRMQTY                                                                 AS SERIALINSPECTQTY,
	           FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU, DP_INPLAN.UOM, 'KG', DP_INVOICE_SN.CONFIRMQTY) AS SERIALSCANWEIGHT,
	           DP_PURCHASE.STORERKEY,
	           DP_PURCHASE.REQUESTDT                                                                    AS SLIPDT,
	           DP_PURCHASE.DCCODE,
	           CM_DC.DCNAME,
	           DP_PURCHASE.CUSTKEY,
	           MS_CUST.DESCRIPTION                                                                      AS CUSTNAME,
	           DP_PURCHASE.CUSTTYPE,
	           DP_PURCHASE.REQUESTNO,
	           DP_PURCHASE.REQUESTLINE,
	           DP_PURCHASE.DEL_YN,
	           DP_PURCHASE.ADDWHO AS ADDWHO,
	           DP_PURCHASE.ADDDATE,
	           DP_PURCHASE.EDITWHO AS EDITWHO,
	           DP_PURCHASE.EDITDATE,
	           USER1.USER_NM AS ADDWHO_NM,  /*등록자명*/
			   USER2.USER_NM AS EDITWHO_NM  /*수정자명*/
	      FROM DP_PURCHASE
	      JOIN CM_DC
	        ON CM_DC.DCCODE = DP_PURCHASE.DCCODE
	      JOIN MS_SKU
	        ON DP_PURCHASE.STORERKEY = MS_SKU.STORERKEY
	       AND DP_PURCHASE.SKU = MS_SKU.SKU
	      LEFT OUTER JOIN DM_DOCUMENT_D
	        ON DP_PURCHASE.DCCODE = DM_DOCUMENT_D.DCCODE
	       AND DP_PURCHASE.STORERKEY = DM_DOCUMENT_D.STORERKEY
	       AND DP_PURCHASE.ORGANIZE = DM_DOCUMENT_D.ORGANIZE
	       AND DP_PURCHASE.AREA = DM_DOCUMENT_D.AREA
	       AND DP_PURCHASE.POKEY = DM_DOCUMENT_D.POKEY
	       AND DP_PURCHASE.POLINE = DM_DOCUMENT_D.POLINE
	      LEFT OUTER JOIN DP_INPLAN
	        ON DP_INPLAN.DCCODE = DM_DOCUMENT_D.DCCODE
	       AND DP_INPLAN.STORERKEY = DM_DOCUMENT_D.STORERKEY
	       AND DP_INPLAN.ORGANIZE = DM_DOCUMENT_D.ORGANIZE
	       AND DP_INPLAN.AREA = DM_DOCUMENT_D.AREA
	       AND DP_INPLAN.DOCDT = DM_DOCUMENT_D.DOCDT
	       AND DP_INPLAN.DOCNO = DM_DOCUMENT_D.DOCNO
	       AND DP_INPLAN.DOCLINE = DM_DOCUMENT_D.DOCLINE
	       AND DP_INPLAN.DOCTYPE = DM_DOCUMENT_D.DOCTYPE
	      LEFT OUTER JOIN DP_INVOICE_SN
	        ON DP_INVOICE_SN.DCCODE = DP_INPLAN.DCCODE
	       AND DP_INVOICE_SN.STORERKEY = DP_INPLAN.STORERKEY
	       AND DP_INVOICE_SN.SLIPNO = DP_INPLAN.SLIPNO
	       AND DP_INVOICE_SN.SLIPDT = DP_INPLAN.SLIPDT
	       AND DP_INVOICE_SN.SLIPLINE = DP_INPLAN.SLIPLINE
	       AND DP_INVOICE_SN.DOCTYPE = DP_INPLAN.DOCTYPE
	       AND DP_INVOICE_SN.SKU = DP_INPLAN.SKU
	       AND DP_INVOICE_SN.DEL_YN = 'N'
	      LEFT OUTER JOIN ST_SNINFO
	        ON DP_INVOICE_SN.STORERKEY = ST_SNINFO.STORERKEY
	       AND DP_INVOICE_SN.SKU = ST_SNINFO.SKU
	       AND DP_INVOICE_SN.SERIALNO = ST_SNINFO.SERIALNO
	       AND DP_INVOICE_SN.STOCKID = ST_SNINFO.STOCKID
	       AND DP_INVOICE_SN.DEL_YN = 'N'
	      JOIN MS_CUST
	        ON MS_CUST.STORERKEY = DP_PURCHASE.STORERKEY
	       AND MS_CUST.CUSTKEY = DP_PURCHASE.CUSTKEY
	       AND MS_CUST.CUSTTYPE = DP_PURCHASE.CUSTTYPE
	      LEFT OUTER JOIN MS_UOM
	        ON MS_SKU.STORERKEY = MS_UOM.STORERKEY
	       AND MS_SKU.SKU = MS_UOM.SKU
	       AND MS_SKU.BASEUOM = MS_UOM.BASEUOM
	       AND MS_SKU.PURCHASEUOM = MS_UOM.UOM
	      LEFT JOIN FRAMEONE_USER USER1 ON USER1.USER_ID = DP_PURCHASE.ADDWHO   /*등록자명*/
          LEFT JOIN FRAMEONE_USER USER2 ON USER2.USER_ID = DP_PURCHASE.EDITWHO  /*수정자명*/
	    <choose>
	        <when test='chkPurchase == "Y"'>
	            JOIN MS_PURCHASEMST
	        </when>
	        <otherwise>
	            LEFT OUTER JOIN MS_PURCHASEMST
	        </otherwise>
	    </choose>
	        ON MS_PURCHASEMST.STORERKEY = DP_PURCHASE.STORERKEY
	       AND MS_PURCHASEMST.DCCODE = DP_PURCHASE.DCCODE
	       AND MS_PURCHASEMST.CUSTTYPE = DP_PURCHASE.CUSTTYPE
	       AND MS_PURCHASEMST.SKU = DP_PURCHASE.SKU
	     WHERE 1 = 1
	       AND DP_PURCHASE.STORERKEY = #{gStorerkey}
	       AND DP_PURCHASE.REQUESTDT = #{slipDt}
	    <if test='multiDcCode != null and multiDcCode.length > 0'>
		  AND DP_PURCHASE.DCCODE IN
	        <foreach collection="multiDcCode" item="dccodeItem" open="(" separator="," close=")">
	            #{dccodeItem}
	        </foreach>
		</if>
	       AND DP_PURCHASE.CUSTKEY = #{custKey}
	       AND DP_PURCHASE.REQUESTNO = #{requestNo}
	    <if test="docNo != null and docNo != ''">
	       AND DP_PURCHASE.POKEY = #{docNo}
	    </if>
        <if test='skuCode != null and skuCode !=""'>
          AND DP_PURCHASE.SKU IN
          (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
                        FROM (SELECT #{skuCode} AS VAL FROM DUAL) A
                     CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
        </if>
	    <if test="purchaseType != null and purchaseType != ''">
	       AND MS_PURCHASEMST.PURCHASETYPE = #{purchaseType}
	    </if>
	    <if test="deliveryType != null and deliveryType != ''">
	       AND MS_PURCHASEMST.DELIVERYTYPE = #{deliveryType}
	    </if>
	    <if test="buyerKey != null and buyerKey != ''">
	       AND MS_PURCHASEMST.BUYERKEY = #{buyerKey}
	    </if>
	     ORDER BY DP_PURCHASE.SKU

    </select>
    
    <select id="getMasterListSTO" resultType="OmPurchaseModifyResDto">
        SELECT /* [omPurchaseModifyService.sqlx][omPurchaseModifyService.getMasterListSTO][저장품발주수정 STO MASTER 조회] */
             DP_DM_H.DELIVERYDATE                     AS SLIPDT
             , DP_DM_H.DOCNO                            AS DOCNO
             , DP_DM_H.DCCODE                           AS DCCODE
             , DP_DM_H.ORGANIZE                         AS ORGANIZE
             , DP_INPLAN.AREA                           AS AREA
             , FN_GETDCNAME(DP_DM_H.DCCODE)             AS DCNAME
             , WD_DM_H.DCCODE                           AS FROM_DCCODE
             , FN_GETDCNAME(WD_DM_H.DCCODE)             AS FROM_DCNAME
             , WD_DM_H.ORGANIZE                         AS FROM_ORGANIZE
             , CM_DCXORGANIZE.DESCRIPTION               AS FROM_ORGANIZENAME
             , DP_DM_H.STORERKEY                        AS STORERKEY             
             , (SELECT MAX(MS_PURCHASEMST.PURCHASETYPE)
                       FROM MS_PURCHASECUST
                       JOIN MS_PURCHASEMST 
                         ON MS_PURCHASECUST.STORERKEY = MS_PURCHASEMST.STORERKEY
                        AND MS_PURCHASECUST.DCCODE    = MS_PURCHASEMST.DCCODE
                        AND MS_PURCHASECUST.CUSTTYPE  = MS_PURCHASEMST.CUSTTYPE
                        AND MS_PURCHASECUST.SKU       = MS_PURCHASEMST.SKU
                      WHERE MS_PURCHASECUST.STORERKEY     = DP_DM_D.STORERKEY
                        AND MS_PURCHASECUST.DCCODE        = DP_DM_D.DCCODE
                        AND MS_PURCHASECUST.SKU           = DP_DM_D.SKU) AS PURCHASETYPE
             , FN_CODEDESCR(DP_INPLAN.STORERKEY, 'DIRECTTYPE'
             , (SELECT MAX(MS_PURCHASEMST.DELIVERYTYPE)
                       FROM MS_PURCHASECUST
                       JOIN MS_PURCHASEMST 
                         ON MS_PURCHASECUST.STORERKEY = MS_PURCHASEMST.STORERKEY
                        AND MS_PURCHASECUST.DCCODE    = MS_PURCHASEMST.DCCODE
                        AND MS_PURCHASECUST.CUSTTYPE  = MS_PURCHASEMST.CUSTTYPE
                        AND MS_PURCHASECUST.SKU       = MS_PURCHASEMST.SKU
                      WHERE MS_PURCHASECUST.STORERKEY     = DP_DM_D.STORERKEY
                        AND MS_PURCHASECUST.DCCODE        = DP_DM_D.DCCODE
                        AND MS_PURCHASECUST.SKU           = DP_DM_D.SKU)
               )                                        AS DELIVERYTYPE
             , DP_INPLAN.SLIPNO                         AS SLIPNO
             , DP_INPLAN.SLIPLINE                       AS SLIPLINE
             , DP_INPLAN.SKU                            AS SKU
             , MS_SKU.DESCRIPTION                       AS SKUNAME
             , DP_INPLAN.UOM                            AS UOM
             , CASE WHEN WD_DM_H.DCCODE NOT IN ('2170','2690') THEN
                     CASE WHEN WD_DM_H.DCCODE = '1000' THEN 
                          CASE WHEN WD_DM_H.ORGANIZE IN ('1000-1260','1000-1400') THEN DP_INPLAN.UOM
                               ELSE MS_SKU.PURCHASEUOM 
                          END 
                          ELSE DP_INPLAN.UOM
                     END 
                     ELSE MS_SKU.PURCHASEUOM 
               END                                      AS PURCHASEUOM
              , CASE WHEN WD_DM_H.DCCODE NOT IN ('2170','2690') THEN
                     CASE WHEN WD_DM_H.DCCODE = '1000' THEN 
                          CASE WHEN WD_DM_H.ORGANIZE IN ('1000-1260','1000-1400') THEN DP_INPLAN.ORDERQTY
                               ELSE DP_INPLAN.ORDERQTY 
                          END 
                          ELSE DP_INPLAN.ORDERQTY
                     END 
                     ELSE DP_INPLAN.ORDERQTY 
               END                                      AS ORDERQTY               
             <!-- , ROUND(DP_INPLAN.ORDERQTY/NVL(MS_UOM.BUNJA, 1)/NVL(MS_UOM.BUNMO, 1)) AS ORDERQTY -->
             , ST_SNINFO.SERIALNO                       AS SERIALNO
             , NVL(ST_SNINFO.STOCKID, WD_DM_D.STOCKID)  AS BARCODE_SN
             , ST_SNINFO.CONVSERIALNO                   AS CONVSERIALNO
             , ST_SNINFO.BUTCHERYDT                     AS BUTCHERYDT
             , ST_SNINFO.FACTORYNAME                    AS FACTORYNAME
             , FN_CODEDESCR(ST_SNINFO.STORERKEY, 'CONTRACTTYPE_SN', ST_SNINFO.CONTRACTTYPE) AS CONTRACTTYPE 
             , ST_SNINFO.CONTRACTCUSTKEY                AS CONTRACTCOMPANY
             , (SELECT DESCRIPTION FROM MS_CUST WHERE CUSTKEY = ST_SNINFO.CONTRACTCUSTKEY AND ROWNUM = 1) AS CONTRACTCOMPANYNAME
             , ST_SNINFO.FROMVALIDDT                    AS FROMVALIDDT
             , ST_SNINFO.TOVALIDDT                      AS TOVALIDDT
             , DP_INVOICE_SN.ORDERQTY                   AS SERIALORDERQTY       
             , DP_INVOICE_SN.CONFIRMQTY                 AS SERIALINSPECTQTY     
             , CASE WHEN DP_INPLAN.STORERKEY = 'CJFW' THEN 
                         CASE WHEN DP_INPLAN.UOM = 'KG' THEN DP_INVOICE_SN.CONFIRMQTY
                              ELSE DP_INVOICE_SN.CONFIRMQTY * ST_SNINFO.NETWEIGHT
                         END                                                                                                            
                    ELSE FN_CONV_UOM(DP_INPLAN.STORERKEY,DP_INPLAN.SKU,DP_INPLAN.UOM,'KG',DP_INVOICE_SN.CONFIRMQTY) 
               END                                      AS SERIALSCANWEIGHT
             , DP_DM_D.DEL_YN                           AS DEL_YN
             , CASE WHEN DP_DM_D.IF_SEND_FILE = 'CK' THEN 'N'
                    WHEN DP_DM_D.STATUS = '30' AND WD_DM_D.STATUS = '30' THEN 'Y'                    
                    ELSE 'N'
               END                                      AS DEL_PROC_YN
             , MS_UOM.BUNJA
			 , MS_UOM.BUNMO
			 , (SELECT FN_CONV_UOM(DP_INPLAN.STORERKEY, MS_SKU.SKU, MS_SKU.PURCHASEUOM, 'EA', 1) FROM DUAL) AS EA_CAL
             , DP_INPLAN.ADDWHO AS ADDWHO
	         , DP_INPLAN.ADDDATE
	         , DP_INPLAN.EDITWHO AS EDITWHO
	         , DP_INPLAN.EDITDATE
	         , USER1.USER_NM AS ADDWHO_NM  /*등록자명*/
			 , USER2.USER_NM AS EDITWHO_NM  /*수정자명*/
			 , DP_INPLAN.AREA
			 , (SELECT CASE WHEN NVL(MAX(SERIALKEY), 0) = 0 THEN 'N'
                            ELSE 'Y' END AS ALLOCATION_YN
                FROM OM_SDY_REGN_REPL_D
                JOIN WD_TASK
                ON   WD_TASK.DCCODE     = DP_DM_H.DCCODE
                AND  WD_TASK.STORERKEY  = DP_DM_H.STORERKEY
                AND  WD_TASK.DOCNO      = OM_SDY_REGN_REPL_D.SOKEY
                AND  WD_TASK.DOCLINE    = OM_SDY_REGN_REPL_D.SOLINE
                AND  WD_TASK.TASKSYSTEM  IS NOT NULL
                AND  WD_TASK.PROCESSQTY <![CDATA[>]]> 0
                AND  WD_TASK.DEL_YN     = 'N'
                WHERE OM_SDY_REGN_REPL_D.DOCNO = DP_DM_H.DOCNO
                AND OM_SDY_REGN_REPL_D.MOVE_DT = DP_DM_H.DELIVERYDATE) AS ALLOCATION_YN
          FROM DM_DOCUMENT_H DP_DM_H
          JOIN DM_DOCUMENT_H WD_DM_H 
            ON WD_DM_H.DOCDT        = DP_DM_H.DOCDT
           AND WD_DM_H.DOCNO        = DP_DM_H.DOCNO
           AND WD_DM_H.DELIVERYDATE = DP_DM_H.DELIVERYDATE
           AND WD_DM_H.DOCTYPE      = 'WD'
          LEFT OUTER JOIN CM_DCXORGANIZE 
            ON CM_DCXORGANIZE.DCCODE   = WD_DM_H.DCCODE
           AND CM_DCXORGANIZE.ORGANIZE = WD_DM_H.ORGANIZE
          JOIN DM_DOCUMENT_D DP_DM_D 
            ON DP_DM_D.DOCDT   = DP_DM_H.DOCDT
           AND DP_DM_D.DOCTYPE = DP_DM_H.DOCTYPE
           AND DP_DM_D.DOCNO   = DP_DM_H.DOCNO
           AND DP_DM_D.STATUS  = '30'
          JOIN DP_INPLAN
            ON DP_INPLAN.DCCODE    = DP_DM_D.DCCODE
           AND DP_INPLAN.STORERKEY = DP_DM_D.STORERKEY
           AND DP_INPLAN.ORGANIZE  = DP_DM_D.ORGANIZE
           AND DP_INPLAN.DOCDT     = DP_DM_D.DOCDT
           AND DP_INPLAN.DOCNO     = DP_DM_D.DOCNO
           AND DP_INPLAN.DOCLINE   = DP_DM_D.DOCLINE
           AND DP_INPLAN.DOCTYPE   = DP_DM_D.DOCTYPE
           AND DP_INPLAN.STATUS    = '00'
          LEFT OUTER JOIN DP_INVOICE_SN        
            ON DP_INVOICE_SN.DCCODE    = DP_INPLAN.DCCODE                          
           AND DP_INVOICE_SN.STORERKEY = DP_INPLAN.STORERKEY                       
           AND DP_INVOICE_SN.SLIPNO    = DP_INPLAN.SLIPNO                                           
           AND DP_INVOICE_SN.SLIPDT    = DP_INPLAN.SLIPDT                          
           AND DP_INVOICE_SN.SLIPLINE  = DP_INPLAN.SLIPLINE       
           AND DP_INVOICE_SN.DOCTYPE   = DP_INPLAN.DOCTYPE       
           AND DP_INVOICE_SN.SKU       = DP_INPLAN.SKU           
           AND DP_INVOICE_SN.DEL_YN    = 'N'             
          LEFT OUTER JOIN ST_SNINFO           
            ON DP_INVOICE_SN.STORERKEY = ST_SNINFO.STORERKEY          
           AND DP_INVOICE_SN.SKU       = ST_SNINFO.SKU          
           AND DP_INVOICE_SN.SERIALNO  = ST_SNINFO.SERIALNO          
           AND DP_INVOICE_SN.STOCKID   = ST_SNINFO.STOCKID          
           AND DP_INVOICE_SN.DEL_YN    = 'N'
          JOIN MS_SKU
            ON DP_INPLAN.STORERKEY = MS_SKU.STORERKEY
           AND DP_INPLAN.SKU       = MS_SKU.SKU
          LEFT OUTER JOIN MS_UOM
            ON MS_SKU.STORERKEY   = MS_UOM.STORERKEY
           AND MS_SKU.SKU         = MS_UOM.SKU
           AND MS_SKU.BASEUOM     = MS_UOM.BASEUOM
           AND MS_SKU.PURCHASEUOM = MS_UOM.UOM
          LEFT OUTER JOIN MS_UOM
		    ON MS_SKU.STORERKEY           = MS_UOM.STORERKEY
		   AND MS_SKU.SKU                 = MS_UOM.SKU
		   AND MS_SKU.BASEUOM             = MS_UOM.BASEUOM
		   AND MS_SKU.PURCHASEUOM         = MS_UOM.UOM
          JOIN DM_DOCUMENT_D WD_DM_D  
            ON WD_DM_D.DOCDT   = DP_DM_D.DOCDT                                   
           AND WD_DM_D.DOCTYPE = 'WD'                        
           AND WD_DM_D.DOCNO   = DP_DM_D.DOCNO                       
           AND WD_DM_D.DOCLINE = DP_DM_D.DOCLINE
          LEFT JOIN FRAMEONE_USER USER1 ON USER1.USER_ID = DP_INPLAN.ADDWHO   /*등록자명*/
          LEFT JOIN FRAMEONE_USER USER2 ON USER2.USER_ID = DP_INPLAN.EDITWHO  /*수정자명*/	       
         WHERE DP_DM_D.STORERKEY       = 'FW00'
           AND DP_DM_D.DOCTYPE         = 'DP'
           AND DP_DM_D.WORKPROCESSCODE = 'STO'
           AND DP_DM_D.DELIVERYDATE   <![CDATA[>=]]> #{slipDtFrom}
           AND DP_DM_D.DELIVERYDATE   <![CDATA[<=]]> #{slipDtTo}
           <if test='multiDcCode != null and multiDcCode.length > 0'>
			  AND DP_DM_D.DCCODE IN
		        <foreach collection="multiDcCode" item="dccodeItem" open="(" separator="," close=")">
		            #{dccodeItem}
		        </foreach>
		   </if>
		   <if test='fromMultiDcCode != null and fromMultiDcCode.length > 0'>
			   AND WD_DM_H.DCCODE IN
		       <foreach collection="fromMultiDcCode" item="dccodeItem" open="(" separator="," close=")">
		            #{dccodeItem}
		       </foreach>
		   </if>
           <if test="slipDt != null and slipDt != ''">
               AND DP_DM_D.DELIVERYDATE = #{slipDt}
           </if>           
           <if test="requestNo != null and requestNo != ''">
               AND DP_DM_D.DOCNO = #{requestNo}
           </if>
           <if test='skuCode != null and skuCode !=""'>
	           AND DP_DM_D.SKU IN
	           (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
	                        FROM (SELECT #{skuCode} AS VAL FROM DUAL) A
	                     CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
	       </if>           
           <if test="fromDcCode != null and fromDcCode != ''">
               AND WD_DM_H.DCCODE LIKE #{fromDcCode}
           </if>
           <if test="fromOrganize != null and fromOrganize != ''">
               AND WD_DM_H.ORGANIZE LIKE #{fromOrganize}
           </if>
           AND EXISTS  (SELECT '1'
	                      FROM DP_INPLAN
	                     WHERE DP_INPLAN.DCCODE    = DP_DM_H.DCCODE
	                       AND DP_INPLAN.STORERKEY = DP_DM_H.STORERKEY
	                       AND DP_INPLAN.ORGANIZE  = DP_DM_H.ORGANIZE
	                       AND DP_INPLAN.DOCDT     = DP_DM_H.DOCDT
	                       AND DP_INPLAN.DOCNO     = DP_DM_H.DOCNO
	                       AND DP_INPLAN.DOCTYPE   = DP_DM_H.DOCTYPE
	                       AND DP_INPLAN.STATUS    = '00')
	       AND EXISTS  (SELECT '1'
	                      FROM WD_INPLAN
	                     WHERE WD_INPLAN.DCCODE    = WD_DM_H.DCCODE
	                       AND WD_INPLAN.STORERKEY = WD_DM_H.STORERKEY
	                       AND WD_INPLAN.ORGANIZE  = WD_DM_H.ORGANIZE
	                       AND WD_INPLAN.DOCDT     = WD_DM_H.DOCDT
	                       AND WD_INPLAN.DOCNO     = WD_DM_H.DOCNO
	                       AND WD_INPLAN.DOCTYPE   = WD_DM_H.DOCTYPE
	                       AND WD_INPLAN.STATUS    = '10')
           <if test="chkPurchase != null and chkPurchase != ''">
           AND EXISTS  (SELECT '1'
                          FROM MS_PURCHASECUST
                          JOIN MS_PURCHASEMST 
                            ON MS_PURCHASECUST.STORERKEY  = MS_PURCHASEMST.STORERKEY
                           AND MS_PURCHASECUST.DCCODE     = MS_PURCHASEMST.DCCODE
                           AND MS_PURCHASECUST.CUSTTYPE   = MS_PURCHASEMST.CUSTTYPE
                           AND MS_PURCHASECUST.SKU        = MS_PURCHASEMST.SKU
                         WHERE 1 = 1
                           AND MS_PURCHASECUST.STORERKEY     = DP_DM_D.STORERKEY
                           AND MS_PURCHASECUST.DCCODE        = DP_DM_D.DCCODE
                           AND MS_PURCHASECUST.SKU           = DP_DM_D.SKU
                           <if test="purchaseType != null and purchaseType != ''">
                             AND MS_PURCHASEMST.PURCHASETYPE = #{purchaseType}
                           </if>
                           <if test="deliveryType != null and deliveryType != ''">
                             AND MS_PURCHASEMST.DELIVERYTYPE = #{deliveryType}
                           </if>
                           <if test="buyerKey != null and buyerKey != ''">
                             AND MS_PURCHASECUST.BUYERKEY = #{buyerKey}
                           </if> 
                       )
           </if>
         ORDER BY DP_DM_H.DELIVERYDATE
                , DP_DM_H.DOCNO
                , DP_DM_H.DCCODE
                , WD_DM_H.DCCODE
                , WD_DM_H.ORGANIZE
                , DP_INPLAN.SKU
    </select>
    
    <!-- select id="getMasterListSTO" resultType="OmPurchaseModifyResDto">
		SELECT /* [omPurchaseModifyService.sqlx][omPurchaseModifyService.getMasterListSTO][저장품발주수정 STO MASTER 조회] */
	           '0'                        AS checkYn,
	           DP_DM_H.DELIVERYDATE       AS slipDt,
	           DP_DM_H.DOCNO              AS docNo,
	           DP_DM_H.DCCODE             AS dcCode,
	           FN_GETDCNAME(DP_DM_H.DCCODE) AS dcName,
	           WD_DM_H.DCCODE             AS fromDcCode,
	           FN_GETDCNAME(WD_DM_H.DCCODE) AS fromDcName,
	           WD_DM_H.ORGANIZE           AS fromOrganize,
	           CM_DCXORGANIZE.DESCRIPTION AS fromOrganizeName,
	           DP_DM_H.STORERKEY          AS storerKey
	      FROM DM_DOCUMENT_H DP_DM_H
	      JOIN DM_DOCUMENT_H WD_DM_H
	        ON WD_DM_H.DOCDT = DP_DM_H.DOCDT
	       AND WD_DM_H.DOCNO = DP_DM_H.DOCNO
	       AND WD_DM_H.DELIVERYDATE = DP_DM_H.DELIVERYDATE
	       AND WD_DM_H.DOCTYPE = 'WD'
	      LEFT OUTER JOIN CM_DCXORGANIZE
	        ON CM_DCXORGANIZE.DCCODE = WD_DM_H.DCCODE
	       AND CM_DCXORGANIZE.ORGANIZE = WD_DM_H.ORGANIZE
	      JOIN DM_DOCUMENT_D DP_DM_D
	        ON DP_DM_D.DOCDT = DP_DM_H.DOCDT
	       AND DP_DM_D.DOCTYPE = DP_DM_H.DOCTYPE
	       AND DP_DM_D.DOCNO = DP_DM_H.DOCNO
	       AND DP_DM_D.STATUS = '30'
	     WHERE DP_DM_H.STORERKEY = #{gStorerkey}
	       AND DP_DM_H.DELIVERYDATE >= #{slipDtFrom}
	       AND DP_DM_H.DELIVERYDATE <![CDATA[<=]]> #{slipDtTo}
	       AND DP_DM_H.DCCODE = #{dcCode}
	    <if test="docNo != null and docNo != ''">
	       AND DP_DM_H.DOCNO = #{docNo}
	    </if>
	       AND DP_DM_H.DOCTYPE = 'DP'
	       AND DP_DM_H.WORKPROCESSCODE = 'STO'
        <if test='skuCode != null and skuCode !=""'>
          AND DP_DM_D.SKU IN
          (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
                        FROM (SELECT #{skuCode} AS VAL FROM DUAL) A
                     CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
        </if>
	    <if test="fromDcCode != null and fromDcCode != ''">
	       AND WD_DM_H.DCCODE LIKE #{fromDcCode}
	    </if>
	    <if test="fromOrganize != null and fromOrganize != ''">
	       AND WD_DM_H.ORGANIZE LIKE #{fromOrganize}
	    </if>
	       AND EXISTS (SELECT '1'
	                     FROM DP_INPLAN
	                    WHERE DP_INPLAN.DCCODE = DP_DM_H.DCCODE
	                      AND DP_INPLAN.STORERKEY = DP_DM_H.STORERKEY
	                      AND DP_INPLAN.ORGANIZE = DP_DM_H.ORGANIZE
	                      AND DP_INPLAN.DOCDT = DP_DM_H.DOCDT
	                      AND DP_INPLAN.DOCNO = DP_DM_H.DOCNO
	                      AND DP_INPLAN.DOCTYPE = DP_DM_H.DOCTYPE
	                      AND DP_INPLAN.STATUS = '00')
	       AND EXISTS (SELECT '1'
	                     FROM WD_INPLAN
	                    WHERE WD_INPLAN.DCCODE = WD_DM_H.DCCODE
	                      AND WD_INPLAN.STORERKEY = WD_DM_H.STORERKEY
	                      AND WD_INPLAN.ORGANIZE = WD_DM_H.ORGANIZE
	                      AND WD_INPLAN.DOCDT = WD_DM_H.DOCDT
	                      AND WD_INPLAN.DOCNO = WD_DM_H.DOCNO
	                      AND WD_INPLAN.DOCTYPE = WD_DM_H.DOCTYPE
	                      AND WD_INPLAN.STATUS = '10')
	    <if test="chkPurchase != null and chkPurchase != ''">
	       AND EXISTS (SELECT '1'
	                     FROM MS_PURCHASECUST
	                     JOIN MS_PURCHASEMST
	                       ON MS_PURCHASECUST.STORERKEY = MS_PURCHASEMST.STORERKEY
	                      AND MS_PURCHASECUST.DCCODE = MS_PURCHASEMST.DCCODE
	                      AND MS_PURCHASECUST.CUSTTYPE = MS_PURCHASEMST.CUSTTYPE
	                      AND MS_PURCHASECUST.SKU = MS_PURCHASEMST.SKU
	                    WHERE 1 = 1
	                      AND MS_PURCHASECUST.STORERKEY = DP_DM_D.STORERKEY
	                      AND MS_PURCHASECUST.DCCODE = DP_DM_D.DCCODE
	                      AND MS_PURCHASECUST.SKU = DP_DM_D.SKU
	                      AND MS_PURCHASECUST.PLANT = DP_DM_D.PLANT
	                      AND MS_PURCHASECUST.ROUTE = WD_DM_H.DCCODE
	                      AND MS_PURCHASECUST.ROUTEORGANIZE = WD_DM_H.ORGANIZE
	                    <if test="purchaseType != null and purchaseType != ''">
	                      AND MS_PURCHASEMST.PURCHASETYPE = #{purchaseType}
	                    </if>
	                    <if test="deliveryType != null and deliveryType != ''">
	                      AND MS_PURCHASEMST.DELIVERYTYPE = #{deliveryType}
	                    </if>
	                    <if test="buyerKey != null and buyerKey != ''">
	                      AND MS_PURCHASEMST.BUYERKEY = #{buyerKey}
	                    </if>
	                  )
	    </if>
	     GROUP BY DP_DM_H.DELIVERYDATE,
	              DP_DM_H.DOCNO,
	              DP_DM_H.DCCODE,
	              WD_DM_H.DCCODE,
	              WD_DM_H.ORGANIZE,
	              CM_DCXORGANIZE.DESCRIPTION,
	              DP_DM_H.STORERKEY
	     ORDER BY DP_DM_H.DELIVERYDATE,
	              DP_DM_H.DCCODE,
	              WD_DM_H.DCCODE,
	              WD_DM_H.ORGANIZE

    </!select -->

	<select id="getDetailListSTO" resultType="OmPurchaseModifyResDto">
		SELECT /* [omPurchaseModifyService.sqlx][omPurchaseModifyService.getDetailListSTO][저장품발주수정 STO DETAIL 조회] */
	           '0'                                                                                      AS checkYn,
	           FN_CODEDESCR(DP_INPLAN.STORERKEY, 'PURCHASETYPE_PO',
	                        (SELECT MAX(MS_PURCHASEMST.PURCHASETYPE)
	                           FROM MS_PURCHASECUST
	                           JOIN MS_PURCHASEMST
	                             ON MS_PURCHASECUST.STORERKEY = MS_PURCHASEMST.STORERKEY
	                            AND MS_PURCHASECUST.DCCODE = MS_PURCHASEMST.DCCODE
	                            AND MS_PURCHASECUST.CUSTTYPE = MS_PURCHASEMST.CUSTTYPE
	                            AND MS_PURCHASECUST.SKU = MS_PURCHASEMST.SKU
	                          WHERE MS_PURCHASECUST.STORERKEY = DP_DM_D.STORERKEY
	                            AND MS_PURCHASECUST.DCCODE = DP_DM_D.DCCODE
	                            AND MS_PURCHASECUST.SKU = DP_DM_D.SKU
	                            AND MS_PURCHASECUST.PLANT = DP_DM_D.PLANT
	                            AND MS_PURCHASECUST.ROUTE = WD_DM_H.DCCODE
	                            AND MS_PURCHASECUST.ROUTEORGANIZE = WD_DM_H.ORGANIZE))                   AS purchaseType,
	           FN_CODEDESCR(DP_INPLAN.STORERKEY, 'DIRECTTYPE',
	                        (SELECT MAX(MS_PURCHASEMST.DELIVERYTYPE)
	                           FROM MS_PURCHASECUST
	                           JOIN MS_PURCHASEMST
	                             ON MS_PURCHASECUST.STORERKEY = MS_PURCHASEMST.STORERKEY
	                            AND MS_PURCHASECUST.DCCODE = MS_PURCHASEMST.DCCODE
	                            AND MS_PURCHASECUST.CUSTTYPE = MS_PURCHASEMST.CUSTTYPE
	                            AND MS_PURCHASECUST.SKU = MS_PURCHASEMST.SKU
	                          WHERE MS_PURCHASECUST.STORERKEY = DP_DM_D.STORERKEY
	                            AND MS_PURCHASECUST.DCCODE = DP_DM_D.DCCODE
	                            AND MS_PURCHASECUST.SKU = DP_DM_D.SKU
	                            AND MS_PURCHASECUST.PLANT = DP_DM_D.PLANT
	                            AND MS_PURCHASECUST.ROUTE = WD_DM_H.DCCODE
	                            AND MS_PURCHASECUST.ROUTEORGANIZE = WD_DM_H.ORGANIZE))                   AS deliverytype,
	           DP_INPLAN.SLIPNO                                                                         AS slipNo,
	           DP_INPLAN.SLIPLINE                                                                       AS slipLine,
	           DP_INPLAN.SKU                                                                            AS sku,
	           MS_SKU.DESCRIPTION                                                                       AS skuName,
	           DP_INPLAN.UOM                                                                            AS uom,
	           CASE
	               WHEN WD_DM_H.DCCODE NOT IN ('2170', '2690') THEN
	                   CASE
	                       WHEN WD_DM_H.DCCODE = '1000' THEN
	                           CASE
	                               WHEN WD_DM_H.ORGANIZE IN ('1000-1260', '1000-1400') THEN DP_INPLAN.UOM
	                               ELSE MS_SKU.PURCHASEUOM
	                           END
	                       ELSE DP_INPLAN.UOM
	                   END
	               ELSE MS_SKU.PURCHASEUOM
	           END                                                                                      AS purchaseuom,
	           CASE
	               WHEN WD_DM_H.DCCODE NOT IN ('2170', '2690') THEN
	                   CASE
	                       WHEN WD_DM_H.DCCODE = '1000' THEN
	                           CASE
	                               WHEN WD_DM_H.ORGANIZE IN ('1000-1260', '1000-1400') THEN DP_INPLAN.ORDERQTY
	                               ELSE ROUND(DP_INPLAN.ORDERQTY / NVL(MS_UOM.BUNJA, 1) / NVL(MS_UOM.BUNMO, 1))
	                           END
	                       ELSE DP_INPLAN.ORDERQTY
	                   END
	               ELSE ROUND(DP_INPLAN.ORDERQTY / NVL(MS_UOM.BUNJA, 1) / NVL(MS_UOM.BUNMO, 1))
	           END                                                                                      AS orderqty,
	           ST_SNINFO.SERIALNO                                                                       AS serialno,	           
	           NVL(ST_SNINFO.STOCKID, WD_DM_D.STOCKID)                                                  AS BARCODE_SN,
	           ST_SNINFO.CONVSERIALNO                                                                   AS convserialno,
	           ST_SNINFO.BUTCHERYDT                                                                     AS butcherydt,
	           ST_SNINFO.FACTORYNAME                                                                    AS factoryname,
	           FN_CODEDESCR(ST_SNINFO.STORERKEY, 'CONTRACTTYPE_SN', ST_SNINFO.CONTRACTTYPE)              AS contracttype,
	           ST_SNINFO.CONTRACTCUSTKEY                                                                AS contractcompany,
	           (SELECT DESCRIPTION FROM MS_CUST WHERE CUSTKEY = ST_SNINFO.CONTRACTCUSTKEY AND ROWNUM = 1) AS contractcompanyname,
	           ST_SNINFO.FROMVALIDDT                                                                    AS fromvaliddt,
	           ST_SNINFO.TOVALIDDT                                                                      AS tovaliddt,
	           DP_INVOICE_SN.ORDERQTY                                                                   AS serialorderqty,
	           DP_INVOICE_SN.CONFIRMQTY                                                                 AS serialinspectqty,
	           CASE
	               WHEN DP_INPLAN.STORERKEY = 'CJFW' THEN
	                   CASE
	                       WHEN DP_INPLAN.UOM = 'KG' THEN DP_INVOICE_SN.CONFIRMQTY
	                       ELSE DP_INVOICE_SN.CONFIRMQTY * ST_SNINFO.NETWEIGHT
	                   END
	               ELSE FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU, DP_INPLAN.UOM, 'KG', DP_INVOICE_SN.CONFIRMQTY)
	           END                                                                                      AS serialscanweight,
	           DP_DM_D.DEL_YN                                                                           AS delYn,
	           CASE
	               WHEN DP_DM_D.STATUS = '30' AND WD_DM_D.STATUS = '30' THEN 'Y'
	               ELSE 'N'
	           END                                                                                      AS delProcYn
	      FROM DM_DOCUMENT_H DP_DM_H
	      JOIN DM_DOCUMENT_H WD_DM_H
	        ON WD_DM_H.DOCDT = DP_DM_H.DOCDT
	       AND WD_DM_H.DOCNO = DP_DM_H.DOCNO
	       AND WD_DM_H.DELIVERYDATE = DP_DM_H.DELIVERYDATE
	       AND WD_DM_H.DOCTYPE = 'WD'
	      LEFT OUTER JOIN CM_DCXORGANIZE
	        ON CM_DCXORGANIZE.DCCODE = WD_DM_H.DCCODE
	       AND CM_DCXORGANIZE.ORGANIZE = WD_DM_H.ORGANIZE
	      JOIN DM_DOCUMENT_D DP_DM_D
	        ON DP_DM_D.DOCDT = DP_DM_H.DOCDT
	       AND DP_DM_D.DOCTYPE = DP_DM_H.DOCTYPE
	       AND DP_DM_D.DOCNO = DP_DM_H.DOCNO
	      JOIN DP_INPLAN
	        ON DP_INPLAN.DCCODE = DP_DM_D.DCCODE
	       AND DP_INPLAN.STORERKEY = DP_DM_D.STORERKEY
	       AND DP_INPLAN.ORGANIZE = DP_DM_D.ORGANIZE
	       AND DP_INPLAN.DOCDT = DP_DM_D.DOCDT
	       AND DP_INPLAN.DOCNO = DP_DM_D.DOCNO
	       AND DP_INPLAN.DOCLINE = DP_DM_D.DOCLINE
	       AND DP_INPLAN.DOCTYPE = DP_DM_D.DOCTYPE
	      LEFT OUTER JOIN DP_INVOICE_SN
	        ON DP_INVOICE_SN.DCCODE = DP_INPLAN.DCCODE
	       AND DP_INVOICE_SN.STORERKEY = DP_INPLAN.STORERKEY
	       AND DP_INVOICE_SN.SLIPNO = DP_INPLAN.SLIPNO
	       AND DP_INVOICE_SN.SLIPDT = DP_INPLAN.SLIPDT
	       AND DP_INVOICE_SN.SLIPLINE = DP_INPLAN.SLIPLINE
	       AND DP_INVOICE_SN.DOCTYPE = DP_INPLAN.DOCTYPE
	       AND DP_INVOICE_SN.SKU = DP_INPLAN.SKU
	       AND DP_INVOICE_SN.DEL_YN = 'N'
	      LEFT OUTER JOIN ST_SNINFO
	        ON DP_INVOICE_SN.STORERKEY = ST_SNINFO.STORERKEY
	       AND DP_INVOICE_SN.SKU = ST_SNINFO.SKU
	       AND DP_INVOICE_SN.SERIALNO = ST_SNINFO.SERIALNO
	       AND DP_INVOICE_SN.STOCKID = ST_SNINFO.STOCKID
	       AND DP_INVOICE_SN.DEL_YN = 'N'
	      JOIN MS_SKU
	        ON DP_INPLAN.STORERKEY = MS_SKU.STORERKEY
	       AND DP_INPLAN.SKU = MS_SKU.SKU
	      LEFT OUTER JOIN MS_UOM
	        ON MS_SKU.STORERKEY = MS_UOM.STORERKEY
	       AND MS_SKU.SKU = MS_UOM.SKU
	       AND MS_SKU.BASEUOM = MS_UOM.BASEUOM
	       AND MS_SKU.PURCHASEUOM = MS_UOM.UOM
	      JOIN DM_DOCUMENT_D WD_DM_D
	        ON WD_DM_D.DOCDT = DP_DM_D.DOCDT
	       AND WD_DM_D.DOCTYPE = 'WD'
	       AND WD_DM_D.DOCNO = DP_DM_D.DOCNO
	       AND WD_DM_D.DOCLINE = DP_DM_D.DOCLINE
	     WHERE DP_DM_H.STORERKEY = #{gStorerkey}
	       AND DP_DM_H.DELIVERYDATE = #{slipDt}
	       AND DP_DM_H.DOCNO = #{docNo}
	    <if test='multiDcCode != null and multiDcCode.length > 0'>
		  AND DP_DM_H.DCCODE IN
	        <foreach collection="multiDcCode" item="dccodeItem" open="(" separator="," close=")">
	            #{dccodeItem}
	        </foreach>
		</if>
	    <if test="docNo != null and docNo != ''">
	       AND DP_DM_H.DOCNO = #{docNo}
	    </if>
	       AND DP_DM_H.DOCTYPE = 'DP'
	       AND DP_DM_H.WORKPROCESSCODE = 'STO'
        <if test='skuCode != null and skuCode !=""'>
          AND DP_DM_D.SKU IN
          (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
                        FROM (SELECT #{skuCode} AS VAL FROM DUAL) A
                     CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
        </if>
	    <if test="fromDcCode != null and fromDcCode != ''">
	       AND WD_DM_H.DCCODE LIKE #{fromDcCode}
	    </if>
	    <if test="fromOrganize != null and fromOrganize != ''">
	       AND WD_DM_H.ORGANIZE LIKE #{fromOrganize}
	    </if>
	    <if test="chkPurchase != null and chkPurchase != ''">
	       AND EXISTS (SELECT '1'
	                     FROM MS_PURCHASECUST
	                     JOIN MS_PURCHASEMST
	                       ON MS_PURCHASECUST.STORERKEY = MS_PURCHASEMST.STORERKEY
	                      AND MS_PURCHASECUST.DCCODE = MS_PURCHASEMST.DCCODE
	                      AND MS_PURCHASECUST.CUSTTYPE = MS_PURCHASEMST.CUSTTYPE
	                      AND MS_PURCHASECUST.SKU = MS_PURCHASEMST.SKU
	                    WHERE 1 = 1
	                      AND MS_PURCHASECUST.STORERKEY = DP_DM_D.STORERKEY
	                      AND MS_PURCHASECUST.DCCODE = DP_DM_D.DCCODE
	                      AND MS_PURCHASECUST.SKU = DP_DM_D.SKU
	                      <!-- AND MS_PURCHASECUST.PLANT = DP_DM_D.PLANT
	                      AND MS_PURCHASECUST.ROUTE = WD_DM_H.DCCODE
	                      AND MS_PURCHASECUST.ROUTEORGANIZE = WD_DM_H.ORGANIZE -->
	                    <if test="purchaseType != null and purchaseType != ''">
	                      AND MS_PURCHASEMST.PURCHASETYPE = #{purchaseType}
	                    </if>
	                    <if test="deliveryType != null and deliveryType != ''">
	                      AND MS_PURCHASEMST.DELIVERYTYPE = #{deliveryType}
	                    </if>
	                    <if test="buyerKey != null and buyerKey != ''">
	                      AND MS_PURCHASEMST.BUYERKEY = #{buyerKey}
	                    </if>
	                  )
	    </if>
	     ORDER BY DP_DM_H.DELIVERYDATE,
	              DP_DM_H.DCCODE,
	              WD_DM_H.DCCODE,
	              WD_DM_H.ORGANIZE
	
	</select>
	
	<!-- I/F 전송내역일 경우 확인 -->
    <select id="getDataCheckSend" resultType="int">
    	/* [omPurchaseModifyService.sqlx][omPurchaseModifyService.getDataCheckSend] */
    	SELECT COUNT(*)
    	  FROM DP_PURCHASE
         WHERE REQUESTNO    = #{requestNo}
		   AND REQUESTLINE  = #{requestLine}
		   AND DEL_YN       = 'Y'
		   AND DELIVERYMEMO = 'SEND'
    </select>
    
    <!-- DP_PURCHASE DEL_YN = 'Y' 처리 -->
    <update id="updatePurchaseDelYn">
	    /* [omPurchaseModifyService.sqlx][omPurchaseModifyService.updatePurchaseDelYn] */
	    BEGIN
		    <!-- I/F 미전송내역에 대해 삭제 처리 -->
		    UPDATE IF_POREQUEST_RESULT
		       SET DEL_YN = 'Y'
		       , IF_FLAG = 'D'
		     WHERE REQUESTNO    = #{requestNo}
		  	   AND REQUESTLINE  = #{requestLine}
		       AND IF_FLAG      = 'N';
		    
		    <!-- I/F 전송일시 SRM확인처리를 위해 해야함 -->   
			IF SQL%ROWCOUNT <![CDATA[<]]> 1 THEN
				UPDATE DP_PURCHASE
				   SET DEL_YN       = 'Y'
				     , IF_FLAG      = 'N'  <!-- 260324 김동진님 요청 -->
				     , DELIVERYMEMO = 'SEND'  <!-- I/F 전송내역일 경우 확인을 위해 DELIVERYMEMO컬럼을 사용 -->
				     , EDITDATE     = SYSDATE
				     , EDITWHO      = #{gUserId}
				 WHERE REQUESTNO    = #{requestNo}
				   AND REQUESTLINE  = #{requestLine};
			ELSE  
				UPDATE DP_PURCHASE
				   SET DEL_YN       = 'Y'     <!-- I/F 미전송내역일 경우 DEL_YN='Y' 처리후 종료 -->
				     , IF_FLAG      = 'N'  <!-- 260324 김동진님 요청 -->
				     , EDITDATE     = SYSDATE
				     , EDITWHO      = #{gUserId}
				 WHERE REQUESTNO    = #{requestNo}
				   AND REQUESTLINE  = #{requestLine};
			END IF;
			
	    END;
    </update>
    
    <!-- DM_DOCUMENT_H copy 처리 -->
    <update id="insertIFHeader">
    /* [omPurchaseModifyService.sqlx][omPurchaseModifyService.insertIFHeader] */
    BEGIN
	    <!-- IF_DM_DOCUMENT_H INSERT -->
        INSERT INTO IF_DM_DOCUMENT_H
	        	(SERIALKEY
				,IF_DESTINATION
				,DOCDT
				,DOCTYPE
				,DOCNO
				,DCCODE
				,STORERKEY
				,ORGANIZE
				,MERGEDOCTYPE
				,MERGEDOCDT
				,MERGEDOCNO
				,PLANDOCTYPE
				,PLANDOCDT
				,PLANDOCNO
				,SHOPPINGMALL
				,MALLINVOICE
				,COURIER
				,INVOICETYPE
				,INVOICENO
				,POTYPE
				,POKEY
				,ORDERTYPE
				,SOURCEKEY
				,FROM_CUSTKEY
				,FROM_CUSTNAME
				,FROM_CUSTTYPE
				,FROM_ORGANIZE
				,FROM_BILLTOKEY
				,FROM_COUNTRY
				,FROM_STATE
				,FROM_CITY
				,FROM_ZIPCODE
				,FROM_ADDRESS_DISP
				,FROM_ADDRESS1
				,FROM_ADDRESS2
				,FROM_ADDRESS3
				,FROM_ADDRESS4
				,FROM_PHONE1_DISP
				,FROM_PHONE1
				,FROM_PHONE2_DISP
				,FROM_PHONE2
				,FROM_FAX
				,FROM_VATNO
				,FROM_VATOWNER
				,FROM_VATTYPE
				,FROM_VATCATEGORY
				,FROM_VATZIPCODE
				,FROM_VATADDRESS1
				,FROM_VATADDRESS2
				,FROM_VATADDRESS3
				,FROM_VATADDRESS4
				,FROM_VATPHONE
				,FROM_VATFAX
				,FROM_EMPNAME1
				,FROM_EMPNAME2
				,FROM_EMPPHONE1
				,FROM_EMPPHONE2
				,TO_CUSTKEY
				,TO_CUSTNAME
				,TO_CUSTTYPE
				,TO_ORGANIZE
				,TO_BILLTOKEY
				,TO_COUNTRY
				,TO_STATE
				,TO_CITY
				,TO_ZIPCODE
				,TO_ADDRESS_DISP
				,TO_ADDRESS1
				,TO_ADDRESS2
				,TO_ADDRESS3
				,TO_ADDRESS4
				,TO_PHONE1_DISP
				,TO_PHONE1
				,TO_PHONE2_DISP
				,TO_PHONE2
				,TO_FAX
				,TO_VATNO
				,TO_VATOWNER
				,TO_VATTYPE
				,TO_VATCATEGORY
				,TO_VATZIPCODE
				,TO_VATADDRESS1
				,TO_VATADDRESS2
				,TO_VATADDRESS3
				,TO_VATADDRESS4
				,TO_VATPHONE
				,TO_VATFAX
				,TO_EMPNAME1
				,TO_EMPNAME2
				,TO_EMPPHONE1
				,TO_EMPPHONE2
				,PRIORITY
				,CHANNEL
				,TOTLINE
				,ORDERQTY
				,OPENQTY
				,PROCESSQTY
				,WORKQTY
				,INSPECTQTY
				,CONFIRMQTY
				,INVOICEQTY
				,CANCELQTY
				,RETURNQTY
				,DCRATE
				,MARGINRATE
				,DELIVERYMEMO
				,REQUESTMEMO
				,CONFIRMDATE
				,PURCHASEDATE
				,POSTINGDATE
				,EFFECTIVEDATE
				,DELIVERYDATE
				,DELIVERYROUTE
				,DELIVERYTYPE
				,DELIVERYGROUP
				,DELIVERYFEETYPE
				,DELIVERYFEE
				,PROCESSCODE
				,STRAGETYCODE
				,WORKPROCESSCODE
				,INTERFACEPROCESSCODE
				,FACILITYPROCESSCODE
				,MEMO1
				,MEMO2
				,REFERENCE01
				,REFERENCE02
				,REFERENCE03
				,REFERENCE04
				,REFERENCE05
				,REFERENCE06
				,REFERENCE07
				,REFERENCE08
				,REFERENCE09
				,REFERENCE10
				,STATUS
				,CANCELSTATUS
				,RETURNSTATUS
				,DEL_YN
				,OMS_FLAG
				,IF_FLAG
				,IF_CNT
				,IF_DATE
				,IF_MEMO
				,IF_RECEIVE_TYPE
				,IF_RECEIVE_FILE
				,IF_AUDIT_FILE
				,IF_SEND_TYPE
				,IF_SEND_FILE
				,PROCPOSS_YN
				,PROCPOSS_MSG
				,TRAFFICCOP
				,ARCHIVECOP
				,SOTYPE
				,SOKEY
				,IF_ID
				,IF_LASTKEY
				,CARNO
				,SLIPTYPE
				,SLIPNO
				,SLIPDT
				,IF_TIMESTAMP
				,REAL_YN
				,ADD_YN
				,MAPKEY_NO
				,REF_DOC_NO
				,MAP_DIV
				,OTCO_GRPCD
				,B2C_YN
				,EXPRESS_YN
				,TPL_TYPE
				,TPL_DTL_TYPE
				,TPL_BCNR_ID
				,ADDDATE
				,EDITDATE
				,ADDWHO
				,EDITWHO)
		SELECT SEQ_IF_DM_DOCUMENT_H.NEXTVAL
		      ,IF_DESTINATION
		      ,DOCDT
		      ,DOCTYPE
		      ,DOCNO
		      ,DCCODE
		      ,STORERKEY
		      ,ORGANIZE
		      ,MERGEDOCTYPE
		      ,MERGEDOCDT
		      ,MERGEDOCNO
		      ,PLANDOCTYPE
		      ,PLANDOCDT
		      ,PLANDOCNO
		      ,SHOPPINGMALL
		      ,MALLINVOICE
		      ,COURIER
		      ,INVOICETYPE
		      ,INVOICENO
		      ,POTYPE
		      ,POKEY
		      ,ORDERTYPE
		      ,SOURCEKEY
		      ,FROM_CUSTKEY
		      ,FROM_CUSTNAME
		      ,FROM_CUSTTYPE
		      ,FROM_ORGANIZE
		      ,FROM_BILLTOKEY
		      ,FROM_COUNTRY
		      ,FROM_STATE
		      ,FROM_CITY
		      ,FROM_ZIPCODE
		      ,FROM_ADDRESS_DISP
		      ,FROM_ADDRESS1
		      ,FROM_ADDRESS2
		      ,FROM_ADDRESS3
		      ,FROM_ADDRESS4
		      ,FROM_PHONE1_DISP
		      ,FROM_PHONE1
		      ,FROM_PHONE2_DISP
		      ,FROM_PHONE2
		      ,FROM_FAX
		      ,FROM_VATNO
		      ,FROM_VATOWNER
		      ,FROM_VATTYPE
		      ,FROM_VATCATEGORY
		      ,FROM_VATZIPCODE
		      ,FROM_VATADDRESS1
		      ,FROM_VATADDRESS2
		      ,FROM_VATADDRESS3
		      ,FROM_VATADDRESS4
		      ,FROM_VATPHONE
		      ,FROM_VATFAX
		      ,FROM_EMPNAME1
		      ,FROM_EMPNAME2
		      ,FROM_EMPPHONE1
		      ,FROM_EMPPHONE2
		      ,TO_CUSTKEY
		      ,TO_CUSTNAME
		      ,TO_CUSTTYPE
		      ,TO_ORGANIZE
		      ,TO_BILLTOKEY
		      ,TO_COUNTRY
		      ,TO_STATE
		      ,TO_CITY
		      ,TO_ZIPCODE
		      ,TO_ADDRESS_DISP
		      ,TO_ADDRESS1
		      ,TO_ADDRESS2
		      ,TO_ADDRESS3
		      ,TO_ADDRESS4
		      ,TO_PHONE1_DISP
		      ,TO_PHONE1
		      ,TO_PHONE2_DISP
		      ,TO_PHONE2
		      ,TO_FAX
		      ,TO_VATNO
		      ,TO_VATOWNER
