<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="wdDeliveryLabelSNService">

	<select id="getTab1MasterList" resultType="WdDeliveryLabelSNResTab1Dto">
        SELECT /* [WdDeliveryLabelSNService.sqlx][getTab1MasterList][이력배송라벨출력-분류표생성 목록 조회][공두경][2025.10.15] */
		       CASE WHEN SUM(CASE WHEN (DM_DOCUMENT_D.STOREROPENQTY 
		                              * DM_DOCUMENT_D.BUNJA 
		                              / DM_DOCUMENT_D.BUNMO)         
		                             - DM_DOCUMENT_D.CANCELQTY      > DM_DOCUMENT_D.INVOICEQTY THEN 1
		                          ELSE 0
		                     END) > 0 THEN '생성중'
		            ELSE '생성완료'
		       END                                                                                  AS CREATEDESCR		/*생성유무*/
              ,DM_DOCUMENT_H.DCCODE                                                                 AS DCCODE           /*물류센터*/
		      ,DM_DOCUMENT_H.ORGANIZE                                                               AS ORGANIZE         /*창고*/
		      ,DM_DOCUMENT_D.PLANT                                                                  AS PLANT            /*플랜트*/
		      ,WD_INPLAN.SLIPDT                                                                     AS SLIPDT           /*출고일자*/
		      ,MAX(NVL(CD1.BASEDESCR,CD1.BASECODE))    												AS ORDERTYPE        /*주문유형*/
		      ,MAX(NVL(CD2.BASEDESCR,CD2.BASECODE))    												AS POTYPE           /*주문사유*/
		      ,DM_DOCUMENT_H.DOCNO                                                                  AS DOCNO            /*주문번호*/
		      ,MAX(NVL(CD3.BASEDESCR,CD3.BASECODE))    												AS SALEGROUP        /*영업조직*/
		      ,MAX(NVL(CD4.BASEDESCR,CD4.BASECODE))    												AS SALEDEPARTMENT   /*사업장*/
		      ,MAX(MS_CUST.CUSTGROUP)                                                               AS CUSTGROUP        /*영업그룹*/
		      ,MAX(DM_DOCUMENT_H.TO_VATNO)                                                          AS TO_VATNO         /*판매처코드*/
		      ,MAX(DM_DOCUMENT_H.TO_VATOWNER)                                                       AS TO_VATOWNER      /*판매처명*/
		      ,MAX(DM_DOCUMENT_H.TO_CUSTKEY)                                                        AS TO_CUSTKEY       /*관리처코드*/
		      ,MAX(DM_DOCUMENT_H.TO_CUSTNAME)                                                       AS TO_CUSTNAME      /*관리처명*/
		      ,MAX(NVL(CD5.BASEDESCR,CD5.BASECODE))    												AS STATUS           /*진행상태*/
		      ,DM_DOCUMENT_H.STORERKEY                                                              AS STORERKEY        /**/
		      ,DM_DOCUMENT_D.AREA                                                                   AS AREA             /**/
		      ,DM_DOCUMENT_H.DOCDT                                                                  AS DOCDT            /**/
		      ,DM_DOCUMENT_H.DOCTYPE                                                                AS DOCTYPE          /**/
		      ,WD_INPLAN.SLIPNO                                                                     AS SLIPNO           /**/
		      ,WD_INPLAN.SLIPTYPE                                                                   AS SLIPTYPE         /**/
		      ,CASE WHEN SUM(CASE WHEN (DM_DOCUMENT_D.STOREROPENQTY 
		                              * DM_DOCUMENT_D.BUNJA 
		                              / DM_DOCUMENT_D.BUNMO)         
		                             - DM_DOCUMENT_D.CANCELQTY      > DM_DOCUMENT_D.INVOICEQTY THEN 1
		                          ELSE 0
		                     END) > 0 THEN 'N'
		            ELSE 'Y'
		       END                                                                                  AS CREATEYN			/**/
		FROM   WD_INPLAN
        JOIN   DM_DOCUMENT_D              
        ON     DM_DOCUMENT_D.DCCODE         =  WD_INPLAN.DCCODE            
        AND    DM_DOCUMENT_D.STORERKEY      =  WD_INPLAN.STORERKEY                  
        AND    DM_DOCUMENT_D.DELIVERYDATE   =  WD_INPLAN.SLIPDT            
        AND    DM_DOCUMENT_D.DOCNO          =  WD_INPLAN.DOCNO            
        AND    DM_DOCUMENT_D.DOCLINE        =  WD_INPLAN.DOCLINE
        AND    DM_DOCUMENT_D.DOCTYPE        =  WD_INPLAN.DOCTYPE            
        AND    DM_DOCUMENT_D.CHANNEL        =  '1'            
        AND    DM_DOCUMENT_D.WORKPROCESSCODE IN ('JASO','SO')      
        AND    DM_DOCUMENT_D.DEL_YN         =  'N'                 
		<if test="plant != null and plant != ''">	AND DM_DOCUMENT_D.PLANT	=	#{plant}	</if>
		JOIN   DM_DOCUMENT_H         
        ON     DM_DOCUMENT_H.DCCODE         =  DM_DOCUMENT_D.DCCODE            
        AND    DM_DOCUMENT_H.STORERKEY      =  DM_DOCUMENT_D.STORERKEY                  
        AND    DM_DOCUMENT_H.DELIVERYDATE   =  DM_DOCUMENT_D.DELIVERYDATE            
        AND    DM_DOCUMENT_H.DOCNO          =  DM_DOCUMENT_D.DOCNO            
        AND    DM_DOCUMENT_H.DOCTYPE        =  DM_DOCUMENT_D.DOCTYPE            
        AND    DM_DOCUMENT_H.DEL_YN         =  'N'        
		<!-- 고객 다중선택 -->
    	<if test="toCustkeyMulti != null and toCustkeyMulti != '' ">
	    	<trim prefix="AND (" suffix=")" prefixOverrides="OR">
	    		<foreach collection="toCustkeyMulti" item="item">
	    			OR DM_DOCUMENT_H.TO_CUSTKEY IN
	    			<foreach collection="item" item="code" open="(" close=")" separator=",">
	    				#{code} 	 
	          		</foreach>
	        	</foreach>
	      	</trim>			                                    
        </if>
		<!-- 본점 다중선택 -->
    	<if test="custkeyMulti != null and custkeyMulti != '' ">
	    	<trim prefix="AND (" suffix=")" prefixOverrides="OR">
	    		<foreach collection="custkeyMulti" item="item">
	    			OR DM_DOCUMENT_H.HDO_ID IN
	    			<foreach collection="item" item="code" open="(" close=")" separator=",">
	    				#{code} 	 
	          		</foreach>
	        	</foreach>
	      	</trim>			                                    
        </if>
		JOIN   MS_CUST           
		ON     MS_CUST.STORERKEY            = DM_DOCUMENT_H.STORERKEY         
		AND    MS_CUST.CUSTTYPE             = DM_DOCUMENT_H.TO_CUSTTYPE 
		AND    MS_CUST.CUSTKEY              = DM_DOCUMENT_H.TO_CUSTKEY 
		AND    MS_CUST.DEL_YN               = 'N'        
		JOIN   MS_SKU 
		ON     MS_SKU.STORERKEY             = WD_INPLAN.STORERKEY         
		AND    MS_SKU.SKU                   = WD_INPLAN.SKU
		AND    MS_SKU.SERIALYN              = 'Y'              
		AND    MS_SKU.DEL_YN                = 'N'
		<if test="storagetype != null and storagetype != ''">	AND MS_SKU.STORAGETYPE      =	#{storagetype}  </if>
		<if test="skugroup != null and skugroup != ''">	   		AND LEFT(MS_SKU.SKUGROUP,2)	=	#{skugroup}  	</if>		
    	<!-- 상품 다중선택 -->
    	<if test="sku != null and sku != '' ">
			<if test="skuMulti != null and skuMulti.size() > 0">
				<trim prefix="AND (" suffix=")" prefixOverrides="OR">
					<foreach collection="skuMulti" item="item">
						OR DM_DOCUMENT_D.SKU IN
						<foreach collection="item" item="code" open="(" close=")" separator=",">
							#{code} 	 
			      		</foreach>
			    	</foreach>
			  	</trim>			                                    
	    	</if>
        </if>
        LEFT JOIN CM_CODE_STORER CD1  ON CD1.STORERKEY  = DM_DOCUMENT_H.STORERKEY AND CD1.CODELIST  = 'ORDERTYPE_WD' 	AND CD1.BASECODE   = DM_DOCUMENT_H.ORDERTYPE
        LEFT JOIN CM_CODE_STORER CD2  ON CD2.STORERKEY  = DM_DOCUMENT_H.STORERKEY AND CD2.CODELIST  = 'POTYPE_WD' 		AND CD2.BASECODE   = DM_DOCUMENT_H.POTYPE
        LEFT JOIN CM_CODE_STORER CD3  ON CD3.STORERKEY  = DM_DOCUMENT_H.STORERKEY AND CD3.CODELIST  = 'SALEGROUP'		AND CD3.BASECODE   = MS_CUST.SALEGROUP
        LEFT JOIN CM_CODE_STORER CD4  ON CD4.STORERKEY  = DM_DOCUMENT_H.STORERKEY AND CD4.CODELIST  = 'SALEDEPARTMENT'	AND CD4.BASECODE   = MS_CUST.SALEDEPARTMENT
        LEFT JOIN CM_CODE_STORER CD5  ON CD5.STORERKEY  = DM_DOCUMENT_H.STORERKEY AND CD5.CODELIST  = 'STATUS_WD'		AND CD5.BASECODE   = DM_DOCUMENT_D.STATUS
		WHERE  WD_INPLAN.DEL_YN         = 'N'         
		<if test="fixdccode != null and fixdccode != ''">	        AND WD_INPLAN.DCCODE    =	#{fixdccode}       </if>                                                                                                                                                 
		<if test="gStorerkey != null and gStorerkey != ''">	AND WD_INPLAN.STORERKEY	=	#{gStorerkey}	</if>                                                                                                                                            
	    <!-- 문서번호 다중선택 -->
        <if test="docnoMulti != null and docnoMulti != ''">
	       AND WD_INPLAN.DOCNO IN
	       <foreach collection="docnoMulti" item="code" open="(" close=")" separator=",">
	         #{code}
	       </foreach>   
        </if>   
		<if test="slipdt != null and slipdt != ''">	AND	WD_INPLAN.SLIPDT	=	#{slipdt}	</if>	
		<if test="ordertype != null and ordertype != ''">	AND DM_DOCUMENT_H.ORDERTYPE =	#{ordertype}	</if>
		GROUP BY DM_DOCUMENT_H.DCCODE
		        ,DM_DOCUMENT_H.STORERKEY
		        ,DM_DOCUMENT_H.ORGANIZE
		        ,DM_DOCUMENT_D.AREA 
		        ,WD_INPLAN.SLIPDT                                
		        ,WD_INPLAN.SLIPNO                                                 
		        ,WD_INPLAN.SLIPTYPE                                                         
		        ,DM_DOCUMENT_H.DOCDT
		        ,DM_DOCUMENT_H.DOCNO
		        ,DM_DOCUMENT_H.DOCTYPE
		        ,DM_DOCUMENT_H.POTYPE
		        ,DM_DOCUMENT_H.ORDERTYPE
		        ,DM_DOCUMENT_D.PLANT
		ORDER BY CREATEYN
				,DM_DOCUMENT_H.DCCODE
		        ,DM_DOCUMENT_H.STORERKEY 
		        ,DM_DOCUMENT_H.ORGANIZE
		        ,WD_INPLAN.SLIPDT
		        ,DM_DOCUMENT_H.DOCDT
		        ,DM_DOCUMENT_H.DOCNO
		        ,DM_DOCUMENT_H.DOCTYPE
		        ,DM_DOCUMENT_H.POTYPE
		        ,DM_DOCUMENT_H.ORDERTYPE      
    </select>
    
    <select id="getTab1DetailList" resultType="WdDeliveryLabelSNResTab1DetailDto">
	   SELECT /* [WdDeliveryLabelSNService.sqlx][getTab1DetailList][이력배송라벨출력-분류표생성 상세 조회][공두경][2025.10.15] */
               DM_DOCUMENT_D.DOCLINE                                                              AS DOCLINE		/*품목번호*/
              ,DM_DOCUMENT_D.SKU                                                                  AS SKU            /*상품코드*/
              ,MAX(MS_SKU.DESCRIPTION             )                                               AS SKUNAME        /*상품명칭*/
              ,'['||DM_DOCUMENT_D.PLANT||']'||FN_DESCR_PLANT(DM_DOCUMENT_D.PLANT)                 AS PLANT_DESCR    /*플랜트*/
              ,MAX(NVL(CD1.BASEDESCR,CD1.BASECODE)) 											  AS CHANNEL        /*저장유무*/
              ,MAX(NVL(CD2.BASEDESCR,CD2.BASECODE))												  AS STORAGETYPE    /*저장조건*/
              ,MAX(DM_DOCUMENT_D.STOREROPENQTY    )                                               AS ORDERQTY       /*주문수량*/
              ,MAX(DM_DOCUMENT_D.STORERUOM)                                                       AS UOM            /*판매단위*/
              ,MAX(NVL(CD3.BASEDESCR,CD3.BASECODE))												  AS STATUS         /*진행상태*/        
       		  ,DM_DOCUMENT_D.DCCODE                                                               AS DCCODE         /**/
		      ,DM_DOCUMENT_D.STORERKEY                                                            AS STORERKEY      /**/
		      ,DM_DOCUMENT_D.ORGANIZE                                                             AS ORGANIZE       /**/  
              ,DM_DOCUMENT_D.AREA                                                                 AS AREA           /**/
		      ,DM_DOCUMENT_D.DOCDT                                                                AS DOCDT          /**/
              ,DM_DOCUMENT_D.DOCNO                                                                AS DOCNO          /**/
              ,DM_DOCUMENT_D.DOCTYPE                                                              AS DOCTYPE        /**/
              ,WD_INPLAN.SLIPDT                                                                   AS SLIPDT         /**/
              ,WD_INPLAN.SLIPNO                                                                   AS SLIPNO         /**/
              ,WD_INPLAN.SLIPTYPE                                                                 AS SLIPTYPE       /**/
              ,WD_INPLAN.SLIPLINE                                                                 AS SLIPLINE       /**/
              ,DM_DOCUMENT_D.PLANT																  AS PLANT          /**/
              ,MS_CUST.DESCRIPTION                                                                AS CONTRACTCOMPANYNAME	/**/
        FROM   DM_DOCUMENT_H      
		JOIN   DM_DOCUMENT_D           
		ON     DM_DOCUMENT_D.DCCODE         =  DM_DOCUMENT_H.DCCODE         
		AND    DM_DOCUMENT_D.STORERKEY      =  DM_DOCUMENT_H.STORERKEY               
		AND    DM_DOCUMENT_D.DELIVERYDATE   =  DM_DOCUMENT_H.DELIVERYDATE         
		AND    DM_DOCUMENT_D.DOCNO          =  DM_DOCUMENT_H.DOCNO         
		AND    DM_DOCUMENT_D.DOCTYPE        =  DM_DOCUMENT_H.DOCTYPE         
		AND    DM_DOCUMENT_D.CHANNEL        =  '1'         
		AND    DM_DOCUMENT_D.WORKPROCESSCODE IN ('JASO','SO')   
		AND    DM_DOCUMENT_D.DEL_YN         =  'N'             
		JOIN   WD_INPLAN
		ON     WD_INPLAN.DCCODE             = DM_DOCUMENT_D.DCCODE         
		AND    WD_INPLAN.STORERKEY          = DM_DOCUMENT_D.STORERKEY               
		AND    WD_INPLAN.ORGANIZE           = DM_DOCUMENT_D.ORGANIZE               
		AND    WD_INPLAN.SLIPDT             = DM_DOCUMENT_D.DELIVERYDATE         
		AND    WD_INPLAN.DOCNO              = DM_DOCUMENT_D.DOCNO         
		AND    WD_INPLAN.DOCLINE            = DM_DOCUMENT_D.DOCLINE         
		AND    WD_INPLAN.DOCTYPE            = DM_DOCUMENT_D.DOCTYPE 
		AND    WD_INPLAN.DEL_YN             = 'N' 
		JOIN   MS_SKU 
		ON     MS_SKU.STORERKEY             =  DM_DOCUMENT_D.STORERKEY         
		AND    MS_SKU.SKU                   =  DM_DOCUMENT_D.SKU
		AND    MS_SKU.DEL_YN                = 'N'		
		AND    MS_SKU.SERIALYN              = 'Y' 
		<if test="storagetype != null and storagetype != ''">	AND MS_SKU.STORAGETYPE      =	#{storagetype}  </if>
		<if test="skugroup != null and skugroup != ''">	   		AND LEFT(MS_SKU.SKUGROUP,2)	=	#{skugroup}  	</if>
		<!-- 상품 다중선택 -->
    	<if test="sku != null and sku != '' ">
			<if test="skuMulti != null and skuMulti.size() > 0">
				<trim prefix="AND (" suffix=")" prefixOverrides="OR">
					<foreach collection="skuMulti" item="item">
						OR DM_DOCUMENT_D.SKU IN
						<foreach collection="item" item="code" open="(" close=")" separator=",">
							#{code} 	 
			      		</foreach>
			    	</foreach>
			  	</trim>			                                    
	    	</if>
        </if>
		LEFT JOIN   MS_CUST
		ON     MS_CUST.STORERKEY            = DM_DOCUMENT_H.STORERKEY 
		AND    MS_CUST.CUSTTYPE             = DM_DOCUMENT_H.TO_CUSTTYPE 
		AND    MS_CUST.CUSTKEY              = DM_DOCUMENT_H.TO_CUSTKEY
		AND    MS_CUST.DEL_YN               = 'N' 
		LEFT JOIN CM_CODE_STORER CD1  ON CD1.STORERKEY  = DM_DOCUMENT_D.STORERKEY AND CD1.CODELIST  = 'PUTAWAYTYPE' 	AND CD1.BASECODE   = DM_DOCUMENT_D.CHANNEL
        LEFT JOIN CM_CODE_STORER CD2  ON CD2.STORERKEY  = DM_DOCUMENT_D.STORERKEY AND CD2.CODELIST  = 'STORAGETYPE' 	AND CD2.BASECODE   = MS_SKU.STORAGETYPE
        LEFT JOIN CM_CODE_STORER CD3  ON CD3.STORERKEY  = DM_DOCUMENT_D.STORERKEY AND CD3.CODELIST  = 'STATUS_WD'		AND CD3.BASECODE   = DM_DOCUMENT_D.STATUS
		WHERE  DM_DOCUMENT_D.DCCODE	        =  #{dccode}
		AND    DM_DOCUMENT_D.STORERKEY	    =  #{storerkey}
		AND    DM_DOCUMENT_D.DELIVERYDATE   =  #{slipdt}
		AND    DM_DOCUMENT_D.DOCNO	        =  #{docno}
		AND    DM_DOCUMENT_D.DOCTYPE        =  #{doctype}
		<!-- 고객 다중선택 -->
    	<if test="toCustkeyMulti != null and toCustkeyMulti != '' ">
	    	<trim prefix="AND (" suffix=")" prefixOverrides="OR">
	    		<foreach collection="toCustkeyMulti" item="item">
	    			OR DM_DOCUMENT_H.TO_CUSTKEY IN
	    			<foreach collection="item" item="code" open="(" close=")" separator=",">
	    				#{code} 	 
	          		</foreach>
	        	</foreach>
	      	</trim>			                                    
        </if>
		<!-- 본점 다중선택 -->
    	<if test="custkeyMulti != null and custkeyMulti != '' ">
	    	<trim prefix="AND (" suffix=")" prefixOverrides="OR">
	    		<foreach collection="custkeyMulti" item="item">
	    			OR DM_DOCUMENT_H.HDO_ID IN
	    			<foreach collection="item" item="code" open="(" close=")" separator=",">
	    				#{code} 	 
	          		</foreach>
	        	</foreach>
	      	</trim>			                                    
        </if>
		GROUP BY DM_DOCUMENT_D.DCCODE           
		        ,DM_DOCUMENT_D.STORERKEY       
		        ,DM_DOCUMENT_D.ORGANIZE          
                ,DM_DOCUMENT_D.AREA               
		        ,DM_DOCUMENT_D.DOCDT            
                ,DM_DOCUMENT_D.DOCNO            
                ,DM_DOCUMENT_D.DOCTYPE          
                ,DM_DOCUMENT_D.DOCLINE
                ,WD_INPLAN.SLIPDT            
                ,WD_INPLAN.SLIPNO            
                ,WD_INPLAN.SLIPTYPE          
                ,WD_INPLAN.SLIPLINE           
                ,DM_DOCUMENT_D.SKU 
                ,DM_DOCUMENT_D.PLANT  
                ,MS_CUST.DESCRIPTION
       ORDER BY DM_DOCUMENT_D.DOCLINE              
		        ,DM_DOCUMENT_D.SKU 
    </select>
    
    <select id="getTab2MasterList" resultType="WdDeliveryLabelSNResTab2Dto">
        WITH T_TOTALQTY AS ( 
            SELECT WD_INVOICE.SKU
                 , CASE WHEN MAX(DM_DOCUMENT_D.STORERUOM) = 'BOX' THEN RTRIM(TO_CHAR(SUM(WD_INVOICE.CONFIRMQTY) * MAX(DM_DOCUMENT_D.BUNMO)/ MAX(DM_DOCUMENT_D.BUNJA),'FM99999999999990.99999'),'.') || 'BOX/0EA'
                        WHEN MAX(DM_DOCUMENT_D.STORERUOM) = 'KG' THEN RTRIM(TO_CHAR(SUM(WD_INVOICE.CONFIRMQTY) * MAX(DM_DOCUMENT_D.BUNMO)/ MAX(DM_DOCUMENT_D.BUNJA),'FM99999999999990.99999'),'.') || 'BOX/0KG'
                        ELSE RTRIM(TO_CHAR(FLOOR((SUM(WD_INVOICE.CONFIRMQTY) * MAX(DM_DOCUMENT_D.BUNMO)/ MAX(DM_DOCUMENT_D.BUNJA)) / MAX(MS_SKU.QTYPERBOX)),'FM99999999999990.99999'),'.') || 'BOX/'||RTRIM(TO_CHAR(MOD(SUM(WD_INVOICE.CONFIRMQTY) * MAX(DM_DOCUMENT_D.BUNMO)/ MAX(DM_DOCUMENT_D.BUNJA) , MAX(MS_SKU.QTYPERBOX)),'FM99999999999990.99999'),'.') ||'EA'
                        END AS TOTALQTY
                FROM   WD_INVOICE
                JOIN   WD_INPLAN
                ON     WD_INPLAN.DCCODE                 = WD_INVOICE.DCCODE
                AND    WD_INPLAN.STORERKEY              = WD_INVOICE.STORERKEY
                AND    WD_INPLAN.SLIPDT                 = WD_INVOICE.SLIPDT
                AND    WD_INPLAN.SLIPNO                 = WD_INVOICE.SLIPNO
                AND    WD_INPLAN.SLIPLINE               = WD_INVOICE.SLIPLINE
                AND    WD_INPLAN.DEL_YN                 = 'N'
                JOIN   DM_DOCUMENT_D
                ON     DM_DOCUMENT_D.DCCODE             = WD_INVOICE.DCCODE
                AND    DM_DOCUMENT_D.STORERKEY          = WD_INVOICE.STORERKEY
                AND    DM_DOCUMENT_D.DOCTYPE            = WD_INVOICE.DOCTYPE
                AND    DM_DOCUMENT_D.DELIVERYDATE       = WD_INVOICE.SLIPDT
                AND    DM_DOCUMENT_D.DOCNO              = WD_INVOICE.DOCNO
                AND    DM_DOCUMENT_D.DOCLINE            = WD_INVOICE.DOCLINE
                AND    DM_DOCUMENT_D.CHANNEL            = '1' AND    DM_DOCUMENT_D.DEL_YN             = 'N'     
                <if test="plant != null and plant != ''">  AND DM_DOCUMENT_D.PLANT =   #{plant}    </if>
                JOIN   DM_DOCUMENT_H                    
                ON     DM_DOCUMENT_H.DCCODE             = DM_DOCUMENT_D.DCCODE
                AND    DM_DOCUMENT_H.STORERKEY          = DM_DOCUMENT_D.STORERKEY
                AND    DM_DOCUMENT_H.DOCTYPE            = DM_DOCUMENT_D.DOCTYPE
                AND    DM_DOCUMENT_H.DELIVERYDATE       = DM_DOCUMENT_D.DELIVERYDATE
                AND    DM_DOCUMENT_H.DOCNO              = DM_DOCUMENT_D.DOCNO
                AND    DM_DOCUMENT_H.DEL_YN             = 'N'
                <if test="ordertype != null and ordertype != ''">   AND DM_DOCUMENT_H.ORDERTYPE =   #{ordertype}    </if>
                <if test="toCustkeyMulti != null and toCustkeyMulti != '' ">
                    <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                        <foreach collection="toCustkeyMulti" item="item">
                            OR DM_DOCUMENT_H.TO_CUSTKEY IN
                            <foreach collection="item" item="code" open="(" close=")" separator=",">
                                #{code}      
                            </foreach>
                        </foreach>
                    </trim>                                             
                </if>        
                <!-- 본점 다중선택 -->
                <if test="custkeyMulti != null and custkeyMulti != '' ">
                    <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                        <foreach collection="custkeyMulti" item="item">
                            OR DM_DOCUMENT_H.HDO_ID IN
                            <foreach collection="item" item="code" open="(" close=")" separator=",">
                                #{code}      
                            </foreach>
                        </foreach>
                    </trim>                                             
                </if>
                <if test="docnoMulti != null and docnoMulti != ''">
                   AND DM_DOCUMENT_H.DOCNO IN
                   <foreach collection="docnoMulti" item="code" open="(" close=")" separator=",">
                     #{code}
                   </foreach>   
                </if>
                JOIN   MS_SKU
                ON     MS_SKU.STORERKEY                 = DM_DOCUMENT_D.STORERKEY
                AND    MS_SKU.SKU                       = DM_DOCUMENT_D.SKU
                AND    MS_SKU.DEL_YN                    = 'N'
                AND    MS_SKU.SERIALYN                  = 'Y'
                <if test="sku != null and sku != '' ">
                    <if test="skuMulti != null and skuMulti.size() > 0">
                        <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                            <foreach collection="skuMulti" item="item">
                                OR WD_INPLAN.SKU IN
                                <foreach collection="item" item="code" open="(" close=")" separator=",">
                                    #{code}      
                                </foreach>
                            </foreach>
                        </trim>                                             
                    </if>
                </if>
                <if test="storagetype != null and storagetype != ''">   AND MS_SKU.STORAGETYPE      =   #{storagetype}  </if>
                <if test="skugroup != null and skugroup != ''">         AND LEFT(MS_SKU.SKUGROUP,2) =   #{skugroup}     </if>
                WHERE  WD_INVOICE.CONFIRMQTY     <![CDATA[>]]>  0
                AND    WD_INVOICE.DEL_YN                = 'N'
                AND    WD_INVOICE.INVOICETYPE           IN ('DELIVERYLABEL','DELIVERYLABEL_SN')
                AND    WD_INVOICE.PICK_LIST_NO          IS NULL
                <if test="fixdccode != null and fixdccode != ''">           AND    WD_INVOICE.DCCODE            =  #{fixdccode}       </if>
                <if test="gStorerkey != null and gStorerkey != ''"> AND    WD_INVOICE.STORERKEY         =  #{gStorerkey}   </if>                                                                                                                                                 
                <if test="slipdt != null and slipdt != ''">         AND    WD_INVOICE.SLIPDT            =  #{slipdt}       </if>
                <if test="printmethod != null and printmethod != ''">
                    <if test="printmethod == 'NEW'.toString()"> 
                        AND    WD_INVOICE.PRINT_YN        IN ('0','N')
                        AND    WD_INVOICE.CONFIRMQTY > 0
                    </if>
                    <if test="printmethod == 'OLD'.toString()"> 
                        AND    WD_INVOICE.PRINT_YN   NOT IN ('0','N') 
                    </if>
                </if>
                GROUP BY WD_INVOICE.SKU
       ) ,
        PRE_CLOSING_CENTER AS (
            SELECT BASECODE AS DCCODE
                 , DATA1 AS PRE_CLOSING_TIME    --1500 시분
              FROM CM_CODE
             WHERE CODELIST = 'PRE_CLOSING_CENTER'
               AND BASECODE = #{fixdccode}
        )                
	   SELECT /* [WdDeliveryLabelSNService.sqlx][getTab2MasterList][이력배송라벨출력-분류표출력 목록 조회][공두경][2025.10.15] */
                DCCODE    		/*물류센터*/
              , DCNAME    		/*물류센터명*/
		      , TO_CUSTKEY		/*관리처코드*/
		      , LBL_CUSTNAME1    /*납품처명1*/
		      , LBL_CUSTNAME2    /*납품처명2*/
		      , LBL_SKU          /*상품코드*/
		      , LBL_SKUNAME1     /*상품명1*/	
		      , LBL_SKUNAME2     /*상품명2*/
		      , LBL_QTY          /*수량*/
		      , LBL_QTY_2
		      , LBL_PAGENO1      /*차량번호*/
		      , LBL_CARGROUP		/*출차조*/		
		      , LBL_DELIVERYGROUP	/*POP*/
              , LBL_MEMO				/*특이사항*/
		      , LBL_LOC           	/*로케이션*/   
		      , STORAGETYPE            /* 저장조건 코드 */
		      , LBL_STORAGETYPE      /*저장조건*/
		      , STORAGETYPE1 AS LBL_STORAGETYPE_1 /* 저장조건1 */
		      , (SELECT MAX(CM_CODE.DATA2) FROM CM_CODE WHERE CM_CODE.CODELIST = 'STORAGETYPE' AND CM_CODE.BASECODE = STORAGETYPE) AS LBL_STORAGETYPE_2 /* 저장조건2 */
		      , LBL_DELIVERYDT       /*배송일자*/
		      , LBL_FROM_CUSTNAME    /*업체명*/
		      , LBL_PAGENO2          /*페이지번호*/
		      , LBL_BARCODETXT       /*바코드텍스트*/
		      , LBL_BARCODE1         /*바코드1*/
		      , LBL_BARCODE2         /*바코드2*/
		      , LBL_MEMO_OFN
		      , CARCHANGE			/*차량변경여부*/
		      , LBL_SMS_YN
		      , LBL_MARKWORD			/*특별관리고객표기*/
              , LBL_MANUDATE         /**/   
		      , LBL_PLACEOFORIGIN	/**/    
			  , LBL_FROM_CARNAME     /**/
		      , LBL_ROUTENAME        /**/
  		      , LOC_YN				/**/
		      , INVOICESORT          /**/
		      , SKUPRIORITY          /**/
		      , PREDELIVERYGROUP     /**/
		      , PRINT_YN             /**/
		      , LBL_ETC_MSG			/**/
		      , DELIVERYGROUP_SEQ    /**/
		      , LBL_DELIVERYGROUP_CHG
		      , ZONE     
		      , LBL_FOLABEL_YN /*FO 라벨 관리처 공통코드 등록 여부 */
		      , TITLE
		      , DCNAME
		      , T_TOTALQTY.TOTALQTY   AS TOTALQTY
		FROM (
				SELECT /* [WdDeliveryLabelSNService.sqlx][getTab2MasterList][이력배송라벨출력-분류표출력 목록 조회][공두경][2025.10.15] */
		               MAX(WD_INVOICE.DCCODE)                                                                           AS DCCODE    		/*물류센터*/
		              /*,MAX(CM_DC.DCNAME)                                                                                AS DCNAME */   		/*물류센터명*/
		              , FN_GETDCNAME(MAX(WD_INVOICE.DCCODE))||'/'||CASE WHEN NVL(MAX(PRE_CLOSING_CENTER.PRE_CLOSING_TIME),'0000') >= TO_CHAR(MAX(WD_INVOICE.ADDDATE),'HH24MI')  THEN '선마감'
                                                                        ELSE '본마감' END    AS DCNAME     /*물류센터명*/
                      , MAX(WD_INVOICE.ADDDATE)                                                           AS ADDDATE
                      , NVL(MAX(PRE_CLOSING_CENTER.PRE_CLOSING_TIME),'0000')                           AS PRE_CLOSING_TIME                                                               
				      ,MAX(DM_DOCUMENT_H.TO_CUSTKEY)                                                                    AS TO_CUSTKEY		/*관리처코드*/
				      ,MAX(CASE WHEN TRUNC(MONTHS_BETWEEN(SYSDATE,ms_cust.adddate)) = 0 or ms_custdlvinfo.qctype = 'Y' then '(R)' end)
				       ||SUBSTR(MAX(NVL(MS_CUST.DESCRIPTION,DM_DOCUMENT_H.TO_CUSTNAME)),1,30)                           AS LBL_CUSTNAME1    /*납품처명1*/
				      ,MAX(CASE WHEN MS_SKU.QTYPERBOX > 1 THEN 
				                    '( '||TO_CHAR(MS_SKU.QTYPERBOX)||MS_SKU.BASEUOM||'/BOX )' 
				                ELSE '' 
				           END)                                                                                         AS LBL_CUSTNAME2    /*납품처명2*/
				      ,MAX(NVL(WD_INPLAN.SKU,' '))                                                                      AS LBL_SKU          /*상품코드*/
				      ,REPLACE(FN_CONV_SKUBCRNAME(MAX(MS_SKU.DESCRIPTION),1),'~','-')                                   AS LBL_SKUNAME1     /*상품명1*/	
				      ,REPLACE(FN_CONV_SKUBCRNAME(MAX(MS_SKU.DESCRIPTION),2),'~','-')                                   AS LBL_SKUNAME2     /*상품명2*/
				      ,RTRIM(TO_CHAR(MAX(WD_INVOICE.CONFIRMQTY) * MAX(DM_DOCUMENT_D.BUNMO)/ MAX(DM_DOCUMENT_D.BUNJA)
				                     ,'FM99999999999990.99999'),'.')                               
				       ||MAX(DM_DOCUMENT_D.STORERUOM)                                                                   AS LBL_QTY          /*수량*/
				      ,' '                                                                             AS LBL_QTY_2 
				      ,NVL(MAX(WD_INPLAN.CARNO),fn_getdefcarno(MAX(WD_INVOICE.DCCODE)
				                                              ,MAX(WD_INVOICE.STORERKEY)
				                                              ,MAX(DM_DOCUMENT_H.TO_CUSTTYPE)
				                                              ,MAX(DM_DOCUMENT_H.TO_CUSTKEY)
				                                              ,MAX(WD_INVOICE.SLIPDT)))                                 AS LBL_PAGENO1      /*차량번호*/
				      ,NVL(MAX(NVL(CD1.BASEDESCR,CD1.BASECODE)),'NODATA')												AS LBL_CARGROUP		/*출차조*/		
				      ,NVL(MAX(WD_INPLAN.DELIVERYGROUP),fn_getdefdistrictcode(MAX(WD_INVOICE.DCCODE)
				                                                             ,MAX(WD_INVOICE.STORERKEY)
				                                                             ,MAX(DM_DOCUMENT_H.TO_CUSTTYPE)
				                                                             ,MAX(DM_DOCUMENT_H.TO_CUSTKEY)
				                                                             ,MAX(WD_INVOICE.SLIPDT))) 
				       || CASE WHEN CORE_CM_STRATEGY.FN_ISINVOICEUSEROTAINERNO(MAX(DM_DOCUMENT_H.DCCODE),MAX(DM_DOCUMENT_H.STORERKEY)) = 'Y' 
			                   THEN '-'||NVL(MAX(WD_INPLAN.MIXBOXKEY)
			                                ,nvl(FN_GETDEFROLLTAINERNO( MAX(WD_INVOICE.DCCODE)
									                                    ,MAX(WD_INVOICE.STORERKEY)
									                                    ,MAX(DM_DOCUMENT_H.TO_CUSTTYPE)
									                                    ,MAX(DM_DOCUMENT_H.TO_CUSTKEY)
									                                    ,MAX(WD_INVOICE.SLIPDT)),unistr('0'))) 
				           END                                                                                          AS LBL_DELIVERYGROUP	/*POP*/
		              ,    CASE WHEN MIN(WD_INVOICE.PRINT_CNT) <![CDATA[>]]> 1 
		                        THEN DECODE(MAX(WD_INVOICE.LABELSTATUS),'M','물량변경','') 
		                        ELSE ''
		                   END
		               ||  CASE WHEN     MAX(WD_INVOICE.DCCODE) = '2260' 
		                             AND MIN(WD_INVOICE.PRINT_CNT) <![CDATA[>]]> 1 
		                             AND MAX(NVL(TM_INPLAN.PREDELIVERYGROUP,' ')) <![CDATA[<>]]> ' ' 
		                             AND MAX(NVL(TM_INPLAN.PREDELIVERYGROUP,' ')) <![CDATA[<>]]> MAX(NVL(WD_INPLAN.DELIVERYGROUP,' ')) 
		                        THEN MAX(NVL(TM_INPLAN.PREDELIVERYGROUP,' ')) ||'>'
		                        ELSE '' 
		                   END
		               ||  CASE WHEN     MAX(WD_INVOICE.DCCODE) = '2620' 
		                             AND MAX(DM_DOCUMENT_D.PLANT) = '2300' 
		                        THEN ' 거래처별>> '||FN_ROLLTAINER(MAX(WD_INVOICE.DCCODE)
		                                                               ,MAX(WD_INVOICE.STORERKEY)
		                                                               ,MAX(DM_DOCUMENT_H.TO_CUSTTYPE)
		                                                               ,MAX(DM_DOCUMENT_H.TO_CUSTKEY)
		                                                               ,MAX(WD_INVOICE.SLIPDT)
		                                                               ,MAX(WD_INPLAN.DELIVERYGROUP)
		                                                               ,MAX(TM_INPLAN.PRIORITY)) 
		                        ELSE ''
		                   END                                                                                          AS LBL_MEMO				/*특이사항*/
				      ,DECODE(#{crossDc},'',MAX(MS_SKUDCSET.LOC),MAX(MS_SKUDCSET_CROSS.LOC))                            AS LBL_LOC           	/*로케이션*/   
				      ,MAX(NVL(CD2.BASEDESCR,CD2.BASECODE))																AS LBL_STORAGETYPE      /*저장조건*/
				      ,MAX(MS_SKU.STORAGETYPE)                                                                          AS STORAGETYPE
				      , NVL(FN_CODEDESCR(MAX(MS_SKUDCLABEL.STORERKEY),'MS_SKUDCLABEL_STORAGE', MAX(MS_SKUDCLABEL.STORAGE_GUBUN)), '')   AS   STORAGETYPE1 
				      ,FN_FORMAT_MASK( MAX(WD_INVOICE.SLIPDT),'####-##-##' )                                    		AS LBL_DELIVERYDT       /*배송일자*/
				      ,NVL(MAX(SUBSTR(B.FROM_CUSTNAME , 1, 30)),SUBSTR(MAX(NVL(MS_CUST.DESCRIPTION,' ')),31,30))  					AS LBL_FROM_CUSTNAME    /*업체명*/
				      ,MAX(NVL(WD_INVOICE.PAGE_NO,' '))                                                                 AS LBL_PAGENO2          /*페이지번호*/
				      ,FN_FORMAT_MASK( WD_INVOICE.INVOICENO,'##### ########## #### ###### ###')       					AS LBL_BARCODETXT       /*바코드텍스트*/
				      ,WD_INVOICE.INVOICENO                                                                        AS LBL_BARCODE1         /*바코드1*/
				      ,CASE WHEN FN_CODEVALUE('FW00', 'BIGOLABEL_CUST', MAX(DM_DOCUMENT_H.MNGPLC_ID), 'BASECODE') IS NOT NULL
                          THEN ''
                          ELSE WD_INVOICE.INVOICENO
                        END                                                                        AS LBL_BARCODE2         /*바코드2*/
                      ,CASE WHEN FN_CODEVALUE('FW00', 'BIGOLABEL_CUST', MAX(DM_DOCUMENT_H.MNGPLC_ID), 'BASECODE') IS NOT NULL
                          THEN SUBSTR(LTRIM(MAX(DM_DOCUMENT_D.REQUESTMEMO)), 0, 15)
                          ELSE ''
                        END                                                                            AS LBL_MEMO_OFN  
				      ,CASE WHEN (   MAX(WD_INPLAN.CARNO) IS NOT NULL 
				                 AND MAX(WD_INPLAN.CARNO) <![CDATA[<>]]> fn_getdefcarno(MAX(WD_INVOICE.DCCODE)
					                                                                   ,MAX(WD_INVOICE.STORERKEY)
					                                                                   ,MAX(DM_DOCUMENT_H.TO_CUSTTYPE)
					                                                                   ,MAX(DM_DOCUMENT_H.TO_CUSTKEY)
					                                                                   ,MAX(WD_INVOICE.SLIPDT))
					             )
				             OR  (   MAX(WD_INPLAN.DELIVERYGROUP) IS NOT NULL
				                 AND MAX(WD_INPLAN.DELIVERYGROUP) <![CDATA[<>]]> fn_getdefdistrictcode(MAX(WD_INVOICE.DCCODE)
				                                                                                      ,MAX(WD_INVOICE.STORERKEY)
				                                                                                      ,MAX(DM_DOCUMENT_H.TO_CUSTTYPE)
				                                                                                      ,MAX(DM_DOCUMENT_H.TO_CUSTKEY)
				                                                                                      ,MAX(WD_INVOICE.SLIPDT))
				                 ) THEN '차량변경'
				            ELSE ''
				       END                                                                                              AS CARCHANGE			/*차량변경여부*/
				      ,NVL(MAX(MS_SKUDCSET.SMS_YN),'N') as LBL_SMS_YN
				      ,FN_CODEVALUE('FW00', 'MARKWORD_SRM', MAX(MS_CUST_REDZONE_SRM.MARK_WORD), 'BASEDESCR') 			AS LBL_MARKWORD			/*특별관리고객표기*/
		              ,FN_FORMAT_MASK( MAX(WD_INVOICE.SLIPDT), '####-##-##' )                                   AS LBL_MANUDATE         /**/   
				      ,DECODE( 
				      		  MAX((SELECT BASEDESCR					    
							    FROM  CM_CODE_STORER CM_CODE
							    WHERE CM_CODE.STORERKEY = MS_SKU.STORERKEY
							    AND   CM_CODE.CODELIST  = 'COUNTRY'
							    AND   CM_CODE.BASECODE  = MS_SKU.COUNTRYOFORIGIN
							    AND   ROWNUM = 1))
				              ,'NOT FOUND'
				              ,''
				              ,'FW'||left(
				              			  MAX((SELECT BASEDESCR					    
										    FROM  CM_CODE_STORER CM_CODE
										    WHERE CM_CODE.STORERKEY = MS_SKU.STORERKEY
										    AND   CM_CODE.CODELIST  = 'COUNTRY'
										    AND   CM_CODE.BASECODE  = MS_SKU.COUNTRYOFORIGIN
										    AND   ROWNUM = 1)),1)
				                   ||MAX(MS_SKU.COUNTRYOFORIGIN) )                                                      AS LBL_PLACEOFORIGIN	/**/    
					  ,MAX(NVL(B.CARNO,' '))                                                            					AS LBL_FROM_CARNAME     /**/
				      ,MAX(NVL(WD_INVOICE.ROUTE,' '))                                                                   AS LBL_ROUTENAME        /**/
		  		      ,DECODE(DECODE(#{crossDc},'',MAX(MS_SKUDCSET.LOC),MAX(MS_SKUDCSET_CROSS.LOC))
		  		              ,NULL,2
		                      ,'STD',2
		                      ,1)                                                                                       AS LOC_YN				/**/
				      ,MAX(SUBSTR(WD_INVOICE.INVOICENO,0,19)||SUBSTR(WD_INVOICE.INVOICENO,26,3))                             AS INVOICESORT          /**/
				      ,NVL(MAX(MS_SKUDCSET.OTHER01),'5')                                                                AS SKUPRIORITY          /**/
				      ,MAX(TM_INPLAN.PREDELIVERYGROUP)	                                                                AS PREDELIVERYGROUP     /**/
				      ,MAX(WD_INVOICE.PRINT_YN)	                                                                        AS PRINT_YN             /**/
				      ,CASE WHEN LEFT(MAX(MS_SKU.SKUGROUP),2) in ('20','30','40') 
				            then '본 배송분류표는 식품위생법상의 고지사항과는 무관합니다.'
				            ELSE '본 배송분류표는 관련법상의 고지사항과는 무관합니다.'
				       END                                                                                              AS LBL_ETC_MSG			/**/
				      ,SUBSTR(MAX(WD_INPLAN.DELIVERYGROUP),2,length(MAX(WD_INPLAN.DELIVERYGROUP)))                      AS DELIVERYGROUP_SEQ    /**/
				      ,CASE WHEN     MAX(WD_INVOICE.DCCODE) = '2260' 
		                             AND MIN(WD_INVOICE.PRINT_CNT) <![CDATA[>]]> 1 
		                             AND MAX(NVL(TM_INPLAN.PREDELIVERYGROUP,' ')) <![CDATA[<>]]> ' ' 
		                             AND MAX(NVL(TM_INPLAN.PREDELIVERYGROUP,' ')) <![CDATA[<>]]> MAX(NVL(WD_INPLAN.DELIVERYGROUP,' ')) 
		                        THEN MAX(NVL(TM_INPLAN.PREDELIVERYGROUP,' ')) ||'>'
		                        ELSE '' 
		                   END
		               || NVL(MAX(WD_INPLAN.DELIVERYGROUP),fn_getdefdistrictcode(MAX(WD_INVOICE.DCCODE)
				                                                             ,MAX(WD_INVOICE.STORERKEY)
				                                                             ,MAX(DM_DOCUMENT_H.TO_CUSTTYPE)
				                                                             ,MAX(DM_DOCUMENT_H.TO_CUSTKEY)
				                                                             ,MAX(WD_INVOICE.SLIPDT))) 
				       || CASE WHEN CORE_CM_STRATEGY.FN_ISINVOICEUSEROTAINERNO(MAX(DM_DOCUMENT_H.DCCODE),MAX(DM_DOCUMENT_H.STORERKEY)) = 'Y' 
			                   THEN '-'||NVL(MAX(WD_INPLAN.MIXBOXKEY)
			                                ,nvl(FN_GETDEFROLLTAINERNO( MAX(WD_INVOICE.DCCODE)
									                                    ,MAX(WD_INVOICE.STORERKEY)
									                                    ,MAX(DM_DOCUMENT_H.TO_CUSTTYPE)
									                                    ,MAX(DM_DOCUMENT_H.TO_CUSTKEY)
									                                    ,MAX(WD_INVOICE.SLIPDT)),'0')) 
				           END                                                                                          AS LBL_DELIVERYGROUP_CHG
				       ,DECODE(#{crossDc},'',MAX(MS_LOCATION.ZONE),MAX(MS_LOCATION_CROSS.ZONE)) AS ZONE
				       ,CASE WHEN FN_CODEVALUE('FW00', 'FOLABEL_CUST', MAX(DM_DOCUMENT_H.MNGPLC_ID), 'BASECODE') IS NOT NULL
                          THEN 'Y'
                          ELSE 'N'
                        END                                                                            AS LBL_FOLABEL_YN
                       ,'총량피킹'                                                                      AS TITLE   
				FROM   WD_INVOICE
				JOIN   WD_INPLAN
				ON     WD_INPLAN.DCCODE                 = WD_INVOICE.DCCODE
				AND    WD_INPLAN.STORERKEY              = WD_INVOICE.STORERKEY
				AND    WD_INPLAN.SLIPDT                 = WD_INVOICE.SLIPDT
				AND    WD_INPLAN.SLIPNO                 = WD_INVOICE.SLIPNO
				AND    WD_INPLAN.SLIPLINE               = WD_INVOICE.SLIPLINE
				AND    WD_INPLAN.DEL_YN                 = 'N'
				JOIN   DM_DOCUMENT_D
				ON     DM_DOCUMENT_D.DCCODE             = WD_INVOICE.DCCODE
				AND    DM_DOCUMENT_D.STORERKEY          = WD_INVOICE.STORERKEY
				AND    DM_DOCUMENT_D.DOCTYPE            = WD_INVOICE.DOCTYPE
				AND    DM_DOCUMENT_D.DELIVERYDATE       = WD_INVOICE.SLIPDT
				AND    DM_DOCUMENT_D.DOCNO              = WD_INVOICE.DOCNO
				AND    DM_DOCUMENT_D.DOCLINE            = WD_INVOICE.DOCLINE
				AND    DM_DOCUMENT_D.CHANNEL            = '1' AND    DM_DOCUMENT_D.DEL_YN             = 'N'		
				<if test="plant != null and plant != ''">	AND DM_DOCUMENT_D.PLANT =	#{plant}	</if>
				JOIN   DM_DOCUMENT_H                    
				ON     DM_DOCUMENT_H.DCCODE             = DM_DOCUMENT_D.DCCODE
				AND    DM_DOCUMENT_H.STORERKEY          = DM_DOCUMENT_D.STORERKEY
				AND    DM_DOCUMENT_H.DOCTYPE            = DM_DOCUMENT_D.DOCTYPE
				AND    DM_DOCUMENT_H.DELIVERYDATE       = DM_DOCUMENT_D.DELIVERYDATE
				AND    DM_DOCUMENT_H.DOCNO              = DM_DOCUMENT_D.DOCNO
				AND    DM_DOCUMENT_H.DEL_YN             = 'N'
				<if test="ordertype != null and ordertype != ''">	AND DM_DOCUMENT_H.ORDERTYPE =	#{ordertype}	</if>
				<if test="toCustkeyMulti != null and toCustkeyMulti != '' ">
			    	<trim prefix="AND (" suffix=")" prefixOverrides="OR">
			    		<foreach collection="toCustkeyMulti" item="item">
			    			OR DM_DOCUMENT_H.TO_CUSTKEY IN
			    			<foreach collection="item" item="code" open="(" close=")" separator=",">
			    				#{code} 	 
			          		</foreach>
			        	</foreach>
			      	</trim>			                                    
		        </if>        
				<!-- 본점 다중선택 -->
		    	<if test="custkeyMulti != null and custkeyMulti != '' ">
			    	<trim prefix="AND (" suffix=")" prefixOverrides="OR">
			    		<foreach collection="custkeyMulti" item="item">
			    			OR DM_DOCUMENT_H.HDO_ID IN
			    			<foreach collection="item" item="code" open="(" close=")" separator=",">
			    				#{code} 	 
			          		</foreach>
			        	</foreach>
			      	</trim>			                                    
		        </if>
		 	    <if test="docnoMulti != null and docnoMulti != ''">
			       AND DM_DOCUMENT_H.DOCNO IN
			       <foreach collection="docnoMulti" item="code" open="(" close=")" separator=",">
			         #{code}
			       </foreach>   
		        </if>
				JOIN   MS_SKU
				ON     MS_SKU.STORERKEY                 = DM_DOCUMENT_D.STORERKEY
				AND    MS_SKU.SKU                       = DM_DOCUMENT_D.SKU
				AND    MS_SKU.DEL_YN                    = 'N'
				AND    MS_SKU.SERIALYN                  = 'Y'
				<if test="sku != null and sku != '' ">
					<if test="skuMulti != null and skuMulti.size() > 0">
						<trim prefix="AND (" suffix=")" prefixOverrides="OR">
							<foreach collection="skuMulti" item="item">
								OR WD_INPLAN.SKU IN
								<foreach collection="item" item="code" open="(" close=")" separator=",">
									#{code} 	 
					      		</foreach>
					    	</foreach>
					  	</trim>			                                    
			    	</if>
		        </if>
		        <if test="storagetype != null and storagetype != ''">	AND MS_SKU.STORAGETYPE      =	#{storagetype}  </if>
				<if test="skugroup != null and skugroup != ''">	   		AND LEFT(MS_SKU.SKUGROUP,2)	=	#{skugroup}  	</if>
		        LEFT JOIN CM_CAR
				ON     WD_INPLAN.CARNO                 = CM_CAR.CARNO
				AND    WD_INPLAN.DEL_YN                = 'N'
			    LEFT JOIN TM_INPLAN
			    ON     WD_INPLAN.DCCODE                 = TM_INPLAN.DCCODE
			    AND    WD_INPLAN.DOCTYPE                = TM_INPLAN.DOCTYPE
			    AND    WD_INPLAN.SLIPDT                 = TM_INPLAN.SLIPDT
			    AND    WD_INPLAN.SLIPNO                 = TM_INPLAN.SLIPNO
			    AND    WD_INPLAN.DEL_YN                 = 'N'
				LEFT JOIN MS_SKUDCSET
				ON     MS_SKUDCSET.DCCODE      	= DM_DOCUMENT_D.DCCODE
				AND    MS_SKUDCSET.STORERKEY    = DM_DOCUMENT_D.STORERKEY
				AND    MS_SKUDCSET.SKU          = DM_DOCUMENT_D.SKU
				AND    MS_SKUDCSET.DEL_YN       = 'N'
				<if test="exceptLoc != null and exceptLoc != ''">            
                    <if test="exceptLoc == '1'.toString()"> 
                        AND     MS_SKUDCSET.LOC        NOT IN  ('STD','중단빈')
                    </if>
                </if>  
				LEFT JOIN MS_LOCATION   
			    ON     MS_LOCATION.DCCODE       = MS_SKUDCSET.DCCODE   
			    AND    MS_LOCATION.LOC          = MS_SKUDCSET.LOC 
			    
		        LEFT JOIN MS_SKUDCSET MS_SKUDCSET_CROSS
		        ON     MS_SKUDCSET_CROSS.DCCODE             = #{crossDc}
		        AND    MS_SKUDCSET_CROSS.STORERKEY          = DM_DOCUMENT_D.STORERKEY   
		        AND    MS_SKUDCSET_CROSS.SKU                = DM_DOCUMENT_D.SKU   
		        AND    MS_SKUDCSET_CROSS.DEL_YN             = 'N' 
		        <if test="exceptLoc != null and exceptLoc != ''">            
                    <if test="exceptLoc == '1'.toString()"> 
                        AND    MS_SKUDCSET_CROSS.LOC        NOT IN  ('STD','중단빈')
                    </if>
                </if>  
		        LEFT JOIN MS_LOCATION    MS_LOCATION_CROSS
		      	ON     MS_LOCATION_CROSS.DCCODE   			= #{crossDc}
		        AND    MS_LOCATION_CROSS.LOC      			= MS_SKUDCSET_CROSS.LOC   
		        AND    MS_LOCATION_CROSS.DEL_YN   			='N'
				LEFT  JOIN MS_CUST                 
				ON     MS_CUST.STORERKEY                      = DM_DOCUMENT_H.STORERKEY
				AND    MS_CUST.CUSTTYPE                       = DM_DOCUMENT_H.TO_CUSTTYPE
				AND    MS_CUST.CUSTKEY                        = DECODE(DM_DOCUMENT_H.STORERKEY,'FW00',DM_DOCUMENT_H.MNGPLC_ID,DM_DOCUMENT_H.TO_CUSTKEY)
				LEFT JOIN MS_CUSTDLVINFO
				ON	   MS_CUSTDLVINFO.STORERKEY	  = DM_DOCUMENT_H.STORERKEY
				AND	   MS_CUSTDLVINFO.DLVCUSTKEY  = DM_DOCUMENT_H.TO_CUSTKEY
				AND	   MS_CUSTDLVINFO.CUSTTYPE	  = DM_DOCUMENT_H.TO_CUSTTYPE
				JOIN   CM_DC
				ON     CM_DC.DCCODE                     = WD_INVOICE.DCCODE
				AND    CM_DC.DEL_YN                     = 'N'
				LEFT JOIN MS_CUST_REDZONE_SRM
				ON	   MS_CUST_REDZONE_SRM.STORERKEY	  	= DM_DOCUMENT_H.STORERKEY
				AND	   MS_CUST_REDZONE_SRM.CUSTKEY  		= DM_DOCUMENT_H.TO_CUSTKEY
				AND	   MS_CUST_REDZONE_SRM.DEL_YN	  		= 'N'
				LEFT JOIN IB_SRMFOLABEL B   
		        ON     WD_INVOICE.DOCNO = B.DOCNO
		        AND    WD_INVOICE.DOCLINE = B.DOCLINE
		        LEFT JOIN MS_SKUDCLABEL
                ON   MS_SKUDCLABEL.DCCODE      = WD_INVOICE.DCCODE
                AND  MS_SKUDCLABEL.STORERKEY   = WD_INVOICE.STORERKEY
                AND  MS_SKUDCLABEL.SKU         = WD_INVOICE.SKU
                LEFT JOIN PRE_CLOSING_CENTER
                ON   PRE_CLOSING_CENTER.DCCODE = WD_INVOICE.DCCODE   
		        LEFT JOIN CM_CODE_STORER CD1  ON CD1.STORERKEY  = 'FW00' 			AND CD1.CODELIST  = 'CARGROUP' 		AND CD1.BASECODE   = CM_CAR.CARGROUP
		        LEFT JOIN CM_CODE_STORER CD2  ON CD2.STORERKEY  = MS_SKU.STORERKEY  AND CD2.CODELIST  = 'STORAGETYPE' 	AND CD2.BASECODE   = MS_SKU.STORAGETYPE
				WHERE  WD_INVOICE.CONFIRMQTY     <![CDATA[>]]>  0
				AND    WD_INVOICE.DEL_YN                = 'N'
				AND    WD_INVOICE.INVOICETYPE           IN ('DELIVERYLABEL','DELIVERYLABEL_SN')
				AND    WD_INVOICE.PICK_LIST_NO          IS NULL
				<if test="fixdccode != null and fixdccode != ''">	        AND    WD_INVOICE.DCCODE            =  #{fixdccode}       </if>
				<if test="gStorerkey != null and gStorerkey != ''">	AND    WD_INVOICE.STORERKEY         =  #{gStorerkey}   </if>                                                                                                                                                 
				<if test="slipdt != null and slipdt != ''">         AND    WD_INVOICE.SLIPDT	        =  #{slipdt}       </if>
				<if test="printmethod != null and printmethod != ''">
					<if test="printmethod == 'NEW'.toString()"> 
						AND    WD_INVOICE.PRINT_YN        IN ('0','N')
		                AND    WD_INVOICE.CONFIRMQTY > 0
					</if>
					<if test="printmethod == 'OLD'.toString()"> 
						AND    WD_INVOICE.PRINT_YN   NOT IN ('0','N') 
					</if>
				</if>
				GROUP BY WD_INVOICE.INVOICENO, B.FROM_CUSTNAME, B.CARNO       
		)   A    
		JOIN T_TOTALQTY
		ON   T_TOTALQTY.SKU = A.LBL_SKU
		WHERE 1=1		
		<if test="zoneMulti != null and zoneMulti != ''">
	       AND ZONE IN
	       <foreach collection="zoneMulti" item="code" open="(" close=")" separator=",">
	         #{code}
	       </foreach>   
        </if>
		<if test="exceptLoc != null and exceptLoc != ''">            
            <if test="exceptLoc == '1'.toString()">
                AND    LBL_LOC    NOT IN  ('STD','중단빈') 
            </if>
        </if>    
    </select>
        
    <select id="getPrintHeaderList" resultType="WdDeliveryLabelSNResPrintHeaderDto">
	   SELECT /* [WdDeliveryLabelSNService.sqlx][getPrintHeaderList][피킹지출력 헤더 조회][공두경][2025.10.15] */
              AA.DCCODE                AS DCCODE 
             ,AA.STORERKEY             AS STORERKEY
             ,AA.SLIPDT                AS SLIPDT
             ,AA.TASKSYSTEM            AS TASKSYSTEM
             ,AA.PICK_BATCH_NO         AS PICK_BATCH_NO
             ,AA.PICK_NO               AS PICK_NO
             ,AA.PICK_LIST_NO          AS PICK_LIST_NO
             ,AA.ZONE                  AS ZONE
             ,MAX(AA.PLANTDESC)        AS PLANTDESC 
             ,MAX(AA.ZONE) 		       AS ZONE
             ,#{memo}                  AS MEMO
             ,MAX(AA.PRINT_CNT)        AS PRINT_CNT
             ,ROW_NUMBER() OVER(PARTITION BY AA.ZONE ORDER BY AA.ZONE) RNUM
		 FROM (
		SELECT WD_INVOICE.STORERKEY                                             AS STORERKEY		          
		         ,WD_INVOICE.INVOICEDT                                          AS INVOICEDT
		         ,MS_SKU.STORAGETYPE                                            AS STORAGETYPE
		         ,MS_SKU.SKU                                                    AS SKU         
		         ,MS_SKU.DESCRIPTION                                            AS SKUNAME                                                               
		         ,WD_INVOICE.CONFIRMQTY                                         AS CONFIRMQTY
		         ,DECODE(#{crossDc},'',MAX(MS_SKUDCSET.LOC),MAX(MS_SKUDCSET_CROSS.LOC))  AS LOC
		         ,DECODE(#{crossDc},'',MAX(MS_LOCATION.ZONE),MAX(MS_LOCATION_CROSS.ZONE)) AS ZONE  
		         ,WD_INVOICE.UOM                                                AS UOM
		         ,MS_SKU.QTYPERBOX                                              AS QTYPERBOX
		         ,MIN(CM_LOT.LOTTABLE01)                                        AS LOTTABLE01
		         ,WD_INVOICE.DCCODE                                             AS DCCODE
		         ,WD_INVOICE.SLIPDT                                             AS SLIPDT
		         ,''                                                            AS TASKSYSTEM     /*WD_TASK에 해당하는 컬럼은 공백처리함*/
		         ,''                                                            AS PICK_BATCH_NO  /*WD_TASK에 해당하는 컬럼은 공백처리함*/
                 ,''                                                            AS PICK_NO        /*WD_TASK에 해당하는 컬럼은 공백처리함*/  
                 ,''                                                            AS PICK_LIST_NO   /*WD_TASK에 해당하는 컬럼은 공백처리함*/
                 ,MAX(MS_PICKBATCHGROUP.DESCRIPTION)                            AS PLANTDESC
                 ,MAX(WD_INVOICE.PRINT_CNT)                                     AS PRINT_CNT
		  FROM WD_INVOICE 
          JOIN DM_DOCUMENT_D
          ON     DM_DOCUMENT_D.DCCODE             = WD_INVOICE.DCCODE
          AND    DM_DOCUMENT_D.STORERKEY          = WD_INVOICE.STORERKEY
          AND    DM_DOCUMENT_D.DOCTYPE            = WD_INVOICE.DOCTYPE
          AND    DM_DOCUMENT_D.DELIVERYDATE       = WD_INVOICE.SLIPDT
          AND    DM_DOCUMENT_D.DOCNO              = WD_INVOICE.DOCNO
          AND    DM_DOCUMENT_D.DOCLINE            = WD_INVOICE.DOCLINE
          AND    DM_DOCUMENT_D.CHANNEL            = '1' AND    DM_DOCUMENT_D.DEL_YN             = 'N'     
          JOIN   DM_DOCUMENT_H                    
          ON     DM_DOCUMENT_H.DCCODE             = DM_DOCUMENT_D.DCCODE
          AND    DM_DOCUMENT_H.STORERKEY          = DM_DOCUMENT_D.STORERKEY
          AND    DM_DOCUMENT_H.DOCTYPE            = DM_DOCUMENT_D.DOCTYPE
          AND    DM_DOCUMENT_H.DELIVERYDATE       = DM_DOCUMENT_D.DELIVERYDATE
          AND    DM_DOCUMENT_H.DOCNO              = DM_DOCUMENT_D.DOCNO
          AND    DM_DOCUMENT_H.DEL_YN             = 'N'
		  JOIN MS_SKU   
		   ON     MS_SKU.STORERKEY                 = WD_INVOICE.STORERKEY   
		   AND    MS_SKU.SKU                       = WD_INVOICE.SKU   
		   AND    MS_SKU.DEL_YN                    = 'N'
		  LEFT JOIN MS_SKUDCSET   
		   ON     MS_SKUDCSET.DCCODE               = WD_INVOICE.DCCODE   
		   AND    MS_SKUDCSET.STORERKEY            = WD_INVOICE.STORERKEY   
		   AND    MS_SKUDCSET.SKU                  = WD_INVOICE.SKU   
		   AND    MS_SKUDCSET.DEL_YN               = 'N' 
		  LEFT JOIN ST_STOCK
		  ON   ST_STOCK.DCCODE = WD_INVOICE.DCCODE
		  AND  ST_STOCK.SKU    = WD_INVOICE.SKU
		  AND  ST_STOCK.STORERKEY = WD_INVOICE.STORERKEY  
		  LEFT JOIN CM_LOT
		  ON   CM_LOT.LOT = ST_STOCK.LOT
		  AND  CM_LOT.STORERKEY = MS_SKUDCSET.STORERKEY
		  LEFT JOIN MS_LOCATION   
		  ON     MS_LOCATION.DCCODE       = MS_SKUDCSET.DCCODE   
		  AND    MS_LOCATION.LOC          = MS_SKUDCSET.LOC
		 LEFT JOIN MS_SKUDCSET MS_SKUDCSET_CROSS
          ON   MS_SKUDCSET_CROSS.DCCODE               = #{crossDc}
          AND  MS_SKUDCSET_CROSS.STORERKEY            = WD_INVOICE.STORERKEY   
          AND  MS_SKUDCSET_CROSS.SKU                  = WD_INVOICE.SKU   
          AND  MS_SKUDCSET_CROSS.DEL_YN               = 'N'
          LEFT JOIN MS_LOCATION    MS_LOCATION_CROSS
      	  ON   MS_LOCATION_CROSS.DCCODE   = #{crossDc}
          AND  MS_LOCATION_CROSS.LOC      = MS_SKUDCSET_CROSS.LOC   
          AND  MS_LOCATION_CROSS.DEL_YN   ='N'
          JOIN MS_CUSTDLVINFO         
          ON   MS_CUSTDLVINFO.STORERKEY    = DM_DOCUMENT_H.STORERKEY         
          AND  MS_CUSTDLVINFO.CUSTTYPE     = DM_DOCUMENT_H.TO_CUSTTYPE         
          AND  MS_CUSTDLVINFO.DLVCUSTKEY   = DM_DOCUMENT_H.TO_CUSTKEY        
          JOIN MS_PICKBATCHGROUP      
          ON   DM_DOCUMENT_D.DCCODE        = MS_PICKBATCHGROUP.DCCODE      
          AND  DM_DOCUMENT_D.PLANT         = MS_PICKBATCHGROUP.PLANT      
          AND  MS_SKU.STORAGETYPE          = MS_PICKBATCHGROUP.STORAGETYPE       
          AND  MS_CUSTDLVINFO.DISTANCETYPE = MS_PICKBATCHGROUP.DISTANCETYPE   
		 WHERE 1=1
		 <choose>
            <when test="invoicenoMulti != null and invoicenoMulti != ''">
            	AND WD_INVOICE.INVOICENO IN
		        <foreach collection="invoicenoMulti" item="code" open="(" close=")" separator=",">
		          #{code}
		        </foreach>   
            </when>
            <otherwise>
            	AND 1 = 2
            </otherwise>
         </choose>
		 GROUP BY WD_INVOICE.INVOICENO
                , WD_INVOICE.STORERKEY
                , WD_INVOICE.INVOICEDT 
                , MS_SKU.STORAGETYPE
                , MS_SKU.SKU
                , MS_SKU.DESCRIPTION
                , WD_INVOICE.CONFIRMQTY
                , MS_SKUDCSET.LOC
                , MS_LOCATION.ZONE
                , WD_INVOICE.UOM
                , MS_SKU.QTYPERBOX
                , WD_INVOICE.DCCODE  
                , WD_INVOICE.SLIPDT 
		)AA
		GROUP BY AA.DCCODE                 
                ,AA.STORERKEY    
                ,AA.ZONE 
                ,AA.SLIPDT                  
                ,AA.TASKSYSTEM             
                ,AA.PICK_BATCH_NO           
                ,AA.PICK_NO                
                ,AA.PICK_LIST_NO
    </select>
    
    <select id="getPrintDetailList" resultType="WdDeliveryLabelSNResPrintDetailDto">
	   SELECT /* [WdDeliveryLabelSNService.sqlx][getPrintDetailList][피킹지출력 상세 조회][공두경][2025.10.15] */
               A.STORERKEY,
		       A.INVOICEDT,
		       A.STORAGETYPE,
		       A.SKU,
		       A.SKUNAME,
		       A.CONFIRMQTY,
		       A.LOC,
		       A.ZONE,
		       A.UOM AS BASEUOM,
               A.QTYPERBOX,
               A.LOTTABLE01,
               A.PROCESSQTY,                                         
               A.CONFIRMQTY AS TOTEAQTY,                                           
               A.SLIPDT,                                             
               A.COURIER,                                            
               A.PICK_NO,                                          
		 fn_FORMAT_MASK2( A.Invoicedt,
		         '####년##월##일' )  ||'  '   
		         ||' 출고('                           || NVL(fn_DESCR_CODE(A.STORERKEY,
		         'STORAGETYPE',
		         A.STORAGETYPE),
		         '    ') ||') 피킹리스트'                                                                      AS PICK_LIST_TITLE                 
		         ,CASE 
		             WHEN A.UOM = 'KG'  THEN A.CONFIRMQTY 
		             ELSE 0 
		         END                                                                      AS KGQTY        
		         ,CASE                 
		             WHEN A.UOM = 'KG' THEN TO_NUMBER(0)                   
		             WHEN A.UOM = 'BOX' THEN A.CONFIRMQTY                  
		             WHEN A.UOM = 'PAC' THEN TO_NUMBER(0)                                     
		             WHEN A.UOM = 'EA'                 THEN TRUNC(A.CONFIRMQTY / A.QTYPERBOX)                        
		         END                                                         AS BOXQTY                     
		         ,CASE                 
		             WHEN A.UOM = 'KG' THEN TO_NUMBER(0)                  
		             WHEN A.UOM = 'BOX' THEN TO_NUMBER(0)                  
		             WHEN A.UOM = 'PAC' THEN TO_NUMBER(0)                                     
		             WHEN A.UOM = 'EA'                 THEN MOD(A.CONFIRMQTY ,A.QTYPERBOX)                                                                            
		         END                                                                   AS EAQTY   
		 FROM (        
		 SELECT AA.STORERKEY, AA.INVOICEDT ,AA.STORAGETYPE, AA.SKU, AA.LOC
		        , MAX(AA.SKUNAME)                                            AS SKUNAME
		        , MAX(AA.ZONE)                                               AS ZONE
		        , MAX(AA.UOM)                                                AS UOM
		        , MAX(AA.QTYPERBOX)                                          AS QTYPERBOX  
		        , SUM(AA.CONFIRMQTY)                                         AS CONFIRMQTY
		        , MIN(AA.LOTTABLE01)                                         AS LOTTABLE01  
		        , MAX(AA.PROCESSQTY)                                         AS PROCESSQTY
                , MAX(AA.SLIPDT)                                             AS SLIPDT
                , MAX(AA.PICK_NO)                                            AS PICK_NO
                , MAX(AA.COURIER)                                            AS COURIER
		 FROM (
		SELECT WD_INVOICE.STORERKEY                                          AS STORERKEY                             
		         ,WD_INVOICE.INVOICEDT                                       AS INVOICEDT
		         ,MS_SKU.STORAGETYPE                                         AS STORAGETYPE
		         ,MS_SKU.SKU                                                 AS SKU         
		         ,MS_SKU.DESCRIPTION                                         AS SKUNAME                                                               
		         ,WD_INVOICE.CONFIRMQTY                                      AS CONFIRMQTY
		         ,DECODE(#{crossDc},'',MAX(MS_SKUDCSET.LOC),MAX(MS_SKUDCSET_CROSS.LOC))   AS LOC
		         ,DECODE(#{crossDc},'',MAX(MS_LOCATION.ZONE),MAX(MS_LOCATION_CROSS.ZONE)) AS ZONE
		         ,WD_INVOICE.UOM                                             AS UOM
		         ,MS_SKU.QTYPERBOX                                           AS QTYPERBOX
		         ,MIN(CM_LOT.LOTTABLE01)                                     AS LOTTABLE01  
		         ,WD_INVOICE.CONFIRMQTY                                      AS PROCESSQTY
                 ,WD_INVOICE.SLIPDT                                          AS SLIPDT
                 ,''                                                         AS PICK_NO     /*WD_TASK에 해당하는 컬럼은 공백처리함*/
                 ,MAX(DM_DOCUMENT_H.COURIER)                                 AS COURIER
		  FROM WD_INVOICE  
          JOIN    DM_DOCUMENT_H
          ON      DM_DOCUMENT_H.DCCODE     = WD_INVOICE.DCCODE
          AND     DM_DOCUMENT_H.DOCTYPE    = 'WD'
          AND     DM_DOCUMENT_H.STORERKEY  = WD_INVOICE.STORERKEY
          AND     DM_DOCUMENT_H.ORGANIZE   = WD_INVOICE.ORGANIZE 
          --튜닝.modify
          AND     DM_DOCUMENT_H.DELIVERYDATE = WD_INVOICE.SLIPDT    
          AND     DM_DOCUMENT_H.DOCNO      = WD_INVOICE.DOCNO
          AND     DM_DOCUMENT_H.DEL_YN     = 'N'       
		  JOIN MS_SKU   
		   ON     MS_SKU.STORERKEY                 = WD_INVOICE.STORERKEY   
		   AND    MS_SKU.SKU                       = WD_INVOICE.SKU   
		   AND    MS_SKU.DEL_YN                    = 'N'
		  LEFT JOIN MS_SKUDCSET   
		   ON     MS_SKUDCSET.DCCODE               = WD_INVOICE.DCCODE   
		   AND    MS_SKUDCSET.STORERKEY            = WD_INVOICE.STORERKEY   
		   AND    MS_SKUDCSET.SKU                  = WD_INVOICE.SKU   
		   AND    MS_SKUDCSET.DEL_YN               = 'N' 
		  LEFT JOIN ST_STOCK
		  ON   ST_STOCK.DCCODE = WD_INVOICE.DCCODE
		  AND  ST_STOCK.SKU    = WD_INVOICE.SKU
		  AND  ST_STOCK.STORERKEY = WD_INVOICE.STORERKEY  
		  AND  ST_STOCK.STOCKTYPE      = 'GOOD' 
          AND  ST_STOCK.STOCKGRADE     = 'STD'
		  LEFT JOIN CM_LOT
		  ON   CM_LOT.LOT = ST_STOCK.LOT
		  AND  CM_LOT.STORERKEY = MS_SKUDCSET.STORERKEY
		  LEFT JOIN MS_LOCATION   
		  ON     MS_LOCATION.DCCODE       = MS_SKUDCSET.DCCODE   
		  AND    MS_LOCATION.LOC          = MS_SKUDCSET.LOC 
		 
		  LEFT JOIN
               MS_SKUDCSET MS_SKUDCSET_CROSS
          ON   MS_SKUDCSET_CROSS.DCCODE               = #{crossDc}
          AND  MS_SKUDCSET_CROSS.STORERKEY            = WD_INVOICE.STORERKEY   
          AND  MS_SKUDCSET_CROSS.SKU                  = WD_INVOICE.SKU   
          AND  MS_SKUDCSET_CROSS.DEL_YN               = 'N'
          
          LEFT JOIN MS_LOCATION    MS_LOCATION_CROSS
          ON   MS_LOCATION_CROSS.DCCODE   = #{crossDc}
          AND  MS_LOCATION_CROSS.LOC      = MS_SKUDCSET_CROSS.LOC   
          AND  MS_LOCATION_CROSS.DEL_YN   = 'N'
          
		 WHERE 1=1
        <choose>
            <when test="invoicenoMulti != null and invoicenoMulti != ''">
            	AND WD_INVOICE.INVOICENO IN
		        <foreach collection="invoicenoMulti" item="code" open="(" close=")" separator=",">
		          #{code}
		        </foreach>   
            </when>
            <otherwise>
            	AND 1 = 2
            </otherwise>
         </choose>
		 GROUP BY WD_INVOICE.INVOICENO, WD_INVOICE.STORERKEY, WD_INVOICE.INVOICEDT ,MS_SKU.STORAGETYPE
		        , MS_SKU.SKU, MS_SKU.DESCRIPTION, WD_INVOICE.CONFIRMQTY, MS_SKUDCSET.LOC, MS_LOCATION.ZONE
		        , WD_INVOICE.UOM, MS_SKU.QTYPERBOX, WD_INVOICE.SLIPDT
		)AA
		GROUP BY AA.STORERKEY, AA.INVOICEDT ,AA.STORAGETYPE, AA.SKU, AA.LOC
		) A
		WHERE 1=1
		<if test="exceptLoc != null and exceptLoc != ''">            
            <if test="exceptLoc == '1'.toString()">
                AND    A.LOC        NOT IN  ('STD','중단빈')
            </if>
        </if>          
		ORDER BY A.ZONE, A.STORAGETYPE, A.LOC ASC 
    </select>
    
    
    <select id="getTab3MasterList" resultType="WdDeliveryLabelSNResTab3Dto">
	   SELECT /* [WdDeliveryLabelSNService.sqlx][getTab3MasterList][이력배송라벨출력-회수리스트 목록 조회][공두경][2025.10.15] */
               WD_INVOICE.DCCODE                                                    AS DCCODE			/*물류센터*/
		      ,CM_DC.DCNAME                                                         AS DCNAME           /*물류센터명*/
		      ,DM_DOCUMENT_H.TO_CUSTKEY                                             AS TO_CUSTKEY       /*관리처코드*/
		      ,NVL(MS_CUST.DESCRIPTION,DM_DOCUMENT_H.TO_CUSTNAME)                   AS TO_CUSTNAME      /*관리처명(배송인도처)*/
		      ,WD_INVOICE.SKU                                                       AS SKU              /*상품코드*/
		      ,MS_SKU.DESCRIPTION                                                   AS SKUNAME          /*상품명칭*/
		      ,NVL(WD_INPLAN.DELIVERYGROUP
		          ,fn_getdefdistrictcode(WD_INVOICE.DCCODE
		                                ,WD_INVOICE.STORERKEY
		                                ,DM_DOCUMENT_H.TO_CUSTTYPE
		                                ,DM_DOCUMENT_H.TO_CUSTKEY
		                                ,WD_INVOICE.SLIPDT))            			AS DELIVERYGROUP	/*POP번호*/
		      ,CASE WHEN WD_INVOICE.LABELSTATUS = 'D' THEN '배송라벨회수'
		            WHEN WD_INVOICE.LABELSTATUS = 'M' THEN '배송라벨교환'
		            ELSE NULL
		       END	||	CASE WHEN WD_INVOICE_SN.STOCKID IS NULL THEN NULL
		            		 ELSE ' 상품회수'	
		                END                                             			AS STATUS			/*진행상태*/
		      ,LEFT(WD_INVOICE.INVOICENO,19) ||LPAD(WD_INVOICE.ORDERQTY * DM_DOCUMENT_D.BUNMO / DM_DOCUMENT_D.BUNJA * 100,6,'0')
		     								 ||RIGHT(WD_INVOICE.INVOICENO,3)        AS INVOICENO_PRE	/*회수대상-인보이스번호*/
		      ,WD_INVOICE.ORDERQTY * DM_DOCUMENT_D.BUNMO / DM_DOCUMENT_D.BUNJA      AS INVOICEQTY_PRE   /*회수대상-수량*/
		      ,CASE WHEN WD_INVOICE.LABELSTATUS = 'M' THEN WD_INVOICE.INVOICENO
		            ELSE NULL
		       END                                                      			AS INVOICENO		/*교환대상-인보이스번호*/
		      ,CASE WHEN WD_INVOICE.LABELSTATUS = 'M' THEN WD_INVOICE.CONFIRMQTY 
		                                                 * DM_DOCUMENT_D.BUNMO 
		                                                 / DM_DOCUMENT_D.BUNJA 
		            ELSE NULL
		       END                                                      			AS INVOICEQTY		/*교환대상-수량*/
		      ,DM_DOCUMENT_D.STORERUOM                                  			AS STORERUOM        /*단위*/		      
		      ,WD_INVOICE_SN.SERIALNO                                   			AS SERIALNO         /*회수대상-이력번호*/
		      ,WD_INVOICE_SN.STOCKID                                    			AS STOCKID          /*회수대상-바코드*/
		      ,WD_INVOICE_SN.PICKEDQTY * DM_DOCUMENT_D.BUNMO / DM_DOCUMENT_D.BUNJA  AS CANCELQTY        /*회수대상-수량*/
		FROM   WD_INVOICE
		JOIN   CM_DC
		ON     CM_DC.DCCODE              = WD_INVOICE.DCCODE
		JOIN   DM_DOCUMENT_D
		ON     DM_DOCUMENT_D.DCCODE      = WD_INVOICE.DCCODE
		AND    DM_DOCUMENT_D.STORERKEY   = WD_INVOICE.STORERKEY
		AND    DM_DOCUMENT_D.DOCTYPE     = WD_INVOICE.DOCTYPE
		AND    DM_DOCUMENT_D.DELIVERYDATE= WD_INVOICE.SLIPDT
		AND    DM_DOCUMENT_D.DOCNO       = WD_INVOICE.DOCNO
		AND    DM_DOCUMENT_D.DOCLINE     = WD_INVOICE.DOCLINE
		JOIN   WD_INPLAN               
		ON     WD_INPLAN.DCCODE          = WD_INVOICE.DCCODE
		AND    WD_INPLAN.STORERKEY       = WD_INVOICE.STORERKEY
		AND    WD_INPLAN.SLIPDT          = WD_INVOICE.SLIPDT
		AND    WD_INPLAN.SLIPNO          = WD_INVOICE.SLIPNO
		AND    WD_INPLAN.SLIPLINE        = WD_INVOICE.SLIPLINE
		JOIN   DM_DOCUMENT_H                     
		ON     DM_DOCUMENT_H.DCCODE      = DM_DOCUMENT_D.DCCODE
		AND    DM_DOCUMENT_H.STORERKEY   = DM_DOCUMENT_D.STORERKEY
		AND    DM_DOCUMENT_H.DOCTYPE     = DM_DOCUMENT_D.DOCTYPE
		AND    DM_DOCUMENT_H.DELIVERYDATE= DM_DOCUMENT_D.DELIVERYDATE
		AND    DM_DOCUMENT_H.DOCNO       = DM_DOCUMENT_D.DOCNO		
		<!-- 본점 다중선택 -->
    	<if test="custkeyMulti != null and custkeyMulti != '' ">
	    	<trim prefix="AND (" suffix=")" prefixOverrides="OR">
	    		<foreach collection="custkeyMulti" item="item">
	    			OR DM_DOCUMENT_H.HDO_ID IN
	    			<foreach collection="item" item="code" open="(" close=")" separator=",">
	    				#{code} 	 
	          		</foreach>
	        	</foreach>
	      	</trim>			                                    
        </if>
		LEFT JOIN MS_CUST                 
		ON     MS_CUST.STORERKEY         = DM_DOCUMENT_H.STORERKEY
		AND    MS_CUST.CUSTTYPE          = DM_DOCUMENT_H.TO_CUSTTYPE
		AND    MS_CUST.CUSTKEY           = DECODE(DM_DOCUMENT_H.STORERKEY,'FW00',DM_DOCUMENT_H.MNGPLC_ID,DM_DOCUMENT_H.TO_CUSTKEY)
		JOIN   MS_SKU
		ON     MS_SKU.STORERKEY          = WD_INVOICE.STORERKEY
		AND    MS_SKU.SKU                = WD_INVOICE.SKU
		LEFT JOIN WD_INVOICE_SN
		ON     WD_INVOICE_SN.INVOICENO   = WD_INVOICE.INVOICENO
		AND    WD_INVOICE_SN.DEL_YN      = 'C'
		WHERE  WD_INVOICE.DCCODE         = #{fixdccode}
		AND    WD_INVOICE.STORERKEY      = #{gStorerkey}                                                                                                                                                 
		AND    WD_INVOICE.SLIPDT         = #{slipdt}		
		AND    WD_INVOICE.LABELSTATUS    <![CDATA[<>]]> 'N'
		AND    NVL(WD_INVOICE.PRINT_CNT,0) > 0
		AND    WD_INVOICE.PICK_LIST_NO   IS NULL
		AND    WD_INVOICE.INVOICETYPE    IN ('DELIVERYLABEL','DELIVERYLABEL_SN')		
		ORDER BY
		       DCCODE
		      ,TO_CUSTKEY
		      ,TO_CUSTNAME
		      ,SKUNAME
		      ,DELIVERYGROUP
		      ,CASE WHEN WD_INVOICE.LABELSTATUS = 'D' THEN 1
		            WHEN WD_INVOICE.LABELSTATUS = 'M' THEN 2
		            ELSE 3
		       END
		      ,CASE WHEN WD_INVOICE_SN.STOCKID IS NULL THEN 1
		            ELSE 2
		       END
		      ,INVOICENO_PRE
		      ,INVOICENO
		      ,SERIALNO
		      ,STOCKID
    </select>
    
    <select id="getPrintReturnList" resultType="WdDeliveryLabelSNResPrintReturnDto">
	   SELECT /* [WdDeliveryLabelSNService.sqlx][getPrintReturnList][회수리스트 조회][공두경][2025.10.15] */
              WD_INVOICE.DCCODE                                        AS DCCODE
		      ,CM_DC.DCNAME                                             AS DCNAME
		      ,DM_DOCUMENT_H.TO_CUSTKEY                                 AS TO_CUSTKEY
		      ,NVL(MS_CUST.DESCRIPTION,DM_DOCUMENT_H.TO_CUSTNAME)       AS TO_CUSTNAME
		      ,WD_INVOICE.SKU                                           AS SKU
		      ,MS_SKU.DESCRIPTION                                       AS SKUNAME
		      ,NVL(WD_INPLAN.DELIVERYGROUP
		          ,fn_getdefdistrictcode(WD_INVOICE.DCCODE
		                                ,WD_INVOICE.STORERKEY
		                                ,DM_DOCUMENT_H.TO_CUSTTYPE
		                                ,DM_DOCUMENT_H.TO_CUSTKEY
		                                ,WD_INVOICE.SLIPDT))            AS DELIVERYGROUP
		      ,CASE WHEN WD_INVOICE.LABELSTATUS = 'D' THEN '배송라벨회수'
		            WHEN WD_INVOICE.LABELSTATUS = 'M' THEN '배송라벨교환'
		            ELSE NULL
		       END
		     ||CASE WHEN WD_INVOICE_SN.STOCKID IS NULL THEN NULL
		            ELSE ' 상품회수'
		       END                                                      AS STATUS
		      ,LEFT(WD_INVOICE.INVOICENO,19)
		     ||LPAD(WD_INVOICE.ORDERQTY 
		          * DM_DOCUMENT_D.BUNMO 
		          / DM_DOCUMENT_D.BUNJA * 100,6,'0')
		     ||RIGHT(WD_INVOICE.INVOICENO,3)                            AS INVOICENO_PRE
		      ,WD_INVOICE.ORDERQTY 
		     * DM_DOCUMENT_D.BUNMO 
		     / DM_DOCUMENT_D.BUNJA ||' '|| DM_DOCUMENT_D.STORERUOM      AS INVOICEQTY_PRE
		      ,CASE WHEN WD_INVOICE.LABELSTATUS = 'M' THEN WD_INVOICE.INVOICENO
		            ELSE NULL
		       END                                                      AS INVOICENO
		      ,CASE WHEN WD_INVOICE.LABELSTATUS = 'M' THEN WD_INVOICE.CONFIRMQTY 
		                                                 * DM_DOCUMENT_D.BUNMO 
		                                                 / DM_DOCUMENT_D.BUNJA  ||' '|| DM_DOCUMENT_D.STORERUOM
		            ELSE NULL
		       END                                                      AS INVOICEQTY
		      ,DM_DOCUMENT_D.STORERUOM                                  AS STORERUOM
		      ,WD_INVOICE_SN.STOCKID                                    AS STOCKID
		      ,WD_INVOICE_SN.SERIALNO                                   AS SERIALNO
		      ,CASE WHEN WD_INVOICE_SN.STOCKID IS NULL THEN NULL
		            ELSE WD_INVOICE_SN.PICKEDQTY
		               * DM_DOCUMENT_D.BUNMO 
		               / DM_DOCUMENT_D.BUNJA  ||' '|| DM_DOCUMENT_D.STORERUOM     
		       END                                                      AS CANCELQTY
		FROM   WD_INVOICE
		JOIN   CM_DC
		ON     CM_DC.DCCODE              = WD_INVOICE.DCCODE
		JOIN   DM_DOCUMENT_D
		ON     DM_DOCUMENT_D.DCCODE      = WD_INVOICE.DCCODE
		AND    DM_DOCUMENT_D.STORERKEY   = WD_INVOICE.STORERKEY
		AND    DM_DOCUMENT_D.DOCTYPE     = WD_INVOICE.DOCTYPE
		--튜닝.modify
		AND    DM_DOCUMENT_D.DELIVERYDATE       = WD_INVOICE.SLIPDT
		AND    DM_DOCUMENT_D.DOCNO       = WD_INVOICE.DOCNO
		AND    DM_DOCUMENT_D.DOCLINE     = WD_INVOICE.DOCLINE
		JOIN   WD_INPLAN               
		ON     WD_INPLAN.DCCODE          = WD_INVOICE.DCCODE
		AND    WD_INPLAN.STORERKEY       = WD_INVOICE.STORERKEY
		AND    WD_INPLAN.SLIPDT          = WD_INVOICE.SLIPDT
		AND    WD_INPLAN.SLIPNO          = WD_INVOICE.SLIPNO
		AND    WD_INPLAN.SLIPLINE        = WD_INVOICE.SLIPLINE
		JOIN   DM_DOCUMENT_H                     
		ON     DM_DOCUMENT_H.DCCODE      = DM_DOCUMENT_D.DCCODE
		AND    DM_DOCUMENT_H.STORERKEY   = DM_DOCUMENT_D.STORERKEY
		AND    DM_DOCUMENT_H.DOCTYPE     = DM_DOCUMENT_D.DOCTYPE
		--튜닝.modify
		AND    DM_DOCUMENT_H.DELIVERYDATE = DM_DOCUMENT_D.DELIVERYDATE
		AND    DM_DOCUMENT_H.DOCNO       = DM_DOCUMENT_D.DOCNO		
		<!-- 본점 다중선택 -->
    	<if test="custkeyMulti != null and custkeyMulti != '' ">
	    	<trim prefix="AND (" suffix=")" prefixOverrides="OR">
	    		<foreach collection="custkeyMulti" item="item">
	    			OR DM_DOCUMENT_H.HDO_ID IN
	    			<foreach collection="item" item="code" open="(" close=")" separator=",">
	    				#{code} 	 
	          		</foreach>
	        	</foreach>
	      	</trim>			                                    
        </if>
		LEFT JOIN MS_CUST                 
		ON     MS_CUST.STORERKEY         = DM_DOCUMENT_H.STORERKEY
		AND    MS_CUST.CUSTTYPE          = DM_DOCUMENT_H.TO_CUSTTYPE
		AND    MS_CUST.CUSTKEY           = DECODE(DM_DOCUMENT_H.STORERKEY,'FW00',DM_DOCUMENT_H.MNGPLC_ID,DM_DOCUMENT_H.TO_CUSTKEY)
		JOIN   MS_SKU
		ON     MS_SKU.STORERKEY          = WD_INVOICE.STORERKEY
		AND    MS_SKU.SKU                = WD_INVOICE.SKU
		LEFT JOIN  WD_INVOICE_SN
		ON     WD_INVOICE_SN.INVOICENO   = WD_INVOICE.INVOICENO
		AND    WD_INVOICE_SN.DEL_YN      = 'C'
		WHERE  WD_INVOICE.DCCODE         = #{dccode}
		AND    WD_INVOICE.STORERKEY      = #{gStorerkey}                                                                                                                                               
		AND    WD_INVOICE.SLIPDT         = #{slipdt}		
		AND    WD_INVOICE.LABELSTATUS    <![CDATA[<>]]> 'N'
		AND    NVL(WD_INVOICE.PRINT_CNT,0) <![CDATA[>]]> 0
		AND    WD_INVOICE.PICK_LIST_NO   IS NULL
		AND    WD_INVOICE.INVOICETYPE    IN ('DELIVERYLABEL','DELIVERYLABEL_SN')		
		ORDER BY
		       DCCODE
		      ,TO_CUSTKEY
		      ,TO_CUSTNAME
		      ,SKUNAME
		      ,DELIVERYGROUP
		      ,CASE WHEN WD_INVOICE.LABELSTATUS = 'D' THEN 1
		            WHEN WD_INVOICE.LABELSTATUS = 'M' THEN 2
		            ELSE 3
		       END
		      ,CASE WHEN WD_INVOICE_SN.STOCKID IS NULL THEN 1
		            ELSE 2
		       END
		      ,INVOICENO_PRE
		      ,INVOICENO
		      ,SERIALNO
		      ,STOCKID 
    </select>
    
    <!-- 엑셀업로드 정보을(를) 등록 -->
    <insert id="insertTempExcel"  >
        INSERT /* [WdDeliveryLabelSNService.sqlx][insertTempExcel][엑셀데이터임시 Tabele 등록][공두경][2025.10.15] */
          INTO SY_PROCESSTEMP_WD (PROCESSTYPE,PROCESSCREATOR,SPID,ADDWHO,EDITWHO,PROCESSFLAG
                                  /**/
                                 ,DCCODE
                                 ,STORERKEY
                                 ,ORGANIZE
                                 ,AREA
                                 ,DOCTYPE
                                 ,DOCDT
                                 ,DOCNO
                                 ,SLIPDT
                                 ,SLIPNO
                                )
        <foreach collection="list" item="item" separator="UNION ALL">
            SELECT
                #{item.processtype},#{item.gUserId},#{item.gSpid},#{item.gUserId},#{item.gUserId},'N'
                /**/
                ,#{item.dccode}          
                ,#{item.storerkey}       
                ,#{item.organize}                        
                ,#{item.area}                        
                ,#{item.doctype}         
                ,#{item.docdt}           
                ,#{item.docno}                          
                ,#{item.slipdt}          
                ,#{item.slipno}          
           FROM DUAL
        </foreach>
    </insert>
    
    <!-- 피킹지 출력여부 Update -->
    <update id="saveInvoiceNoPrtYn">
        UPDATE   /* [wdDeliveryLabelSNService.sqlx][saveInvoiceNoPrtYn][배송분류표 출력여부 Update][공두경][20251203] */
               WD_INVOICE
        SET    WD_INVOICE.PRINT_YN   = 'Y'
              ,WD_INVOICE.PRINT_CNT  = PRINT_CNT + 1
              ,WD_INVOICE.PRINT_DATE = SYSDATE
              ,WD_INVOICE.DLV_DATA04 = 'FORCEPRINT'
        WHERE 1=1
        <choose>
            <when test="invoiceNoPrintMulti != null and invoiceNoPrintMulti != ''">
                AND WD_INVOICE.INVOICENO IN
                <foreach collection="invoiceNoPrintMulti" item="code" open="(" close=")" separator=",">
                  #{code}
                </foreach>   
            </when>
            <otherwise>
                AND 1 = 2
            </otherwise>
         </choose>
    </update>
    
</mapper>