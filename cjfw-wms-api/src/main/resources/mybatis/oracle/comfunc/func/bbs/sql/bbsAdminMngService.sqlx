<?xml version="1.0" encoding="UTF-8"?><!--Converted at: Mon Feb 17 11:21:55 KST 2014-->
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="bbsAdminMngService">

	<!-- 공지사항 목록 조회 -->
	<select id="getBoardListUser" resultType="BbsBoardListGetResDto">
		SELECT  /* [bbsAdminMngService.sqlx][getBoardListUser][공지사항 목록 조회(User)][CWS][20200207]*/
				BS.BBS_SEQ AS BBS_SEQ															/* 게시번호 */
		        , ( SELECT  CD_NM
		            FROM    TB_CM_CD_DTL
		            WHERE   COM_GRP_CD = 'BBS_SCP'
		            AND     COM_CD = BS.BBS_SCP_CD) AS BBS_SCP									/* 공지대상 */
		        , ( SELECT  CD_NM
		            FROM    TB_CM_CD_DTL
		            WHERE   COM_GRP_CD = 'BBS_TP'
		            AND     COM_CD = BS.BBS_TP_CD) AS BBS_TP									/* 공지구분 */
		        , BS.BBS_TITLE AS BBS_TITLE	/* 제목 */
		        , NVL2(BS.ATTCH_FILE_GRP_NO, '1', '0') AS ATTCH_YN								/* 첨부파일 */
		        , BS.VW_CNT AS VW_CNT															/* 조회수 */
		        , TO_CHAR(BS.REG_DT, 'YYYY-MM-DD') AS REG_DT									/* 게시일 */
		        , TOP_YN 																		/* 최상위 여부 */
		        , ( SELECT 	USER_NM 
		            FROM 	TB_CF_USERS 
		            WHERE 	USER_ID = BS.REG_ID ) AS REGR_NM                                   /* 게시자 */
		FROM    TB_BS_BBS BS 
		WHERE   1=1
		<if test='bbsScpCd !=null and bbsScpCd !=""'>
			AND BS.BBS_SCP_CD = #{bbsScpCd}						/* 공지 대상 */
		</if>
		
		<if test='bbsTpCd !=null and bbsTpCd !=""'>
        	AND BS.BBS_TP_CD=#{bbsTpCd}							/* 공지 구분 */
	    </if>
	    
        <if test='searchType == 1 '>
     		AND BS.BBS_TITLE LIKE '%' || #{bbsTitleNote} ||'%'	/* 제목 */
        </if>
        
        <if test='searchType == 2 '>
       		AND (
       		BS.BBS_TITLE LIKE '%' || #{bbsTitleNote} ||'%'
       		OR BS.BBS_NOTE LIKE '%' || #{bbsTitleNote} ||'%'
       	)															/* 제목+본문 */
        </if>
        <if test='viewYn !=null and viewYn !=""'>
       		AND BS.VW_YN= #{viewYn}								/* 공지여부 */
        </if>
		        
																	
		AND TO_CHAR(BS.REG_DT, 'YYYYMMDD') <![CDATA[<=]]> REPLACE(#{thruDt}, '-', '')	/* 게시기간 */
       	AND TO_CHAR(BS.REG_DT, 'YYYYMMDD') <![CDATA[>=]]> REPLACE(#{fromDt}, '-', '')	/* 게시기간 */
		ORDER BY BS.TOP_YN DESC, BS.BBS_SEQ DESC
	</select>
	
	<!-- 공지사항 목록 조회 -->
	<select id="getBoardListAll" resultType="BbsBoardListGetResDto">
		SELECT  /* [bbsAdminMngService.sqlx][getBoardListAll][공지사항 목록 조회(Admin)][CWS][20200207]*/
				BS.BBS_SEQ AS BBS_SEQ																/* 게시번호 */
		        , ( SELECT  CD_NM
		            FROM    TB_CM_CD_DTL
		            WHERE   COM_GRP_CD = 'BBS_SCP'
		            AND     COM_CD = BS.BBS_SCP_CD) AS BBS_SCP										/* 공지대상 */
		        , ( SELECT  CD_NM
		            FROM    TB_CM_CD_DTL
		            WHERE   COM_GRP_CD = 'BBS_TP'
		            AND     COM_CD = BS.BBS_TP_CD) AS BBS_TP										/* 공지구분 */
		        , BS.BBS_TITLE AS BBS_TITLE		/* 제목 */
		        , NVL2(BS.ATTCH_FILE_GRP_NO, '1', '0') AS ATTCH_YN									/* 첨부파일 */
		        , BS.VW_CNT AS VW_CNT																/* 조회수 */
		        , TO_CHAR(BS.REG_DT, 'YYYY-MM-DD') AS REG_DT										/* 게시일 */
		        , TOP_YN 																			/* 최상위 여부 */
		        , ( SELECT 	USER_NM 
		            FROM 	TB_CF_USERS 
		            WHERE 	USER_ID = BS.REG_ID ) AS REGR_NM                                   /* 게시자 */
		FROM    TB_BS_BBS BS 
		WHERE   1=1
		<if test='bbsScpCd !=null and bbsScpCd !=""'>
			AND BS.BBS_SCP_CD = #{bbsScpCd}						/* 공지 대상 */
		</if>
		
		<if test='bbsTpCd !=null and bbsTpCd !=""'>
        	AND BS.BBS_TP_CD=#{bbsTpCd}							/* 공지 구분 */
	    </if>
	    
        <if test='searchType == 1 '>
     		AND BS.BBS_TITLE LIKE '%' || #{bbsTitleNote} ||'%'	/* 제목 */
        </if>
        
        <if test='searchType == 2 '>
       		AND (
       		BS.BBS_TITLE LIKE '%' || #{bbsTitleNote} ||'%'
       		OR BS.BBS_NOTE LIKE '%' || #{bbsTitleNote} ||'%'
       	)															/* 제목+본문 */
        </if>
        <if test='viewYn !=null and viewYn !=""'>
       		AND BS.VW_YN= #{viewYn}								/* 공지여부 */
        </if>
		        
		
		AND TO_CHAR(BS.REG_DT, 'YYYYMMDD') <![CDATA[<=]]> REPLACE(#{thruDt}, '-', '')	/* 게시기간 */
       	AND TO_CHAR(BS.REG_DT, 'YYYYMMDD') <![CDATA[>=]]> REPLACE(#{fromDt}, '-', '')	/* 게시기간 */
		ORDER BY BS.TOP_YN DESC, BS.BBS_SEQ DESC
	</select>
	
	<!-- 권한 체크 -->
	<select id="getBbsAdminCheck" resultType="INT">
		SELECT /* [bbsAdminMngService.sqlx][getBbsAdminCheck][권한 체크][CWS][20200207]*/
				COUNT(1) 
		FROM TB_CF_AUTH
		WHERE AUTHORITY = 'BBS_ADMIN'
		AND USER_ID = #{userId}
			
	</select>
</mapper>