    <update id="savePopupDocumentInfoHeader">
        UPDATE  /* [ibExpenseService.sqlx][savePopupDocumentInfoHeader][비용기표 DocumentInfo Header 저장][sunho.kim][2025.08.04] */
        IB_EXPENSE
        SET    ISSUE_DATE               = TO_DATE(LEFT(#{issueDate},8),'YYYYMMDD')
             , ADJUSTMENT_SUPPLIER_CODE = #{adjustmentSupplierCode}
             , ADJUSTMENT_SUPPLIER_NAME = NVL((SELECT DESCRIPTION 
                                            FROM MS_CUST 
                                            WHERE MS_CUST.CUSTTYPE  = 'P'
                                             AND  MS_CUST.DEL_YN    = 'N'
                                             AND  MS_CUST.STORERKEY = #{gStorerkey}
                                             AND  MS_CUST.CUSTKEY   = #{adjustmentSupplierCode}
                                             AND  ROWNUM            = 1), NULL) 
             , ACTUAL_SUPPLIER_CODE     = #{actualSupplierCode}
             , ACTUAL_SUPPLIER_NAME     = NVL((SELECT DESCRIPTION 
                                            FROM MS_CUST 
                                            WHERE MS_CUST.CUSTTYPE  = 'P'
                                             AND  MS_CUST.DEL_YN    = 'N'
                                             AND  MS_CUST.STORERKEY = #{gStorerkey}
                                             AND  MS_CUST.CUSTKEY   = #{actualSupplierCode}
                                             AND  ROWNUM            = 1), NULL) 
             , ACCOUNT_CR_CODE          = #{accountCrCode}
             , ACCOUNT_CR_NAME          = #{accountCrName}
             , TAX_TYPE_CODE            = #{taxTypeCode}
             , TAX_TYPE_NAME            = (SELECT BASEDESCR
                                           FROM CM_CODE_STORER        
                                           WHERE CODELIST  = 'TAX_CLASS'
                                            AND  STORERKEY = #{gStorerkey}
                                            AND  BASECODE  = #{taxTypeCode}
                                            )
             , TAX_RATE                 = #{taxRate}
             , SUMMARY                  = #{summary}
             , FISCAL_YEAR              = #{fiscalYear}
             , POSTING_DATE             = TO_DATE(LEFT(#{postingDate},8),'YYYYMMDD')
             , TAX_YMD                  = TO_DATE(LEFT(#{taxYmd},8),'YYYYMMDD')
             , PAYMENT_TERM             = #{paymentTerm}
             , TAX_NO                   = #{taxNo}
             , JOURNAL_TYPE_CODE        = #{journalTypeCode}
             , JOURNAL_TYPE_NAME        = #{journalTypeName}
             , TAX_TAG                  = #{taxTag}
             , TAX_AUTO_FLAG            = #{taxAutoFlag}
             , INV_SIGN                 = #{invSign}
             , EDITWHO                  = #{gUserId}
             , EDITDATE                 = SYSDATE
        WHERE  SERIALKEY                = #{serialkey}  
    </update>

    <update id="savePopupDocumentInfoDetail">
        UPDATE  /* [ibExpenseService.sqlx][savePopupDocumentInfoDetail][비용기표 DocumentInfo Detail 저장][sunho.kim][2025.08.04] */
        IB_EXPENSE_DISTRIBUTION
        SET    CREDIT_KIND          = #{creditKind}
             , DOCUMENT_TYPE_CODE   = #{documentTypeCode}
             , ACCOUNT_DR_CODE      = #{accountDrCode}
             , ACCOUNT_DR_NAME      = #{accountDrName}
             , ACCOUNT_DETAIL_CODE  = #{accountDetailCode}
             , ACCOUNT_DETAIL_NAME  = #{accountDetailName}
             , SUPPLY_PRICE         = #{supplyPrice}
             , TAX_RATE             = #{taxRate}
             , TAX_AMOUNT           = #{taxAmount}
             , AMOUNT               = #{amount}
             , SUMMARY              = #{summary}
             , TAX_FLAG             = #{taxFlag}
             , EDITWHO              = #{gUserId}
             , EDITDATE             = SYSDATE
        WHERE  SERIALKEY            = #{serialkey}  
    </update>

    <update id="saveKGPopupDocumentInfoDetail">
        UPDATE  /* [ibExpenseService.sqlx][saveKGPopupDocumentInfoDetail][비용기표  DocumentInfo Detail 저장(KG비용분배)][sunho.kim][2025.08.04] */
        IB_EXPENSE_DISTRIBUTION
        SET    SUPPLY_PRICE         = #{disCost}
             , TAX_AMOUNT           = ROUND((#{disCost})*(#{taxRate})/100)
             , AMOUNT               = (#{disCost}) + ROUND((#{disCost})*(#{taxRate})/100)
             , EDITWHO              = #{gUserId}
             , EDITDATE             = SYSDATE
        WHERE  SERIALKEY            = #{serialkey}
    </update>

    <update id="saveKGPopupDocumentInfoHeader">
        UPDATE  /* [ibExpenseService.sqlx][saveKGPopupDocumentInfoHeader][비용기표  DocumentInfo Header 저장(KG비용분배)][sunho.kim][2025.08.04] */
        IB_EXPENSE
        SET    SUPPLY_PRICE         = (SELECT SUM(SUPPLY_PRICE) FROM IB_EXPENSE_DISTRIBUTION WHERE EXPENSE_SN = #{expenseSn})
             , TAX_AMOUNT           = (SELECT SUM(TAX_AMOUNT) FROM IB_EXPENSE_DISTRIBUTION WHERE EXPENSE_SN = #{expenseSn})
             , AMOUNT               = (SELECT SUM(AMOUNT) FROM IB_EXPENSE_DISTRIBUTION WHERE EXPENSE_SN = #{expenseSn})
             , EDITWHO              = #{gUserId}
             , EDITDATE             = SYSDATE
        WHERE  SERIALKEY            = #{expenseSn}
    </update>
    
    <update id="saveKGPopupDocumentInfoDetailAdjust">
        MERGE   /* [ibExpenseService.sqlx][saveKGPopupDocumentInfoDetailAdjust][비용기표  DocumentInfo Detail 조정(KG비용분배)][sunho.kim][2025.08.04] */
        INTO IB_EXPENSE_DISTRIBUTION
                USING (
                        SELECT SERIALKEY
                          FROM (SELECT RANK() OVER(ORDER BY AMOUNT DESC, SERIALKEY) AS RANK_NUM
                                      ,SERIALKEY
                                  FROM IB_EXPENSE_DISTRIBUTION
                                 WHERE 1 = 1
                                   AND EXPENSE_SN = #{expenseSn}
                                   AND TAX_RATE <![CDATA[>]]> 0)
                         WHERE RANK_NUM = 1
                      ) SN_TB
                ON (IB_EXPENSE_DISTRIBUTION.SERIALKEY = SN_TB.SERIALKEY)
                WHEN MATCHED THEN
                     UPDATE
                     SET   SUPPLY_PRICE = SUPPLY_PRICE + (#{supplyPriceDiff})
                         , TAX_AMOUNT   = TAX_AMOUNT + (#{taxDiff})
                         , AMOUNT       = (SUPPLY_PRICE + (#{supplyPriceDiff})) + (TAX_AMOUNT + (#{taxDiff}))
    </update>
    
    <insert id="insertIbApprovalLineDummy">
