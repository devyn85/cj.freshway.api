<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="smsSendKkoBatchService">

    <select id="selectSms" resultType="cjfw.batch.job.smsSendKko.SmsSendKkoParamsDto">
        SELECT /* [smsSendKkoBatchService.sqlx][selectSms][SMS발송대상조회][ASIS쿼리][20260108] */
               SENDPHONE
             , RECEIVEPHONE
             , SENDDT
             , SENDTITLE
             , SENDMESSAGE
             , SERIALKEY
          FROM MG_SMSMMSSEND
         WHERE  1=1
           AND STATUS = '10'
           AND DEL_YN = 'N'
           AND SENDDT <![CDATA[>=]]> TO_CHAR(SYSDATE-1,'YYYYMMDDHH24MISS')
    </select>

    <insert id="insertKkoMsg" >
        INSERT INTO /* [smsSendKkoBatchService.sqlx][insertKkoMsg][알림톡템플릿 테이블에 저장.][TOBE쿼리][20260113] */ KKO_MSG
        (
           STATUS
           , PHONE
           , CALLBACK
           , REQDATE
           , MSG
           , TEMPLATE_CODE
           , TEMPLATE_TITLE
           , FAILED_TYPE
           , FAILED_SUBJECT
           , FAILED_MSG
           , PROFILE_KEY
           , KKO_TYPE
        )
        VALUES
        (
           '1'
           , TRIM(SUBSTRB('01093927708',1 ,16))     /* 테스트 기간동안 임시 */
           , '1588-8161'                        	/* 발신번호 */
           , SYSDATE
           , #{SENDMESSAGE}                         /* 알림톡의 경우 등록한 템플릿 코드형식의 발송 메세지 */
           , '템플릿코드'                           	/* 등록된 템플릿 코드명 */
           , #{SENDTITLE}                           /* 등록된 템플릿이 강조형일 경우 */
           , 'SMS'                                  /* 알림톡 실패시 SMS, MMS 등의 형태로 보낼 경우 */
           , #{SENDTITLE}                           /* 알림톡 실패시 대체발송(SMS/MMS) 타이틀 */
           , #{SENDMESSAGE}                         /* 알림톡 실패시 대체발송(SMS/MMS) 본문 내용 */
           , '344c6c25b2c3eacae088fa7b60f52582b9eb8b72' /* 프로파일키 */
           , 'AT'                                   /* 알림톡 */
        )
    </insert>

    <update id="updateSms">
        UPDATE /* [smsSendKkoBatchService.sqlx][updateSms][SMS발송상태변경][ASIS쿼리][20260108] */ MG_SMSMMSSEND
        SET	   STATUS   = '90'
              ,EDITDATE = SYSDATE
              ,EDITWHO  = 'LOGISONEBATCH'
        WHERE  1=1
          AND  SERIALKEY = #{SERIALKEY}
    </update>

</mapper>