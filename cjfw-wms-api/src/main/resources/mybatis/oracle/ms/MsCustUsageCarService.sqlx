<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="msCustUsageCarService">
    
    <!-- 거래처별전용차량정보 조회(목록) -->
    <select id="getMasterList" resultType="MsCustUsageCarResDto">
        SELECT    /* [msCustUsageCarService.sqlx][msCustUsageCarService.getMasterList][거래처별전용차량정보 조회(목록)][JeongHyeongCheol][20250829] */ 
                 MS_CUSTXCAR.STORERKEY                     AS STORERKEY            /* 회사코드 */
                ,CD1.DCNAME                                AS DCNAME                /* 센터명 */
                ,MS_CUSTXCAR.DCCODE                     AS DCCODE                /* 센터코드 */
                ,MS_CUSTXCAR.CUSTCARTYPE
                ,CASE 
                    WHEN MS_CUSTXCAR.CUSTCARTYPE = '10'
                    THEN 'Y'
                    ELSE 'N'
                 END                                     AS CUSTCARTYPE10         /* 거래처차량유형(전용) */
                ,CASE 
                    WHEN MS_CUSTXCAR.CUSTCARTYPE = '99'
                    THEN 'Y'
                    ELSE 'N'
                 END                                     AS CUSTCARTYPE99        /* 거래처차량유형(강성) */
                ,MS_CUSTXCAR.CUSTKEY                     AS CUSTKEY                /* 거래처코드 */
                ,MS_CUSTXCAR.FROMDATE                     AS FROMDATE                /* 적용시작일자 */
                ,MS_CUSTXCAR.TODATE                     AS TODATE                /* 적용종료일자 */
                ,MS_CUSTXCAR.CARNO                         AS CARNO                /* 차량번호 */
                ,MS_CUSTXCAR.PRIORITY                     AS PRIORITY                /* 우선순위 */
                ,MS_CUSTXCAR.STATUS                     AS STATUS                /* 상태 */
                ,CUST1.DESCRIPTION                        AS CUSTNAME                /* 거래처명 */
                ,MS_CUSTXCAR.MEMO                         AS MEMO                    /* 메모 */
                ,MS_CUSTXCAR.APPLY_YN                     AS APPLY_YN                /* 적용여부 */
                ,DRIVER1.DRIVERNAME                     AS DRIVER1                /* 운전자1 */
                ,DRIVER1.DRIVERID                         AS DRIVER1_ID            /* 운전자1 */
                ,DRIVER2.DRIVERNAME                     AS DRIVER2                /* 운전자2 */
                ,DRIVER2.DRIVERID                         AS DRIVER2_ID            /* 운전자2 */
                ,MS_CUSTXCAR.ADDWHO                        AS ADDWHO               /* 최초등록자*/
                ,MS_CUSTXCAR.ADDDATE                    AS ADDDATE              /* 최초등록시간*/
                ,MS_CUSTXCAR.EDITWHO                    AS EDITWHO              /* 최종변경자*/
                ,MS_CUSTXCAR.EDITDATE                    AS EDITDATE             /* 최종변경시간*/    
                ,USER1.USER_NM                          AS REG_NM                /* 등록자명 */
                ,USER2.USER_NM                          AS UPD_NM                /* 수정자명 */
        FROM MS_CUSTXCAR
        JOIN CM_CAR ON CM_CAR.CARNO = MS_CUSTXCAR.CARNO
        
        LEFT JOIN CM_DC CD1  ON CD1.DCCODE = MS_CUSTXCAR.DCCODE
        
        LEFT JOIN MS_CUST CUST1  ON CUST1.STORERKEY = MS_CUSTXCAR.STORERKEY
                                AND CUST1.CUSTKEY   = MS_CUSTXCAR.CUSTKEY
                                AND CUST1.CUSTTYPE = 'C'
        
        LEFT OUTER JOIN CM_DRIVER DRIVER1 ON DRIVER1.DRIVERID = CM_CAR.DRIVER1
        LEFT OUTER JOIN CM_DRIVER DRIVER2 ON DRIVER2.DRIVERID = CM_CAR.DRIVER2
        
        LEFT JOIN FRAMEONE_USER USER1 
            ON USER1.USER_ID = MS_CUSTXCAR.ADDWHO      /*등록자명*/
        LEFT JOIN FRAMEONE_USER USER2 
                ON USER2.USER_ID = MS_CUSTXCAR.EDITWHO  /*수정자명*/
        WHERE
            1=1
            AND MS_CUSTXCAR.STORERKEY = #{gStorerkey}
            <if test='dccodeMulti != null and dccodeMulti != ""'>
                AND MS_CUSTXCAR.DCCODE IN 
                <foreach collection="dccodeMulti" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>            
            </if>
            <if test='applyYn != null and applyYn != ""'>
                AND MS_CUSTXCAR.APPLY_YN = #{applyYn}
            </if>
            <if test='custcartype != null and custcartype != ""'>
                AND MS_CUSTXCAR.CUSTCARTYPE = #{custcartype}
            </if>
            <if test='periodFrom != null and periodFrom != ""'>
                AND MS_CUSTXCAR.FROMDATE <![CDATA[<=]]> #{periodTo}
            </if>
            <if test='periodTo != null and periodTo != ""'>
                AND MS_CUSTXCAR.TODATE <![CDATA[>=]]> #{periodFrom}
            </if>
            <if test='driverIdNm != null and driverIdNm != ""'>
                AND (
                    CM_CAR.DRIVER1 LIKE '%' || #{driverIdNm} || '%' OR
                    CM_CAR.DRIVER2 LIKE '%' || #{driverIdNm} || '%' OR
                    DRIVER1.DRIVERNAME LIKE '%' || #{driverIdNm} || '%' OR
                    DRIVER2.DRIVERNAME LIKE '%' || #{driverIdNm} || '%'
                )
            </if>            
            <if test='custkeyMulti != null and custkeyMulti != ""'>
                AND MS_CUSTXCAR.CUSTKEY IN 
                <foreach collection="custkeyMulti" item="code" open="("  close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            <if test='carnoMulti != null and carnoMulti != ""'>
                AND MS_CUSTXCAR.CARNO IN 
                <foreach collection="carnoMulti" item="code" open="("  close=")" separator=",">
                    #{code}
                </foreach>
            </if>            
    </select>
    
    <!-- 거래처별전용차량정보 저장 -->
    <insert id="saveMasterList">
        /* [msCustUsageCarService.sqlx][updateMasterList][거래처별전용차량정보 저장][JeongHyeongCheol][20250829] */
        BEGIN
            MERGE INTO MS_CUSTXCAR
            USING DUAL
            ON (CUSTKEY = #{custkey} AND CARNO = #{carno} AND DCCODE = #{dccode})
            WHEN MATCHED THEN
                UPDATE
                SET
                      APPLY_YN        = nvl(#{applyYn},'Y')
                    , CUSTCARTYPE     = #{custcartype}
                    , EDITDATE        = SYSDATE
                    , EDITWHO         = #{gUserId}
            WHEN NOT MATCHED THEN
                INSERT
                    (SERIALKEY
                    , STORERKEY
                    , DCCODE
                    , CUSTKEY
                    , CUSTCARTYPE
                    , CARNO
                    , APPLY_YN
                    , ADDWHO
                    
                    , ADDDATE
                    , EDITWHO
                    , EDITDATE)
                VALUES
                    (SEQ_MS_CUSTXCAR.NEXTVAL
                    , 'FW00'
                    , nvl(#{dccode},'STD')
                    , #{custkey}
                    , #{custcartype}
                    , #{carno}
                    , nvl(#{applyYn},'Y')
                    , #{gUserId}
                    , SYSDATE
                    , #{gUserId}
                    , SYSDATE);
        END;
    </insert>
    
    <!-- 엑셀업로드 유효성 체크 -->
    <select id="getValidateSaveList" resultType="MsCustUsageCarResDto">
        WITH  /* [msCustUsageCarService.sqlx][msCustUsageCarService.getValidateSaveList][엑셀업로드 유효성 체크][JeongHyeongCheol][20260121] */
               V AS (
                <foreach collection="list" item="item" index="idx" separator="UNION ALL">
                    SELECT
                         #{item.dccode}                                AS DCCODE
                        ,#{item.custkey}                            AS CUSTKEY
                        ,#{item.carno}                                AS CARNO        
                         ,CASE WHEN TRIM(#{item.custcartype10}) IS NOT NULL  AND TRIM(#{item.custcartype10}) IN ('전용','Y')
                              THEN 'Y' ELSE 'N' END                    AS CUSTCARTYPE10       
                         ,CASE WHEN TRIM(#{item.custcartype99}) IS NOT NULL  AND TRIM(#{item.custcartype99}) IN ('제외','Y')
                              THEN 'Y' ELSE 'N' END                    AS CUSTCARTYPE99                   
                        ,${idx} + 1 AS RN 
                    FROM DUAL
                </foreach>
            )
            
            SELECT 
                 V.DCCODE                    AS DCCODE                
                ,V.CUSTKEY                    AS CUSTKEY                
                ,V.CARNO                    AS CARNO                
                                
                ,CASE 
                    WHEN T1.CUSTKEY IS NOT NULL 
                    THEN 'Y' ELSE 'N' 
                 END                                 AS CUSTKEY_CHK
                ,CASE 
                    WHEN T2.DCCODE IS NOT NULL 
                    THEN 'Y' ELSE 'N' 
                 END                                 AS DCCODE_CHK               
                 ,CASE 
                    WHEN T4.CARNO IS NOT NULL 
                    THEN 'Y' ELSE 'N' 
                 END                                 AS CARNO_CHK
                 ,CASE 
                    WHEN T5.CARNO IS NOT NULL 
                    THEN 'Y' ELSE 'N' 
                 END                                 AS UPDATE_CHK
                ,CASE WHEN V.CUSTCARTYPE10 = 'Y' AND V.CUSTCARTYPE99 = 'Y' THEN 'N'
                      WHEN V.CUSTCARTYPE10 = 'N' AND V.CUSTCARTYPE99 = 'N' THEN 'N'
                      ELSE 'Y' 
                 END                         AS CUSTCARTYPE_CHK
                 , V.CUSTCARTYPE10  AS  CUSTCARTYPE10
                 , V.CUSTCARTYPE99 AS  CUSTCARTYPE99
                 , V.RN                             AS RN
            FROM V
            
            LEFT JOIN MS_CUST T1 
                   ON T1.STORERKEY     = 'FW00'
                  AND T1.CUSTKEY     = V.CUSTKEY
                  AND T1.CUSTTYPE    = 'C'                  
                
            LEFT JOIN CM_DC T2 
                   ON T2.DEL_YN ='N'
                  AND (T2.REAL_DC_YN <![CDATA[<>]]> 'N' OR T2.REAL_DC_YN IS NULL)
                  AND T2.DCCODE     = V.DCCODE    
                  
            LEFT JOIN CM_CAR T4 
                   ON T4.CARNO         = V.CARNO
                   
            LEFT JOIN MS_CUSTXCAR T5
                   ON T5.DCCODE     = V.DCCODE
                  AND T5.CUSTKEY     = V.CUSTKEY
                  AND T5.CARNO         = V.CARNO
                      
            ORDER BY V.RN 
    </select>
        
</mapper>