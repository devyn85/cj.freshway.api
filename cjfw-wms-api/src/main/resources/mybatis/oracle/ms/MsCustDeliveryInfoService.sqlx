	<select id="getSrmCustdlvinfo_API" resultType="MsCustDeliveryInfoResDto">
	    SELECT /* [msCustDeliveryInfoNewService.sqlx][msCustDeliveryInfoNewService.getSrmCustdlvinfo_API] */
			 MS_CUSTDLVINFO.CUSTKEY						 	 AS CUSTKEY
			,CASE WHEN NVL(MS_CUSTDLVINFO.LABELPRINTTYPE, 'STD') = 'CHD' AND #{labelprinttype} = 'STD' THEN 'Y'
			      ELSE 'N'
			 END                                         AS DEL_YN
			,CASE WHEN NVL(MS_CUSTDLVINFO.LABELPRINTTYPE, 'STD') <![CDATA[<>]]> #{labelprinttype} THEN 'Y'
			      ELSE 'N'
			 END									     AS SRM_SEND_FLAG
        FROM MS_CUSTDLVINFO                     
       WHERE 1=1
         AND MS_CUSTDLVINFO.STORERKEY = 'FW00'
		 AND MS_CUSTDLVINFO.CUSTKEY   = #{custkey} 	
	</select>
	
	<!-- 추천실착지코드 팝업 목록 조회 -->
	<select id="getTruthcustkeyList" resultType="MsCustDeliveryInfoPopResDto">
   SELECT /* [msCustDeliveryInfoNewService.sqlx][msCustDeliveryInfoNewService.getTruthcustkeyList] */
        A.CUSTKEY       AS CUSTKEY        -- 고객코드
      , C.DESCRIPTION   AS CUSTNAME       -- 고객명  
      , A.ADDRESS1      AS ADDRESS1       --주소 
      , A.ADDRESS2      AS ADDRESS2       -- 상세주소
      , A.TRUTHCUSTKEY  AS TRUTHCUSTKEY   -- 추천실착지코드
      , D.DESCRIPTION   AS TRUTHCUSTNAME  -- 추천실착지명
      , A.TRUTHADDRESS1 AS TRUTHADDRESS1  -- 추천주소
      , A.TRUTHADDRESS2 AS TRUTHADDRESS2  -- 추천상세주소
      , A.SIMILARITY    AS SIMILARITY     -- 유사도 (%)
  FROM (
        SELECT 
              A.CUSTKEY		 AS CUSTKEY         -- 고객코드
            , A.CUSTTYPE     AS CUSTTYPE        -- 고객유형
            , A.STORERKEY    AS STORERKEY       -- 고객사코드
            , A.ADDRESS1	 AS ADDRESS1        -- 주소
            , A.ADDRESS2	 AS ADDRESS2        -- 상세주소
            , B.CUSTKEY		 AS TRUTHCUSTKEY    -- 추천실착지코드
            , B.ADDRESS1	 AS TRUTHADDRESS1  -- 추천주소
            , B.ADDRESS2	 AS TRUTHADDRESS2  -- 추천상세주소
            , UTL_MATCH.JARO_WINKLER_SIMILARITY(TRIM(A.ADDRESS1 || A.ADDRESS2), TRIM(B.ADDRESS1 || B.ADDRESS2)) AS SIMILARITY -- 유사도 (%)
            ,ROW_NUMBER() OVER (PARTITION BY A.CUSTKEY
                                ORDER BY UTL_MATCH.JARO_WINKLER_SIMILARITY(TRIM(A.ADDRESS1 || A.ADDRESS2), TRIM(B.ADDRESS1 || B.ADDRESS2)) DESC) AS ROW_NM
            FROM MS_CUSTDLVINFO A
            LEFT JOIN MS_CUSTDLVINFO B
            ON A.STORERKEY 	= B.STORERKEY
            AND A.CUSTTYPE 	= B.CUSTTYPE
            WHERE A.STORERKEY    ='FW00'
            AND A.CUSTTYPE     ='C'
            AND A.CUSTKEY     != B.CUSTKEY
            AND B.TRUTHADDRESS1 IS NOT NULL
            AND A.STORERKEY    = B.STORERKEY
            AND A.CUSTKEY      = #{name}  -- 입력파라미터 ‘고객 코드’
        --    AND D.OTCO_GRP_ID   IS NOT NULL   -- 온라인 고객 여부   --제거 3/27
            AND UTL_MATCH.JARO_WINKLER_SIMILARITY(TRIM( A.ADDRESS1 || A.ADDRESS2), TRIM(B.ADDRESS1 || B.ADDRESS2))  <![CDATA[>]]>  90
            AND UTL_MATCH.EDIT_DISTANCE(A.ADDRESS2, B.ADDRESS2)   <![CDATA[<]]>  10   
     ) A
    LEFT JOIN MS_CUST C
    ON  C.STORERKEY = A.STORERKEY
    AND C.CUSTTYPE  = A.CUSTTYPE
    AND C.CUSTKEY   = A.CUSTKEY
    LEFT JOIN MS_CUST D
    ON  D.STORERKEY = A.STORERKEY
    AND D.CUSTTYPE  = A.CUSTTYPE
    AND D.CUSTKEY   = A.TRUTHCUSTKEY
WHERE 1=1
   AND ROW_NM <![CDATA[<=]]>20
   
   
	</select>
    <update id="updateConfirm"> 
        UPDATE    /* [msCustDeliveryInfoService.sqlx][msCustDeliveryInfoService.updateConfirm][고객정보수신내역테이블 수정][박요셉][20260213] */
               CRM_CUSTDLVINFO_HIS
           SET STATUS       = #{status} 
             , CONFIRMDATE  = SYSDATE
             , EDITDATE     = SYSDATE
             , EDITWHO      = #{gUserId}
         WHERE SERIALKEY    = #{serialkeyHis}

    </update>
    
    <update id="mergeCrmDlvInfo">
        BEGIN
            MERGE 
             INTO LOGISONE.MS_CUSTDLVINFO
            USING DUAL
               ON (CUSTKEY = #{custkey} AND CUSTTYPE = #{custtype})
             WHEN MATCHED THEN
           UPDATE
              SET ADDRESSMATCHYN            = #{addressmatchyn}
                , TRUTHADDRESS1             = #{truthaddress1}
                , TRUTHADDRESS2             = #{truthaddress2}
                , TRUTHZIPCODE              = #{truthzipcode}
                , FACEINSPECT               = #{faceinspect}
                , INSPECTIONWORKERPHONE     = DAMO.ENC(FN_FORMAT_TELNO(#{inspectionworkerphone}))
                , INSPECTORPRINTYN          = #{inspectorprintyn}
                , PARKINGHEIGHT             = #{parkingheight}
                , KEYTYPE                   = #{keytype}
                , KEYDETAIL                 = #{keydetail}
                , REQDLVTIME2_FROM          = #{reqdlvtime2From}
                , REQDLVTIME2_TO            = #{reqdlvtime2To}
                , DELIVERYAVAILABLETIME     = #{deliveryavailabletime}
                , BUILDINGOPENTIME          = #{buildingopentime}
                , ACCESSWAY                 = #{accessway}
                , FREEZEPLACE               = #{freezeplace}
                , COLDPLACE                 = #{coldplace}
                , HTEMPERATURE              = #{htemperature}
                , LOADPLACE2                = #{loadplace2}
                , INITREQUESTDT             = #{initrequestdt}
                , INITREQUESTTIMESTART      = #{initrequesttimestart}
                , INITREQUESTTIMEEND        = #{initrequesttimeend}
                , INITFTFINSPECTIONYN       = #{initftfinspectionyn}
                , INITDELIVERYCONTACT       = #{initdeliverycontact}
                , INITDELIVERYDESC          = #{initdeliverydesc}
                , DELIVERYTYPE              = #{deliverytype}
                , TEMPTARGET                = #{temptarget}
                , LABELPRINTTYPE            = #{labelprinttype}
                , DELIVERYNOTIYN            = #{deliverynotiyn}
                , DELIVERYNOTIPHONE         = DAMO.ENC(FN_FORMAT_TELNO(#{deliverynotiphone}))
                , DELIVERYNOTITIMESTART     = #{deliverynotitimestart}
                , DELIVERYNOTITIMEEND       = #{deliverynotitimeend}
                , EMPLOEENUMBER             = #{emploeenumber}
                , STORETYPE                 = #{storetype}
                , EDITDATE                  = SYSDATE
                , EDITWHO                   = #{gUserId}
            WHEN NOT MATCHED THEN
          INSERT
                (
                SERIALKEY
                , STORERKEY
                , CUSTKEY
                , CUSTTYPE
                , ADDRESSMATCHYN
                , TRUTHADDRESS1     /* ARRIVALADDRESS */
                , TRUTHADDRESS2     /* ARRIVALDETAILADDRESS */
                , TRUTHZIPCODE      /* ARRIVALPOSTALCODE */
                , FACEINSPECT       /* FTFINSPECTIONYN */
                , INSPECTIONWORKERPHONE
                , INSPECTORPRINTYN
                , PARKINGHEIGHT
                , KEYTYPE
                , KEYDETAIL
                , REQDLVTIME2_FROM
                , REQDLVTIME2_TO
                
                , DELIVERYAVAILABLETIME
                , BUILDINGOPENTIME
                , ACCESSWAY         /* MOVEMENTENTRY */
                , FREEZEPLACE       /* GOODSLOCATIONFROZEN */
                , COLDPLACE         /* GOODSLOCATIONREFRIG */
                , HTEMPERATURE      /* GOODSLOCATIONROOM */
                , LOADPLACE2        /* RETURNLOCATION */
                
                , INITREQUESTDT
                , INITREQUESTTIMESTART
                , INITREQUESTTIMEEND
                , INITFTFINSPECTIONYN
                , INITDELIVERYCONTACT
                , INITDELIVERYDESC
                , DELIVERYTYPE
                , TEMPTARGET
                , LABELPRINTTYPE
                , DELIVERYNOTIYN
                , DELIVERYNOTIPHONE
                , DELIVERYNOTITIMESTART
                , DELIVERYNOTITIMEEND
                , EMPLOEENUMBER
                , CREATEDBYEMAIL
                , CREATEDBYNAME
                , CREATEDDATE
                , STORETYPE
                , EDMSFILEID
                , STATUS
                , ADDWHO
                , ADDDATE
                , EDITWHO
                , EDITDATE
                
               ) VALUES (
               
                  SEQ_MS_CUSTDLVINFO.NEXTVAL
                , #{gStorerkey}
                , #{custkey}
                , #{custtype}
                , #{addressmatchyn}
                , #{truthaddress1}  /* ARRIVALADDRESS */
                , #{truthaddress2}  /* ARRIVALDETAILADDRESS */
                , #{truthzipcode}   /* ARRIVALPOSTALCODE */
                , #{faceinspect}    /* FTFINSPECTIONYN */
                , DAMO.ENC(FN_FORMAT_TELNO(#{inspectionworkerphone}))
                , #{inspectorprintyn}
                , #{parkingheight}
                , #{keytype}
                , #{keydetail}
                , #{reqdlvtime2From}    /* deliveryRequestTimeStart */
                , #{reqdlvtime2To}      /* deliveryRequestTimeEnd */
                
                , #{deliveryavailabletime}
                , #{buildingopentime}
                , #{accessway}          /* movementEntry */
                , #{freezeplace}        /* goodsLocationFrozen */
                , #{coldplace}          /* goodsLocationRefrig */
                , #{htemperature}       /* GOODSLOCATIONROOM */
                , #{loadplace2}         /* RETURNLOCATION */
                
                , #{initrequestdt}
                , #{initrequesttimestart}
                , #{initrequesttimeend}
                , #{initftfinspectionyn}
                , #{initdeliverycontact}
                , #{initdeliverydesc}
                , #{deliverytype}
                , #{temptarget}
                , #{labelprinttype}
                , #{deliverynotiyn}
                , DAMO.ENC(FN_FORMAT_TELNO(#{deliverynotiphone}))
                , #{deliverynotitimestart}
                , #{deliverynotitimeend}
                , #{emploeenumber}
                , #{createdbyemail}
                , #{gUserId}
                , SYSDATE
                , #{storetype}
                , #{edmsfileid}
                , '03'
                , #{gUserId}
                , SYSDATE
                , #{gUserId}
                , SYSDATE);
        END;
    </update>
    <select id="getAddressList" resultType="MsCustDeliveryInfoMasterResDto">
    SELECT /* [msCustDeliveryInfoService.sqlx][getAddressList][][][] */
	       MS_CUST.CUSTKEY   AS CODE                  
	     , MS_CUST.DESCRIPTION  AS NAME                  
	     , MS_CUST.ADDRESS1  AS ADDRESS1                  
	     , MS_CUST.ADDRESS2  AS ADDRESS2                  
      FROM MS_CUST         
     WHERE MS_CUST.STORERKEY   =  'FW00'
       AND MS_CUST.CUSTKEY         	= #{name}
       AND MS_CUST.CUSTTYPE = 'C'
    </select>
</mapper>
