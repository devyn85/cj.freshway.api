    <!-- 신규: 고객배송조건 첨부 임시저장 (STATUS='N') -->
    <insert id="insertCustDlvInfoFile">
        INSERT /* [msCustDeliveryInfoService.sqlx][msCustDeliveryInfoService.insertCustDlvInfoFile][고객배송조건 첨부 임시저장] */
               INTO CRM_CUSTDLVINFO_FILE
               (
                 SERIALKEY
               , ISSUENO
               , DOC_TYPE
               , DOC_NAME
               , FILE_NAME
               , FILE_EXTENSION
               , FILE_LOCATION
               , FILE_SIZE_BYTES
               , TRANS_FILE_NAME
               , UPLOAD_HASH_ID
               , UPLOAD_RES_DOC_ID
               , UPLOAD_FILE_NAME
               , UPLOAD_WORKPLACE_ID
               , UPLOAD_LOCATION
               , DOWNLOAD_COUNT
               , FILE_CONTENT
               , FILE_TYPE
               , STATUS
               , DEL_YN
               , ADDWHO
               , ADDDATE
               , EDITWHO
               , EDITDATE
               )
        VALUES
               (
                 SEQ_CRM_CUSTDLVINFO_FILE.NEXTVAL
               , #{issueno}
               , #{docType}
               , 'CRMDLVINFO_FILE'
               , #{fileName}
               , #{fileExtension}
               , #{fileLocation}
               , to_number(#{fileSizeBytes})
               , #{transFileName}
               , #{code}
               , ''
               , ''
               , ''
               , #{uploadLocation}
               , '0'
               , ''
               , 'HTTP'
               , 'N'
               , 'N'
               , #{gUserId}
               , SYSDATE
               , #{gUserId}
               , SYSDATE
               )
    </insert>

    <!-- 신규: 확정된 첨부 개수 조회(최대 2개 제한 체크용) -->
    <select id="selectCustDlvInfoConfirmedCnt" resultType="int">
        SELECT /* [msCustDeliveryInfoService.sqlx][msCustDeliveryInfoService.selectCustDlvInfoConfirmedCnt] */
               COUNT(*)
          FROM CRM_CUSTDLVINFO_FILE
         WHERE ISSUENO        = #{issueno}
           AND DOC_NAME       = 'CRMDLVINFO_FILE'
           AND UPLOAD_HASH_ID = #{code}
           AND UPLOAD_RES_DOC_ID IS NOT NULL
           AND STATUS         = 'Y'
           AND DEL_YN         = 'N'
    </select>

    <!-- 신규: 임시저장 파일 조회(확정 대상) -->
    <select id="selectCustDlvInfoTempFilesBySerialkeys" resultType="Hmap">
        SELECT SERIALKEY, ISSUENO, FILE_LOCATION, TRANS_FILE_NAME, FILE_NAME
          FROM CRM_CUSTDLVINFO_FILE
         WHERE ISSUENO = #{issueno}
           AND STATUS = 'N'
           AND DEL_YN = 'N'
           AND SERIALKEY IN
           <foreach collection="serialkeys" item="k" open="(" separator="," close=")">
             #{k}
           </foreach>
    </select>

    <!-- 신규: 확정(EDMS) 업데이트 -->
    <update id="updateCustDlvInfoFileConfirm">
        UPDATE CRM_CUSTDLVINFO_FILE
           SET UPLOAD_RES_DOC_ID   = #{uploadResDocId}
             , UPLOAD_FILE_NAME    = #{uploadFileName}
             , UPLOAD_WORKPLACE_ID = #{uploadWorkplaceId}
             , FILE_LOCATION       = #{fileLocation}
             , STATUS              = 'Y'
             , EDITWHO             = #{gUserId}
             , EDITDATE            = SYSDATE
         WHERE ISSUENO    = #{issueno}
           AND SERIALKEY  = #{serialkey}
           AND STATUS     = 'N'
           AND DEL_YN     = 'N'
    </update>

    <!-- 신규: 확정 파일 소프트 삭제(선택 행) -->
    <update id="updateCustDlvInfoSoftDeleteConfirmedBySerialkeys">
        UPDATE CRM_CUSTDLVINFO_FILE
           SET DEL_YN   = 'Y'
             , EDITWHO  = #{gUserId}
             , EDITDATE = SYSDATE
         WHERE ISSUENO = #{issueno}
           AND DOC_NAME = 'CRMDLVINFO_FILE'
           AND UPLOAD_HASH_ID = #{code}
           AND DEL_YN   = 'N'
           AND SERIALKEY IN
           <foreach collection="serialkeys" item="k" open="(" separator="," close=")">
             #{k}
           </foreach>
    </update>

    <!-- 임시/확정 공통: 파일행 조회(삭제/검증용) -->
    <select id="selectCustDlvInfoFilesBySerialkeys" resultType="Hmap">
        SELECT SERIALKEY, ISSUENO, STATUS, DEL_YN, FILE_LOCATION
          FROM CRM_CUSTDLVINFO_FILE
         WHERE ISSUENO = #{issueno}
           AND DOC_NAME = 'CRMDLVINFO_FILE'
           AND UPLOAD_HASH_ID = #{code}
           AND DEL_YN = 'N'
           AND SERIALKEY IN
           <foreach collection="serialkeys" item="k" open="(" separator="," close=")">
             #{k}
           </foreach>
    </select>
    
    <update id="updateCrmDlvInfoHis">
        MERGE 
            INTO LOGISONE.CRM_CUSTDLVINFO_HIS
           USING DUAL  ON (SERIALKEY = #{serialkeyHis})
    WHEN MATCHED THEN
          UPDATE 
             SET STATUS = '03'
               , CONFIRMDATE    = SYSDATE
               , EDITWHO        = #{gUserId}
               , EDITDATE       = SYSDATE
WHEN NOT MATCHED THEN
          INSERT (
                 SERIALKEY
               , STORERKEY
               , CUSTKEY
               , CUSTTYPE
               , ADDRESSMATCHYN
               , ARRIVALADDRESS
               , ARRIVALDETAILADDRESS
               , ARRIVALPOSTALCODE
               , FTFINSPECTIONYN
               , INSPECTIONWORKERPHONE
               , INSPECTORPRINTYN
               , PARKINGHEIGHT
