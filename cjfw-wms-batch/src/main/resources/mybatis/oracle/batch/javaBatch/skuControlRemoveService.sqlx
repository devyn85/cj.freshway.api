<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="skuControlRemoveService">
    <sql id="procedureParams">
          #{AVC_SYSTEM,      mode=IN, jdbcType=VARCHAR}
        , #{AVC_EXECUTEMODE, mode=IN, jdbcType=VARCHAR}
        , #{AVC_COMMAND,     mode=IN, jdbcType=VARCHAR}
        , #{AVC_DCCODE,      mode=IN, jdbcType=VARCHAR}
        , #{AVC_STORERKEY,   mode=IN, jdbcType=VARCHAR}
        , #{AVC_ORGANIZE,    mode=IN, jdbcType=VARCHAR}
        , #{AVC_AREA,        mode=IN, jdbcType=VARCHAR}
        , #{AVC_REQUESTCODE, mode=IN, jdbcType=VARCHAR}
        , #{AVC_REQUESTMSG,  mode=IN, jdbcType=VARCHAR}
        , #{AVC_WORKER,      mode=IN, jdbcType=VARCHAR}
        , #{AVC_SECURITYKEY, mode=IN, jdbcType=VARCHAR}
        , #{AI_SPID,         mode=IN, jdbcType=INTEGER}
        , #{ERR,             mode=INOUT, jdbcType=INTEGER}
        , #{RESULTMSG,       mode=INOUT, jdbcType=VARCHAR}
        , #{RETURNMSG,       mode=INOUT, jdbcType=VARCHAR}
        , AVC_LOG_PARAMS => #{AVC_LOG_PARAMS, mode=IN , jdbcType=VARCHAR} /*(20251020) BATCH LOG관련 PARAMS.*/
    </sql>
    <select id="callProcExecute" statementType="CALLABLE" parameterType="BatchParamsUtil" resultType="BatchParamsUtil" timeout="6000">
        { CALL SPDP_PURCHASECUST_SP.EXECUTE( /* [skuControlRemoveService.sqlx][callProcExecute][중단제어 자동해제][김환수][20250801] */
