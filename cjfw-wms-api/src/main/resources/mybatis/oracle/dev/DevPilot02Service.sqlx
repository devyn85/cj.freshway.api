<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="devPilot01Service">

    <select id="getMasterList" resultType="cjfw.wms.dev.dto.DevPilot01ResDto">     
        SELECT  /* [DevPilot02Service.sqlx][getMasterList][센터상품속성 목록 조회][sss][2025.05.23] */
               MS_SKUDCSET.DCCODE                        AS DCCODE         /* 센터코드 */
              ,MS_SKUDCSET.STORERKEY                     AS STORERKEY      /* 고객사 */
              ,MS_SKUDCSET.SKU                           AS SKU            /* 상품코드 */
              ,MS_SKU.DESCRIPTION                        AS SKU_DESCR
              ,MS_SKUDCSET.CROSSDOCKTYPE                 AS CROSSDOCKTYPE  /**크로스도킹*/
              ,MS_SKUDCSET.PUTAWAYTYPE                   AS PUTAWAYTYPE
              ,MS_SKUDCSET.WHAREA                        AS WHAREA         /* 기본보관창고동 */
              ,MS_SKUDCSET.WHAREAFLOOR                   AS WHAREAFLOOR    /* 기본보관창고층 */
              ,MS_SKUDCSET.LOCCATEGORY                   AS LOCCATEGORY    /* 기본보관로케이션유형 */
              ,MS_SKUDCSET.LOCLEVEL                      AS LOCLEVEL       /* 기본보관로케이션층 */
              ,MS_SKUDCSET.ZONE                          AS ZONE           /* 기본보관존 */
              ,MS_SKUDCSET.LOC                           AS LOC            /* 기본보관장소 */
              ,MS_SKUDCSET.ABC                           AS ABC
              ,MS_SKUDCSET.MINPOQTY                      AS MINPOQTY
              ,MS_SKUDCSET.TARGETPOQTY                   AS TARGETPOQTY
              ,MS_SKUDCSET.EFFECTIVEDATE                 AS EFFECTIVEDATE
              ,MS_SKUDCSET.OTHER01                       AS OTHER01
              ,MS_SKUDCSET.OTHER02                       AS OTHER02
              ,MS_SKUDCSET.OTHER03                       AS OTHER03
              ,MS_SKUDCSET.OTHER04                       AS OTHER04
              ,MS_SKUDCSET.OTHER05                       AS OTHER05
              ,MS_SKUDCSET.STATUS                        AS STATUS          /* 상태 */
              ,MS_SKUDCSET.SMS_YN                        AS SMS_YN          /* SMS처리대상여부 */     
              ,MS_SKUDCSET.DEL_YN                        AS DEL_YN          /* 삭제여부 */
              ,MS_SKUDCSET.INVOICE_CRT_TYPE              AS INVOICE_CRT_TYPE/*배송분류표 생성유형*/
              ,MS_SKUDCSET.SERIALKEY                     AS SERIALKEY       /* 데이터번호 */
              ,MS_SKUDCSET.CUBE_YN                       AS CUBE_YN         /* 고부피여부 */
              ,MS_SKUDCSET.CP_YN                         AS CP_YN           /* 쿠팡라벨여부 */
              ,TO_CHAR(MS_SKUDCSET.ADDDATE, 'yyyy-mm-dd hh24:mi:ss')  AS ADDDATE  /* 최초등록시간 */
              ,TO_CHAR(MS_SKUDCSET.EDITDATE, 'yyyy-mm-dd hh24:mi:ss') AS EDITDATE /* 최종변경시간 */
              ,MS_SKUDCSET.ADDWHO                        AS ADDWHO         /* 최초등록자 */
              ,MS_SKUDCSET.EDITWHO                       AS EDITWHO        /* 최종변경자 */
          FROM MS_SKUDCSET
          JOIN MS_SKU
            ON (
                MS_SKUDCSET.SKU       = MS_SKU.SKU
           AND  MS_SKUDCSET.STORERKEY = MS_SKU.STORERKEY
               )             
          JOIN CM_USER_AUTHORITY_DCXSTORER  
            ON (
                CM_USER_AUTHORITY_DCXSTORER.USERID = #{gUserId}
            <if test="dccode != null and dccode != ''"> 
                AND CM_USER_AUTHORITY_DCXSTORER.DCCODE      = #{dccode}             
            </if> 
            <if test="storerkey != null and storerkey != ''"> 
                AND CM_USER_AUTHORITY_DCXSTORER.STORERKEY   = #{storerkey} 
            </if>
                AND CM_USER_AUTHORITY_DCXSTORER.DCCODE      = MS_SKUDCSET.DCCODE
                AND CM_USER_AUTHORITY_DCXSTORER.STORERKEY   = MS_SKUDCSET.STORERKEY
                )
            WHERE  1=1
            <if test="dccode != null and dccode != ''">    
                AND MS_SKUDCSET.DCCODE                   LIKE #{dccode} || '%'       
            </if>
            <!-- 상품 다중선택 -->
            <if test="multiSku != null and multiSku != ''">
                AND MS_SKUDCSET.SKU IN (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
                                         FROM (SELECT #{multiSku} AS VAL FROM DUAL) A
                                         CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)                
            </if>
    </select>
    
   <select id="getMaskingList" resultType="cjfw.wms.dev.dto.DevPilot02MaskResDto">
    <![CDATA[
        SELECT A.EMP_NO
              ,A.NAME
              ,A.ENG_NAME
              ,A.TEL_NO
              ,A.ADDR
              ,A.EMAIL
              ,A.JUMIN
              ,A.BIRTH
              ,A.DRV_LICENSE
              ,A.PASSPORT
              ,A.CASH_CARD
              ,A.CREDIT_CARD
              ,A.ETC_CARD
              ,A.BIZ_NO
              ,A.ACCOUNT_NO
              ,A.QR_CD
              ,A.IP
              ,A.ID
          FROM (
                SELECT '감자' AS NAME
                    ,'GamJa' AS ENG_NAME
                    ,'010-2222-2222' AS TEL_NO       
                    ,'서울 서초구 서초동 1321-6 서초동아타워 1F' AS ADDR    
                    ,'EMAIL_test_1234@ehyundai.com' AS EMAIL     
                    ,'900101-1111111' AS JUMIN        
                    ,'1990-01-01' AS BIRTH        
                    ,'11-95-123123-61' AS DRV_LICENSE     
                    ,'M99999999' AS PASSPORT  
                    ,'154420201234123456' AS CASH_CARD     
                    ,'1234-1234-1234-1234' AS CREDIT_CARD    
                    ,'1234-1234-123' AS ETC_CARD       
                    ,'123-99-45644' AS BIZ_NO     
                    ,'78945612345685' AS ACCOUNT_NO        
                    ,'126-0-1234-1234' AS QR_CD      
                    ,'111.111.111.111' AS IP            
                    ,'test_id_test_id' AS ID
                    , '1' AS EMP_NO
                FROM DUAL
                UNION ALL
                SELECT '고구마' AS NAME
                    ,'Guma Ko' AS ENG_NAME
                    ,'010-0000-0000' AS TEL_NO       
                    ,'서울 강남구 강남대로 438 스타플렉스' AS ADDR    
                    ,'123123@ehyundai.com' AS EMAIL     
                    ,'9001011111111' AS JUMIN        
                    ,'19901212' AS BIRTH        
                    ,'119512312361' AS DRV_LICENSE     
                    ,'M99999999' AS PASSPORT  
                    ,'1544-2020-1234-123456' AS CASH_CARD     
                    ,'1234123412341234' AS CREDIT_CARD    
                    ,'1234-1234-123' AS ETC_CARD       
                    ,'123-80-88888' AS BIZ_NO     
                    ,'54654987321' AS ACCOUNT_NO        
                    ,'111911119999' AS QR_CD      
                    ,'222.111.222.111' AS IP            
                    ,'gumaguma' AS ID
                    , '2' AS EMP_NO
                FROM DUAL
                UNION ALL
                SELECT '브로콜리' AS NAME
                    ,'bc' AS ENG_NAME
                    ,'02-123-7890' AS TEL_NO       
                    ,'서울 서초구 서초동 1327-29 서초 파라곤 지하01호' AS ADDR    
                    ,'cj@naver.com' AS EMAIL     
                    ,'9001012999999' AS JUMIN        
                    ,'1945.08.15' AS BIRTH        
                    ,'119512312361' AS DRV_LICENSE     
                    ,'M99999999' AS PASSPORT  
                    ,'154420201234123456' AS CASH_CARD     
                    ,'1234123412341234' AS CREDIT_CARD    
                    ,'88888888888888' AS ETC_CARD       
                    ,'123-80-88888' AS BIZ_NO     
                    ,'54654987878787321' AS ACCOUNT_NO        
                    ,'123456780000' AS QR_CD      
                    ,'123.123.123.123' AS IP            
                    ,'11testId' AS ID
                    , '3' AS EMP_NO
                FROM DUAL
                UNION ALL
                SELECT '김' AS NAME
                    ,'Yim Dae Sung' AS ENG_NAME
                    ,'02-1234-7890' AS TEL_NO       
                    ,'서울 서초구 서초동 1327-29 서초 파라곤 지하01호' AS ADDR    
                    ,'idididid@naver.com' AS EMAIL     
                    ,'9001012999999' AS JUMIN        
                    ,'19910101' AS BIRTH        
                    ,'119512312361' AS DRV_LICENSE     
                    ,'M99999999' AS PASSPORT  
                    ,'154420201234123456' AS CASH_CARD     
                    ,'1234123412341234' AS CREDIT_CARD    
                    ,'88888888888888' AS ETC_CARD       
                    ,'123-80-88888' AS BIZ_NO     
                    ,'54654987878787321' AS ACCOUNT_NO        
                    ,'000122223333' AS QR_CD      
                    ,'123.123.123.123' AS IP            
                    ,'11testId' AS ID
                    , '4' AS EMP_NO
                FROM DUAL
                UNION ALL
                SELECT '호박고구마' AS NAME
                    ,'JiSoo.mi Kyung' AS ENG_NAME
                    ,'031-123-7890' AS TEL_NO       
                    ,'서울시 서울구 서울동 123-1 땡땡아파트 101동 1001호' AS ADDR    
                    ,'abcd123@ehyundai.com' AS EMAIL     
                    ,'9001012999999' AS JUMIN        
                    ,'19920531' AS BIRTH        
                    ,'119512312361' AS DRV_LICENSE     
                    ,'M99999999' AS PASSPORT  
                    ,'154420201234123456' AS CASH_CARD     
                    ,'1234123412341234' AS CREDIT_CARD    
                    ,'88888888888888' AS ETC_CARD       
                    ,'123-80-88888' AS BIZ_NO     
                    ,'54654987878787321' AS ACCOUNT_NO        
                    ,'126012341234' AS QR_CD      
                    ,'123.123.123.123' AS IP            
                    ,'11testId' AS ID
                    , '5' AS EMP_NO
                FROM DUAL
                UNION ALL
                SELECT '개인정보' AS NAME
                    ,'Im Dae Sang' AS ENG_NAME
                    ,'031-1234-7890' AS TEL_NO       
                    ,'서울특별시 광진구 화양동 AAAAA' AS ADDR    
                    ,'q123_dddd@naver.com' AS EMAIL     
                    ,'9001012999999' AS JUMIN        
                    ,'1988-01-01' AS BIRTH        
                    ,'119512312361' AS DRV_LICENSE     
                    ,'M99999999' AS PASSPORT  
                    ,'154420201234123456' AS CASH_CARD     
                    ,'1234123412341234' AS CREDIT_CARD    
                    ,'88888888888888' AS ETC_CARD       
                    ,'123-80-88888' AS BIZ_NO     
                    ,'54654987878787321' AS ACCOUNT_NO        
                    ,'126012341234' AS QR_CD      
                    ,'111111111111' AS IP            
                    ,'123123test' AS ID
                    , '6' AS EMP_NO
                FROM DUAL
                UNION ALL
                SELECT '마스킹처리' AS NAME
                    ,'YimDaeSang' AS ENG_NAME
                    ,'01012347890' AS TEL_NO       
                    ,'인천광역시 남동구 무슨동 AA아파트 110동 101호' AS ADDR    
                    ,'id_test12345@naver.com' AS EMAIL     
                    ,'9001012999999' AS JUMIN        
                    ,'2000.01.01' AS BIRTH        
                    ,'119512312361' AS DRV_LICENSE     
                    ,'M99999999' AS PASSPORT  
                    ,'154420201234123456' AS CASH_CARD     
                    ,'1234123412341234' AS CREDIT_CARD    
                    ,'88888888888888' AS ETC_CARD       
                    ,'123-80-88888' AS BIZ_NO     
                    ,'54654987878787321' AS ACCOUNT_NO        
                    ,'126012341234' AS QR_CD      
                    ,'123.123.123.123' AS IP            
                    ,'aaa231235235' AS ID
                    , '7' AS EMP_NO
                FROM DUAL
                UNION ALL
                SELECT '이름테스트' AS NAME
                    ,'testName' AS ENG_NAME
                    ,'0101237890' AS TEL_NO       
                    ,'서울 서초구 서초동 111-01' AS ADDR    
                    ,'0__123@naver.com' AS EMAIL     
                    ,'9001012999999' AS JUMIN        
                    ,'19900808' AS BIRTH        
                    ,'119512312361' AS DRV_LICENSE     
                    ,'M99999999' AS PASSPORT  
                    ,'154420201234123456' AS CASH_CARD     
                    ,'1234123412341234' AS CREDIT_CARD    
                    ,'88888888888888' AS ETC_CARD       
                    ,'123-80-88888' AS BIZ_NO     
                    ,'54654987878787321' AS ACCOUNT_NO        
                    ,'126012341234' AS QR_CD      
                    ,'123.123.123.123' AS IP            
                    ,'z_zdkdkdkd' AS ID
                    , '8' AS EMP_NO
                FROM DUAL
                UNION ALL
                SELECT '테스트' AS NAME
                    ,'abc' AS ENG_NAME
                    ,'021237890' AS TEL_NO       
                    ,'경기도 이천시 땡땡면 무슨로 123123 AA건물' AS ADDR    
                    ,'mm_rkk55@test.com' AS EMAIL     
                    ,'9001012999999' AS JUMIN        
                    ,'19900808' AS BIRTH        
                    ,'119512312361' AS DRV_LICENSE     
                    ,'M99999999' AS PASSPORT  
                    ,'154420201234123456' AS CASH_CARD     
                    ,'1234123412341234' AS CREDIT_CARD    
                    ,'88888888888888' AS ETC_CARD       
                    ,'123-80-88888' AS BIZ_NO     
                    ,'54654987878787321' AS ACCOUNT_NO        
                    ,'126012341234' AS QR_CD      
                    ,'123.123.123.123' AS IP            
                    ,'test_idtddddd' AS ID
                    , '9' AS EMP_NO
                FROM DUAL
                UNION ALL
                SELECT '이름' AS NAME
                    ,'A' AS ENG_NAME
                    ,'0212347890' AS TEL_NO       
                    ,'경기 이천시 대월면 사동리 111-111 ZZZZ상점' AS ADDR    
                    ,'123556@naver.com' AS EMAIL     
                    ,'9001012999999' AS JUMIN        
                    ,'19900808' AS BIRTH        
                    ,'119512312361' AS DRV_LICENSE     
                    ,'M99999999' AS PASSPORT  
                    ,'154420201234123456' AS CASH_CARD     
                    ,'1234123412341234' AS CREDIT_CARD    
                    ,'88888888888888' AS ETC_CARD       
                    ,'123-80-88888' AS BIZ_NO     
                    ,'54654987878787321' AS ACCOUNT_NO        
                    ,'126012341234' AS QR_CD      
                    ,'123.123.123.123' AS IP            
                    ,'vvvvvv' AS ID
                    , '10' AS EMP_NO
                FROM DUAL
                UNION ALL
                SELECT '기역니은디귿' AS NAME
                    ,'test' AS ENG_NAME
                    ,'0311237890' AS TEL_NO       
                    ,'경기 이천시 마장면 덕이로 154번길 123-12' AS ADDR    
                    ,'ganadala@naver.com' AS EMAIL     
                    ,'9001012999999' AS JUMIN        
                    ,'19900808' AS BIRTH        
                    ,'119512312361' AS DRV_LICENSE     
                    ,'M99999999' AS PASSPORT  
                    ,'154420201234123456' AS CASH_CARD     
                    ,'1234123412341234' AS CREDIT_CARD    
                    ,'88888888888888' AS ETC_CARD       
                    ,'123-80-88888' AS BIZ_NO     
                    ,'54654987878787321' AS ACCOUNT_NO        
                    ,'126012341234' AS QR_CD      
                    ,'123.123.123.123' AS IP            
                    ,'11tavestId' AS ID
                    , '11' AS EMP_NO
                FROM DUAL
                UNION ALL
                SELECT '가나다' AS NAME
                    ,'a b c d' AS ENG_NAME
                    ,'03112347890' AS TEL_NO       
                    ,'충청남도 서천군 장항읍 장산로 2222' AS ADDR    
                    ,'test123123@google.com' AS EMAIL     
                    ,'9001012-999999' AS JUMIN        
                    ,'19900808' AS BIRTH        
                    ,'119512312361' AS DRV_LICENSE     
                    ,'M99999999' AS PASSPORT  
                    ,'154420201234123456' AS CASH_CARD     
                    ,'1234123412341234' AS CREDIT_CARD    
                    ,'88888888888888' AS ETC_CARD       
                    ,'123-80-88888' AS BIZ_NO     
                    ,'54654987878787321' AS ACCOUNT_NO        
                    ,'126012341234' AS QR_CD      
                    ,'123123123123' AS IP            
                    ,'bdsd234' AS ID
                    , '12' AS EMP_NO
                FROM DUAL
        ) A
      WHERE 1=1
    ]]>
        <if test="empNo != null and empNo != ''"> 
            AND A.EMP_NO = #{empNo}             
        </if>     
    </select>    
    
    <update id="deleteTampTable">
        DELETE /* [DevPilot02Service.sqlx][deleteTampTable][엑셀데이터임시 Tabele 삭제][sss][2025.05.23] */
               SY_PROCESSTEMP_WD
         WHERE PROCESSCREATOR = #{gUserId}
           AND PROCESSTYPE    = 'MS_EXCEPTION'
           AND SPID           = 'SPMS_EXCEPTION'
    </update>    
    
    <!-- 엑셀업로드 정보을(를) 등록 -->
    <insert id="insertTempExcel" parameterType="java.util.List" >
        <!-- 
        <selectKey resultType="int" keyProperty="seq" order="BEFORE">
        SELECT '1' AS SEQ FROM DUAL
        </selectKey>
        -->
        <foreach collection="list" index="index" item="item" separator=" " open="INSERT ALL" close="SELECT * FROM DUAL">
              /* [DevPilot02Service.sqlx][insertTempExcel][엑셀데이터임시 Tabele 등록][sss][2025.05.23] */
              INTO SY_PROCESSTEMP_WD (PROCESSTYPE,PROCESSCREATOR,SPID,ADDWHO,EDITWHO
                                      /**/
                                     ,DCCODE
                                     ,STORERKEY
                                     ,DOCNO
                                     ,DOCLINE
                                     ,SLIPDT
                                     ,SKU
                                     /**/
                                     ,OTHER01
                                    )
            VALUES (
                    'MS_EXCEPTION',#{item.gUserId},#{item.gSpid},#{item.gUserId},#{item.gUserId}
                    /**/
                    ,#{item.dccode}          /*1.센터코드*/
                    ,#{item.storerkey}       /*2.고객사코드*/
                    ,#{item.docno}           /*3.문서번호*/
                    ,#{item.docline}         /*4.문서라인*/
                    ,#{item.slipdt}          /*5.전표일자*/
                    ,#{item.sku}             /*6.상품*/
                    /**/
                    ,TO_CHAR(#{index})      /*1~999999*/
                   )
        </foreach>
    </insert>
    
      
    
  
</mapper>