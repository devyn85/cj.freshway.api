<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="msDCxCustService">
	<!-- 센터별거래처관리 정보 조회(목록) -->
    <select id="getMasterList" resultType="MsDCxCustResDto">
    	  SELECT /* [msDcXCustService.sqlx][msDcXCustService.getMasterList][주출고처 기준정보 조회 (목록)][jangjaehyun][20250708] */
	           MS_DCXCUST.SERIALKEY                                                             AS SERIALKEY,    /* 데이터번호 */
	           MS_DCXCUST.DCCODE                                                                AS DCCODE,       /* 센터코드 */
	           MS_DCXCUST.STORERKEY                                                             AS STORERKEY,    /* 고객사코드 */
	           MS_DCXCUST.CUSTKEY                                                               AS CUSTKEY,      /* 거래처코드 */
	           MS_CUST.DESCRIPTION                                                              AS CUSTNAME,     /* 거래처명 */
	           NVL(CD1.BASEDESCR,CD1.BASECODE)                                                  AS CUSTTYPE,     /* 거래처유형 */
	           MS_DCXCUST.PARTNERKEY                                                            AS PARTNERKEY,   /* PARTNERKEY */
	           NVL(CD3.BASEDESCR,CD3.BASECODE)                                                  AS DISTANCETYPE, /* DISTANCETYPE */
	           MS_DCXCUST.STATUS                                                                AS STATUS,       /* 상태 */
	           MS_DCXCUST.DEL_YN                                                                AS DEL_YN,       /* 삭제여부 */
	           MS_DCXCUST.CUSTTYPE                                                              AS CUSTTYPE_CD,
	           MS_DCXCUST.ADDWHO 	                                                            AS ADDWHO,        /* 최초등록자 */
	           MS_DCXCUST.EDITWHO 	  	       	       	       	       	       	                AS EDITWHO,       /* 최종변경자 */
	           MS_DCXCUST.ADDDATE 	 	       	       	       	       	       	                AS ADDDATE,       /* 최초등록시간 */
	           MS_DCXCUST.EDITDATE 	   	       	       	       	       	       	       	        AS EDITDATE,       /* 최종변경시간 */
	           USER1.USER_NM                                                                    AS ADDWHO_NM,      /* 등록자명 */
			   USER2.USER_NM                                                                    AS EDITWHO_NM     /* 수정자명 */
	      FROM MS_DCXCUST
	      JOIN MS_CUST
	        ON MS_CUST.STORERKEY = MS_DCXCUST.STORERKEY
	       AND MS_CUST.CUSTKEY = MS_DCXCUST.CUSTKEY
	       AND MS_CUST.CUSTTYPE = MS_DCXCUST.CUSTTYPE
	      JOIN CM_USER_AUTHORITY_DCXSTORER
	        ON CM_USER_AUTHORITY_DCXSTORER.USERID = #{gUserId}
	       AND CM_USER_AUTHORITY_DCXSTORER.DCCODE = #{gDccode}
	    <if test='gStorerkey != "%"'>
	       AND CM_USER_AUTHORITY_DCXSTORER.STORERKEY = #{gStorerkey}
	    </if>
	       AND CM_USER_AUTHORITY_DCXSTORER.STORERKEY = MS_DCXCUST.STORERKEY
	      LEFT JOIN CM_CODE_STORER CD1  ON CD1.STORERKEY  = MS_DCXCUST.STORERKEY AND CD1.CODELIST  = 'CUSTTYPE' 	AND CD1.BASECODE   = MS_DCXCUST.CUSTTYPE
	      LEFT JOIN CM_CODE_STORER CD3  ON CD3.STORERKEY  = MS_DCXCUST.STORERKEY AND CD3.CODELIST  = 'DISTANCETYPE' AND CD3.BASECODE   = MS_DCXCUST.DISTANCETYPE
	      LEFT JOIN FRAMEONE_USER USER1 ON USER1.USER_ID = MS_DCXCUST.ADDWHO  /*등록자명*/
          LEFT JOIN FRAMEONE_USER USER2 ON USER2.USER_ID = MS_DCXCUST.EDITWHO  /*수정자명*/
	     WHERE 1=1
	       AND MS_DCXCUST.STORERKEY = #{gStorerkey}
	    <if test='multiDcCode != null and multiDcCode.length > 0'>
		   AND MS_DCXCUST.DCCODE IN
	       <foreach collection="multiDcCode" item="dccodeItem" open="(" separator="," close=")">
	           #{dccodeItem}
	       </foreach>
		</if>
	    <if test='custKey != null and custKey !=""'>
           AND MS_DCXCUST.CUSTKEY IN
            (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
                        FROM (SELECT #{custKey} AS VAL FROM DUAL) A
                     CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
        </if>
	    <if test="custType != null and custType != ''">
	        AND MS_DCXCUST.CUSTTYPE = #{custType}
	    </if>
	    <if test="partnerKey != null and partnerKey != ''">
	        AND MS_DCXCUST.PARTNERKEY = #{partnerKey}
	    </if>
	    <if test="distanceType != null and distanceType != ''">
	        AND MS_DCXCUST.DISTANCETYPE = #{distanceType}
	    </if>
	    <if test="addDateFrom != null and addDateFrom != ''">
	        AND MS_DCXCUST.ADDDATE <![CDATA[ >= ]]> TO_DATE(#{addDateFrom},'YYYYMMDD')
	    </if>
	    <if test="addDateTo != null and addDateTo != ''">
	        AND MS_DCXCUST.ADDDATE <![CDATA[ < ]]> TO_DATE(#{addDateTo},'YYYYMMDD') + 1
	    </if>
	    <if test="status != null and status != ''">
	        AND MS_DCXCUST.STATUS LIKE #{status}
	    </if>
	    <if test="delYn != null and delYn != ''">
	        AND MS_DCXCUST.DEL_YN LIKE #{delYn}
	    </if>
    </select>
    
    <!-- 센터별거래처관리 정보 UPDATE -->
    <update id="updateMaster">		
		UPDATE /* [msDCxCustService.sqlx][msDCxCustService.updateMaster][센터별거래처관리 정보 UPDATE][jangjaehyun][20250708] */ 
		    MS_DCXCUST
		SET STATUS           = #{status}          /* 상태 */
           ,DEL_YN           = #{delYn}           /* 삭제여부 */
           ,PARTNERKEY       = #{partnerKey}      /* PARTNERKEY */
           ,DISTANCETYPE     = #{distanceType}    /* DISTANCETYPE */
           ,EDITDATE         = SYSDATE    	      /* 최종변경시간 */
           ,EDITWHO          = #{gUserId}         /* 최종변경자 */
        WHERE SERIALKEY      = #{serialKey}
	</update>    
   
</mapper>