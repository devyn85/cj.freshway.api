<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="omCloseMonitoringService">


	<select id="getMasterList" resultType="OmCloseMonitoringResDto">		
		WITH T_DM_DOCUMENT_D AS (
			    SELECT /*+ LEADING(DM_DOCUMENT_D) */ --■ DBA 2025.12.07 힌트추가 
			           DM_DOCUMENT_D.DCCODE
			          ,DM_DOCUMENT_D.STORERKEY
			          ,DM_DOCUMENT_D.DOCTYPE
			          ,DM_DOCUMENT_D.DELIVERYDATE
			          ,DM_DOCUMENT_D.DOCNO
			          ,DM_DOCUMENT_D.DOCLINE
			          ,DM_DOCUMENT_D.SKU
			          ,DM_DOCUMENT_D.DOCDT
			          ,DECODE(DM_DOCUMENT_D.DEL_YN,'N',DM_DOCUMENT_D.STOREROPENQTY,0) * DM_DOCUMENT_D.BUNJA / DM_DOCUMENT_D.BUNMO AS STORERORDERQTY
			          ,DM_DOCUMENT_D.STORERCONFIRMQTY * DM_DOCUMENT_D.BUNJA / DM_DOCUMENT_D.BUNMO AS STORERCONFIRMQTY
			          ,DM_DOCUMENT_D.ORDERQTY + DM_DOCUMENT_D.ORDERADJUSTQTY AS ORDERQTY
			          ,DM_DOCUMENT_D.PROCESSQTY
			          ,DM_DOCUMENT_D.WORKQTY
			          ,DM_DOCUMENT_D.INSPECTQTY
			          ,DM_DOCUMENT_D.INVOICEQTY
			          ,DM_DOCUMENT_D.CONFIRMQTY
			          ,DM_DOCUMENT_D.DEL_YN
			          ,DM_DOCUMENT_D.STATUS
			          ,DM_DOCUMENT_D.CHANNEL
			          ,NVL( DM_DOCUMENT_H.SHPTO_ID
										          , CASE WHEN DM_DOCUMENT_H.DOCTYPE = 'WD' THEN DM_DOCUMENT_H.TO_CUSTKEY
										                 WHEN DM_DOCUMENT_H.DOCTYPE = 'RT' THEN DM_DOCUMENT_H.FROM_CUSTKEY
								                         ELSE DM_DOCUMENT_H.TO_CUSTKEY
								                    END 
								                  ) AS CUSTKEY
			          ,CASE WHEN DM_DOCUMENT_H.DOCTYPE = 'WD' THEN DM_DOCUMENT_H.TO_CUSTTYPE
                            WHEN DM_DOCUMENT_H.DOCTYPE = 'RT' THEN DM_DOCUMENT_H.FROM_CUSTTYPE
                            ELSE DM_DOCUMENT_H.TO_CUSTTYPE	
                       END	AS CUSTTYPE
			    FROM   DM_DOCUMENT_D
			    JOIN   DM_DOCUMENT_H
			    ON     DM_DOCUMENT_H.DCCODE = DM_DOCUMENT_D.DCCODE
			    AND    DM_DOCUMENT_H.DOCTYPE = DM_DOCUMENT_D.DOCTYPE
			    AND    DM_DOCUMENT_H.DELIVERYDATE = DM_DOCUMENT_D.DELIVERYDATE
			    AND    DM_DOCUMENT_H.DOCNO = DM_DOCUMENT_D.DOCNO
			   WHERE   DM_DOCUMENT_D.DCCODE       = #{fixdccode}
				 AND   DM_DOCUMENT_D.DELIVERYDATE = #{deliverydt}
			    )
		SELECT /* [OmCloseMonitoringService.sqlx][getMasterList][마감주문반영-전표모니터링 목록 조회][공두경][2025.06.23] */				 
		       T_DM_DOCUMENT_D.DCCODE					AS DCCODE				/*물류센터*/	
		      ,T_DM_DOCUMENT_D.DELIVERYDATE				AS DELIVERYDATE			/*배송일자*/		       
		      ,NVL(CD3.BASEDESCR,CD3.BASECODE)			AS DOCTYPE				/*문서유형*/
		      ,T_DM_DOCUMENT_D.DOCNO					AS DOCNO				/*문서번호*/
		      ,T_DM_DOCUMENT_D.DOCLINE					AS DOCLINE				/*품목번호*/
		      ,T_DM_DOCUMENT_D.SKU						AS SKU					/*상품코드*/
		      ,MS_SKU.DESCRIPTION                   	AS SKUNAME 				/*상품명칭*/
		      ,T_DM_DOCUMENT_D.STORERORDERQTY			AS STORERORDERQTY		/*원수량*/
		      ,T_DM_DOCUMENT_D.STORERCONFIRMQTY			AS STORERCONFIRMQTY		/*고객실적수량*/
		      ,T_DM_DOCUMENT_D.ORDERQTY					AS ORDERQTY				/*주문수량*/
		      ,T_DM_DOCUMENT_D.PROCESSQTY				AS PROCESSQTY			/*진행수량*/
		      ,T_DM_DOCUMENT_D.WORKQTY					AS WORKQTY				/*현장작업량*/
		      ,T_DM_DOCUMENT_D.INSPECTQTY				AS INSPECTQTY			/*검품수량*/
		      ,T_DM_DOCUMENT_D.INVOICEQTY				AS INVOICEQTY			/*운송장수량*/
		      ,T_DM_DOCUMENT_D.CONFIRMQTY				AS CONFIRMQTY			/*확정수량*/
		       ,NVL(CD1.BASEDESCR,CD1.BASECODE) 		AS CHANNEL				/*배송채널*/
		      ,(   CASE WHEN T_DM_DOCUMENT_D.DEL_YN <![CDATA[<>]]> 'N' AND T_DM_DOCUMENT_D.ORDERQTY <![CDATA[ > ]]> 0    THEN '삭제미처리 ' ELSE '' END
		        || CASE WHEN T_DM_DOCUMENT_D.STORERORDERQTY <![CDATA[ > ]]>  T_DM_DOCUMENT_D.ORDERQTY AND T_DM_DOCUMENT_D.STATUS <![CDATA[<> ]]> '90' THEN '결품예상 ' ELSE '' END
		        || CASE WHEN T_DM_DOCUMENT_D.STORERORDERQTY <![CDATA[ < ]]>  T_DM_DOCUMENT_D.ORDERQTY AND T_DM_DOCUMENT_D.STATUS <![CDATA[<> ]]>'90' THEN '과출예상 ' ELSE '' END
		        || CASE WHEN T_DM_DOCUMENT_D.STORERORDERQTY <![CDATA[ > ]]>  T_DM_DOCUMENT_D.CONFIRMQTY AND T_DM_DOCUMENT_D.STATUS = '90'  THEN '결품발생 ' ELSE '' END
		        || CASE WHEN T_DM_DOCUMENT_D.STORERORDERQTY <![CDATA[ < ]]>  T_DM_DOCUMENT_D.CONFIRMQTY AND T_DM_DOCUMENT_D.STATUS = '90'  THEN '과출발생 ' ELSE '' END
		        || CASE WHEN T_DM_DOCUMENT_D.STORERORDERQTY <![CDATA[ < ]]>  T_DM_DOCUMENT_D.STORERCONFIRMQTY THEN '초과확정 '   ELSE '' END
		        || CASE WHEN T_DM_DOCUMENT_D.STORERORDERQTY <![CDATA[ < ]]>  T_DM_DOCUMENT_D.PROCESSQTY       THEN '초과할당 '   ELSE '' END
		        || CASE WHEN T_DM_DOCUMENT_D.STORERORDERQTY <![CDATA[ < ]]>  T_DM_DOCUMENT_D.WORKQTY          THEN '초과피킹 '   ELSE '' END
		        || CASE WHEN T_DM_DOCUMENT_D.STORERORDERQTY <![CDATA[ < ]]>  T_DM_DOCUMENT_D.INSPECTQTY       THEN '초과상차 '   ELSE '' END
		        || CASE WHEN T_DM_DOCUMENT_D.STORERORDERQTY <![CDATA[ < ]]>  T_DM_DOCUMENT_D.INVOICEQTY       THEN '초과발행 '   ELSE '' END
		        || CASE WHEN T_DM_DOCUMENT_D.STORERORDERQTY <![CDATA[ < ]]>  T_DM_DOCUMENT_D.CONFIRMQTY       THEN '초과확정 '   ELSE '' END
		       ) 										AS ERRMSG				/*에러사항*/
		      ,CD2.BASEDESCR||' '||CD2.CONVDESCR		AS CLOSETIME_STANDARD	/*마감기준시간*/ 
		      ,MS_CUST.CUSTKEY							AS CUSTKEY				/*거래처*/
		      ,MS_CUST.DESCRIPTION						AS CUSTNAME				/*거래처명*/
		      ,T_DM_DOCUMENT_D.STORERKEY				AS STORERKEY			/**/
		      ,T_DM_DOCUMENT_D.DOCDT					AS DOCDT				/**/
		       ,'0'										AS CHECKYN
		FROM   T_DM_DOCUMENT_D    
		JOIN   MS_SKU
		ON     MS_SKU.STORERKEY = T_DM_DOCUMENT_D.STORERKEY
		AND    MS_SKU.SKU       = T_DM_DOCUMENT_D.SKU		
		<if test="serialyn != null and serialyn != ''">	AND MS_SKU.SERIALYN	= #{serialyn} 	</if>
		JOIN MS_CUST 
		ON     T_DM_DOCUMENT_D.STORERKEY    = MS_CUST.STORERKEY
		AND    T_DM_DOCUMENT_D.CUSTKEY   = MS_CUST.CUSTKEY
		AND    T_DM_DOCUMENT_D.CUSTTYPE  = MS_CUST.CUSTTYPE		
		<if test="closetimeStandardMulti != null and closetimeStandardMulti != ''">
           AND MS_CUST.CUSTSTRATEGY4 IN
           <foreach collection="closetimeStandardMulti" item="code" open="(" close=")" separator=",">
             #{code}
           </foreach>   
        </if> 
		LEFT JOIN CM_CODE_STORER CD1  ON CD1.STORERKEY  = T_DM_DOCUMENT_D.STORERKEY AND CD1.CODELIST  = 'PUTAWAYTYPE' 			AND CD1.BASECODE   = T_DM_DOCUMENT_D.CHANNEL
		LEFT JOIN CM_CODE_STORER CD2  ON CD2.STORERKEY  = MS_CUST.STORERKEY 		AND CD2.CODELIST  = 'CUSTORDERCLOSETIME' 	AND CD2.BASECODE   = MS_CUST.CUSTSTRATEGY4
		LEFT JOIN CM_CODE_STORER CD3  ON CD3.STORERKEY  = T_DM_DOCUMENT_D.STORERKEY AND CD3.CODELIST  = 'DOCTYPE'   			AND CD3.BASECODE   = T_DM_DOCUMENT_D.DOCTYPE
		WHERE  T_DM_DOCUMENT_D.DCCODE       = #{fixdccode}
		AND    T_DM_DOCUMENT_D.DELIVERYDATE = #{deliverydt}
		AND    (   T_DM_DOCUMENT_D.STORERORDERQTY  <![CDATA[ <>  ]]> T_DM_DOCUMENT_D.ORDERQTY
		        OR T_DM_DOCUMENT_D.STORERORDERQTY  <![CDATA[ <  ]]> T_DM_DOCUMENT_D.STORERCONFIRMQTY
		        OR T_DM_DOCUMENT_D.STORERORDERQTY  <![CDATA[ <  ]]> T_DM_DOCUMENT_D.ORDERQTY
		        OR T_DM_DOCUMENT_D.STORERORDERQTY  <![CDATA[ <  ]]> T_DM_DOCUMENT_D.PROCESSQTY
		        OR T_DM_DOCUMENT_D.STORERORDERQTY  <![CDATA[ <  ]]> T_DM_DOCUMENT_D.WORKQTY
		        OR T_DM_DOCUMENT_D.STORERORDERQTY  <![CDATA[ <  ]]> T_DM_DOCUMENT_D.INSPECTQTY
		        OR T_DM_DOCUMENT_D.STORERORDERQTY  <![CDATA[ <  ]]> T_DM_DOCUMENT_D.INVOICEQTY
		        OR T_DM_DOCUMENT_D.STORERORDERQTY  <![CDATA[ <  ]]> T_DM_DOCUMENT_D.CONFIRMQTY
		      )
		
	</select>
	
	
    <delete id="deleteTampTable">
        DELETE /* [WdInplanService.sqlx][deleteTampTable][엑셀데이터임시 Tabele 삭제][sss][2025.05.23] */
               SY_PROCESSTEMP_WD
         WHERE PROCESSCREATOR = #{gUserId}
           AND PROCESSTYPE    = 'ORDERCLOSE'
           AND SPID           = #{gSpid}
    </delete>    
    
    <!-- 엑셀업로드 정보을(를) 등록 -->
    <insert id="insertTempExcel" parameterType="java.util.List" >
        <foreach collection="list" index="index" item="item" separator=" " open="INSERT ALL" close="SELECT * FROM DUAL">
              /* [OmCloseMonitoringService.sqlx][insertTempExcel][엑셀데이터임시 Tabele 등록][공두경][2025.06.24] */
              INTO SY_PROCESSTEMP_WD (PROCESSTYPE,PROCESSCREATOR,SPID,ADDWHO,EDITWHO
                                      /**/
                                     ,DCCODE
                                     ,STORERKEY
                                     ,DOCNO
                                     ,DOCLINE
                                     ,SLIPDT
                                     ,DELIVERYDT
                                     ,OTHER01
                                    )
            VALUES (
                    'ORDERCLOSE',#{item.gUserId},#{item.gSpid},#{item.gUserId},#{item.gUserId}
                    /**/
                    ,#{item.dccode}          /*1.센터코드*/
                    ,#{item.storerkey}       /*2.고객사코드*/
                    ,#{item.docno}           /*3.문서번호*/
                    ,#{item.docline}         /*4.문서라인*/
                    ,#{item.deliverydt}    /*5.전표일자*/
                    ,#{item.deliverydt}    /*6.배송일자*/
                    /**/
                    ,TO_CHAR(#{index})      /*1~999999*/
                   )
        </foreach>
    </insert>
    
    
    <select id="getCloseTime" resultType="OmCloseMonitoringResCloseTimeDto">                
        SELECT /* [OmCloseMonitoringService.sqlx][getCloseTime][마감기준시간 콤보데이터 조회][공두경][2025.07.16] */
               LISTAGG(BASECODE, ', ') WITHIN GROUP (ORDER BY BASECODE)     AS BASECODE
              , DATA1                                                   AS BASEDESCR     
          FROM CM_CODE_STORER
         WHERE CODELIST = 'CUSTORDERCLOSETIME'
 		   AND TRIM(BASEDESCR) IS NOT NULL
        GROUP BY DATA1
        ORDER BY DATA1 ASC
    </select>
</mapper>