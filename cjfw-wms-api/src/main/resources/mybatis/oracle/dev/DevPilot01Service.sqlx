<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="devPilot01Service">

    <select id="getSkuDcSetList" resultType="cjfw.wms.dev.dto.DevPilot01ResDto">     
        SELECT  /* [MsSkuDcSetService.sqlx][getSkuDcSetList][센터상품속성 목록 조회][sunho.kim][2025.05.23] */
               MS_SKUDCSET.DCCODE                        AS DCCODE         /* 센터코드 */
              ,MS_SKUDCSET.STORERKEY                     AS STORERKEY      /* 고객사 */
              ,MS_SKUDCSET.SKU                           AS SKU            /* 상품코드 */
              ,MS_SKU.DESCRIPTION                        AS SKU_DESCR
              ,MS_SKUDCSET.CROSSDOCKTYPE                 AS CROSSDOCKTYPE  /**크로스도킹*/
              ,MS_SKUDCSET.PUTAWAYTYPE                   AS PUTAWAYTYPE
              ,MS_SKUDCSET.WHAREA                        AS WHAREA         /* 기본보관창고동 */
              ,MS_SKUDCSET.WHAREAFLOOR                   AS WHAREAFLOOR    /* 기본보관창고층 */
              ,MS_SKUDCSET.LOCCATEGORY                   AS LOCCATEGORY    /* 기본보관로케이션유형 */
              ,MS_SKUDCSET.LOCLEVEL                      AS LOCLEVEL       /* 기본보관로케이션층 */
              ,MS_SKUDCSET.ZONE                          AS ZONE           /* 기본보관존 */
              ,MS_SKUDCSET.LOC                           AS LOC            /* 기본보관장소 */
              ,MS_SKUDCSET.ABC                           AS ABC
              ,MS_SKUDCSET.MINPOQTY                      AS MINPOQTY
              ,MS_SKUDCSET.TARGETPOQTY                   AS TARGETPOQTY
              ,MS_SKUDCSET.EFFECTIVEDATE                 AS EFFECTIVEDATE
              ,MS_SKUDCSET.OTHER01                       AS OTHER01
              ,MS_SKUDCSET.OTHER02                       AS OTHER02
              ,MS_SKUDCSET.OTHER03                       AS OTHER03
              ,MS_SKUDCSET.OTHER04                       AS OTHER04
              ,MS_SKUDCSET.OTHER05                       AS OTHER05
              ,MS_SKUDCSET.STATUS                        AS STATUS          /* 상태 */
              ,MS_SKUDCSET.SMS_YN                        AS SMS_YN          /* SMS처리대상여부 */     
              ,MS_SKUDCSET.DEL_YN                        AS DEL_YN          /* 삭제여부 */
              ,MS_SKUDCSET.INVOICE_CRT_TYPE              AS INVOICE_CRT_TYPE/*배송분류표 생성유형*/
              ,MS_SKUDCSET.SERIALKEY                     AS SERIALKEY       /* 데이터번호 */
              ,MS_SKUDCSET.CUBE_YN                       AS CUBE_YN         /* 고부피여부 */
              ,MS_SKUDCSET.CP_YN                         AS CP_YN           /* 쿠팡라벨여부 */
              ,TO_CHAR(MS_SKUDCSET.ADDDATE, 'yyyy-mm-dd hh24:mi:ss')  AS ADDDATE  /* 최초등록시간 */
              ,TO_CHAR(MS_SKUDCSET.EDITDATE, 'yyyy-mm-dd hh24:mi:ss') AS EDITDATE /* 최종변경시간 */
              ,MS_SKUDCSET.ADDWHO                        AS ADDWHO         /* 최초등록자 */
              ,MS_SKUDCSET.EDITWHO                       AS EDITWHO        /* 최종변경자 */
          FROM MS_SKUDCSET
          JOIN MS_SKU
            ON (
                MS_SKUDCSET.SKU       = MS_SKU.SKU
           AND  MS_SKUDCSET.STORERKEY = MS_SKU.STORERKEY
               )             
          JOIN CM_USER_AUTHORITY_DCXSTORER  
            ON (
                CM_USER_AUTHORITY_DCXSTORER.USERID = #{userId}
            <if test="dccode != null and dccode != ''"> 
                AND CM_USER_AUTHORITY_DCXSTORER.DCCODE      = #{dccode}             
            </if> 
            <if test="storerkey != null and storerkey != ''"> 
                AND CM_USER_AUTHORITY_DCXSTORER.STORERKEY   = #{storerkey} 
            </if>
                AND CM_USER_AUTHORITY_DCXSTORER.DCCODE      = MS_SKUDCSET.DCCODE
                AND CM_USER_AUTHORITY_DCXSTORER.STORERKEY   = MS_SKUDCSET.STORERKEY
                )
            WHERE  1=1
            <if test="dccode != null and dccode != ''">    
                AND MS_SKUDCSET.DCCODE                   LIKE #{dccode} || '%'       
            </if>
            <!-- 상품 다중선택 -->
            <if test="multiSku != null and multiSku != ''">
                AND MS_SKUDCSET.SKU IN (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
                                         FROM (SELECT #{multiSku} AS VAL FROM DUAL) A
                                         CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)                
            </if>
    </select>
    
    <select id="getSkuDcSetDtl" resultType="cjfw.wms.dev.dto.DevPilot01ResDto">
        SELECT  /* [MsSkuDcSetService.sqlx][getSkuDcSetDtl][센터상품속성 단건 조회][sunho.kim][2025.05.23] */
               MS_SKUDCSET.SERIALKEY                     AS SERIALKEY   /* 데이터번호 */
              ,MS_SKUDCSET.DCCODE                        AS DCCODE      /* 센터코드 */
              ,MS_SKUDCSET.STORERKEY                     AS STORERKEY   /* 고객사 */
              ,MS_SKUDCSET.SKU                           AS SKU         /* 상품코드 */
              ,MS_SKU.DESCRIPTION                        AS SKU_DESCR   /* 상품명 */ 
              ,MS_SKUDCSET.PUTAWAYTYPE                   AS PUTAWAYTYPE /* 적치유형 */
              ,MS_SKUDCSET.WHAREA                        AS WHAREA      /* 기본보관창고동 */
              ,MS_SKUDCSET.WHAREAFLOOR                   AS WHAREAFLOOR /* 기본보관창고층 */
              ,MS_SKUDCSET.LOCCATEGORY                   AS LOCCATEGORY /* 기본보관로케이션유형 */
              ,MS_SKUDCSET.LOCLEVEL                      AS LOCLEVEL    /* 기본보관로케이션층 */
              ,MS_SKUDCSET.ZONE                          AS ZONE        /* 기본보관존 */
              ,MS_SKUDCSET.LOC                           AS LOC         /* 기본보관장소 */
              ,MS_SKUDCSET.ABC                           AS ABC
              ,MS_SKUDCSET.MINPOQTY                      AS MINPOQTY
              ,MS_SKUDCSET.TARGETPOQTY                   AS TARGETPOQTY
              ,MS_SKUDCSET.EFFECTIVEDATE                 AS EFFECTIVEDATE
              ,MS_SKUDCSET.OTHER01                       AS OTHER01
              ,MS_SKUDCSET.OTHER02                       AS OTHER02
              ,MS_SKUDCSET.OTHER03                       AS OTHER03
              ,MS_SKUDCSET.OTHER04                       AS OTHER04
              ,MS_SKUDCSET.OTHER05                       AS OTHER05
              ,MS_SKUDCSET.STATUS                        AS STATUS      /* 상태 */
              ,MS_SKUDCSET.DEL_YN                        AS DEL_YN      /* 삭제여부 */
              ,TO_CHAR(MS_SKUDCSET.ADDDATE, 'yyyy-mm-dd hh24:mi:ss')  AS ADDDATE  /* 최초등록시간 */
              ,TO_CHAR(MS_SKUDCSET.EDITDATE, 'yyyy-mm-dd hh24:mi:ss') AS EDITDATE /* 최종변경시간 */
              ,MS_SKUDCSET.ADDWHO                        AS ADDWHO       /* 최초등록자 */
              ,MS_SKUDCSET.EDITWHO                       AS EDITWHO      /* 최종변경자 */
              ,NVL(MS_SKUDCSET.CROSSDOCKTYPE,'STD')      AS CROSSDOCKTYPE
              ,MS_SKUDCSET.SMS_YN                        AS SMS_YN      /* SMS처리대상여부 */
              ,MS_SKUDCSET.CP_YN                         AS CP_YN       /* 쿠폰 여부 */
              ,MS_SKUDCSET.INVOICE_CRT_TYPE              AS INVOICE_CRT_TYPE /*배송분류표 생성유형*/
              ,MS_SKUDCSET.CUBE_YN
        FROM   MS_SKUDCSET
   LEFT JOIN MS_SKU
          ON (
             MS_SKUDCSET.SKU       = MS_SKU.SKU
         AND MS_SKUDCSET.STORERKEY = MS_SKU.STORERKEY
             )
        WHERE  MS_SKUDCSET.DCCODE    = #{dccode}
        AND    MS_SKUDCSET.STORERKEY = #{storerkey}
        AND    MS_SKUDCSET.SKU       = #{sku}    
    </select>    
    
    <select id="getSelectDC" resultType="cjfw.wms.dev.dto.DevPilot01ResDto">
        SELECT    /* [MsSkuDcSetService.sqlx][getSelectPlant][센터 리스트 조회][sunho.kim][2025.05.22] */  
                DCCODE                             AS DCCODE
               ,'['||DCCODE||']'||DCNAME           AS DCNAME
        
        FROM CM_DC        
        WHERE DEL_YN = 'N'
        ORDER BY DCCODE    
    </select>   
    
    <insert id="insert">
        INSERT  /* [MsSkuDcSetService.sqlx][insert][상품기본적치 기준정보 INSERT][sunho.kim][2025.05.22] */
            INTO MS_SKUDCSET
              (DCCODE
              ,STORERKEY
              ,SKU
              ,PUTAWAYTYPE
              ,WHAREA
              ,WHAREAFLOOR
              ,LOCCATEGORY
              ,LOCLEVEL
              ,ZONE
              ,LOC
              ,ABC
              ,MINPOQTY
              ,TARGETPOQTY
              ,EFFECTIVEDATE
              ,OTHER01
              ,OTHER02
              ,OTHER03
              ,OTHER04
              ,OTHER05    
              ,STATUS
              ,ADDDATE
              ,EDITDATE
              ,ADDWHO
              ,EDITWHO
              ,CROSSDOCKTYPE
              ,SMS_YN
              ,INVOICE_CRT_TYPE
              ,CUBE_YN
              ,CP_YN
              )
            VALUES
              (#{dccode}                        /* 센터코드 */
              ,#{storerkey}                     /* 고객사 */
              ,#{sku}                           /* 상품코드 */
              ,#{putawaytype}                   /* 적치유형 */
              ,nvl(#{wharea},'STD')             /* 기본보관창고동 */
              ,nvl(#{whareafloor},1)            /* 기본보관창고층 */
              ,nvl(#{loccategory},'STD')        /* 기본보관로케이션유형 */
              ,nvl(#{loclevel},'STD')           /* 기본보관로케이션층 */
              ,nvl(#{zone},'STD')               /* 기본보관존 */
              ,nvl(trim(#{loc}),'STD')          /* 기본보관장소 */
              ,nvl(trim(#{abc}),'B')            /* ABC */
              ,#{minpoqty}                      /* 최소재고량 */
              ,#{targetpoqty}                   /* 목표재고량 */
              ,#{effectivedate}                 /* 적용일자 */
              ,#{other01}
              ,#{other02}
              ,#{other03}
              ,#{other04}
              ,#{other05}
              ,#{status}                         /* 상태 */
              ,SYSDATE                           /* 최초등록시간 */
              ,SYSDATE                           /* 최종변경시간 */
              ,#{userId}                         /* 최초등록자 */
              ,#{userId}                         /* 최종변경자 */
              ,nvl(#{crossdocktype},'STD')       /* 크로스도킹타입 */   
              ,nvl(#{smsYn},'N')                 /* 소터사용여부*/  
              ,#{invoiceCrtType}                 /* 배송분류표생성유형 */
              ,#{cubeYn}                         /*  */
              ,#{cpYn}                           /*  */
              )          
    </insert>
    
    <update id="update">
        UPDATE  /* [MsSkuDcSetService.sqlx][update][상품기본적치 기준정보 update][sunho.kim][2025.05.22] */
            MS_SKUDCSET
        SET DCCODE           = #{dccode}          /* 센터코드 */
           ,STORERKEY        = #{storerkey}       /* 고객사 */
           ,SKU              = #{sku}             /* 상품코드 */
           ,PUTAWAYTYPE      = #{putawaytype}     /* 적치유형 */
           ,WHAREA           = #{wharea}          /* 기본보관창고동 */
           ,WHAREAFLOOR      = #{whareafloor}     /* 기본보관창고층 */
           ,LOCCATEGORY      = #{loccategory}     /* 기본보관로케이션유형 */
           ,LOCLEVEL         = #{loclevel}        /* 기본보관로케이션층 */
           ,ZONE             = #{zone}            /* 기본보관존 */
           ,LOC              = #{loc}             /* 기본보관장소 */
           ,ABC              = #{abc}             /* ABC */
           ,CROSSDOCKTYPE    = #{crossdocktype}   /* 크로스도킹타입*/
           ,MINPOQTY         = #{minpoqty}        /* 최소재고량 */
           ,TARGETPOQTY      = #{targetpoqty}     /* 목표재고량 */
           ,EFFECTIVEDATE    = #{effectivedate}   /* 적용일자 */
           ,OTHER01          = #{other01}
           ,OTHER02          = #{other02}
           ,OTHER03          = #{other03}
           ,OTHER04          = #{other04}
           ,OTHER05          = #{other05}
           ,STATUS           = #{status}          /* 상태 */
           ,DEL_YN           = #{delYn}           /* 삭제여부 */
           ,EDITDATE         = SYSDATE            /* 최종변경시간 */
           ,EDITWHO          = #{userId}          /* 최종변경자 */
           ,SMS_YN           = nvl(#{smsYn},'N')  /* 소터사용여부*/ 
           ,INVOICE_CRT_TYPE = #{invoiceCrtType}  /* 배송분류표생성유형 */
           ,CUBE_YN          = #{cubeYn}          /*  */      
           ,CP_YN            = #{cpYn}            /*  */
        WHERE SERIALKEY      = #{serialkey}
    </update>
  
</mapper>