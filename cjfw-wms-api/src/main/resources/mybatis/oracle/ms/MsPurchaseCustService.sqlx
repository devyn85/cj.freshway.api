	</insert>
	
	<select id="getExcelUploadList" resultType="MsPurchaseCustResDto">
	    SELECT OM_FILECONVERT.SERIALKEY    AS SERIALKEY
	          ,OM_FILECONVERT.FILETYPE
	          ,OM_FILECONVERT.BATCHNO
	          ,OM_FILECONVERT.FILELINENO
	          ,OM_FILECONVERT.DCCODE       AS G_DCCODE            
	          ,OM_FILECONVERT.STORERKEY    AS STORERKEY         
	          ,OM_FILECONVERT.ORGANIZE     AS ORGANIZE          
	          ,OM_FILECONVERT.DATA_VALUE01 AS PURCHASETYPE      
	          ,OM_FILECONVERT.DATA_VALUE02 AS DELIVERYTYPE      
	          ,OM_FILECONVERT.DATA_VALUE03 AS DCCODE
	          ,OM_FILECONVERT.DATA_VALUE04 AS SKU               
	          ,OM_FILECONVERT.DATA_VALUE05 AS SKUNAME           
	          ,OM_FILECONVERT.DATA_VALUE06 AS PLANT     
	          ,''                          AS PLANT_DESCR        
	          ,OM_FILECONVERT.DATA_VALUE07 AS CONTROLTYPE       
	          ,OM_FILECONVERT.DATA_VALUE08 AS FROMDATE          
	          ,OM_FILECONVERT.DATA_VALUE09 AS TODATE            
	          ,OM_FILECONVERT.DATA_VALUE10 AS STORAGETYPENM 
	          ,OM_FILECONVERT.DATA_VALUE11 AS CUSTTYPENM          
	          ,OM_FILECONVERT.DATA_VALUE12 AS CUSTKEY           
	          ,OM_FILECONVERT.DATA_VALUE13 AS CUSTNAME          
	          ,OM_FILECONVERT.DATA_VALUE14 AS BUYERKEY          
	          ,OM_FILECONVERT.DATA_VALUE15 AS BUYERKEYNM        
	          ,OM_FILECONVERT.DATA_VALUE16 AS PURCHASEGROUP     
	          ,OM_FILECONVERT.DATA_VALUE17 AS MINORDERQTY       
	          ,OM_FILECONVERT.DATA_VALUE18 AS ORDERQTY_UNIT
	          ,OM_FILECONVERT.DATA_VALUE19 AS QTYPERBOX
	          ,OM_FILECONVERT.DATA_VALUE20 AS UOM
	          ,OM_FILECONVERT.DATA_VALUE21 AS LAYERPERPLT
	          ,OM_FILECONVERT.DATA_VALUE22 AS BOXPERLAYER
	          ,OM_FILECONVERT.DATA_VALUE23 AS COEFFICIENTSAFETY
	          ,OM_FILECONVERT.DATA_VALUE24 AS LEADTIME
	          ,OM_FILECONVERT.DATA_VALUE25 AS PURINTERVAL
	          ,OM_FILECONVERT.DATA_VALUE26 AS EDIT_REORDERPOINT
	          ,OM_FILECONVERT.DATA_VALUE27 AS EDIT_STOCKGOAL
	          ,OM_FILECONVERT.DATA_VALUE28 AS REFERENCE04
	          ,OM_FILECONVERT.DATA_VALUE29 AS MON_YN
	          ,OM_FILECONVERT.DATA_VALUE30 AS TUE_YN
	          ,OM_FILECONVERT.DATA_VALUE31 AS WED_YN
	          ,OM_FILECONVERT.DATA_VALUE32 AS THU_YN
	          ,OM_FILECONVERT.DATA_VALUE33 AS FRI_YN
	          ,OM_FILECONVERT.DATA_VALUE34 AS SAT_YN
	          ,OM_FILECONVERT.DATA_VALUE35 AS SUN_YN
	          ,OM_FILECONVERT.DATA_VALUE36 AS RETURNTYPE
	          ,OM_FILECONVERT.DATA_VALUE37 AS REFERENCE01
	          ,OM_FILECONVERT.DATA_VALUE38 AS REFERENCE02
	          ,OM_FILECONVERT.DATA_VALUE39 AS REFERENCE03
	          ,OM_FILECONVERT.DATA_VALUE40 AS REFERENCE06
	          ,OM_FILECONVERT.DATA_VALUE41 AS ROUTE
	          ,OM_FILECONVERT.DATA_VALUE42 AS ROUTEORGANIZE
	          ,OM_FILECONVERT.DATA_VALUE43 AS CHANNEL
	          ,OM_FILECONVERT.DATA_VALUE44 AS SERIALYN
	          ,OM_FILECONVERT.DATA_VALUE45 AS LINE01
	          ,OM_FILECONVERT.DATA_VALUE46 AS REFERENCE05
	          ,OM_FILECONVERT.DATA_VALUE47 AS MOQ_VENDER
	          ,OM_FILECONVERT.DATA_VALUE48 AS EXHAUSTION_STOP_YN
	          ,OM_FILECONVERT.DATA_VALUE49 AS REFERENCE07
	          ,OM_FILECONVERT.ERRCODE      AS PROCESS_YN
	          ,OM_FILECONVERT.ERRMSG       AS PROCESS_MSG
	    FROM OM_FILECONVERT
	    WHERE OM_FILECONVERT.DATA_INDEX01 = 'PURCHASECUST_UPLOAD'  
	      AND OM_FILECONVERT.DATA_INDEX02 = #{gUserId}      
	      AND OM_FILECONVERT.DATA_INDEX03 = #{gSpid}         
	    ORDER BY OM_FILECONVERT.FILELINENO
	</select>
	<insert id="insertCmDtlCode">
		INSERT	/* [CmCodeService.sqlx][insertCmDtlCode][상세 코드 저장][][2026.02.03] */ INTO CM_CODE
		(
             STORERKEY
			,CODELIST
			,SEQNO
			,BASECODE
			,BASEDESCR
			,CONVCODE
			,CONVDESCR
			,DATA1
			,DATA2
			,DATA3
			,DATA4
			,STATUS
			,DEL_YN
			,ADDWHO
			,EDITWHO
        )
        VALUES
        (
             #{storerkey}
			,#{codelist}
			,(SELECT NVL(MAX(SEQNO), 0) + 1 
          FROM CM_CODE 
          WHERE STORERKEY = #{storerkey} 
            AND CODELIST = #{codelist})
			,#{basecode}
			,#{basedescr}
			,#{convcode}
			,#{convdescr}
			,#{data1}
			,#{data2}
			,#{data3}
			,#{data4}
			,#{status}
			,#{delYn}
			,#{addwho}
			,#{addwho}
        )
	</insert>
	
	<update id="updateCmDtlCode">
        UPDATE /* [CmCodeService.sqlx][updateCmDtlCode][상세 코드 수정][][2026.02.03] */ CM_CODE
		SET		
			 SEQNO      = #{seqno}
			,BASECODE   = #{basecode}
			,BASEDESCR  = #{basedescr}
			,CONVCODE   = #{convcode}
			,CONVDESCR  = #{convdescr}
			,DATA1      = #{data1}
			,DATA2      = #{data2}
			,DATA3      = #{data3}
			,DATA4      = #{data4}
			,STATUS     = #{status}
			,DEL_YN     = #{delYn}
			,EDITDATE   = SYSDATE
			,EDITWHO    = #{addwho}
		WHERE SERIALKEY = #{serialkey}
     </update>
</mapper>