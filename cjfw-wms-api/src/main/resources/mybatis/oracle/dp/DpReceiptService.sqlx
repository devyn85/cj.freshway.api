<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="dpReceiptService">
    <!-- 입고확정 헤더  -->
    <select id="getMasterList" resultType="cjfw.wms.dp.dto.DpReceiptResDto">
        SELECT
            /* [dpReceiptService.sqlx][dpReceiptService.getDataHeaderList][입고확정처리] */
            '0' AS CHECKYN,
            DP_INPLAN.DCCODE AS DCCODE,
            DP_INPLAN.STORERKEY AS STORERKEY,
            DP_INPLAN.DOCDT AS DOCDT,
            DP_INPLAN.DOCNO AS DOCNO,
            DP_INPLAN.DOCTYPE AS DOCTYPE,
            DP_INPLAN.SLIPDT AS SLIPDT,
            DP_INPLAN.SLIPNO AS SLIPNO,
            CASE WHEN MAX(DM_DOCUMENT_D.CHANNEL) = '3' THEN CASE WHEN (SELECT MAX(ROUTE)   
                                                                         FROM DM_DOCUMENT_D Z
                                                                        WHERE Z.POKEY  = DP_INPLAN.SLIPNO
                                                                          AND Z.DCCODE = DP_INPLAN.DCCODE
                                                                          AND Z.DELIVERYDATE=DP_INPLAN.SLIPDT  -- 2) ■ 2026.01.19 조인조건 추가
                                                                          AND Z.DOCTYPE ='WD' ) IS NULL THEN
                                                                    NULL
                                                                ELSE
                                                                    (SELECT '[' ||  X.ROUTE || ']' || CM_DC.DCNAME
                                                                      FROM  (SELECT MAX(ROUTE) ROUTE
                                                                               FROM DM_DOCUMENT_D Z
                                                                              WHERE Z.POKEY  = DP_INPLAN.SLIPNO
                                                                                AND Z.DCCODE = DP_INPLAN.DCCODE
                                                                                AND Z.DELIVERYDATE=DP_INPLAN.SLIPDT -- 3) ■ 2026.01.19 조인조건 추가
                                                                                AND Z.DOCTYPE ='WD' ) X 
                                                                     JOIN CM_DC
                                                                     ON   CM_DC.DCCODE = X.ROUTE
                                                                     AND  CM_DC.DEL_YN = 'N')
                                                            END 
                  ELSE '' END   AS ROUTE,
            MAX(DM_DOCUMENT_H.POTYPE) AS POTYPE,
            MAX((SELECT FN_CODEDESCR(DM_DOCUMENT_H.STORERKEY, 'POTYPE_DP', DM_DOCUMENT_H.POTYPE) FROM DUAL)) AS POTYPENAME,
            MAX(DM_DOCUMENT_H.ORGANIZE) AS ORGANIZE,
            MAX((SELECT fn_descr_organize(DM_DOCUMENT_H.DCCODE, DM_DOCUMENT_H.ORGANIZE) FROM DUAL)) AS ORGANIZENAME,
            MAX(DM_DOCUMENT_H.ORDERTYPE) AS ORDERTYPE,
            MAX((SELECT FN_CODEDESCR(DM_DOCUMENT_H.STORERKEY, 'ORDERTYPE_DP', DM_DOCUMENT_H.ORDERTYPE) FROM DUAL)) AS ORDERTYPE_NAME,
            MIN(DM_DOCUMENT_D.STATUS) AS STATUS,
            FN_CODEDESCR(MIN(DM_DOCUMENT_D.STORERKEY), 'STATUS_DP', MIN(DM_DOCUMENT_D.STATUS)) AS STATUSNAME,
            MAX(DM_DOCUMENT_H.FROM_CUSTKEY) AS FROM_CUSTKEY,
            MAX(DM_DOCUMENT_H.FROM_CUSTNAME) AS FROM_CUSTNAME,
            '[' || MAX(DM_DOCUMENT_D.PLANT) || ']' || FN_DESCR_PLANT(MAX(DM_DOCUMENT_D.PLANT)) AS PLANT,
            MAX(DM_DOCUMENT_D.WORKPROCESSCODE) AS WORKPROCESSCODE,
            MAX(DM_DOCUMENT_D.CHANNEL) AS CHANNEL,
            CASE WHEN (SELECT count(*)
                      FROM OM_SDY_REGN_REPL_D
                      WHERE OM_SDY_REGN_REPL_D.DOCNO = DP_INPLAN.DOCNO) > 0 THEN '주문STO'
                ELSE FN_CODEDESCR(MAX(DM_DOCUMENT_H.STORERKEY), 'CREATIONTYPE_STO', MAX(DM_DOCUMENT_H.SOTYPE))
            END AS STOTYPE <!-- 센터간이체시 선택된 STO유형 -->
            ,CASE WHEN sum(FN_UOMCAL  ( DM_DOCUMENT_D_WD.BUNMO, DM_DOCUMENT_D_WD.BUNJA, DM_DOCUMENT_D_WD.CONFIRMQTY + DM_DOCUMENT_D_WD.CANCELQTY )) - sum(FN_UOMCAL(DM_DOCUMENT_D.BUNMO, DM_DOCUMENT_D.BUNJA, DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY)) = 0
            	THEN 'Y'
            	ELSE 'N'
        	END AS STO_DP_YN
        FROM DM_DOCUMENT_D
        JOIN DM_DOCUMENT_H
            ON DM_DOCUMENT_D.DCCODE = DM_DOCUMENT_H.DCCODE
            AND DM_DOCUMENT_D.DOCTYPE = DM_DOCUMENT_H.DOCTYPE
            AND DM_DOCUMENT_D.DELIVERYDATE = DM_DOCUMENT_H.DELIVERYDATE
            AND DM_DOCUMENT_D.DOCNO = DM_DOCUMENT_H.DOCNO
            AND DM_DOCUMENT_H.DEL_YN = 'N'
            <!-- 배송그룹 공통조회 조건 -->
            <if test="gMultiCourier != null and gMultiCourier != ''">
                AND DM_DOCUMENT_H.COURIER = #{gMultiCourier}
            </if>
            <!-- 협력사 다중선택 -->
            <if test="fromCustkeyMulti != null and fromCustkeyMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="fromCustkeyMulti" item="item">
                        OR DM_DOCUMENT_H.FROM_CUSTKEY IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
        JOIN DP_INPLAN
            ON DP_INPLAN.DCCODE = DM_DOCUMENT_D.DCCODE
            AND DP_INPLAN.DOCTYPE = DM_DOCUMENT_D.DOCTYPE
            AND DP_INPLAN.SLIPDT = DM_DOCUMENT_D.DELIVERYDATE
            AND DP_INPLAN.DOCNO = DM_DOCUMENT_D.DOCNO
            AND DP_INPLAN.DOCLINE = DM_DOCUMENT_D.DOCLINE
            AND DP_INPLAN.DEL_YN = 'N'
            <!-- 상품 다중선택 -->
            <if test="skuMulti != null and skuMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="skuMulti" item="item">
                        OR DP_INPLAN.SKU IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
        LEFT JOIN DM_DOCUMENT_D DM_DOCUMENT_D_WD
            ON    DM_DOCUMENT_D_WD.DOCNO          = DP_INPLAN.DOCNO
            AND   DM_DOCUMENT_D_WD.DOCLINE        = DP_INPLAN.DOCLINE
            AND   DM_DOCUMENT_D_WD.DELIVERYDATE   = DP_INPLAN.SLIPDT  -- 4) ■ 2026.01.19 조인조건 추가
            AND   DM_DOCUMENT_D_WD.DOCTYPE        = 'WD'
            AND   DM_DOCUMENT_D_WD.WORKPROCESSCODE = 'STO'
        JOIN MS_SKU
            ON MS_SKU.STORERKEY = DM_DOCUMENT_D.STORERKEY
            AND MS_SKU.SKU = DM_DOCUMENT_D.SKU
            AND MS_SKU.SERIALYN = 'N'
            <if test="storagetype != null and storagetype != ''">
                AND MS_SKU.STORAGETYPE LIKE #{storagetype}
            </if>
        LEFT OUTER JOIN MS_SKUDCSET
            ON MS_SKUDCSET.STORERKEY = DM_DOCUMENT_D.STORERKEY
            AND MS_SKUDCSET.DCCODE = DM_DOCUMENT_D.DCCODE
            AND MS_SKUDCSET.SKU = DM_DOCUMENT_D.SKU
        WHERE 1 = 1
            <!-- START.권한센터 -->
            AND EXISTS (SELECT 1
                          FROM CM_USER_AUTHORITY
                         WHERE CM_USER_AUTHORITY.DCCODE = DM_DOCUMENT_D.DCCODE
                        AND CM_USER_AUTHORITY.STORERKEY = DM_DOCUMENT_D.STORERKEY
                        AND CM_USER_AUTHORITY.ORGANIZE = DM_DOCUMENT_D.ORGANIZE
                        AND CM_USER_AUTHORITY.AREA = DM_DOCUMENT_D.AREA
                           AND CM_USER_AUTHORITY.STORERKEY = #{gStorerkey}
                           AND CM_USER_AUTHORITY.USERID    = #{gUserId}
                           AND CM_USER_AUTHORITY.DCCODE    = #{fixdccode}
                           AND CM_USER_AUTHORITY.AREA      = #{gArea}
                            AND CM_USER_AUTHORITY.ORGANIZE  = #{fixdccode}
                       )
            <!-- END.권한센터	-->
            AND DM_DOCUMENT_D.DCCODE NOT IN (
                SELECT BASECODE
                FROM CM_CODE WMS_MNG_DC
                WHERE WMS_MNG_DC.STORERKEY = 'FW00'
                    AND WMS_MNG_DC.CODELIST = 'WMS_MNG_DC'
                    AND WMS_MNG_DC.DATA3 = 'Y'
            )
            AND DM_DOCUMENT_D.DOCTYPE = 'DP'
            AND DM_DOCUMENT_D.DEL_YN = 'N'
            <if test="status != null and status != ''">
                AND DM_DOCUMENT_D.STATUS LIKE #{status}
            </if>
            <if test="channel != null and channel != ''">
                AND DM_DOCUMENT_D.CHANNEL LIKE #{channel}
            </if>
            <if test="docdtFrom != null and docdtFrom != ''">
                AND DM_DOCUMENT_D.DOCDT <![CDATA[>=]]> #{docdtFrom}
            </if>
            <if test="docdtTo != null and docdtTo != ''">
                AND DM_DOCUMENT_D.DOCDT <![CDATA[<=]]> #{docdtTo}
            </if>
            <if test="slipdtFrom != null and slipdtFrom != ''">
<!--                AND DM_DOCUMENT_D.DOCDT <![CDATA[>=]]> #{slipdtFrom}-->
                AND DM_DOCUMENT_D.deliverydate <![CDATA[>=]]> #{slipdtFrom}
            </if>
            <if test="slipdtTo != null and slipdtTo != ''">
<!--                AND DM_DOCUMENT_D.DOCDT <![CDATA[<=]]> #{slipdtTo}-->
                AND DM_DOCUMENT_D.deliverydate <![CDATA[<=]]> #{slipdtTo}
            </if>
            <!-- 문서번호 다중선택 -->
            <if test="docnoMulti != null and docnoMulti != ''">
                AND DM_DOCUMENT_D.DOCNO IN
                <foreach collection="docnoMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            <if test="ordertypeMulti != null and ordertypeMulti != ''">
                AND DM_DOCUMENT_D.ORDERTYPE IN
                <foreach collection="ordertypeMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            <if test='crossyn == "Y"'>
                AND MS_SKUDCSET.CROSSDOCKTYPE = 'CROSS'
            </if>
        GROUP BY 
            DP_INPLAN.DCCODE,
            DP_INPLAN.STORERKEY,
            DP_INPLAN.DOCDT,
            DP_INPLAN.DOCNO,
            DP_INPLAN.DOCTYPE,
            DP_INPLAN.SLIPDT,
            DP_INPLAN.SLIPNO
        ORDER BY
            ORDERTYPE,
            POTYPE,
            FROM_CUSTKEY,
            DOCNO,
            DP_INPLAN.SLIPDT,
            DP_INPLAN.SLIPNO
    </select>

    <!-- 입고확정처리 상세 -->
    <select id="getDetailList" resultType="cjfw.wms.dp.dto.DpReceiptResDetailDto">
        WITH T_DP_INSPECT AS (
            SELECT 
                DP_INSPECT.DCCODE AS DCCODE,
                DP_INSPECT.STORERKEY AS STORERKEY,
                DP_INSPECT.ORGANIZE AS ORGANIZE,
                DP_INSPECT.AREA AS AREA,
                DP_INSPECT.DOCDT AS DOCDT,
                DP_INSPECT.DOCNO AS DOCNO,
                DP_INSPECT.DOCLINE AS DOCLINE,
                DP_INSPECT.DOCTYPE AS DOCTYPE,
                DP_INSPECT.SLIPDT AS SLIPDT,
                DP_INSPECT.SLIPNO AS SLIPNO,
                DP_INSPECT.SLIPLINE AS SLIPLINE,
                DP_INSPECT.SLIPTYPE AS SLIPTYPE,
                DP_INSPECT.SKU AS SKU,
                DP_INSPECT.LOTTABLE01 AS LOTTABLE01,
                DP_INSPECT.STOCKID AS STOCKID,
                DP_INSPECT.STOCKGRADE AS STOCKGRADE,
                SUM(DP_INSPECT.INSPECTQTY) AS INSPECTQTY,
                SUM(DP_INSPECT.CONFIRMQTY) AS CONFIRMQTY,
                DP_INSPECT.TOLOC AS TOLOC
            FROM DP_INSPECT
            WHERE 1 = 1
                <if test="fixdccode != null and fixdccode != ''">
                    AND DP_INSPECT.DCCODE = #{fixdccode}
                    AND DP_INSPECT.ORGANIZE = #{fixdccode}
                </if>
                <if test="gStorerkey != null and gStorerkey != ''">
                    AND DP_INSPECT.STORERKEY = #{gStorerkey}
                </if>
                <if test="gArea != null and gArea != ''">
                    AND DP_INSPECT.AREA = #{gArea}
                </if>
                AND DP_INSPECT.DCCODE = #{dccode}
                AND DP_INSPECT.STORERKEY = #{storerkey}
                AND DP_INSPECT.SLIPDT = #{slipdt}
                AND DP_INSPECT.SLIPNO = #{slipno}
                AND DP_INSPECT.OPENQTY > 0
                AND DP_INSPECT.INSPECTQTY > 0
            GROUP BY 
                DP_INSPECT.DCCODE,
                DP_INSPECT.STORERKEY,
                DP_INSPECT.ORGANIZE,
                DP_INSPECT.AREA,
                DP_INSPECT.DOCDT,
                DP_INSPECT.DOCNO,
                DP_INSPECT.DOCLINE,
                DP_INSPECT.DOCTYPE,
                DP_INSPECT.SLIPDT,
                DP_INSPECT.SLIPNO,
                DP_INSPECT.SLIPLINE,
                DP_INSPECT.SLIPTYPE,
                DP_INSPECT.SKU,
                DP_INSPECT.LOTTABLE01,
                DP_INSPECT.STOCKID,
                DP_INSPECT.STOCKGRADE,
                DP_INSPECT.TOLOC
        ),
        T_DP_EXCPT_SKU AS (
        	SELECT
	        	SLIPNO,
		        DELIVERYDATE,
		        SKU,
		        EXCPT_YN,
		        DRAFT_NO,
		        EDITWHO,
		        SLIPLINE_SEQ
		    FROM (
		        SELECT
	        	SLIPNO,
		            DELIVERYDATE,
		            SKU,
		            EXCPT_YN,
		            DRAFT_NO,
		            EDITWHO,
		            SLIPLINE_SEQ,
		            ROW_NUMBER() OVER (
		                PARTITION BY DELIVERYDATE, SKU
		                ORDER BY EDITDATE DESC
		            ) AS RN
		        FROM DP_EXCPT_SKU
<!--		        WHERE EXCPT_YN = 'Y'-->
		    )
		    WHERE RN = 1
        )
        SELECT
            /* [dpReceiptService.sqlx][dpReceiptService.getDataDetailList][입고확정처리 문서 Detail정보] */
            '0' AS CHECKYN,
            DP_INPLAN.DCCODE AS DCCODE,
            DP_INPLAN.STORERKEY AS STORERKEY,
            DP_INPLAN.ORGANIZE AS ORGANIZE,
            DP_INPLAN.DOCDT AS DOCDT,
            DP_INPLAN.DOCNO AS DOCNO,
            DP_INPLAN.DOCLINE AS DOCLINE,
            DP_INPLAN.SLIPDT AS SLIPDT,
            DP_INPLAN.SLIPNO AS SLIPNO,
            DP_INPLAN.SLIPLINE AS SLIPLINE,
            DP_INPLAN.SKU AS SKU,
            MS_SKU.DESCRIPTION AS SKUNAME,
            '[' || MS_SKU.COUNTRYOFORIGIN || ']' || (
                SELECT BASEDESCR
                FROM CM_CODE
                WHERE CM_CODE.STORERKEY = MS_SKU.STORERKEY
                    AND CM_CODE.CODELIST = 'COUNTRY'
                    AND CM_CODE.BASECODE = MS_SKU.COUNTRYOFORIGIN
                    AND CM_CODE.DEL_YN = 'N'
            ) AS COUNTRYOFORIGIN,
            DM_DOCUMENT_D.STORERUOM AS UOM,
            DM_DOCUMENT_D.BUNJA AS BUNJA,
            DM_DOCUMENT_D.BUNMO AS BUNMO,
            FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY, DM_DOCUMENT_D.SKU, DM_DOCUMENT_D.STORERUOM, 'EA', DP_INPLAN.OPENQTY) AS OPENQTY_EA,
            CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY, DM_DOCUMENT_D.SKU, DM_DOCUMENT_D.STORERUOM, 'BOX', DP_INPLAN.OPENQTY)) AS OPENQTY_BOX,
            DECODE(MS_SKU.BOXPERPLT, 0, 0, CEIL(CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY, DM_DOCUMENT_D.SKU, DM_DOCUMENT_D.STORERUOM, 'BOX', DP_INPLAN.OPENQTY)) / MS_SKU.BOXPERPLT)) AS PLTQTY,
            FN_UOMCAL(DM_DOCUMENT_D.BUNMO, DM_DOCUMENT_D.BUNJA, DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY) AS ORDERQTY,
            ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU, DP_INPLAN.UOM, 'KG', DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY), 2) AS ORDERWEIGHT,
            ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU, DP_INPLAN.UOM, 'KG', DP_INPLAN.CONFIRMQTY), 2) AS CONFIRMWEIGHT,
            FN_UOMCAL(DM_DOCUMENT_D.BUNMO, DM_DOCUMENT_D.BUNJA, NVL(T_DP_INSPECT.INSPECTQTY, DP_INPLAN.INSPECTQTY)) AS INSPECTQTY,
            FN_UOMCAL(DM_DOCUMENT_D.BUNMO, DM_DOCUMENT_D.BUNJA, NVL(T_DP_INSPECT.CONFIRMQTY, DP_INPLAN.CONFIRMQTY)) AS CONFIRMQTY,
            FN_UOMCAL(DM_DOCUMENT_D.BUNMO, DM_DOCUMENT_D.BUNJA, DP_INPLAN.CANCELQTY) AS SHORTAGEQTY,
            0 AS SHORTAGETRANQTY,
            0 AS TRANQTY,
            MS_SKUDCSET.LOC AS LOC,
            NVL(T_DP_INSPECT.TOLOC, SPDP_RECEIPT.FN_GETTOLOC(DP_INPLAN.DCCODE, DP_INPLAN.STORERKEY, DP_INPLAN.SKU, DM_DOCUMENT_D.PLANT, DM_DOCUMENT_D.STORAGELOC, DM_DOCUMENT_D.CHANNEL)) AS TOLOC,
            NVL(T_DP_INSPECT.LOTTABLE01, DP_INPLAN.LOTTABLE01) AS LOTTABLE01
           --
           --,NVL(CASE WHEN MS_SKU.DURATIONTYPE = '1' AND REGEXP_LIKE(NVL(T_DP_INSPECT.LOTTABLE01, DP_INPLAN.LOTTABLE01), '^[0-9]{8}$')
           -- THEN TO_CHAR(TO_DATE(NVL(T_DP_INSPECT.LOTTABLE01, DP_INPLAN.LOTTABLE01),'YYYYMMDD') - (MS_SKU.DURATION - 1), 'YYYYMMDD')
           -- ELSE NVL(T_DP_INSPECT.LOTTABLE01, DP_INPLAN.LOTTABLE01)
           -- END,'STD') AS LOT_MANUFACTURE                    /** 제조 */
           -- , NVL(CASE WHEN MS_SKU.DURATIONTYPE != '1' AND REGEXP_LIKE(NVL(T_DP_INSPECT.LOTTABLE01, DP_INPLAN.LOTTABLE01), '^[0-9]{8}$')
           -- THEN TO_CHAR(TO_DATE(NVL(T_DP_INSPECT.LOTTABLE01, DP_INPLAN.LOTTABLE01),'YYYYMMDD') + (MS_SKU.DURATION - 1), 'YYYYMMDD')
           -- ELSE NVL(T_DP_INSPECT.LOTTABLE01, DP_INPLAN.LOTTABLE01)
           -- END,'STD') AS LOT_EXPIRE                         /** 유통 */
            --
            ,LOGISONESVC.FN_LOTTABLE_INFO('1',DP_INPLAN.STORERKEY,NVL(T_DP_INSPECT.LOTTABLE01, DP_INPLAN.LOTTABLE01),MS_SKU.DURATIONTYPE,MS_SKU.DURATION,'') AS LOT_MANUFACTURE /*제조일자*/
            ,LOGISONESVC.FN_LOTTABLE_INFO('2',DP_INPLAN.STORERKEY,NVL(T_DP_INSPECT.LOTTABLE01, DP_INPLAN.LOTTABLE01),MS_SKU.DURATIONTYPE,MS_SKU.DURATION,'') AS LOT_EXPIRE      /*소비일자*/
            --
            ,FN_LOTDURATION(DP_INPLAN.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, NVL(T_DP_INSPECT.LOTTABLE01, DP_INPLAN.LOTTABLE01), 'N') || '/' || MS_SKU.DURATION AS DURATION_TERM,
            MS_SKU.COLORDESCR AS COLORDESCR,
            DM_DOCUMENT_D.REFERENCE02 AS REFERENCE02,
            DP_INPLAN.REASONCODE AS REASONCODE,
            DP_INPLAN.REASONMSG AS REASONMSG,
            CASE 
                WHEN NVL(T_DP_INSPECT.LOTTABLE01, DP_INPLAN.LOTTABLE01) = 'STD' THEN 'N'
                WHEN MONTHS_BETWEEN(TO_DATE(NVL(T_DP_INSPECT.LOTTABLE01, DP_INPLAN.LOTTABLE01), 'yyyy-mm-dd'), SYSDATE) > 3 THEN 'N' 
                ELSE 'Y' 
            END AS NEARDURATIONYN,
            DM_DOCUMENT_D.STATUS AS STATUS,
            FN_CODEDESCR(DM_DOCUMENT_D.STORERKEY, 'STATUS_DP', DM_DOCUMENT_D.STATUS) AS STATUSNAME,
            MS_SKU.QTYPERBOX AS QTYPERBOX,
            DM_DOCUMENT_D.CHANNEL AS CHANNEL,
            0 AS DURATION_RATE,
            MS_SKU.DURATION AS DURATION,
            MS_SKU.DURATIONTYPE AS DURATIONTYPE,
            UNISTR('') AS LASTLOTTABLE01,
            NVL(T_DP_INSPECT.STOCKID, DP_INPLAN.STOCKID) AS STOCKID,
            NVL(T_DP_INSPECT.STOCKGRADE, DP_INPLAN.STOCKGRADE) AS STOCKGRADE,
            DECODE(SPDP_RECEIPT.FN_GETTOLOC(DP_INPLAN.DCCODE, DP_INPLAN.STORERKEY, DP_INPLAN.SKU, DM_DOCUMENT_D.PLANT, DM_DOCUMENT_D.STORAGELOC, DM_DOCUMENT_D.CHANNEL), 'CROSS', 'CROSS', 'STAGE') AS CROSSLOC,
            DM_DOCUMENT_D.PLANT AS PLANT,
            '[' || DM_DOCUMENT_D.PLANT || ']' || fn_descr_plant(DM_DOCUMENT_D.PLANT) AS PLANT_DESCR,
            FN_CODEDESCR(DP_INPLAN.STORERKEY, 'PUTAWAYTYPE', DM_DOCUMENT_D.CHANNEL) AS CHANNEL_NAME,
            MS_SKU.STORAGETYPE AS STORAGETYPE,
            FN_CODEDESCR(MS_SKU.STORERKEY, 'STORAGETYPE', MS_SKU.STORAGETYPE) AS STORAGETYPENAME
            <if test='workprocesscode == "STO"'>
                ,FN_UOMCAL(DM_DOCUMENT_D_WD.BUNMO, DM_DOCUMENT_D_WD.BUNJA, DM_DOCUMENT_D_WD.INSPECTQTY) AS INSPECTQTY_WD
                ,FN_UOMCAL(DM_DOCUMENT_D_WD.BUNMO, DM_DOCUMENT_D_WD.BUNJA, DM_DOCUMENT_D_WD.CONFIRMQTY) AS CONFIRMQTY_WD
                ,FN_UOMCAL(DM_DOCUMENT_D_WD.BUNMO, DM_DOCUMENT_D_WD.BUNJA, DM_DOCUMENT_D_WD.CANCELQTY) AS SHORTAGEQTY_WD
                ,1 AS STO_FLAG
            </if>
            <if test='workprocesscode != "STO"'>
                ,0 AS INSPECTQTY_WD
                ,0 AS CONFIRMQTY_WD
                ,0 AS SHORTAGEQTY_WD
                ,0 AS STO_FLAG
            </if>
            ,CASE WHEN MS_DC_PLT_LOAD.BOXPERLAYER IS NOT NULL AND MS_DC_PLT_LOAD.LAYERPERPLT IS NOT NULL
                THEN MS_DC_PLT_LOAD.BOXPERLAYER * MS_DC_PLT_LOAD.LAYERPERPLT
                ELSE MS_SKUCHAIN.BOXPERPLT
            END AS BOXPERPLT
            ,MS_DC_PLT_LOAD.BOXPERLAYER AS BOXPERLAYER /** 방수 */
            ,MS_DC_PLT_LOAD.LAYERPERPLT AS LAYERPERPLT /** 단수 */
            , DP_EXCPT_SKU.EXCPT_YN AS EXCPT_YN  /** 입고예외여부 */
            , DP_EXCPT_SKU.EXCPT_YN AS EXCPT_YN_ORI  /** 입고예외여부 */
            , DP_EXCPT_SKU.DRAFT_NO AS DRAFT_NO  /** 기안번호 */
            , DP_EXCPT_SKU.SLIPLINE_SEQ AS SLIPLINE_SEQ  /** SEQ */
            , DP_EXCPT_SKU.EDITWHO AS EDITWHO  /** 최종변경자 */
            , FRAMEONE_USER.USER_NM AS EDITWHO_NAME /** 예외입력자 이름 */
            , OM_STO_DP_RETURN.STO_DOCNO AS RESTONO /** 역STO 번호 */
            , OM_STO_DP_RETURN.RETURNQTY AS RESTOQTY /** 역STO 수량 */
        FROM DP_INPLAN
        JOIN CM_USER_AUTHORITY
            ON CM_USER_AUTHORITY.USERID = #{gUserId}
            AND CM_USER_AUTHORITY.DCCODE = DP_INPLAN.DCCODE
            AND CM_USER_AUTHORITY.STORERKEY = DP_INPLAN.STORERKEY
            AND CM_USER_AUTHORITY.ORGANIZE = DP_INPLAN.ORGANIZE
            AND CM_USER_AUTHORITY.AREA = DP_INPLAN.AREA
            <if test="fixdccode != null and fixdccode != ''">
                AND CM_USER_AUTHORITY.DCCODE = #{fixdccode}
                AND CM_USER_AUTHORITY.ORGANIZE = #{fixdccode}
            </if>
            <if test="gStorerkey != null and gStorerkey != ''">
                AND CM_USER_AUTHORITY.STORERKEY = #{gStorerkey}
            </if>
            <if test="gArea != null and gArea != ''">
                AND CM_USER_AUTHORITY.AREA = #{gArea}
            </if>
        JOIN DM_DOCUMENT_H
            ON DM_DOCUMENT_H.DCCODE = DP_INPLAN.DCCODE
            AND DM_DOCUMENT_H.STORERKEY = DP_INPLAN.STORERKEY
            AND DM_DOCUMENT_H.DELIVERYDATE = DP_INPLAN.SLIPDT
            AND DM_DOCUMENT_H.DOCTYPE = DP_INPLAN.DOCTYPE
            AND DM_DOCUMENT_H.DOCNO = DP_INPLAN.DOCNO
            AND DM_DOCUMENT_H.DOCTYPE = 'DP'
            AND DM_DOCUMENT_H.DEL_YN = 'N'
            <!-- 협력사 다중선택 -->
            <if test="fromCustkeyMulti != null and fromCustkeyMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="fromCustkeyMulti" item="item">
                        OR DM_DOCUMENT_H.FROM_CUSTKEY IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
        JOIN DM_DOCUMENT_D
            ON DM_DOCUMENT_D.DCCODE = DP_INPLAN.DCCODE
            AND DM_DOCUMENT_D.STORERKEY = DP_INPLAN.STORERKEY
            AND DM_DOCUMENT_D.DOCTYPE = DP_INPLAN.DOCTYPE
            AND DM_DOCUMENT_D.DELIVERYDATE = DP_INPLAN.SLIPDT
            AND DM_DOCUMENT_D.DOCNO = DP_INPLAN.DOCNO
            AND DM_DOCUMENT_D.DOCLINE = DP_INPLAN.DOCLINE
            AND DM_DOCUMENT_D.CHANNEL IN ('1', '2', '3')   <!-- 저장품만 처리함 1.저장 2.일배 3.광역일배 2015.01.26 SLLEE MODIFY [ 1,2] 김해경님 요청 -->
            <if test="channel != null and channel != ''">
                AND DM_DOCUMENT_D.CHANNEL LIKE #{channel}
            </if>
            AND DM_DOCUMENT_D.DEL_YN = 'N'
            <if test='workprocesscode == "STO"'>
                JOIN DM_DOCUMENT_D DM_DOCUMENT_D_WD
                    ON DM_DOCUMENT_D_WD.DOCNO = DP_INPLAN.DOCNO
                    AND DM_DOCUMENT_D_WD.DOCLINE = DP_INPLAN.DOCLINE
                    AND DM_DOCUMENT_D_WD.DOCTYPE = 'WD'
                    AND DM_DOCUMENT_D_WD.WORKPROCESSCODE = 'STO'
            </if>
        JOIN MS_SKU
            ON MS_SKU.STORERKEY = DP_INPLAN.STORERKEY
            AND MS_SKU.SKU = DP_INPLAN.SKU
            AND MS_SKU.SERIALYN = 'N'
            <if test="storagetype != null and storagetype != ''">
                AND MS_SKU.STORAGETYPE LIKE #{storagetype}
            </if>
        LEFT OUTER JOIN MS_SKUDCSET
            ON MS_SKUDCSET.DCCODE = DP_INPLAN.DCCODE
            AND MS_SKUDCSET.STORERKEY = DP_INPLAN.STORERKEY
            AND MS_SKUDCSET.SKU = DP_INPLAN.SKU
        LEFT OUTER JOIN T_DP_INSPECT
            ON T_DP_INSPECT.DCCODE = DP_INPLAN.DCCODE
            AND T_DP_INSPECT.STORERKEY = DP_INPLAN.STORERKEY
            AND T_DP_INSPECT.ORGANIZE = DP_INPLAN.ORGANIZE
            AND T_DP_INSPECT.AREA = DP_INPLAN.AREA
            AND T_DP_INSPECT.SLIPDT = DP_INPLAN.SLIPDT
            AND T_DP_INSPECT.DOCNO = DP_INPLAN.DOCNO
            AND T_DP_INSPECT.DOCLINE = DP_INPLAN.DOCLINE
            AND T_DP_INSPECT.DOCTYPE = DP_INPLAN.DOCTYPE
            AND T_DP_INSPECT.SLIPDT = DP_INPLAN.SLIPDT
            AND T_DP_INSPECT.SLIPNO = DP_INPLAN.SLIPNO
            AND T_DP_INSPECT.SLIPLINE = DP_INPLAN.SLIPLINE
            AND T_DP_INSPECT.SLIPTYPE = DP_INPLAN.SLIPTYPE
            AND T_DP_INSPECT.SKU = DP_INPLAN.SKU
        LEFT OUTER JOIN MS_SKUCHAIN
            ON MS_SKUCHAIN.SKU = DP_INPLAN.SKU
            AND MS_SKUCHAIN.STORERKEY = DP_INPLAN.STORERKEY
            AND MS_SKUCHAIN.DEL_YN = 'N'
        LEFT OUTER JOIN MS_DC_PLT_LOAD
            ON MS_DC_PLT_LOAD.DCCODE = DP_INPLAN.DCCODE
            AND MS_DC_PLT_LOAD.PLANT = DM_DOCUMENT_D.PLANT
            AND MS_DC_PLT_LOAD.STORERKEY = DP_INPLAN.STORERKEY
            AND MS_DC_PLT_LOAD.SKU = DP_INPLAN.SKU
            AND MS_DC_PLT_LOAD.CUSTKEY = DP_INPLAN.CUSTKEY
        LEFT JOIN T_DP_EXCPT_SKU DP_EXCPT_SKU
        	ON DP_EXCPT_SKU.SKU = DP_INPLAN.SKU
        	AND DP_EXCPT_SKU.DELIVERYDATE = DP_INPLAN.SLIPDT
        	AND DP_EXCPT_SKU.SLIPNO = DP_INPLAN.SLIPNO
        LEFT JOIN FRAMEONE_USER
            ON FRAMEONE_USER.USER_ID = DP_EXCPT_SKU.EDITWHO
        LEFT JOIN OM_STO_DP_RETURN
            ON OM_STO_DP_RETURN.FROM_DCCODE = DP_INPLAN.DCCODE
            AND OM_STO_DP_RETURN.DOCNO = DP_INPLAN.DOCNO
            AND OM_STO_DP_RETURN.DOCLINE = DP_INPLAN.DOCLINE
        WHERE DP_INPLAN.DCCODE = #{dccode}
            AND DP_INPLAN.STORERKEY = #{storerkey}
            AND DP_INPLAN.SLIPDT = #{slipdt}
            AND DP_INPLAN.SLIPNO = #{slipno}
            <!-- 상품 다중선택 -->
            <if test="skuMulti != null and skuMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="skuMulti" item="item">
                        OR DP_INPLAN.SKU IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
            <!-- 문서번호 다중선택 -->
            <if test="docnoMulti != null and docnoMulti != ''">
                AND DP_INPLAN.DOCNO IN
                <foreach collection="docnoMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            <if test="ordertypeMulti != null and ordertypeMulti != ''">
                AND DP_INPLAN.ORDERTYPE IN
                <foreach collection="ordertypeMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            <if test='crossyn == "Y"'>
                AND MS_SKUDCSET.CROSSDOCKTYPE = 'CROSS'
            </if>
<!--            AND DP_INPLAN.ORDERQTY <![CDATA[>]]> 0 /** 결품으로만 확정완료된건은 안보이게 하기위해서 */-->
        ORDER BY CASE
                    WHEN REGEXP_LIKE(DP_INPLAN.SLIPLINE, '^\d+$')
                    THEN LPAD(DP_INPLAN.SLIPLINE, 20, '0')
                    ELSE DP_INPLAN.SLIPLINE
                  END, DP_INPLAN.SKU
    </select>

    <!-- 입고확정처리 엑셀 -->
    <select id="getExcelList" resultType="cjfw.wms.dp.dto.DpReceiptResExcelDto">
        WITH T_DP_INSPECT AS(
            SELECT DP_INSPECT.DCCODE AS DCCODE
                ,DP_INSPECT.STORERKEY AS STORERKEY
                ,DP_INSPECT.ORGANIZE AS ORGANIZE
                ,DP_INSPECT.AREA AS AREA
                ,DP_INSPECT.DOCDT AS DOCDT
                ,DP_INSPECT.DOCNO AS DOCNO
                ,DP_INSPECT.DOCLINE AS DOCLINE
                ,DP_INSPECT.DOCTYPE AS DOCTYPE
                ,DP_INSPECT.SLIPDT AS SLIPDT
                ,DP_INSPECT.SLIPNO AS SLIPNO
                ,DP_INSPECT.SLIPLINE AS SLIPLINE
                ,DP_INSPECT.SLIPTYPE AS SLIPTYPE
                ,DP_INSPECT.SKU AS SKU
                ,DP_INSPECT.LOTTABLE01 AS LOTTABLE01
                ,DP_INSPECT.STOCKID AS STOCKID
                ,DP_INSPECT.STOCKGRADE AS STOCKGRADE
                ,SUM(DP_INSPECT.INSPECTQTY) AS INSPECTQTY
                ,SUM(DP_INSPECT.CONFIRMQTY) AS CONFIRMQTY
                ,DP_INSPECT.TOLOC AS TOLOC
            FROM DP_INSPECT
            WHERE 1 = 1
                <if test="fixdccode != null and fixdccode != ''">
                    AND DP_INSPECT.DCCODE = #{fixdccode}
                    AND DP_INSPECT.ORGANIZE = #{fixdccode}
                </if>
                <if test="gStorerkey != null and gStorerkey != ''">AND DP_INSPECT.STORERKEY = #{gStorerkey}</if>
                <if test="gArea != null and gArea != ''">AND DP_INSPECT.AREA = #{gArea}</if>
                AND DP_INSPECT.SLIPDT     <![CDATA[>=]]> #{slipdtFrom}
                AND DP_INSPECT.SLIPDT     <![CDATA[<=]]> #{slipdtTo}
                AND DP_INSPECT.OPENQTY > 0
                AND DP_INSPECT.INSPECTQTY > 0
            GROUP BY DP_INSPECT.DCCODE
                ,DP_INSPECT.STORERKEY
                ,DP_INSPECT.ORGANIZE
                ,DP_INSPECT.AREA
                ,DP_INSPECT.DOCDT
                ,DP_INSPECT.DOCNO
                ,DP_INSPECT.DOCLINE
                ,DP_INSPECT.DOCTYPE
                ,DP_INSPECT.SLIPDT
                ,DP_INSPECT.SLIPNO
                ,DP_INSPECT.SLIPLINE
                ,DP_INSPECT.SLIPTYPE
                ,DP_INSPECT.SKU
                ,DP_INSPECT.LOTTABLE01
                ,DP_INSPECT.STOCKID
                ,DP_INSPECT.STOCKGRADE
                ,DP_INSPECT.TOLOC
        )
        SELECT /* [dpReceiptService.sqlx][dpReceiptService.getDataExcelList][입고확정처리 엑셀] */
            DP_INPLAN.DCCODE AS DCCODE
            ,DP_INPLAN.STORERKEY AS STORERKEY
            ,DP_INPLAN.ORGANIZE AS ORGANIZE
            ,DP_INPLAN.DOCDT AS DOCDT
            ,DP_INPLAN.DOCNO AS DOCNO
            ,DP_INPLAN.DOCLINE AS DOCLINE
            ,DP_INPLAN.SLIPDT AS SLIPDT
            ,DP_INPLAN.SLIPNO AS SLIPNO
            ,DP_INPLAN.SLIPLINE AS SLIPLINE
            ,DM_DOCUMENT_H.POTYPE AS POTYPE
            ,FN_CODEDESCR(DM_DOCUMENT_H.STORERKEY
            ,'POTYPE_DP'
            ,DM_DOCUMENT_H.POTYPE) AS POTYPENAME
            ,fn_descr_organize(DM_DOCUMENT_H.DCCODE, DM_DOCUMENT_H.ORGANIZE) AS ORGANIZENAME
            ,DM_DOCUMENT_H.ORDERTYPE AS ORDERTYPE
            ,FN_CODEDESCR(DM_DOCUMENT_H.STORERKEY
            ,'ORDERTYPE_DP'
            ,DM_DOCUMENT_H.ORDERTYPE) AS ORDERTYPE_NAME
            ,DM_DOCUMENT_H.FROM_CUSTKEY AS FROM_CUSTKEY
            ,DM_DOCUMENT_H.FROM_CUSTNAME AS FROM_CUSTNAME
            ,DP_INPLAN.SKU AS SKU
            ,MS_SKU.DESCRIPTION AS SKUNAME
            ,'[' || MS_SKU.COUNTRYOFORIGIN || ']' ||
            (SELECT BASEDESCR
            FROM CM_CODE
            WHERE CM_CODE.STORERKEY = MS_SKU.STORERKEY
            AND CM_CODE.CODELIST = 'COUNTRY'
            AND CM_CODE.BASECODE = MS_SKU.COUNTRYOFORIGIN
            AND CM_CODE.DEL_YN = 'N') AS COUNTRYOFORIGIN
            ,DM_DOCUMENT_D.STORERUOM AS UOM
            ,DM_DOCUMENT_D.BUNJA AS BUNJA
            ,DM_DOCUMENT_D.BUNMO AS BUNMO
            ,FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'EA',DP_INPLAN.OPENQTY) AS OPENQTY_EA
            ,CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY)) AS OPENQTY_BOX
            ,DECODE(MS_SKU.BOXPERPLT,0,0,CEIL(CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY)) /
            MS_SKU.BOXPERPLT)) AS PLTQTY
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY ) AS ORDERQTY
            ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU , DP_INPLAN.UOM, 'KG',DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY),2) AS ORDERWEIGHT
            ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU, DP_INPLAN.UOM, 'KG', DP_INPLAN.CONFIRMQTY), 2) AS CONFIRMWEIGHT
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,NVL(T_DP_INSPECT.INSPECTQTY, DP_INPLAN.INSPECTQTY) ) AS INSPECTQTY
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,NVL(T_DP_INSPECT.CONFIRMQTY, DP_INPLAN.CONFIRMQTY) ) AS CONFIRMQTY
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.CANCELQTY ) AS SHORTAGEQTY
            ,0 AS SHORTAGETRANQTY
            ,0 AS TRANQTY
            ,MS_SKUDCSET.LOC AS LOC
            ,NVL(T_DP_INSPECT.TOLOC,
            SPDP_RECEIPT.FN_GETTOLOC(DP_INPLAN.DCCODE,
            DP_INPLAN.STORERKEY,
            DP_INPLAN.SKU,
            DM_DOCUMENT_D.PLANT,
            DM_DOCUMENT_D.STORAGELOC,
            DM_DOCUMENT_D.CHANNEL)) AS TOLOC
            ,NVL(T_DP_INSPECT.LOTTABLE01, DP_INPLAN.LOTTABLE01) AS LOTTABLE01
            ,FN_LOTDURATION(DP_INPLAN.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, NVL(T_DP_INSPECT.LOTTABLE01, DP_INPLAN.LOTTABLE01), 'N')||'/'||MS_SKU.DURATION AS DURATION_TERM
            ,MS_SKU.COLORDESCR AS COLORDESCR
            ,DM_DOCUMENT_D.REFERENCE02 AS REFERENCE02
            ,DM_DOCUMENT_D.REASONCODE AS REASONCODE
            ,DM_DOCUMENT_D.REASONMSG AS REASONMSG
            ,CASE WHEN NVL(T_DP_INSPECT.LOTTABLE01,DP_INPLAN.LOTTABLE01)='STD' THEN 'N'
            WHEN MONTHS_BETWEEN(TO_DATE(NVL(T_DP_INSPECT.LOTTABLE01, DP_INPLAN.LOTTABLE01),'yyyy-mm-dd'),SYSDATE)>3 THEN 'N' ELSE 'Y' END AS NEARDURATIONYN
            ,DM_DOCUMENT_D.STATUS AS STATUS
            ,FN_CODEDESCR(DM_DOCUMENT_D.STORERKEY,'STATUS_DP', DM_DOCUMENT_D.STATUS) AS STATUSNAME
            ,MS_SKU.QTYPERBOX AS QTYPERBOX
            ,DM_DOCUMENT_D.CHANNEL AS CHANNEL
            ,MS_SKU.DURATION AS DURATION
            ,MS_SKU.DURATIONTYPE AS DURATIONTYPE
            ,UNISTR('') AS LASTLOTTABLE01
            ,NVL(T_DP_INSPECT.STOCKID, DP_INPLAN.STOCKID) AS STOCKID
            ,NVL(T_DP_INSPECT.STOCKGRADE, DP_INPLAN.STOCKGRADE) AS STOCKGRADE
            ,DM_DOCUMENT_D.PLANT AS PLANT
            ,'['||DM_DOCUMENT_D.PLANT||']'||fn_descr_plant(DM_DOCUMENT_D.PLANT) AS PLANT_DESCR
            ,FN_CODEDESCR(DP_INPLAN.STORERKEY,'PUTAWAYTYPE', DM_DOCUMENT_D.CHANNEL) AS CHANNEL_NAME
            ,FN_CODEDESCR(MS_SKU.STORERKEY,'STORAGETYPE', MS_SKU.STORAGETYPE) AS STORAGETYPENAME
            , NVL(CASE WHEN MS_SKU.DURATIONTYPE = '1' AND REGEXP_LIKE(T_DP_INSPECT.LOTTABLE01, '^[0-9]{8}$')
                       THEN TO_CHAR(TO_DATE(T_DP_INSPECT.LOTTABLE01,'YYYYMMDD') - (MS_SKU.DURATION - 1), 'YYYYMMDD')
                       ELSE T_DP_INSPECT.LOTTABLE01 END,'STD')                                                                                         AS MANUFACTUREDT   /* 기준일(제조) */
            , NVL(CASE WHEN MS_SKU.DURATIONTYPE != '1' AND REGEXP_LIKE(T_DP_INSPECT.LOTTABLE01, '^[0-9]{8}$')                                                              
                       THEN TO_CHAR(TO_DATE(T_DP_INSPECT.LOTTABLE01,'YYYYMMDD') + (MS_SKU.DURATION - 1), 'YYYYMMDD')
                       ELSE T_DP_INSPECT.LOTTABLE01 END,'STD')                                                                                         AS EXPIREDT        /* 기준일(소비) */		            
        FROM DM_DOCUMENT_D
        JOIN CM_USER_AUTHORITY
            ON CM_USER_AUTHORITY.USERID = #{gUserId}
            AND CM_USER_AUTHORITY.DCCODE = DM_DOCUMENT_D.DCCODE
            AND CM_USER_AUTHORITY.STORERKEY = DM_DOCUMENT_D.STORERKEY
            AND CM_USER_AUTHORITY.ORGANIZE = DM_DOCUMENT_D.ORGANIZE
            AND CM_USER_AUTHORITY.AREA = DM_DOCUMENT_D.AREA
            <if test="fixdccode != null and fixdccode != ''">
                AND CM_USER_AUTHORITY.DCCODE = #{fixdccode}
                AND CM_USER_AUTHORITY.ORGANIZE = #{fixdccode}
            </if>
            <if test="gStorerkey != null and gStorerkey != ''">AND CM_USER_AUTHORITY.STORERKEY = #{gStorerkey}</if>
            <if test="gArea != null and gArea != ''">AND CM_USER_AUTHORITY.AREA = #{gArea}</if>
        JOIN DM_DOCUMENT_H
            ON DM_DOCUMENT_D.DCCODE = DM_DOCUMENT_H.DCCODE
            AND DM_DOCUMENT_D.DOCTYPE = DM_DOCUMENT_H.DOCTYPE
            AND DM_DOCUMENT_D.DELIVERYDATE = DM_DOCUMENT_H.DELIVERYDATE
            AND DM_DOCUMENT_D.DOCNO = DM_DOCUMENT_H.DOCNO
            AND DM_DOCUMENT_H.DEL_YN = 'N'
            <!-- 협력사 다중선택 -->
            <if test="fromCustkeyMulti != null and fromCustkeyMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="fromCustkeyMulti" item="item">
                        OR DM_DOCUMENT_H.FROM_CUSTKEY IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
        JOIN DP_INPLAN
            ON DP_INPLAN.DCCODE = DM_DOCUMENT_D.DCCODE
            AND DP_INPLAN.DOCTYPE = DM_DOCUMENT_D.DOCTYPE
            AND DP_INPLAN.SLIPDT = DM_DOCUMENT_D.DELIVERYDATE
            AND DP_INPLAN.DOCNO = DM_DOCUMENT_D.DOCNO
            AND DP_INPLAN.DOCLINE = DM_DOCUMENT_D.DOCLINE
            AND DP_INPLAN.DEL_YN = 'N'
            <!-- 상품 다중선택 -->
            <if test="skuMulti != null and skuMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="skuMulti" item="item">
                        OR DP_INPLAN.SKU IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
        JOIN MS_SKU
            ON MS_SKU.STORERKEY = DM_DOCUMENT_D.STORERKEY
            AND MS_SKU.SKU = DM_DOCUMENT_D.SKU
            <if test="storagetype != null and storagetype != ''">AND MS_SKU.STORAGETYPE LIKE #{storagetype}</if>
        LEFT OUTER JOIN MS_SKUDCSET
            ON MS_SKUDCSET.DCCODE = DM_DOCUMENT_D.DCCODE
            AND MS_SKUDCSET.STORERKEY = DM_DOCUMENT_D.STORERKEY
            AND MS_SKUDCSET.SKU = DM_DOCUMENT_D.SKU
        LEFT OUTER JOIN T_DP_INSPECT
            ON T_DP_INSPECT.DCCODE = DP_INPLAN.DCCODE
            AND T_DP_INSPECT.STORERKEY = DP_INPLAN.STORERKEY
            AND T_DP_INSPECT.ORGANIZE = DP_INPLAN.ORGANIZE
            AND T_DP_INSPECT.AREA = DP_INPLAN.AREA
            AND T_DP_INSPECT.SLIPDT = DP_INPLAN.SLIPDT
            AND T_DP_INSPECT.DOCNO = DP_INPLAN.DOCNO
            AND T_DP_INSPECT.DOCLINE = DP_INPLAN.DOCLINE
            AND T_DP_INSPECT.DOCTYPE = DP_INPLAN.DOCTYPE
            AND T_DP_INSPECT.SLIPDT = DP_INPLAN.SLIPDT
            AND T_DP_INSPECT.SLIPNO = DP_INPLAN.SLIPNO
            AND T_DP_INSPECT.SLIPLINE = DP_INPLAN.SLIPLINE
            AND T_DP_INSPECT.SLIPTYPE = DP_INPLAN.SLIPTYPE
            AND T_DP_INSPECT.SKU = DP_INPLAN.SKU
        WHERE 1=1
            AND DM_DOCUMENT_D.DCCODE = #{fixdccode}
            AND DM_DOCUMENT_D.DOCTYPE = 'DP'
            AND DM_DOCUMENT_D.DEL_YN = 'N'
            <if test="status != null and status != ''">AND DM_DOCUMENT_D.STATUS LIKE #{status}</if>
            <if test="channel != null and channel != ''">AND DM_DOCUMENT_D.CHANNEL LIKE #{channel}</if>
            <if test="docdtFrom != null and docdtFrom != ''">AND DM_DOCUMENT_D.DOCDT    <![CDATA[>=]]> #{docdtFrom}</if>
            <if test="docdtTo != null and docdtTo != ''">AND DM_DOCUMENT_D.DOCDT    <![CDATA[<=]]> #{docdtTo}</if>
            <if test="slipdtFrom != null and slipdtFrom != ''">AND DM_DOCUMENT_D.deliverydate   <![CDATA[>=]]> #{slipdtFrom}</if>
            <if test="slipdtTo != null and slipdtTo != ''">AND DM_DOCUMENT_D.deliverydate   <![CDATA[<=]]> #{slipdtTo}</if>
            <!-- 문서번호 다중선택 -->
            <if test="docnoMulti != null and docnoMulti != ''">
                AND DM_DOCUMENT_D.DOCNO IN
                <foreach collection="docnoMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            <if test="ordertypeMulti != null and ordertypeMulti != ''">
                AND DM_DOCUMENT_D.ORDERTYPE IN
                <foreach collection="ordertypeMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            <if test='crossyn == "Y"'>
                    AND MS_SKUDCSET.CROSSDOCKTYPE = 'CROSS'
            </if>
        ORDER BY DM_DOCUMENT_H.ORDERTYPE
            ,DM_DOCUMENT_H.POTYPE
            ,DM_DOCUMENT_H.FROM_CUSTKEY
            ,DM_DOCUMENT_H.DOCNO
            ,DP_INPLAN.SLIPDT
            ,DP_INPLAN.SLIPNO
            ,DP_INPLAN.SLIPLINE
            ,DP_INPLAN.SKU
    </select>
    <!-- 입고확정 이력상품 헤더  -->
    <select id="getMasterList2" resultType="cjfw.wms.dp.dto.DpReceiptResDto">
        WITH /* [dpReceiptService.sqlx][dpReceiptService.getMasterList2][입고확정처리-이력상품 목록 조회] */
        T_DP_INPLAN AS (
        SELECT
            DP_INPLAN.DCCODE AS DCCODE
            ,DP_INPLAN.STORERKEY AS STORERKEY
            ,DP_INPLAN.DOCDT AS DOCDT
            ,DP_INPLAN.DOCNO AS DOCNO
            ,DP_INPLAN.DOCTYPE AS DOCTYPE
            ,DP_INPLAN.SLIPDT AS SLIPDT
            ,DP_INPLAN.SLIPNO AS SLIPNO
            ,MIN(DM_DOCUMENT_D.STATUS) AS STATUS
            ,MAX(DM_DOCUMENT_D.PLANT) AS PLANT
            ,MAX(DM_DOCUMENT_D.WORKPROCESSCODE) AS WORKPROCESSCODE
            ,MAX(DM_DOCUMENT_D.CHANNEL) AS CHANNEL
            ,CASE WHEN sum(FN_UOMCAL  ( DM_DOCUMENT_D_WD.BUNMO, DM_DOCUMENT_D_WD.BUNJA, DM_DOCUMENT_D_WD.CONFIRMQTY + DM_DOCUMENT_D_WD.CANCELQTY )) - sum(FN_UOMCAL(DM_DOCUMENT_D.BUNMO, DM_DOCUMENT_D.BUNJA, DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY)) = 0
            	THEN 'Y'
            	ELSE 'N'
        	END AS STO_DP_YN
        FROM DM_DOCUMENT_D
        JOIN DM_DOCUMENT_H
            ON DM_DOCUMENT_D.DCCODE = DM_DOCUMENT_H.DCCODE
            AND DM_DOCUMENT_D.DOCTYPE = DM_DOCUMENT_H.DOCTYPE
            AND DM_DOCUMENT_D.DELIVERYDATE = DM_DOCUMENT_H.DELIVERYDATE
            AND DM_DOCUMENT_D.DOCNO = DM_DOCUMENT_H.DOCNO
            AND DM_DOCUMENT_H.DEL_YN = 'N'
            <!-- 배송그룹 공통조회 조건 -->
            <if test="gMultiCourier != null and gMultiCourier != ''">AND DM_DOCUMENT_H.COURIER = #{gMultiCourier}</if>
            <!-- 협력사 다중선택 -->
            <if test="fromCustkeyMulti != null and fromCustkeyMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="fromCustkeyMulti" item="item">
                        OR DM_DOCUMENT_H.FROM_CUSTKEY IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
        JOIN DP_INPLAN
            ON DP_INPLAN.DCCODE = DM_DOCUMENT_D.DCCODE
            AND DP_INPLAN.DOCTYPE = DM_DOCUMENT_D.DOCTYPE
            AND DP_INPLAN.SLIPDT = DM_DOCUMENT_D.DELIVERYDATE
            AND DP_INPLAN.DOCNO = DM_DOCUMENT_D.DOCNO
            AND DP_INPLAN.DOCLINE = DM_DOCUMENT_D.DOCLINE
            AND DP_INPLAN.DEL_YN = 'N'
        LEFT JOIN DM_DOCUMENT_D DM_DOCUMENT_D_WD
            ON    DM_DOCUMENT_D_WD.DOCNO          = DP_INPLAN.DOCNO
            AND   DM_DOCUMENT_D_WD.DOCLINE        = DP_INPLAN.DOCLINE
            AND   DM_DOCUMENT_D_WD.DOCTYPE        = 'WD'
            AND   DM_DOCUMENT_D_WD.WORKPROCESSCODE = 'STO'
        JOIN MS_SKU
            ON MS_SKU.STORERKEY = DM_DOCUMENT_D.STORERKEY
            AND MS_SKU.SKU = DM_DOCUMENT_D.SKU
            AND MS_SKU.SERIALYN = DECODE(DM_DOCUMENT_D.DCCODE,'2170',MS_SKU.SERIALYN,'Y')             <!-- 이력상품만 조회 되도록 -->
            <if test="storagetype != null and storagetype != ''">AND MS_SKU.STORAGETYPE LIKE #{storagetype}</if>
        LEFT OUTER JOIN MS_SKUDCSET
            ON MS_SKUDCSET.STORERKEY = DM_DOCUMENT_D.STORERKEY
            AND MS_SKUDCSET.DCCODE = DM_DOCUMENT_D.DCCODE
            AND MS_SKUDCSET.SKU = DM_DOCUMENT_D.SKU
        WHERE 1=1
        <!-- START.권한센터 -->
            AND EXISTS (SELECT 1
                          FROM CM_USER_AUTHORITY
                         WHERE CM_USER_AUTHORITY.DCCODE = DM_DOCUMENT_D.DCCODE
                        AND CM_USER_AUTHORITY.STORERKEY = DM_DOCUMENT_D.STORERKEY
                        AND CM_USER_AUTHORITY.ORGANIZE = DM_DOCUMENT_D.ORGANIZE
                        AND CM_USER_AUTHORITY.AREA = DM_DOCUMENT_D.AREA
                           AND CM_USER_AUTHORITY.STORERKEY = #{gStorerkey}
                           AND CM_USER_AUTHORITY.USERID    = #{gUserId}
                           AND CM_USER_AUTHORITY.DCCODE    = #{fixdccode}
                           AND CM_USER_AUTHORITY.AREA      = #{gArea}
                           AND CM_USER_AUTHORITY.ORGANIZE = #{fixdccode}
                       )
            <!-- END.권한센터	-->
            AND DM_DOCUMENT_D.DCCODE = #{fixdccode}
            AND DM_DOCUMENT_D.DOCTYPE = 'DP'
            AND DM_DOCUMENT_D.DEL_YN = 'N'
            <if test="status != null and status != ''">AND DM_DOCUMENT_D.STATUS = #{status}</if>
            <if test="channel != null and channel != ''">AND DM_DOCUMENT_D.CHANNEL = #{channel}</if>
            <if test="docdtFrom != null and docdtFrom != ''">AND DM_DOCUMENT_D.DOCDT    <![CDATA[>=]]> #{docdtFrom}</if>
            <if test="docdtTo != null and docdtTo != ''">AND DM_DOCUMENT_D.DOCDT    <![CDATA[<=]]> #{docdtTo}</if>
            <if test="slipdtFrom != null and slipdtFrom != ''">AND DM_DOCUMENT_D.DELIVERYDATE   <![CDATA[>=]]> #{slipdtFrom}</if>
            <if test="slipdtTo != null and slipdtTo != ''">AND DM_DOCUMENT_D.DELIVERYDATE   <![CDATA[<=]]> #{slipdtTo}</if>
            <if test='crossyn == "Y"'>
                    AND MS_SKUDCSET.CROSSDOCKTYPE = 'CROSS'
            </if>
            <!-- 상품 다중선택 -->
            <if test="skuMulti != null and skuMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="skuMulti" item="item">
                        OR DM_DOCUMENT_D.SKU IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
            <if test="docnoMulti != null and docnoMulti != ''">
                AND DM_DOCUMENT_D.DOCNO IN
                <foreach collection="docnoMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            <if test="ordertypeMulti != null and ordertypeMulti != ''">
                AND DM_DOCUMENT_D.ORDERTYPE IN
                <foreach collection="ordertypeMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            <if test="serialCheck != null and serialCheck != ''">
                AND EXISTS (
                SELECT 'A'
                FROM ST_SNINFO
                JOIN DP_INVOICE_SN
                ON DP_INVOICE_SN.STORERKEY = ST_SNINFO.STORERKEY
                AND DP_INVOICE_SN.SKU = ST_SNINFO.SKU
                AND DP_INVOICE_SN.SERIALNO = ST_SNINFO.SERIALNO
                AND DP_INVOICE_SN.STOCKID = ST_SNINFO.STOCKID
                AND DP_INVOICE_SN.DEL_YN = 'N'
                WHERE DP_INVOICE_SN.DCCODE = DP_INPLAN.DCCODE
                AND DP_INVOICE_SN.STORERKEY = DP_INPLAN.STORERKEY
                AND DP_INVOICE_SN.DOCTYPE = DP_INPLAN.DOCTYPE
                AND DP_INVOICE_SN.SLIPNO = DP_INPLAN.SLIPNO
                AND DP_INVOICE_SN.SLIPDT = DP_INPLAN.SLIPDT
                AND DP_INVOICE_SN.SLIPLINE = DP_INPLAN.SLIPLINE
                AND DP_INVOICE_SN.SKU = DP_INPLAN.SKU

                <if test="blno != null and blno != ''">
                    AND ST_SNINFO.CONVSERIALNO = #{blno}
                </if>
                <if test="serialno != null and serialno != ''">
                    AND ST_SNINFO.SERIALNO = #{serialno}
                </if>
                <if test="wdCustkey != null and wdCustkey != ''">
                    AND ST_SNINFO.CONTRACTCUSTKEY = #{wdCustkey}
                </if>
                )
            </if>
        GROUP BY DP_INPLAN.DCCODE
            ,DP_INPLAN.STORERKEY
            ,DP_INPLAN.DOCDT
            ,DP_INPLAN.DOCNO
            ,DP_INPLAN.DOCTYPE
            ,DP_INPLAN.SLIPDT
            ,DP_INPLAN.SLIPNO
        )
        SELECT
            '0' AS CHECKYN
            , DM_DOCUMENT_H.DCCODE AS DCCODE
            , DM_DOCUMENT_H.DOCNO AS DOCNO
            , DM_DOCUMENT_H.STORERKEY AS STORERKEY
            , DM_DOCUMENT_H.DOCTYPE AS DOCTYPE
            , DM_DOCUMENT_H.POTYPE AS POTYPE
            , (select FN_CODEDESCR(DM_DOCUMENT_H.STORERKEY,'POTYPE_DP', DM_DOCUMENT_H.POTYPE) from dual) AS POTYPENAME
            , DM_DOCUMENT_H.ORGANIZE AS ORGANIZE
            , (select fn_descr_organize(DM_DOCUMENT_H.DCCODE,DM_DOCUMENT_H.ORGANIZE) from dual) AS ORGANIZENAME
            , DM_DOCUMENT_H.ORDERTYPE AS ORDERTYPE
            , (select FN_CODEDESCR(DM_DOCUMENT_H.STORERKEY,'ORDERTYPE_DP', DM_DOCUMENT_H.ORDERTYPE) from dual) AS ORDERTYPE_NAME
            , T_DP_INPLAN.STATUS AS STATUS
            , (select FN_CODEDESCR(T_DP_INPLAN.STORERKEY,'STATUS_DP', T_DP_INPLAN.STATUS) from dual) AS STATUSNAME
            , DM_DOCUMENT_H.DOCDT AS DOCDT
            , DM_DOCUMENT_H.FROM_CUSTKEY AS FROM_CUSTKEY
            , DM_DOCUMENT_H.FROM_CUSTNAME AS FROM_CUSTNAME
            , T_DP_INPLAN.SLIPDT AS SLIPDT
            , T_DP_INPLAN.SLIPNO AS SLIPNO
            , '['||T_DP_INPLAN.PLANT||']'||(select FN_DESCR_PLANT(T_DP_INPLAN.PLANT) from dual) AS PLANT
            , T_DP_INPLAN.WORKPROCESSCODE AS WORKPROCESSCODE
            , (select FN_CODEDESCR(DM_DOCUMENT_H.STORERKEY,'CREATIONTYPE_STO', DM_DOCUMENT_H.SOTYPE) from dual) AS STOTYPE <!-- 센터간이체시 선택된 STO유형 -->
            , T_DP_INPLAN.CHANNEL AS CHANNEL
            , CASE WHEN T_DP_INPLAN.CHANNEL = '3' THEN CASE WHEN  (SELECT MAX(ROUTE)   
                                                                     FROM DM_DOCUMENT_D Z
                                                                    WHERE Z.POKEY  = T_DP_INPLAN.SLIPNO
                                                                      AND Z.DCCODE = T_DP_INPLAN.DCCODE
                                                                      AND Z.DOCTYPE ='WD' ) IS NULL THEN
                                                                NULL
                                                            ELSE
                                                                (SELECT '[' ||  X.ROUTE || ']' || CM_DC.DCNAME
                                                                  FROM  (SELECT MAX(ROUTE) ROUTE
                                                                           FROM DM_DOCUMENT_D Z
                                                                          WHERE Z.POKEY  = T_DP_INPLAN.SLIPNO
                                                                            AND Z.DCCODE = T_DP_INPLAN.DCCODE
                                                                            AND Z.DOCTYPE ='WD' ) X 
                                                                 JOIN CM_DC
                                                                 ON   CM_DC.DCCODE = X.ROUTE
                                                                 AND  CM_DC.DEL_YN = 'N')
                                                        END 
                    ELSE '' END AS ROUTE
            ,T_DP_INPLAN.STO_DP_YN
        FROM T_DP_INPLAN
        JOIN DM_DOCUMENT_H
            ON DM_DOCUMENT_H.DCCODE = T_DP_INPLAN.DCCODE
            AND DM_DOCUMENT_H.STORERKEY = T_DP_INPLAN.STORERKEY
            AND DM_DOCUMENT_H.DELIVERYDATE = T_DP_INPLAN.SLIPDT
            AND DM_DOCUMENT_H.DOCTYPE = T_DP_INPLAN.DOCTYPE
            AND DM_DOCUMENT_H.DOCNO = T_DP_INPLAN.DOCNO
            AND DM_DOCUMENT_H.DOCTYPE = 'DP'
            AND DM_DOCUMENT_H.DEL_YN = 'N'
        ORDER BY
            DM_DOCUMENT_H.ORDERTYPE
            ,DM_DOCUMENT_H.POTYPE
            ,DM_DOCUMENT_H.FROM_CUSTKEY
            ,DM_DOCUMENT_H.DOCNO
            ,T_DP_INPLAN.SLIPDT
            ,T_DP_INPLAN.SLIPNO
    </select>

    <!-- 입고확정처리 이력상품 상세 2026-01-06 라인같은데 바코드 다른것들 처리-->
    <select id="getDetailList2" resultType="cjfw.wms.dp.dto.DpReceiptResDetailDto">
        WITH T_DP_INSPECT AS (
        SELECT DP_INSPECT.DCCODE AS DCCODE
            ,DP_INSPECT.STORERKEY AS STORERKEY
            ,DP_INSPECT.ORGANIZE AS ORGANIZE
            ,DP_INSPECT.AREA AS AREA
            ,DP_INSPECT.DOCDT AS DOCDT
            ,DP_INSPECT.DOCNO AS DOCNO
            ,DP_INSPECT.DOCLINE AS DOCLINE
            ,DP_INSPECT.DOCTYPE AS DOCTYPE
            ,DP_INSPECT.SLIPDT AS SLIPDT
            ,DP_INSPECT.SLIPNO AS SLIPNO
            ,DP_INSPECT.SLIPLINE AS SLIPLINE
            ,DP_INSPECT.SLIPTYPE AS SLIPTYPE
            ,DP_INSPECT.SKU AS SKU
            ,DP_INSPECT.LOTTABLE01 AS LOTTABLE01
            ,DP_INSPECT.STOCKID AS STOCKID
            ,DP_INSPECT.STOCKGRADE AS STOCKGRADE
            ,SUM(DP_INSPECT.INSPECTQTY) AS INSPECTQTY
            ,SUM(DP_INSPECT.CONFIRMQTY) AS CONFIRMQTY
            ,DP_INSPECT.TOLOC AS TOLOC
        FROM DP_INSPECT
        WHERE 1 = 1
            <if test="fixdccode != null and fixdccode != ''">AND DP_INSPECT.DCCODE = #{fixdccode}</if>
            <if test="gStorerkey != null and gStorerkey != ''">AND DP_INSPECT.STORERKEY = #{gStorerkey}</if>
            <if test="gOrganize != null and gOrganize != ''">AND DP_INSPECT.ORGANIZE = #{fixdccode}</if>
            <if test="gArea != null and gArea != ''">AND DP_INSPECT.AREA = #{gArea}</if>
            AND DP_INSPECT.DCCODE = #{dccode}
            AND DP_INSPECT.STORERKEY = #{storerkey}
            AND DP_INSPECT.SLIPDT = #{slipdt}
            AND DP_INSPECT.SLIPNO = #{slipno}
            AND DP_INSPECT.OPENQTY > 0
            AND DP_INSPECT.INSPECTQTY > 0
        GROUP BY DP_INSPECT.DCCODE
            ,DP_INSPECT.STORERKEY
            ,DP_INSPECT.ORGANIZE
            ,DP_INSPECT.AREA
            ,DP_INSPECT.DOCDT
            ,DP_INSPECT.DOCNO
            ,DP_INSPECT.DOCLINE
            ,DP_INSPECT.DOCTYPE
            ,DP_INSPECT.SLIPDT
            ,DP_INSPECT.SLIPNO
            ,DP_INSPECT.SLIPLINE
            ,DP_INSPECT.SLIPTYPE
            ,DP_INSPECT.SKU
            ,DP_INSPECT.LOTTABLE01
            ,DP_INSPECT.STOCKID
            ,DP_INSPECT.STOCKGRADE
            ,DP_INSPECT.TOLOC
        ),
        T_DP_EXCPT_SKU AS (
        	SELECT
	        	SLIPNO,
		        DELIVERYDATE,
		        SKU,
		        EXCPT_YN,
		        DRAFT_NO,
		        EDITWHO,
		        SLIPLINE_SEQ
		    FROM (
		        SELECT
	        	    SLIPNO,
		            DELIVERYDATE,
		            SKU,
		            EXCPT_YN,
		            DRAFT_NO,
		            EDITWHO,
		            SLIPLINE_SEQ,
		            ROW_NUMBER() OVER (
		                PARTITION BY DELIVERYDATE, SKU
		                ORDER BY EDITDATE DESC
		            ) AS RN
		        FROM DP_EXCPT_SKU
<!--		        WHERE EXCPT_YN = 'Y'-->
		    )
		    WHERE RN = 1
        )
        SELECT
            '0' AS CHECKYN
            ,DP_INPLAN.DCCODE AS DCCODE
            ,DP_INPLAN.STORERKEY AS STORERKEY
            ,DP_INPLAN.ORGANIZE AS ORGANIZE
            ,DP_INPLAN.DOCDT AS DOCDT
            ,DP_INPLAN.DOCNO AS DOCNO
            ,DP_INPLAN.DOCLINE AS DOCLINE
            ,DP_INPLAN.SLIPDT AS SLIPDT
            ,DP_INPLAN.SLIPNO AS SLIPNO
            ,DP_INPLAN.SLIPLINE AS SLIPLINE
            ,DP_INPLAN.SKU AS SKU
            ,MS_SKU.DESCRIPTION AS SKUNAME
            ,'[' || MS_SKU.COUNTRYOFORIGIN || ']' ||
            (SELECT BASEDESCR
            FROM CM_CODE
            WHERE CM_CODE.STORERKEY = MS_SKU.STORERKEY
            AND CM_CODE.CODELIST = 'COUNTRY'
            AND CM_CODE.BASECODE = MS_SKU.COUNTRYOFORIGIN
            AND CM_CODE.DEL_YN = 'N') AS COUNTRYOFORIGIN
            ,DM_DOCUMENT_D.STORERUOM AS UOM
            ,DM_DOCUMENT_D.BUNJA AS BUNJA
            ,DM_DOCUMENT_D.BUNMO AS BUNMO
            ,FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'EA',DP_INVOICE_SN.OPENQTY) AS OPENQTY_EA
            ,CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INVOICE_SN.OPENQTY)) AS OPENQTY_BOX
            ,DECODE(MS_SKU.BOXPERPLT,0,0,CEIL(CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INVOICE_SN.OPENQTY)) / MS_SKU.BOXPERPLT)) AS PLTQTY
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO ,DM_DOCUMENT_D.BUNJA ,DP_INVOICE_SN.ORDERQTY + DP_INVOICE_SN.CANCELQTY ) AS ORDERQTY
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO ,DM_DOCUMENT_D.BUNJA ,DM_DOCUMENT_D.ORDERQTY ) AS DOCORDERQTY
            ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU , DP_INPLAN.UOM, 'KG',DP_INVOICE_SN.ORDERQTY + DP_INVOICE_SN.CANCELQTY),2) AS ORDERWEIGHT
            ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU, DP_INPLAN.UOM, 'KG', DP_INPLAN.CONFIRMQTY), 2) AS CONFIRMWEIGHT
            ,FN_UOMCAL (
                    DM_DOCUMENT_D.BUNMO,
                    DM_DOCUMENT_D.BUNJA,
                    CASE WHEN DM_DOCUMENT_D.CHANNEL = '1' THEN NVL(DP_INSPECT.INSPECTQTY, DP_INVOICE_SN.CONFIRMQTY)
                        ELSE DP_INPLAN.INSPECTQTY
                    END
                ) AS INSPECTQTY
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO,DM_DOCUMENT_D.BUNJA,DP_INVOICE_SN.CONFIRMQTY) AS CONFIRMQTY
            <if test='workprocesscode == "STO"'>
                ,FN_UOMCAL(DM_DOCUMENT_D_WD.BUNMO, DM_DOCUMENT_D_WD.BUNJA, DM_DOCUMENT_D_WD.CONFIRMQTY) AS CONFIRMQTY_WD
                ,FN_UOMCAL(DM_DOCUMENT_D_WD.BUNMO, DM_DOCUMENT_D_WD.BUNJA, DM_DOCUMENT_D_WD.CANCELQTY) AS SHORTAGEQTY_WD
                ,1 AS STO_FLAG
            </if>
            <if test='workprocesscode != "STO"'>
                ,0 AS CONFIRMQTY_WD
                ,0 AS SHORTAGEQTY_WD
                ,0 AS STO_FLAG
            </if>
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO,DM_DOCUMENT_D.BUNJA,DP_INVOICE_SN.CANCELQTY ) AS SHORTAGEQTY
            ,0 AS SHORTAGETRANQTY
            ,0 AS TRANQTY
            ,CORE_CM_STRATEGY.FN_GETTOLOC ( DP_INPLAN.DOCTYPE,DP_INPLAN.DCCODE,DP_INPLAN.STORERKEY,DP_INPLAN.ORDERTYPE,DP_INPLAN.SLIPTYPE ) AS TOLOC
            ,NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01) AS LOTTABLE01
            --, NVL(CASE WHEN MS_SKU.DURATIONTYPE = '1' AND REGEXP_LIKE(NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01), '^[0-9]{8}$')
            --THEN TO_CHAR(TO_DATE(NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01),'YYYYMMDD') - (MS_SKU.DURATION - 1), 'YYYYMMDD')
            --ELSE NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01)
            --END,'STD') AS LOT_MANUFACTURE                    /** 제조 */
            --, NVL(CASE WHEN MS_SKU.DURATIONTYPE != '1' AND REGEXP_LIKE(NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01), '^[0-9]{8}$')
            --THEN TO_CHAR(TO_DATE(NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01),'YYYYMMDD') + (MS_SKU.DURATION - 1), 'YYYYMMDD')
            --ELSE NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01)
            --END,'STD') AS LOT_EXPIRE                         /** 유통 */
            --
            ,LOGISONESVC.FN_LOTTABLE_INFO('1',DP_INPLAN.STORERKEY,ST_SNINFO.LOTTABLE01,MS_SKU.DURATIONTYPE,MS_SKU.DURATION,'') AS LOT_MANUFACTURE /*제조일자*/
            ,LOGISONESVC.FN_LOTTABLE_INFO('2',DP_INPLAN.STORERKEY,ST_SNINFO.LOTTABLE01,MS_SKU.DURATIONTYPE,MS_SKU.DURATION,'') AS LOT_EXPIRE      /*소비일자*/
            --
            ,FN_LOTDURATION(DP_INPLAN.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01), 'N')||'/'||MS_SKU.DURATION AS DURATION_TERM
            ,MS_SKU.COLORDESCR AS COLORDESCR
            ,DM_DOCUMENT_D.REFERENCE02 AS REFERENCE02
            ,DP_INVOICE_SN.REASONCODE AS REASONCODE
            ,DP_INVOICE_SN.REASONMSG AS REASONMSG
            ,CASE WHEN NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01)='STD' THEN 'N'
            WHEN MONTHS_BETWEEN(TO_DATE(NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01),'yyyy-mm-dd'),SYSDATE)>3 THEN 'N' ELSE 'Y' END AS NEARDURATIONYN
            ,DM_DOCUMENT_D.STATUS AS STATUS
            ,FN_CODEDESCR(DM_DOCUMENT_D.STORERKEY,'STATUS_DP', DM_DOCUMENT_D.STATUS) AS STATUSNAME
            ,MS_SKU.QTYPERBOX AS QTYPERBOX
            ,DM_DOCUMENT_D.CHANNEL AS CHANNEL
            ,MS_SKU.DURATION AS DURATION
            ,0 AS DURATION_RATE
            ,MS_SKU.DURATIONTYPE AS DURATIONTYPE
            ,UNISTR('') AS LASTLOTTABLE01
            ,NVL(ST_SNINFO.STOCKID,DP_INPLAN.STOCKID) AS STOCKID
            ,DP_INPLAN.STOCKGRADE AS STOCKGRADE
            ,DECODE(SPDP_RECEIPT.FN_GETTOLOC( DP_INPLAN.DCCODE
            ,DP_INPLAN.STORERKEY
            ,DP_INPLAN.SKU
            ,DM_DOCUMENT_D.PLANT
            ,DM_DOCUMENT_D.STORAGELOC
            ,DM_DOCUMENT_D.CHANNEL
            ),'CROSS','CROSS','STAGE') AS CROSSLOC
            ,DM_DOCUMENT_D.PLANT AS PLANT
            ,'['||DM_DOCUMENT_D.PLANT||']'||fn_descr_plant(DM_DOCUMENT_D.PLANT) AS PLANT_DESCR
            ,FN_CODEDESCR(DP_INPLAN.STORERKEY,'PUTAWAYTYPE', DM_DOCUMENT_D.CHANNEL) AS CHANNEL_NAME
            ,FN_CODEDESCR(MS_SKU.STORERKEY,'STORAGETYPE', MS_SKU.STORAGETYPE) AS STORAGETYPENAME
            ,MS_SKU.STORAGETYPE AS STORAGETYPE
            ,ST_SNINFO.SERIALNO AS SERIALNO
            ,ST_SNINFO.CONVSERIALNO AS CONVSERIALNO
            ,ST_SNINFO.FACTORYNAME AS FACTORYNAME
            ,ST_SNINFO.CONTRACTCUSTKEY AS CONTRACTCOMPANY
            ,( SELECT DESCRIPTION FROM MS_CUST
            WHERE CUSTKEY = ST_SNINFO.CONTRACTCUSTKEY
            AND ROWNUM = 1) AS CONTRACTCOMPANYNAME
            ,FN_CODEDESCR(ST_SNINFO.STORERKEY,'CONTRACTTYPE_SN',ST_SNINFO.CONTRACTTYPE) AS CONTRACTTYPE
            ,ST_SNINFO.BUTCHERYDT AS BUTCHERYDT
            ,ST_SNINFO.FROMVALIDDT AS FROMVALIDDT
            ,ST_SNINFO.TOVALIDDT AS TOVALIDDT
            ,ST_SNINFO.STOCKID AS BARCODE
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO,DM_DOCUMENT_D.BUNJA,DP_INVOICE_SN.ORDERQTY)                                                                                           AS SERIALORDERQTY
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO,DM_DOCUMENT_D.BUNJA,DP_INVOICE_SN.CONFIRMQTY)                                                                                         AS SERIALINSPECTQTY
            ,CASE WHEN DP_INPLAN.STORERKEY = 'CJFW'
            		THEN CASE WHEN DP_INPLAN.UOM = 'KG' THEN DP_INVOICE_SN.CONFIRMQTY
		            ELSE DP_INVOICE_SN.CONFIRMQTY * ST_SNINFO.NETWEIGHT
		            END
		            ELSE FN_CONV_UOM(DP_INPLAN.STORERKEY,DP_INPLAN.SKU,DP_INPLAN.UOM,'KG',DP_INVOICE_SN.CONFIRMQTY)
            END                                                                                                                           AS SERIALSCANWEIGHT
            ,CASE WHEN DP_INPLAN.STORERKEY = 'CJFW'
            		OR ( ST_SNINFO.SERIALNO IS NOT NULL
	            	AND ( DM_DOCUMENT_D.CHANNEL  !=  '1'
		            OR DP_INPLAN.DCCODE = '2170')
		            ) THEN 'Y'
            		ELSE 'N'
            END AS CHECKFLAG
            ,MS_SKU.LINE01 AS LINE01
            ,MS_SKU.SERIALYN AS SERIALYN
            ,CASE WHEN DP_INPLAN.STORERKEY = 'FW00' AND ST_SNINFO.SERIALNO IS NULL THEN 'gray' ELSE 'black' END AS FONTCOLOR
            ,CASE WHEN MS_DC_PLT_LOAD.BOXPERLAYER IS NOT NULL AND MS_DC_PLT_LOAD.LAYERPERPLT IS NOT NULL
                THEN MS_DC_PLT_LOAD.BOXPERLAYER * MS_DC_PLT_LOAD.LAYERPERPLT
                ELSE MS_SKUCHAIN.BOXPERPLT
            END AS BOXPERPLT
            ,MS_DC_PLT_LOAD.BOXPERLAYER AS BOXPERLAYER /** 방수 */
            ,MS_DC_PLT_LOAD.LAYERPERPLT AS LAYERPERPLT /** 단수 */
            , DP_EXCPT_SKU.EXCPT_YN AS EXCPT_YN  /** 입고예외여부 */
            , DP_EXCPT_SKU.EXCPT_YN AS EXCPT_YN_ORI  /** 입고예외여부 */
            , DP_EXCPT_SKU.DRAFT_NO AS DRAFT_NO  /** 기안번호 */
            , DP_EXCPT_SKU.SLIPLINE_SEQ AS SLIPLINE_SEQ  /** SEQ */
            , DP_EXCPT_SKU.EDITWHO AS EDITWHO  /** 최종변경자 */
            , FRAMEONE_USER.USER_NM AS EDITWHO_NAME /** 예외입력자 이름 */
        FROM DP_INPLAN
        JOIN CM_USER_AUTHORITY
            ON CM_USER_AUTHORITY.USERID = #{gUserId}
            AND CM_USER_AUTHORITY.DCCODE = DP_INPLAN.DCCODE
            AND CM_USER_AUTHORITY.STORERKEY = DP_INPLAN.STORERKEY
            AND CM_USER_AUTHORITY.ORGANIZE = DP_INPLAN.ORGANIZE
            AND CM_USER_AUTHORITY.AREA = DP_INPLAN.AREA
            <if test="fixdccode != null and fixdccode != ''">AND CM_USER_AUTHORITY.DCCODE = #{fixdccode}</if>
            <if test="gStorerkey != null and gStorerkey != ''">AND CM_USER_AUTHORITY.STORERKEY = #{gStorerkey}</if>
            <if test="gOrganize != null and gOrganize != ''">AND CM_USER_AUTHORITY.ORGANIZE = #{fixdccode}</if>
            <if test="gArea != null and gArea != ''">AND CM_USER_AUTHORITY.AREA = #{gArea}</if>
        JOIN DM_DOCUMENT_H
            ON DM_DOCUMENT_H.DCCODE = DP_INPLAN.DCCODE
            AND DM_DOCUMENT_H.STORERKEY = DP_INPLAN.STORERKEY
            AND DM_DOCUMENT_H.DELIVERYDATE = DP_INPLAN.SLIPDT
            AND DM_DOCUMENT_H.DOCTYPE = DP_INPLAN.DOCTYPE
            AND DM_DOCUMENT_H.DOCNO = DP_INPLAN.DOCNO
            AND DM_DOCUMENT_H.DOCTYPE = 'DP'
            AND DM_DOCUMENT_H.DEL_YN = 'N'
            <!-- 협력사 다중선택 -->
            <if test="fromCustkeyMulti != null and fromCustkeyMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="fromCustkeyMulti" item="item">
                        OR DM_DOCUMENT_H.FROM_CUSTKEY IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
        JOIN DM_DOCUMENT_D
            ON DM_DOCUMENT_D.DCCODE = DP_INPLAN.DCCODE
            AND DM_DOCUMENT_D.STORERKEY = DP_INPLAN.STORERKEY
            AND DM_DOCUMENT_D.DOCTYPE = DP_INPLAN.DOCTYPE
            AND DM_DOCUMENT_D.DELIVERYDATE = DP_INPLAN.SLIPDT
            AND DM_DOCUMENT_D.DOCNO = DP_INPLAN.DOCNO
            AND DM_DOCUMENT_D.DOCLINE = DP_INPLAN.DOCLINE
            <if test="channel != null and channel != ''">AND DM_DOCUMENT_D.CHANNEL LIKE #{channel}</if>
            AND DM_DOCUMENT_D.DEL_YN = 'N'
            <if test='workprocesscode == "STO"'>
                JOIN
                DM_DOCUMENT_D DM_DOCUMENT_D_WD
                ON DM_DOCUMENT_D_WD.DOCNO = DP_INPLAN.DOCNO
                AND DM_DOCUMENT_D_WD.DOCLINE = DP_INPLAN.DOCLINE
                AND DM_DOCUMENT_D_WD.DOCTYPE = 'WD'
                AND DM_DOCUMENT_D_WD.WORKPROCESSCODE = 'STO'
            </if>
        JOIN MS_SKU
            ON MS_SKU.STORERKEY = DP_INPLAN.STORERKEY
            AND MS_SKU.SKU = DP_INPLAN.SKU
            AND MS_SKU.SERIALYN = DECODE(DP_INPLAN.DCCODE,'2170',MS_SKU.SERIALYN,'Y')
            <if test="storagetype != null and storagetype != ''">AND MS_SKU.STORAGETYPE LIKE #{storagetype}</if>
        LEFT OUTER JOIN MS_SKUDCSET
            ON MS_SKUDCSET.STORERKEY = DM_DOCUMENT_D.STORERKEY
            AND MS_SKUDCSET.DCCODE = DM_DOCUMENT_D.DCCODE
            AND MS_SKUDCSET.SKU = DM_DOCUMENT_D.SKU
        JOIN DP_INVOICE_SN
            ON DP_INVOICE_SN.DCCODE = DP_INPLAN.DCCODE
            AND DP_INVOICE_SN.STORERKEY = DP_INPLAN.STORERKEY
            AND DP_INVOICE_SN.DOCTYPE = DP_INPLAN.DOCTYPE
            AND DP_INVOICE_SN.SLIPNO = DP_INPLAN.SLIPNO
            AND DP_INVOICE_SN.SLIPDT = DP_INPLAN.SLIPDT
            AND DP_INVOICE_SN.SLIPLINE = DP_INPLAN.SLIPLINE
            AND DP_INVOICE_SN.SKU = DP_INPLAN.SKU
        LEFT JOIN T_DP_INSPECT DP_INSPECT
            ON DP_INSPECT.DCCODE = DP_INPLAN.DCCODE
            AND DP_INSPECT.STORERKEY = DP_INPLAN.STORERKEY
            AND DP_INSPECT.SLIPDT = DP_INPLAN.SLIPDT
            AND DP_INSPECT.SLIPNO = DP_INPLAN.SLIPNO
            AND DP_INSPECT.STOCKID = DP_INVOICE_SN.STOCKID
        LEFT OUTER JOIN ST_SNINFO
            ON ST_SNINFO.STORERKEY = DP_INVOICE_SN.STORERKEY
            AND ST_SNINFO.SKU = DP_INVOICE_SN.SKU
            AND ST_SNINFO.SERIALNO = DP_INVOICE_SN.SERIALNO
            AND ST_SNINFO.STOCKID = DP_INVOICE_SN.STOCKID
        LEFT OUTER JOIN MS_SKUCHAIN
            ON MS_SKUCHAIN.SKU = DP_INPLAN.SKU
            AND MS_SKUCHAIN.STORERKEY = DP_INPLAN.STORERKEY
            AND MS_SKUCHAIN.DEL_YN = 'N'
        LEFT OUTER JOIN MS_DC_PLT_LOAD
            ON MS_DC_PLT_LOAD.DCCODE = DP_INPLAN.DCCODE
            AND MS_DC_PLT_LOAD.PLANT = DM_DOCUMENT_D.PLANT
            AND MS_DC_PLT_LOAD.STORERKEY = DP_INPLAN.STORERKEY
            AND MS_DC_PLT_LOAD.SKU = DP_INPLAN.SKU
            AND MS_DC_PLT_LOAD.CUSTKEY = DP_INPLAN.CUSTKEY
        LEFT JOIN T_DP_EXCPT_SKU DP_EXCPT_SKU
        	ON DP_EXCPT_SKU.SKU = DP_INPLAN.SKU
        	AND DP_EXCPT_SKU.DELIVERYDATE = DP_INPLAN.SLIPDT
        	AND DP_EXCPT_SKU.SLIPNO = DP_INPLAN.SLIPNO
        LEFT JOIN FRAMEONE_USER
            ON FRAMEONE_USER.USER_ID = DP_EXCPT_SKU.EDITWHO
        WHERE DP_INPLAN.DCCODE = #{dccode}
            AND DP_INPLAN.STORERKEY = #{storerkey}
            AND DP_INPLAN.SLIPDT = #{slipdt}
            AND DP_INPLAN.SLIPNO = #{slipno}
            <!-- 상품 다중선택 -->
            <if test="skuMulti != null and skuMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="skuMulti" item="item">
                        OR DP_INPLAN.SKU IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
            <if test="docnoMulti != null and docnoMulti != ''">
                AND DP_INPLAN.DOCNO IN
                <foreach collection="docnoMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            <if test="ordertypeMulti != null and ordertypeMulti != ''">
                AND DP_INPLAN.ORDERTYPE IN
                <foreach collection="ordertypeMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            <if test="blno != null and blno != ''">
                AND ST_SNINFO.CONVSERIALNO = #{blno}
            </if>
            <if test="serialno != null and serialno != ''">
                AND ST_SNINFO.SERIALNO = #{serialno}
            </if>
            <if test="wdCustkey != null and wdCustkey != ''">
                AND ST_SNINFO.CONTRACTCUSTKEY = #{wdCustkey}
            </if>
            <if test='crossyn == "Y"'>
                    AND MS_SKUDCSET.CROSSDOCKTYPE = 'CROSS'
            </if>
        ORDER BY CASE
                    WHEN REGEXP_LIKE(SLIPLINE, '^\d+$')
                    THEN LPAD(SLIPLINE, 20, '0')
                    ELSE SLIPLINE
                  END, SKU
    </select>

    <select id="getDetailList2Old" resultType="cjfw.wms.dp.dto.DpReceiptResDetailDto">
        WITH T_DP_INSPECT AS (
        SELECT DP_INSPECT.DCCODE AS DCCODE
            ,DP_INSPECT.STORERKEY AS STORERKEY
            ,DP_INSPECT.ORGANIZE AS ORGANIZE
            ,DP_INSPECT.AREA AS AREA
            ,DP_INSPECT.DOCDT AS DOCDT
            ,DP_INSPECT.DOCNO AS DOCNO
            ,DP_INSPECT.DOCLINE AS DOCLINE
            ,DP_INSPECT.DOCTYPE AS DOCTYPE
            ,DP_INSPECT.SLIPDT AS SLIPDT
            ,DP_INSPECT.SLIPNO AS SLIPNO
            ,DP_INSPECT.SLIPLINE AS SLIPLINE
            ,DP_INSPECT.SLIPTYPE AS SLIPTYPE
            ,DP_INSPECT.SKU AS SKU
            ,DP_INSPECT.LOTTABLE01 AS LOTTABLE01
            ,DP_INSPECT.STOCKID AS STOCKID
            ,DP_INSPECT.STOCKGRADE AS STOCKGRADE
            ,SUM(DP_INSPECT.INSPECTQTY) AS INSPECTQTY
            ,SUM(DP_INSPECT.CONFIRMQTY) AS CONFIRMQTY
            ,DP_INSPECT.TOLOC AS TOLOC
        FROM DP_INSPECT
        WHERE 1 = 1
            <if test="fixdccode != null and fixdccode != ''">AND DP_INSPECT.DCCODE = #{fixdccode}</if>
            <if test="gStorerkey != null and gStorerkey != ''">AND DP_INSPECT.STORERKEY = #{gStorerkey}</if>
            <if test="gOrganize != null and gOrganize != ''">AND DP_INSPECT.ORGANIZE = #{fixdccode}</if>
            <if test="gArea != null and gArea != ''">AND DP_INSPECT.AREA = #{gArea}</if>
            AND DP_INSPECT.DCCODE = #{dccode}
            AND DP_INSPECT.STORERKEY = #{storerkey}
            AND DP_INSPECT.SLIPDT = #{slipdt}
            AND DP_INSPECT.SLIPNO = #{slipno}
            AND DP_INSPECT.OPENQTY > 0
            AND DP_INSPECT.INSPECTQTY > 0
        GROUP BY DP_INSPECT.DCCODE
            ,DP_INSPECT.STORERKEY
            ,DP_INSPECT.ORGANIZE
            ,DP_INSPECT.AREA
            ,DP_INSPECT.DOCDT
            ,DP_INSPECT.DOCNO
            ,DP_INSPECT.DOCLINE
            ,DP_INSPECT.DOCTYPE
            ,DP_INSPECT.SLIPDT
            ,DP_INSPECT.SLIPNO
            ,DP_INSPECT.SLIPLINE
            ,DP_INSPECT.SLIPTYPE
            ,DP_INSPECT.SKU
            ,DP_INSPECT.LOTTABLE01
            ,DP_INSPECT.STOCKID
            ,DP_INSPECT.STOCKGRADE
            ,DP_INSPECT.TOLOC
        ),
        T_DP_EXCPT_SKU AS (
        	SELECT
	        	SLIPNO,
		        DELIVERYDATE,
		        SKU,
		        EXCPT_YN,
		        DRAFT_NO,
		        EDITWHO,
		        SLIPLINE_SEQ
		    FROM (
		        SELECT
	        	    SLIPNO,
		            DELIVERYDATE,
		            SKU,
		            EXCPT_YN,
		            DRAFT_NO,
		            EDITWHO,
		            SLIPLINE_SEQ,
		            ROW_NUMBER() OVER (
		                PARTITION BY DELIVERYDATE, SKU
		                ORDER BY EDITDATE DESC
		            ) AS RN
		        FROM DP_EXCPT_SKU
<!--		        WHERE EXCPT_YN = 'Y'-->
		    )
		    WHERE RN = 1
        )<!--1번-->
        SELECT /* [dpReceiptService.sqlx][dpReceiptService.getDataDetailSerialList][입고확정처리 이력상품 문서 Detail정보] */
            '0' AS CHECKYN
            ,DP_INPLAN.DCCODE AS DCCODE
            ,DP_INPLAN.STORERKEY AS STORERKEY
            ,DP_INPLAN.ORGANIZE AS ORGANIZE
            ,DP_INPLAN.DOCDT AS DOCDT
            ,DP_INPLAN.DOCNO AS DOCNO
            ,DP_INPLAN.DOCLINE AS DOCLINE
            ,DP_INPLAN.SLIPDT AS SLIPDT
            ,DP_INPLAN.SLIPNO AS SLIPNO
            ,DP_INPLAN.SLIPLINE AS SLIPLINE
            ,DP_INPLAN.SKU AS SKU
            ,MS_SKU.DESCRIPTION AS SKUNAME
            ,'[' || MS_SKU.COUNTRYOFORIGIN || ']' ||
            (SELECT BASEDESCR
            FROM CM_CODE
            WHERE CM_CODE.STORERKEY = MS_SKU.STORERKEY
            AND CM_CODE.CODELIST = 'COUNTRY'
            AND CM_CODE.BASECODE = MS_SKU.COUNTRYOFORIGIN
            AND CM_CODE.DEL_YN = 'N') AS COUNTRYOFORIGIN
            ,DM_DOCUMENT_D.STORERUOM AS UOM
            ,DM_DOCUMENT_D.BUNJA AS BUNJA
            ,DM_DOCUMENT_D.BUNMO AS BUNMO
            ,FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'EA',DP_INPLAN.OPENQTY) AS OPENQTY_EA
            ,CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY)) AS OPENQTY_BOX
            ,DECODE(MS_SKU.BOXPERPLT,0,0,CEIL(CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY)) /
            MS_SKU.BOXPERPLT)) AS PLTQTY
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY ) AS ORDERQTY
            ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU , DP_INPLAN.UOM, 'KG',DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY),2) AS ORDERWEIGHT
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.INSPECTQTY) AS INSPECTQTY
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.CONFIRMQTY) AS CONFIRMQTY

            <if test='workprocesscode == "STO"'>
                ,FN_UOMCAL ( DM_DOCUMENT_D_WD.BUNMO
                ,DM_DOCUMENT_D_WD.BUNJA
                ,DM_DOCUMENT_D_WD.CONFIRMQTY ) AS CONFIRMQTY_WD
                ,1 AS STO_FLAG
            </if>
            <if test='workprocesscode != "STO"'>
                ,0 AS CONFIRMQTY_WD
                ,0 AS STO_FLAG
            </if>


            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.CANCELQTY ) AS SHORTAGEQTY
            ,0 AS SHORTAGETRANQTY
            ,0 AS TRANQTY
            ,NVL(T_DP_INSPECT.TOLOC
            , CORE_CM_STRATEGY.FN_GETTOLOC ( DP_INPLAN.DOCTYPE
            ,DP_INPLAN.DCCODE
            ,DP_INPLAN.STORERKEY
            ,DP_INPLAN.ORDERTYPE
            ,DP_INPLAN.SLIPTYPE )) AS TOLOC
            ,NVL(T_DP_INSPECT.LOTTABLE01,DP_INPLAN.LOTTABLE01) AS LOTTABLE01
            --, NVL(CASE WHEN MS_SKU.DURATIONTYPE = '1' AND REGEXP_LIKE(NVL(T_DP_INSPECT.LOTTABLE01,DP_INPLAN.LOTTABLE01), '^[0-9]{8}$')
            --THEN TO_CHAR(TO_DATE(NVL(T_DP_INSPECT.LOTTABLE01,DP_INPLAN.LOTTABLE01),'YYYYMMDD') - (MS_SKU.DURATION - 1), 'YYYYMMDD')
            --ELSE NVL(T_DP_INSPECT.LOTTABLE01,DP_INPLAN.LOTTABLE01)
            --END,'STD') AS LOT_MANUFACTURE                    /** 제조 */
            --, NVL(CASE WHEN MS_SKU.DURATIONTYPE != '1' AND REGEXP_LIKE(NVL(T_DP_INSPECT.LOTTABLE01,DP_INPLAN.LOTTABLE01), '^[0-9]{8}$')
            --THEN TO_CHAR(TO_DATE(NVL(T_DP_INSPECT.LOTTABLE01,DP_INPLAN.LOTTABLE01),'YYYYMMDD') + (MS_SKU.DURATION - 1), 'YYYYMMDD')
            --ELSE NVL(T_DP_INSPECT.LOTTABLE01,DP_INPLAN.LOTTABLE01)
            --END,'STD') AS LOT_EXPIRE                         /** 유통 */
            --
            ,LOGISONESVC.FN_LOTTABLE_INFO('1',DP_INPLAN.STORERKEY,NVL(T_DP_INSPECT.LOTTABLE01, DP_INPLAN.LOTTABLE01),MS_SKU.DURATIONTYPE,MS_SKU.DURATION,'') AS LOT_MANUFACTURE /*제조일자*/
            ,LOGISONESVC.FN_LOTTABLE_INFO('2',DP_INPLAN.STORERKEY,NVL(T_DP_INSPECT.LOTTABLE01, DP_INPLAN.LOTTABLE01),MS_SKU.DURATIONTYPE,MS_SKU.DURATION,'') AS LOT_EXPIRE      /*소비일자*/
            --            
            ,FN_LOTDURATION(DP_INPLAN.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, NVL(T_DP_INSPECT.LOTTABLE01,DP_INPLAN.LOTTABLE01), 'N')||'/'||MS_SKU.DURATION AS DURATION_TERM
            ,MS_SKU.COLORDESCR AS COLORDESCR
            ,DM_DOCUMENT_D.REFERENCE02 AS REFERENCE02
            ,DP_INPLAN.REASONCODE AS REASONCODE
            ,DP_INPLAN.REASONMSG AS REASONMSG
            ,CASE WHEN NVL(T_DP_INSPECT.LOTTABLE01,DP_INPLAN.LOTTABLE01)='STD' THEN 'N'
            WHEN MONTHS_BETWEEN(TO_DATE(NVL(T_DP_INSPECT.LOTTABLE01,DP_INPLAN.LOTTABLE01),'yyyy-mm-dd'),SYSDATE)>3 THEN 'N' ELSE 'Y' END AS NEARDURATIONYN
            ,DM_DOCUMENT_D.STATUS AS STATUS
            ,FN_CODEDESCR(DM_DOCUMENT_D.STORERKEY,'STATUS_DP', DM_DOCUMENT_D.STATUS) AS STATUSNAME
            ,MS_SKU.QTYPERBOX AS QTYPERBOX
            ,DM_DOCUMENT_D.CHANNEL AS CHANNEL
            ,MS_SKU.DURATION AS DURATION
            ,0 AS DURATION_RATE
            ,MS_SKU.DURATIONTYPE AS DURATIONTYPE
            ,UNISTR('') AS LASTLOTTABLE01
            ,NVL(NVL(ST_SNINFO.STOCKID,T_DP_INSPECT.STOCKID),DP_INPLAN.STOCKID) AS STOCKID
            ,NVL(T_DP_INSPECT.STOCKGRADE,DP_INPLAN.STOCKGRADE) AS STOCKGRADE
            ,DECODE(SPDP_RECEIPT.FN_GETTOLOC( DP_INPLAN.DCCODE
            ,DP_INPLAN.STORERKEY
            ,DP_INPLAN.SKU
            ,DM_DOCUMENT_D.PLANT
            ,DM_DOCUMENT_D.STORAGELOC
            ,DM_DOCUMENT_D.CHANNEL
            ),'CROSS','CROSS','STAGE') AS CROSSLOC
            ,DM_DOCUMENT_D.PLANT AS PLANT
            ,'['||DM_DOCUMENT_D.PLANT||']'||fn_descr_plant(DM_DOCUMENT_D.PLANT) AS PLANT_DESCR
            ,FN_CODEDESCR(DP_INPLAN.STORERKEY,'PUTAWAYTYPE', DM_DOCUMENT_D.CHANNEL) AS CHANNEL_NAME
            ,FN_CODEDESCR(MS_SKU.STORERKEY,'STORAGETYPE', MS_SKU.STORAGETYPE) AS STORAGETYPENAME
            ,MS_SKU.STORAGETYPE AS STORAGETYPE
            ,ST_SNINFO.SERIALNO AS SERIALNO
            ,ST_SNINFO.CONVSERIALNO AS CONVSERIALNO
            ,ST_SNINFO.FACTORYNAME AS FACTORYNAME
            ,ST_SNINFO.CONTRACTCUSTKEY AS CONTRACTCOMPANY
            ,( SELECT DESCRIPTION FROM MS_CUST
            WHERE CUSTKEY = ST_SNINFO.CONTRACTCUSTKEY
            AND ROWNUM = 1) AS CONTRACTCOMPANYNAME
            ,FN_CODEDESCR(ST_SNINFO.STORERKEY,'CONTRACTTYPE_SN',ST_SNINFO.CONTRACTTYPE) AS CONTRACTTYPE
            ,ST_SNINFO.BUTCHERYDT AS BUTCHERYDT
            ,ST_SNINFO.FROMVALIDDT AS FROMVALIDDT
            ,ST_SNINFO.TOVALIDDT AS TOVALIDDT
            ,ST_SNINFO.STOCKID AS BARCODE
            ,CASE WHEN ST_SNINFO.STOCKID IS NULL THEN NULL
            ELSE FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,T_DP_INSPECT.INSPECTQTY )
            END                                                                                                                           AS SERIALORDERQTY
            ,CASE WHEN ST_SNINFO.STOCKID IS NULL THEN NULL
            ELSE FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,T_DP_INSPECT.CONFIRMQTY )
            END                                                                                                                           AS SERIALINSPECTQTY
            ,CASE WHEN DP_INPLAN.STORERKEY = 'CJFW' THEN CASE WHEN ST_SNINFO.STOCKID IS NULL THEN NULL
            ELSE DECODE(DP_INPLAN.UOM,'KG',T_DP_INSPECT.CONFIRMQTY,T_DP_INSPECT.CONFIRMQTY * ST_SNINFO.NETWEIGHT)
            END
            ELSE CASE WHEN ST_SNINFO.STOCKID IS NULL THEN NULL
            ELSE FN_CONV_UOM(DP_INPLAN.STORERKEY,DP_INPLAN.SKU,DP_INPLAN.UOM,'KG',T_DP_INSPECT.CONFIRMQTY)
            END
        END                                                                                                                           AS SERIALSCANWEIGHT
            ,CASE WHEN DP_INPLAN.STORERKEY = 'CJFW'
            OR (ST_SNINFO.SERIALNO IS NOT NULL) THEN 'Y'
            ELSE 'N'
            END AS CHECKFLAG
            ,MS_SKU.LINE01 AS LINE01
            ,MS_SKU.SERIALYN AS SERIALYN
            ,CASE WHEN DP_INPLAN.STORERKEY = 'FW00' AND ST_SNINFO.SERIALNO IS NULL THEN 'gray' ELSE 'black' END AS FONTCOLOR
            ,CASE WHEN MS_DC_PLT_LOAD.BOXPERLAYER IS NOT NULL AND MS_DC_PLT_LOAD.LAYERPERPLT IS NOT NULL
                THEN MS_DC_PLT_LOAD.BOXPERLAYER * MS_DC_PLT_LOAD.LAYERPERPLT
                ELSE MS_SKUCHAIN.BOXPERPLT
            END AS BOXPERPLT
            ,MS_DC_PLT_LOAD.BOXPERLAYER AS BOXPERLAYER /** 방수 */
            ,MS_DC_PLT_LOAD.LAYERPERPLT AS LAYERPERPLT /** 단수 */
            , DP_EXCPT_SKU.EXCPT_YN AS EXCPT_YN  /** 입고예외여부 */
            , DP_EXCPT_SKU.EXCPT_YN AS EXCPT_YN_ORI  /** 입고예외여부 */
            , DP_EXCPT_SKU.DRAFT_NO AS DRAFT_NO  /** 기안번호 */
            , DP_EXCPT_SKU.SLIPLINE_SEQ AS SLIPLINE_SEQ  /** SEQ */
            , DP_EXCPT_SKU.EDITWHO AS EDITWHO  /** 최종변경자 */
            , FRAMEONE_USER.USER_NM AS EDITWHO_NAME /** 예외입력자 이름 */
        FROM DP_INPLAN
        JOIN CM_USER_AUTHORITY
            ON CM_USER_AUTHORITY.USERID = #{gUserId}
            AND CM_USER_AUTHORITY.DCCODE = DP_INPLAN.DCCODE
            AND CM_USER_AUTHORITY.STORERKEY = DP_INPLAN.STORERKEY
            AND CM_USER_AUTHORITY.ORGANIZE = DP_INPLAN.ORGANIZE
            AND CM_USER_AUTHORITY.AREA = DP_INPLAN.AREA
            <if test="fixdccode != null and fixdccode != ''">AND CM_USER_AUTHORITY.DCCODE = #{fixdccode}</if>
            <if test="gStorerkey != null and gStorerkey != ''">AND CM_USER_AUTHORITY.STORERKEY = #{gStorerkey}</if>
            <if test="gOrganize != null and gOrganize != ''">AND CM_USER_AUTHORITY.ORGANIZE = #{fixdccode}</if>
            <if test="gArea != null and gArea != ''">AND CM_USER_AUTHORITY.AREA = #{gArea}</if>
        JOIN DM_DOCUMENT_H
            ON DM_DOCUMENT_H.DCCODE = DP_INPLAN.DCCODE
            AND DM_DOCUMENT_H.STORERKEY = DP_INPLAN.STORERKEY
            AND DM_DOCUMENT_H.DELIVERYDATE = DP_INPLAN.SLIPDT
            AND DM_DOCUMENT_H.DOCTYPE = DP_INPLAN.DOCTYPE
            AND DM_DOCUMENT_H.DOCNO = DP_INPLAN.DOCNO
            AND DM_DOCUMENT_H.DOCTYPE = 'DP'
            AND DM_DOCUMENT_H.DEL_YN = 'N'
            <!-- 협력사 다중선택 -->
            <if test="fromCustkeyMulti != null and fromCustkeyMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="fromCustkeyMulti" item="item">
                        OR DM_DOCUMENT_H.FROM_CUSTKEY IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
        JOIN DM_DOCUMENT_D
            ON DM_DOCUMENT_D.DCCODE = DP_INPLAN.DCCODE
            AND DM_DOCUMENT_D.STORERKEY = DP_INPLAN.STORERKEY
            AND DM_DOCUMENT_D.DOCTYPE = DP_INPLAN.DOCTYPE
            AND DM_DOCUMENT_D.DELIVERYDATE = DP_INPLAN.SLIPDT
            AND DM_DOCUMENT_D.DOCNO = DP_INPLAN.DOCNO
            AND DM_DOCUMENT_D.DOCLINE = DP_INPLAN.DOCLINE
            AND DM_DOCUMENT_D.CHANNEL IN ('1','2','3')   <!-- 저장품만 처리함 1.저장 2.일배 3.광역일배 2015.01.26 SLLEE MODIFY [ 1,2] 김해경님 요청 -->
            <if test="channel != null and channel != ''">AND DM_DOCUMENT_D.CHANNEL LIKE #{channel}</if>
            AND DM_DOCUMENT_D.DEL_YN = 'N'

        <if test='workprocesscode == "STO"'>
            JOIN
            DM_DOCUMENT_D DM_DOCUMENT_D_WD
            ON DM_DOCUMENT_D_WD.DOCNO = DP_INPLAN.DOCNO
            AND DM_DOCUMENT_D_WD.DOCLINE = DP_INPLAN.DOCLINE
            AND DM_DOCUMENT_D_WD.DOCTYPE = 'WD'
            AND DM_DOCUMENT_D_WD.WORKPROCESSCODE = 'STO'
        </if>
        JOIN MS_SKU
            ON MS_SKU.STORERKEY = DP_INPLAN.STORERKEY
            AND MS_SKU.SKU = DP_INPLAN.SKU
            AND MS_SKU.SERIALYN = DECODE(DP_INPLAN.DCCODE, '2170', MS_SKU.SERIALYN, 'Y')
            <if test="storagetype != null and storagetype != ''">
                AND MS_SKU.STORAGETYPE LIKE #{storagetype}
            </if>
        LEFT OUTER JOIN MS_SKUDCSET
            ON MS_SKUDCSET.STORERKEY = DM_DOCUMENT_D.STORERKEY
            AND MS_SKUDCSET.DCCODE = DM_DOCUMENT_D.DCCODE
            AND MS_SKUDCSET.SKU = DM_DOCUMENT_D.SKU
        JOIN T_DP_INSPECT
            ON T_DP_INSPECT.DCCODE = DP_INPLAN.DCCODE
            AND T_DP_INSPECT.STORERKEY = DP_INPLAN.STORERKEY
            AND T_DP_INSPECT.SLIPDT = DP_INPLAN.SLIPDT
            AND T_DP_INSPECT.SLIPNO = DP_INPLAN.SLIPNO
            AND T_DP_INSPECT.SLIPLINE = DP_INPLAN.SLIPLINE
        LEFT OUTER JOIN ST_SNINFO
            ON ST_SNINFO.STORERKEY = T_DP_INSPECT.STORERKEY
            AND ST_SNINFO.STOCKID = T_DP_INSPECT.STOCKID
        LEFT OUTER JOIN MS_SKUCHAIN
            ON MS_SKUCHAIN.SKU = DP_INPLAN.SKU
            AND MS_SKUCHAIN.STORERKEY = DP_INPLAN.STORERKEY
            AND MS_SKUCHAIN.DEL_YN = 'N'
        LEFT OUTER JOIN MS_DC_PLT_LOAD
            ON MS_DC_PLT_LOAD.DCCODE = DP_INPLAN.DCCODE
            AND MS_DC_PLT_LOAD.PLANT = DM_DOCUMENT_D.PLANT
            AND MS_DC_PLT_LOAD.STORERKEY = DP_INPLAN.STORERKEY
            AND MS_DC_PLT_LOAD.SKU = DP_INPLAN.SKU
            AND MS_DC_PLT_LOAD.CUSTKEY = DP_INPLAN.CUSTKEY
        LEFT JOIN T_DP_EXCPT_SKU DP_EXCPT_SKU
        	ON DP_EXCPT_SKU.SKU = DP_INPLAN.SKU
        	AND DP_EXCPT_SKU.DELIVERYDATE = DP_INPLAN.SLIPDT
        	AND DP_EXCPT_SKU.SLIPNO = DP_INPLAN.SLIPNO
        LEFT JOIN FRAMEONE_USER
            ON FRAMEONE_USER.USER_ID = DP_EXCPT_SKU.EDITWHO
        WHERE DP_INPLAN.DCCODE = #{dccode}
            AND DP_INPLAN.STORERKEY = #{storerkey}
            AND DP_INPLAN.SLIPDT = #{slipdt}
            AND DP_INPLAN.SLIPNO = #{slipno}
            <!-- 상품 다중선택 -->
            <if test="skuMulti != null and skuMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="skuMulti" item="item">
                        OR DP_INPLAN.SKU IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
            <if test="docnoMulti != null and docnoMulti != ''">
                AND DP_INPLAN.DOCNO IN
                <foreach collection="docnoMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            <if test="ordertypeMulti != null and ordertypeMulti != ''">
                AND DP_INPLAN.ORDERTYPE IN
                <foreach collection="ordertypeMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            <if test='crossyn == "Y"'>
                AND MS_SKUDCSET.CROSSDOCKTYPE = 'CROSS'
            </if>
<!--            AND DP_INPLAN.ORDERQTY <![CDATA[>]]> 0 /** 결품으로만 확정완료된건은 안보이게 하기위해서 */-->
            <if test="blno != null and blno != ''">
                AND ST_SNINFO.CONVSERIALNO = #{blno}
            </if>
            <if test="serialno != null and serialno != ''">
                AND ST_SNINFO.SERIALNO = #{serialno}
            </if>
            <if test="wdCustkey != null and wdCustkey != ''">
                AND ST_SNINFO.CONTRACTCUSTKEY = #{wdCustkey}
            </if>
            <if test='crossyn == "Y"'>
                AND MS_SKUDCSET.CROSSDOCKTYPE = 'CROSS'
            </if>
        UNION ALL<!--2번-->
        SELECT /* [dpReceiptService.sqlx][dpReceiptService.getDataDetailSerialList][입고확정처리 이력상품 문서 Detail정보] */
            '0' AS CHECKYN,
            DP_INPLAN.DCCODE AS DCCODE,
            DP_INPLAN.STORERKEY AS STORERKEY,
            DP_INPLAN.ORGANIZE AS ORGANIZE,
            DP_INPLAN.DOCDT AS DOCDT,
            DP_INPLAN.DOCNO AS DOCNO,
            DP_INPLAN.DOCLINE AS DOCLINE,
            DP_INPLAN.SLIPDT AS SLIPDT,
            DP_INPLAN.SLIPNO AS SLIPNO,
            DP_INPLAN.SLIPLINE AS SLIPLINE,
            DP_INPLAN.SKU AS SKU,
            MS_SKU.DESCRIPTION AS SKUNAME,
            '[' || MS_SKU.COUNTRYOFORIGIN || ']' || (
                SELECT BASEDESCR
                FROM CM_CODE
                WHERE CM_CODE.STORERKEY = MS_SKU.STORERKEY
                    AND CM_CODE.CODELIST = 'COUNTRY'
                    AND CM_CODE.BASECODE = MS_SKU.COUNTRYOFORIGIN
                    AND CM_CODE.DEL_YN = 'N'
            ) AS COUNTRYOFORIGIN,
            DM_DOCUMENT_D.STORERUOM AS UOM,
            DM_DOCUMENT_D.BUNJA AS BUNJA,
            DM_DOCUMENT_D.BUNMO AS BUNMO,
            FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY, DM_DOCUMENT_D.SKU, DM_DOCUMENT_D.STORERUOM, 'EA', DP_INPLAN.OPENQTY) AS OPENQTY_EA,
            CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY, DM_DOCUMENT_D.SKU, DM_DOCUMENT_D.STORERUOM, 'BOX', DP_INPLAN.OPENQTY)) AS OPENQTY_BOX,
            DECODE(MS_SKU.BOXPERPLT, 0, 0, CEIL(CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY, DM_DOCUMENT_D.SKU, DM_DOCUMENT_D.STORERUOM, 'BOX', DP_INPLAN.OPENQTY)) / MS_SKU.BOXPERPLT)) AS PLTQTY,
            FN_UOMCAL(DM_DOCUMENT_D.BUNMO, DM_DOCUMENT_D.BUNJA, DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY) AS ORDERQTY,
            ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU, DP_INPLAN.UOM, 'KG', DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY), 2) AS ORDERWEIGHT,
            FN_UOMCAL(DM_DOCUMENT_D.BUNMO, DM_DOCUMENT_D.BUNJA, DP_INPLAN.INSPECTQTY) AS INSPECTQTY,
            FN_UOMCAL(DM_DOCUMENT_D.BUNMO, DM_DOCUMENT_D.BUNJA, DP_INPLAN.CONFIRMQTY) AS CONFIRMQTY
        <if test='workprocesscode == "STO"'>
            ,FN_UOMCAL ( DM_DOCUMENT_D_WD.BUNMO
            ,DM_DOCUMENT_D_WD.BUNJA
            ,DM_DOCUMENT_D_WD.CONFIRMQTY ) AS CONFIRMQTY_WD
            ,1 AS STO_FLAG
        </if>
        <if test='workprocesscode != "STO"'>
            ,0 AS CONFIRMQTY_WD
            ,0 AS STO_FLAG
        </if>
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.CANCELQTY ) AS SHORTAGEQTY
            ,0 AS SHORTAGETRANQTY
            ,0 AS TRANQTY
            ,CORE_CM_STRATEGY.FN_GETTOLOC ( DP_INPLAN.DOCTYPE
            ,DP_INPLAN.DCCODE
            ,DP_INPLAN.STORERKEY
            ,DP_INPLAN.ORDERTYPE
            ,DP_INPLAN.SLIPTYPE ) AS TOLOC
            ,NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01) AS LOTTABLE01
            --, NVL(CASE WHEN MS_SKU.DURATIONTYPE = '1' AND REGEXP_LIKE(NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01), '^[0-9]{8}$')
            --THEN TO_CHAR(TO_DATE(NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01),'YYYYMMDD') - (MS_SKU.DURATION - 1), 'YYYYMMDD')
            --ELSE NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01)
            --END,'STD') AS LOT_MANUFACTURE                    /** 제조 */
            --, NVL(CASE WHEN MS_SKU.DURATIONTYPE != '1' AND REGEXP_LIKE(NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01), '^[0-9]{8}$')
            --THEN TO_CHAR(TO_DATE(NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01),'YYYYMMDD') + (MS_SKU.DURATION - 1), 'YYYYMMDD')
            --ELSE NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01)
            --END,'STD') AS LOT_EXPIRE                         /** 유통 */
            --
            ,LOGISONESVC.FN_LOTTABLE_INFO('1',DP_INPLAN.STORERKEY,NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01),MS_SKU.DURATIONTYPE,MS_SKU.DURATION,'') AS LOT_MANUFACTURE /*제조일자*/
            ,LOGISONESVC.FN_LOTTABLE_INFO('2',DP_INPLAN.STORERKEY,NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01),MS_SKU.DURATIONTYPE,MS_SKU.DURATION,'') AS LOT_EXPIRE      /*소비일자*/
            --             
            ,FN_LOTDURATION(DP_INPLAN.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01), 'N')||'/'||MS_SKU.DURATION AS DURATION_TERM
            ,MS_SKU.COLORDESCR AS COLORDESCR
            ,DM_DOCUMENT_D.REFERENCE02 AS REFERENCE02
            ,DM_DOCUMENT_D.REASONCODE AS REASONCODE
            ,DM_DOCUMENT_D.REASONMSG AS REASONMSG
            ,CASE WHEN NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01)='STD' THEN 'N'
            WHEN MONTHS_BETWEEN(TO_DATE(NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01),'yyyy-mm-dd'),SYSDATE)>3 THEN 'N' ELSE 'Y' END AS NEARDURATIONYN
            ,DM_DOCUMENT_D.STATUS AS STATUS
            ,FN_CODEDESCR(DM_DOCUMENT_D.STORERKEY,'STATUS_DP', DM_DOCUMENT_D.STATUS) AS STATUSNAME
            ,MS_SKU.QTYPERBOX AS QTYPERBOX
            ,DM_DOCUMENT_D.CHANNEL AS CHANNEL
            ,MS_SKU.DURATION AS DURATION
            ,0 AS DURATION_RATE
            ,MS_SKU.DURATIONTYPE AS DURATIONTYPE
            ,UNISTR('') AS LASTLOTTABLE01
            ,NVL(ST_SNINFO.STOCKID,DP_INPLAN.STOCKID) AS STOCKID
            ,DP_INPLAN.STOCKGRADE AS STOCKGRADE
            ,DECODE(SPDP_RECEIPT.FN_GETTOLOC( DP_INPLAN.DCCODE
            ,DP_INPLAN.STORERKEY
            ,DP_INPLAN.SKU
            ,DM_DOCUMENT_D.PLANT
            ,DM_DOCUMENT_D.STORAGELOC
            ,DM_DOCUMENT_D.CHANNEL
            ),'CROSS','CROSS','STAGE') AS CROSSLOC
            ,DM_DOCUMENT_D.PLANT AS PLANT
            ,'['||DM_DOCUMENT_D.PLANT||']'||fn_descr_plant(DM_DOCUMENT_D.PLANT) AS PLANT_DESCR
            ,FN_CODEDESCR(DP_INPLAN.STORERKEY,'PUTAWAYTYPE', DM_DOCUMENT_D.CHANNEL) AS CHANNEL_NAME
            ,FN_CODEDESCR(MS_SKU.STORERKEY,'STORAGETYPE', MS_SKU.STORAGETYPE) AS STORAGETYPENAME
            ,MS_SKU.STORAGETYPE AS STORAGETYPE
            ,ST_SNINFO.SERIALNO AS SERIALNO
            ,ST_SNINFO.CONVSERIALNO AS CONVSERIALNO
            ,ST_SNINFO.FACTORYNAME AS FACTORYNAME
            ,ST_SNINFO.CONTRACTCUSTKEY AS CONTRACTCOMPANY
            ,( SELECT DESCRIPTION FROM MS_CUST
            WHERE CUSTKEY = ST_SNINFO.CONTRACTCUSTKEY
            AND ROWNUM = 1) AS CONTRACTCOMPANYNAME
            ,FN_CODEDESCR(ST_SNINFO.STORERKEY,'CONTRACTTYPE_SN',ST_SNINFO.CONTRACTTYPE) AS CONTRACTTYPE
            ,ST_SNINFO.BUTCHERYDT AS BUTCHERYDT
            ,ST_SNINFO.FROMVALIDDT AS FROMVALIDDT
            ,ST_SNINFO.TOVALIDDT AS TOVALIDDT
            ,ST_SNINFO.STOCKID AS BARCODE
            ,CASE WHEN ST_SNINFO.STOCKID IS NULL THEN NULL
            ELSE FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INVOICE_SN.ORDERQTY - DP_INVOICE_SN.CONFIRMQTY)
            END                                                                                                                           AS SERIALORDERQTY
            ,CASE WHEN ST_SNINFO.STOCKID IS NULL THEN NULL
            ELSE 0
            END                                                                                                                           AS SERIALINSPECTQTY
            ,CASE WHEN ST_SNINFO.STOCKID IS NULL THEN NULL
            ELSE 0
            END                                                                                                                           AS SERIALSCANWEIGHT
            ,CASE WHEN DP_INPLAN.STORERKEY = 'CJFW'
            OR DP_INPLAN.DCCODE IN
            (SELECT BASECODE
            FROM CM_CODE
            WHERE CM_CODE.STORERKEY = MS_SKU.STORERKEY
            AND CM_CODE.CODELIST = 'WITHOUTPDA_DP'
            AND CM_CODE.DEL_YN = 'N')
            OR ( ST_SNINFO.SERIALNO IS NOT NULL
            AND ( DM_DOCUMENT_D.CHANNEL <![CDATA[<>]]> '1'
            OR DP_INPLAN.DCCODE = '2170')
            ) THEN 'Y'
            ELSE 'N'
            END AS CHECKFLAG
            ,MS_SKU.LINE01 AS LINE01
            ,MS_SKU.SERIALYN AS SERIALYN
            ,CASE WHEN DP_INPLAN.STORERKEY = 'FW00' AND ST_SNINFO.SERIALNO IS NULL THEN 'gray' ELSE 'black' END AS FONTCOLOR
            ,CASE WHEN MS_DC_PLT_LOAD.BOXPERLAYER IS NOT NULL AND MS_DC_PLT_LOAD.LAYERPERPLT IS NOT NULL
                THEN MS_DC_PLT_LOAD.BOXPERLAYER * MS_DC_PLT_LOAD.LAYERPERPLT
                ELSE MS_SKUCHAIN.BOXPERPLT
            END AS BOXPERPLT
            ,MS_DC_PLT_LOAD.BOXPERLAYER AS BOXPERLAYER /** 방수 */
            ,MS_DC_PLT_LOAD.LAYERPERPLT AS LAYERPERPLT /** 단수 */
            , DP_EXCPT_SKU.EXCPT_YN AS EXCPT_YN  /** 입고예외여부 */
            , DP_EXCPT_SKU.EXCPT_YN AS EXCPT_YN_ORI  /** 입고예외여부 */
            , DP_EXCPT_SKU.DRAFT_NO AS DRAFT_NO  /** 기안번호 */
            , DP_EXCPT_SKU.SLIPLINE_SEQ AS SLIPLINE_SEQ  /** SEQ */
            , DP_EXCPT_SKU.EDITWHO AS EDITWHO  /** 최종변경자 */
            , FRAMEONE_USER.USER_NM AS EDITWHO_NAME /** 예외입력자 이름 */
        FROM DP_INPLAN
        JOIN CM_USER_AUTHORITY
            ON CM_USER_AUTHORITY.USERID = #{gUserId}
            AND CM_USER_AUTHORITY.DCCODE = DP_INPLAN.DCCODE
            AND CM_USER_AUTHORITY.STORERKEY = DP_INPLAN.STORERKEY
            AND CM_USER_AUTHORITY.ORGANIZE = DP_INPLAN.ORGANIZE
            AND CM_USER_AUTHORITY.AREA = DP_INPLAN.AREA
            <if test="fixdccode != null and fixdccode != ''">AND CM_USER_AUTHORITY.DCCODE = #{fixdccode}</if>
            <if test="gStorerkey != null and gStorerkey != ''">AND CM_USER_AUTHORITY.STORERKEY = #{gStorerkey}</if>
            <if test="gOrganize != null and gOrganize != ''">AND CM_USER_AUTHORITY.ORGANIZE = #{fixdccode}</if>
            <if test="gArea != null and gArea != ''">AND CM_USER_AUTHORITY.AREA = #{gArea}</if>
        JOIN DM_DOCUMENT_H
            ON DM_DOCUMENT_H.DCCODE = DP_INPLAN.DCCODE
            AND DM_DOCUMENT_H.STORERKEY = DP_INPLAN.STORERKEY
            AND DM_DOCUMENT_H.DELIVERYDATE = DP_INPLAN.SLIPDT
            AND DM_DOCUMENT_H.DOCTYPE = DP_INPLAN.DOCTYPE
            AND DM_DOCUMENT_H.DOCNO = DP_INPLAN.DOCNO
            AND DM_DOCUMENT_H.DOCTYPE = 'DP'
            AND DM_DOCUMENT_H.DEL_YN = 'N'
            <!-- 협력사 다중선택 -->
            <if test="fromCustkeyMulti != null and fromCustkeyMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="fromCustkeyMulti" item="item">
                        OR DM_DOCUMENT_H.FROM_CUSTKEY IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
        JOIN DM_DOCUMENT_D
            ON DM_DOCUMENT_D.DCCODE = DP_INPLAN.DCCODE
            AND DM_DOCUMENT_D.STORERKEY = DP_INPLAN.STORERKEY
            AND DM_DOCUMENT_D.DOCTYPE = DP_INPLAN.DOCTYPE
            AND DM_DOCUMENT_D.DELIVERYDATE = DP_INPLAN.SLIPDT
            AND DM_DOCUMENT_D.DOCNO = DP_INPLAN.DOCNO
            AND DM_DOCUMENT_D.DOCLINE = DP_INPLAN.DOCLINE
            AND DM_DOCUMENT_D.CHANNEL = '1'   <!-- 저장품만 처리함 1.저장 2.일배 3.광역일배 2015.01.26 SLLEE MODIFY [ 1,2] 김해경님 요청 -->
            <if test="channel != null and channel != ''">AND DM_DOCUMENT_D.CHANNEL LIKE #{channel}</if>
            AND DM_DOCUMENT_D.DEL_YN = 'N'
            <if test='workprocesscode == "STO"'>
                JOIN
                DM_DOCUMENT_D DM_DOCUMENT_D_WD
                ON DM_DOCUMENT_D_WD.DOCNO = DP_INPLAN.DOCNO
                AND DM_DOCUMENT_D_WD.DOCLINE = DP_INPLAN.DOCLINE
                AND DM_DOCUMENT_D_WD.DOCTYPE = 'WD'
                AND DM_DOCUMENT_D_WD.WORKPROCESSCODE = 'STO'
            </if>
        JOIN MS_SKU
            ON MS_SKU.STORERKEY = DP_INPLAN.STORERKEY
            AND MS_SKU.SKU = DP_INPLAN.SKU
            AND MS_SKU.SERIALYN = DECODE(DP_INPLAN.DCCODE,'2170',MS_SKU.SERIALYN,'Y')
            <if test="storagetype != null and storagetype != ''">AND MS_SKU.STORAGETYPE LIKE #{storagetype}</if>
        LEFT OUTER JOIN MS_SKUDCSET
            ON MS_SKUDCSET.STORERKEY = DM_DOCUMENT_D.STORERKEY
            AND MS_SKUDCSET.DCCODE = DM_DOCUMENT_D.DCCODE
            AND MS_SKUDCSET.SKU = DM_DOCUMENT_D.SKU
        LEFT OUTER JOIN DP_INVOICE_SN
            ON DP_INVOICE_SN.DCCODE = DP_INPLAN.DCCODE
            AND DP_INVOICE_SN.STORERKEY = DP_INPLAN.STORERKEY
            AND DP_INVOICE_SN.DOCTYPE = DP_INPLAN.DOCTYPE
            AND DP_INVOICE_SN.SLIPNO = DP_INPLAN.SLIPNO
            AND DP_INVOICE_SN.SLIPDT = DP_INPLAN.SLIPDT
            AND DP_INVOICE_SN.SLIPLINE = DP_INPLAN.SLIPLINE
            AND DP_INVOICE_SN.SKU = DP_INPLAN.SKU
        <!--2026-01-04 FWNEXTWMS-5657 결품처리시 합쳐지는것 수정-->
            AND DP_INVOICE_SN.ORDERQTY - DP_INVOICE_SN.CONFIRMQTY > 0
        LEFT OUTER JOIN ST_SNINFO
            ON ST_SNINFO.STORERKEY = DP_INVOICE_SN.STORERKEY
            AND ST_SNINFO.SKU = DP_INVOICE_SN.SKU
            AND ST_SNINFO.SERIALNO = DP_INVOICE_SN.SERIALNO
            AND ST_SNINFO.STOCKID = DP_INVOICE_SN.STOCKID
        LEFT OUTER JOIN MS_SKUCHAIN
            ON MS_SKUCHAIN.SKU = DP_INPLAN.SKU
            AND MS_SKUCHAIN.STORERKEY = DP_INPLAN.STORERKEY
            AND MS_SKUCHAIN.DEL_YN = 'N'
        LEFT OUTER JOIN MS_DC_PLT_LOAD
            ON MS_DC_PLT_LOAD.DCCODE = DP_INPLAN.DCCODE
            AND MS_DC_PLT_LOAD.PLANT = DM_DOCUMENT_D.PLANT
            AND MS_DC_PLT_LOAD.STORERKEY = DP_INPLAN.STORERKEY
            AND MS_DC_PLT_LOAD.SKU = DP_INPLAN.SKU
            AND MS_DC_PLT_LOAD.CUSTKEY = DP_INPLAN.CUSTKEY
        LEFT JOIN T_DP_EXCPT_SKU DP_EXCPT_SKU
        	ON DP_EXCPT_SKU.SKU = DP_INPLAN.SKU
        	AND DP_EXCPT_SKU.DELIVERYDATE = DP_INPLAN.SLIPDT
        	AND DP_EXCPT_SKU.SLIPNO = DP_INPLAN.SLIPNO
        LEFT JOIN FRAMEONE_USER
            ON FRAMEONE_USER.USER_ID = DP_EXCPT_SKU.EDITWHO
        WHERE DP_INPLAN.DCCODE = #{dccode}
            AND DP_INPLAN.STORERKEY = #{storerkey}
            AND DP_INPLAN.SLIPDT = #{slipdt}
            AND DP_INPLAN.SLIPNO = #{slipno}
            <!-- 상품 다중선택 -->
            <if test="skuMulti != null and skuMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="skuMulti" item="item">
                        OR DP_INPLAN.SKU IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
            <if test="docnoMulti != null and docnoMulti != ''">
                AND DP_INPLAN.DOCNO IN
                <foreach collection="docnoMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            <if test="ordertypeMulti != null and ordertypeMulti != ''">
                AND DP_INPLAN.ORDERTYPE IN
                <foreach collection="ordertypeMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
<!--2026-01-04 FWNEXTWMS-5657 결품처리시 합쳐지는것 수정-->
<!--            AND DP_INPLAN.ORDERQTY  <![CDATA[>]]> 0 /** 결품으로만 확정완료된건은 안보이게 하기위해서 */-->
<!--            AND DP_INPLAN.ORDERQTY - DP_INPLAN.CONFIRMQTY <![CDATA[>]]> 0-->

            <if test="blno != null and blno != ''">
                AND ST_SNINFO.CONVSERIALNO = #{blno}
            </if>
            <if test="serialno != null and serialno != ''">
                AND ST_SNINFO.SERIALNO = #{serialno}
            </if>
            <if test="wdCustkey != null and wdCustkey != ''">
                AND ST_SNINFO.CONTRACTCUSTKEY = #{wdCustkey}
            </if>
            <if test='crossyn == "Y"'>
                    AND MS_SKUDCSET.CROSSDOCKTYPE = 'CROSS'
            </if>
        UNION ALL
        SELECT<!--3번-->
            '0' AS CHECKYN
            ,DP_INPLAN.DCCODE AS DCCODE
            ,DP_INPLAN.STORERKEY AS STORERKEY
            ,DP_INPLAN.ORGANIZE AS ORGANIZE
            ,DP_INPLAN.DOCDT AS DOCDT
            ,DP_INPLAN.DOCNO AS DOCNO
            ,DP_INPLAN.DOCLINE AS DOCLINE
            ,DP_INPLAN.SLIPDT AS SLIPDT
            ,DP_INPLAN.SLIPNO AS SLIPNO
            ,DP_INPLAN.SLIPLINE AS SLIPLINE
            ,DP_INPLAN.SKU AS SKU
            ,MS_SKU.DESCRIPTION AS SKUNAME
            ,'[' || MS_SKU.COUNTRYOFORIGIN || ']' ||
            (SELECT BASEDESCR
            FROM CM_CODE
            WHERE CM_CODE.STORERKEY = MS_SKU.STORERKEY
            AND CM_CODE.CODELIST = 'COUNTRY'
            AND CM_CODE.BASECODE = MS_SKU.COUNTRYOFORIGIN
            AND CM_CODE.DEL_YN = 'N') AS COUNTRYOFORIGIN
            ,DM_DOCUMENT_D.STORERUOM AS UOM
            ,DM_DOCUMENT_D.BUNJA AS BUNJA
            ,DM_DOCUMENT_D.BUNMO AS BUNMO
            ,FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'EA',DP_INPLAN.OPENQTY) AS OPENQTY_EA
            ,CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY)) AS OPENQTY_BOX
            ,DECODE(MS_SKU.BOXPERPLT,0,0,CEIL(CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY)) /
            MS_SKU.BOXPERPLT)) AS PLTQTY
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY ) AS ORDERQTY
            ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU , DP_INPLAN.UOM, 'KG',DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY),2) AS ORDERWEIGHT
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.INSPECTQTY) AS INSPECTQTY
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.CONFIRMQTY) AS CONFIRMQTY
            <if test='workprocesscode == "STO"'>
                ,FN_UOMCAL ( DM_DOCUMENT_D_WD.BUNMO
                ,DM_DOCUMENT_D_WD.BUNJA
                ,DM_DOCUMENT_D_WD.CONFIRMQTY ) AS CONFIRMQTY_WD
                ,1 AS STO_FLAG
            </if>
            <if test='workprocesscode != "STO"'>
                ,0 AS CONFIRMQTY_WD
                ,0 AS STO_FLAG
            </if>
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.CANCELQTY ) AS SHORTAGEQTY
            ,0 AS SHORTAGETRANQTY
            ,0 AS TRANQTY
            ,CORE_CM_STRATEGY.FN_GETTOLOC ( DP_INPLAN.DOCTYPE
            ,DP_INPLAN.DCCODE
            ,DP_INPLAN.STORERKEY
            ,DP_INPLAN.ORDERTYPE
            ,DP_INPLAN.SLIPTYPE ) AS TOLOC
            ,NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01) AS LOTTABLE01
            --, NVL(CASE WHEN MS_SKU.DURATIONTYPE = '1' AND REGEXP_LIKE(NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01), '^[0-9]{8}$')
            --THEN TO_CHAR(TO_DATE(NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01),'YYYYMMDD') - (MS_SKU.DURATION - 1), 'YYYYMMDD')
            --ELSE NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01)
            --END,'STD') AS LOT_MANUFACTURE                    /** 제조 */
            --, NVL(CASE WHEN MS_SKU.DURATIONTYPE != '1' AND REGEXP_LIKE(NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01), '^[0-9]{8}$')
            --THEN TO_CHAR(TO_DATE(NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01),'YYYYMMDD') + (MS_SKU.DURATION - 1), 'YYYYMMDD')
            --ELSE NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01)
            --END,'STD') AS LOT_EXPIRE                         /** 유통 */
            --
            ,LOGISONESVC.FN_LOTTABLE_INFO('1',DP_INPLAN.STORERKEY,NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01),MS_SKU.DURATIONTYPE,MS_SKU.DURATION,'') AS LOT_MANUFACTURE /*제조일자*/
            ,LOGISONESVC.FN_LOTTABLE_INFO('2',DP_INPLAN.STORERKEY,NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01),MS_SKU.DURATIONTYPE,MS_SKU.DURATION,'') AS LOT_EXPIRE      /*소비일자*/
            --                
            ,FN_LOTDURATION(DP_INPLAN.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01), 'N')||'/'||MS_SKU.DURATION AS DURATION_TERM
            ,MS_SKU.COLORDESCR AS COLORDESCR
            ,DM_DOCUMENT_D.REFERENCE02 AS REFERENCE02
            ,DM_DOCUMENT_D.REASONCODE AS REASONCODE
            ,DM_DOCUMENT_D.REASONMSG AS REASONMSG
            ,CASE WHEN NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01)='STD' THEN 'N'
            WHEN MONTHS_BETWEEN(TO_DATE(NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01),'yyyy-mm-dd'),SYSDATE)>3 THEN 'N' ELSE 'Y' END AS NEARDURATIONYN
            ,DM_DOCUMENT_D.STATUS AS STATUS
            ,FN_CODEDESCR(DM_DOCUMENT_D.STORERKEY,'STATUS_DP', DM_DOCUMENT_D.STATUS) AS STATUSNAME
            ,MS_SKU.QTYPERBOX AS QTYPERBOX
            ,DM_DOCUMENT_D.CHANNEL AS CHANNEL
            ,MS_SKU.DURATION AS DURATION
            ,0 AS DURATION_RATE
            ,MS_SKU.DURATIONTYPE AS DURATIONTYPE
            ,UNISTR('') AS LASTLOTTABLE01
            ,NVL(ST_SNINFO.STOCKID,DP_INPLAN.STOCKID) AS STOCKID
            ,DP_INPLAN.STOCKGRADE AS STOCKGRADE
            ,DECODE(SPDP_RECEIPT.FN_GETTOLOC( DP_INPLAN.DCCODE
            ,DP_INPLAN.STORERKEY
            ,DP_INPLAN.SKU
            ,DM_DOCUMENT_D.PLANT
            ,DM_DOCUMENT_D.STORAGELOC
            ,DM_DOCUMENT_D.CHANNEL
            ),'CROSS','CROSS','STAGE') AS CROSSLOC
            ,DM_DOCUMENT_D.PLANT AS PLANT
            ,'['||DM_DOCUMENT_D.PLANT||']'||fn_descr_plant(DM_DOCUMENT_D.PLANT) AS PLANT_DESCR
            ,FN_CODEDESCR(DP_INPLAN.STORERKEY,'PUTAWAYTYPE', DM_DOCUMENT_D.CHANNEL) AS CHANNEL_NAME
            ,FN_CODEDESCR(MS_SKU.STORERKEY,'STORAGETYPE', MS_SKU.STORAGETYPE) AS STORAGETYPENAME
            ,MS_SKU.STORAGETYPE AS STORAGETYPE
            ,ST_SNINFO.SERIALNO AS SERIALNO
            ,ST_SNINFO.CONVSERIALNO AS CONVSERIALNO
            ,ST_SNINFO.FACTORYNAME AS FACTORYNAME
            ,ST_SNINFO.CONTRACTCUSTKEY AS CONTRACTCOMPANY
            ,( SELECT DESCRIPTION FROM MS_CUST
            WHERE CUSTKEY = ST_SNINFO.CONTRACTCUSTKEY
            AND ROWNUM = 1) AS CONTRACTCOMPANYNAME
            ,FN_CODEDESCR(ST_SNINFO.STORERKEY,'CONTRACTTYPE_SN',ST_SNINFO.CONTRACTTYPE) AS CONTRACTTYPE
            ,ST_SNINFO.BUTCHERYDT AS BUTCHERYDT
            ,ST_SNINFO.FROMVALIDDT AS FROMVALIDDT
            ,ST_SNINFO.TOVALIDDT AS TOVALIDDT
            ,ST_SNINFO.STOCKID AS BARCODE
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INVOICE_SN.ORDERQTY)                                                                                           AS SERIALORDERQTY
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INVOICE_SN.CONFIRMQTY)                                                                                         AS SERIALINSPECTQTY
            ,CASE WHEN DP_INPLAN.STORERKEY = 'CJFW' THEN CASE WHEN DP_INPLAN.UOM = 'KG' THEN DP_INVOICE_SN.CONFIRMQTY
            ELSE DP_INVOICE_SN.CONFIRMQTY * ST_SNINFO.NETWEIGHT
            END
            ELSE FN_CONV_UOM(DP_INPLAN.STORERKEY,DP_INPLAN.SKU,DP_INPLAN.UOM,'KG',DP_INVOICE_SN.CONFIRMQTY)
            END                                                                                                                           AS SERIALSCANWEIGHT
            ,CASE WHEN DP_INPLAN.STORERKEY = 'CJFW'
            OR ( ST_SNINFO.SERIALNO IS NOT NULL
            AND ( DM_DOCUMENT_D.CHANNEL <![CDATA[<>]]> '1'
            OR DP_INPLAN.DCCODE = '2170')
            ) THEN 'Y'
            ELSE 'N'
            END AS CHECKFLAG
            ,MS_SKU.LINE01 AS LINE01
            ,MS_SKU.SERIALYN AS SERIALYN
            ,CASE WHEN DP_INPLAN.STORERKEY = 'FW00' AND ST_SNINFO.SERIALNO IS NULL THEN 'gray' ELSE 'black' END AS FONTCOLOR
            ,CASE WHEN MS_DC_PLT_LOAD.BOXPERLAYER IS NOT NULL AND MS_DC_PLT_LOAD.LAYERPERPLT IS NOT NULL
                THEN MS_DC_PLT_LOAD.BOXPERLAYER * MS_DC_PLT_LOAD.LAYERPERPLT
                ELSE MS_SKUCHAIN.BOXPERPLT
            END AS BOXPERPLT
            ,MS_DC_PLT_LOAD.BOXPERLAYER AS BOXPERLAYER /** 방수 */
            ,MS_DC_PLT_LOAD.LAYERPERPLT AS LAYERPERPLT /** 단수 */
            , DP_EXCPT_SKU.EXCPT_YN AS EXCPT_YN  /** 입고예외여부 */
            , DP_EXCPT_SKU.EXCPT_YN AS EXCPT_YN_ORI  /** 입고예외여부 */
            , DP_EXCPT_SKU.DRAFT_NO AS DRAFT_NO  /** 기안번호 */
            , DP_EXCPT_SKU.SLIPLINE_SEQ AS SLIPLINE_SEQ  /** SEQ */
            , DP_EXCPT_SKU.EDITWHO AS EDITWHO  /** 최종변경자 */
            , FRAMEONE_USER.USER_NM AS EDITWHO_NAME /** 예외입력자 이름 */
        FROM DP_INPLAN
        JOIN CM_USER_AUTHORITY
            ON CM_USER_AUTHORITY.USERID = #{gUserId}
            AND CM_USER_AUTHORITY.DCCODE = DP_INPLAN.DCCODE
            AND CM_USER_AUTHORITY.STORERKEY = DP_INPLAN.STORERKEY
            AND CM_USER_AUTHORITY.ORGANIZE = DP_INPLAN.ORGANIZE
            AND CM_USER_AUTHORITY.AREA = DP_INPLAN.AREA
            <if test="fixdccode != null and fixdccode != ''">AND CM_USER_AUTHORITY.DCCODE = #{fixdccode}</if>
            <if test="gStorerkey != null and gStorerkey != ''">AND CM_USER_AUTHORITY.STORERKEY = #{gStorerkey}</if>
            <if test="gOrganize != null and gOrganize != ''">AND CM_USER_AUTHORITY.ORGANIZE = #{fixdccode}</if>
            <if test="gArea != null and gArea != ''">AND CM_USER_AUTHORITY.AREA = #{gArea}</if>
        JOIN DM_DOCUMENT_H
            ON DM_DOCUMENT_H.DCCODE = DP_INPLAN.DCCODE
            AND DM_DOCUMENT_H.STORERKEY = DP_INPLAN.STORERKEY
            AND DM_DOCUMENT_H.DELIVERYDATE = DP_INPLAN.SLIPDT
            AND DM_DOCUMENT_H.DOCTYPE = DP_INPLAN.DOCTYPE
            AND DM_DOCUMENT_H.DOCNO = DP_INPLAN.DOCNO
            AND DM_DOCUMENT_H.DOCTYPE = 'DP'
            AND DM_DOCUMENT_H.DEL_YN = 'N'
            <!-- 협력사 다중선택 -->
            <if test="fromCustkeyMulti != null and fromCustkeyMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="fromCustkeyMulti" item="item">
                        OR DM_DOCUMENT_H.FROM_CUSTKEY IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
        JOIN DM_DOCUMENT_D
            ON DM_DOCUMENT_D.DCCODE = DP_INPLAN.DCCODE
            AND DM_DOCUMENT_D.STORERKEY = DP_INPLAN.STORERKEY
            AND DM_DOCUMENT_D.DOCTYPE = DP_INPLAN.DOCTYPE
            AND DM_DOCUMENT_D.DELIVERYDATE = DP_INPLAN.SLIPDT
            AND DM_DOCUMENT_D.DOCNO = DP_INPLAN.DOCNO
            AND DM_DOCUMENT_D.DOCLINE = DP_INPLAN.DOCLINE
            AND DM_DOCUMENT_D.CHANNEL IN ('2','3')   <!-- 저장품만 처리함 1.저장 2.일배 3.광역일배 2015.01.26 SLLEE MODIFY [ 1,2] 김해경님 요청 -->
            <if test="channel != null and channel != ''">AND DM_DOCUMENT_D.CHANNEL LIKE #{channel}</if>
            AND DM_DOCUMENT_D.DEL_YN = 'N'
            <if test='workprocesscode == "STO"'>
                JOIN
                DM_DOCUMENT_D DM_DOCUMENT_D_WD
                ON DM_DOCUMENT_D_WD.DOCNO = DP_INPLAN.DOCNO
                AND DM_DOCUMENT_D_WD.DOCLINE = DP_INPLAN.DOCLINE
                AND DM_DOCUMENT_D_WD.DOCTYPE = 'WD'
                AND DM_DOCUMENT_D_WD.WORKPROCESSCODE = 'STO'
            </if>
        JOIN MS_SKU
            ON MS_SKU.STORERKEY = DP_INPLAN.STORERKEY
            AND MS_SKU.SKU = DP_INPLAN.SKU
            AND MS_SKU.SERIALYN = DECODE(DP_INPLAN.DCCODE,'2170',MS_SKU.SERIALYN,'Y')
            <if test="storagetype != null and storagetype != ''">AND MS_SKU.STORAGETYPE LIKE #{storagetype}</if>
        LEFT OUTER JOIN MS_SKUDCSET
            ON MS_SKUDCSET.STORERKEY = DM_DOCUMENT_D.STORERKEY
            AND MS_SKUDCSET.DCCODE = DM_DOCUMENT_D.DCCODE
            AND MS_SKUDCSET.SKU = DM_DOCUMENT_D.SKU
        LEFT OUTER JOIN DP_INVOICE_SN
            ON DP_INVOICE_SN.DCCODE = DP_INPLAN.DCCODE
            AND DP_INVOICE_SN.STORERKEY = DP_INPLAN.STORERKEY
            AND DP_INVOICE_SN.DOCTYPE = DP_INPLAN.DOCTYPE
            AND DP_INVOICE_SN.SLIPNO = DP_INPLAN.SLIPNO
            AND DP_INVOICE_SN.SLIPDT = DP_INPLAN.SLIPDT
            AND DP_INVOICE_SN.SLIPLINE = DP_INPLAN.SLIPLINE
            AND DP_INVOICE_SN.SKU = DP_INPLAN.SKU
        <!--2026-01-04 FWNEXTWMS-5657 결품처리시 합쳐지는것 수정-->
<!--            AND ( ( DP_INVOICE_SN.CONFIRMQTY > 0-->
<!--            AND DP_INPLAN.ORDERQTY = DP_INPLAN.CONFIRMQTY)-->
<!--            OR ( DP_INPLAN.ORDERQTY > DP_INPLAN.CONFIRMQTY)-->
<!--            )-->
        LEFT OUTER JOIN ST_SNINFO
            ON ST_SNINFO.STORERKEY = DP_INVOICE_SN.STORERKEY
            AND ST_SNINFO.SKU = DP_INVOICE_SN.SKU
            AND ST_SNINFO.SERIALNO = DP_INVOICE_SN.SERIALNO
            AND ST_SNINFO.STOCKID = DP_INVOICE_SN.STOCKID
        LEFT OUTER JOIN MS_SKUCHAIN
            ON MS_SKUCHAIN.SKU = DP_INPLAN.SKU
            AND MS_SKUCHAIN.STORERKEY = DP_INPLAN.STORERKEY
            AND MS_SKUCHAIN.DEL_YN = 'N'
        LEFT OUTER JOIN MS_DC_PLT_LOAD
            ON MS_DC_PLT_LOAD.DCCODE = DP_INPLAN.DCCODE
            AND MS_DC_PLT_LOAD.PLANT = DM_DOCUMENT_D.PLANT
            AND MS_DC_PLT_LOAD.STORERKEY = DP_INPLAN.STORERKEY
            AND MS_DC_PLT_LOAD.SKU = DP_INPLAN.SKU
            AND MS_DC_PLT_LOAD.CUSTKEY = DP_INPLAN.CUSTKEY
        LEFT JOIN T_DP_EXCPT_SKU DP_EXCPT_SKU
        	ON DP_EXCPT_SKU.SKU = DP_INPLAN.SKU
        	AND DP_EXCPT_SKU.DELIVERYDATE = DP_INPLAN.SLIPDT
        	AND DP_EXCPT_SKU.SLIPNO = DP_INPLAN.SLIPNO
        LEFT JOIN FRAMEONE_USER
            ON FRAMEONE_USER.USER_ID = DP_EXCPT_SKU.EDITWHO
        WHERE DP_INPLAN.DCCODE = #{dccode}
            AND DP_INPLAN.STORERKEY = #{storerkey}
            AND DP_INPLAN.SLIPDT = #{slipdt}
            AND DP_INPLAN.SLIPNO = #{slipno}
            <!-- 상품 다중선택 -->
            <if test="skuMulti != null and skuMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="skuMulti" item="item">
                        OR DP_INPLAN.SKU IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
            <if test="docnoMulti != null and docnoMulti != ''">
                AND DP_INPLAN.DOCNO IN
                <foreach collection="docnoMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            <if test="ordertypeMulti != null and ordertypeMulti != ''">
                AND DP_INPLAN.ORDERTYPE IN
                <foreach collection="ordertypeMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
<!--            AND DP_INPLAN.ORDERQTY  <![CDATA[>]]> 0 /** 결품으로만 확정완료된건은 안보이게 하기위해서 */-->
            <if test="blno != null and blno != ''">
                AND ST_SNINFO.CONVSERIALNO = #{blno}
            </if>
            <if test="serialno != null and serialno != ''">
                AND ST_SNINFO.SERIALNO = #{serialno}
            </if>
            <if test="wdCustkey != null and wdCustkey != ''">
                AND ST_SNINFO.CONTRACTCUSTKEY = #{wdCustkey}
            </if>
            <if test='crossyn == "Y"'>
                    AND MS_SKUDCSET.CROSSDOCKTYPE = 'CROSS'
            </if>
        ORDER BY SLIPLINE
        ,SKU
    </select>

    <!-- 입고확정처리 이력상품 엑셀 -->
    <select id="getExcelList2" resultType="cjfw.wms.dp.dto.DpReceiptResExcelDto">
        SELECT /* [dpReceiptService.sqlx][dpReceiptService.getDataExcelSerialList][입고확정처리 이력상품 엑셀] */
            '0' AS CHECKYN
            ,DP_INPLAN.DCCODE AS DCCODE
            ,DP_INPLAN.STORERKEY AS STORERKEY
            ,DP_INPLAN.ORGANIZE AS ORGANIZE
            ,DP_INPLAN.DOCDT AS DOCDT
            ,DP_INPLAN.DOCNO AS DOCNO
            ,DP_INPLAN.DOCLINE AS DOCLINE
            ,DP_INPLAN.SLIPDT AS SLIPDT
            ,DP_INPLAN.SLIPNO AS SLIPNO
            ,DP_INPLAN.SLIPLINE AS SLIPLINE
            ,DM_DOCUMENT_H.POTYPE AS POTYPE
            ,FN_CODEDESCR(DM_DOCUMENT_H.STORERKEY
            ,'POTYPE_DP'
            ,DM_DOCUMENT_H.POTYPE) AS POTYPENAME
            ,fn_descr_organize(DM_DOCUMENT_H.DCCODE, DM_DOCUMENT_H.ORGANIZE) AS ORGANIZENAME
            ,DM_DOCUMENT_H.ORDERTYPE AS ORDERTYPE
            ,FN_CODEDESCR(DM_DOCUMENT_H.STORERKEY
            ,'ORDERTYPE_DP'
            ,DM_DOCUMENT_H.ORDERTYPE) AS ORDERTYPE_NAME
            ,DM_DOCUMENT_H.FROM_CUSTKEY AS FROM_CUSTKEY
            ,DM_DOCUMENT_H.FROM_CUSTNAME AS FROM_CUSTNAME
            ,DP_INPLAN.SKU AS SKU
            ,MS_SKU.DESCRIPTION AS SKUNAME
            ,'[' || MS_SKU.COUNTRYOFORIGIN || ']' ||
            (SELECT BASEDESCR
            FROM CM_CODE
            WHERE CM_CODE.STORERKEY = MS_SKU.STORERKEY
            AND CM_CODE.CODELIST = 'COUNTRY'
            AND CM_CODE.BASECODE = MS_SKU.COUNTRYOFORIGIN
            AND CM_CODE.DEL_YN = 'N') AS COUNTRYOFORIGIN
            ,DM_DOCUMENT_D.STORERUOM AS UOM
            ,DM_DOCUMENT_D.BUNJA AS BUNJA
            ,DM_DOCUMENT_D.BUNMO AS BUNMO
            ,FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'EA',DP_INPLAN.OPENQTY) AS OPENQTY_EA
            ,CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY)) AS OPENQTY_BOX
            ,DECODE(MS_SKU.BOXPERPLT,0,0,CEIL(CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY)) /
            MS_SKU.BOXPERPLT)) AS PLTQTY
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY ) AS ORDERQTY
            ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU , DP_INPLAN.UOM, 'KG',DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY),2) AS ORDERWEIGHT
            ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU, DP_INPLAN.UOM, 'KG', DP_INPLAN.CONFIRMQTY), 2) AS CONFIRMWEIGHT
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.INSPECTQTY ) AS INSPECTQTY
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.CONFIRMQTY ) AS CONFIRMQTY
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.CANCELQTY ) AS SHORTAGEQTY
            ,0 AS SHORTAGETRANQTY
            ,0 AS TRANQTY
            ,NVL(DP_INPLAN.TOLOC
            , CORE_CM_STRATEGY.FN_GETTOLOC ( DP_INPLAN.DOCTYPE
            ,DP_INPLAN.DCCODE
            ,DP_INPLAN.STORERKEY
            ,DP_INPLAN.ORDERTYPE
            ,DP_INPLAN.SLIPTYPE )) AS TOLOC
            ,DP_INPLAN.LOTTABLE01 AS LOTTABLE01
            ,FN_LOTDURATION(DP_INPLAN.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, DP_INPLAN.LOTTABLE01, 'N')||'/'||MS_SKU.DURATION AS DURATION_TERM
            ,MS_SKU.COLORDESCR AS COLORDESCR
            ,DM_DOCUMENT_D.REFERENCE02 AS REFERENCE02
            ,DM_DOCUMENT_D.REASONCODE AS REASONCODE
            ,DM_DOCUMENT_D.REASONMSG AS REASONMSG
            ,CASE WHEN DP_INPLAN.LOTTABLE01 ='STD' THEN 'N'
            WHEN MONTHS_BETWEEN(TO_DATE(DP_INPLAN.LOTTABLE01,'yyyy-mm-dd'),SYSDATE)>3 THEN 'N' ELSE 'Y' END AS NEARDURATIONYN
            ,DM_DOCUMENT_D.STATUS AS STATUS
            ,FN_CODEDESCR(DM_DOCUMENT_D.STORERKEY,'STATUS_DP', DM_DOCUMENT_D.STATUS) AS STATUSNAME
            ,MS_SKU.QTYPERBOX AS QTYPERBOX
            ,DM_DOCUMENT_D.CHANNEL AS CHANNEL
            ,MS_SKU.DURATION AS DURATION
            ,MS_SKU.DURATIONTYPE AS DURATIONTYPE
            ,UNISTR('') AS LASTLOTTABLE01
            ,DP_INPLAN.STOCKID AS STOCKID
            ,DP_INPLAN.STOCKGRADE AS STOCKGRADE
            ,DM_DOCUMENT_D.PLANT AS PLANT
            ,'['||DM_DOCUMENT_D.PLANT||']'||fn_descr_plant(DM_DOCUMENT_D.PLANT) AS PLANT_DESCR
            ,FN_CODEDESCR(DP_INPLAN.STORERKEY,'PUTAWAYTYPE', DM_DOCUMENT_D.CHANNEL) AS CHANNEL_NAME
            ,FN_CODEDESCR(MS_SKU.STORERKEY,'STORAGETYPE', MS_SKU.STORAGETYPE) AS STORAGETYPENAME

            ,ST_SNINFO.SERIALNO AS SERIALNO
            ,ST_SNINFO.CONVSERIALNO AS CONVSERIALNO
            ,ST_SNINFO.FACTORYNAME AS FACTORYNAME
            ,ST_SNINFO.CONTRACTCUSTKEY AS CONTRACTCOMPANY
            ,( SELECT DESCRIPTION FROM MS_CUST
            WHERE CUSTKEY = ST_SNINFO.CONTRACTCUSTKEY
            AND ROWNUM = 1) AS CONTRACTCOMPANYNAME
            ,ST_SNINFO.CONTRACTTYPE AS CONTRACTTYPE
            ,ST_SNINFO.BUTCHERYDT AS BUTCHERYDT
            ,ST_SNINFO.FROMVALIDDT AS FROMVALIDDT
            ,ST_SNINFO.TOVALIDDT AS TOVALIDDT
            ,ST_SNINFO.STOCKID AS BARCODE
            ,DP_INVOICE_SN.ORDERQTY AS SERIALORDERQTY
            ,DP_INVOICE_SN.CONFIRMQTY AS SERIALINSPECTQTY
            ,CASE WHEN DP_INPLAN.STORERKEY = 'CJFW' THEN CASE WHEN DP_INPLAN.UOM = 'KG' THEN DP_INVOICE_SN.CONFIRMQTY
            ELSE DP_INVOICE_SN.CONFIRMQTY * ST_SNINFO.NETWEIGHT
            END
            ELSE FN_CONV_UOM(DP_INPLAN.STORERKEY,DP_INPLAN.SKU,DP_INPLAN.UOM,'KG',DP_INVOICE_SN.CONFIRMQTY)
            END AS SERIALSCANWEIGHT
          , NVL(CASE WHEN MS_SKU.DURATIONTYPE = '1' AND REGEXP_LIKE(DP_INPLAN.LOTTABLE01, '^[0-9]{8}$')
                     THEN TO_CHAR(TO_DATE(DP_INPLAN.LOTTABLE01,'YYYYMMDD') - (MS_SKU.DURATION - 1), 'YYYYMMDD')
                     ELSE DP_INPLAN.LOTTABLE01 END,'STD')                                                                                         AS MANUFACTUREDT   /* 기준일(제조) */
          , NVL(CASE WHEN MS_SKU.DURATIONTYPE != '1' AND REGEXP_LIKE(DP_INPLAN.LOTTABLE01, '^[0-9]{8}$')                                                              
                     THEN TO_CHAR(TO_DATE(DP_INPLAN.LOTTABLE01,'YYYYMMDD') + (MS_SKU.DURATION - 1), 'YYYYMMDD')
                     ELSE DP_INPLAN.LOTTABLE01 END,'STD')                                                                                         AS EXPIREDT        /* 기준일(소비) */	                  
        FROM DP_INPLAN
        JOIN CM_USER_AUTHORITY
            ON CM_USER_AUTHORITY.USERID = #{gUserId}
            AND CM_USER_AUTHORITY.DCCODE = DP_INPLAN.DCCODE
            AND CM_USER_AUTHORITY.STORERKEY = DP_INPLAN.STORERKEY
            AND CM_USER_AUTHORITY.ORGANIZE = DP_INPLAN.ORGANIZE
            AND CM_USER_AUTHORITY.AREA = DP_INPLAN.AREA
            <if test="fixdccode != null and fixdccode != ''">AND CM_USER_AUTHORITY.DCCODE = #{fixdccode}</if>
            <if test="gStorerkey != null and gStorerkey != ''">AND CM_USER_AUTHORITY.STORERKEY = #{gStorerkey}</if>
            <if test="gOrganize != null and gOrganize != ''">AND CM_USER_AUTHORITY.ORGANIZE = #{fixdccode}</if>
            <if test="gArea != null and gArea != ''">AND CM_USER_AUTHORITY.AREA = #{gArea}</if>
        JOIN DM_DOCUMENT_H
            ON DM_DOCUMENT_H.DCCODE = DP_INPLAN.DCCODE
            AND DM_DOCUMENT_H.STORERKEY = DP_INPLAN.STORERKEY
            AND DM_DOCUMENT_H.DELIVERYDATE = DP_INPLAN.SLIPDT
            AND DM_DOCUMENT_H.DOCTYPE = DP_INPLAN.DOCTYPE
            AND DM_DOCUMENT_H.DOCNO = DP_INPLAN.DOCNO
            AND DM_DOCUMENT_H.DOCTYPE = 'DP'
            AND DM_DOCUMENT_H.DEL_YN = 'N'
            <!-- 협력사 다중선택 -->
            <if test="fromCustkeyMulti != null and fromCustkeyMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="fromCustkeyMulti" item="item">
                        OR DM_DOCUMENT_H.FROM_CUSTKEY IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
        JOIN DM_DOCUMENT_D
            ON DP_INPLAN.DCCODE = DM_DOCUMENT_D.DCCODE
            AND DP_INPLAN.DOCTYPE = DM_DOCUMENT_D.DOCTYPE
            AND DP_INPLAN.SLIPDT = DM_DOCUMENT_D.DELIVERYDATE
            AND DP_INPLAN.DOCNO = DM_DOCUMENT_D.DOCNO
            AND DP_INPLAN.DOCLINE = DM_DOCUMENT_D.DOCLINE
            AND DM_DOCUMENT_D.CHANNEL IN ('1','2','3')   <!-- 저장품만 처리함 1.저장 2.일배 3.광역일배 2015.01.26 SLLEE MODIFY [ 1,2] 김해경님 요청 -->
            <if test="status != null and status != ''">AND DM_DOCUMENT_D.STATUS LIKE #{status}</if>
            <if test="channel != null and channel != ''">AND DM_DOCUMENT_D.CHANNEL LIKE #{channel}</if>
            AND DM_DOCUMENT_D.DEL_YN = 'N'
        JOIN MS_SKU
            ON MS_SKU.STORERKEY = DP_INPLAN.STORERKEY
            AND MS_SKU.SKU = DP_INPLAN.SKU
            AND   MS_SKU.SERIALYN                    = DECODE(DP_INPLAN.DCCODE,'2170',MS_SKU.SERIALYN,'Y')
            <if test="storagetype != null and storagetype != ''">AND MS_SKU.STORAGETYPE LIKE #{storagetype}</if>
        LEFT OUTER JOIN MS_SKUDCSET
            ON MS_SKUDCSET.STORERKEY = DP_INPLAN.STORERKEY
            AND MS_SKUDCSET.DCCODE = DP_INPLAN.DCCODE
            AND MS_SKUDCSET.SKU = DP_INPLAN.SKU
        LEFT OUTER JOIN DP_INVOICE_SN
            ON DP_INVOICE_SN.DCCODE = DP_INPLAN.DCCODE
            AND DP_INVOICE_SN.STORERKEY = DP_INPLAN.STORERKEY
            AND DP_INVOICE_SN.DOCTYPE = DP_INPLAN.DOCTYPE
            AND DP_INVOICE_SN.SLIPNO = DP_INPLAN.SLIPNO
            AND DP_INVOICE_SN.SLIPDT = DP_INPLAN.SLIPDT
            AND DP_INVOICE_SN.SLIPLINE = DP_INPLAN.SLIPLINE
            AND DP_INVOICE_SN.SKU = DP_INPLAN.SKU
        LEFT OUTER JOIN ST_SNINFO
            ON ST_SNINFO.STORERKEY = DP_INVOICE_SN.STORERKEY
            AND ST_SNINFO.SKU = DP_INVOICE_SN.SKU
            AND ST_SNINFO.SERIALNO = DP_INVOICE_SN.SERIALNO
            AND ST_SNINFO.STOCKID = DP_INVOICE_SN.STOCKID
        WHERE 1=1
            <if test="docdtFrom != null and docdtFrom != ''">AND DP_INPLAN.DOCDT    <![CDATA[>=]]> #{docdtFrom}</if>
            <if test="docdtTo != null and docdtTo != ''">AND DP_INPLAN.DOCDT    <![CDATA[<=]]> #{docdtTo}</if>
            <if test="slipdtFrom != null and slipdtFrom != ''">AND DP_INPLAN.SLIPDT   <![CDATA[>=]]> #{slipdtFrom}</if>
            <if test="slipdtTo != null and slipdtTo != ''">AND DP_INPLAN.SLIPDT   <![CDATA[<=]]> #{slipdtTo}</if>
            <!-- 상품 다중선택 -->
            <if test="skuMulti != null and skuMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="skuMulti" item="item">
                        OR DP_INPLAN.SKU IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
            <if test="docnoMulti != null and docnoMulti != ''">
                AND DP_INPLAN.DOCNO IN
                <foreach collection="docnoMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            <if test="ordertypeMulti != null and ordertypeMulti != ''">
                AND DP_INPLAN.ORDERTYPE IN
                <foreach collection="ordertypeMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            <if test="blno != null and blno != ''">
                AND ST_SNINFO.CONVSERIALNO = #{blno}
            </if>
            <if test="serialno != null and serialno != ''">
                AND ST_SNINFO.SERIALNO = #{serialno}
            </if>
            <if test="wdCustkey != null and wdCustkey != ''">
                AND ST_SNINFO.CONTRACTCUSTKEY = #{wdCustkey}
            </if>
        <if test='crossyn == "Y"'>
                AND MS_SKUDCSET.CROSSDOCKTYPE = 'CROSS'
        </if>
        ORDER BY DM_DOCUMENT_H.ORDERTYPE
            ,DM_DOCUMENT_H.POTYPE
            ,DM_DOCUMENT_H.FROM_CUSTKEY
            ,DM_DOCUMENT_H.DOCNO
            ,DP_INPLAN.SLIPDT
            ,DP_INPLAN.SLIPNO
            ,DP_INPLAN.SLIPLINE
            ,DP_INPLAN.SKU
    </select>

    <!-- PLT 변환값 UPDATE -->
    <update id="saveBoxPlt">
        /* [dpReceiptService.sqlx][dpReceiptService.updateBoxperplt][PLT 방단 입력/수정] */
        MERGE INTO LOGISONE.MS_DC_PLT_LOAD T
        USING (
            SELECT
            #{dccode} AS DCCODE,
            #{plant} AS PLANT,
            #{storerkey} AS STORERKEY,
            #{sku} AS SKU,
            #{custkey} AS CUSTKEY,
            #{boxperlayer} AS BOXPERLAYER,
            #{layerperplt} AS LAYERPERPLT,
            #{editwho} AS EDITWHO
            FROM DUAL
        ) S
        ON (
            T.DCCODE = S.DCCODE
            AND T.PLANT = S.PLANT
            AND T.STORERKEY = S.STORERKEY
            AND T.SKU = S.SKU
            AND T.CUSTKEY = S.CUSTKEY
        )
        WHEN MATCHED THEN
        UPDATE SET
            T.BOXPERLAYER = S.BOXPERLAYER,
            T.LAYERPERPLT = S.LAYERPERPLT,
            T.EDITDATE = SYSDATE,
            T.EDITWHO = S.EDITWHO
        WHEN NOT MATCHED THEN
            INSERT (
                DCCODE, PLANT, STORERKEY, SKU, CUSTKEY,
                BOXPERLAYER, LAYERPERPLT,
                ADDDATE, EDITDATE, ADDWHO, EDITWHO
            )
            VALUES (
                S.DCCODE, S.PLANT, S.STORERKEY, S.SKU, S.CUSTKEY,
                S.BOXPERLAYER, S.LAYERPERPLT,
                SYSDATE, SYSDATE, S.EDITWHO, S.EDITWHO
            )
    </update>

    <!-- 저장품 입고예정 현황 리포트 -->
    <select id="getPrintList" resultType="cjfw.wms.dp.dto.DpReceiptResExcelDto">
        SELECT
            SLIPDT AS SLIPDT
            ,FROM_CUSTKEY AS FROM_CUSTKEY
            ,FROM_CUSTNAME AS FROM_CUSTNAME
            ,LOC AS LOC
            ,SKU AS SKU
            ,SKUNAME AS SKUNAME
            ,OPENQTY_EA AS OPENQTY_EA
            ,OPENQTY_KG AS OPENQTY_KG
            ,CHANNEL_NAME AS CHANNEL_NAME
            ,OPENQTY_BOX AS OPENQTY_BOX
            ,PLTQTY AS PLTQTY
            ,SUM(PLTQTY) OVER (PARTITION BY SLIPDT, FROM_CUSTKEY) AS TOTPLTQTY
        FROM (
            WITH T_DP_INSPECT AS(
            SELECT DP_INSPECT.DCCODE            AS DCCODE
                ,DP_INSPECT.STORERKEY         AS STORERKEY
                ,DP_INSPECT.ORGANIZE          AS ORGANIZE
                ,DP_INSPECT.AREA              AS AREA
                ,DP_INSPECT.DOCDT             AS DOCDT
                ,DP_INSPECT.DOCNO             AS DOCNO
                ,DP_INSPECT.DOCLINE           AS DOCLINE
                ,DP_INSPECT.DOCTYPE           AS DOCTYPE
                ,DP_INSPECT.SLIPDT            AS SLIPDT
                ,DP_INSPECT.SLIPNO            AS SLIPNO
                ,DP_INSPECT.SLIPLINE          AS SLIPLINE
                ,DP_INSPECT.SLIPTYPE          AS SLIPTYPE
                ,DP_INSPECT.SKU               AS SKU
                ,DP_INSPECT.LOTTABLE01        AS LOTTABLE01
                ,DP_INSPECT.STOCKID           AS STOCKID
                ,DP_INSPECT.STOCKGRADE        AS STOCKGRADE
                ,SUM(DP_INSPECT.INSPECTQTY)   AS INSPECTQTY
                ,SUM(DP_INSPECT.CONFIRMQTY)   AS CONFIRMQTY
                ,DP_INSPECT.TOLOC             AS TOLOC
            FROM DP_INSPECT
            WHERE 1 = 1
                <if test="fixdccode != null and fixdccode != ''">    AND    DP_INSPECT.DCCODE     =  #{fixdccode}      </if>
                <if test="gStorerkey != null and gStorerkey != ''"> AND    DP_INSPECT.STORERKEY  =  #{gStorerkey}   </if>
                <if test="gOrganize != null and gOrganize != ''">  AND    DP_INSPECT.ORGANIZE   =  #{fixdccode}    </if>
                <if test="gArea != null and gArea != ''">      AND    DP_INSPECT.AREA       =  #{gArea}        </if>
                AND DP_INSPECT.SLIPDT     <![CDATA[>=]]> #{slipdtFrom}
                AND DP_INSPECT.SLIPDT     <![CDATA[<=]]> #{slipdtTo}
                AND DP_INSPECT.OPENQTY                  >  0
                AND DP_INSPECT.INSPECTQTY               >  0
            GROUP BY DP_INSPECT.DCCODE
                ,DP_INSPECT.STORERKEY
                ,DP_INSPECT.ORGANIZE
                ,DP_INSPECT.AREA
                ,DP_INSPECT.DOCDT
                ,DP_INSPECT.DOCNO
                ,DP_INSPECT.DOCLINE
                ,DP_INSPECT.DOCTYPE
                ,DP_INSPECT.SLIPDT
                ,DP_INSPECT.SLIPNO
                ,DP_INSPECT.SLIPLINE
                ,DP_INSPECT.SLIPTYPE
                ,DP_INSPECT.SKU
                ,DP_INSPECT.LOTTABLE01
                ,DP_INSPECT.STOCKID
                ,DP_INSPECT.STOCKGRADE
                ,DP_INSPECT.TOLOC
            )
            SELECT /* [dpReceiptService.sqlx][dpReceiptService.getDataReportList][저장품 입고예정 현황 리포트정보][Chnag][20190801] */
                DP_INPLAN.DCCODE																				       							    AS DCCODE
                ,DP_INPLAN.STORERKEY																				    							AS STORERKEY
                ,DP_INPLAN.ORGANIZE																				    							AS ORGANIZE
                ,DP_INPLAN.DOCDT																					    							AS DOCDT
                ,DP_INPLAN.DOCNO																					    							AS DOCNO
                ,DP_INPLAN.DOCLINE                                   												    							AS DOCLINE
                ,DP_INPLAN.SLIPDT																					    							AS SLIPDT
                ,DP_INPLAN.SLIPNO																					    							AS SLIPNO
                ,DP_INPLAN.SLIPLINE                                   											    							AS SLIPLINE
                ,DM_DOCUMENT_H.POTYPE                                                                                                             AS POTYPE
                ,FN_CODEDESCR(DM_DOCUMENT_H.STORERKEY
                ,'POTYPE_DP'
                ,DM_DOCUMENT_H.POTYPE)                                                                                               AS POTYPENAME
                ,fn_descr_organize(DM_DOCUMENT_H.DCCODE, DM_DOCUMENT_H.ORGANIZE)                                                                  AS ORGANIZENAME
                ,DM_DOCUMENT_H.ORDERTYPE                                                                                                          AS ORDERTYPE
                ,FN_CODEDESCR(DM_DOCUMENT_H.STORERKEY
                ,'ORDERTYPE_DP'
                ,DM_DOCUMENT_H.ORDERTYPE)                                                                                            AS ORDERTYPE_NAME
                ,DM_DOCUMENT_H.FROM_CUSTKEY                                                                                                       AS FROM_CUSTKEY
                ,DM_DOCUMENT_H.FROM_CUSTNAME                                                                                                      AS FROM_CUSTNAME
                ,DP_INPLAN.SKU                                       												    							AS SKU
                ,MS_SKU.DESCRIPTION                                      																	        AS SKUNAME
                ,'[' || MS_SKU.COUNTRYOFORIGIN || ']' ||
                (SELECT BASEDESCR
                FROM CM_CODE
                WHERE CM_CODE.STORERKEY = MS_SKU.STORERKEY
                AND CM_CODE.CODELIST = 'COUNTRY'
                AND CM_CODE.BASECODE = MS_SKU.COUNTRYOFORIGIN
                AND CM_CODE.DEL_YN = 'N') 																									AS COUNTRYOFORIGIN
                ,DM_DOCUMENT_D.STORERUOM                                 																			AS UOM
                ,DM_DOCUMENT_D.BUNJA                                 																				AS BUNJA
                ,DM_DOCUMENT_D.BUNMO                                 																				AS BUNMO
                ,FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'EA',DP_INPLAN.OPENQTY)		 					AS OPENQTY_EA
                ,FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'KG',DP_INPLAN.OPENQTY)		 					AS OPENQTY_KG
                ,CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY))					AS OPENQTY_BOX
                ,DECODE(MS_SKU.BOXPERPLT,0,0,CEIL(CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY)) /
                MS_SKU.BOXPERPLT)) 																												AS PLTQTY
                ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
                ,DM_DOCUMENT_D.BUNJA
                ,DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY    )                                      									AS ORDERQTY
                ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU , DP_INPLAN.UOM, 'KG',DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY),2)          AS ORDERWEIGHT
                ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU, DP_INPLAN.UOM, 'KG', DP_INPLAN.CONFIRMQTY), 2) AS CONFIRMWEIGHT
                ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
                ,DM_DOCUMENT_D.BUNJA
                ,NVL(T_DP_INSPECT.INSPECTQTY, DP_INPLAN.INSPECTQTY)   )                            								 	AS INSPECTQTY
                ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
                ,DM_DOCUMENT_D.BUNJA
                ,NVL(T_DP_INSPECT.CONFIRMQTY, DP_INPLAN.CONFIRMQTY)   )                             								 	AS CONFIRMQTY
                ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
                ,DM_DOCUMENT_D.BUNJA
                ,DP_INPLAN.CANCELQTY    )                                                            								AS SHORTAGEQTY
                ,0                                                                                                     							AS SHORTAGETRANQTY
                ,0                                                                                                     							AS TRANQTY
                ,MS_SKUDCSET.LOC                                                                                                                  AS LOC
                ,NVL(T_DP_INSPECT.TOLOC,
                SPDP_RECEIPT.FN_GETTOLOC(DP_INPLAN.DCCODE,
                DP_INPLAN.STORERKEY,
                DP_INPLAN.SKU,
                DM_DOCUMENT_D.PLANT,
                DM_DOCUMENT_D.STORAGELOC,
                DM_DOCUMENT_D.CHANNEL))                                                                          AS TOLOC
                ,NVL(T_DP_INSPECT.LOTTABLE01,   DP_INPLAN.LOTTABLE01)                                       				                        AS LOTTABLE01
                ,FN_LOTDURATION(DP_INPLAN.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION,  NVL(T_DP_INSPECT.LOTTABLE01, DP_INPLAN.LOTTABLE01), 'N')||'/'||MS_SKU.DURATION       AS DURATION_TERM
                ,MS_SKU.COLORDESCR                                       																			AS COLORDESCR
                ,DM_DOCUMENT_D.REFERENCE02                                                      													AS REFERENCE02
                ,DM_DOCUMENT_D.REASONCODE                                                             											AS REASONCODE
                ,DM_DOCUMENT_D.REASONMSG                                 																			AS REASONMSG
                ,CASE WHEN NVL(T_DP_INSPECT.LOTTABLE01,DP_INPLAN.LOTTABLE01)='STD' THEN 'N'
                WHEN MONTHS_BETWEEN(TO_DATE(NVL(T_DP_INSPECT.LOTTABLE01, DP_INPLAN.LOTTABLE01),'yyyy-mm-dd'),SYSDATE)>3 THEN 'N' ELSE 'Y' END                             AS NEARDURATIONYN
                ,DM_DOCUMENT_D.STATUS            																									AS STATUS
                ,FN_CODEDESCR(DM_DOCUMENT_D.STORERKEY,'STATUS_DP', DM_DOCUMENT_D.STATUS)                                      					AS STATUSNAME
                ,MS_SKU.QTYPERBOX         																								    	AS QTYPERBOX
                ,DM_DOCUMENT_D.CHANNEL     																										AS CHANNEL
                ,MS_SKU.DURATION																													AS DURATION
                ,MS_SKU.DURATIONTYPE																												AS DURATIONTYPE
                ,UNISTR('')               																									    AS LASTLOTTABLE01
                ,NVL(T_DP_INSPECT.STOCKID,         DP_INPLAN.STOCKID)                                                                             AS STOCKID
                ,NVL(T_DP_INSPECT.STOCKGRADE,      DP_INPLAN.STOCKGRADE)                                                                          AS STOCKGRADE
                ,DM_DOCUMENT_D.PLANT																												AS PLANT
                ,'['||DM_DOCUMENT_D.PLANT||']'||fn_descr_plant(DM_DOCUMENT_D.PLANT)  																AS PLANT_DESCR
                ,FN_CODEDESCR(DP_INPLAN.STORERKEY,'PUTAWAYTYPE', DM_DOCUMENT_D.CHANNEL) 											                AS CHANNEL_NAME
                ,FN_CODEDESCR(MS_SKU.STORERKEY,'STORAGETYPE', MS_SKU.STORAGETYPE)  												                AS STORAGETYPENAME
            FROM DM_DOCUMENT_D
            JOIN CM_USER_AUTHORITY
                ON CM_USER_AUTHORITY.USERID     = #{gUserId}
                AND CM_USER_AUTHORITY.DCCODE     =  DM_DOCUMENT_D.DCCODE
                AND CM_USER_AUTHORITY.STORERKEY  =  DM_DOCUMENT_D.STORERKEY
                AND CM_USER_AUTHORITY.ORGANIZE   =  DM_DOCUMENT_D.ORGANIZE
                AND CM_USER_AUTHORITY.AREA       =  DM_DOCUMENT_D.AREA
                <if test="fixdccode != null and fixdccode != ''">    AND    CM_USER_AUTHORITY.DCCODE     =  #{fixdccode}      </if>
                <if test="gStorerkey != null and gStorerkey != ''"> AND    CM_USER_AUTHORITY.STORERKEY  =  #{gStorerkey}   </if>
                <if test="gOrganize != null and gOrganize != ''">  AND    CM_USER_AUTHORITY.ORGANIZE   =  #{fixdccode}    </if>
                <if test="gArea != null and gArea != ''">      AND    CM_USER_AUTHORITY.AREA       =  #{gArea}        </if>
            JOIN DM_DOCUMENT_H
                ON DM_DOCUMENT_D.DCCODE = DM_DOCUMENT_H.DCCODE
                AND DM_DOCUMENT_D.DOCTYPE = DM_DOCUMENT_H.DOCTYPE
                AND DM_DOCUMENT_D.DELIVERYDATE = DM_DOCUMENT_H.DELIVERYDATE
                AND DM_DOCUMENT_D.DOCNO = DM_DOCUMENT_H.DOCNO
                AND DM_DOCUMENT_H.DEL_YN            = 'N'
            <!-- 협력사 다중선택 -->
                <if test="fromCustkeyMulti != null and fromCustkeyMulti != '' ">
                    <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                        <foreach collection="fromCustkeyMulti" item="item">
                            OR DM_DOCUMENT_H.FROM_CUSTKEY IN
                            <foreach collection="item" item="code" open="(" close=")" separator=",">
                                #{code}
                            </foreach>
                        </foreach>
                    </trim>
                </if>
            JOIN DP_INPLAN
                ON    DP_INPLAN.DCCODE = DM_DOCUMENT_D.DCCODE
                AND DP_INPLAN.DOCTYPE = DM_DOCUMENT_D.DOCTYPE
                AND DP_INPLAN.SLIPDT = DM_DOCUMENT_D.DELIVERYDATE
                AND DP_INPLAN.DOCNO = DM_DOCUMENT_D.DOCNO
                AND DP_INPLAN.DOCLINE = DM_DOCUMENT_D.DOCLINE
                AND DP_INPLAN.DEL_YN      = 'N'
            <!-- 상품 다중선택 -->
                <if test="skuMulti != null and skuMulti != '' ">
                    <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                        <foreach collection="skuMulti" item="item">
                            OR DP_INPLAN.SKU IN
                            <foreach collection="item" item="code" open="(" close=")" separator=",">
                                #{code}
                            </foreach>
                        </foreach>
                    </trim>
                </if>
            JOIN MS_SKU
                ON MS_SKU.STORERKEY             =  DM_DOCUMENT_D.STORERKEY
                AND MS_SKU.SKU                   =  DM_DOCUMENT_D.SKU
                AND MS_SKU.SERIALYN = 'N'
            <if test="storagetype != null and storagetype != ''">  AND    MS_SKU.STORAGETYPE LIKE #{storagetype}             	  </if>
            LEFT OUTER JOIN MS_SKUDCSET
                ON MS_SKUDCSET.DCCODE           = DM_DOCUMENT_D.DCCODE
                AND MS_SKUDCSET.STORERKEY        = DM_DOCUMENT_D.STORERKEY
                AND MS_SKUDCSET.SKU              = DM_DOCUMENT_D.SKU
            LEFT OUTER JOIN T_DP_INSPECT
                ON T_DP_INSPECT.DCCODE       = DP_INPLAN.DCCODE
                AND T_DP_INSPECT.STORERKEY    = DP_INPLAN.STORERKEY
                AND T_DP_INSPECT.ORGANIZE     = DP_INPLAN.ORGANIZE
                AND T_DP_INSPECT.AREA         = DP_INPLAN.AREA
                AND T_DP_INSPECT.DOCDT        = DP_INPLAN.DOCDT
                AND T_DP_INSPECT.DOCNO        = DP_INPLAN.DOCNO
                AND T_DP_INSPECT.DOCLINE      = DP_INPLAN.DOCLINE
                AND T_DP_INSPECT.DOCTYPE      = DP_INPLAN.DOCTYPE
                AND T_DP_INSPECT.SLIPDT       = DP_INPLAN.SLIPDT
                AND T_DP_INSPECT.SLIPNO       = DP_INPLAN.SLIPNO
                AND T_DP_INSPECT.SLIPLINE     = DP_INPLAN.SLIPLINE
                AND T_DP_INSPECT.SLIPTYPE     = DP_INPLAN.SLIPTYPE
                AND T_DP_INSPECT.SKU          = DP_INPLAN.SKU
            WHERE 1=1
                AND DM_DOCUMENT_D.DCCODE      = #{fixdccode}
                AND DM_DOCUMENT_D.DOCTYPE     = 'DP'
                AND DM_DOCUMENT_D.DEL_YN      = 'N'
                <if test="status != null and status != ''">       AND    DM_DOCUMENT_D.STATUS       LIKE #{status}              </if>
                <if test="channel != null and channel != ''">      AND    DM_DOCUMENT_D.CHANNEL      LIKE #{channel}             </if>
                <!-- 문서번호 다중선택 -->
                    <if test="docnoMulti != null and docnoMulti != ''">
                        AND DM_DOCUMENT_D.DOCNO IN
                        <foreach collection="docnoMulti" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </if>
                    <if test="ordertypeMulti != null and ordertypeMulti != ''">
                        AND DM_DOCUMENT_D.ORDERTYPE IN
                        <foreach collection="ordertypeMulti" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </if>
                    <if test="slipnoMulti != null and slipnoMulti != ''">
                        AND  DP_INPLAN.SLIPNO      IN
                        <foreach collection="slipnoMulti" item="item" open="(" separator="," close=")">
                             #{item}
                        </foreach>
                    </if>
            ORDER BY DM_DOCUMENT_H.ORDERTYPE
                ,DM_DOCUMENT_H.POTYPE
                ,DM_DOCUMENT_H.FROM_CUSTKEY
                ,DM_DOCUMENT_H.DOCNO
                ,DP_INPLAN.SLIPDT
                ,DP_INPLAN.SLIPNO
                ,DP_INPLAN.SLIPLINE
                ,DP_INPLAN.SKU
        )
    </select>

    <!-- 저장품 입고예정 현황 리포트 C/D -->
    <select id="getPrintCdList" resultType="cjfw.wms.dp.dto.DpReceiptResExcelDto">
        SELECT SLIPDT
            ,SLIPNO
            ,FROM_CUSTKEY
            ,FROM_CUSTNAME
            ,LOC
            ,SKU
            ,SKUNAME
            ,ORDERQTY
            ,UOM
            ,OPENQTY_EA
            ,OPENQTY_BOX
            ,OPENQTY_KG AS OPENQTY_KG
            ,CHANNEL_NAME AS CHANNEL_NAME
            ,QTYPERBOX
        FROM (
            WITH T_DP_INSPECT AS(
            SELECT DP_INSPECT.DCCODE            AS DCCODE
                ,DP_INSPECT.STORERKEY         AS STORERKEY
                ,DP_INSPECT.ORGANIZE          AS ORGANIZE
                ,DP_INSPECT.AREA              AS AREA
                ,DP_INSPECT.DOCDT             AS DOCDT
                ,DP_INSPECT.DOCNO             AS DOCNO
                ,DP_INSPECT.DOCLINE           AS DOCLINE
                ,DP_INSPECT.DOCTYPE           AS DOCTYPE
                ,DP_INSPECT.SLIPDT            AS SLIPDT
                ,DP_INSPECT.SLIPNO            AS SLIPNO
                ,DP_INSPECT.SLIPLINE          AS SLIPLINE
                ,DP_INSPECT.SLIPTYPE          AS SLIPTYPE
                ,DP_INSPECT.SKU               AS SKU
                ,DP_INSPECT.LOTTABLE01        AS LOTTABLE01
                ,DP_INSPECT.STOCKID           AS STOCKID
                ,DP_INSPECT.STOCKGRADE        AS STOCKGRADE
                ,SUM(DP_INSPECT.INSPECTQTY)   AS INSPECTQTY
                ,SUM(DP_INSPECT.CONFIRMQTY)   AS CONFIRMQTY
                ,DP_INSPECT.TOLOC             AS TOLOC
            FROM DP_INSPECT
            WHERE 1 = 1
                <if test="fixdccode != null and fixdccode != ''">    AND    DP_INSPECT.DCCODE     =  #{fixdccode}      </if>
                <if test="gStorerkey != null and gStorerkey != ''"> AND    DP_INSPECT.STORERKEY  =  #{gStorerkey}   </if>
                <if test="gOrganize != null and gOrganize != ''">  AND    DP_INSPECT.ORGANIZE   =  #{fixdccode}    </if>
                <if test="gArea != null and gArea != ''">      AND    DP_INSPECT.AREA       =  #{gArea}        </if>
                AND DP_INSPECT.SLIPDT     <![CDATA[>=]]> #{slipdtFrom}
                AND DP_INSPECT.SLIPDT     <![CDATA[<=]]> #{slipdtTo}
                AND DP_INSPECT.OPENQTY                  >  0
                AND DP_INSPECT.INSPECTQTY               >  0
            GROUP BY DP_INSPECT.DCCODE
                ,DP_INSPECT.STORERKEY
                ,DP_INSPECT.ORGANIZE
                ,DP_INSPECT.AREA
                ,DP_INSPECT.DOCDT
                ,DP_INSPECT.DOCNO
                ,DP_INSPECT.DOCLINE
                ,DP_INSPECT.DOCTYPE
                ,DP_INSPECT.SLIPDT
                ,DP_INSPECT.SLIPNO
                ,DP_INSPECT.SLIPLINE
                ,DP_INSPECT.SLIPTYPE
                ,DP_INSPECT.SKU
                ,DP_INSPECT.LOTTABLE01
                ,DP_INSPECT.STOCKID
                ,DP_INSPECT.STOCKGRADE
                ,DP_INSPECT.TOLOC
            )
            SELECT /* [dpReceiptService.sqlx][dpReceiptService.getDataReportCdList][저장품 입고예정 현황 리포트정보 C/D][Chnag][20190822] */
                DP_INPLAN.DCCODE																				       							    AS DCCODE
                ,DP_INPLAN.STORERKEY																				    							AS STORERKEY
                ,DP_INPLAN.ORGANIZE																				    							AS ORGANIZE
                ,DP_INPLAN.DOCDT																					    							AS DOCDT
                ,DP_INPLAN.DOCNO																					    							AS DOCNO
                ,DP_INPLAN.DOCLINE                                   												    							AS DOCLINE
                ,DP_INPLAN.SLIPDT																					    							AS SLIPDT
                ,DP_INPLAN.SLIPNO																					    							AS SLIPNO
                ,DP_INPLAN.SLIPLINE                                   											    							AS SLIPLINE
                ,DM_DOCUMENT_H.POTYPE                                                                                                             AS POTYPE
                ,FN_CODEDESCR(DM_DOCUMENT_H.STORERKEY
                ,'POTYPE_DP'
                ,DM_DOCUMENT_H.POTYPE)                                                                                               AS POTYPENAME
                ,fn_descr_organize(DM_DOCUMENT_H.DCCODE, DM_DOCUMENT_H.ORGANIZE)                                                                  AS ORGANIZENAME
                ,DM_DOCUMENT_H.ORDERTYPE                                                                                                          AS ORDERTYPE
                ,FN_CODEDESCR(DM_DOCUMENT_H.STORERKEY
                ,'ORDERTYPE_DP'
                ,DM_DOCUMENT_H.ORDERTYPE)                                                                                            AS ORDERTYPE_NAME
                ,DM_DOCUMENT_H.FROM_CUSTKEY                                                                                                       AS FROM_CUSTKEY
                ,DM_DOCUMENT_H.FROM_CUSTNAME                                                                                                      AS FROM_CUSTNAME
                ,DP_INPLAN.SKU                                       												    							AS SKU
                ,MS_SKU.DESCRIPTION                                      																	        AS SKUNAME
                ,'[' || MS_SKU.COUNTRYOFORIGIN || ']' ||
                (SELECT BASEDESCR
                FROM CM_CODE
                WHERE CM_CODE.STORERKEY = MS_SKU.STORERKEY
                AND CM_CODE.CODELIST = 'COUNTRY'
                AND CM_CODE.BASECODE = MS_SKU.COUNTRYOFORIGIN
                AND CM_CODE.DEL_YN = 'N') 																									AS COUNTRYOFORIGIN
                ,DM_DOCUMENT_D.STORERUOM                                 																			AS UOM
                ,DM_DOCUMENT_D.BUNJA                                 																				AS BUNJA
                ,DM_DOCUMENT_D.BUNMO                                 																				AS BUNMO
                ,FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'EA',DP_INPLAN.OPENQTY)		 					AS OPENQTY_EA
                ,FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'KG',DP_INPLAN.OPENQTY)		 					AS OPENQTY_KG
                ,CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY))					AS OPENQTY_BOX
                ,DECODE(MS_SKU.BOXPERPLT,0,0,CEIL(CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY)) /
                MS_SKU.BOXPERPLT)) 																												AS PLTQTY
                ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
                ,DM_DOCUMENT_D.BUNJA
                ,DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY    )                                      									AS ORDERQTY
                ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU , DP_INPLAN.UOM, 'KG',DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY),2)          AS ORDERWEIGHT
                ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU, DP_INPLAN.UOM, 'KG', DP_INPLAN.CONFIRMQTY), 2) AS CONFIRMWEIGHT
                ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
                ,DM_DOCUMENT_D.BUNJA
                ,NVL(T_DP_INSPECT.INSPECTQTY, DP_INPLAN.INSPECTQTY)   )                            								 	AS INSPECTQTY
                ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
                ,DM_DOCUMENT_D.BUNJA
                ,NVL(T_DP_INSPECT.CONFIRMQTY, DP_INPLAN.CONFIRMQTY)   )                             								 	AS CONFIRMQTY
                ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
                ,DM_DOCUMENT_D.BUNJA
                ,DP_INPLAN.CANCELQTY    )                                                            								AS SHORTAGEQTY
                ,0                                                                                                     							AS SHORTAGETRANQTY
                ,0                                                                                                     							AS TRANQTY
                ,MS_SKUDCSET.LOC                                                                                                                  AS LOC
                ,NVL(T_DP_INSPECT.TOLOC,
                SPDP_RECEIPT.FN_GETTOLOC(DP_INPLAN.DCCODE,
                DP_INPLAN.STORERKEY,
                DP_INPLAN.SKU,
                DM_DOCUMENT_D.PLANT,
                DM_DOCUMENT_D.STORAGELOC,
                DM_DOCUMENT_D.CHANNEL))                                                                          AS TOLOC
                ,NVL(T_DP_INSPECT.LOTTABLE01,   DP_INPLAN.LOTTABLE01)                                       				                        AS LOTTABLE01
                ,FN_LOTDURATION(DP_INPLAN.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION,  NVL(T_DP_INSPECT.LOTTABLE01, DP_INPLAN.LOTTABLE01), 'N')||'/'||MS_SKU.DURATION       AS DURATION_TERM
                ,MS_SKU.COLORDESCR                                       																			AS COLORDESCR
                ,DM_DOCUMENT_D.REFERENCE02                                                      													AS REFERENCE02
                ,DM_DOCUMENT_D.REASONCODE                                                             											AS REASONCODE
                ,DM_DOCUMENT_D.REASONMSG                                 																			AS REASONMSG
                ,CASE WHEN NVL(T_DP_INSPECT.LOTTABLE01,DP_INPLAN.LOTTABLE01)='STD' THEN 'N'
                WHEN MONTHS_BETWEEN(TO_DATE(NVL(T_DP_INSPECT.LOTTABLE01, DP_INPLAN.LOTTABLE01),'yyyy-mm-dd'),SYSDATE)>3 THEN 'N' ELSE 'Y' END                             AS NEARDURATIONYN
                ,DM_DOCUMENT_D.STATUS            																									AS STATUS
                ,FN_CODEDESCR(DM_DOCUMENT_D.STORERKEY,'STATUS_DP', DM_DOCUMENT_D.STATUS)                                      					AS STATUSNAME
                ,MS_SKU.QTYPERBOX         																								    	AS QTYPERBOX
                ,DM_DOCUMENT_D.CHANNEL     																										AS CHANNEL
                ,MS_SKU.DURATION																													AS DURATION
                ,MS_SKU.DURATIONTYPE																												AS DURATIONTYPE
                ,UNISTR('')               																									    AS LASTLOTTABLE01
                ,NVL(T_DP_INSPECT.STOCKID,         DP_INPLAN.STOCKID)                                                                             AS STOCKID
                ,NVL(T_DP_INSPECT.STOCKGRADE,      DP_INPLAN.STOCKGRADE)                                                                          AS STOCKGRADE
                ,DM_DOCUMENT_D.PLANT																												AS PLANT
                ,'['||DM_DOCUMENT_D.PLANT||']'||fn_descr_plant(DM_DOCUMENT_D.PLANT)  																AS PLANT_DESCR
                ,FN_CODEDESCR(DP_INPLAN.STORERKEY,'PUTAWAYTYPE', DM_DOCUMENT_D.CHANNEL) 											                AS CHANNEL_NAME
                ,FN_CODEDESCR(MS_SKU.STORERKEY,'STORAGETYPE', MS_SKU.STORAGETYPE)  												                AS STORAGETYPENAME
            FROM DM_DOCUMENT_D
            JOIN CM_USER_AUTHORITY
                ON CM_USER_AUTHORITY.USERID     = #{gUserId}
                AND CM_USER_AUTHORITY.DCCODE     =  DM_DOCUMENT_D.DCCODE
                AND CM_USER_AUTHORITY.STORERKEY  =  DM_DOCUMENT_D.STORERKEY
                AND CM_USER_AUTHORITY.ORGANIZE   =  DM_DOCUMENT_D.ORGANIZE
                AND CM_USER_AUTHORITY.AREA       =  DM_DOCUMENT_D.AREA
                <if test="fixdccode != null and fixdccode != ''">    AND    CM_USER_AUTHORITY.DCCODE     =  #{fixdccode}      </if>
                <if test="gStorerkey != null and gStorerkey != ''"> AND    CM_USER_AUTHORITY.STORERKEY  =  #{gStorerkey}   </if>
                <if test="gOrganize != null and gOrganize != ''">  AND    CM_USER_AUTHORITY.ORGANIZE   =  #{fixdccode}    </if>
                <if test="gArea != null and gArea != ''">      AND    CM_USER_AUTHORITY.AREA       =  #{gArea}        </if>
            JOIN DM_DOCUMENT_H
                ON DM_DOCUMENT_D.DCCODE = DM_DOCUMENT_H.DCCODE
                AND DM_DOCUMENT_D.DOCTYPE = DM_DOCUMENT_H.DOCTYPE
                AND DM_DOCUMENT_D.DELIVERYDATE = DM_DOCUMENT_H.DELIVERYDATE
                AND DM_DOCUMENT_D.DOCNO = DM_DOCUMENT_H.DOCNO
                AND DM_DOCUMENT_H.DEL_YN            = 'N'
                <!-- 협력사 다중선택 -->
                <if test="fromCustkeyMulti != null and fromCustkeyMulti != '' ">
                    <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                        <foreach collection="fromCustkeyMulti" item="item">
                            OR DM_DOCUMENT_H.FROM_CUSTKEY IN
                            <foreach collection="item" item="code" open="(" close=")" separator=",">
                                #{code}
                            </foreach>
                        </foreach>
                    </trim>
                </if>
            JOIN DP_INPLAN
                ON    DP_INPLAN.DCCODE = DM_DOCUMENT_D.DCCODE
                AND DP_INPLAN.DOCTYPE = DM_DOCUMENT_D.DOCTYPE
                AND DP_INPLAN.SLIPDT = DM_DOCUMENT_D.DELIVERYDATE
                AND DP_INPLAN.DOCNO = DM_DOCUMENT_D.DOCNO
                AND DP_INPLAN.DOCLINE = DM_DOCUMENT_D.DOCLINE
                AND DP_INPLAN.DEL_YN      = 'N'
                <!-- 상품 다중선택 -->
                <if test="skuMulti != null and skuMulti != '' ">
                    <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                        <foreach collection="skuMulti" item="item">
                            OR DP_INPLAN.SKU IN
                            <foreach collection="item" item="code" open="(" close=")" separator=",">
                                #{code}
                            </foreach>
                        </foreach>
                    </trim>
                </if>
            JOIN MS_SKU
                ON MS_SKU.STORERKEY             =  DM_DOCUMENT_D.STORERKEY
                AND MS_SKU.SKU                   =  DM_DOCUMENT_D.SKU
                <if test="storagetype != null and storagetype != ''">  AND    MS_SKU.STORAGETYPE LIKE #{storagetype}             	  </if>
            LEFT OUTER JOIN MS_SKUDCSET
                ON MS_SKUDCSET.DCCODE           = DM_DOCUMENT_D.DCCODE
                AND MS_SKUDCSET.STORERKEY        = DM_DOCUMENT_D.STORERKEY
                AND MS_SKUDCSET.SKU              = DM_DOCUMENT_D.SKU
            LEFT OUTER JOIN T_DP_INSPECT
                ON T_DP_INSPECT.DCCODE       = DP_INPLAN.DCCODE
                AND T_DP_INSPECT.STORERKEY    = DP_INPLAN.STORERKEY
                AND T_DP_INSPECT.ORGANIZE     = DP_INPLAN.ORGANIZE
                AND T_DP_INSPECT.AREA         = DP_INPLAN.AREA
                AND T_DP_INSPECT.DOCDT        = DP_INPLAN.DOCDT
                AND T_DP_INSPECT.DOCNO        = DP_INPLAN.DOCNO
                AND T_DP_INSPECT.DOCLINE      = DP_INPLAN.DOCLINE
                AND T_DP_INSPECT.DOCTYPE      = DP_INPLAN.DOCTYPE
                AND T_DP_INSPECT.SLIPDT       = DP_INPLAN.SLIPDT
                AND T_DP_INSPECT.SLIPNO       = DP_INPLAN.SLIPNO
                AND T_DP_INSPECT.SLIPLINE     = DP_INPLAN.SLIPLINE
                AND T_DP_INSPECT.SLIPTYPE     = DP_INPLAN.SLIPTYPE
                AND T_DP_INSPECT.SKU          = DP_INPLAN.SKU
            WHERE 1=1
                AND DM_DOCUMENT_D.DCCODE      = #{fixdccode}
                AND DM_DOCUMENT_D.DOCTYPE     = 'DP'
                AND DM_DOCUMENT_D.DEL_YN      = 'N'
                <if test="status != null and status != ''">       AND    DM_DOCUMENT_D.STATUS       LIKE #{status}              </if>
                <if test="channel != null and channel != ''">      AND    DM_DOCUMENT_D.CHANNEL      LIKE #{channel}             </if>
                <!-- 문서번호 다중선택 -->
                    <if test="docnoMulti != null and docnoMulti != ''">
                        AND DM_DOCUMENT_D.DOCNO IN
                        <foreach collection="docnoMulti" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </if>
                    <if test="ordertypeMulti != null and ordertypeMulti != ''">
                        AND DM_DOCUMENT_D.ORDERTYPE IN
                        <foreach collection="ordertypeMulti" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </if>
                    <if test="slipnoMulti != null and slipnoMulti != ''">
                        AND  DP_INPLAN.SLIPNO      IN
                        <foreach collection="slipnoMulti" item="item" open="(" separator="," close=")">
                             #{item}
                        </foreach>
                    </if>
                AND  MS_SKUDCSET.CROSSDOCKTYPE 				= 'CROSS'
            ORDER BY DM_DOCUMENT_H.ORDERTYPE
                ,DM_DOCUMENT_H.POTYPE
                ,DM_DOCUMENT_H.FROM_CUSTKEY
                ,DM_DOCUMENT_H.DOCNO
                ,DP_INPLAN.SLIPDT
                ,DP_INPLAN.SLIPNO
                ,DP_INPLAN.SLIPLINE
                ,DP_INPLAN.SKU
        )
    </select>

    <!-- 저장품 입고예정 현황 리포트 이력상품 -->
    <select id="getPrintList2" resultType="cjfw.wms.dp.dto.DpReceiptResExcelDto">
        SELECT /* [dpReceiptService.sqlx][dpReceiptService.getDataReportSerialList][]저장품 입고예정 현황 리포트정보(이력상품)][Chnag][20190822] */
            SLIPDT
            ,FROM_CUSTKEY
            ,FROM_CUSTNAME
            ,LOC
            ,SKU
            ,SKUNAME
            ,OPENQTY_EA
            ,OPENQTY_BOX
            ,OPENQTY_KG AS OPENQTY_KG
            ,CHANNEL_NAME AS CHANNEL_NAME
            ,PLTQTY
            ,SUM(PLTQTY) OVER (PARTITION BY SLIPDT, FROM_CUSTKEY) AS TOTPLTQTY
        FROM (
        WITH T_DP_INSPECT AS (
            SELECT DP_INSPECT.DCCODE          	AS DCCODE
                ,DP_INSPECT.STORERKEY 			AS STORERKEY
                ,DP_INSPECT.ORGANIZE 			AS ORGANIZE
                ,DP_INSPECT.AREA    			AS AREA
                ,DP_INSPECT.DOCDT  			AS DOCDT
                ,DP_INSPECT.DOCNO   			AS DOCNO
                ,DP_INSPECT.DOCLINE 			AS DOCLINE
                ,DP_INSPECT.DOCTYPE  			AS DOCTYPE
                ,DP_INSPECT.SLIPDT    			AS SLIPDT
                ,DP_INSPECT.SLIPNO   			AS SLIPNO
                ,DP_INSPECT.SLIPLINE  			AS SLIPLINE
                ,DP_INSPECT.SLIPTYPE   		AS SLIPTYPE
                ,DP_INSPECT.SKU				AS SKU
                ,DP_INSPECT.LOTTABLE01			AS LOTTABLE01
                ,DP_INSPECT.STOCKID			AS STOCKID
                ,DP_INSPECT.STOCKGRADE         AS STOCKGRADE
                ,SUM(DP_INSPECT.INSPECTQTY)    AS INSPECTQTY
                ,SUM(DP_INSPECT.CONFIRMQTY)    AS CONFIRMQTY
                ,DP_INSPECT.TOLOC				AS TOLOC
            FROM DP_INSPECT
            WHERE 1 = 1
                <if test="fixdccode != null and fixdccode != ''">    AND    DP_INSPECT.DCCODE     =  #{fixdccode}      </if>
                <if test="gStorerkey != null and gStorerkey != ''"> AND    DP_INSPECT.STORERKEY  =  #{gStorerkey}   </if>
                <if test="gOrganize != null and gOrganize != ''">  AND    DP_INSPECT.ORGANIZE   =  #{fixdccode}    </if>
                <if test="gArea != null and gArea != ''">      AND    DP_INSPECT.AREA       =  #{gArea}        </if>
                AND DP_INSPECT.DCCODE      = #{fixdccode}
                <if test="slipnoMulti != null and slipnoMulti != ''">
                    AND  DP_INSPECT.SLIPNO      IN
                    <foreach collection="slipnoMulti" item="item" open="(" separator="," close=")">
                         #{item}
                    </foreach>
                </if>
                AND  DP_INSPECT.OPENQTY                  >  0
                AND  DP_INSPECT.INSPECTQTY               >  0
            GROUP BY DP_INSPECT.DCCODE
                ,DP_INSPECT.STORERKEY
                ,DP_INSPECT.ORGANIZE
                ,DP_INSPECT.AREA
                ,DP_INSPECT.DOCDT
                ,DP_INSPECT.DOCNO
                ,DP_INSPECT.DOCLINE
                ,DP_INSPECT.DOCTYPE
                ,DP_INSPECT.SLIPDT
                ,DP_INSPECT.SLIPNO
                ,DP_INSPECT.SLIPLINE
                ,DP_INSPECT.SLIPTYPE
                ,DP_INSPECT.SKU
                ,DP_INSPECT.LOTTABLE01
                ,DP_INSPECT.STOCKID
                ,DP_INSPECT.STOCKGRADE
                ,DP_INSPECT.TOLOC
        )
        SELECT '0'                   																											AS CHECKYN
            ,DP_INPLAN.DCCODE																				       							    AS DCCODE
            ,DP_INPLAN.STORERKEY																				    							AS STORERKEY
            ,DP_INPLAN.ORGANIZE																				    							AS ORGANIZE
            ,DP_INPLAN.DOCDT																					    							AS DOCDT
            ,DP_INPLAN.DOCNO																					    							AS DOCNO
            ,DP_INPLAN.DOCLINE                                   												    							AS DOCLINE
            ,DP_INPLAN.SLIPDT																					    							AS SLIPDT
            ,DP_INPLAN.SLIPNO																					    							AS SLIPNO
            ,DP_INPLAN.SLIPLINE                                   											    							AS SLIPLINE
            ,DM_DOCUMENT_H.FROM_CUSTKEY                                                                                                       AS FROM_CUSTKEY
            ,DM_DOCUMENT_H.FROM_CUSTNAME                                                                                                      AS FROM_CUSTNAME
            ,MS_SKUDCSET.LOC                                                                                                                  AS LOC
            ,DP_INPLAN.SKU                                       												    							AS SKU
            ,MS_SKU.DESCRIPTION                                      																	        AS SKUNAME
            ,'[' || MS_SKU.COUNTRYOFORIGIN || ']' ||
            (SELECT BASEDESCR
            FROM CM_CODE
            WHERE CM_CODE.STORERKEY = MS_SKU.STORERKEY
            AND CM_CODE.CODELIST = 'COUNTRY'
            AND CM_CODE.BASECODE = MS_SKU.COUNTRYOFORIGIN
            AND CM_CODE.DEL_YN = 'N') 																									AS COUNTRYOFORIGIN
            ,DM_DOCUMENT_D.STORERUOM                                 																			AS UOM
            ,DM_DOCUMENT_D.BUNJA                                 																				AS BUNJA
            ,DM_DOCUMENT_D.BUNMO                                 																				AS BUNMO
            ,FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'EA',DP_INPLAN.OPENQTY)		 					AS OPENQTY_EA
            ,FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'KG',DP_INPLAN.OPENQTY)		 					AS OPENQTY_KG
            ,CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY))					AS OPENQTY_BOX
            ,DECODE(MS_SKU.BOXPERPLT,0,0,CEIL(CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY)) /
            MS_SKU.BOXPERPLT)) 																												AS PLTQTY
            ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY    )                                      									AS ORDERQTY
            ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU , DP_INPLAN.UOM, 'KG',DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY),2)          AS ORDERWEIGHT
            ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU, DP_INPLAN.UOM, 'KG', DP_INPLAN.CONFIRMQTY), 2) AS CONFIRMWEIGHT
            ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.INSPECTQTY)                               					                                            AS INSPECTQTY
            ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.CONFIRMQTY)                                                                                               AS CONFIRMQTY

            <if test="workprocesscode == 'STO'">
                ,FN_UOMCAL  ( DM_DOCUMENT_D_WD.BUNMO
                ,DM_DOCUMENT_D_WD.BUNJA
                ,DM_DOCUMENT_D_WD.CONFIRMQTY )                                                                                       AS CONFIRMQTY_WD
                ,1                                                                          											           AS STO_FLAG
            </if>
            <if test='workprocesscode == "STO"'>
                ,0                                                                                                      				           AS CONFIRMQTY_WD
                ,0                                                                  															   AS STO_FLAG
            </if>
            ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.CANCELQTY    )                                                            								AS SHORTAGEQTY
            ,0                                                                                                     							AS SHORTAGETRANQTY
            ,0                                                                                                     							AS TRANQTY
            ,NVL(T_DP_INSPECT.TOLOC
            , CORE_CM_STRATEGY.FN_GETTOLOC ( DP_INPLAN.DOCTYPE
            ,DP_INPLAN.DCCODE
            ,DP_INPLAN.STORERKEY
            ,DP_INPLAN.ORDERTYPE
            ,DP_INPLAN.SLIPTYPE   ))                                           							AS TOLOC
            ,NVL(T_DP_INSPECT.LOTTABLE01,DP_INPLAN.LOTTABLE01)                                       				                            AS LOTTABLE01
            ,FN_LOTDURATION(DP_INPLAN.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, NVL(T_DP_INSPECT.LOTTABLE01,DP_INPLAN.LOTTABLE01), 'N')||'/'||MS_SKU.DURATION      AS DURATION_TERM
            ,MS_SKU.COLORDESCR                                       																			AS COLORDESCR
            ,DM_DOCUMENT_D.REFERENCE02                                                      													AS REFERENCE02
            ,DM_DOCUMENT_D.REASONCODE                                                             											AS REASONCODE
            ,DM_DOCUMENT_D.REASONMSG                                 																			AS REASONMSG
            ,CASE WHEN NVL(T_DP_INSPECT.LOTTABLE01,DP_INPLAN.LOTTABLE01)='STD' THEN 'N'
            WHEN MONTHS_BETWEEN(TO_DATE(NVL(T_DP_INSPECT.LOTTABLE01,DP_INPLAN.LOTTABLE01),'yyyy-mm-dd'),SYSDATE)>3 THEN 'N' ELSE 'Y' END   AS NEARDURATIONYN
            ,DM_DOCUMENT_D.STATUS            																									AS STATUS
            ,FN_CODEDESCR(DM_DOCUMENT_D.STORERKEY,'STATUS_DP', DM_DOCUMENT_D.STATUS)                                      					AS STATUSNAME
            ,MS_SKU.QTYPERBOX         																								    	AS QTYPERBOX
            ,DM_DOCUMENT_D.CHANNEL     																										AS CHANNEL
            ,MS_SKU.DURATION																													AS DURATION
            ,0     																															AS DURATION_RATE
            ,MS_SKU.DURATIONTYPE																												AS DURATIONTYPE
            ,UNISTR('')                																									    AS LASTLOTTABLE01
            ,NVL(NVL(ST_SNINFO.STOCKID,T_DP_INSPECT.STOCKID),DP_INPLAN.STOCKID)                                                               AS STOCKID
            ,NVL(T_DP_INSPECT.STOCKGRADE,DP_INPLAN.STOCKGRADE)                                                                                AS STOCKGRADE
            ,DECODE(SPDP_RECEIPT.FN_GETTOLOC( DP_INPLAN.DCCODE
            ,DP_INPLAN.STORERKEY
            ,DP_INPLAN.SKU
            ,DM_DOCUMENT_D.PLANT
            ,DM_DOCUMENT_D.STORAGELOC
            ,DM_DOCUMENT_D.CHANNEL
            ),'CROSS','CROSS','STAGE')                                                                        AS CROSSLOC
            ,DM_DOCUMENT_D.PLANT																												AS PLANT
            ,'['||DM_DOCUMENT_D.PLANT||']'||fn_descr_plant(DM_DOCUMENT_D.PLANT)  																AS PLANT_DESCR
            ,FN_CODEDESCR(DP_INPLAN.STORERKEY,'PUTAWAYTYPE', DM_DOCUMENT_D.CHANNEL) 											                AS CHANNEL_NAME
            ,FN_CODEDESCR(MS_SKU.STORERKEY,'STORAGETYPE', MS_SKU.STORAGETYPE)  												                AS STORAGETYPENAME

            ,ST_SNINFO.SERIALNO               																						        AS SERIALNO
            ,ST_SNINFO.CONVSERIALNO           																						        AS CONVSERIALNO
            ,ST_SNINFO.FACTORYNAME            																						        AS FACTORYNAME
            ,ST_SNINFO.CONTRACTCUSTKEY                                                                                                     AS CONTRACTCOMPANY
            ,( SELECT DESCRIPTION  FROM MS_CUST
            WHERE CUSTKEY = ST_SNINFO.CONTRACTCUSTKEY
            AND ROWNUM = 1)                                                                                                              AS CONTRACTCOMPANYNAME
            ,FN_CODEDESCR(ST_SNINFO.STORERKEY,'CONTRACTTYPE_SN',ST_SNINFO.CONTRACTTYPE)                                                AS CONTRACTTYPE
            ,ST_SNINFO.BUTCHERYDT                                                                                                          AS BUTCHERYDT
            ,ST_SNINFO.FROMVALIDDT                                                                                                         AS FROMVALIDDT
            ,ST_SNINFO.TOVALIDDT                                                                                                           AS TOVALIDDT
            ,ST_SNINFO.STOCKID                                                                                                             AS BARCODE
            ,ST_SNINFO.STOCKID                                                                                                             AS BARCODE
            ,CASE WHEN ST_SNINFO.STOCKID IS NULL THEN NULL
            ELSE FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,T_DP_INSPECT.INSPECTQTY )
            END                                                                                                                           AS SERIALORDERQTY
            ,CASE WHEN ST_SNINFO.STOCKID IS NULL THEN NULL
            ELSE FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,T_DP_INSPECT.CONFIRMQTY )
            END                                                                                                                           AS SERIALINSPECTQTY
            ,CASE WHEN DP_INPLAN.STORERKEY = 'CJFW' THEN CASE WHEN ST_SNINFO.STOCKID IS NULL THEN NULL
            ELSE DECODE(DP_INPLAN.UOM,'KG',T_DP_INSPECT.CONFIRMQTY,T_DP_INSPECT.CONFIRMQTY * ST_SNINFO.NETWEIGHT)
            END
            ELSE CASE WHEN ST_SNINFO.STOCKID IS NULL THEN NULL
            ELSE FN_CONV_UOM(DP_INPLAN.STORERKEY,DP_INPLAN.SKU,DP_INPLAN.UOM,'KG',T_DP_INSPECT.CONFIRMQTY)
            END
            END                                                                                                                           AS SERIALSCANWEIGHT
            ,CASE WHEN  DP_INPLAN.STORERKEY = 'CJFW'
            OR (ST_SNINFO.SERIALNO IS NOT NULL) THEN 'Y'
            ELSE 'N'
            END                                                                                                                           AS CHECKFLAG
            ,MS_SKU.LINE01                                                                                                                 AS LINE01
            ,MS_SKU.SERIALYN                                                                                                               AS SERIALYN
            ,CASE WHEN DP_INPLAN.STORERKEY = 'FW00' AND ST_SNINFO.SERIALNO IS NULL THEN 'gray' ELSE 'black' END                            AS FONTCOLOR
        FROM DP_INPLAN
        JOIN CM_USER_AUTHORITY
            ON  CM_USER_AUTHORITY.USERID     = #{gUserId}
            AND  CM_USER_AUTHORITY.DCCODE     =  DP_INPLAN.DCCODE
            AND  CM_USER_AUTHORITY.STORERKEY  =  DP_INPLAN.STORERKEY
            AND  CM_USER_AUTHORITY.ORGANIZE   =  DP_INPLAN.ORGANIZE
            AND  CM_USER_AUTHORITY.AREA       =  DP_INPLAN.AREA
            <if test="fixdccode != null and fixdccode != ''">    AND    CM_USER_AUTHORITY.DCCODE     =  #{fixdccode}      </if>
            <if test="gStorerkey != null and gStorerkey != ''"> AND    CM_USER_AUTHORITY.STORERKEY  =  #{gStorerkey}   </if>
            <if test="gOrganize != null and gOrganize != ''">  AND    CM_USER_AUTHORITY.ORGANIZE   =  #{fixdccode}    </if>
            <if test="gArea != null and gArea != ''">      AND    CM_USER_AUTHORITY.AREA       =  #{gArea}        </if>
        JOIN DM_DOCUMENT_H
            ON     DP_INPLAN.DCCODE = DM_DOCUMENT_H.DCCODE
            AND DP_INPLAN.DOCTYPE = DM_DOCUMENT_H.DOCTYPE
            AND DP_INPLAN.SLIPDT = DM_DOCUMENT_H.DELIVERYDATE
            AND DP_INPLAN.DOCNO = DM_DOCUMENT_H.DOCNO
            AND    DM_DOCUMENT_H.DOCTYPE            = 'DP'
            AND    DM_DOCUMENT_H.DEL_YN             = 'N'
            <!-- 협력사 다중선택 -->
                <if test="fromCustkeyMulti != null and fromCustkeyMulti != '' ">
                    <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                        <foreach collection="fromCustkeyMulti" item="item">
                            OR DM_DOCUMENT_H.FROM_CUSTKEY IN
                            <foreach collection="item" item="code" open="(" close=")" separator=",">
                                #{code}
                            </foreach>
                        </foreach>
                    </trim>
                </if>
        JOIN DM_DOCUMENT_D
            ON    DP_INPLAN.DCCODE = DM_DOCUMENT_D.DCCODE
            AND DP_INPLAN.DOCTYPE = DM_DOCUMENT_D.DOCTYPE
            AND DP_INPLAN.SLIPDT = DM_DOCUMENT_D.DELIVERYDATE
            AND DP_INPLAN.DOCNO = DM_DOCUMENT_D.DOCNO
            AND DP_INPLAN.DOCLINE = DM_DOCUMENT_D.DOCLINE
            AND   DM_DOCUMENT_D.CHANNEL      IN ('1','2','3')   <!-- 저장품만 처리함 1.저장 2.일배 3.광역일배 2015.01.26 SLLEE MODIFY [ 1,2] 김해경님 요청 -->
            <if test="channel != null and channel != ''">      AND    DM_DOCUMENT_D.CHANNEL      LIKE #{channel}             </if>
            AND   DM_DOCUMENT_D.DEL_YN      = 'N'

        <if test="workprocesscode == 'STO'">
            JOIN DM_DOCUMENT_D DM_DOCUMENT_D_WD
                ON    DM_DOCUMENT_D_WD.DOCNO          = DP_INPLAN.DOCNO
                AND   DM_DOCUMENT_D_WD.DOCLINE        = DP_INPLAN.DOCLINE
                AND   DM_DOCUMENT_D_WD.DOCTYPE        = 'WD'
                AND   DM_DOCUMENT_D_WD.WORKPROCESSCODE = 'STO'
        </if>
        JOIN MS_SKU
            ON   MS_SKU.STORERKEY             	  =  DP_INPLAN.STORERKEY
            AND   MS_SKU.SKU                   	  =  DP_INPLAN.SKU
            AND   MS_SKU.SERIALYN                    = DECODE(DP_INPLAN.DCCODE,'2170',MS_SKU.SERIALYN,'Y')
            <if test="storagetype != null and storagetype != ''">  AND    MS_SKU.STORAGETYPE LIKE #{storagetype}             	  </if>
        LEFT OUTER JOIN    MS_SKUDCSET
            ON   	MS_SKUDCSET.STORERKEY  		  = DM_DOCUMENT_D.STORERKEY
            AND   	MS_SKUDCSET.DCCODE			  = DM_DOCUMENT_D.DCCODE
            AND   	MS_SKUDCSET.SKU				  = DM_DOCUMENT_D.SKU
        JOIN T_DP_INSPECT
            ON     T_DP_INSPECT.DCCODE           = DP_INPLAN.DCCODE
            AND    T_DP_INSPECT.STORERKEY        = DP_INPLAN.STORERKEY
            AND    T_DP_INSPECT.SLIPDT           = DP_INPLAN.SLIPDT
            AND    T_DP_INSPECT.SLIPNO           = DP_INPLAN.SLIPNO
            AND    T_DP_INSPECT.SLIPLINE         = DP_INPLAN.SLIPLINE
        LEFT OUTER JOIN   ST_SNINFO
            ON     ST_SNINFO.STORERKEY       = T_DP_INSPECT.STORERKEY
            AND    ST_SNINFO.STOCKID         = T_DP_INSPECT.STOCKID

        WHERE DP_INPLAN.DCCODE      = #{fixdccode}
            <if test="slipnoMulti != null and slipnoMulti != ''">
                AND  DP_INPLAN.SLIPNO      IN
                <foreach collection="slipnoMulti" item="item" open="(" separator="," close=")">
                     #{item}
                </foreach>
            </if>
            <if test="skuMulti != null and skuMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="skuMulti" item="item">
                        OR DP_INPLAN.SKU IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
            <if test="docnoMulti != null and docnoMulti != ''">
                AND DP_INPLAN.DOCNO IN
                <foreach collection="docnoMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            <if test="ordertypeMulti != null and ordertypeMulti != ''">
                AND DP_INPLAN.ORDERTYPE IN
                <foreach collection="ordertypeMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
    <!--        AND   DP_INPLAN.ORDERQTY  <![CDATA[>]]> 0	  /** 결품으로만 확정완료된건은 안보이게 하기위해서 */-->
            <if test="blno != null and blno != ''">
                AND   ST_SNINFO.CONVSERIALNO       =  #{blno}
            </if>
            <if test="serialno != null and serialno != ''">
                AND   ST_SNINFO.SERIALNO           =  #{serialno}
            </if>
            <if test="wdCustkey != null and wdCustkey != ''">
                AND   ST_SNINFO.CONTRACTCUSTKEY         =  #{wdCustkey}
            </if>
            <if test='crossyn == "Y"'>
                AND   MS_SKUDCSET.CROSSDOCKTYPE        = 'CROSS'
            </if>
        UNION ALL
        SELECT '0'                   																											AS CHECKYN
            ,DP_INPLAN.DCCODE																				       							    AS DCCODE
            ,DP_INPLAN.STORERKEY																				    							AS STORERKEY
            ,DP_INPLAN.ORGANIZE																				    							AS ORGANIZE
            ,DP_INPLAN.DOCDT																					    							AS DOCDT
            ,DP_INPLAN.DOCNO																					    							AS DOCNO
            ,DP_INPLAN.DOCLINE                                   												    							AS DOCLINE
            ,DP_INPLAN.SLIPDT																					    							AS SLIPDT
            ,DP_INPLAN.SLIPNO																					    							AS SLIPNO
            ,DP_INPLAN.SLIPLINE                                   											    							AS SLIPLINE
            ,DM_DOCUMENT_H.FROM_CUSTKEY                                                                                                       AS FROM_CUSTKEY
            ,DM_DOCUMENT_H.FROM_CUSTNAME                                                                                                      AS FROM_CUSTNAME
            ,MS_SKUDCSET.LOC                                                                                                                  AS LOC
            ,DP_INPLAN.SKU                                       												    							AS SKU
            ,MS_SKU.DESCRIPTION                                      																	        AS SKUNAME
            ,'[' || MS_SKU.COUNTRYOFORIGIN || ']' ||
            (SELECT BASEDESCR
            FROM CM_CODE
            WHERE CM_CODE.STORERKEY = MS_SKU.STORERKEY
            AND CM_CODE.CODELIST = 'COUNTRY'
            AND CM_CODE.BASECODE = MS_SKU.COUNTRYOFORIGIN
            AND CM_CODE.DEL_YN = 'N') 																									AS COUNTRYOFORIGIN
            ,DM_DOCUMENT_D.STORERUOM                                 																			AS UOM
            ,DM_DOCUMENT_D.BUNJA                                 																				AS BUNJA
            ,DM_DOCUMENT_D.BUNMO                                 																				AS BUNMO
            ,FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'EA',DP_INPLAN.OPENQTY)		 					AS OPENQTY_EA
            ,FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'KG',DP_INPLAN.OPENQTY)		 					AS OPENQTY_KG
            ,CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY))					AS OPENQTY_BOX
            ,DECODE(MS_SKU.BOXPERPLT,0,0,CEIL(CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY)) /
            MS_SKU.BOXPERPLT)) 																												AS PLTQTY
            ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY    )                                      									AS ORDERQTY
            ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU , DP_INPLAN.UOM, 'KG',DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY),2)          AS ORDERWEIGHT
            ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU, DP_INPLAN.UOM, 'KG', DP_INPLAN.CONFIRMQTY), 2) AS CONFIRMWEIGHT
            ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.INSPECTQTY)                               					                                            AS INSPECTQTY
            ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.CONFIRMQTY)                                                                                               AS CONFIRMQTY
            <if test="workprocesscode == 'STO'">
                ,FN_UOMCAL  ( DM_DOCUMENT_D_WD.BUNMO
                ,DM_DOCUMENT_D_WD.BUNJA
                ,DM_DOCUMENT_D_WD.CONFIRMQTY )                                                                                       AS CONFIRMQTY_WD
                ,1                                                                          											           AS STO_FLAG
            </if>
            <if test='workprocesscode == "STO"'>
                ,0                                                                                                      				           AS CONFIRMQTY_WD
                ,0                                                                  															   AS STO_FLAG
            </if>
            ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.CANCELQTY    )                                                            								AS SHORTAGEQTY
            ,0                                                                                                     							AS SHORTAGETRANQTY
            ,0                                                                                                     							AS TRANQTY
            ,CORE_CM_STRATEGY.FN_GETTOLOC ( DP_INPLAN.DOCTYPE
            ,DP_INPLAN.DCCODE
            ,DP_INPLAN.STORERKEY
            ,DP_INPLAN.ORDERTYPE
            ,DP_INPLAN.SLIPTYPE   )                                           							        AS TOLOC
            ,NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01)                                       				                            AS LOTTABLE01
            ,FN_LOTDURATION(DP_INPLAN.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01), 'N')||'/'||MS_SKU.DURATION      AS DURATION_TERM
            ,MS_SKU.COLORDESCR                                       																			AS COLORDESCR
            ,DM_DOCUMENT_D.REFERENCE02                                                      													AS REFERENCE02
            ,DM_DOCUMENT_D.REASONCODE                                                             											AS REASONCODE
            ,DM_DOCUMENT_D.REASONMSG                                 																			AS REASONMSG
            ,CASE WHEN NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01)='STD' THEN 'N'
            WHEN MONTHS_BETWEEN(TO_DATE(NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01),'yyyy-mm-dd'),SYSDATE)>3 THEN 'N' ELSE 'Y' END   AS NEARDURATIONYN
            ,DM_DOCUMENT_D.STATUS            																									AS STATUS
            ,FN_CODEDESCR(DM_DOCUMENT_D.STORERKEY,'STATUS_DP', DM_DOCUMENT_D.STATUS)                                      					AS STATUSNAME
            ,MS_SKU.QTYPERBOX         																								    	AS QTYPERBOX
            ,DM_DOCUMENT_D.CHANNEL     																										AS CHANNEL
            ,MS_SKU.DURATION																													AS DURATION
            ,0     																															AS DURATION_RATE
            ,MS_SKU.DURATIONTYPE																												AS DURATIONTYPE
            ,UNISTR('')          																									            AS LASTLOTTABLE01
            ,NVL(ST_SNINFO.STOCKID,DP_INPLAN.STOCKID)                                                                                     AS STOCKID
            ,DP_INPLAN.STOCKGRADE                                                                                                             AS STOCKGRADE
            ,DECODE(SPDP_RECEIPT.FN_GETTOLOC( DP_INPLAN.DCCODE
            ,DP_INPLAN.STORERKEY
            ,DP_INPLAN.SKU
            ,DM_DOCUMENT_D.PLANT
            ,DM_DOCUMENT_D.STORAGELOC
            ,DM_DOCUMENT_D.CHANNEL
            ),'CROSS','CROSS','STAGE')                                                                        AS CROSSLOC
            ,DM_DOCUMENT_D.PLANT																												AS PLANT
            ,'['||DM_DOCUMENT_D.PLANT||']'||fn_descr_plant(DM_DOCUMENT_D.PLANT)  																AS PLANT_DESCR
            ,FN_CODEDESCR(DP_INPLAN.STORERKEY,'PUTAWAYTYPE', DM_DOCUMENT_D.CHANNEL) 											                AS CHANNEL_NAME
            ,FN_CODEDESCR(MS_SKU.STORERKEY,'STORAGETYPE', MS_SKU.STORAGETYPE)  												                AS STORAGETYPENAME

            ,ST_SNINFO.SERIALNO               																						        AS SERIALNO
            ,ST_SNINFO.CONVSERIALNO           																						        AS CONVSERIALNO
            ,ST_SNINFO.FACTORYNAME            																						        AS FACTORYNAME
            ,ST_SNINFO.CONTRACTCUSTKEY                                                                                                     AS CONTRACTCOMPANY
            ,( SELECT DESCRIPTION  FROM MS_CUST
            WHERE CUSTKEY = ST_SNINFO.CONTRACTCUSTKEY
            AND ROWNUM = 1)                                                                                                              AS CONTRACTCOMPANYNAME
            ,FN_CODEDESCR(ST_SNINFO.STORERKEY,'CONTRACTTYPE_SN',ST_SNINFO.CONTRACTTYPE)                                                AS CONTRACTTYPE
            ,ST_SNINFO.BUTCHERYDT                                                                                                          AS BUTCHERYDT
            ,ST_SNINFO.FROMVALIDDT                                                                                                         AS FROMVALIDDT
            ,ST_SNINFO.TOVALIDDT                                                                                                           AS TOVALIDDT
            ,ST_SNINFO.STOCKID                                                                                                             AS BARCODE
            ,ST_SNINFO.STOCKID                                                                                                             AS BARCODE
            ,CASE WHEN ST_SNINFO.STOCKID IS NULL THEN NULL
            ELSE FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INVOICE_SN.ORDERQTY - DP_INVOICE_SN.CONFIRMQTY)
            END                                                                                                                           AS SERIALORDERQTY
            ,CASE WHEN ST_SNINFO.STOCKID IS NULL THEN NULL
            ELSE 0
            END                                                                                                                           AS SERIALINSPECTQTY
            ,CASE WHEN ST_SNINFO.STOCKID IS NULL THEN NULL
            ELSE 0
            END                                                                                                                           AS SERIALSCANWEIGHT
            ,CASE WHEN  DP_INPLAN.STORERKEY = 'CJFW'
            OR (    ST_SNINFO.SERIALNO IS NOT NULL
            AND (   DM_DOCUMENT_D.CHANNEL <![CDATA[<>]]> '1'
            OR DP_INPLAN.DCCODE = '2170')
            ) THEN 'Y'
            ELSE 'N'
            END                                                                                                                           AS CHECKFLAG
            ,MS_SKU.LINE01                                                                                                                 AS LINE01
            ,MS_SKU.SERIALYN                                                                                                                   AS SERIALYN
            ,CASE WHEN DP_INPLAN.STORERKEY = 'FW00' AND ST_SNINFO.SERIALNO IS NULL THEN 'gray' ELSE 'black' END                            AS FONTCOLOR
        FROM DP_INPLAN
        JOIN CM_USER_AUTHORITY
            ON  CM_USER_AUTHORITY.USERID     = #{gUserId}
            AND  CM_USER_AUTHORITY.DCCODE     =  DP_INPLAN.DCCODE
            AND  CM_USER_AUTHORITY.STORERKEY  =  DP_INPLAN.STORERKEY
            AND  CM_USER_AUTHORITY.ORGANIZE   =  DP_INPLAN.ORGANIZE
            AND  CM_USER_AUTHORITY.AREA       =  DP_INPLAN.AREA
            <if test="fixdccode != null and fixdccode != ''">    AND    CM_USER_AUTHORITY.DCCODE     =  #{fixdccode}      </if>
            <if test="gStorerkey != null and gStorerkey != ''"> AND    CM_USER_AUTHORITY.STORERKEY  =  #{gStorerkey}   </if>
            <if test="gOrganize != null and gOrganize != ''">  AND    CM_USER_AUTHORITY.ORGANIZE   =  #{fixdccode}    </if>
            <if test="gArea != null and gArea != ''">      AND    CM_USER_AUTHORITY.AREA       =  #{gArea}        </if>
        JOIN DM_DOCUMENT_H
            ON     DP_INPLAN.DCCODE = DM_DOCUMENT_H.DCCODE
            AND DP_INPLAN.DOCTYPE = DM_DOCUMENT_H.DOCTYPE
            AND DP_INPLAN.SLIPDT = DM_DOCUMENT_H.DELIVERYDATE
            AND DP_INPLAN.DOCNO = DM_DOCUMENT_H.DOCNO
            AND    DM_DOCUMENT_H.DOCTYPE            = 'DP'
            AND    DM_DOCUMENT_H.DEL_YN             = 'N'
            <!-- 협력사 다중선택 -->
                <if test="fromCustkeyMulti != null and fromCustkeyMulti != '' ">
                    <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                        <foreach collection="fromCustkeyMulti" item="item">
                            OR DM_DOCUMENT_H.FROM_CUSTKEY IN
                            <foreach collection="item" item="code" open="(" close=")" separator=",">
                                #{code}
                            </foreach>
                        </foreach>
                    </trim>
                </if>
        JOIN DM_DOCUMENT_D
            ON    DP_INPLAN.DCCODE = DM_DOCUMENT_D.DCCODE
            AND DP_INPLAN.DOCTYPE = DM_DOCUMENT_D.DOCTYPE
            AND DP_INPLAN.SLIPDT = DM_DOCUMENT_D.DELIVERYDATE
            AND DP_INPLAN.DOCNO = DM_DOCUMENT_D.DOCNO
            AND DP_INPLAN.DOCLINE = DM_DOCUMENT_D.DOCLINE
            AND   DM_DOCUMENT_D.CHANNEL     = '1'   <!-- 저장품만 처리함 1.저장 2.일배 3.광역일배 2015.01.26 SLLEE MODIFY [ 1,2] 김해경님 요청 -->
            <if test="channel != null and channel != ''">      AND    DM_DOCUMENT_D.CHANNEL      LIKE #{channel}             </if>
            AND   DM_DOCUMENT_D.DEL_YN      = 'N'
            <if test="workprocesscode == 'STO'">
                JOIN
                DM_DOCUMENT_D DM_DOCUMENT_D_WD
                ON    DM_DOCUMENT_D_WD.DOCNO          = DP_INPLAN.DOCNO
                AND   DM_DOCUMENT_D_WD.DOCLINE        = DP_INPLAN.DOCLINE
                AND   DM_DOCUMENT_D_WD.DOCTYPE        = 'WD'
                AND   DM_DOCUMENT_D_WD.WORKPROCESSCODE = 'STO'
            </if>
        JOIN MS_SKU
            ON   MS_SKU.STORERKEY             	  =  DP_INPLAN.STORERKEY
            AND   MS_SKU.SKU                   	  =  DP_INPLAN.SKU
            AND   MS_SKU.SERIALYN                    = DECODE(DP_INPLAN.DCCODE,'2170',MS_SKU.SERIALYN,'Y')
            <if test="storagetype != null and storagetype != ''">  AND    MS_SKU.STORAGETYPE LIKE #{storagetype}             	  </if>
        LEFT OUTER JOIN MS_SKUDCSET
            ON    MS_SKUDCSET.STORERKEY  			= DM_DOCUMENT_D.STORERKEY
            AND   MS_SKUDCSET.DCCODE				= DM_DOCUMENT_D.DCCODE
            AND   MS_SKUDCSET.SKU					= DM_DOCUMENT_D.SKU
        LEFT OUTER JOIN DP_INVOICE_SN
            ON    DP_INVOICE_SN.DCCODE             = DP_INPLAN.DCCODE
            AND   DP_INVOICE_SN.STORERKEY          = DP_INPLAN.STORERKEY
            AND   DP_INVOICE_SN.DOCTYPE            = DP_INPLAN.DOCTYPE
            AND   DP_INVOICE_SN.SLIPNO             = DP_INPLAN.SLIPNO
            AND   DP_INVOICE_SN.SLIPDT             = DP_INPLAN.SLIPDT
            AND   DP_INVOICE_SN.SLIPLINE           = DP_INPLAN.SLIPLINE
            AND   DP_INVOICE_SN.SKU                = DP_INPLAN.SKU
            AND   DP_INVOICE_SN.ORDERQTY-DP_INVOICE_SN.CONFIRMQTY         > 0
        LEFT OUTER JOIN ST_SNINFO
            ON    ST_SNINFO.STORERKEY              = DP_INVOICE_SN.STORERKEY
            AND   ST_SNINFO.SKU                    = DP_INVOICE_SN.SKU
            AND   ST_SNINFO.SERIALNO               = DP_INVOICE_SN.SERIALNO
            AND   ST_SNINFO.STOCKID                = DP_INVOICE_SN.STOCKID
        WHERE DP_INPLAN.DCCODE      = #{fixdccode}
            <if test="slipnoMulti != null and slipnoMulti != ''">
                AND  DP_INPLAN.SLIPNO      IN
                <foreach collection="slipnoMulti" item="item" open="(" separator="," close=")">
                     #{item}
                </foreach>
            </if>
                <if test="skuMulti != null and skuMulti != '' ">
                    <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                        <foreach collection="skuMulti" item="item">
                            OR DP_INPLAN.SKU IN
                            <foreach collection="item" item="code" open="(" close=")" separator=",">
                                #{code}
                            </foreach>
                        </foreach>
                    </trim>
                </if>
                <if test="docnoMulti != null and docnoMulti != ''">
                    AND DP_INPLAN.DOCNO IN
                    <foreach collection="docnoMulti" item="code" open="(" close=")" separator=",">
                        #{code}
                    </foreach>
                </if>
                <if test="ordertypeMulti != null and ordertypeMulti != ''">
                    AND DP_INPLAN.ORDERTYPE IN
                    <foreach collection="ordertypeMulti" item="code" open="(" close=")" separator=",">
                        #{code}
                    </foreach>
                </if>

    <!--        AND   DP_INPLAN.ORDERQTY  <![CDATA[>]]> 0	  /** 결품으로만 확정완료된건은 안보이게 하기위해서 */-->
            AND   DP_INPLAN.ORDERQTY
            - DP_INPLAN.CONFIRMQTY <![CDATA[>]]> 0

            <if test="blno != null and blno != ''">
                AND   ST_SNINFO.CONVSERIALNO       =  #{blno}
            </if>
            <if test="serialno != null and serialno != ''">
                AND   ST_SNINFO.SERIALNO           =  #{serialno}
            </if>
            <if test="wdCustkey != null and wdCustkey != ''">
                AND   ST_SNINFO.CONTRACTCUSTKEY         =  #{wdCustkey}
            </if>
            <if test='crossyn == "Y"'>
                AND   MS_SKUDCSET.CROSSDOCKTYPE        = 'CROSS'
            </if>
        UNION ALL
        SELECT
            '0'                   																											AS CHECKYN
            ,DP_INPLAN.DCCODE																				       							    AS DCCODE
            ,DP_INPLAN.STORERKEY																				    							AS STORERKEY
            ,DP_INPLAN.ORGANIZE																				    							AS ORGANIZE
            ,DP_INPLAN.DOCDT																					    							AS DOCDT
            ,DP_INPLAN.DOCNO																					    							AS DOCNO
            ,DP_INPLAN.DOCLINE                                   												    							AS DOCLINE
            ,DP_INPLAN.SLIPDT																					    							AS SLIPDT
            ,DP_INPLAN.SLIPNO																					    							AS SLIPNO
            ,DP_INPLAN.SLIPLINE                                   											    							AS SLIPLINE
            ,DM_DOCUMENT_H.FROM_CUSTKEY                                                                                                       AS FROM_CUSTKEY
            ,DM_DOCUMENT_H.FROM_CUSTNAME                                                                                                      AS FROM_CUSTNAME
            ,MS_SKUDCSET.LOC                                                                                                                  AS LOC
            ,DP_INPLAN.SKU                                       												    							AS SKU
            ,MS_SKU.DESCRIPTION                                      																	        AS SKUNAME
            ,'[' || MS_SKU.COUNTRYOFORIGIN || ']' ||
            (SELECT BASEDESCR
            FROM CM_CODE
            WHERE CM_CODE.STORERKEY = MS_SKU.STORERKEY
            AND CM_CODE.CODELIST = 'COUNTRY'
            AND CM_CODE.BASECODE = MS_SKU.COUNTRYOFORIGIN
            AND CM_CODE.DEL_YN = 'N') 																									AS COUNTRYOFORIGIN
            ,DM_DOCUMENT_D.STORERUOM                                 																			AS UOM
            ,DM_DOCUMENT_D.BUNJA                                 																				AS BUNJA
            ,DM_DOCUMENT_D.BUNMO                                 																				AS BUNMO
            ,FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'EA',DP_INPLAN.OPENQTY)		 					AS OPENQTY_EA
            ,FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'KG',DP_INPLAN.OPENQTY)		 					AS OPENQTY_KG
            ,CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY))					AS OPENQTY_BOX
            ,DECODE(MS_SKU.BOXPERPLT,0,0,CEIL(CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY)) /
            MS_SKU.BOXPERPLT)) 																												AS PLTQTY
            ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY    )                                      									AS ORDERQTY
            ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU , DP_INPLAN.UOM, 'KG',DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY),2)          AS ORDERWEIGHT
            ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU, DP_INPLAN.UOM, 'KG', DP_INPLAN.CONFIRMQTY), 2) AS CONFIRMWEIGHT
            ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.INSPECTQTY)                               					                                            AS INSPECTQTY
            ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.CONFIRMQTY)                                                                                               AS CONFIRMQTY
            <if test="workprocesscode == 'STO'">
                ,FN_UOMCAL  ( DM_DOCUMENT_D_WD.BUNMO
                ,DM_DOCUMENT_D_WD.BUNJA
                ,DM_DOCUMENT_D_WD.CONFIRMQTY )                                                                                       AS CONFIRMQTY_WD
                ,1                                                                          											           AS STO_FLAG
            </if>
            <if test='workprocesscode == "STO"'>
                ,0                                                                                                      				           AS CONFIRMQTY_WD
                ,0                                                                  															   AS STO_FLAG
            </if>
            ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INPLAN.CANCELQTY    )                                                            								AS SHORTAGEQTY
            ,0                                                                                                     							AS SHORTAGETRANQTY
            ,0                                                                                                     							AS TRANQTY
            ,CORE_CM_STRATEGY.FN_GETTOLOC ( DP_INPLAN.DOCTYPE
            ,DP_INPLAN.DCCODE
            ,DP_INPLAN.STORERKEY
            ,DP_INPLAN.ORDERTYPE
            ,DP_INPLAN.SLIPTYPE   )                                           							        AS TOLOC
            ,NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01)                                       				                            AS LOTTABLE01
            ,FN_LOTDURATION(DP_INPLAN.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01), 'N')||'/'||MS_SKU.DURATION      AS DURATION_TERM
            ,MS_SKU.COLORDESCR                                       																			AS COLORDESCR
            ,DM_DOCUMENT_D.REFERENCE02                                                      													AS REFERENCE02
            ,DM_DOCUMENT_D.REASONCODE                                                             											AS REASONCODE
            ,DM_DOCUMENT_D.REASONMSG                                 																			AS REASONMSG
            ,CASE WHEN NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01)='STD' THEN 'N'
            WHEN MONTHS_BETWEEN(TO_DATE(NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01),'yyyy-mm-dd'),SYSDATE)>3 THEN 'N' ELSE 'Y' END   AS NEARDURATIONYN
            ,DM_DOCUMENT_D.STATUS            																									AS STATUS
            ,FN_CODEDESCR(DM_DOCUMENT_D.STORERKEY,'STATUS_DP', DM_DOCUMENT_D.STATUS)                                      					AS STATUSNAME
            ,MS_SKU.QTYPERBOX         																								    	AS QTYPERBOX
            ,DM_DOCUMENT_D.CHANNEL     																										AS CHANNEL
            ,MS_SKU.DURATION																													AS DURATION
            ,0     																															AS DURATION_RATE
            ,MS_SKU.DURATIONTYPE																												AS DURATIONTYPE
            ,UNISTR('')       																									            AS LASTLOTTABLE01
            ,NVL(ST_SNINFO.STOCKID,DP_INPLAN.STOCKID)                                                                                     AS STOCKID
            ,DP_INPLAN.STOCKGRADE                                                                                                             AS STOCKGRADE
            ,DECODE(SPDP_RECEIPT.FN_GETTOLOC( DP_INPLAN.DCCODE
            ,DP_INPLAN.STORERKEY
            ,DP_INPLAN.SKU
            ,DM_DOCUMENT_D.PLANT
            ,DM_DOCUMENT_D.STORAGELOC
            ,DM_DOCUMENT_D.CHANNEL
            ),'CROSS','CROSS','STAGE')                                                                        AS CROSSLOC
            ,DM_DOCUMENT_D.PLANT																												AS PLANT
            ,'['||DM_DOCUMENT_D.PLANT||']'||fn_descr_plant(DM_DOCUMENT_D.PLANT)  																AS PLANT_DESCR
            ,FN_CODEDESCR(DP_INPLAN.STORERKEY,'PUTAWAYTYPE', DM_DOCUMENT_D.CHANNEL) 											                AS CHANNEL_NAME
            ,FN_CODEDESCR(MS_SKU.STORERKEY,'STORAGETYPE', MS_SKU.STORAGETYPE)  												                AS STORAGETYPENAME

            ,ST_SNINFO.SERIALNO               																						        AS SERIALNO
            ,ST_SNINFO.CONVSERIALNO           																						        AS CONVSERIALNO
            ,ST_SNINFO.FACTORYNAME            																						        AS FACTORYNAME
            ,ST_SNINFO.CONTRACTCUSTKEY                                                                                                     AS CONTRACTCOMPANY
            ,( SELECT DESCRIPTION  FROM MS_CUST
            WHERE CUSTKEY = ST_SNINFO.CONTRACTCUSTKEY
            AND ROWNUM = 1)                                                                                                          AS CONTRACTCOMPANYNAME
            ,FN_CODEDESCR(ST_SNINFO.STORERKEY,'CONTRACTTYPE_SN',ST_SNINFO.CONTRACTTYPE)                                                    AS CONTRACTTYPE
            ,ST_SNINFO.BUTCHERYDT                                                                                                          AS BUTCHERYDT
            ,ST_SNINFO.FROMVALIDDT                                                                                                         AS FROMVALIDDT
            ,ST_SNINFO.TOVALIDDT                                                                                                           AS TOVALIDDT
            ,ST_SNINFO.STOCKID                                                                                                             AS BARCODE
            ,ST_SNINFO.STOCKID                                                                                                             AS BARCODE
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INVOICE_SN.ORDERQTY)                                                                                           AS SERIALORDERQTY
            ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
            ,DM_DOCUMENT_D.BUNJA
            ,DP_INVOICE_SN.CONFIRMQTY)                                                                                         AS SERIALINSPECTQTY
            ,CASE WHEN DP_INPLAN.STORERKEY = 'CJFW' THEN CASE WHEN DP_INPLAN.UOM = 'KG' THEN DP_INVOICE_SN.CONFIRMQTY
            ELSE DP_INVOICE_SN.CONFIRMQTY * ST_SNINFO.NETWEIGHT
            END
            ELSE FN_CONV_UOM(DP_INPLAN.STORERKEY,DP_INPLAN.SKU,DP_INPLAN.UOM,'KG',DP_INVOICE_SN.CONFIRMQTY)
            END                                                                                                                           AS SERIALSCANWEIGHT
            ,CASE WHEN  DP_INPLAN.STORERKEY = 'CJFW'
            OR (    ST_SNINFO.SERIALNO IS NOT NULL
            AND (   DM_DOCUMENT_D.CHANNEL <![CDATA[<>]]> '1'
            OR DP_INPLAN.DCCODE = '2170')
            ) THEN 'Y'
            ELSE 'N'
            END                                                                                                                           AS CHECKFLAG
            ,MS_SKU.LINE01                                                                                                                 AS LINE01
            ,MS_SKU.SERIALYN                                                                                                               AS SERIALYN
            ,CASE WHEN DP_INPLAN.STORERKEY = 'FW00' AND ST_SNINFO.SERIALNO IS NULL THEN 'gray' ELSE 'black' END                            AS FONTCOLOR
        FROM DP_INPLAN
        JOIN CM_USER_AUTHORITY
            ON  CM_USER_AUTHORITY.USERID     = #{gUserId}
            AND  CM_USER_AUTHORITY.DCCODE     =  DP_INPLAN.DCCODE
            AND  CM_USER_AUTHORITY.STORERKEY  =  DP_INPLAN.STORERKEY
            AND  CM_USER_AUTHORITY.ORGANIZE   =  DP_INPLAN.ORGANIZE
            AND  CM_USER_AUTHORITY.AREA       =  DP_INPLAN.AREA
            <if test="fixdccode != null and fixdccode != ''">    AND    CM_USER_AUTHORITY.DCCODE     =  #{fixdccode}      </if>
            <if test="gStorerkey != null and gStorerkey != ''"> AND    CM_USER_AUTHORITY.STORERKEY  =  #{gStorerkey}   </if>
            <if test="gOrganize != null and gOrganize != ''">  AND    CM_USER_AUTHORITY.ORGANIZE   =  #{fixdccode}    </if>
            <if test="gArea != null and gArea != ''">      AND    CM_USER_AUTHORITY.AREA       =  #{gArea}        </if>
        JOIN DM_DOCUMENT_H
            ON     DP_INPLAN.DCCODE = DM_DOCUMENT_H.DCCODE
            AND DP_INPLAN.DOCTYPE = DM_DOCUMENT_H.DOCTYPE
            AND DP_INPLAN.SLIPDT = DM_DOCUMENT_H.DELIVERYDATE
            AND DP_INPLAN.DOCNO = DM_DOCUMENT_H.DOCNO
            AND    DM_DOCUMENT_H.DOCTYPE            = 'DP'
            AND    DM_DOCUMENT_H.DEL_YN             = 'N'
            <!-- 협력사 다중선택 -->
                <if test="fromCustkeyMulti != null and fromCustkeyMulti != '' ">
                    <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                        <foreach collection="fromCustkeyMulti" item="item">
                            OR DM_DOCUMENT_H.FROM_CUSTKEY IN
                            <foreach collection="item" item="code" open="(" close=")" separator=",">
                                #{code}
                            </foreach>
                        </foreach>
                    </trim>
                </if>
        JOIN DM_DOCUMENT_D
            ON    DP_INPLAN.DCCODE = DM_DOCUMENT_D.DCCODE
            AND DP_INPLAN.DOCTYPE = DM_DOCUMENT_D.DOCTYPE
            AND DP_INPLAN.SLIPDT = DM_DOCUMENT_D.DELIVERYDATE
            AND DP_INPLAN.DOCNO = DM_DOCUMENT_D.DOCNO
            AND DP_INPLAN.DOCLINE = DM_DOCUMENT_D.DOCLINE
            AND   DM_DOCUMENT_D.CHANNEL    IN ('2','3')   <!-- 저장품만 처리함 1.저장 2.일배 3.광역일배 2015.01.26 SLLEE MODIFY [ 1,2] 김해경님 요청 -->
            <if test="channel != null and channel != ''">      AND    DM_DOCUMENT_D.CHANNEL      LIKE #{channel}             </if>
            AND   DM_DOCUMENT_D.DEL_YN      = 'N'
            <if test="workprocesscode == 'STO'">
                JOIN
                DM_DOCUMENT_D DM_DOCUMENT_D_WD
                ON    DM_DOCUMENT_D_WD.DOCNO          = DP_INPLAN.DOCNO
                AND   DM_DOCUMENT_D_WD.DOCLINE        = DP_INPLAN.DOCLINE
                AND   DM_DOCUMENT_D_WD.DOCTYPE        = 'WD'
                AND   DM_DOCUMENT_D_WD.WORKPROCESSCODE = 'STO'
            </if>
        JOIN MS_SKU
            ON   MS_SKU.STORERKEY             	  =  DP_INPLAN.STORERKEY
            AND   MS_SKU.SKU                   	  =  DP_INPLAN.SKU
            AND   MS_SKU.SERIALYN                    = DECODE(DP_INPLAN.DCCODE,'2170',MS_SKU.SERIALYN,'Y')
            <if test="storagetype != null and storagetype != ''">  AND    MS_SKU.STORAGETYPE LIKE #{storagetype}             	  </if>
        LEFT OUTER JOIN MS_SKUDCSET
            ON    MS_SKUDCSET.STORERKEY  			= DM_DOCUMENT_D.STORERKEY
            AND   MS_SKUDCSET.DCCODE				= DM_DOCUMENT_D.DCCODE
            AND   MS_SKUDCSET.SKU					= DM_DOCUMENT_D.SKU
        LEFT OUTER JOIN DP_INVOICE_SN
            ON    DP_INVOICE_SN.DCCODE             = DP_INPLAN.DCCODE
            AND   DP_INVOICE_SN.STORERKEY          = DP_INPLAN.STORERKEY
            AND   DP_INVOICE_SN.DOCTYPE            = DP_INPLAN.DOCTYPE
            AND   DP_INVOICE_SN.SLIPNO             = DP_INPLAN.SLIPNO
            AND   DP_INVOICE_SN.SLIPDT             = DP_INPLAN.SLIPDT
            AND   DP_INVOICE_SN.SLIPLINE           = DP_INPLAN.SLIPLINE
            AND   DP_INVOICE_SN.SKU                = DP_INPLAN.SKU
            AND  (   (    DP_INVOICE_SN.CONFIRMQTY > 0
            AND DP_INPLAN.ORDERQTY       = DP_INPLAN.CONFIRMQTY)
            OR (    DP_INPLAN.ORDERQTY       > DP_INPLAN.CONFIRMQTY)
            )
        LEFT OUTER JOIN ST_SNINFO
            ON    ST_SNINFO.STORERKEY              = DP_INVOICE_SN.STORERKEY
            AND   ST_SNINFO.SKU                    = DP_INVOICE_SN.SKU
            AND   ST_SNINFO.SERIALNO               = DP_INVOICE_SN.SERIALNO
            AND   ST_SNINFO.STOCKID                = DP_INVOICE_SN.STOCKID
        WHERE DP_INPLAN.DCCODE      = #{fixdccode}
            <if test="slipnoMulti != null and slipnoMulti != ''">
                AND  DP_INPLAN.SLIPNO      IN
                <foreach collection="slipnoMulti" item="item" open="(" separator="," close=")">
                     #{item}
                </foreach>
            </if>
            <if test="skuMulti != null and skuMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="skuMulti" item="item">
                        OR DP_INPLAN.SKU IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
            <if test="docnoMulti != null and docnoMulti != ''">
                AND DP_INPLAN.DOCNO IN
                <foreach collection="docnoMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            <if test="ordertypeMulti != null and ordertypeMulti != ''">
                AND DP_INPLAN.ORDERTYPE IN
                <foreach collection="ordertypeMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
<!--        AND   DP_INPLAN.ORDERQTY  <![CDATA[>]]> 0	  /** 결품으로만 확정완료된건은 안보이게 하기위해서 */-->

        <if test="blno != null and blno != ''">
            AND   ST_SNINFO.CONVSERIALNO       =  #{blno}
        </if>
        <if test="serialno != null and serialno != ''">
            AND   ST_SNINFO.SERIALNO           =  #{serialno}
        </if>
        <if test="wdCustkey != null and wdCustkey != ''">
            AND   ST_SNINFO.CONTRACTCUSTKEY         =  #{wdCustkey}
        </if>
        <if test='crossyn == "Y"'>
            AND   MS_SKUDCSET.CROSSDOCKTYPE        = 'CROSS'
        </if>
        ORDER BY SLIPLINE
            ,SKU
        )
    </select>

    <!-- 저장품 입고예정 현황 리포트 이력상품 C/D -->
    <select id="getPrintCdList2" resultType="cjfw.wms.dp.dto.DpReceiptResExcelDto">
        SELECT /* [dpReceiptService.sqlx][dpReceiptService.getDataReportSerialCdList][]저장품 입고예정 현황 리포트정보(이력상품 C/D)][Chnag][20190822] */
            SLIPDT
            ,SLIPNO
            ,FROM_CUSTKEY
            ,FROM_CUSTNAME
            ,LOC
            ,SKU
            ,SKUNAME
            ,ORDERQTY
            ,UOM
            ,OPENQTY_EA
            ,OPENQTY_BOX
            ,OPENQTY_KG AS OPENQTY_KG
            ,CHANNEL_NAME AS CHANNEL_NAME
            ,QTYPERBOX
        FROM (
        WITH T_DP_INSPECT AS (
        SELECT DP_INSPECT.DCCODE          	AS DCCODE
        ,DP_INSPECT.STORERKEY 			AS STORERKEY
        ,DP_INSPECT.ORGANIZE 			AS ORGANIZE
        ,DP_INSPECT.AREA    			AS AREA
        ,DP_INSPECT.DOCDT  			AS DOCDT
        ,DP_INSPECT.DOCNO   			AS DOCNO
        ,DP_INSPECT.DOCLINE 			AS DOCLINE
        ,DP_INSPECT.DOCTYPE  			AS DOCTYPE
        ,DP_INSPECT.SLIPDT    			AS SLIPDT
        ,DP_INSPECT.SLIPNO   			AS SLIPNO
        ,DP_INSPECT.SLIPLINE  			AS SLIPLINE
        ,DP_INSPECT.SLIPTYPE   		AS SLIPTYPE
        ,DP_INSPECT.SKU				AS SKU
        ,DP_INSPECT.LOTTABLE01			AS LOTTABLE01
        ,DP_INSPECT.STOCKID			AS STOCKID
        ,DP_INSPECT.STOCKGRADE         AS STOCKGRADE
        ,SUM(DP_INSPECT.INSPECTQTY)    AS INSPECTQTY
        ,SUM(DP_INSPECT.CONFIRMQTY)    AS CONFIRMQTY
        ,DP_INSPECT.TOLOC				AS TOLOC
        FROM DP_INSPECT
        WHERE 1 = 1
        <if test="fixdccode != null and fixdccode != ''">    AND    DP_INSPECT.DCCODE     =  #{fixdccode}      </if>
        <if test="gStorerkey != null and gStorerkey != ''"> AND    DP_INSPECT.STORERKEY  =  #{gStorerkey}   </if>
        <if test="gOrganize != null and gOrganize != ''">  AND    DP_INSPECT.ORGANIZE   =  #{fixdccode}    </if>
        <if test="gArea != null and gArea != ''">      AND    DP_INSPECT.AREA       =  #{gArea}        </if>
        AND DP_INSPECT.DCCODE      = #{fixdccode}
            <if test="slipnoMulti != null and slipnoMulti != ''">
                AND  DP_INSPECT.SLIPNO      IN
                <foreach collection="slipnoMulti" item="item" open="(" separator="," close=")">
                     #{item}
                </foreach>
            </if>
        AND  DP_INSPECT.OPENQTY                  >  0
        AND  DP_INSPECT.INSPECTQTY               >  0
        GROUP BY DP_INSPECT.DCCODE
        ,DP_INSPECT.STORERKEY
        ,DP_INSPECT.ORGANIZE
        ,DP_INSPECT.AREA
        ,DP_INSPECT.DOCDT
        ,DP_INSPECT.DOCNO
        ,DP_INSPECT.DOCLINE
        ,DP_INSPECT.DOCTYPE
        ,DP_INSPECT.SLIPDT
        ,DP_INSPECT.SLIPNO
        ,DP_INSPECT.SLIPLINE
        ,DP_INSPECT.SLIPTYPE
        ,DP_INSPECT.SKU
        ,DP_INSPECT.LOTTABLE01
        ,DP_INSPECT.STOCKID
        ,DP_INSPECT.STOCKGRADE
        ,DP_INSPECT.TOLOC
        )
        SELECT '0'                   																											AS CHECKYN
        ,DP_INPLAN.DCCODE																				       							    AS DCCODE
        ,DP_INPLAN.STORERKEY																				    							AS STORERKEY
        ,DP_INPLAN.ORGANIZE																				    							AS ORGANIZE
        ,DP_INPLAN.DOCDT																					    							AS DOCDT
        ,DP_INPLAN.DOCNO																					    							AS DOCNO
        ,DP_INPLAN.DOCLINE                                   												    							AS DOCLINE
        ,DP_INPLAN.SLIPDT																					    							AS SLIPDT
        ,DP_INPLAN.SLIPNO																					    							AS SLIPNO
        ,DP_INPLAN.SLIPLINE                                   											    							AS SLIPLINE
        ,DM_DOCUMENT_H.FROM_CUSTKEY                                                                                                       AS FROM_CUSTKEY
        ,DM_DOCUMENT_H.FROM_CUSTNAME                                                                                                      AS FROM_CUSTNAME
        ,MS_SKUDCSET.LOC                                                                                                                  AS LOC
        ,DP_INPLAN.SKU                                       												    							AS SKU
        ,MS_SKU.DESCRIPTION                                      																	        AS SKUNAME
        ,'[' || MS_SKU.COUNTRYOFORIGIN || ']' ||
        (SELECT BASEDESCR
        FROM CM_CODE
        WHERE CM_CODE.STORERKEY = MS_SKU.STORERKEY
        AND CM_CODE.CODELIST = 'COUNTRY'
        AND CM_CODE.BASECODE = MS_SKU.COUNTRYOFORIGIN
        AND CM_CODE.DEL_YN = 'N') 																									AS COUNTRYOFORIGIN
        ,DM_DOCUMENT_D.STORERUOM                                 																			AS UOM
        ,DM_DOCUMENT_D.BUNJA                                 																				AS BUNJA
        ,DM_DOCUMENT_D.BUNMO                                 																				AS BUNMO
        ,FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'EA',DP_INPLAN.OPENQTY)		 					AS OPENQTY_EA
        ,FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'KG',DP_INPLAN.OPENQTY)		 					AS OPENQTY_KG
        ,CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY))					AS OPENQTY_BOX
        ,DECODE(MS_SKU.BOXPERPLT,0,0,CEIL(CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY)) /
        MS_SKU.BOXPERPLT)) 																												AS PLTQTY
        ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
        ,DM_DOCUMENT_D.BUNJA
        ,DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY    )                                      									AS ORDERQTY
        ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU , DP_INPLAN.UOM, 'KG',DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY),2)          AS ORDERWEIGHT
        ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU, DP_INPLAN.UOM, 'KG', DP_INPLAN.CONFIRMQTY), 2) AS CONFIRMWEIGHT
        ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
        ,DM_DOCUMENT_D.BUNJA
        ,DP_INPLAN.INSPECTQTY)                               					                                            AS INSPECTQTY
        ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
        ,DM_DOCUMENT_D.BUNJA
        ,DP_INPLAN.CONFIRMQTY)                                                                                               AS CONFIRMQTY

        <if test="workprocesscode == 'STO'">
            ,FN_UOMCAL  ( DM_DOCUMENT_D_WD.BUNMO
            ,DM_DOCUMENT_D_WD.BUNJA
            ,DM_DOCUMENT_D_WD.CONFIRMQTY )                                                                                       AS CONFIRMQTY_WD
            ,1                                                                          											           AS STO_FLAG
        </if>
        <if test='workprocesscode == "STO"'>
            ,0                                                                                                      				           AS CONFIRMQTY_WD
            ,0                                                                  															   AS STO_FLAG
        </if>
        ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
        ,DM_DOCUMENT_D.BUNJA
        ,DP_INPLAN.CANCELQTY    )                                                            								AS SHORTAGEQTY
        ,0                                                                                                     							AS SHORTAGETRANQTY
        ,0                                                                                                     							AS TRANQTY
        ,NVL(T_DP_INSPECT.TOLOC
        , CORE_CM_STRATEGY.FN_GETTOLOC ( DP_INPLAN.DOCTYPE
        ,DP_INPLAN.DCCODE
        ,DP_INPLAN.STORERKEY
        ,DP_INPLAN.ORDERTYPE
        ,DP_INPLAN.SLIPTYPE   ))                                           							AS TOLOC
        ,NVL(T_DP_INSPECT.LOTTABLE01,DP_INPLAN.LOTTABLE01)                                       				                            AS LOTTABLE01
        ,FN_LOTDURATION(DP_INPLAN.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, NVL(T_DP_INSPECT.LOTTABLE01,DP_INPLAN.LOTTABLE01), 'N')||'/'||MS_SKU.DURATION      AS DURATION_TERM
        ,MS_SKU.COLORDESCR                                       																			AS COLORDESCR
        ,DM_DOCUMENT_D.REFERENCE02                                                      													AS REFERENCE02
        ,DM_DOCUMENT_D.REASONCODE                                                             											AS REASONCODE
        ,DM_DOCUMENT_D.REASONMSG                                 																			AS REASONMSG
        ,CASE WHEN NVL(T_DP_INSPECT.LOTTABLE01,DP_INPLAN.LOTTABLE01)='STD' THEN 'N'
        WHEN MONTHS_BETWEEN(TO_DATE(NVL(T_DP_INSPECT.LOTTABLE01,DP_INPLAN.LOTTABLE01),'yyyy-mm-dd'),SYSDATE)>3 THEN 'N' ELSE 'Y' END   AS NEARDURATIONYN
        ,DM_DOCUMENT_D.STATUS            																									AS STATUS
        ,FN_CODEDESCR(DM_DOCUMENT_D.STORERKEY,'STATUS_DP', DM_DOCUMENT_D.STATUS)                                      					AS STATUSNAME
        ,MS_SKU.QTYPERBOX         																								    	AS QTYPERBOX
        ,DM_DOCUMENT_D.CHANNEL     																										AS CHANNEL
        ,MS_SKU.DURATION																													AS DURATION
        ,0     																															AS DURATION_RATE
        ,MS_SKU.DURATIONTYPE																												AS DURATIONTYPE
        ,UNISTR('')                																									    AS LASTLOTTABLE01
        ,NVL(NVL(ST_SNINFO.STOCKID,T_DP_INSPECT.STOCKID),DP_INPLAN.STOCKID)                                                               AS STOCKID
        ,NVL(T_DP_INSPECT.STOCKGRADE,DP_INPLAN.STOCKGRADE)                                                                                AS STOCKGRADE
        ,DECODE(SPDP_RECEIPT.FN_GETTOLOC( DP_INPLAN.DCCODE
        ,DP_INPLAN.STORERKEY
        ,DP_INPLAN.SKU
        ,DM_DOCUMENT_D.PLANT
        ,DM_DOCUMENT_D.STORAGELOC
        ,DM_DOCUMENT_D.CHANNEL
        ),'CROSS','CROSS','STAGE')                                                                        AS CROSSLOC
        ,DM_DOCUMENT_D.PLANT																												AS PLANT
        ,'['||DM_DOCUMENT_D.PLANT||']'||fn_descr_plant(DM_DOCUMENT_D.PLANT)  																AS PLANT_DESCR
        ,FN_CODEDESCR(DP_INPLAN.STORERKEY,'PUTAWAYTYPE', DM_DOCUMENT_D.CHANNEL) 											                AS CHANNEL_NAME
        ,FN_CODEDESCR(MS_SKU.STORERKEY,'STORAGETYPE', MS_SKU.STORAGETYPE)  												                AS STORAGETYPENAME

        ,ST_SNINFO.SERIALNO               																						        AS SERIALNO
        ,ST_SNINFO.CONVSERIALNO           																						        AS CONVSERIALNO
        ,ST_SNINFO.FACTORYNAME            																						        AS FACTORYNAME
        ,ST_SNINFO.CONTRACTCUSTKEY                                                                                                     AS CONTRACTCOMPANY
        ,( SELECT DESCRIPTION  FROM MS_CUST
        WHERE CUSTKEY = ST_SNINFO.CONTRACTCUSTKEY
        AND ROWNUM = 1)                                                                                                              AS CONTRACTCOMPANYNAME
        ,FN_CODEDESCR(ST_SNINFO.STORERKEY,'CONTRACTTYPE_SN',ST_SNINFO.CONTRACTTYPE)                                                AS CONTRACTTYPE
        ,ST_SNINFO.BUTCHERYDT                                                                                                          AS BUTCHERYDT
        ,ST_SNINFO.FROMVALIDDT                                                                                                         AS FROMVALIDDT
        ,ST_SNINFO.TOVALIDDT                                                                                                           AS TOVALIDDT
        ,ST_SNINFO.STOCKID                                                                                                             AS BARCODE
        ,ST_SNINFO.STOCKID                                                                                                             AS BARCODE
        ,CASE WHEN ST_SNINFO.STOCKID IS NULL THEN NULL
        ELSE FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
        ,DM_DOCUMENT_D.BUNJA
        ,T_DP_INSPECT.INSPECTQTY )
        END                                                                                                                           AS SERIALORDERQTY
        ,CASE WHEN ST_SNINFO.STOCKID IS NULL THEN NULL
        ELSE FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
        ,DM_DOCUMENT_D.BUNJA
        ,T_DP_INSPECT.CONFIRMQTY )
        END                                                                                                                           AS SERIALINSPECTQTY
        ,CASE WHEN DP_INPLAN.STORERKEY = 'CJFW' THEN CASE WHEN ST_SNINFO.STOCKID IS NULL THEN NULL
        ELSE DECODE(DP_INPLAN.UOM,'KG',T_DP_INSPECT.CONFIRMQTY,T_DP_INSPECT.CONFIRMQTY * ST_SNINFO.NETWEIGHT)
        END
        ELSE CASE WHEN ST_SNINFO.STOCKID IS NULL THEN NULL
        ELSE FN_CONV_UOM(DP_INPLAN.STORERKEY,DP_INPLAN.SKU,DP_INPLAN.UOM,'KG',T_DP_INSPECT.CONFIRMQTY)
        END
        END                                                                                                                           AS SERIALSCANWEIGHT
        ,CASE WHEN  DP_INPLAN.STORERKEY = 'CJFW'
        OR (ST_SNINFO.SERIALNO IS NOT NULL) THEN 'Y'
        ELSE 'N'
        END                                                                                                                           AS CHECKFLAG
        ,MS_SKU.LINE01                                                                                                                 AS LINE01
        ,MS_SKU.SERIALYN                                                                                                               AS SERIALYN
        ,CASE WHEN DP_INPLAN.STORERKEY = 'FW00' AND ST_SNINFO.SERIALNO IS NULL THEN 'gray' ELSE 'black' END                            AS FONTCOLOR
        FROM
        DP_INPLAN
        JOIN
        CM_USER_AUTHORITY
        ON  CM_USER_AUTHORITY.USERID     = #{gUserId}
        AND  CM_USER_AUTHORITY.DCCODE     =  DP_INPLAN.DCCODE
        AND  CM_USER_AUTHORITY.STORERKEY  =  DP_INPLAN.STORERKEY
        AND  CM_USER_AUTHORITY.ORGANIZE   =  DP_INPLAN.ORGANIZE
        AND  CM_USER_AUTHORITY.AREA       =  DP_INPLAN.AREA
        <if test="fixdccode != null and fixdccode != ''">    AND    CM_USER_AUTHORITY.DCCODE     =  #{fixdccode}      </if>
        <if test="gStorerkey != null and gStorerkey != ''"> AND    CM_USER_AUTHORITY.STORERKEY  =  #{gStorerkey}   </if>
        <if test="gOrganize != null and gOrganize != ''">  AND    CM_USER_AUTHORITY.ORGANIZE   =  #{fixdccode}    </if>
        <if test="gArea != null and gArea != ''">      AND    CM_USER_AUTHORITY.AREA       =  #{gArea}        </if>
        JOIN
        DM_DOCUMENT_H
        ON     DP_INPLAN.DCCODE = DM_DOCUMENT_H.DCCODE
        AND DP_INPLAN.DOCTYPE = DM_DOCUMENT_H.DOCTYPE
        AND DP_INPLAN.SLIPDT = DM_DOCUMENT_H.DELIVERYDATE
        AND DP_INPLAN.DOCNO = DM_DOCUMENT_H.DOCNO
        AND    DM_DOCUMENT_H.DOCTYPE            = 'DP'
        AND    DM_DOCUMENT_H.DEL_YN             = 'N'
        <!-- 협력사 다중선택 -->
            <if test="fromCustkeyMulti != null and fromCustkeyMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="fromCustkeyMulti" item="item">
                        OR DM_DOCUMENT_H.FROM_CUSTKEY IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
        JOIN
        DM_DOCUMENT_D
        ON    DP_INPLAN.DCCODE = DM_DOCUMENT_D.DCCODE
        AND DP_INPLAN.DOCTYPE = DM_DOCUMENT_D.DOCTYPE
        AND DP_INPLAN.SLIPDT = DM_DOCUMENT_D.DELIVERYDATE
        AND DP_INPLAN.DOCNO = DM_DOCUMENT_D.DOCNO
        AND DP_INPLAN.DOCLINE = DM_DOCUMENT_D.DOCLINE
        AND   DM_DOCUMENT_D.CHANNEL      IN ('1','2','3')   <!-- 저장품만 처리함 1.저장 2.일배 3.광역일배 2015.01.26 SLLEE MODIFY [ 1,2] 김해경님 요청 -->
        <if test="channel != null and channel != ''">      AND    DM_DOCUMENT_D.CHANNEL      LIKE #{channel}             </if>
        AND   DM_DOCUMENT_D.DEL_YN      = 'N'

        <if test="workprocesscode == 'STO'">
            JOIN
            DM_DOCUMENT_D DM_DOCUMENT_D_WD
            ON    DM_DOCUMENT_D_WD.DOCNO          = DP_INPLAN.DOCNO
            AND   DM_DOCUMENT_D_WD.DOCLINE        = DP_INPLAN.DOCLINE
            AND   DM_DOCUMENT_D_WD.DOCTYPE        = 'WD'
            AND   DM_DOCUMENT_D_WD.WORKPROCESSCODE = 'STO'
        </if>
        JOIN
        MS_SKU
        ON   MS_SKU.STORERKEY             	  =  DP_INPLAN.STORERKEY
        AND   MS_SKU.SKU                   	  =  DP_INPLAN.SKU
        AND   MS_SKU.SERIALYN                    = DECODE(DP_INPLAN.DCCODE,'2170',MS_SKU.SERIALYN,'Y')
        <if test="storagetype != null and storagetype != ''">  AND    MS_SKU.STORAGETYPE LIKE #{storagetype}             	  </if>
        LEFT OUTER JOIN    MS_SKUDCSET
        ON   	MS_SKUDCSET.STORERKEY  		  = DM_DOCUMENT_D.STORERKEY
        AND   	MS_SKUDCSET.DCCODE			  = DM_DOCUMENT_D.DCCODE
        AND   	MS_SKUDCSET.SKU				  = DM_DOCUMENT_D.SKU
        JOIN
        T_DP_INSPECT
        ON     T_DP_INSPECT.DCCODE           = DP_INPLAN.DCCODE
        AND    T_DP_INSPECT.STORERKEY        = DP_INPLAN.STORERKEY
        AND    T_DP_INSPECT.SLIPDT           = DP_INPLAN.SLIPDT
        AND    T_DP_INSPECT.SLIPNO           = DP_INPLAN.SLIPNO
        AND    T_DP_INSPECT.SLIPLINE         = DP_INPLAN.SLIPLINE
        LEFT OUTER JOIN   ST_SNINFO
        ON     ST_SNINFO.STORERKEY       = T_DP_INSPECT.STORERKEY
        AND    ST_SNINFO.STOCKID         = T_DP_INSPECT.STOCKID

        WHERE DP_INPLAN.DCCODE      = #{fixdccode}
            <if test="slipnoMulti != null and slipnoMulti != ''">
                AND  DP_INPLAN.SLIPNO      IN
                <foreach collection="slipnoMulti" item="item" open="(" separator="," close=")">
                     #{item}
                </foreach>
            </if>
            <if test="skuMulti != null and skuMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="skuMulti" item="item">
                        OR DP_INPLAN.SKU IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
            <if test="docnoMulti != null and docnoMulti != ''">
                AND DP_INPLAN.DOCNO IN
                <foreach collection="docnoMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            <if test="ordertypeMulti != null and ordertypeMulti != ''">
                AND DP_INPLAN.ORDERTYPE IN
                <foreach collection="ordertypeMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
<!--        AND   DP_INPLAN.ORDERQTY  <![CDATA[>]]> 0	  /** 결품으로만 확정완료된건은 안보이게 하기위해서 */-->
        <if test="blno != null and blno != ''">
            AND   ST_SNINFO.CONVSERIALNO       =  #{blno}
        </if>
        <if test="serialno != null and serialno != ''">
            AND   ST_SNINFO.SERIALNO           =  #{serialno}
        </if>
        <if test="wdCustkey != null and wdCustkey != ''">
            AND   ST_SNINFO.CONTRACTCUSTKEY         =  #{wdCustkey}
        </if>
        <if test='crossyn == "Y"'>
            AND   MS_SKUDCSET.CROSSDOCKTYPE        = 'CROSS'
        </if>
        UNION ALL
        SELECT '0'                   																											AS CHECKYN
        ,DP_INPLAN.DCCODE																				       							    AS DCCODE
        ,DP_INPLAN.STORERKEY																				    							AS STORERKEY
        ,DP_INPLAN.ORGANIZE																				    							AS ORGANIZE
        ,DP_INPLAN.DOCDT																					    							AS DOCDT
        ,DP_INPLAN.DOCNO																					    							AS DOCNO
        ,DP_INPLAN.DOCLINE                                   												    							AS DOCLINE
        ,DP_INPLAN.SLIPDT																					    							AS SLIPDT
        ,DP_INPLAN.SLIPNO																					    							AS SLIPNO
        ,DP_INPLAN.SLIPLINE                                   											    							AS SLIPLINE
        ,DM_DOCUMENT_H.FROM_CUSTKEY                                                                                                       AS FROM_CUSTKEY
        ,DM_DOCUMENT_H.FROM_CUSTNAME                                                                                                      AS FROM_CUSTNAME
        ,MS_SKUDCSET.LOC                                                                                                                  AS LOC
        ,DP_INPLAN.SKU                                       												    							AS SKU
        ,MS_SKU.DESCRIPTION                                      																	        AS SKUNAME
        ,'[' || MS_SKU.COUNTRYOFORIGIN || ']' ||
        (SELECT BASEDESCR
        FROM CM_CODE
        WHERE CM_CODE.STORERKEY = MS_SKU.STORERKEY
        AND CM_CODE.CODELIST = 'COUNTRY'
        AND CM_CODE.BASECODE = MS_SKU.COUNTRYOFORIGIN
        AND CM_CODE.DEL_YN = 'N') 																									AS COUNTRYOFORIGIN
        ,DM_DOCUMENT_D.STORERUOM                                 																			AS UOM
        ,DM_DOCUMENT_D.BUNJA                                 																				AS BUNJA
        ,DM_DOCUMENT_D.BUNMO                                 																				AS BUNMO
        ,FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'EA',DP_INPLAN.OPENQTY)		 					AS OPENQTY_EA
        ,FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'KG',DP_INPLAN.OPENQTY)		 					AS OPENQTY_KG
        ,CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY))					AS OPENQTY_BOX
        ,DECODE(MS_SKU.BOXPERPLT,0,0,CEIL(CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY)) /
        MS_SKU.BOXPERPLT)) 																												AS PLTQTY
        ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
        ,DM_DOCUMENT_D.BUNJA
        ,DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY    )                                      									AS ORDERQTY
        ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU , DP_INPLAN.UOM, 'KG',DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY),2)          AS ORDERWEIGHT
        ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU, DP_INPLAN.UOM, 'KG', DP_INPLAN.CONFIRMQTY), 2) AS CONFIRMWEIGHT
        ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
        ,DM_DOCUMENT_D.BUNJA
        ,DP_INPLAN.INSPECTQTY)                               					                                            AS INSPECTQTY
        ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
        ,DM_DOCUMENT_D.BUNJA
        ,DP_INPLAN.CONFIRMQTY)                                                                                               AS CONFIRMQTY
        <if test="workprocesscode == 'STO'">
            ,FN_UOMCAL  ( DM_DOCUMENT_D_WD.BUNMO
            ,DM_DOCUMENT_D_WD.BUNJA
            ,DM_DOCUMENT_D_WD.CONFIRMQTY )                                                                                       AS CONFIRMQTY_WD
            ,1                                                                          											           AS STO_FLAG
        </if>
        <if test='workprocesscode == "STO"'>
            ,0                                                                                                      				           AS CONFIRMQTY_WD
            ,0                                                                  															   AS STO_FLAG
        </if>
        ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
        ,DM_DOCUMENT_D.BUNJA
        ,DP_INPLAN.CANCELQTY    )                                                            								AS SHORTAGEQTY
        ,0                                                                                                     							AS SHORTAGETRANQTY
        ,0                                                                                                     							AS TRANQTY
        ,CORE_CM_STRATEGY.FN_GETTOLOC ( DP_INPLAN.DOCTYPE
        ,DP_INPLAN.DCCODE
        ,DP_INPLAN.STORERKEY
        ,DP_INPLAN.ORDERTYPE
        ,DP_INPLAN.SLIPTYPE   )                                           							        AS TOLOC
        ,NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01)                                       				                            AS LOTTABLE01
        ,FN_LOTDURATION(DP_INPLAN.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01), 'N')||'/'||MS_SKU.DURATION      AS DURATION_TERM
        ,MS_SKU.COLORDESCR                                       																			AS COLORDESCR
        ,DM_DOCUMENT_D.REFERENCE02                                                      													AS REFERENCE02
        ,DM_DOCUMENT_D.REASONCODE                                                             											AS REASONCODE
        ,DM_DOCUMENT_D.REASONMSG                                 																			AS REASONMSG
        ,CASE WHEN NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01)='STD' THEN 'N'
        WHEN MONTHS_BETWEEN(TO_DATE(NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01),'yyyy-mm-dd'),SYSDATE)>3 THEN 'N' ELSE 'Y' END   AS NEARDURATIONYN
        ,DM_DOCUMENT_D.STATUS            																									AS STATUS
        ,FN_CODEDESCR(DM_DOCUMENT_D.STORERKEY,'STATUS_DP', DM_DOCUMENT_D.STATUS)                                      					AS STATUSNAME
        ,MS_SKU.QTYPERBOX         																								    	AS QTYPERBOX
        ,DM_DOCUMENT_D.CHANNEL     																										AS CHANNEL
        ,MS_SKU.DURATION																													AS DURATION
        ,0     																															AS DURATION_RATE
        ,MS_SKU.DURATIONTYPE																												AS DURATIONTYPE
        ,UNISTR('')          																									            AS LASTLOTTABLE01
        ,NVL(ST_SNINFO.STOCKID,DP_INPLAN.STOCKID)                                                                                     AS STOCKID
        ,DP_INPLAN.STOCKGRADE                                                                                                             AS STOCKGRADE
        ,DECODE(SPDP_RECEIPT.FN_GETTOLOC( DP_INPLAN.DCCODE
        ,DP_INPLAN.STORERKEY
        ,DP_INPLAN.SKU
        ,DM_DOCUMENT_D.PLANT
        ,DM_DOCUMENT_D.STORAGELOC
        ,DM_DOCUMENT_D.CHANNEL
        ),'CROSS','CROSS','STAGE')                                                                        AS CROSSLOC
        ,DM_DOCUMENT_D.PLANT																												AS PLANT
        ,'['||DM_DOCUMENT_D.PLANT||']'||fn_descr_plant(DM_DOCUMENT_D.PLANT)  																AS PLANT_DESCR
        ,FN_CODEDESCR(DP_INPLAN.STORERKEY,'PUTAWAYTYPE', DM_DOCUMENT_D.CHANNEL) 											                AS CHANNEL_NAME
        ,FN_CODEDESCR(MS_SKU.STORERKEY,'STORAGETYPE', MS_SKU.STORAGETYPE)  												                AS STORAGETYPENAME

        ,ST_SNINFO.SERIALNO               																						        AS SERIALNO
        ,ST_SNINFO.CONVSERIALNO           																						        AS CONVSERIALNO
        ,ST_SNINFO.FACTORYNAME            																						        AS FACTORYNAME
        ,ST_SNINFO.CONTRACTCUSTKEY                                                                                                     AS CONTRACTCOMPANY
        ,( SELECT DESCRIPTION  FROM MS_CUST
        WHERE CUSTKEY = ST_SNINFO.CONTRACTCUSTKEY
        AND ROWNUM = 1)                                                                                                              AS CONTRACTCOMPANYNAME
        ,FN_CODEDESCR(ST_SNINFO.STORERKEY,'CONTRACTTYPE_SN',ST_SNINFO.CONTRACTTYPE)                                                AS CONTRACTTYPE
        ,ST_SNINFO.BUTCHERYDT                                                                                                          AS BUTCHERYDT
        ,ST_SNINFO.FROMVALIDDT                                                                                                         AS FROMVALIDDT
        ,ST_SNINFO.TOVALIDDT                                                                                                           AS TOVALIDDT
        ,ST_SNINFO.STOCKID                                                                                                             AS BARCODE
        ,ST_SNINFO.STOCKID                                                                                                             AS BARCODE
        ,CASE WHEN ST_SNINFO.STOCKID IS NULL THEN NULL
        ELSE FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
        ,DM_DOCUMENT_D.BUNJA
        ,DP_INVOICE_SN.ORDERQTY - DP_INVOICE_SN.CONFIRMQTY)
        END                                                                                                                           AS SERIALORDERQTY
        ,CASE WHEN ST_SNINFO.STOCKID IS NULL THEN NULL
        ELSE 0
        END                                                                                                                           AS SERIALINSPECTQTY
        ,CASE WHEN ST_SNINFO.STOCKID IS NULL THEN NULL
        ELSE 0
        END                                                                                                                           AS SERIALSCANWEIGHT
        ,CASE WHEN  DP_INPLAN.STORERKEY = 'CJFW'
        OR (    ST_SNINFO.SERIALNO IS NOT NULL
        AND (   DM_DOCUMENT_D.CHANNEL <![CDATA[<>]]> '1'
        OR DP_INPLAN.DCCODE = '2170')
        ) THEN 'Y'
        ELSE 'N'
        END                                                                                                                           AS CHECKFLAG
        ,MS_SKU.LINE01                                                                                                                 AS LINE01
        ,MS_SKU.SERIALYN                                                                                                                   AS SERIALYN
        ,CASE WHEN DP_INPLAN.STORERKEY = 'FW00' AND ST_SNINFO.SERIALNO IS NULL THEN 'gray' ELSE 'black' END                            AS FONTCOLOR
        FROM
        DP_INPLAN
        JOIN
        CM_USER_AUTHORITY
        ON  CM_USER_AUTHORITY.USERID     = #{gUserId}
        AND  CM_USER_AUTHORITY.DCCODE     =  DP_INPLAN.DCCODE
        AND  CM_USER_AUTHORITY.STORERKEY  =  DP_INPLAN.STORERKEY
        AND  CM_USER_AUTHORITY.ORGANIZE   =  DP_INPLAN.ORGANIZE
        AND  CM_USER_AUTHORITY.AREA       =  DP_INPLAN.AREA
        <if test="fixdccode != null and fixdccode != ''">    AND    CM_USER_AUTHORITY.DCCODE     =  #{fixdccode}      </if>
        <if test="gStorerkey != null and gStorerkey != ''"> AND    CM_USER_AUTHORITY.STORERKEY  =  #{gStorerkey}   </if>
        <if test="gOrganize != null and gOrganize != ''">  AND    CM_USER_AUTHORITY.ORGANIZE   =  #{fixdccode}    </if>
        <if test="gArea != null and gArea != ''">      AND    CM_USER_AUTHORITY.AREA       =  #{gArea}        </if>
        JOIN
        DM_DOCUMENT_H
        ON     DP_INPLAN.DCCODE = DM_DOCUMENT_H.DCCODE
        AND DP_INPLAN.DOCTYPE = DM_DOCUMENT_H.DOCTYPE
        AND DP_INPLAN.SLIPDT = DM_DOCUMENT_H.DELIVERYDATE
        AND DP_INPLAN.DOCNO = DM_DOCUMENT_H.DOCNO
        AND    DM_DOCUMENT_H.DOCTYPE            = 'DP'
        AND    DM_DOCUMENT_H.DEL_YN             = 'N'
        <!-- 협력사 다중선택 -->
            <if test="fromCustkeyMulti != null and fromCustkeyMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="fromCustkeyMulti" item="item">
                        OR DM_DOCUMENT_H.FROM_CUSTKEY IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
        JOIN
        DM_DOCUMENT_D
        ON    DP_INPLAN.DCCODE = DM_DOCUMENT_D.DCCODE
        AND DP_INPLAN.DOCTYPE = DM_DOCUMENT_D.DOCTYPE
        AND DP_INPLAN.SLIPDT = DM_DOCUMENT_D.DELIVERYDATE
        AND DP_INPLAN.DOCNO = DM_DOCUMENT_D.DOCNO
        AND DP_INPLAN.DOCLINE = DM_DOCUMENT_D.DOCLINE
        AND   DM_DOCUMENT_D.CHANNEL     = '1'   <!-- 저장품만 처리함 1.저장 2.일배 3.광역일배 2015.01.26 SLLEE MODIFY [ 1,2] 김해경님 요청 -->
        <if test="channel != null and channel != ''">      AND    DM_DOCUMENT_D.CHANNEL      LIKE #{channel}             </if>
        AND   DM_DOCUMENT_D.DEL_YN      = 'N'
        <if test="workprocesscode == 'STO'">
            JOIN
            DM_DOCUMENT_D DM_DOCUMENT_D_WD
            ON    DM_DOCUMENT_D_WD.DOCNO          = DP_INPLAN.DOCNO
            AND   DM_DOCUMENT_D_WD.DOCLINE        = DP_INPLAN.DOCLINE
            AND   DM_DOCUMENT_D_WD.DOCTYPE        = 'WD'
            AND   DM_DOCUMENT_D_WD.WORKPROCESSCODE = 'STO'
        </if>
        JOIN
        MS_SKU
        ON   MS_SKU.STORERKEY             	  =  DP_INPLAN.STORERKEY
        AND   MS_SKU.SKU                   	  =  DP_INPLAN.SKU
        AND   MS_SKU.SERIALYN                    = DECODE(DP_INPLAN.DCCODE,'2170',MS_SKU.SERIALYN,'Y')
        <if test="storagetype != null and storagetype != ''">  AND    MS_SKU.STORAGETYPE LIKE #{storagetype}             	  </if>
        LEFT OUTER JOIN
        MS_SKUDCSET
        ON    MS_SKUDCSET.STORERKEY  			= DM_DOCUMENT_D.STORERKEY
        AND   MS_SKUDCSET.DCCODE				= DM_DOCUMENT_D.DCCODE
        AND   MS_SKUDCSET.SKU					= DM_DOCUMENT_D.SKU

        LEFT OUTER JOIN
        DP_INVOICE_SN
        ON    DP_INVOICE_SN.DCCODE             = DP_INPLAN.DCCODE
        AND   DP_INVOICE_SN.STORERKEY          = DP_INPLAN.STORERKEY
        AND   DP_INVOICE_SN.DOCTYPE            = DP_INPLAN.DOCTYPE
        AND   DP_INVOICE_SN.SLIPNO             = DP_INPLAN.SLIPNO
        AND   DP_INVOICE_SN.SLIPDT             = DP_INPLAN.SLIPDT
        AND   DP_INVOICE_SN.SLIPLINE           = DP_INPLAN.SLIPLINE
        AND   DP_INVOICE_SN.SKU                = DP_INPLAN.SKU
        AND   DP_INVOICE_SN.ORDERQTY
        -DP_INVOICE_SN.CONFIRMQTY         > 0

        LEFT OUTER JOIN
        ST_SNINFO
        ON    ST_SNINFO.STORERKEY              = DP_INVOICE_SN.STORERKEY
        AND   ST_SNINFO.SKU                    = DP_INVOICE_SN.SKU
        AND   ST_SNINFO.SERIALNO               = DP_INVOICE_SN.SERIALNO
        AND   ST_SNINFO.STOCKID                = DP_INVOICE_SN.STOCKID

        WHERE DP_INPLAN.DCCODE      = #{fixdccode}
            <if test="slipnoMulti != null and slipnoMulti != ''">
                AND  DP_INPLAN.SLIPNO      IN
                <foreach collection="slipnoMulti" item="item" open="(" separator="," close=")">
                     #{item}
                </foreach>
            </if>
            <if test="skuMulti != null and skuMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="skuMulti" item="item">
                        OR DP_INPLAN.SKU IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
            <if test="docnoMulti != null and docnoMulti != ''">
                AND DP_INPLAN.DOCNO IN
                <foreach collection="docnoMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            <if test="ordertypeMulti != null and ordertypeMulti != ''">
                AND DP_INPLAN.ORDERTYPE IN
                <foreach collection="ordertypeMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>

<!--        AND   DP_INPLAN.ORDERQTY  <![CDATA[>]]> 0	  /** 결품으로만 확정완료된건은 안보이게 하기위해서 */-->
        AND   DP_INPLAN.ORDERQTY
        - DP_INPLAN.CONFIRMQTY <![CDATA[>]]> 0

        <if test="blno != null and blno != ''">
            AND   ST_SNINFO.CONVSERIALNO       =  #{blno}
        </if>
        <if test="serialno != null and serialno != ''">
            AND   ST_SNINFO.SERIALNO           =  #{serialno}
        </if>
        <if test="wdCustkey != null and wdCustkey != ''">
            AND   ST_SNINFO.CONTRACTCUSTKEY         =  #{wdCustkey}
        </if>
        <if test='crossyn == "Y"'>
            AND   MS_SKUDCSET.CROSSDOCKTYPE        = 'CROSS'
        </if>
        UNION ALL
        SELECT
        '0'                   																											AS CHECKYN
        ,DP_INPLAN.DCCODE																				       							    AS DCCODE
        ,DP_INPLAN.STORERKEY																				    							AS STORERKEY
        ,DP_INPLAN.ORGANIZE																				    							AS ORGANIZE
        ,DP_INPLAN.DOCDT																					    							AS DOCDT
        ,DP_INPLAN.DOCNO																					    							AS DOCNO
        ,DP_INPLAN.DOCLINE                                   												    							AS DOCLINE
        ,DP_INPLAN.SLIPDT																					    							AS SLIPDT
        ,DP_INPLAN.SLIPNO																					    							AS SLIPNO
        ,DP_INPLAN.SLIPLINE                                   											    							AS SLIPLINE
        ,DM_DOCUMENT_H.FROM_CUSTKEY                                                                                                       AS FROM_CUSTKEY
        ,DM_DOCUMENT_H.FROM_CUSTNAME                                                                                                      AS FROM_CUSTNAME
        ,MS_SKUDCSET.LOC                                                                                                                  AS LOC
        ,DP_INPLAN.SKU                                       												    							AS SKU
        ,MS_SKU.DESCRIPTION                                      																	        AS SKUNAME
        ,'[' || MS_SKU.COUNTRYOFORIGIN || ']' ||
        (SELECT BASEDESCR
        FROM CM_CODE
        WHERE CM_CODE.STORERKEY = MS_SKU.STORERKEY
        AND CM_CODE.CODELIST = 'COUNTRY'
        AND CM_CODE.BASECODE = MS_SKU.COUNTRYOFORIGIN
        AND CM_CODE.DEL_YN = 'N') 																									AS COUNTRYOFORIGIN
        ,DM_DOCUMENT_D.STORERUOM                                 																			AS UOM
        ,DM_DOCUMENT_D.BUNJA                                 																				AS BUNJA
        ,DM_DOCUMENT_D.BUNMO                                 																				AS BUNMO
        ,FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'EA',DP_INPLAN.OPENQTY)		 					AS OPENQTY_EA
        ,FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'KG',DP_INPLAN.OPENQTY)		 					AS OPENQTY_KG
        ,CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY))					AS OPENQTY_BOX
        ,DECODE(MS_SKU.BOXPERPLT,0,0,CEIL(CEIL(FN_CONV_UOM(DM_DOCUMENT_D.STORERKEY,DM_DOCUMENT_D.SKU,DM_DOCUMENT_D.STORERUOM, 'BOX',DP_INPLAN.OPENQTY)) /
        MS_SKU.BOXPERPLT)) 																												AS PLTQTY
        ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
        ,DM_DOCUMENT_D.BUNJA
        ,DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY    )                                      									AS ORDERQTY
        ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU , DP_INPLAN.UOM, 'KG',DP_INPLAN.ORDERQTY + DP_INPLAN.CANCELQTY),2)          AS ORDERWEIGHT
        ,ROUND(FN_CONV_UOM(DP_INPLAN.STORERKEY, DP_INPLAN.SKU, DP_INPLAN.UOM, 'KG', DP_INPLAN.CONFIRMQTY), 2) AS CONFIRMWEIGHT
        ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
        ,DM_DOCUMENT_D.BUNJA
        ,DP_INPLAN.INSPECTQTY)                               					                                            AS INSPECTQTY
        ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
        ,DM_DOCUMENT_D.BUNJA
        ,DP_INPLAN.CONFIRMQTY)                                                                                               AS CONFIRMQTY
        <if test="workprocesscode == 'STO'">
            ,FN_UOMCAL  ( DM_DOCUMENT_D_WD.BUNMO
            ,DM_DOCUMENT_D_WD.BUNJA
            ,DM_DOCUMENT_D_WD.CONFIRMQTY )                                                                                       AS CONFIRMQTY_WD
            ,1                                                                          											           AS STO_FLAG
        </if>
        <if test='workprocesscode == "STO"'>
            ,0                                                                                                      				           AS CONFIRMQTY_WD
            ,0                                                                  															   AS STO_FLAG
        </if>
        ,FN_UOMCAL  ( DM_DOCUMENT_D.BUNMO
        ,DM_DOCUMENT_D.BUNJA
        ,DP_INPLAN.CANCELQTY    )                                                            								AS SHORTAGEQTY
        ,0                                                                                                     							AS SHORTAGETRANQTY
        ,0                                                                                                     							AS TRANQTY
        ,CORE_CM_STRATEGY.FN_GETTOLOC ( DP_INPLAN.DOCTYPE
        ,DP_INPLAN.DCCODE
        ,DP_INPLAN.STORERKEY
        ,DP_INPLAN.ORDERTYPE
        ,DP_INPLAN.SLIPTYPE   )                                           							        AS TOLOC
        ,NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01)                                       				                            AS LOTTABLE01
        ,FN_LOTDURATION(DP_INPLAN.STORERKEY, MS_SKU.DURATIONTYPE, MS_SKU.DURATION, NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01), 'N')||'/'||MS_SKU.DURATION      AS DURATION_TERM
        ,MS_SKU.COLORDESCR                                       																			AS COLORDESCR
        ,DM_DOCUMENT_D.REFERENCE02                                                      													AS REFERENCE02
        ,DM_DOCUMENT_D.REASONCODE                                                             											AS REASONCODE
        ,DM_DOCUMENT_D.REASONMSG                                 																			AS REASONMSG
        ,CASE WHEN NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01)='STD' THEN 'N'
        WHEN MONTHS_BETWEEN(TO_DATE(NVL(ST_SNINFO.LOTTABLE01,DP_INPLAN.LOTTABLE01),'yyyy-mm-dd'),SYSDATE)>3 THEN 'N' ELSE 'Y' END   AS NEARDURATIONYN
        ,DM_DOCUMENT_D.STATUS            																									AS STATUS
        ,FN_CODEDESCR(DM_DOCUMENT_D.STORERKEY,'STATUS_DP', DM_DOCUMENT_D.STATUS)                                      					AS STATUSNAME
        ,MS_SKU.QTYPERBOX         																								    	AS QTYPERBOX
        ,DM_DOCUMENT_D.CHANNEL     																										AS CHANNEL
        ,MS_SKU.DURATION																													AS DURATION
        ,0     																															AS DURATION_RATE
        ,MS_SKU.DURATIONTYPE																												AS DURATIONTYPE
        ,UNISTR('')       																									            AS LASTLOTTABLE01
        ,NVL(ST_SNINFO.STOCKID,DP_INPLAN.STOCKID)                                                                                     AS STOCKID
        ,DP_INPLAN.STOCKGRADE                                                                                                             AS STOCKGRADE
        ,DECODE(SPDP_RECEIPT.FN_GETTOLOC( DP_INPLAN.DCCODE
        ,DP_INPLAN.STORERKEY
        ,DP_INPLAN.SKU
        ,DM_DOCUMENT_D.PLANT
        ,DM_DOCUMENT_D.STORAGELOC
        ,DM_DOCUMENT_D.CHANNEL
        ),'CROSS','CROSS','STAGE')                                                                        AS CROSSLOC
        ,DM_DOCUMENT_D.PLANT																												AS PLANT
        ,'['||DM_DOCUMENT_D.PLANT||']'||fn_descr_plant(DM_DOCUMENT_D.PLANT)  																AS PLANT_DESCR
        ,FN_CODEDESCR(DP_INPLAN.STORERKEY,'PUTAWAYTYPE', DM_DOCUMENT_D.CHANNEL) 											                AS CHANNEL_NAME
        ,FN_CODEDESCR(MS_SKU.STORERKEY,'STORAGETYPE', MS_SKU.STORAGETYPE)  												                AS STORAGETYPENAME

        ,ST_SNINFO.SERIALNO               																						        AS SERIALNO
        ,ST_SNINFO.CONVSERIALNO           																						        AS CONVSERIALNO
        ,ST_SNINFO.FACTORYNAME            																						        AS FACTORYNAME
        ,ST_SNINFO.CONTRACTCUSTKEY                                                                                                     AS CONTRACTCOMPANY
        ,( SELECT DESCRIPTION  FROM MS_CUST
        WHERE CUSTKEY = ST_SNINFO.CONTRACTCUSTKEY
        AND ROWNUM = 1)                                                                                                          AS CONTRACTCOMPANYNAME
        ,FN_CODEDESCR(ST_SNINFO.STORERKEY,'CONTRACTTYPE_SN',ST_SNINFO.CONTRACTTYPE)                                                    AS CONTRACTTYPE
        ,ST_SNINFO.BUTCHERYDT                                                                                                          AS BUTCHERYDT
        ,ST_SNINFO.FROMVALIDDT                                                                                                         AS FROMVALIDDT
        ,ST_SNINFO.TOVALIDDT                                                                                                           AS TOVALIDDT
        ,ST_SNINFO.STOCKID                                                                                                             AS BARCODE
        ,ST_SNINFO.STOCKID                                                                                                             AS BARCODE
        ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
        ,DM_DOCUMENT_D.BUNJA
        ,DP_INVOICE_SN.ORDERQTY)                                                                                           AS SERIALORDERQTY
        ,FN_UOMCAL ( DM_DOCUMENT_D.BUNMO
        ,DM_DOCUMENT_D.BUNJA
        ,DP_INVOICE_SN.CONFIRMQTY)                                                                                         AS SERIALINSPECTQTY
        ,CASE WHEN DP_INPLAN.STORERKEY = 'CJFW' THEN CASE WHEN DP_INPLAN.UOM = 'KG' THEN DP_INVOICE_SN.CONFIRMQTY
        ELSE DP_INVOICE_SN.CONFIRMQTY * ST_SNINFO.NETWEIGHT
        END
        ELSE FN_CONV_UOM(DP_INPLAN.STORERKEY,DP_INPLAN.SKU,DP_INPLAN.UOM,'KG',DP_INVOICE_SN.CONFIRMQTY)
        END                                                                                                                           AS SERIALSCANWEIGHT
        ,CASE WHEN  DP_INPLAN.STORERKEY = 'CJFW'
        OR (    ST_SNINFO.SERIALNO IS NOT NULL
        AND (   DM_DOCUMENT_D.CHANNEL <![CDATA[<>]]> '1'
        OR DP_INPLAN.DCCODE = '2170')
        ) THEN 'Y'
        ELSE 'N'
        END                                                                                                                           AS CHECKFLAG
        ,MS_SKU.LINE01                                                                                                                 AS LINE01
        ,MS_SKU.SERIALYN                                                                                                               AS SERIALYN
        ,CASE WHEN DP_INPLAN.STORERKEY = 'FW00' AND ST_SNINFO.SERIALNO IS NULL THEN 'gray' ELSE 'black' END                            AS FONTCOLOR
        FROM
        DP_INPLAN
        JOIN
        CM_USER_AUTHORITY
        ON  CM_USER_AUTHORITY.USERID     = #{gUserId}
        AND  CM_USER_AUTHORITY.DCCODE     =  DP_INPLAN.DCCODE
        AND  CM_USER_AUTHORITY.STORERKEY  =  DP_INPLAN.STORERKEY
        AND  CM_USER_AUTHORITY.ORGANIZE   =  DP_INPLAN.ORGANIZE
        AND  CM_USER_AUTHORITY.AREA       =  DP_INPLAN.AREA
        <if test="fixdccode != null and fixdccode != ''">    AND    CM_USER_AUTHORITY.DCCODE     =  #{fixdccode}      </if>
        <if test="gStorerkey != null and gStorerkey != ''"> AND    CM_USER_AUTHORITY.STORERKEY  =  #{gStorerkey}   </if>
        <if test="gOrganize != null and gOrganize != ''">  AND    CM_USER_AUTHORITY.ORGANIZE   =  #{fixdccode}    </if>
        <if test="gArea != null and gArea != ''">      AND    CM_USER_AUTHORITY.AREA       =  #{gArea}        </if>
        JOIN
        DM_DOCUMENT_H
        ON     DP_INPLAN.DCCODE = DM_DOCUMENT_H.DCCODE
        AND DP_INPLAN.DOCTYPE = DM_DOCUMENT_H.DOCTYPE
        AND DP_INPLAN.SLIPDT = DM_DOCUMENT_H.DELIVERYDATE
        AND DP_INPLAN.DOCNO = DM_DOCUMENT_H.DOCNO
        AND    DM_DOCUMENT_H.DOCTYPE            = 'DP'
        AND    DM_DOCUMENT_H.DEL_YN             = 'N'
        <!-- 협력사 다중선택 -->
            <if test="fromCustkeyMulti != null and fromCustkeyMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="fromCustkeyMulti" item="item">
                        OR DM_DOCUMENT_H.FROM_CUSTKEY IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
        JOIN
        DM_DOCUMENT_D
        ON    DP_INPLAN.DCCODE = DM_DOCUMENT_D.DCCODE
        AND DP_INPLAN.DOCTYPE = DM_DOCUMENT_D.DOCTYPE
        AND DP_INPLAN.SLIPDT = DM_DOCUMENT_D.DELIVERYDATE
        AND DP_INPLAN.DOCNO = DM_DOCUMENT_D.DOCNO
        AND DP_INPLAN.DOCLINE = DM_DOCUMENT_D.DOCLINE
        AND   DM_DOCUMENT_D.CHANNEL    IN ('2','3')   <!-- 저장품만 처리함 1.저장 2.일배 3.광역일배 2015.01.26 SLLEE MODIFY [ 1,2] 김해경님 요청 -->
        <if test="channel != null and channel != ''">      AND    DM_DOCUMENT_D.CHANNEL      LIKE #{channel}             </if>
        AND   DM_DOCUMENT_D.DEL_YN      = 'N'
        <if test="workprocesscode == 'STO'">
            JOIN
            DM_DOCUMENT_D DM_DOCUMENT_D_WD
            ON    DM_DOCUMENT_D_WD.DOCNO          = DP_INPLAN.DOCNO
            AND   DM_DOCUMENT_D_WD.DOCLINE        = DP_INPLAN.DOCLINE
            AND   DM_DOCUMENT_D_WD.DOCTYPE        = 'WD'
            AND   DM_DOCUMENT_D_WD.WORKPROCESSCODE = 'STO'
        </if>
        JOIN
        MS_SKU
        ON   MS_SKU.STORERKEY             	  =  DP_INPLAN.STORERKEY
        AND   MS_SKU.SKU                   	  =  DP_INPLAN.SKU
        AND   MS_SKU.SERIALYN                    = DECODE(DP_INPLAN.DCCODE,'2170',MS_SKU.SERIALYN,'Y')
        <if test="storagetype != null and storagetype != ''">  AND    MS_SKU.STORAGETYPE LIKE #{storagetype}             	  </if>
        LEFT OUTER JOIN
        MS_SKUDCSET
        ON    MS_SKUDCSET.STORERKEY  			= DM_DOCUMENT_D.STORERKEY
        AND   MS_SKUDCSET.DCCODE				= DM_DOCUMENT_D.DCCODE
        AND   MS_SKUDCSET.SKU					= DM_DOCUMENT_D.SKU

        LEFT OUTER JOIN
        DP_INVOICE_SN
        ON    DP_INVOICE_SN.DCCODE             = DP_INPLAN.DCCODE
        AND   DP_INVOICE_SN.STORERKEY          = DP_INPLAN.STORERKEY
        AND   DP_INVOICE_SN.DOCTYPE            = DP_INPLAN.DOCTYPE
        AND   DP_INVOICE_SN.SLIPNO             = DP_INPLAN.SLIPNO
        AND   DP_INVOICE_SN.SLIPDT             = DP_INPLAN.SLIPDT
        AND   DP_INVOICE_SN.SLIPLINE           = DP_INPLAN.SLIPLINE
        AND   DP_INVOICE_SN.SKU                = DP_INPLAN.SKU
        AND  (   (    DP_INVOICE_SN.CONFIRMQTY > 0
        AND DP_INPLAN.ORDERQTY       = DP_INPLAN.CONFIRMQTY)
        OR (    DP_INPLAN.ORDERQTY       > DP_INPLAN.CONFIRMQTY)
        )

        LEFT OUTER JOIN
        ST_SNINFO
        ON    ST_SNINFO.STORERKEY              = DP_INVOICE_SN.STORERKEY
        AND   ST_SNINFO.SKU                    = DP_INVOICE_SN.SKU
        AND   ST_SNINFO.SERIALNO               = DP_INVOICE_SN.SERIALNO
        AND   ST_SNINFO.STOCKID                = DP_INVOICE_SN.STOCKID

        WHERE DP_INPLAN.DCCODE      = #{fixdccode}
            <if test="slipnoMulti != null and slipnoMulti != ''">
                AND  DP_INPLAN.SLIPNO      IN
                <foreach collection="slipnoMulti" item="item" open="(" separator="," close=")">
                     #{item}
                </foreach>
            </if>
            <if test="skuMulti != null and skuMulti != '' ">
                <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                    <foreach collection="skuMulti" item="item">
                        OR DP_INPLAN.SKU IN
                        <foreach collection="item" item="code" open="(" close=")" separator=",">
                            #{code}
                        </foreach>
                    </foreach>
                </trim>
            </if>
            <if test="docnoMulti != null and docnoMulti != ''">
                AND DP_INPLAN.DOCNO IN
                <foreach collection="docnoMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>
            <if test="ordertypeMulti != null and ordertypeMulti != ''">
                AND DP_INPLAN.ORDERTYPE IN
                <foreach collection="ordertypeMulti" item="code" open="(" close=")" separator=",">
                    #{code}
                </foreach>
            </if>

<!--        AND   DP_INPLAN.ORDERQTY  <![CDATA[>]]> 0	  /** 결품으로만 확정완료된건은 안보이게 하기위해서 */-->

        <if test="blno != null and blno != ''">
            AND   ST_SNINFO.CONVSERIALNO       =  #{blno}
        </if>
        <if test="serialno != null and serialno != ''">
            AND   ST_SNINFO.SERIALNO           =  #{serialno}
        </if>
        <if test="wdCustkey != null and wdCustkey != ''">
            AND   ST_SNINFO.CONTRACTCUSTKEY         =  #{wdCustkey}
        </if>
        <if test='crossyn == "Y"'>
            AND   MS_SKUDCSET.CROSSDOCKTYPE        = 'CROSS'
        </if>
        ORDER BY SLIPLINE
        ,SKU
        )
    </select>

    <insert id="insertReverseSto">
        INSERT INTO OM_STO_DP_RETURN(
            FROM_DCCODE
            , DOCNO
            , DOCLINE
            , RETURNQTY
            , STO_DOCDT
            , STO_DOCNO
            , STO_DOCLINE
            , RMK
            , ADDDATE
            , EDITDATE
            , ADDWHO
            , EDITWHO
        )VALUES(
            #{fromDccode}
            , #{docno}
            , #{docline}
            , #{returnqty}
            , #{stoDocdt}
            , #{stoDocno}
            , #{stoDocline}
            , #{rmk}
            , SYSDATE
            , SYSDATE
            , #{addwho}
            , #{editwho}
        )
    </insert>

    <delete id="deleteDpPltInspect">
        DELETE FROM DP_INSPECT_PLT
        WHERE DP_INSPECT_PLT.DCCODE = #{dccode}
            AND DP_INSPECT_PLT.DELIVERYDATE = #{slipdt}
            AND DP_INSPECT_PLT.DP_LABEL = #{barcode}
    </delete>
</mapper>