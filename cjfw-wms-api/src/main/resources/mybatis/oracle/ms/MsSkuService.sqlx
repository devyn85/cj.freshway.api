<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="msSkuService">
	<!-- 상품 정보 조회(목록) -->
	<select id="getMasterList" resultType="MsSkuResDto">
        SELECT  /* [msSkuService.sqlx][msSkuService.getMasterList][상품 정보 조회(목록)][jangjaehyun][20250611] */ 
        A.*
	        	FROM
    (     SELECT
            '0'                                  AS CHECKYN      /* 체크여부  */        ,
            MAX(MS_SKU.SERIALKEY      )                     AS SERIALKEY             /* 데이터번호*/        ,
            CUSTXSKU.DCCODE         AS DCCODE         ,
            MS_SKU.STORERKEY                                AS STORERKEY             /* 고객사코드*/        ,
            MS_SKU.SKU                                      AS SKU                   /* 상품코드*/        ,
            MAX(MS_SKU.DESCRIPTION)                         AS DESCRIPTION           /* 기본 제품명 없을경우 SKU코드*/        ,
            MAX(MS_SKU.STORAGETYPE    )                     AS STORAGETYPE           /** 대분류 혹은 저장 타입 1-저온 2-상온 3-제약 4-사료벌크 5-셋트 ....*/        ,
            NVL(MAX(MS_SKU.DURATIONTYPE   ),'N')            AS DURATIONTYPE          /* 유통기한관리방법*/        ,
            MAX(MS_SKU.DURATION       )                     AS DURATION              /* 유통기간*/        ,
            MAX(MS_SKU.QTYPERBOX      )                     AS QTYPERBOX             /* 박스당 낱개수*/        ,
            MAX(MS_SKU.NETWEIGHT      )                     AS NETWEIGHT             /* 개당 실중량 Kg*/        ,
            MAX(MS_SKU.BASEUOM        )                     AS BASEUOM               /* 기본 단위*/        ,
            MAX(MS_SKU.PURCHASEUOM    )                     AS PURCHASEUOM           /* 구매 단위*/        ,
            MAX(MS_SKU.RETURNUOM      )                     AS RETURNUOM             /* 회수 돤위*/        ,
            MAX(MS_SKU.SKUTYPE        )                     AS SKUTYPE               /** 상품유형 제품-FERT,상품-HAWA,반제품-HALB,원자재-ROH*/        ,
            MAX(MS_SKU.SKUCLASS       )                     AS SKUCLASS              /* 상품클래스*/        ,
            MAX(MS_SKU.SERIALTYPE     )                     AS SERIALTYPE            /* 유통이력신고기관*/    ,
            MAX(MS_SKU.BOXPERPLT      )                     AS BOXPERPLT             /* 팔렛당 박스수*/        ,
            MAX(MS_SKU.LAYERPERPLT    )                     AS LAYERPERPLT           /* 팔렛당적재단수*/        ,
            MAX(MS_SKU.BOXPERLAYER    )                     AS BOXPERLAYER           /* 적재단당박스수*/        ,
            --MAX(MS_SKU.PUTAWAYTYPE    )                     AS PUTAWAYTYPE           /* 적치유형*/        ,
            MAX(CUSTXSKU.channel    )                     AS PUTAWAYTYPE           /* 적치유형*/        ,
            MAX(MS_SKU.SERIALYN       )                     AS SERIALYN              /* 시리얼관리여부*/        ,
            MAX(MS_SKU.LINE01         )                     AS LINE01                /* 제품 생산라인1*/        ,
            CUSTXSKU.CUSTTYPE                        AS CUSTTYPE              /* 거래처유형*/        ,
            CUSTXSKU.CUSTKEY                         AS CUSTKEY               /* 거래처코드*/        ,
            MAX(CUST1.DESCRIPTION)                   AS CUSTNAME              /* 거래처명*/        ,
            MAX(MS_SKU.REFERENCE01    )                     AS REFERENCE01           /* 참조정보1*/        ,
            MAX(MS_SKU.SOMDNAME       )                     AS SOMDNAME              /* 판매담당명*/        ,
            MAX(MS_SKU.LABELTYPE  )       AS LABELTYPE                     ,
            MAX(MS_SKU.ADDWHO  )       AS ADDWHO                     ,
            MAX(MS_SKU.ADDDATE  )       AS ADDDATE                     ,
            MAX(MS_SKU.EDITWHO  )       AS EDITWHO                     ,
            MAX(MS_SKU.EDITDATE  )       AS EDITDATE
            ,MAX(USER1.USER_NM) AS ADDWHO_NM  /*등록자명*/
			,MAX(USER2.USER_NM) AS EDITWHO_NM  /*수정자명*/
        	FROM   MS_SKU
        LEFT OUTER JOIN (select ms_purchasecust.custtype
		        	          , ms_purchasecust.custkey
		        	          , ms_purchasecust.dccode
		        	          , ms_purchasecust.STORERKEY 
		        	          , ms_purchasecust.sku
		        	          ,  ms_purchasecust.channel
		        	     from   ms_purchasecust
		        	     where  ms_purchasecust.dccode = #{gDccode}
		        	     and    ms_purchasecust.storerkey = #{gStorerkey}
		        	     group by ms_purchasecust.storerkey
		        	            , ms_purchasecust.dccode
		        	            , ms_purchasecust.custtype
		        	            , ms_purchasecust.custkey
		        	            , ms_purchasecust.sku
		        	            , ms_purchasecust.channel) CUSTXSKU
        ON     MS_SKU.STORERKEY = CUSTXSKU.STORERKEY 
        AND    MS_SKU.SKU =  CUSTXSKU.SKU 
		JOIN   CM_USER_AUTHORITY_DCXSTORER  
        ON     CM_USER_AUTHORITY_DCXSTORER.USERID        = #{gUserId}
        AND    CM_USER_AUTHORITY_DCXSTORER.DCCODE     = #{gDccode}
        AND    CM_USER_AUTHORITY_DCXSTORER.STORERKEY	=  #{gStorerkey}
        AND    CM_USER_AUTHORITY_DCXSTORER.STORERKEY     = MS_SKU.STORERKEY
        LEFT JOIN MS_CUST CUST1 	  ON CUST1.STORERKEY = CUSTXSKU.STORERKEY AND CUST1.CUSTTYPE  = 'P' 	AND CUST1.CUSTKEY   = CUSTXSKU.CUSTKEY
        LEFT JOIN FRAMEONE_USER USER1 ON USER1.USER_ID = MS_SKU.ADDWHO   /*등록자명*/
        LEFT JOIN FRAMEONE_USER USER2 ON USER2.USER_ID = MS_SKU.EDITWHO  /*수정자명*/
        WHERE  1=1        
        <if test="storerKey != null and storerKey.trim().length() > 0">
        	AND    MS_SKU.STORERKEY                 LIKE #{storerKey}
        </if>
		<if test='skuCodeList != null and skuCodeList.length > 0'>
		  AND (
			    <foreach item="group" collection="skuCodeList" separator="OR">
			        MS_SKU.SKU IN
			        <foreach item="item" collection="group" open="(" close=")" separator=",">
			            #{item}
			        </foreach>
			    </foreach>
			  )
		</if>  
        <if test="description != null and description.trim().length() > 0">
		    AND MS_SKU.DESCRIPTION LIKE #{description}
		</if>
		<if test="skuGroup != null and skuGroup.trim().length() > 0">
		    AND LEFT(MS_SKU.SKUGROUP,2) LIKE #{skuGroup}
		</if>
		<if test="product != null and product.trim().length() > 0">
		    AND MS_SKU.PRODUCT LIKE #{product}
		</if>
		<if test="skuType != null and skuType.trim().length() > 0">
		    AND MS_SKU.SKUTYPE LIKE #{skuType}
		</if>
		<if test="salesSku != null and salesSku.trim().length() > 0">
		    AND MS_SKU.SALESSKU LIKE #{salesSku}
		</if>
		<if test="manufacturerSku != null and manufacturerSku.trim().length() > 0">
		    AND MS_SKU.MANUFACTURERSKU LIKE #{manufacturerSku}
		</if>
		<if test="custSku != null and custSku.trim().length() > 0">
		    AND MS_SKU.CUSTSKU LIKE #{custSku}
		</if>
		<if test="etcDescr1 != null and etcDescr1.trim().length() > 0">
		    AND MS_SKU.ETC_DESCR1 LIKE #{etcDescr1}
		</if>
		<if test="etcDescr2 != null and etcDescr2.trim().length() > 0">
		    AND MS_SKU.ETC_DESCR2 LIKE #{etcDescr2}
		</if>
		<if test="altSku != null and altSku.trim().length() > 0">
		    AND MS_SKU.ALTSKU LIKE #{altSku}
		</if>
		<if test="retailSku != null and retailSku.trim().length() > 0">
		    AND MS_SKU.RETAILSKU LIKE #{retailSku}
		</if>
		<if test="barcode1 != null and barcode1.trim().length() > 0">
		    AND MS_SKU.BARCODE1 LIKE #{barcode1}
		</if>
		<if test="barcode2 != null and barcode2.trim().length() > 0">
		    AND MS_SKU.BARCODE2 LIKE #{barcode2}
		</if>
		<if test="barcode3 != null and barcode3.trim().length() > 0">
		    AND MS_SKU.BARCODE3 LIKE #{barcode3}
		</if>
		<if test="brandCode != null and brandCode.trim().length() > 0">
		    AND MS_SKU.BRANDCODE LIKE #{brandCode}
		</if>
		<if test="brandDescr != null and brandDescr.trim().length() > 0">
		    AND MS_SKU.BRANDDESCR LIKE #{brandDescr}
		</if>
		<if test="seasonYear != null and seasonYear.trim().length() > 0">
		    AND MS_SKU.SEASONYEAR LIKE #{seasonYear}
		</if>
		<if test="seasonCode != null and seasonCode.trim().length() > 0">
		    AND MS_SKU.SEASONCODE LIKE #{seasonCode}
		</if>
		<if test="seasonDescr != null and seasonDescr.trim().length() > 0">
		    AND MS_SKU.SEASONDESCR LIKE #{seasonDescr}
		</if>
		<if test="seasonOut != null and seasonOut.trim().length() > 0">
		    AND MS_SKU.SEASONOUT LIKE #{seasonOut}
		</if>
		<if test="styleCode != null and styleCode.trim().length() > 0">
		    AND MS_SKU.STYLECODE LIKE #{styleCode}
		</if>
		<if test="styleDescr != null and styleDescr.trim().length() > 0">
		    AND MS_SKU.STYLEDESCR LIKE #{styleDescr}
		</if>
		<if test="colorCode != null and colorCode.trim().length() > 0">
		    AND MS_SKU.COLORCODE LIKE #{colorCode}
		</if>
		<if test="colorDescr != null and colorDescr.trim().length() > 0">
		    AND MS_SKU.COLORDESCR LIKE #{colorDescr}
		</if>
		<if test="sizeCode != null and sizeCode.trim().length() > 0">
		    AND MS_SKU.SIZECODE LIKE #{sizeCode}
		</if>
		<if test="sizeDescr != null and sizeDescr.trim().length() > 0">
		    AND MS_SKU.SIZEDESCR LIKE #{sizeDescr}
		</if>
		<if test="plantCustKey != null and plantCustKey.trim().length() > 0">
		    AND MS_SKU.PLANTCUSTKEY LIKE #{plantCustKey}
		</if>
		<if test="importCustKey != null and importCustKey.trim().length() > 0">
		    AND MS_SKU.IMPORTCUSTKEY LIKE #{importCustKey}
		</if>
		<if test="distributionCustKey != null and distributionCustKey.trim().length() > 0">
		    AND MS_SKU.DISTRIBUTIONCUSTKEY LIKE #{distributionCustKey}
		</if>
		<if test="returnCustKey != null and returnCustKey.trim().length() > 0">
		    AND MS_SKU.RETURNCUSTKEY LIKE #{returnCustKey}
		</if>
		<if test="disuseCustKey != null and disuseCustKey.trim().length() > 0">
		    AND MS_SKU.DISUSECUSTKEY LIKE #{disuseCustKey}
		</if>
		<if test="vendor != null and vendor.trim().length() > 0">
		    AND MS_SKU.VENDOR LIKE #{vendor}
		</if>
		<if test="skuOptions != null and skuOptions.trim().length() > 0">
		    AND MS_SKU.SKUOPTIONS LIKE #{skuOptions}
		</if>
		<if test="duration != null and duration.trim().length() > 0">
		    AND MS_SKU.DURATION LIKE #{duration}
		</if>
		<if test="baseUom != null and baseUom.trim().length() > 0">
		    AND MS_SKU.BASEUOM LIKE #{baseUom}
		</if>
		<if test="purchaseUom != null and purchaseUom.trim().length() > 0">
		    AND MS_SKU.PURCHASEUOM LIKE #{purchaseUom}
		</if>
		<if test="salesUom != null and salesUom.trim().length() > 0">
		    AND MS_SKU.SALESUOM LIKE #{salesUom}
		</if>
		<if test="grossWeight != null and grossWeight.trim().length() > 0">
		    AND MS_SKU.GROSSWEIGHT LIKE #{grossWeight}
		</if>
		<if test="netWeight != null and netWeight.trim().length() > 0">
		    AND MS_SKU.NETWEIGHT LIKE #{netWeight}
		</if>
		<if test="cube != null and cube.trim().length() > 0">
		    AND MS_SKU.CUBE LIKE #{cube}
		</if>
		<if test="cubeDescr != null and cubeDescr.trim().length() > 0">
		    AND MS_SKU.CUBEDESCR LIKE #{cubeDescr}
		</if>
		<if test="storageType != null and storageType.trim().length() > 0">
		    <if test="storageType == '50'">
		    	AND MS_SKU.STORAGETYPE IN ('10','20')
		    </if>
		    <if test="storageType != '50'">
		    	AND MS_SKU.STORAGETYPE LIKE #{storageType}
		    </if>
		</if>
		<if test="bomType != null and bomType.trim().length() > 0">
		    AND MS_SKU.BOMTYPE LIKE #{bomType}
		</if>
		<if test="purchaseType != null and purchaseType.trim().length() > 0">
		    AND MS_SKU.PURCHASETYPE LIKE #{purchaseType}
		</if>
		<if test="purchasePrice != null and purchasePrice.trim().length() > 0">
		    AND MS_SKU.PURCHASEPRICE LIKE #{purchasePrice}
		</if>
		<if test="serialYn != null and serialYn.trim().length() > 0">
		    AND MS_SKU.SERIALYN LIKE #{serialYn}
		</if>
		<if test="mixboxYn != null and mixboxYn.trim().length() > 0">
		    AND MS_SKU.MIXBOXYN LIKE #{mixboxYn}
		</if>
		<if test="abc != null and abc.trim().length() > 0">
		    AND MS_SKU.ABC LIKE #{abc}
		</if>
		<if test="line01 != null and line01.trim().length() > 0">
		    AND MS_SKU.LINE01 LIKE #{line01}
		</if>
		<if test="line02 != null and line02.trim().length() > 0">
		    AND MS_SKU.LINE02 LIKE #{line02}
		</if>
		<if test="line03 != null and line03.trim().length() > 0">
		    AND MS_SKU.LINE03 LIKE #{line03}
		</if>
		<if test="other01 != null and other01.trim().length() > 0">
		    AND MS_SKU.OTHER01 LIKE #{other01}
		</if>
		<if test="other02 != null and other02.trim().length() > 0">
		    AND MS_SKU.OTHER02 LIKE #{other02}
		</if>
		<if test="other03 != null and other03.trim().length() > 0">
		    AND MS_SKU.OTHER03 LIKE #{other03}
		</if>
		<if test="other04 != null and other04.trim().length() > 0">
		    AND MS_SKU.OTHER04 LIKE #{other04}
		</if>
		<if test="other05 != null and other05.trim().length() > 0">
		    AND MS_SKU.OTHER05 LIKE #{other05}
		</if>
		<if test="reference01 != null and reference01.trim().length() > 0">
		    AND MS_SKU.REFERENCE01 LIKE #{reference01}
		</if>
		<if test="reference02 != null and reference02.trim().length() > 0">
		    AND MS_SKU.REFERENCE02 LIKE #{reference02}
		</if>
		<if test="reference03 != null and reference03.trim().length() > 0">
		    AND MS_SKU.REFERENCE03 LIKE #{reference03}
		</if>
		<if test="reference04 != null and reference04.trim().length() > 0">
		    AND MS_SKU.REFERENCE04 LIKE #{reference04}
		</if>
		<if test="reference05 != null and reference05.trim().length() > 0">
		    AND MS_SKU.REFERENCE05 LIKE #{reference05}
		</if>
		<if test="ifFileName != null and ifFileName.trim().length() > 0">
		    AND MS_SKU.IFFILENAME LIKE #{ifFileName}
		</if>
		<if test="statusSku != null and statusSku.trim().length() > 0">
		    AND MS_SKU.STATUS LIKE #{statusSku}
		</if>
		<if test="delYn != null and delYn.trim().length() > 0">
		    AND MS_SKU.DEL_YN LIKE #{delYn}
		</if>
		<if test="somdName != null and somdName.trim().length() > 0">
		    AND MS_SKU.SOMDNAME LIKE #{somdName}
		</if>
		<if test="pomdName != null and pomdName.trim().length() > 0">
		    AND MS_SKU.POMDNAME LIKE #{pomdName}
		</if>
        <!-- 협력사 다중선택 -->				
		<if test='partnerCode != null and partnerCode !=""'>
          AND CUSTXSKU.CUSTKEY IN
          (SELECT TRIM(REGEXP_SUBSTR(VAL,'[^,]+',1,LEVEL)) AS VAL
                        FROM (SELECT #{partnerCode} AS VAL FROM DUAL) A
                     CONNECT BY INSTR(A.VAL, ',', 1, LEVEL - 1) > 0)
        </if>        
		GROUP BY 
		    MS_SKU.STORERKEY   
		   ,MS_SKU.SKU         
		   ,CUSTXSKU.DCCODE      
		   ,CUSTXSKU.CUSTTYPE    
		   ,CUSTXSKU.CUSTKEY     
		   ,CUSTXSKU.STORERKEY
        ORDER BY
            MS_SKU.SKU                ,
            CUSTXSKU.CUSTKEY        ) A        
    </select>
    
    <!-- 상품 정보 조회(목록) -->
	<select id="getMaster" resultType="MsSkuDetailResDto">
		SELECT
		    /* [msSkuService.sqlx][msSkuService.getMaster][상품 정보 조회(단건)][jangjaehyun][20250616] */         
		    MS_SKU.SERIALKEY                           AS SERIALKEY             /* 데이터번호*/    ,
		    MS_SKU.STORERKEY                           AS STORERKEY             /* 고객사코드*/    ,
		    MS_SKU.SKU                                 AS SKU                   /* 상품코드*/    ,
		    MS_SKU.DESCRIPTION                         AS DESCRIPTION           /* 기본 제품명 없을경우 SKU코드*/    ,
		    MS_SKU.INVOICEDESCR                        AS INVOICEDESCR          /* 명세서및 운송장 표기용 상품명*/    ,
		    MS_SKU.ETC_DESCR1                          AS ETC_DESCR1            /* 기타 제품명*/    ,
		    MS_SKU.ETC_DESCR2                          AS ETC_DESCR2            /* 기타 제품명 */    ,
		    MS_SKU.NAMEPRINTTYPE                       AS NAMEPRINTTYPE         /* 명세서찍히는 상품명 출력방법*/    ,
		    MS_SKU.STORAGETYPE                         AS STORAGETYPE           /** 대분류 혹은 저장 타입 1-저온 2-상온 3-제약 4-사료벌크 5-셋트 ....*/    ,
		    MS_SKU.SKUGROUP                            AS SKUGROUP              /* 상품그룹*/    ,
		    MS_SKU.PRODUCT                             AS PRODUCT               /* 상품종류*/    ,
		    MS_SKU.SKUTYPE                             AS SKUTYPE               /** 상품유형 제품-FERT,상품-HAWA,반제품-HALB,원자재-ROH*/    ,
		    MS_SKU.PUTAWAYTYPE                         AS PUTAWAYTYPE           /* 적치유형*/    ,
		    MS_SKU.SKUCLASS                            AS SKUCLASS              /* 상품클래스*/    ,		    
		    MS_SKU.UNITCODE                            AS UNITCODE              /* 단품코드*/    ,
		    MS_SKU.ITEMCODE                            AS ITEMCODE              /* 아이템코드*/    ,
		    MS_SKU.CUSTSKU                             AS CUSTSKU               /* 거래처상품코드*/    ,
		    MS_SKU.SALESSKU                            AS SALESSKU              /* 판매상품코드*/    ,
		    MS_SKU.MANUFACTURERSKU                     AS MANUFACTURERSKU       /* 생산코드*/    ,
		    MS_SKU.ALTSKU                              AS ALTSKU                /* 대체상품코드*/    ,
		    MS_SKU.RETAILSKU                           AS RETAILSKU             /* 판매상품코드*/    ,
		    MS_SKU.BARCODE1                            AS BARCODE1              /* 표준 바코드*/    ,
		    MS_SKU.BARCODE2                            AS BARCODE2              /* EAN13 바코드*/    ,
		    MS_SKU.BARCODE3                            AS BARCODE3              /* EAN14 바코드*/    ,
		    MS_SKU.BRANDCODE                           AS BRANDCODE             /* 제픔 브랜드 없을경우 고객사코드*/    ,
		    MS_SKU.BRANDDESCR                          AS BRANDDESCR            /* 브랜드명*/    ,
		    MS_SKU.SEASONYEAR                          AS SEASONYEAR            /* 시즌년도*/    ,
		    MS_SKU.SEASONCODE                          AS SEASONCODE            /* 제품 시즌*/    ,
		    MS_SKU.SEASONDESCR                         AS SEASONDESCR           /* 시즌명*/    ,
		    MS_SKU.SEASONOUT                           AS SEASONOUT             /* 시즌아웃정보*/    ,
		    MS_SKU.STYLECODE                           AS STYLECODE             /* 스타일코드 없을경우 SKU코드*/    ,
		    MS_SKU.STYLEDESCR                          AS STYLEDESCR            /* 스타일명*/    ,
		    MS_SKU.COLORCODE                           AS COLORCODE             /* 컬러코드 없을경우 SKU코드*/    ,
		    MS_SKU.COLORDESCR                          AS COLORDESCR            /* 컬러명*/    ,
		    MS_SKU.SIZECODE                            AS RICE_YN              /* 사이즈코드 없을경우 SKU코드=> 미곡여부로 변경*/    ,
		    MS_SKU.SIZEDESCR                           AS SIZEDESCR             /* 사이즈명*/    ,
		    MS_SKU.VENDOR                              AS VENDOR                /* 판매업체코드 없을경우 고객사코드*/        ,
		    '['||MS_SKU.PLACEOFORIGIN||']'||(SELECT
		        BASEDESCR 
		    FROM
		        CM_CODE 
		    WHERE
		        STORERKEY=MS_SKU.STORERKEY 
		        AND CM_CODE.CODELIST = 'COUNTRY' 
		        AND BASECODE=MS_SKU.PLACEOFORIGIN 
		        AND DEL_YN='N') AS PLACEOFORIGIN         /* 원산지명*/        ,
		    '['||MS_SKU.COUNTRYOFORIGIN||']'||(SELECT
		        BASEDESCR 
		    FROM
		        CM_CODE 
		    WHERE
		        STORERKEY=MS_SKU.STORERKEY 
		        AND CM_CODE.CODELIST = 'COUNTRY' 
		        AND BASECODE=MS_SKU.COUNTRYOFORIGIN 
		        AND DEL_YN='N') AS COUNTRYOFORIGIN         /* 원산국명*/    ,
		    MS_SKU.POMDCODE                            AS POMDCODE              /* 구매담당코드*/    ,
		    MS_SKU.POMDNAME                            AS POMDNAME              /* 구매담당명*/    ,
		    MS_SKU.SOMDCODE                            AS SOMDCODE              /* 판매담당코드*/    ,
		    MS_SKU.SOMDNAME                            AS SOMDNAME              /* 판매담당명*/    ,
		    MS_SKU.PLANTCUSTKEY                        AS PLANTCUSTKEY          /* 생산업체코드 없을경우 고객사코드*/    ,
		    MS_SKU.IMPORTCUSTKEY                       AS IMPORTCUSTKEY         /* 수입업체코드 없을경우 고객사코드*/    ,
		    MS_SKU.DISTRIBUTIONCUSTKEY                 AS DISTRIBUTIONCUSTKEY   /* 유통업체코드  없을경우 고객사코드*/    ,
		    MS_SKU.RETURNCUSTKEY                       AS RETURNCUSTKEY         /* 반품업체코드  없을경우 고객사코드*/    ,
		    MS_SKU.DISUSECUSTKEY                       AS DISUSECUSTKEY         /* 폐기업체코드  없을경우 고객사코드*/    ,
		    MS_SKU.SKUOPTIONS                          AS SKUOPTIONS            /* 상품옵션(비표등)*/    ,
		    MS_SKU.DURATION                            AS DURATION              /* 유통기간*/    ,
		    MS_SKU.BASEUOM                             AS BASEUOM               /* 기본 단위*/    ,
		    MS_SKU.PURCHASEUOM                         AS PURCHASEUOM           /* 구매 단위*/    ,
		    MS_SKU.SALESUOM                            AS SALESUOM              /* 판매 단위*/    ,
		    MS_SKU.RETURNUOM                           AS RETURNUOM             /* 회수 돤위*/    ,
		    MS_SKU.BOXPERPLT                           AS BOXPERPLT             /* 팔렛당 박스수*/    ,
		    MS_SKU.QTYPERBOX                           AS QTYPERBOX             /* 박스당 낱개수*/    ,
		    MS_SKU.PACKPERBOX                          AS PACKPERBOX            /* 박스당 팩수*/    ,
		    MS_SKU.QTYPERPACK                          AS QTYPERPACK            /* 팩당 낱개수*/    ,
		    MS_SKU.BOXPERLAYER                         AS BOXPERLAYER           /* 적재단당박스수*/    ,
		    MS_SKU.LAYERPERPLT                         AS LAYERPERPLT           /* 팔렛당적재단수*/    ,
		    MS_SKU.GROSSWEIGHT                         AS GROSSWEIGHT           /* 개당 총중량 Kg*/    ,
		    MS_SKU.NETWEIGHT                           AS NETWEIGHT             /* 개당 실중량 Kg*/    ,
		    MS_SKU.CUBE                                AS CUBE                  /* 상품 체적 cm^3 1CBM-1000000*/    ,
		    MS_SKU.CUBEDESCR                           AS CUBEDESCR             /* 상품 체적 설명 길이(Length)-너비(Width)-높이(Height) 단위 mm*/    ,
		    0                  AS CUBEDESCR1           /* 상품 체적 설명(장) */       ,
		    0                              AS CUBEDESCR2           /* 상품 체적 설명(폭) */       ,
		    0                                 AS CUBEDESCR3           /* 상품 체적 설명(고) */    ,
		    MS_SKU.MINTEMPERATURE                      AS MINTEMPERATURE        /* 관리온도최저값(섭씨)*/    ,
		    MS_SKU.MAXTEMPERATURE                      AS MAXTEMPERATURE        /* 관리온도최대값(섭씨)*/    ,
		    MS_SKU.PURCHASETYPE                        AS PURCHASETYPE          /* 구매유형*/    ,
		    MS_SKU.PURCHASEPRICE                       AS PURCHASEPRICE         /* 구매단가*/    ,
		    MS_SKU.PACKBOXTYPE                         AS PACKBOXTYPE           /* 포장박스유형*/    ,
		    MS_SKU.QCTYPE                              AS QCTYPE                /* QC유형*/    ,
		    MS_SKU.INSPECTTYPE                         AS INSPECTTYPE           /* 검수유형*/    ,
		    MS_SKU.BOMTYPE                             AS BOMTYPE               /* FG-완성품 MTL-구성품 및 일반 PKG-팩키지상품*/    ,
		    MS_SKU.SERIALTYPE                          AS SERIALTYPE            /* 시리얼타입*/    ,
		    MS_SKU.SERIALYN                            AS SERIALYN              /* 시리얼관리여부*/    ,
		    MS_SKU.MIXBOXYN                            AS MIXBOXYN              /* 합포장가능여부*/    ,
		    MS_SKU.ABC                                 AS ABC                   /* ABC*/    ,
		    MS_SKU.LINE01                              AS LINE01                /* 제품 생산라인1*/    ,
		    MS_SKU.LINE02                              AS LINE02                /* 제품 생산라인2*/    ,
		    MS_SKU.LINE03                              AS LINE03                /* 제품 생산라인3*/    ,
		    MS_SKU.POSTRATEGY                          AS POSTRATEGY            /* 구매전략*/    ,
		    MS_SKU.SOSTRATEGY                          AS SOSTRATEGY            /* 판매전략*/    ,
		    MS_SKU.ROSTRATEGY                          AS ROSTRATEGY            /* 반품전략*/    ,
		    MS_SKU.INSTRATEGY                          AS INSTRATEGY            /* 입고전략*/    ,
		    MS_SKU.PASTRATEGY                          AS PASTRATEGY            /* 적치전략*/    ,
		    MS_SKU.KEEPSTRATEGY                        AS KEEPSTRATEGY          /* 보관전략*/    ,
		    MS_SKU.FIFOSTRATEGY                        AS FIFOSTRATEGY          /* FIFO전략*/    ,
		    MS_SKU.DISASSEMSTRATEGY                    AS DISASSEMSTRATEGY      /* 해체전략*/    ,
		    MS_SKU.OUTSTRATEGY                         AS OUTSTRATEGY           /* 출고전략*/    ,
		    MS_SKU.RETURNSTRATEGY                      AS RETURNSTRATEGY        /* 회수전략*/    ,
		    MS_SKU.PACKSTRATEGY                        AS PACKSTRATEGY          /* 패킹전략*/    ,
		    MS_SKU.STOCKSTRATEGY                       AS STOCKSTRATEGY         /* 재고전략*/    ,
		    MS_SKU.ADJUSTSTRATEGY                      AS ADJUSTSTRATEGY        /* 조정전략*/    ,
		    MS_SKU.HOLDSTRATEGY                        AS HOLDSTRATEGY          /* 보류전략*/    ,
		    MS_SKU.DISUSESTRATEGY                      AS DISUSESTRATEGY        /* 폐기전략*/    ,
		    MS_SKU.HANDLESTRATEGY                      AS HANDLESTRATEGY        /* 취급전략*/    ,
		    MS_SKU.OTHER01                             AS OTHER01               /* 기타정보1*/    ,
		    MS_SKU.OTHER02                             AS OTHER02               /* 기타정보2*/    ,
		    MS_SKU.OTHER03                             AS OTHER03               /* 기타정보3*/    ,
		    MS_SKU.OTHER04                             AS OTHER04               /* 기타정보4*/    ,
		    MS_SKU.OTHER05                             AS OTHER05               /* 기타정보5*/    ,
		    MS_SKU.REFERENCE01                         AS REFERENCE01           /* 참조정보1*/    ,
		    MS_SKU.REFERENCE02                         AS REFERENCE02           /* 참조정보2*/    ,
		    MS_SKU.REFERENCE03                         AS REFERENCE03           /* 참조정보3*/    ,
		    MS_SKU.REFERENCE04                         AS REFERENCE04           /* 참조정보4*/    ,
		    MS_SKU.REFERENCE05                         AS REFERENCE05           /* 참조정보5*/    ,
		    MS_SKU.IMAGEURL1                           AS IMAGEURL1             /* 관련이미지URL1*/    ,
		    MS_SKU.IMAGEURL2                           AS IMAGEURL2             /* 관련이미지URL2*/    ,
		    MS_SKU.IMAGEURL3                           AS IMAGEURL3             /* 관련이미지URL3*/    ,
		    MS_SKU.IMAGEURL4                           AS IMAGEURL4             /* 관련이미지URL4*/    ,
		    MS_SKU.IMAGEURL5                           AS IMAGEURL5             /* 관련이미지URL5*/    ,
		    MS_SKU.IFFILENAME                          AS IFFILENAME            /* 인터페이스파일명*/    ,
		    MS_SKU.STATUS                              AS STATUS                /* 상태*/    ,
		    MS_SKU.DEL_YN                              AS DEL_YN                /* 삭제여부*/    ,
		    MS_SKU.TRAFFICCOP                          AS TRAFFICCOP            /* 데이터흐름제어*/    ,
		    MS_SKU.ARCHIVECOP                          AS ARCHIVECOP            /* 아카이브제어*/    ,
		    NVL(USER1.USER_NM, MS_SKU.ADDWHO)          AS ADDWHO                /* 최초등록자*/    ,
		    NVL(USER2.USER_NM, MS_SKU.EDITWHO)         AS EDITWHO               /* 최종변경자*/    ,
		    MS_SKU.DURATIONTYPE                        AS DURATIONTYPE          /* 유통기한관리방법*/               ,
		    TO_CHAR(MS_SKU.ADDDATE,
		    'yyyymmddhh24miss')     AS ADDDATE      /* 최초등록시간 */               ,
		    TO_CHAR(MS_SKU.EDITDATE,
		    'yyyymmddhh24miss')    AS EDITDATE      /* 최종변경시간 */               ,
		    MS_SKU.LABELTYPE             ,
		    SKUSPEC1.SPECDESCR     AS SKU_DDESC                                  ,
		    SKUSPEC2.SPECDESCR     AS SKU_SDESC                                  ,
		    SKUSPEC3.SPECDESCR     AS SKU_MDESC                                  ,
		    SKUSPEC4.SPECDESCR     AS SKU_LDESC
		FROM
		    MS_SKU         
		JOIN CM_USER_AUTHORITY_STORER     ON CM_USER_AUTHORITY_STORER.STORERKEY = MS_SKU.STORERKEY AND CM_USER_AUTHORITY_STORER.USERID = #{gUserId} /**P*/
		LEFT JOIN MS_SKUSPEC SKUSPEC1 	  ON SKUSPEC1.STORERKEY = MS_SKU.STORERKEY AND SKUSPEC1.SPECCATEGORY = 'SKUGROUP' AND SKUSPEC1.SPECCODE   = MS_SKU.SKUGROUP
		LEFT JOIN MS_SKUSPEC SKUSPEC2 	  ON SKUSPEC2.STORERKEY = MS_SKU.STORERKEY AND SKUSPEC2.SPECCATEGORY = 'SKUGROUP' AND SKUSPEC2.SPECCODE   = LEFT(MS_SKU.SKUGROUP, 6)
		LEFT JOIN MS_SKUSPEC SKUSPEC3 	  ON SKUSPEC3.STORERKEY = MS_SKU.STORERKEY AND SKUSPEC3.SPECCATEGORY = 'SKUGROUP' AND SKUSPEC3.SPECCODE   = LEFT(MS_SKU.SKUGROUP, 4)
		LEFT JOIN MS_SKUSPEC SKUSPEC4 	  ON SKUSPEC4.STORERKEY = MS_SKU.STORERKEY AND SKUSPEC4.SPECCATEGORY = 'SKUGROUP' AND SKUSPEC4.SPECCODE   = LEFT(MS_SKU.SKUGROUP, 2)
		LEFT JOIN FRAMEONE_USER USER1 ON USER1.USER_ID = MS_SKU.ADDWHO   /*등록자명*/
        LEFT JOIN FRAMEONE_USER USER2 ON USER2.USER_ID = MS_SKU.EDITWHO  /*수정자명*/
		WHERE
		    1=1    
		    AND    MS_SKU.STORERKEY    =  #{gStorerkey} /**P*/   
		    AND    MS_SKU.SKU          =  #{sku} /**P*/ 
	</select>
	
	<!-- CBM 조회(목록) -->
	<select id="getCbmList" resultType="MsSkuCbmResDto">
        SELECT  /* [msSkuService.sqlx][msSkuService.getCbmList][CBM 조회(목록)][jangjaehyun][20250618] */
		    MS_UOM.SERIALKEY                           AS SERIALKEY             /* 테이블시리얼번호*/      ,
		    MS_UOM.STORERKEY                           AS STORERKEY             /* 고객사코드*/      ,
		    MS_UOM.SKU                                 AS SKU                   /* 상품코드*/      ,
		    MS_UOM.BASEUOM                             AS BASEUOM               /* 기본UOM*/      ,
		    MS_UOM.UOM                                 AS UOM                   /* BUNJAUOM 코드*/      ,
		    MS_UOM.BUNJA                               AS BUNJA                 /* BUNMO UOM에 내입된 수량*/      ,
		    MS_UOM.BUNMO                               AS BUNMO                 /* BASE UOM에 내입된 수량 대부분 BASEUOM 이므로 1이다 */      ,
		    MS_UOM.CONVERTVAL                          AS CONVERTVAL            /* BUNJA/BUNMO 자동계산됨*/      ,
		    MS_UOM.CONVERTQTY                          AS CONVERTQTY            /* UOM이가지고 있는 낱개수량*/      ,
		    MS_UOM.GROSSWEIGHT                         AS GROSSWEIGHT           /* 총중량 1Kg*/      ,
		    MS_UOM.NETWEIGHT                           AS NETWEIGHT             /* 실중량 1Kg*/      ,
		    MS_UOM.CUBE                                AS CUBE                  /* 상품 체적 cm^3 1CBM:1000000*/      ,
		    MS_UOM.CUBEDESCR                           AS CUBEDESCR             /* 상품 체적 설명 길이(Length)-너비(Width)-높이(Height) 단위 mm*/      ,
		    MS_UOM.BARCODE1                            AS BARCODE1              /* UOM에 해당하는 바코드*/      ,
		    MS_UOM.BARCODE2                            AS BARCODE2              /* UOM에 해당하는 바코드*/      ,
		    MS_UOM.BARCODE3                            AS BARCODE3              /* UOM에 해당하는 바코드*/      ,
		    MS_UOM.VESSEL                              AS VESSEL                /* 포장용기코드*/      ,
		    MS_UOM.STATUS                              AS STATUS                /* 상태*/      ,
		    MS_UOM.DEFAULT_YN                          AS DEFAULT_YN            /* 기본값여부*/      ,
		    MS_UOM.DEL_YN                              AS DEL_YN                /* 삭제여부*/      ,
		    MS_UOM.TRAFFICCOP                          AS TRAFFICCOP            /* 데이터흐름제어*/      ,
		    MS_UOM.ARCHIVECOP                          AS ARCHIVECOP            /* 아카이브제어*/      ,
		    MS_UOM.ADDDATE                             AS ADDDATE               /* 최초등록시간*/      ,
		    MS_UOM.EDITDATE                            AS EDITDATE              /* 최종변경시간*/      ,
		    MS_UOM.ADDWHO                              AS ADDWHO                /* 최초등록자*/      ,
		    MS_UOM.EDITWHO                             AS EDITWHO               /* 최종변경자*/           ,
		    NVL(MS_UOM.LENGTH, 0)                      AS LENGTH                /* 상품 체적 설명(장) */   ,
		    NVL(MS_UOM.WIDTH, 0)                       AS WIDTH                 /* 상품 체적 설명(폭) */   ,
		    NVL(MS_UOM.HEIGHT, 0)                      AS HEIGHT                /* 상품 체적 설명(고) */     
		FROM
		    MS_UOM      
		WHERE
		    STORERKEY =  #{gStorerkey} /**P*/       
		    AND SKU =   #{sku} /**P*/
    </select>
    
    <!-- 상품 팔렛트 단수 UPDATE(목록) -->
    <update id="updateMsSkuPlt">
		UPDATE	/* [msSkuService.sqlx][msSkuService.updateMsSkuPlt][상품 팔렛트 단수 UPDATE(목록)][jangjaehyun][20250618] */
			MS_SKU
		SET   LAYERPERPLT = #{layerPerPlt}
		     ,BOXPERPLT   = #{boxPerPlt}
		     ,BOXPERLAYER = #{boxPerLayer}
		     ,EDITDATE	  = SYSDATE
		     ,EDITWHO	  = #{gUserId}
		WHERE SERIALKEY   = #{serialKey}
	</update>
    
    <!-- 상품 정보 INSERT -->
    <insert id="insertMaster">
		INSERT	/* [msSkuService.sqlx][msSkuService.insertMaster][상품 정보 INSERT][jangjaehyun][20250611] */ 
			INTO MS_SKU
		  (DCCODE
		  ,ZONE
		  ,DESCRIPTION
		  ,INSTRATEGY
		  ,OUTSTRATEGY
		  ,STORAGETYPE
		  ,ZONE_GUGAN
		  ,ADDWHO
		  ,EDITWHO)
		VALUES
		  (#{dccode}
		  ,UPPER(#{zone})
		  ,#{description}
		  ,NVL(#{instrategy},'STD')
		  ,NVL(#{outstrategy},'STD')
		  ,#{storagetype}
		  ,#{zoneGugan}
		  ,#{gUserId}
		  ,#{gUserId})
    </insert>
    
    <!-- 상품 정보 UPDATE -->
    <update id="updateMaster">
		UPDATE	/* [msSkuService.sqlx][msSkuService.updateMaster][상품 정보 UPDATE][jangjaehyun][20250611] */
			MS_SKU
		   SET BOXPERPLT	   = #{boxPerLayer},		       
		       LABELTYPE	   = #{labelType},
		       LAYERPERPLT     = #{layerPerPlt},
		       BOXPERLAYER     = #{boxPerPlt},
		       SIZECODE        = #{riceYn},
		       GROSSWEIGHT     = #{grossWeight},
		       REFERENCE01     = #{reference01},
		       QTYPERBOX	   = #{qtyPerBox},
		       EDITDATE        = SYSDATE,
		       EDITWHO         = #{gUserId}		       
		WHERE SERIALKEY = #{serialKey}
	</update>
	
	<select id="update" statementType="CALLABLE" resultType="HMAP">
		<![CDATA[
        {
	        CALL  /* [msSkuService.sqlx][update][상품 정보 UPDATE][jangjaehyun][20250717] */
	        DECLARE
                V_AFTER     MS_SKU%rowtype;
                O_SUCCESS   NUMBER         :=  1;      /* 성공여부(1이면 성공) */
                O_ERRCODE   NUMBER         :=  0;      /* 오류 코드 */
                O_ERRMSG    VARCHAR2(4000) := '';      /* 오류 메세지 */
            BEGIN
                FOR KEY_LIST IN (
                    SELECT
                            SERIALKEY  /* 데이터번호 */
                    FROM    MS_SKU
                    WHERE   SERIALKEY = #{serialKey}
                )
                LOOP
                    BEGIN
                        SELECT  *
                        INTO    V_AFTER
                        FROM    MS_SKU
                        WHERE   SERIALKEY = KEY_LIST.SERIALKEY
                       ;
    
                       V_AFTER.BOXPERPLT       := #{boxPerPlt};
                       V_AFTER.LAYERPERPLT     := #{layerPerPlt};
                       V_AFTER.BOXPERLAYER     := #{boxPerLayer};
                       V_AFTER.SIZECODE        := #{riceYn};
                       V_AFTER.GROSSWEIGHT     := #{grossWeight};
                       V_AFTER.REFERENCE01     := #{reference01};
                       V_AFTER.QTYPERBOX       := #{qtyPerBox};
                       V_AFTER.STYLECODE       := #{styleCode};
                       V_AFTER.LABELTYPE       := #{labelType};
                       V_AFTER.EDITDATE        := SYSDATE;
                       V_AFTER.EDITWHO         := #{gUserId};
    
                       -- 프로시저 호출
                       TRMS_SKU.TR_UPDATE(
                                V_AFTER
                            ,   O_SUCCESS
                            ,   O_ERRCODE
                            ,   O_ERRMSG
                        );
    
                        EXIT    WHEN O_SUCCESS < 1;
    
                    END;
                END    LOOP;
    
                #{success, mode=OUT, jdbcType=INTEGER, javaType=int}    :=  O_SUCCESS;
                #{err, mode=OUT, jdbcType=INTEGER, javaType=int}        :=  O_ERRCODE;
                #{errmsg, mode=OUT, jdbcType=VARCHAR, javaType=String}  :=  O_ERRMSG;
    
            END
        }
        ]]>
    </select>
    
    <select id="updatePlt" statementType="CALLABLE" resultType="HMAP">
		<![CDATA[
        {
	        CALL  /* [msSkuService.sqlx][updatePlt][상품 정보 UPDATE][jangjaehyun][20250717] */
	        DECLARE
                V_AFTER     MS_SKU%rowtype;
                O_SUCCESS   NUMBER         :=  1;      /* 성공여부(1이면 성공) */
                O_ERRCODE   NUMBER         :=  0;      /* 오류 코드 */
                O_ERRMSG    VARCHAR2(4000) := '';      /* 오류 메세지 */
            BEGIN
                FOR KEY_LIST IN (
                    SELECT
                            SERIALKEY  /* 데이터번호 */
                    FROM    MS_SKU
                    WHERE   SERIALKEY = #{serialKey}
                )
                LOOP
                    BEGIN
                        SELECT  *
                        INTO    V_AFTER
                        FROM    MS_SKU
                        WHERE   SERIALKEY = KEY_LIST.SERIALKEY
                       ;
    
                       V_AFTER.BOXPERPLT       := #{boxPerLayer};
                       V_AFTER.LAYERPERPLT     := #{layerPerPlt};
                       V_AFTER.BOXPERLAYER     := #{boxPerPlt};
                       V_AFTER.EDITDATE        := SYSDATE;
                       V_AFTER.EDITWHO         := #{gUserId};                       
    
                       -- 프로시저 호출
                       TRMS_SKU.TR_UPDATE(
                                V_AFTER
                            ,   O_SUCCESS
                            ,   O_ERRCODE
                            ,   O_ERRMSG
                        );
    
                        EXIT    WHEN O_SUCCESS < 1;
    
                    END;
                END    LOOP;
    
                #{success, mode=OUT, jdbcType=INTEGER, javaType=int}    :=  O_SUCCESS;
                #{err, mode=OUT, jdbcType=INTEGER, javaType=int}        :=  O_ERRCODE;
                #{errmsg, mode=OUT, jdbcType=VARCHAR, javaType=String}  :=  O_ERRMSG;
    
            END
        }
        ]]>
    </select>
	
	<!-- CBM UPDATE(목록) -->
    <update id="updateCbm">
		UPDATE	/* [msSkuService.sqlx][msSkuService.updateCbm][CBM UPDATE(목록)][jangjaehyun][20250618] */
			MS_UOM
		SET   LENGTH = #{length}
		     ,WIDTH   = #{width}
		     ,HEIGHT = #{height}
		     ,GROSSWEIGHT = #{grossWeight}
		     ,NETWEIGHT = #{netWeight}
		     ,CUBE = #{cube}
		     ,CUBEDESCR = #{cubeDescr}
		     ,EDITDATE	  = SYSDATE
		     ,EDITWHO	  = #{gUserId}
		WHERE SERIALKEY   = #{serialKey}
	</update>
	
	<!-- 엑셀업로드 UPDATE(목록) -->
    <update id="updateExcelList">
		UPDATE	/* [msSkuService.sqlx][msSkuService.updateExcelList][엑셀업로드 UPDATE(목록)][jangjaehyun][20250723] */
			MS_SKU
		SET   LAYERPERPLT = #{layerPerPlt}
		     ,BOXPERPLT   = #{boxPerPlt}
		     ,BOXPERLAYER = #{boxPerLayer}
		     ,EDITDATE	  = SYSDATE
		     ,EDITWHO	  = #{gUserId}
		WHERE SKU   = #{sku}
	</update>
	
	<!-- 엑셀업로드 유효성체크-->
	<select id="getValidateExcelList" resultType="MsSkuResDto">
		SELECT  /* [MsSkuService.sqlx][MsSkuService.getValidateExcelList][엑셀 업로드 유효성 체크][jangjaehyun][20251202] */
	  		 #{sku} 												AS SKU
	  		,(SELECT CASE WHEN COUNT(1) > 0 THEN 'Y' ELSE 'N' END
				FROM   MS_SKU
				WHERE  MS_SKU.STORERKEY 	= #{gStorerkey}  
				AND	   MS_SKU.SKU 		    = #{sku})	AS PROCESS_YN
		FROM   DUAL
    </select>
    
</mapper>